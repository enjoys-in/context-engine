{
  "base": "hc-light",
  "inherit": false,
  "rules": [
    {
      "token": "",
      "foreground": "292929",
      "background": "ffffff"
    },
    {
      "token": "comment",
      "foreground": "515151"
    },
    {
      "token": "keyword",
      "foreground": "0f4a85"
    },
    {
      "token": "string",
      "foreground": "0f4a85"
    },
    {
      "token": "number",
      "foreground": "096d48"
    },
    {
      "token": "regexp",
      "foreground": "811f3f"
    },
    {
      "token": "type",
      "foreground": "185e73"
    },
    {
      "token": "class",
      "foreground": "185e73"
    },
    {
      "token": "function",
      "foreground": "5e2cbc"
    },
    {
      "token": "variable",
      "foreground": "292929"
    },
    {
      "token": "constant",
      "foreground": "096d48"
    },
    {
      "token": "tag",
      "foreground": "0f4a85"
    },
    {
      "token": "attribute.name",
      "foreground": "292929"
    },
    {
      "token": "attribute.value",
      "foreground": "0f4a85"
    },
    {
      "token": "operator",
      "foreground": "292929"
    },
    {
      "token": "delimiter",
      "foreground": "292929"
    },
    {
      "token": "annotation",
      "foreground": "5e2cbc"
    },
    {
      "token": "invalid",
      "foreground": "b5200d",
      "fontStyle": "bold underline"
    },
    {
      "token": "identifier",
      "foreground": "292929"
    },
    {
      "token": "decorator",
      "foreground": "5e2cbc"
    },
    {
      "token": "namespace",
      "foreground": "185e73"
    },
    {
      "token": "enum",
      "foreground": "185e73"
    },
    {
      "token": "struct",
      "foreground": "185e73"
    },
    {
      "token": "interface",
      "foreground": "185e73"
    },
    {
      "token": "typeParameter",
      "foreground": "185e73"
    },
    {
      "token": "property",
      "foreground": "292929"
    },
    {
      "token": "enumMember",
      "foreground": "096d48"
    },
    {
      "token": "method",
      "foreground": "5e2cbc"
    }
  ],
  "colors": {
    "editor.foreground": "#292929",
    "editor.background": "#ffffff",
    "editor.selectionBackground": "#0f4a85",
    "editor.lineHighlightBackground": "#f5f5f5",
    "editorCursor.foreground": "#292929",
    "editorWhitespace.foreground": "#7c7c7c",
    "editorIndentGuide.background": "#7c7c7c",
    "editorIndentGuide.activeBackground": "#292929",
    "editor.selectionHighlightBackground": "#add6ff80",
    "editor.findMatchBackground": "#a8ac94",
    "editor.findMatchHighlightBackground": "#ea5c0055",
    "editorBracketMatch.background": "#0064001a",
    "editorBracketMatch.border": "#292929",
    "contrastBorder": "#0f4a85",
    "contrastActiveBorder": "#b5200d",
    "editorOverviewRuler.border": "#0f4a85",
    "editorGutter.background": "#ffffff",
    "editorLineNumber.foreground": "#292929",
    "editorLineNumber.activeForeground": "#292929",
    "focusBorder": "#006bbd",
    "minimap.selectionHighlight": "#0f4a85"
  }
}
