{
  "base": "vs",
  "inherit": false,
  "rules": [
    {
      "token": "",
      "foreground": "000000",
      "background": "fffffe"
    },
    {
      "token": "comment",
      "foreground": "008000"
    },
    {
      "token": "keyword",
      "foreground": "0000ff"
    },
    {
      "token": "string",
      "foreground": "a31515"
    },
    {
      "token": "number",
      "foreground": "098658"
    },
    {
      "token": "regexp",
      "foreground": "811f3f"
    },
    {
      "token": "type",
      "foreground": "267f99"
    },
    {
      "token": "class",
      "foreground": "267f99"
    },
    {
      "token": "function",
      "foreground": "795e26"
    },
    {
      "token": "variable",
      "foreground": "001080"
    },
    {
      "token": "variable.predefined",
      "foreground": "4864aa"
    },
    {
      "token": "constant",
      "foreground": "098658"
    },
    {
      "token": "tag",
      "foreground": "800000"
    },
    {
      "token": "attribute.name",
      "foreground": "ff0000"
    },
    {
      "token": "attribute.value",
      "foreground": "0451a5"
    },
    {
      "token": "string.key.json",
      "foreground": "0451a5"
    },
    {
      "token": "string.value.json",
      "foreground": "a31515"
    },
    {
      "token": "operator",
      "foreground": "000000"
    },
    {
      "token": "delimiter",
      "foreground": "000000"
    },
    {
      "token": "delimiter.html",
      "foreground": "383838"
    },
    {
      "token": "delimiter.xml",
      "foreground": "0000ff"
    },
    {
      "token": "metatag",
      "foreground": "0000ff"
    },
    {
      "token": "metatag.content.html",
      "foreground": "ff0000"
    },
    {
      "token": "metatag.html",
      "foreground": "808080"
    },
    {
      "token": "metatag.xml",
      "foreground": "808080"
    },
    {
      "token": "key",
      "foreground": "863b00"
    },
    {
      "token": "annotation",
      "foreground": "808000"
    },
    {
      "token": "invalid",
      "foreground": "cd3131"
    },
    {
      "token": "identifier",
      "foreground": "001080"
    },
    {
      "token": "decorator",
      "foreground": "795e26"
    },
    {
      "token": "macro",
      "foreground": "795e26"
    },
    {
      "token": "namespace",
      "foreground": "267f99"
    },
    {
      "token": "enum",
      "foreground": "267f99"
    },
    {
      "token": "struct",
      "foreground": "267f99"
    },
    {
      "token": "interface",
      "foreground": "267f99"
    },
    {
      "token": "typeParameter",
      "foreground": "267f99"
    },
    {
      "token": "parameter",
      "foreground": "001080"
    },
    {
      "token": "property",
      "foreground": "001080"
    },
    {
      "token": "enumMember",
      "foreground": "0070c1"
    },
    {
      "token": "event",
      "foreground": "001080"
    },
    {
      "token": "method",
      "foreground": "795e26"
    }
