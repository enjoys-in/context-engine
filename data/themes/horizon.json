{
  "inherit": true,
  "base": "vs-dark",
  "colors": {
    "editor.background": "#1c1e26",
    "editor.foreground": "#d5d8da",
    "editor.lineHighlightBackground": "#232530",
    "editor.selectionBackground": "#2e303e",
    "editor.selectionHighlightBackground": "#2e303e88",
    "editor.inactiveSelectionBackground": "#2e303e66",
    "editor.findMatchBackground": "#e9567844",
    "editor.findMatchHighlightBackground": "#e9567833",
    "editor.wordHighlightBackground": "#25b0bc33",
    "editor.wordHighlightStrongBackground": "#25b0bc55",
    "editorCursor.foreground": "#e95678",
    "editorWhitespace.foreground": "#6c6f9344",
    "editorIndentGuide.background": "#6c6f9333",
    "editorIndentGuide.activeBackground": "#6c6f9366",
    "editorLineNumber.foreground": "#6c6f93",
    "editorLineNumber.activeForeground": "#d5d8da",
    "editorBracketMatch.background": "#25b0bc22",
    "editorBracketMatch.border": "#25b0bc88",
    "editorOverviewRuler.border": "#1c1e26",
    "editorRuler.foreground": "#6c6f9333",
    "editorGutter.background": "#1c1e26",
    "editorError.foreground": "#e95678",
    "editorWarning.foreground": "#fab795",
    "editorInfo.foreground": "#25b0bc",
    "editorHint.foreground": "#b877db",
    "editorWidget.background": "#1c1e26",
    "editorWidget.border": "#2e303e",
    "editorSuggestWidget.background": "#1c1e26",
    "editorSuggestWidget.border": "#2e303e",
    "editorSuggestWidget.selectedBackground": "#2e303e",
    "editorSuggestWidget.highlightForeground": "#25b0bc",
    "editorHoverWidget.background": "#1c1e26",
    "editorHoverWidget.border": "#2e303e",
    "editorGroup.border": "#2e303e",
    "editorGroupHeader.tabsBackground": "#1c1e26",
    "tab.activeBackground": "#232530",
    "tab.inactiveBackground": "#1c1e26",
    "tab.activeForeground": "#d5d8da",
    "tab.inactiveForeground": "#6c6f93",
    "tab.border": "#1c1e26",
    "minimap.background": "#1c1e26",
    "minimapGutter.addedBackground": "#25b0bc",
    "minimapGutter.modifiedBackground": "#fab795",
    "minimapGutter.deletedBackground": "#e95678",
    "scrollbar.shadow": "#00000044",
    "scrollbarSlider.background": "#6c6f9333",
    "scrollbarSlider.hoverBackground": "#6c6f9355",
    "scrollbarSlider.activeBackground": "#6c6f9377",
    "input.background": "#232530",
    "input.foreground": "#d5d8da",
    "input.border": "#2e303e",
    "input.placeholderForeground": "#6c6f93",
    "focusBorder": "#25b0bc66",
    "list.activeSelectionBackground": "#2e303e",
    "list.activeSelectionForeground": "#d5d8da",
    "list.hoverBackground": "#23253088",
    "list.highlightForeground": "#25b0bc",
    "badge.background": "#e95678",
    "badge.foreground": "#d5d8da"
