  "rules": [
    { "token": "", "foreground": "d5d8da" },
    { "token": "comment", "foreground": "6c6f93", "fontStyle": "italic" },
    { "token": "comment.line", "foreground": "6c6f93", "fontStyle": "italic" },
    { "token": "comment.block", "foreground": "6c6f93", "fontStyle": "italic" },
    { "token": "comment.block.documentation", "foreground": "6c6f93", "fontStyle": "italic" },

    { "token": "string", "foreground": "fab795" },
    { "token": "string.quoted", "foreground": "fab795" },
    { "token": "string.quoted.single", "foreground": "fab795" },
    { "token": "string.quoted.double", "foreground": "fab795" },
    { "token": "string.template", "foreground": "fab795" },
    { "token": "string.escape", "foreground": "f09383" },
    { "token": "string.regexp", "foreground": "e95678" },
    { "token": "string.interpolated", "foreground": "fab795" },

    { "token": "keyword", "foreground": "c678dd" },
    { "token": "keyword.control", "foreground": "c678dd" },
    { "token": "keyword.control.flow", "foreground": "c678dd" },
    { "token": "keyword.control.import", "foreground": "c678dd" },
    { "token": "keyword.operator", "foreground": "e95678" },
    { "token": "keyword.operator.assignment", "foreground": "e95678" },
    { "token": "keyword.operator.arithmetic", "foreground": "e95678" },
    { "token": "keyword.operator.logical", "foreground": "e95678" },
    { "token": "keyword.operator.new", "foreground": "c678dd" },
    { "token": "keyword.other", "foreground": "c678dd" },

    { "token": "identifier", "foreground": "d5d8da" },
    { "token": "variable", "foreground": "e95678" },
    { "token": "variable.predefined", "foreground": "e95678" },
    { "token": "variable.parameter", "foreground": "d5d8da" },
    { "token": "variable.other", "foreground": "e95678" },
    { "token": "variable.language", "foreground": "e95678", "fontStyle": "italic" },

    { "token": "type", "foreground": "fac29a" },
    { "token": "type.identifier", "foreground": "fac29a" },
    { "token": "type.primitive", "foreground": "fac29a" },

    { "token": "function", "foreground": "25b0bc" },
    { "token": "function.call", "foreground": "25b0bc" },
    { "token": "function.declaration", "foreground": "25b0bc" },
    { "token": "function.method", "foreground": "25b0bc" },

    { "token": "number", "foreground": "f09383" },
    { "token": "number.float", "foreground": "f09383" },
    { "token": "number.hex", "foreground": "f09383" },
    { "token": "number.octal", "foreground": "f09383" },
    { "token": "number.binary", "foreground": "f09383" },

    { "token": "operator", "foreground": "e95678" },
    { "token": "operator.assignment", "foreground": "e95678" },

    { "token": "constant", "foreground": "f09383" },
    { "token": "constant.numeric", "foreground": "f09383" },
    { "token": "constant.language", "foreground": "f09383" },
    { "token": "constant.character", "foreground": "f09383" },
    { "token": "constant.other", "foreground": "f09383" },

    { "token": "class", "foreground": "fac29a" },
    { "token": "class.name", "foreground": "fac29a" },

    { "token": "regexp", "foreground": "e95678" },
    { "token": "regexp.escape", "foreground": "f09383" },

    { "token": "storage", "foreground": "c678dd" },
    { "token": "storage.type", "foreground": "c678dd" },
    { "token": "storage.modifier", "foreground": "c678dd" },

    { "token": "support", "foreground": "25b0bc" },
    { "token": "support.function", "foreground": "25b0bc" },
    { "token": "support.class", "foreground": "fac29a" },
    { "token": "support.type", "foreground": "fac29a" },
    { "token": "support.variable", "foreground": "e95678" },
    { "token": "support.constant", "foreground": "f09383" },

    { "token": "entity", "foreground": "25b0bc" },
    { "token": "entity.name", "foreground": "25b0bc" },
    { "token": "entity.name.function", "foreground": "25b0bc" },
    { "token": "entity.name.type", "foreground": "fac29a" },
    { "token": "entity.name.class", "foreground": "fac29a" },
    { "token": "entity.name.tag", "foreground": "e95678" },
    { "token": "entity.other.attribute-name", "foreground": "fac29a" },
    { "token": "entity.other.inherited-class", "foreground": "fac29a", "fontStyle": "italic" },

    { "token": "meta", "foreground": "d5d8da" },
    { "token": "meta.brace", "foreground": "d5d8da" },
    { "token": "meta.delimiter", "foreground": "d5d8da" },
    { "token": "meta.tag", "foreground": "e95678" },
    { "token": "meta.selector", "foreground": "c678dd" },

    { "token": "markup.heading", "foreground": "e95678", "fontStyle": "bold" },
    { "token": "markup.bold", "fontStyle": "bold" },
    { "token": "markup.italic", "fontStyle": "italic" },
    { "token": "markup.underline", "fontStyle": "underline" },
    { "token": "markup.strikethrough", "fontStyle": "strikethrough" },
    { "token": "markup.inline.raw", "foreground": "fab795" },
    { "token": "markup.list", "foreground": "e95678" },
    { "token": "markup.quote", "foreground": "6c6f93", "fontStyle": "italic" },
    { "token": "markup.link", "foreground": "25b0bc" },

    { "token": "tag", "foreground": "e95678" },
    { "token": "tag.id.pug", "foreground": "fac29a" },
    { "token": "tag.class.pug", "foreground": "fac29a" },

    { "token": "attribute.name", "foreground": "fac29a" },
    { "token": "attribute.value", "foreground": "fab795" },
    { "token": "attribute.value.html", "foreground": "fab795" },
    { "token": "attribute.value.xml", "foreground": "fab795" },

    { "token": "metatag", "foreground": "6c6f93" },
    { "token": "metatag.content.html", "foreground": "d5d8da" },
    { "token": "metatag.html", "foreground": "6c6f93" },
    { "token": "metatag.xml", "foreground": "6c6f93" },

    { "token": "delimiter", "foreground": "d5d8da" },
    { "token": "delimiter.bracket", "foreground": "d5d8da" },
    { "token": "delimiter.parenthesis", "foreground": "d5d8da" },
    { "token": "delimiter.square", "foreground": "d5d8da" },
    { "token": "delimiter.angle", "foreground": "d5d8da" },
    { "token": "delimiter.html", "foreground": "d5d8da" },
    { "token": "delimiter.xml", "foreground": "d5d8da" },

    { "token": "annotation", "foreground": "b877db" },
    { "token": "annotation.declaration", "foreground": "b877db" },
    { "token": "decorator", "foreground": "b877db" },

    { "token": "namespace", "foreground": "fac29a" },
    { "token": "interface", "foreground": "fac29a" },
    { "token": "enum", "foreground": "fac29a" },
    { "token": "enumMember", "foreground": "f09383" },
    { "token": "struct", "foreground": "fac29a" },
    { "token": "property", "foreground": "d5d8da" },
    { "token": "parameter", "foreground": "d5d8da" },
    { "token": "label", "foreground": "e95678" },
    { "token": "macro", "foreground": "b877db" },
    { "token": "event", "foreground": "25b0bc" },
    { "token": "typeParameter", "foreground": "fac29a" },

    { "token": "punctuation", "foreground": "d5d8da" },
    { "token": "punctuation.definition.tag", "foreground": "e95678" },
    { "token": "punctuation.definition.string", "foreground": "fab795" },
    { "token": "punctuation.definition.comment", "foreground": "6c6f93" },

    { "token": "invalid", "foreground": "e95678" },
    { "token": "invalid.illegal", "foreground": "e95678" },
    { "token": "invalid.deprecated", "foreground": "6c6f93", "fontStyle": "strikethrough" }
  ]
}
