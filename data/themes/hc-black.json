{
  "base": "hc-black",
  "inherit": false,
  "rules": [
    {
      "token": "",
      "foreground": "ffffff",
      "background": "000000"
    },
    {
      "token": "comment",
      "foreground": "7ca668"
    },
    {
      "token": "keyword",
      "foreground": "569cd6"
    },
    {
      "token": "string",
      "foreground": "ce9178"
    },
    {
      "token": "number",
      "foreground": "b5cea8"
    },
    {
      "token": "regexp",
      "foreground": "d16969"
    },
    {
      "token": "type",
      "foreground": "4ec9b0"
    },
    {
      "token": "class",
      "foreground": "4ec9b0"
    },
    {
      "token": "function",
      "foreground": "dcdcaa"
    },
    {
      "token": "variable",
      "foreground": "9cdcfe"
    },
    {
      "token": "constant",
      "foreground": "4fc1ff"
    },
    {
      "token": "tag",
      "foreground": "569cd6"
    },
    {
      "token": "attribute.name",
      "foreground": "9cdcfe"
    },
    {
      "token": "attribute.value",
      "foreground": "ce9178"
    },
    {
      "token": "operator",
      "foreground": "ffffff"
    },
    {
      "token": "delimiter",
      "foreground": "ffffff"
    },
    {
      "token": "annotation",
      "foreground": "dcdcaa"
    },
    {
      "token": "invalid",
      "foreground": "f44747",
      "fontStyle": "bold underline"
    },
    {
      "token": "identifier",
      "foreground": "9cdcfe"
    },
    {
      "token": "decorator",
      "foreground": "dcdcaa"
    },
    {
      "token": "namespace",
      "foreground": "4ec9b0"
    },
    {
      "token": "enum",
      "foreground": "4ec9b0"
    },
    {
      "token": "struct",
      "foreground": "4ec9b0"
    },
    {
      "token": "interface",
      "foreground": "4ec9b0"
    },
    {
      "token": "typeParameter",
      "foreground": "4ec9b0"
    },
    {
      "token": "property",
      "foreground": "9cdcfe"
    },
    {
      "token": "enumMember",
      "foreground": "4fc1ff"
    },
    {
      "token": "method",
      "foreground": "dcdcaa"
    }
  ],
  "colors": {
    "editor.foreground": "#ffffff",
    "editor.background": "#000000",
    "editor.selectionBackground": "#264f78",
    "editor.lineHighlightBackground": "#ffffff0a",
    "editorCursor.foreground": "#ffffff",
    "editorWhitespace.foreground": "#7c7c7c",
    "editorIndentGuide.background": "#7c7c7c",
    "editorIndentGuide.activeBackground": "#c0c0c0",
    "editor.selectionHighlightBackground": "#add6ff26",
    "editor.findMatchBackground": "#515c6a",
    "editor.findMatchHighlightBackground": "#ea5c0055",
    "editorBracketMatch.background": "#0064001a",
    "editorBracketMatch.border": "#ffffff",
    "contrastBorder": "#6fc3df",
    "contrastActiveBorder": "#f38518",
    "editorOverviewRuler.border": "#6fc3df",
    "editorGutter.background": "#000000",
    "editorLineNumber.foreground": "#ffffff",
    "editorLineNumber.activeForeground": "#ffffff",
    "focusBorder": "#f38518",
    "minimap.selectionHighlight": "#264f78"
  }
}
