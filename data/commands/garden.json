{
  "name": "garden",
  "description": "Garden — automate building, deploying, and testing Kubernetes apps",
  "category": "containers",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "deploy",
      "description": "Deploy actions/services",
      "examples": [
        "garden deploy",
        "garden deploy my-service",
        "garden deploy --force"
      ]
    },
    {
      "name": "dev",
      "description": "Start development mode",
      "examples": [
        "garden dev",
        "garden dev my-service"
      ]
    },
    {
      "name": "build",
      "description": "Build modules/actions",
      "examples": [
        "garden build",
        "garden build my-module"
      ]
    },
    {
      "name": "test",
      "description": "Run tests",
      "examples": [
        "garden test",
        "garden test my-module",
        "garden test --force"
      ]
    },
    {
      "name": "run",
      "description": "Run a one-off action",
      "examples": [
        "garden run my-task",
        "garden run my-task -- arg1 arg2"
      ]
    },
    {
      "name": "logs",
      "description": "View runtime logs",
      "examples": [
        "garden logs",
        "garden logs my-service",
        "garden logs --follow"
      ]
    },
    {
      "name": "exec",
      "description": "Execute command in container",
      "examples": [
        "garden exec my-service -- sh"
      ]
    },
    {
      "name": "get",
      "description": "Get info about resources",
      "examples": [
        "garden get status",
        "garden get outputs",
        "garden get actions",
        "garden get graph"
      ]
    },
    {
      "name": "cleanup",
      "description": "Clean up resources",
      "examples": [
        "garden cleanup namespace",
        "garden cleanup deploy"
      ]
    },
    {
      "name": "plugins",
      "description": "List/manage plugins",
      "examples": [
        "garden plugins",
        "garden plugins resolve-action my-action"
      ]
    },
    {
      "name": "login",
      "description": "Login to Garden Cloud",
      "examples": [
        "garden login"
      ]
    },
    {
      "name": "create",
      "description": "Create a project/module",
      "examples": [
        "garden create project"
      ]
    },
    {
      "name": "validate",
      "description": "Validate config",
      "examples": [
        "garden validate"
      ]
    },
    {
      "name": "util",
      "description": "Utility commands",
      "examples": [
        "garden util fetch-tools",
        "garden util profile-project"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--env",
      "short": "-e",
      "description": "Environment",
      "type": "string"
    },
    {
      "name": "--root",
      "description": "Project root",
      "type": "string"
    },
    {
      "name": "--logger-type",
      "description": "Logger type",
      "type": "string"
    },
    {
      "name": "--log-level",
      "short": "-l",
      "description": "Log level",
      "type": "string"
    },
    {
      "name": "--force-refresh",
      "description": "Force refresh of provider plugins"
    },
    {
      "name": "--var",
      "description": "Set variables",
      "type": "string"
    }
  ],
  "examples": [
    "garden deploy",
    "garden dev",
    "garden build",
    "garden test",
    "garden run my-task",
    "garden logs --follow",
    "garden get status",
    "garden validate"
  ],
  "relatedCommands": [
    "skaffold",
    "tilt",
    "devspace",
    "kubectl"
  ]
}
