{
  "language": "elixir",
  "name": "mix",
  "description": "Elixir command-line tool",
  "category": "development",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--help",
      "description": "Show help information"
    },
    {
      "name": "--version",
      "description": "Show version information"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    }
  ],
  "subcommands": [
    {
      "name": "new project_name",
      "description": "Create new Elixir project",
      "args": [],
      "options": []
    },
    {
      "name": "deps.get",
      "description": "Fetch dependencies",
      "args": [],
      "options": []
    },
    {
      "name": "compile",
      "description": "Compile project",
      "args": [],
      "options": []
    },
    {
      "name": "test",
      "description": "Run tests",
      "args": [],
      "options": []
    },
    {
      "name": "format",
      "description": "Format code",
      "args": [],
      "options": []
    },
    {
      "name": "phx.new app",
      "description": "Create Phoenix app",
      "args": [],
      "options": []
    },
    {
      "name": "phx.server",
      "description": "Start Phoenix server",
      "args": [],
      "options": []
    },
    {
      "name": "ecto.create",
      "description": "Create database",
      "args": [],
      "options": []
    },
    {
      "name": "ecto.migrate",
      "description": "Run migrations",
      "args": [],
      "options": []
    }
  ],
  "examples": [
    {
      "command": "mix new my_app",
      "description": "Create new Elixir project"
    },
    {
      "command": "mix deps.get",
      "description": "Fetch dependencies"
    },
    {
      "command": "mix test",
      "description": "Run tests"
    },
    {
      "command": "mix phx.server",
      "description": "Start Phoenix server"
    },
    {
      "command": "iex -S mix",
      "description": "Start interactive shell with project loaded"
    }
  ],
  "relatedCommands": []
}
