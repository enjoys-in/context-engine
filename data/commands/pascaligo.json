{
  "language": "pascaligo",
  "name": "ligo",
  "description": "LIGO — PascaLIGO smart contract language for Tezos",
  "category": "language",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--entry-point",
      "description": "Specify the contract entry point function"
    },
    {
      "name": "--syntax",
      "description": "Source syntax (pascaligo, cameligo, jsligo)"
    },
    {
      "name": "--protocol",
      "description": "Target Tezos protocol version"
    },
    {
      "name": "--output-file",
      "description": "Write output to file"
    },
    {
      "name": "--display-format",
      "description": "Output format (human-readable, json, dev)"
    },
    {
      "name": "--warn",
      "description": "Enable or disable warnings"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    }
  ],
  "subcommands": [
    {
      "name": "compile contract file.ligo",
      "description": "Compile PascaLIGO contract to Michelson",
      "args": [
        "file"
      ],
      "options": [
        "--entry-point"
      ]
    },
    {
      "name": "run test file.ligo",
      "description": "Run tests defined in PascaLIGO file",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "compile expression pascaligo 'expr'",
      "description": "Compile a single PascaLIGO expression",
      "args": [
        "expression"
      ],
      "options": []
    },
    {
      "name": "run dry-run file.ligo 'param' 'storage'",
      "description": "Simulate contract execution",
      "args": [
        "file",
        "param",
        "storage"
      ],
      "options": []
    },
    {
      "name": "compile storage file.ligo 'value'",
      "description": "Compile initial storage value",
      "args": [
        "file",
        "value"
      ],
      "options": []
    },
    {
      "name": "info measure-contract file.ligo",
      "description": "Measure compiled contract size",
      "args": [
        "file"
      ],
      "options": []
    }
  ],
  "examples": [
    "ligo compile contract counter.ligo --entry-point main",
    "ligo run test counter.test.ligo",
    "ligo run dry-run counter.ligo 'Increment(5)' '0'",
    "ligo compile storage counter.ligo '0'",
    "ligo info measure-contract counter.ligo"
  ],
  "relatedCommands": [
    "cameligo",
    "tezos-client",
    "sol"
  ]
}
