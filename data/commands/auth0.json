        { "name": "--origins", "description": "Updated allowed origins", "type": "string" },
        { "name": "--json", "description": "Output in JSON format" }
      ],
      "examples": ["auth0 apps update <client-id> --name 'Updated App' --callbacks https://app.example.com/callback"]
    },
