{
  "name": "tilt",
  "description": "Tilt — smart rebuilds and live updates for Kubernetes dev",
  "category": "containers",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "up",
      "description": "Start Tilt with UI",
      "examples": [
        "tilt up",
        "tilt up --stream",
        "tilt up --port 10350",
        "tilt up -- --my-flag"
      ]
    },
    {
      "name": "down",
      "description": "Tear down resources",
      "examples": [
        "tilt down",
        "tilt down --delete-namespaces"
      ]
    },
    {
      "name": "ci",
      "description": "CI mode (run, wait, exit)",
      "examples": [
        "tilt ci",
        "tilt ci --timeout 10m"
      ]
    },
    {
      "name": "demo",
      "description": "Start demo project",
      "examples": [
        "tilt demo"
      ]
    },
    {
      "name": "get",
      "description": "Get resource info",
      "examples": [
        "tilt get uiresources",
        "tilt get cmd"
      ]
    },
    {
      "name": "logs",
      "description": "View resource logs",
      "examples": [
        "tilt logs",
        "tilt logs my-resource"
      ]
    },
    {
      "name": "trigger",
      "description": "Trigger an update",
      "examples": [
        "tilt trigger my-resource"
      ]
    },
    {
      "name": "enable",
      "description": "Enable a resource",
      "examples": [
        "tilt enable my-resource"
      ]
    },
    {
      "name": "disable",
      "description": "Disable a resource",
      "examples": [
        "tilt disable my-resource"
      ]
    },
    {
      "name": "describe",
      "description": "Describe a resource",
      "examples": [
        "tilt describe uiresource/my-resource"
      ]
    },
    {
      "name": "doctor",
      "description": "Diagnose issues",
      "examples": [
        "tilt doctor"
      ]
    },
    {
      "name": "dump",
      "description": "Dump internal state",
      "examples": [
        "tilt dump engine",
        "tilt dump cli"
      ]
    },
    {
      "name": "version",
      "description": "Show version",
      "examples": [
        "tilt version"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--context",
      "description": "Kubernetes context",
      "type": "string"
    },
    {
      "name": "--namespace",
      "description": "Default namespace",
      "type": "string"
    },
    {
      "name": "--file",
      "short": "-f",
      "description": "Tiltfile path",
      "type": "string"
    },
    {
      "name": "--port",
      "description": "Web UI port",
      "type": "number"
    },
    {
      "name": "--stream",
      "description": "Stream logs to stdout"
    }
  ],
  "examples": [
    "tilt up",
    "tilt up --stream",
    "tilt down",
    "tilt ci",
    "tilt logs",
    "tilt trigger my-resource",
    "tilt doctor",
    "tilt version"
  ],
  "relatedCommands": [
    "skaffold",
    "kubectl",
    "docker",
    "devspace"
  ]
}
