{
  "name": "dart",
  "description": "Dart command-line interface",
  "category": "Mobile Development",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "run",
      "description": "Run a Dart program"
    },
    {
      "name": "test",
      "description": "Run tests in this package"
    },
    {
      "name": "format",
      "description": "Idiomatically format Dart source code"
    },
    {
      "name": "analyze",
      "description": "Analyze the project's Dart code"
    }
  ],
  "globalOptions": [],
  "examples": [
    {
      "command": "dart run bin/main.dart",
      "description": "Run dart file"
    },
    {
      "command": "dart format .",
      "description": "Format all dart files"
    }
  ],
  "relatedCommands": [
    "flutter"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "dart_version",
        "description": "Dart Version",
        "command": "dart --version 2>/dev/null",
        "parser": "text",
        "cacheFor": 3600
      }
    ]
  }
}