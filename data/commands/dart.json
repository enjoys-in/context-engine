{
  "language": "dart",
  "name": "dart",
  "description": "Dart SDK command-line tool",
  "category": "mobile",
  "contextEngine": {
    "detectors": [
      {
        "name": "version",
        "description": "Dart SDK Version",
        "command": "dart --version 2>/dev/null",
        "parser": "text",
        "cacheFor": 3600
      }
    ]
  },
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--verbose",
      "short": "-v",
      "description": "Show additional command output."
    },
    {
      "name": "--version",
      "description": "Print the Dart SDK version."
    },
    {
      "name": "--help",
      "short": "-h",
      "description": "Print this usage information."
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    },
    {
      "name": "--working-dir",
      "description": "Set the working directory",
      "valueHint": "dir",
      "alias": "-d"
    },
    {
      "name": "--env",
      "description": "Set environment (development, staging, production)",
      "valueHint": "name"
    }
  ],
  "subcommands": [
    {
      "name": "analyze",
      "description": "Analyze the project's Dart code.",
      "args": [
        {
          "name": "[directory]",
          "type": "path",
          "required": false,
          "description": "The directory to analyze"
        }
      ],
      "options": [
        {
          "name": "--fatal-infos",
          "description": "Treat info level issues as fatal."
        },
        {
          "name": "--fatal-warnings",
          "description": "Treat warning level issues as fatal."
        }
      ],
      "examples": [
        "dart analyze",
        "dart analyze lib/"
      ]
    },
    {
      "name": "compile",
      "description": "Compile Dart to various formats.",
      "args": [],
      "options": [],
      "examples": [
        "dart compile exe bin/myapp.dart",
        "dart compile js bin/myapp.dart"
      ]
    },
    {
      "name": "create",
      "description": "Create a new Dart project.",
      "args": [
        {
          "name": "<directory>",
          "type": "path",
          "required": true,
          "description": "Directory to create the project in"
        }
      ],
      "options": [
        {
          "name": "--template",
          "short": "-t",
          "description": "The template used to generate the project.",
          "type": "string"
        }
      ],
      "examples": [
        "dart create cli_app",
        "dart create -t server-shelf server_app"
      ]
    },
    {
      "name": "format",
      "description": "Idiomatically format Dart source code.",
      "args": [
        {
          "name": "[files or directories...]",
          "type": "path",
          "required": false,
          "description": "The files or directories to format"
        }
      ],
      "options": [
        {
          "name": "--output",
          "short": "-o",
          "description": "Set where to write formatted output [write|show|json|none].",
          "type": "string"
        },
        {
          "name": "--set-exit-if-changed",
          "description": "Return exit code 1 if there are any formatting changes."
        }
      ],
      "examples": [
        "dart format lib/",
        "dart format -o none --set-exit-if-changed ."
      ]
    },
    {
      "name": "pub",
      "description": "Work with packages.",
      "args": [],
      "options": [],
      "examples": [
        "dart pub get",
        "dart pub upgrade",
        "dart pub add http"
      ]
    },
    {
      "name": "run",
      "description": "Run a Dart program.",
      "args": [
        {
          "name": "<executable>",
          "type": "string",
          "required": true,
          "description": "The program to run"
        },
        {
          "name": "[args...]",
          "type": "string",
          "required": false,
          "description": "Arguments to pass to the program"
        }
      ],
      "options": [
        {
          "name": "--enable-asserts",
          "description": "Enable assert statements."
        },
        {
          "name": "--enable-experiment",
          "description": "Enable one or more experimental features.",
          "type": "string"
        }
      ],
      "examples": [
        "dart run bin/myapp.dart",
        "dart run test"
      ]
    },
    {
      "name": "test",
      "description": "Run tests for a project.",
      "args": [
        {
          "name": "[files or directories...]",
          "type": "path",
          "required": false,
          "description": "The tests to run"
        }
      ],
      "options": [
        {
          "name": "--name",
          "short": "-n",
          "description": "A regular expression matching the name of the test to run.",
          "type": "string"
        },
        {
          "name": "--tags",
          "short": "-t",
          "description": "Run only tests with all of the specified tags.",
          "type": "string"
        }
      ],
      "examples": [
        "dart test",
        "dart test test/my_test.dart"
      ]
    }
  ],
  "examples": [
    "dart run bin/myapp.dart",
    "dart pub get",
    "dart format lib/",
    "dart test"
  ],
  "relatedCommands": [
    "flutter"
  ]
}
