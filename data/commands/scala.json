{
  "language": "scala",
  "name": "scala",
  "description": "Scala programming language tools",
  "category": "languages",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--help",
      "description": "Show help information"
    },
    {
      "name": "--version",
      "description": "Show version information"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    },
    {
      "name": "--working-dir",
      "description": "Set the working directory",
      "valueHint": "dir",
      "alias": "-d"
    },
    {
      "name": "--env",
      "description": "Set environment (development, staging, production)",
      "valueHint": "name"
    }
  ],
  "subcommands": [
    {
      "name": "scala",
      "description": "Scala REPL and script runner (Scala 3 / scala-cli)",
      "args": [
        {
          "name": "[file.scala]",
          "type": "path",
          "required": false,
          "description": "Scala source file to run"
        }
      ],
      "options": [
        {
          "name": "-classpath",
          "description": "Specify classpath entries"
        },
        {
          "name": "-version",
          "description": "Print Scala version"
        },
        {
          "name": "-deprecation",
          "description": "Show deprecation warnings"
        },
        {
          "name": "-feature",
          "description": "Show feature warnings"
        },
        {
          "name": "-unchecked",
          "description": "Enable additional warnings"
        }
      ],
      "examples": [
        "scala",
        "scala script.scala",
        "scala -version",
        "scala -classpath lib/*.jar Main"
      ]
    },
    {
      "name": "scalac",
      "description": "Scala compiler",
      "args": [
        {
          "name": "<files>",
          "type": "path",
          "required": true,
          "description": "Source files to compile"
        }
      ],
      "options": [
        {
          "name": "-d",
          "description": "Output directory for class files"
        },
        {
          "name": "-classpath",
          "description": "Specify classpath entries"
        },
        {
          "name": "-deprecation",
          "description": "Emit deprecation warnings"
        },
        {
          "name": "-feature",
          "description": "Emit feature warnings"
        },
        {
          "name": "-unchecked",
          "description": "Enable additional warnings"
        },
        {
          "name": "-Werror",
          "description": "Treat warnings as errors"
        },
        {
          "name": "-Xfatal-warnings",
          "description": "Treat warnings as errors (Scala 2)"
        },
        {
          "name": "-opt:l:inline",
          "description": "Enable optimizer with inlining"
        },
        {
          "name": "-source",
          "description": "Set Scala language version (e.g., 3.3)"
        },
        {
          "name": "-target",
          "description": "Set JVM target version"
        }
      ],
      "examples": [
        "scalac Main.scala",
        "scalac -d out/ src/*.scala",
        "scalac -deprecation -feature Main.scala",
        "scalac -classpath lib/*.jar -d bin/ src/**/*.scala"
      ]
    },
    {
      "name": "sbt",
      "description": "Scala Build Tool - interactive build tool for Scala projects",
      "args": [
        {
          "name": "[command]",
          "type": "string",
          "required": false,
          "description": "sbt command to run"
        }
      ],
      "options": [
        {
          "name": "-J-Xmx",
          "description": "Set maximum JVM heap size (e.g., -J-Xmx4G)"
        },
        {
          "name": "--batch",
          "description": "Run in batch mode, non-interactive"
        },
        {
          "name": "-v",
          "description": "Verbose output"
        },
        {
          "name": "-no-colors",
          "description": "Disable ANSI color codes"
        }
      ],
      "examples": [
        "sbt",
        "sbt compile",
        "sbt test",
        "sbt run",
        "sbt clean compile",
        "sbt \"testOnly *MySpec\"",
        "sbt assembly",
        "sbt publishLocal",
        "sbt \"project submodule\" compile",
        "sbt reload",
        "sbt update",
        "sbt console",
        "sbt doc"
      ]
    },
    {
      "name": "mill",
      "description": "Mill build tool for Scala/Java projects",
      "args": [
        {
          "name": "<task>",
          "type": "string",
          "required": true,
          "description": "Build task to execute"
        }
      ],
      "options": [
        {
          "name": "-i",
          "description": "Interactive mode (REPL)"
        },
        {
          "name": "-w",
          "description": "Watch for file changes and re-run"
        },
        {
          "name": "--no-server",
          "description": "Run without the Mill server"
        },
        {
          "name": "-j",
          "description": "Number of parallel jobs"
        }
      ],
      "examples": [
        "mill app.compile",
        "mill app.run",
        "mill app.test",
        "mill -w app.compile",
        "mill app.assembly",
        "mill resolve _",
        "mill show app.scalaVersion"
      ]
    },
    {
      "name": "amm",
      "description": "Ammonite - enhanced Scala REPL and script runner",
      "args": [
        {
          "name": "[script.sc]",
          "type": "path",
          "required": false,
          "description": "Ammonite script to run"
        }
      ],
      "options": [
        {
          "name": "--predef",
          "description": "Predef file to load on startup"
        },
        {
          "name": "--no-remote-logging",
          "description": "Disable remote logging"
        },
        {
          "name": "-c",
          "description": "Execute code inline"
        },
        {
          "name": "-w",
          "description": "Watch mode - re-run on file changes"
        }
      ],
      "examples": [
        "amm",
        "amm script.sc",
        "amm -c 'println(1 + 1)'",
        "amm -w script.sc"
      ]
    },
    {
      "name": "scala-cli",
      "description": "Scala CLI - command-line tool to compile, run, test, and package Scala code",
      "args": [
        {
          "name": "[inputs]",
          "type": "path",
          "required": false,
          "description": "Source files or directories"
        }
      ],
      "options": [
        {
          "name": "--scala",
          "description": "Set the Scala version"
        },
        {
          "name": "--jvm",
          "description": "Set the JVM version"
        },
        {
          "name": "--dep",
          "description": "Add an external dependency"
        },
        {
          "name": "-w",
          "description": "Watch mode"
        },
        {
          "name": "--main-class",
          "description": "Specify the main class to run"
        },
        {
          "name": "--power",
          "description": "Enable power mode for advanced features"
        }
      ],
      "examples": [
        "scala-cli run Main.scala",
        "scala-cli test .",
        "scala-cli compile .",
        "scala-cli repl",
        "scala-cli run . --scala 3.3",
        "scala-cli run . --dep com.lihaoyi::os-lib:0.9.1",
        "scala-cli package . -o app",
        "scala-cli fmt .",
        "scala-cli setup-ide ."
      ]
    },
    {
      "name": "cs",
      "description": "Coursier - artifact fetching and dependency resolution for Scala/Java",
      "args": [
        {
          "name": "<command>",
          "type": "string",
          "required": true,
          "description": "Coursier subcommand"
        }
      ],
      "options": [
        {
          "name": "--cache",
          "description": "Cache directory"
        },
        {
          "name": "--no-default",
          "description": "Don't add default repositories"
        }
      ],
      "examples": [
        "cs fetch org.typelevel::cats-core:2.10.0",
        "cs resolve org.typelevel::cats-core:2.10.0",
        "cs install scala",
        "cs install scalafmt",
        "cs install ammonite",
        "cs launch org.scalameta::metals:latest.stable",
        "cs java --jvm 17 -version",
        "cs setup",
        "cs update"
      ]
    }
  ],
  "examples": [
    {
      "command": "sbt new scala/scala3.g8",
      "description": "Create new Scala 3 project"
    },
    {
      "command": "sbt compile",
      "description": "Compile Scala project"
    },
    {
      "command": "sbt test",
      "description": "Run tests"
    },
    {
      "command": "sbt run",
      "description": "Run the main class"
    },
    {
      "command": "scala-cli run script.scala",
      "description": "Run a Scala script"
    }
  ],
  "relatedCommands": []
}
