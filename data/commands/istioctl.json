{
  "name": "istioctl",
  "description": "Istio service mesh CLI",
  "category": "containers",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "install",
      "description": "Install Istio",
      "examples": [
        "istioctl install --set profile=demo"
      ]
    },
    {
      "name": "analyze",
      "description": "Analyze Istio configuration",
      "examples": [
        "istioctl analyze"
      ]
    },
    {
      "name": "proxy-status",
      "description": "Show proxy sync status",
      "examples": [
        "istioctl proxy-status"
      ]
    },
    {
      "name": "proxy-config",
      "description": "Show proxy configuration",
      "examples": [
        "istioctl proxy-config clusters myapp-pod"
      ]
    },
    {
      "name": "dashboard",
      "description": "Open web dashboards",
      "examples": [
        "istioctl dashboard kiali",
        "istioctl dashboard grafana"
      ]
    },
    {
      "name": "kube-inject",
      "description": "Inject Envoy sidecar",
      "examples": [
        "istioctl kube-inject -f deployment.yaml | kubectl apply -f -"
      ]
    },
    {
      "name": "verify-install",
      "description": "Verify Istio installation",
      "examples": [
        "istioctl verify-install"
      ]
    },
    {
      "name": "uninstall",
      "description": "Uninstall Istio",
      "examples": [
        "istioctl uninstall --purge"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--context",
      "description": "Kubernetes context",
      "type": "string"
    },
    {
      "name": "-n",
      "description": "Namespace",
      "type": "string"
    },
    {
      "name": "--istioNamespace",
      "description": "Istio system namespace",
      "type": "string"
    }
  ],
  "examples": [
    "istioctl install --set profile=demo",
    "istioctl analyze",
    "istioctl proxy-status",
    "istioctl dashboard kiali",
    "istioctl verify-install"
  ],
  "relatedCommands": [
    "kubectl",
    "helm",
    "argocd",
    "linkerd"
  ]
}
