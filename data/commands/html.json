{
  "name": "html-validate",
  "description": "HTML validation, formatting, and linting tools",
  "category": "development",
  "platforms": ["linux", "macos", "windows"],
  "shells": ["bash", "zsh", "powershell"],
  "subcommands": [
    { "name": "validate", "description": "Validate HTML files for standards compliance", "args": ["files"], "options": ["--config", "--formatter"] },
    { "name": "lint", "description": "Lint HTML files for common errors", "args": ["files"], "options": ["--rule", "--fix"] },
    { "name": "format", "description": "Format HTML files with Prettier", "args": ["files"], "options": ["--write", "--tab-width"] },
    { "name": "minify", "description": "Minify HTML files using html-minifier-terser", "args": ["file"], "options": ["--collapse-whitespace", "--remove-comments"] },
    { "name": "serve", "description": "Serve HTML files with a local dev server", "args": ["directory"], "options": ["--port", "--open"] },
    { "name": "init", "description": "Initialize html-validate configuration", "args": [], "options": [] }
  ],
  "globalOptions": [
    { "name": "--config", "description": "Path to configuration file" },
    { "name": "--formatter", "description": "Output formatter (stylish, json, codeframe)" },
    { "name": "--max-warnings", "description": "Max number of warnings before failing" },
    { "name": "--ext", "description": "File extensions to process (default: .html)" },
    { "name": "--ignore-path", "description": "Path to ignore file" }
  ],
  "examples": [
    "npx html-validate index.html",
    "npx html-validate 'src/**/*.html' --formatter stylish",
    "npx prettier --write --parser html '**/*.html'",
    "npx html-minifier-terser --collapse-whitespace --remove-comments index.html -o index.min.html",
    "npx serve ./public --port 3000"
  ],
  "relatedCommands": ["prettier", "css", "javascript", "eslint"]
}