{
  "language": "html",
  "name": "html-validate",
  "description": "HTML validation, formatting, and linting tools",
  "category": "development",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--config",
      "description": "Path to configuration file"
    },
    {
      "name": "--formatter",
      "description": "Output formatter (stylish, json, codeframe)"
    },
    {
      "name": "--max-warnings",
      "description": "Max number of warnings before failing"
    },
    {
      "name": "--ext",
      "description": "File extensions to process (default: .html)"
    },
    {
      "name": "--ignore-path",
      "description": "Path to ignore file"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    }
  ],
  "subcommands": [
    {
      "name": "validate",
      "description": "Validate HTML files for standards compliance",
      "args": [
        "files"
      ],
      "options": [
        "--config",
        "--formatter"
      ]
    },
    {
      "name": "lint",
      "description": "Lint HTML files for common errors",
      "args": [
        "files"
      ],
      "options": [
        "--rule",
        "--fix"
      ]
    },
    {
      "name": "format",
      "description": "Format HTML files with Prettier",
      "args": [
        "files"
      ],
      "options": [
        "--write",
        "--tab-width"
      ]
    },
    {
      "name": "minify",
      "description": "Minify HTML files using html-minifier-terser",
      "args": [
        "file"
      ],
      "options": [
        "--collapse-whitespace",
        "--remove-comments"
      ]
    },
    {
      "name": "serve",
      "description": "Serve HTML files with a local dev server",
      "args": [
        "directory"
      ],
      "options": [
        "--port",
        "--open"
      ]
    },
    {
      "name": "init",
      "description": "Initialize html-validate configuration",
      "args": [],
      "options": []
    }
  ],
  "examples": [
    "npx html-validate index.html",
    "npx html-validate 'src/**/*.html' --formatter stylish",
    "npx prettier --write --parser html '**/*.html'",
    "npx html-minifier-terser --collapse-whitespace --remove-comments index.html -o index.min.html",
    "npx serve ./public --port 3000"
  ],
  "relatedCommands": [
    "prettier",
    "css",
    "javascript",
    "eslint"
  ]
}
