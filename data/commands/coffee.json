{
  "language": "coffee",
  "name": "coffee",
  "description": "CoffeeScript command-line tool",
  "category": "development",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--help",
      "description": "Show help information"
    },
    {
      "name": "--version",
      "description": "Show version information"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    }
  ],
  "subcommands": [
    {
      "name": "-c file.coffee",
      "description": "Compile CoffeeScript to JavaScript",
      "args": [],
      "options": []
    },
    {
      "name": "-w file.coffee",
      "description": "Watch and compile on changes",
      "args": [],
      "options": []
    },
    {
      "name": "-p file.coffee",
      "description": "Print compiled JS to stdout",
      "args": [],
      "options": []
    },
    {
      "name": "-e 'code'",
      "description": "Evaluate CoffeeScript expression",
      "args": [],
      "options": []
    },
    {
      "name": "lint",
      "description": "Lint CoffeeScript",
      "usage": "coffeelint app.coffee"
    },
    {
      "name": "eval",
      "description": "Evaluate CoffeeScript expression",
      "usage": "coffee -e 'console.log 1 + 2'"
    },
    {
      "name": "repl",
      "description": "Start CoffeeScript REPL",
      "usage": "coffee"
    },
    {
      "name": "tokens",
      "description": "Print token stream",
      "usage": "coffee --tokens app.coffee"
    },
    {
      "name": "nodes",
      "description": "Print AST nodes",
      "usage": "coffee --nodes app.coffee"
    }
  ],
  "examples": [
    {
      "command": "coffee app.coffee",
      "description": "Run a CoffeeScript file"
    },
    {
      "command": "coffee -c app.coffee",
      "description": "Compile CoffeeScript to JavaScript"
    },
    {
      "command": "coffee -w -c src/",
      "description": "Watch and compile a directory"
    },
    {
      "command": "coffee --map app.coffee",
      "description": "Compile with source maps"
    }
  ],
  "relatedCommands": []
}
