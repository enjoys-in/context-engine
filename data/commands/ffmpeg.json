{
  "name": "ffmpeg",
  "description": "Universal media converter — audio, video, streaming",
  "category": "media",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "-i",
      "description": "Input file",
      "type": "file"
    },
    {
      "name": "-c:v",
      "description": "Video codec",
      "type": "string"
    },
    {
      "name": "-c:a",
      "description": "Audio codec",
      "type": "string"
    },
    {
      "name": "-b:v",
      "description": "Video bitrate",
      "type": "string"
    },
    {
      "name": "-b:a",
      "description": "Audio bitrate",
      "type": "string"
    },
    {
      "name": "-r",
      "description": "Frame rate",
      "type": "number"
    },
    {
      "name": "-s",
      "description": "Frame size (WxH)",
      "type": "string"
    },
    {
      "name": "-ss",
      "description": "Start time offset",
      "type": "string"
    },
    {
      "name": "-t",
      "description": "Duration",
      "type": "string"
    },
    {
      "name": "-to",
      "description": "Stop time",
      "type": "string"
    },
    {
      "name": "-vn",
      "description": "No video"
    },
    {
      "name": "-an",
      "description": "No audio"
    },
    {
      "name": "-f",
      "description": "Force format",
      "type": "string"
    },
    {
      "name": "-y",
      "description": "Overwrite output"
    },
    {
      "name": "-map",
      "description": "Stream mapping",
      "type": "string"
    },
    {
      "name": "-filter:v",
      "description": "Video filter",
      "type": "string"
    },
    {
      "name": "-filter:a",
      "description": "Audio filter",
      "type": "string"
    }
  ],
  "examples": [
    "ffmpeg -i input.mp4 output.avi",
    "ffmpeg -i input.mp4 -c:v libx264 -crf 23 output.mp4",
    "ffmpeg -i input.mp4 -vn -c:a libmp3lame output.mp3",
    "ffmpeg -i input.mp4 -ss 00:01:00 -t 30 clip.mp4",
    "ffmpeg -i input.mp4 -vf scale=1280:720 output.mp4",
    "ffmpeg -i input.mp4 -r 30 -s 1920x1080 output.mp4"
  ],
  "relatedCommands": [
    "ffprobe",
    "imagemagick",
    "sox",
    "vlc"
  ]
}
