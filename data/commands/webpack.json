{
  "name": "webpack",
  "description": "Module bundler for JavaScript applications",
  "category": "build-tools",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "serve",
      "description": "Start webpack dev server",
      "examples": [
        "webpack serve",
        "webpack serve --open"
      ]
    },
    {
      "name": "watch",
      "description": "Watch files for changes",
      "examples": [
        "webpack watch"
      ]
    },
    {
      "name": "build",
      "description": "Build the project",
      "examples": [
        "webpack build"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--mode",
      "description": "Build mode (development, production, none)",
      "type": "string"
    },
    {
      "name": "--config",
      "description": "Path to config file",
      "type": "file"
    },
    {
      "name": "--entry",
      "description": "Entry point",
      "type": "string"
    },
    {
      "name": "--output-path",
      "description": "Output directory",
      "type": "string"
    },
    {
      "name": "--devtool",
      "description": "Source map strategy",
      "type": "string"
    },
    {
      "name": "--watch",
      "short": "-w",
      "description": "Watch for changes"
    },
    {
      "name": "--stats",
      "description": "Stats preset",
      "type": "string"
    },
    {
      "name": "--progress",
      "description": "Show build progress"
    }
  ],
  "examples": [
    "webpack",
    "webpack --mode production",
    "webpack --config webpack.prod.js",
    "webpack serve --open",
    "webpack --progress --stats errors-only"
  ],
  "relatedCommands": [
    "esbuild",
    "rollup",
    "vite",
    "babel"
  ]
}
