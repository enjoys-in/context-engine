{
  "name": "wasm-pack",
  "description": "Build, test, and publish Rust-generated WebAssembly packages",
  "category": "rust-ecosystem",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell",
    "fish"
  ],
  "subcommands": [
    {
      "name": "build",
      "description": "Build the project into a wasm pkg",
      "args": [
        {
          "name": "path",
          "description": "Path to crate directory",
          "required": false
        }
      ],
      "options": [
        {
          "name": "--target",
          "shorthand": "-t",
          "description": "Target (bundler, nodejs, web, no-modules)",
          "takesValue": true
        },
        {
          "name": "--out-dir",
          "shorthand": "-d",
          "description": "Output directory",
          "takesValue": true
        },
        {
          "name": "--out-name",
          "description": "Output file name",
          "takesValue": true
        },
        {
          "name": "--scope",
          "shorthand": "-s",
          "description": "npm scope",
          "takesValue": true
        },
        {
          "name": "--dev",
          "description": "Development build"
        },
        {
          "name": "--release",
          "description": "Release build"
        },
        {
          "name": "--profiling",
          "description": "Profiling build"
        },
        {
          "name": "--no-typescript",
          "description": "Don't generate TypeScript definitions"
        },
        {
          "name": "--weak-refs",
          "description": "Enable weak references"
        },
        {
          "name": "--reference-types",
          "description": "Enable reference types"
        }
      ]
    },
    {
      "name": "test",
      "description": "Run wasm tests in headless browser",
      "options": [
        {
          "name": "--headless",
          "description": "Run headless"
        },
        {
          "name": "--chrome",
          "description": "Use Chrome"
        },
        {
          "name": "--firefox",
          "description": "Use Firefox"
        },
        {
          "name": "--safari",
          "description": "Use Safari"
        },
        {
          "name": "--node",
          "description": "Test in Node.js"
        }
      ]
    },
    {
      "name": "pack",
      "description": "Create a tarball from pkg directory"
    },
    {
      "name": "publish",
      "description": "Publish to npm registry",
      "options": [
        {
          "name": "--access",
          "description": "npm access level (public, restricted)",
          "takesValue": true
        },
        {
          "name": "--tag",
          "description": "npm tag",
          "takesValue": true
        }
      ]
    },
    {
      "name": "new",
      "description": "Create a new wasm-pack project",
      "args": [
        {
          "name": "name",
          "description": "Project name",
          "required": true
        }
      ],
      "options": [
        {
          "name": "--template",
          "description": "Template to use",
          "takesValue": true
        },
        {
          "name": "--mode",
          "description": "Mode (normal, noinstall, force)",
          "takesValue": true
        }
      ]
    },
    {
      "name": "login",
      "description": "Login to npm registry",
      "options": [
        {
          "name": "--registry",
          "description": "Registry URL",
          "takesValue": true
        },
        {
          "name": "--scope",
          "description": "npm scope",
          "takesValue": true
        }
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--verbose",
      "shorthand": "-v",
      "description": "Verbose output"
    },
    {
      "name": "--quiet",
      "shorthand": "-q",
      "description": "Quiet output"
    },
    {
      "name": "--log-level",
      "description": "Log level",
      "takesValue": true
    },
    {
      "name": "--help",
      "shorthand": "-h",
      "description": "Show help"
    },
    {
      "name": "--version",
      "shorthand": "-V",
      "description": "Show version"
    }
  ],
  "examples": [
    {
      "command": "wasm-pack build",
      "description": "Build WASM package for bundlers"
    },
    {
      "command": "wasm-pack build --target web",
      "description": "Build for web (no bundler)"
    },
    {
      "command": "wasm-pack build --target nodejs",
      "description": "Build for Node.js"
    },
    {
      "command": "wasm-pack test --headless --chrome",
      "description": "Run tests in headless Chrome"
    },
    {
      "command": "wasm-pack publish --access public",
      "description": "Publish to npm"
    },
    {
      "command": "wasm-pack new my-wasm-lib",
      "description": "Create new project"
    }
  ],
  "relatedCommands": [
    "cargo",
    "rustup",
    "npm"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "cargo_toml",
        "description": "Crate metadata",
        "command": "cat Cargo.toml 2>/dev/null | head -20",
        "parser": "text",
        "cacheFor": 30
      },
      {
        "name": "wasm_target",
        "description": "WASM target installed",
        "command": "rustup target list --installed 2>/dev/null | grep wasm",
        "parser": "lines",
        "cacheFor": 120,
        "requiresCmd": "rustup"
      },
      {
        "name": "pkg_dir",
        "description": "Built package directory",
        "command": "ls pkg/ 2>/dev/null",
        "parser": "lines",
        "cacheFor": 30
      },
      {
        "name": "crate_type",
        "description": "Crate type from Cargo.toml",
        "command": "grep 'crate-type' Cargo.toml 2>/dev/null",
        "parser": "text",
        "cacheFor": 60
      }
    ]
  }
}
