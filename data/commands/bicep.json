{
  "language": "bicep",
  "name": "az bicep",
  "description": "Bicep command-line tool",
  "category": "development",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--help",
      "description": "Show help information"
    },
    {
      "name": "--version",
      "description": "Show version information"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    },
    {
      "name": "--working-dir",
      "description": "Set the working directory",
      "valueHint": "dir",
      "alias": "-d"
    },
    {
      "name": "--env",
      "description": "Set environment (development, staging, production)",
      "valueHint": "name"
    },
    {
      "name": "--timeout",
      "description": "Set operation timeout in seconds",
      "valueHint": "seconds"
    },
    {
      "name": "--parallel",
      "description": "Run operations in parallel where possible"
    }
  ],
  "subcommands": [
    {
      "name": "build",
      "description": "Build a Bicep file",
      "args": [],
      "options": []
    },
    {
      "name": "decompile",
      "description": "Decompile ARM template to Bicep",
      "args": [],
      "options": []
    },
    {
      "name": "install",
      "description": "Install Bicep CLI",
      "args": [],
      "options": []
    },
    {
      "name": "upgrade",
      "description": "Upgrade Bicep CLI",
      "args": [],
      "options": []
    },
    {
      "name": "publish",
      "description": "Publish a Bicep file to a registry",
      "args": [],
      "options": []
    }
  ],
  "examples": [
    {
      "command": "az bicep build --file main.bicep",
      "description": "Build Bicep file to ARM template"
    },
    {
      "command": "az bicep decompile --file template.json",
      "description": "Decompile ARM template to Bicep"
    },
    {
      "command": "az deployment group create --template-file main.bicep --resource-group myRG",
      "description": "Deploy a Bicep template"
    },
    {
      "command": "az bicep lint --file main.bicep",
      "description": "Lint a Bicep file"
    }
  ],
  "relatedCommands": []
}
