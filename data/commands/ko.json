{
  "name": "ko",
  "description": "Build and deploy Go applications to Kubernetes",
  "category": "containers",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "build",
      "description": "Build Go binary into container image",
      "examples": [
        "ko build ./cmd/app"
      ]
    },
    {
      "name": "apply",
      "description": "Build and apply to Kubernetes",
      "examples": [
        "ko apply -f config/"
      ]
    },
    {
      "name": "resolve",
      "description": "Build and print resolved YAML",
      "examples": [
        "ko resolve -f config/"
      ]
    },
    {
      "name": "delete",
      "description": "Delete resources",
      "examples": [
        "ko delete -f config/"
      ]
    },
    {
      "name": "login",
      "description": "Login to registry",
      "examples": [
        "ko login ghcr.io"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--base-import-paths",
      "short": "-B",
      "description": "Use base import path for naming"
    },
    {
      "name": "--tags",
      "short": "-t",
      "description": "Image tags",
      "type": "string"
    },
    {
      "name": "--platform",
      "description": "Target platforms",
      "type": "string"
    },
    {
      "name": "--local",
      "short": "-L",
      "description": "Build to local Docker daemon"
    }
  ],
  "examples": [
    "ko build ./cmd/app",
    "ko apply -f config/",
    "ko build -B -t latest ./cmd/app",
    "ko resolve -f deploy.yaml > resolved.yaml",
    "KO_DOCKER_REPO=ghcr.io/user ko build ./cmd/app"
  ],
  "relatedCommands": [
    "docker",
    "kubectl",
    "podman",
    "buildah"
  ]
}
