{
  "language": "abap",
  "name": "abapgit",
  "description": "abapGit command-line tool for ABAP development (note: ABAP is primarily SAP-based, limited CLI usage)",
  "category": "enterprise",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--help",
      "description": "Show help information"
    },
    {
      "name": "--version",
      "description": "Show version information"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    },
    {
      "name": "--working-dir",
      "description": "Set the working directory",
      "valueHint": "dir",
      "alias": "-d"
    }
  ],
  "subcommands": [
    {
      "name": "clone",
      "description": "Clone a repository into an ABAP system",
      "args": [
        {
          "name": "url",
          "type": "string",
          "required": true,
          "description": "Git repository URL"
        }
      ],
      "options": [
        {
          "name": "--package",
          "description": "Target ABAP package",
          "type": "string",
          "required": true
        },
        {
          "name": "--transport",
          "description": "Transport request number",
          "type": "string",
          "required": false
        }
      ]
    },
    {
      "name": "pull",
      "description": "Pull changes from remote repository",
      "args": [],
      "options": [
        {
          "name": "--package",
          "description": "ABAP package",
          "type": "string",
          "required": true
        }
      ]
    },
    {
      "name": "push",
      "description": "Push local ABAP objects to remote repository",
      "args": [],
      "options": [
        {
          "name": "--package",
          "description": "ABAP package",
          "type": "string",
          "required": true
        },
        {
          "name": "--message",
          "description": "Commit message",
          "type": "string",
          "required": true
        }
      ]
    },
    {
      "name": "status",
      "description": "Show repository status",
      "args": [],
      "options": []
    },
    {
      "name": "check",
      "description": "Check ABAP syntax",
      "usage": "abaplint check src/"
    },
    {
      "name": "format",
      "description": "Format ABAP files",
      "usage": "abaplint fix src/"
    },
    {
      "name": "unit",
      "description": "Run ABAP unit tests",
      "usage": "abapunit run"
    },
    {
      "name": "deps",
      "description": "Check dependencies",
      "usage": "apack dependencies"
    }
  ],
  "examples": [
    {
      "command": "abaplint check src/",
      "description": "Lint ABAP source files"
    },
    {
      "command": "abaplint fix src/",
      "description": "Auto-fix ABAP lint issues"
    },
    {
      "command": "abapGit pull",
      "description": "Pull latest from abapGit repository"
    },
    {
      "command": "apack install",
      "description": "Install ABAP package dependencies"
    }
  ],
  "relatedCommands": []
}
