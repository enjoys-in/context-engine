{
  "name": "abapgit",
  "description": "abapGit command-line tool for ABAP development (note: ABAP is primarily SAP-based, limited CLI usage)",
  "category": "enterprise",
  "platforms": ["linux", "macos", "windows"],
  "shells": ["bash", "zsh", "powershell"],
  "subcommands": [
    {
      "name": "clone",
      "description": "Clone a repository into an ABAP system",
      "args": [{ "name": "url", "type": "string", "required": true, "description": "Git repository URL" }],
      "options": [
        { "name": "--package", "description": "Target ABAP package", "type": "string", "required": true },
        { "name": "--transport", "description": "Transport request number", "type": "string", "required": false }
      ]
    },
    {
      "name": "pull",
      "description": "Pull changes from remote repository",
      "args": [],
      "options": [
        { "name": "--package", "description": "ABAP package", "type": "string", "required": true }
      ]
    },
    {
      "name": "push",
      "description": "Push local ABAP objects to remote repository",
      "args": [],
      "options": [
        { "name": "--package", "description": "ABAP package", "type": "string", "required": true },
        { "name": "--message", "description": "Commit message", "type": "string", "required": true }
      ]
    },
    {
      "name": "status",
      "description": "Show repository status",
      "args": [],
      "options": []
    }
  ]
}
