{
  "language": "lua",
  "name": "lua",
  "description": "Lua — lightweight, embeddable scripting language",
  "category": "language",
  "contextEngine": {
    "detectors": [
      {
        "name": "version",
        "description": "Lua interpreter version",
        "command": "lua -v 2>&1 | head -1",
        "parser": "text",
        "cacheFor": 300,
        "requiresCmd": "lua"
      },
      {
        "name": "lua_path",
        "description": "Lua module search path",
        "command": "lua -e \"print(package.path)\" 2>/dev/null",
        "parser": "text",
        "cacheFor": 120,
        "requiresCmd": "lua"
      },
      {
        "name": "lua_cpath",
        "description": "Lua C module search path",
        "command": "lua -e \"print(package.cpath)\" 2>/dev/null",
        "parser": "text",
        "cacheFor": 120,
        "requiresCmd": "lua"
      },
      {
        "name": "luarocks_list",
        "description": "Installed LuaRocks packages",
        "command": "luarocks list --porcelain 2>/dev/null | head -20",
        "parser": "lines",
        "cacheFor": 120,
        "requiresCmd": "luarocks"
      }
    ]
  },
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "-e",
      "description": "Execute a Lua statement",
      "type": "string"
    },
    {
      "name": "-l",
      "description": "Require library before executing script",
      "type": "string"
    },
    {
      "name": "-i",
      "description": "Enter interactive mode after executing script"
    },
    {
      "name": "-v",
      "description": "Show version information"
    },
    {
      "name": "-E",
      "description": "Ignore environment variables"
    },
    {
      "name": "-W",
      "description": "Turn warnings on"
    },
    {
      "name": "--",
      "description": "Stop handling options"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    },
    {
      "name": "--working-dir",
      "description": "Set the working directory",
      "valueHint": "dir",
      "alias": "-d"
    },
    {
      "name": "--env",
      "description": "Set environment (development, staging, production)",
      "valueHint": "name"
    }
  ],
  "subcommands": [],
  "examples": [
    "lua",
    "lua script.lua",
    "lua -e \"print('hello')\"",
    "lua -i script.lua",
    "lua -l mylib script.lua",
    "lua -v",
    "lua -e \"for i=1,10 do print(i) end\"",
    "lua -e \"dofile('script.lua')\"",
    "lua -W script.lua",
    "lua -E script.lua"
  ],
  "relatedCommands": [
    "luac",
    "luajit",
    "python",
    "node",
    "ruby"
  ]
}
