{
  "name": "asdf",
  "description": "Multiple runtime version manager",
  "category": "version-manager",
  "platforms": [
    "linux",
    "macos"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish"
  ],
  "subcommands": [
    {
      "name": "plugin add",
      "description": "Add a plugin",
      "examples": [
        "asdf plugin add nodejs",
        "asdf plugin add python"
      ]
    },
    {
      "name": "install",
      "description": "Install a version",
      "examples": [
        "asdf install nodejs 20.10.0",
        "asdf install python 3.12.0"
      ]
    },
    {
      "name": "global",
      "description": "Set global version",
      "examples": [
        "asdf global nodejs 20.10.0"
      ]
    },
    {
      "name": "local",
      "description": "Set local version",
      "examples": [
        "asdf local nodejs 20.10.0"
      ]
    },
    {
      "name": "list",
      "description": "List installed versions",
      "examples": [
        "asdf list nodejs"
      ]
    },
    {
      "name": "list all",
      "description": "List all available versions",
      "examples": [
        "asdf list all nodejs"
      ]
    },
    {
      "name": "current",
      "description": "Show currently active versions",
      "examples": [
        "asdf current"
      ]
    },
    {
      "name": "plugin list",
      "description": "List installed plugins",
      "examples": [
        "asdf plugin list"
      ]
    },
    {
      "name": "uninstall",
      "description": "Uninstall a version",
      "examples": [
        "asdf uninstall nodejs 18.0.0"
      ]
    },
    {
      "name": "reshim",
      "description": "Recreate shims",
      "examples": [
        "asdf reshim nodejs"
      ]
    }
  ],
  "globalOptions": [],
  "examples": [
    "asdf plugin add nodejs",
    "asdf install nodejs 20.10.0",
    "asdf global nodejs 20.10.0",
    "asdf current",
    "asdf list"
  ],
  "relatedCommands": [
    "nvm",
    "pyenv",
    "rbenv",
    "mise"
  ]
}
