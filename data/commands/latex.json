{
  "name": "latex",
  "description": "LaTeX document typesetting system",
  "category": "media",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "-output-directory",
      "description": "Output directory",
      "type": "string"
    },
    {
      "name": "-jobname",
      "description": "Base name for output files",
      "type": "string"
    },
    {
      "name": "-interaction",
      "description": "Interaction mode (nonstopmode, batchmode, scrollmode)",
      "type": "string"
    },
    {
      "name": "-shell-escape",
      "description": "Enable shell commands"
    },
    {
      "name": "-synctex",
      "description": "Generate SyncTeX data",
      "type": "number"
    },
    {
      "name": "-file-line-error",
      "description": "Show file and line in errors"
    },
    {
      "name": "-halt-on-error",
      "description": "Stop on first error"
    }
  ],
  "examples": [
    "pdflatex document.tex",
    "xelatex document.tex",
    "lualatex document.tex",
    "pdflatex -interaction=nonstopmode document.tex",
    "latexmk -pdf document.tex",
    "bibtex document"
  ],
  "relatedCommands": [
    "pandoc",
    "bibtex",
    "latexmk",
    "dvipdfm"
  ]
}
