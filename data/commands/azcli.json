{
  "language": "azcli",
  "name": "az",
  "description": "Azure CLI command-line tool",
  "category": "development",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--help",
      "description": "Show help information"
    },
    {
      "name": "--version",
      "description": "Show version information"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    },
    {
      "name": "--working-dir",
      "description": "Set the working directory",
      "valueHint": "dir",
      "alias": "-d"
    },
    {
      "name": "--env",
      "description": "Set environment (development, staging, production)",
      "valueHint": "name"
    }
  ],
  "subcommands": [
    {
      "name": "login",
      "description": "Login to Azure",
      "args": [],
      "options": []
    },
    {
      "name": "account show",
      "description": "Show current subscription",
      "args": [],
      "options": []
    },
    {
      "name": "group create",
      "description": "Create resource group",
      "args": [],
      "options": []
    },
    {
      "name": "vm create",
      "description": "Create virtual machine",
      "args": [],
      "options": []
    },
    {
      "name": "webapp create",
      "description": "Create web app",
      "args": [],
      "options": []
    },
    {
      "name": "aks create",
      "description": "Create AKS cluster",
      "args": [],
      "options": []
    },
    {
      "name": "storage account create",
      "description": "Create storage account",
      "args": [],
      "options": []
    }
  ],
  "examples": [
    {
      "command": "az login",
      "description": "Log in to Azure"
    },
    {
      "command": "az account list",
      "description": "List all Azure subscriptions"
    },
    {
      "command": "az group create --name myRG --location eastus",
      "description": "Create a resource group"
    },
    {
      "command": "az vm list -o table",
      "description": "List all VMs in table format"
    }
  ],
  "relatedCommands": []
}
