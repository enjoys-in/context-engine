{
  "name": "astro",
  "description": "The web framework for content-driven websites",
  "category": "static-site",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "dev",
      "description": "Start development server",
      "examples": [
        "astro dev",
        "astro dev --port 3001"
      ]
    },
    {
      "name": "build",
      "description": "Build production site",
      "examples": [
        "astro build"
      ]
    },
    {
      "name": "preview",
      "description": "Preview production build",
      "examples": [
        "astro preview"
      ]
    },
    {
      "name": "check",
      "description": "Check project for errors",
      "examples": [
        "astro check"
      ]
    },
    {
      "name": "add",
      "description": "Add an integration",
      "examples": [
        "astro add react",
        "astro add tailwind"
      ]
    },
    {
      "name": "sync",
      "description": "Generate TypeScript types",
      "examples": [
        "astro sync"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--port",
      "description": "Port number",
      "type": "number"
    },
    {
      "name": "--host",
      "description": "Network host to listen on",
      "type": "string"
    },
    {
      "name": "--root",
      "description": "Project root directory",
      "type": "string"
    },
    {
      "name": "--config",
      "description": "Config file path",
      "type": "file"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose logging"
    },
    {
      "name": "--silent",
      "description": "Suppress output"
    }
  ],
  "examples": [
    "npm create astro@latest",
    "astro dev",
    "astro build",
    "astro add react",
    "astro add tailwind",
    "astro check"
  ],
  "relatedCommands": [
    "vite",
    "gatsby",
    "hugo",
    "next"
  ]
}
