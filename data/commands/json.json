{
  "language": "json",
  "name": "jq",
  "description": "JSON command-line tool",
  "category": "development",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--help",
      "description": "Show help information"
    },
    {
      "name": "--version",
      "description": "Show version information"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    }
  ],
  "subcommands": [
    {
      "name": ".",
      "description": "Pretty print",
      "args": [],
      "options": []
    },
    {
      "name": ".key",
      "description": "Extract key",
      "args": [],
      "options": []
    },
    {
      "name": ".[] | .field",
      "description": "Map array",
      "args": [],
      "options": []
    },
    {
      "name": "-r .field",
      "description": "Raw output",
      "args": [],
      "options": []
    },
    {
      "name": "validate",
      "description": "Validate JSON syntax",
      "usage": "jq '.' file.json > /dev/null"
    },
    {
      "name": "query",
      "description": "Query JSON with jq expressions",
      "usage": "jq '.path.to.key' file.json"
    },
    {
      "name": "merge",
      "description": "Merge JSON files",
      "usage": "jq -s '.[0] * .[1]' file1.json file2.json"
    },
    {
      "name": "convert",
      "description": "Convert JSON to other formats",
      "usage": "jq -r '.[] | [.id,.name] | @csv' file.json"
    },
    {
      "name": "minify",
      "description": "Minify JSON output",
      "usage": "jq -c '.' file.json"
    },
    {
      "name": "sort-keys",
      "description": "Sort JSON object keys",
      "usage": "jq -S '.' file.json"
    }
  ],
  "examples": [
    {
      "command": "jq '.' file.json",
      "description": "Pretty print a JSON file"
    },
    {
      "command": "jq '.key' file.json",
      "description": "Extract a specific key from JSON"
    },
    {
      "command": "jq '.[] | .name' file.json",
      "description": "Iterate array and extract field"
    },
    {
      "command": "python -m json.tool file.json",
      "description": "Validate and format JSON with Python"
    }
  ],
  "relatedCommands": []
}
