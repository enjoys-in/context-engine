{
  "language": "powerquery",
  "name": "powerquery",
  "description": "Power Query M language tools for data transformation in Power BI and Excel",
  "category": "tool",
  "platforms": [
    "windows",
    "linux",
    "macos"
  ],
  "shells": [
    "powershell",
    "bash",
    "zsh"
  ],
  "globalOptions": [
    {
      "name": "--output",
      "description": "Output file or directory path"
    },
    {
      "name": "--format",
      "description": "Output format (json, csv, text)"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose output"
    },
    {
      "name": "--encoding",
      "description": "File encoding (default: utf-8)"
    },
    {
      "name": "--strict",
      "description": "Enable strict validation mode"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    },
    {
      "name": "--working-dir",
      "description": "Set the working directory",
      "valueHint": "dir",
      "alias": "-d"
    },
    {
      "name": "--env",
      "description": "Set environment (development, staging, production)",
      "valueHint": "name"
    },
    {
      "name": "--timeout",
      "description": "Set operation timeout in seconds",
      "valueHint": "seconds"
    }
  ],
  "subcommands": [
    {
      "name": "evaluate",
      "description": "Evaluate a Power Query M expression",
      "args": [
        "expression"
      ],
      "options": [
        "--output"
      ]
    },
    {
      "name": "format",
      "description": "Format Power Query M code",
      "args": [
        "file.pq"
      ],
      "options": [
        "--indent",
        "--write"
      ]
    },
    {
      "name": "extract",
      "description": "Extract Power Query M code from PBIX file",
      "args": [
        "file.pbix"
      ],
      "options": [
        "--output-dir"
      ]
    },
    {
      "name": "lint",
      "description": "Check Power Query M code for common issues",
      "args": [
        "file.pq"
      ],
      "options": [
        "--strict"
      ]
    },
    {
      "name": "compile",
      "description": "Compile Power Query M expression to mashup document",
      "args": [
        "file.pq"
      ],
      "options": [
        "--output"
      ]
    }
  ],
  "examples": [
    "pbi-tools extract report.pbix --output ./extracted",
    "pbi-tools compile ./extracted --output report.pbix",
    "pq format query.pq --write",
    "tabular-editor model.bim --script update-partitions.csx"
  ],
  "relatedCommands": [
    "msdax",
    "powershell",
    "sql"
  ]
}
