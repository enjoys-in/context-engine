{
  "name": "powerquery",
  "description": "Power Query M language tools for data transformation in Power BI and Excel",
  "category": "tool",
  "platforms": ["windows", "linux", "macos"],
  "shells": ["powershell", "bash", "zsh"],
  "subcommands": [
    { "name": "evaluate", "description": "Evaluate a Power Query M expression", "args": ["expression"], "options": ["--output"] },
    { "name": "format", "description": "Format Power Query M code", "args": ["file.pq"], "options": ["--indent", "--write"] },
    { "name": "extract", "description": "Extract Power Query M code from PBIX file", "args": ["file.pbix"], "options": ["--output-dir"] },
    { "name": "lint", "description": "Check Power Query M code for common issues", "args": ["file.pq"], "options": ["--strict"] },
    { "name": "compile", "description": "Compile Power Query M expression to mashup document", "args": ["file.pq"], "options": ["--output"] }
  ],
  "globalOptions": [
    { "name": "--output", "description": "Output file or directory path" },
    { "name": "--format", "description": "Output format (json, csv, text)" },
    { "name": "--verbose", "description": "Enable verbose output" },
    { "name": "--encoding", "description": "File encoding (default: utf-8)" },
    { "name": "--strict", "description": "Enable strict validation mode" }
  ],
  "examples": [
    "pbi-tools extract report.pbix --output ./extracted",
    "pbi-tools compile ./extracted --output report.pbix",
    "pq format query.pq --write",
    "tabular-editor model.bim --script update-partitions.csx"
  ],
  "relatedCommands": ["msdax", "powershell", "sql"]
}