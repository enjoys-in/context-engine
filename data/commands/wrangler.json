{
  "name": "wrangler",
  "description": "Cloudflare Workers CLI",
  "category": "cloud",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "init",
      "description": "Create a new project",
      "examples": [
        "wrangler init my-worker"
      ]
    },
    {
      "name": "dev",
      "description": "Start local dev server",
      "examples": [
        "wrangler dev"
      ]
    },
    {
      "name": "deploy",
      "description": "Deploy to Cloudflare",
      "examples": [
        "wrangler deploy"
      ]
    },
    {
      "name": "publish",
      "description": "Publish worker (alias for deploy)",
      "examples": [
        "wrangler publish"
      ]
    },
    {
      "name": "tail",
      "description": "Stream worker logs",
      "examples": [
        "wrangler tail"
      ]
    },
    {
      "name": "secret put",
      "description": "Set a secret",
      "examples": [
        "wrangler secret put MY_SECRET"
      ]
    },
    {
      "name": "kv",
      "description": "Manage KV storage",
      "examples": [
        "wrangler kv namespace list",
        "wrangler kv key put --namespace-id=xxx key value"
      ]
    },
    {
      "name": "r2",
      "description": "Manage R2 storage",
      "examples": [
        "wrangler r2 bucket list"
      ]
    },
    {
      "name": "d1",
      "description": "Manage D1 databases",
      "examples": [
        "wrangler d1 list",
        "wrangler d1 execute mydb --command 'SELECT * FROM users'"
      ]
    },
    {
      "name": "pages",
      "description": "Manage Pages projects",
      "examples": [
        "wrangler pages deploy dist"
      ]
    },
    {
      "name": "login",
      "description": "Login to Cloudflare",
      "examples": [
        "wrangler login"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "-c",
      "description": "Config file",
      "type": "file"
    },
    {
      "name": "--env",
      "short": "-e",
      "description": "Environment",
      "type": "string"
    }
  ],
  "examples": [
    "wrangler init my-worker",
    "wrangler dev",
    "wrangler deploy",
    "wrangler tail",
    "wrangler pages deploy dist",
    "wrangler d1 list"
  ],
  "relatedCommands": [
    "serverless",
    "miniflare",
    "npm",
    "vercel"
  ]
}
