{
  "name": "choco",
  "description": "Chocolatey package manager for Windows",
  "category": "package-manager",
  "platforms": [
    "windows"
  ],
  "shells": [
    "powershell",
    "cmd"
  ],
  "subcommands": [
    {
      "name": "install",
      "description": "Install packages",
      "args": [
        {
          "name": "packages",
          "description": "Package names",
          "required": true
        }
      ],
      "options": [
        {
          "name": "-y",
          "description": "Confirm all prompts"
        },
        {
          "name": "--version",
          "description": "Specific version",
          "takesValue": true
        },
        {
          "name": "--pre",
          "description": "Include prerelease"
        },
        {
          "name": "--force",
          "shorthand": "-f",
          "description": "Force install"
        },
        {
          "name": "--params",
          "description": "Package parameters",
          "takesValue": true
        },
        {
          "name": "--install-arguments",
          "shorthand": "-ia",
          "description": "Install arguments",
          "takesValue": true
        },
        {
          "name": "--override-arguments",
          "shorthand": "-o",
          "description": "Override default arguments"
        },
        {
          "name": "--x86",
          "description": "Force 32-bit"
        },
        {
          "name": "--ignore-checksums",
          "description": "Ignore checksums"
        },
        {
          "name": "--no-progress",
          "description": "Hide progress"
        },
        {
          "name": "--source",
          "shorthand": "-s",
          "description": "Package source",
          "takesValue": true
        }
      ]
    },
    {
      "name": "uninstall",
      "description": "Uninstall packages",
      "args": [
        {
          "name": "packages",
          "description": "Package names",
          "required": true
        }
      ],
      "options": [
        {
          "name": "-y",
          "description": "Confirm all"
        },
        {
          "name": "--force",
          "description": "Force uninstall"
        },
        {
          "name": "--all-versions",
          "description": "Remove all versions"
        }
      ]
    },
    {
      "name": "upgrade",
      "description": "Upgrade packages",
      "args": [
        {
          "name": "packages",
          "description": "Package names (or all)",
          "required": true
        }
      ],
      "options": [
        {
          "name": "-y",
          "description": "Confirm all"
        },
        {
          "name": "--except",
          "description": "Exclude packages",
          "takesValue": true
        },
        {
          "name": "--pre",
          "description": "Include prerelease"
        },
        {
          "name": "--noop",
          "description": "Dry run / simulation"
        }
      ]
    },
    {
      "name": "search",
      "description": "Search packages",
      "args": [
        {
          "name": "query",
          "description": "Search term",
          "required": true
        }
      ],
      "options": [
        {
          "name": "--exact",
          "description": "Exact match"
        },
        {
          "name": "--source",
          "shorthand": "-s",
          "description": "Source",
          "takesValue": true
        },
        {
          "name": "--pre",
          "description": "Include prerelease"
        },
        {
          "name": "--page",
          "description": "Page number",
          "takesValue": true
        },
        {
          "name": "--page-size",
          "description": "Page size",
          "takesValue": true
        }
      ]
    },
    {
      "name": "list",
      "description": "List installed packages",
      "options": [
        {
          "name": "--local-only",
          "shorthand": "-l",
          "description": "Local only (installed)"
        },
        {
          "name": "--pre",
          "description": "Include prerelease"
        }
      ]
    },
    {
      "name": "info",
      "description": "Get package info",
      "args": [
        {
          "name": "package",
          "description": "Package name",
          "required": true
        }
      ]
    },
    {
      "name": "outdated",
      "description": "Show outdated packages"
    },
    {
      "name": "pin",
      "description": "Pin a package version",
      "subcommands": [
        {
          "name": "add",
          "description": "Pin a package"
        },
        {
          "name": "remove",
          "description": "Unpin a package"
        },
        {
          "name": "list",
          "description": "List pinned packages"
        }
      ]
    },
    {
      "name": "source",
      "description": "Manage sources",
      "subcommands": [
        {
          "name": "add",
          "description": "Add source"
        },
        {
          "name": "remove",
          "description": "Remove source"
        },
        {
          "name": "list",
          "description": "List sources"
        },
        {
          "name": "enable",
          "description": "Enable source"
        },
        {
          "name": "disable",
          "description": "Disable source"
        }
      ]
    },
    {
      "name": "config",
      "description": "Manage config",
      "subcommands": [
        {
          "name": "get",
          "description": "Get config value"
        },
        {
          "name": "set",
          "description": "Set config value"
        },
        {
          "name": "unset",
          "description": "Unset config"
        },
        {
          "name": "list",
          "description": "List config"
        }
      ]
    },
    {
      "name": "feature",
      "description": "Manage features",
      "subcommands": [
        {
          "name": "list",
          "description": "List features"
        },
        {
          "name": "enable",
          "description": "Enable feature"
        },
        {
          "name": "disable",
          "description": "Disable feature"
        }
      ]
    },
    {
      "name": "pack",
      "description": "Create a package from nuspec"
    },
    {
      "name": "push",
      "description": "Push package to repository"
    },
    {
      "name": "new",
      "description": "Create new package template"
    },
    {
      "name": "export",
      "description": "Export installed packages to file"
    }
  ],
  "globalOptions": [
    {
      "name": "-y",
      "description": "Confirm all prompts"
    },
    {
      "name": "-f",
      "description": "Force"
    },
    {
      "name": "--verbose",
      "shorthand": "-v",
      "description": "Verbose output"
    },
    {
      "name": "--debug",
      "description": "Debug output"
    },
    {
      "name": "--trace",
      "description": "Trace output"
    },
    {
      "name": "--no-color",
      "description": "No colors"
    },
    {
      "name": "--limit-output",
      "shorthand": "-r",
      "description": "Limit output for parsing"
    },
    {
      "name": "--timeout",
      "description": "Command timeout",
      "takesValue": true
    },
    {
      "name": "--cache-location",
      "shorthand": "-c",
      "description": "Cache location",
      "takesValue": true
    },
    {
      "name": "--allow-unofficial-build",
      "description": "Allow unofficial build"
    }
  ],
  "examples": [
    {
      "command": "choco install git -y",
      "description": "Install Git"
    },
    {
      "command": "choco install nodejs python3 -y",
      "description": "Install multiple packages"
    },
    {
      "command": "choco install nodejs --version 18.0.0",
      "description": "Specific version"
    },
    {
      "command": "choco upgrade all -y",
      "description": "Upgrade all packages"
    },
    {
      "command": "choco search redis",
      "description": "Search packages"
    },
    {
      "command": "choco list -l",
      "description": "List installed"
    },
    {
      "command": "choco outdated",
      "description": "Show outdated"
    },
    {
      "command": "choco uninstall nodejs -y",
      "description": "Uninstall"
    },
    {
      "command": "choco pin add -n nodejs --version 18.0.0",
      "description": "Pin version"
    },
    {
      "command": "choco export packages.config",
      "description": "Export package list"
    }
  ],
  "relatedCommands": [
    "winget",
    "scoop"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "installed",
        "description": "Installed packages",
        "command": "choco list -l -r 2>$null | Select-Object -Last 20",
        "parser": "lines",
        "cacheFor": 120,
        "requiresCmd": "choco"
      },
      {
        "name": "outdated",
        "description": "Outdated packages",
        "command": "choco outdated -r 2>$null | Select-Object -First 15",
        "parser": "lines",
        "cacheFor": 300,
        "requiresCmd": "choco"
      },
      {
        "name": "sources",
        "description": "Configured sources",
        "command": "choco source list -r 2>$null",
        "parser": "lines",
        "cacheFor": 300,
        "requiresCmd": "choco"
      },
      {
        "name": "pinned",
        "description": "Pinned packages",
        "command": "choco pin list -r 2>$null",
        "parser": "lines",
        "cacheFor": 300,
        "requiresCmd": "choco"
      }
    ]
  }
}
