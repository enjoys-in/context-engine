{
  "name": "hexo",
  "description": "Fast, simple blog framework powered by Node.js",
  "category": "static-site",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "init",
      "description": "Initialize a new Hexo site",
      "examples": [
        "hexo init myblog"
      ]
    },
    {
      "name": "new",
      "description": "Create a new post",
      "examples": [
        "hexo new \"My Post\"",
        "hexo new page about"
      ]
    },
    {
      "name": "generate",
      "description": "Generate static files",
      "examples": [
        "hexo generate",
        "hexo g"
      ]
    },
    {
      "name": "server",
      "description": "Start local server",
      "examples": [
        "hexo server",
        "hexo s"
      ]
    },
    {
      "name": "deploy",
      "description": "Deploy site",
      "examples": [
        "hexo deploy",
        "hexo d"
      ]
    },
    {
      "name": "clean",
      "description": "Clean cache and generated files",
      "examples": [
        "hexo clean"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--debug",
      "description": "Debug mode"
    },
    {
      "name": "--safe",
      "description": "Safe mode (disable plugins)"
    },
    {
      "name": "--silent",
      "description": "Silent mode"
    },
    {
      "name": "--draft",
      "description": "Include draft posts"
    },
    {
      "name": "-p",
      "description": "Custom port",
      "type": "number"
    }
  ],
  "examples": [
    "hexo init myblog",
    "hexo new \"Hello World\"",
    "hexo generate",
    "hexo server",
    "hexo deploy",
    "hexo clean && hexo g && hexo d"
  ],
  "relatedCommands": [
    "hugo",
    "jekyll",
    "gatsby",
    "eleventy"
  ]
}
