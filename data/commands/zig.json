{
  "name": "zig",
  "description": "Zig programming language compiler and build system",
  "category": "language",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "build",
      "description": "Build project using build.zig",
      "examples": [
        "zig build",
        "zig build -Drelease"
      ]
    },
    {
      "name": "build-exe",
      "description": "Compile executable",
      "examples": [
        "zig build-exe src/main.zig"
      ]
    },
    {
      "name": "build-lib",
      "description": "Compile library",
      "examples": [
        "zig build-lib src/lib.zig"
      ]
    },
    {
      "name": "run",
      "description": "Build and run",
      "examples": [
        "zig run src/main.zig"
      ]
    },
    {
      "name": "test",
      "description": "Run tests",
      "examples": [
        "zig test src/main.zig"
      ]
    },
    {
      "name": "init",
      "description": "Initialize new project",
      "examples": [
        "zig init"
      ]
    },
    {
      "name": "fetch",
      "description": "Fetch Zig package",
      "examples": [
        "zig fetch --save url"
      ]
    },
    {
      "name": "fmt",
      "description": "Format source files",
      "examples": [
        "zig fmt src/"
      ]
    },
    {
      "name": "cc",
      "description": "Use Zig as C/C++ compiler",
      "examples": [
        "zig cc -o hello hello.c"
      ]
    },
    {
      "name": "translate-c",
      "description": "Translate C to Zig",
      "examples": [
        "zig translate-c header.h"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "-target",
      "description": "Cross-compilation target",
      "type": "string"
    },
    {
      "name": "-O",
      "description": "Optimization mode (Debug, ReleaseSafe, ReleaseFast, ReleaseSmall)",
      "type": "string"
    }
  ],
  "examples": [
    "zig build",
    "zig run src/main.zig",
    "zig test src/main.zig",
    "zig fmt src/",
    "zig cc -o hello hello.c"
  ],
  "relatedCommands": [
    "gcc",
    "clang",
    "rust",
    "cmake"
  ]
}
