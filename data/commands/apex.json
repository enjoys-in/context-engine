{
  "language": "apex",
  "name": "sfdx",
  "description": "Salesforce CLI for Apex development",
  "category": "cloud",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--help",
      "description": "Show help information"
    },
    {
      "name": "--version",
      "description": "Show version information"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    },
    {
      "name": "--working-dir",
      "description": "Set the working directory",
      "valueHint": "dir",
      "alias": "-d"
    },
    {
      "name": "--env",
      "description": "Set environment (development, staging, production)",
      "valueHint": "name"
    },
    {
      "name": "--timeout",
      "description": "Set operation timeout in seconds",
      "valueHint": "seconds"
    }
  ],
  "subcommands": [
    {
      "name": "force:source:push",
      "description": "Push source to a scratch org",
      "args": [],
      "options": [
        {
          "name": "--forceoverwrite",
          "description": "Overwrite conflicts",
          "type": "boolean",
          "required": false
        }
      ]
    },
    {
      "name": "force:source:pull",
      "description": "Pull source from a scratch org",
      "args": [],
      "options": [
        {
          "name": "--forceoverwrite",
          "description": "Overwrite conflicts",
          "type": "boolean",
          "required": false
        }
      ]
    },
    {
      "name": "force:apex:execute",
      "description": "Execute anonymous Apex code",
      "args": [],
      "options": [
        {
          "name": "--apexcodefile",
          "description": "Path to Apex code file",
          "type": "string",
          "required": false
        }
      ]
    },
    {
      "name": "force:apex:test:run",
      "description": "Run Apex tests",
      "args": [],
      "options": [
        {
          "name": "--classnames",
          "description": "Comma-separated test class names",
          "type": "string",
          "required": false
        },
        {
          "name": "--resultformat",
          "description": "Output format",
          "type": "string",
          "required": false
        }
      ]
    },
    {
      "name": "force:org:create",
      "description": "Create a scratch org",
      "args": [],
      "options": [
        {
          "name": "--definitionfile",
          "description": "Path to org definition file",
          "type": "string",
          "required": false
        }
      ]
    },
    {
      "name": "force:data:soql:query",
      "description": "Execute a SOQL query",
      "args": [],
      "options": [
        {
          "name": "--query",
          "description": "SOQL query string",
          "type": "string",
          "required": true
        }
      ]
    }
  ],
  "examples": [
    {
      "command": "sf project deploy start",
      "description": "Deploy Apex to Salesforce org"
    },
    {
      "command": "sf apex run -f script.apex",
      "description": "Execute anonymous Apex"
    },
    {
      "command": "sf apex test run --code-coverage",
      "description": "Run Apex tests with coverage"
    },
    {
      "command": "sf org login web",
      "description": "Login to Salesforce org"
    }
  ],
  "relatedCommands": []
}
