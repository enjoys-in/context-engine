{
  "name": "sfdx",
  "description": "Salesforce CLI for Apex development",
  "category": "cloud",
  "platforms": ["linux", "macos", "windows"],
  "shells": ["bash", "zsh", "powershell"],
  "subcommands": [
    { "name": "force:source:push", "description": "Push source to a scratch org", "args": [], "options": [{ "name": "--forceoverwrite", "description": "Overwrite conflicts", "type": "boolean", "required": false }] },
    { "name": "force:source:pull", "description": "Pull source from a scratch org", "args": [], "options": [{ "name": "--forceoverwrite", "description": "Overwrite conflicts", "type": "boolean", "required": false }] },
    { "name": "force:apex:execute", "description": "Execute anonymous Apex code", "args": [], "options": [{ "name": "--apexcodefile", "description": "Path to Apex code file", "type": "string", "required": false }] },
    { "name": "force:apex:test:run", "description": "Run Apex tests", "args": [], "options": [{ "name": "--classnames", "description": "Comma-separated test class names", "type": "string", "required": false }, { "name": "--resultformat", "description": "Output format", "type": "string", "required": false }] },
    { "name": "force:org:create", "description": "Create a scratch org", "args": [], "options": [{ "name": "--definitionfile", "description": "Path to org definition file", "type": "string", "required": false }] },
    { "name": "force:data:soql:query", "description": "Execute a SOQL query", "args": [], "options": [{ "name": "--query", "description": "SOQL query string", "type": "string", "required": true }] }
  ]
}
