{
  "name": "head",
  "description": "Output the first part of files",
  "category": "coreutils",
  "platforms": [
    "linux",
    "macos"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "-n",
      "description": "Print the first N lines",
      "type": "number"
    },
    {
      "name": "-c",
      "description": "Print the first N bytes",
      "type": "number"
    },
    {
      "name": "-q",
      "description": "Never print headers for multiple files"
    },
    {
      "name": "-v",
      "description": "Always print headers"
    }
  ],
  "examples": [
    "head file.txt",
    "head -n 20 file.txt",
    "head -c 100 file.txt",
    "head -n 5 *.log",
    "cat log.txt | head -n 50"
  ],
  "relatedCommands": [
    "tail",
    "cat",
    "less",
    "more"
  ]
}
