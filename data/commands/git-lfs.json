{
  "name": "git-lfs",
  "description": "Git Large File Storage — manage large files with Git",
  "category": "git",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "install",
      "description": "Set up Git LFS",
      "examples": [
        "git lfs install"
      ]
    },
    {
      "name": "track",
      "description": "Track file patterns",
      "examples": [
        "git lfs track '*.psd'",
        "git lfs track '*.zip'"
      ]
    },
    {
      "name": "untrack",
      "description": "Stop tracking patterns",
      "examples": [
        "git lfs untrack '*.psd'"
      ]
    },
    {
      "name": "ls-files",
      "description": "List tracked LFS files",
      "examples": [
        "git lfs ls-files"
      ]
    },
    {
      "name": "fetch",
      "description": "Download LFS objects",
      "examples": [
        "git lfs fetch"
      ]
    },
    {
      "name": "pull",
      "description": "Fetch and checkout LFS files",
      "examples": [
        "git lfs pull"
      ]
    },
    {
      "name": "push",
      "description": "Push LFS objects",
      "examples": [
        "git lfs push origin main"
      ]
    },
    {
      "name": "status",
      "description": "Show LFS status",
      "examples": [
        "git lfs status"
      ]
    },
    {
      "name": "migrate",
      "description": "Migrate existing files to LFS",
      "examples": [
        "git lfs migrate import --include='*.bin'"
      ]
    }
  ],
  "globalOptions": [],
  "examples": [
    "git lfs install",
    "git lfs track '*.psd'",
    "git lfs ls-files",
    "git lfs migrate import --include='*.bin'",
    "git lfs fetch --all"
  ],
  "relatedCommands": [
    "git",
    "github-cli",
    "gitlab-cli"
  ]
}
