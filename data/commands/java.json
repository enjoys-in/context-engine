{
  "language": "java",
  "name": "java",
  "description": "Java application launcher",
  "category": "runtime",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "-version",
      "description": "Display version"
    },
    {
      "name": "-jar",
      "description": "Execute a JAR file",
      "type": "file"
    },
    {
      "name": "-cp",
      "description": "Classpath",
      "type": "path"
    },
    {
      "name": "-classpath",
      "description": "Classpath (alias)",
      "type": "path"
    },
    {
      "name": "-Xmx",
      "description": "Maximum heap size",
      "type": "string"
    },
    {
      "name": "-Xms",
      "description": "Initial heap size",
      "type": "string"
    },
    {
      "name": "-Xss",
      "description": "Thread stack size",
      "type": "string"
    },
    {
      "name": "-D",
      "description": "Set system property",
      "type": "string"
    },
    {
      "name": "-server",
      "description": "Use server JVM"
    },
    {
      "name": "-verbose",
      "description": "Verbose output"
    },
    {
      "name": "--enable-preview",
      "description": "Enable preview features"
    },
    {
      "name": "-ea",
      "description": "Enable assertions"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    }
  ],
  "subcommands": [],
  "examples": [
    "java -version",
    "java -jar app.jar",
    "java -Xmx512m -jar app.jar",
    "java -cp lib/*:. com.example.Main",
    "java -Dserver.port=8080 -jar app.jar",
    "java --enable-preview Main.java"
  ],
  "relatedCommands": [
    "javac",
    "mvn",
    "gradle",
    "jpackage",
    "jshell",
    "jar"
  ]
}
