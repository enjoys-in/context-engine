{
  "language": "msdax",
  "name": "dax",
  "description": "DAX — Data Analysis Expressions tools for Power BI and SSAS",
  "category": "tool",
  "platforms": [
    "windows",
    "linux",
    "macos"
  ],
  "shells": [
    "powershell",
    "bash",
    "zsh"
  ],
  "globalOptions": [
    {
      "name": "--server",
      "description": "Analysis Services server connection string"
    },
    {
      "name": "--database",
      "description": "Target database name"
    },
    {
      "name": "--output",
      "description": "Output file path"
    },
    {
      "name": "--format",
      "description": "Output format (csv, json, xlsx)"
    },
    {
      "name": "--timeout",
      "description": "Query timeout in seconds"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    },
    {
      "name": "--working-dir",
      "description": "Set the working directory",
      "valueHint": "dir",
      "alias": "-d"
    }
  ],
  "subcommands": [
    {
      "name": "format",
      "description": "Format DAX expressions using DAX Formatter",
      "args": [
        "expression"
      ],
      "options": [
        "--short",
        "--long"
      ]
    },
    {
      "name": "analyze",
      "description": "Analyze DAX model using DAX Studio",
      "args": [
        "connection"
      ],
      "options": [
        "--query",
        "--output"
      ]
    },
    {
      "name": "query",
      "description": "Execute DAX query against tabular model",
      "args": [
        "query"
      ],
      "options": [
        "--server",
        "--database"
      ]
    },
    {
      "name": "export",
      "description": "Export DAX query results to file",
      "args": [
        "query"
      ],
      "options": [
        "--format",
        "--output"
      ]
    },
    {
      "name": "benchmark",
      "description": "Benchmark DAX query performance",
      "args": [
        "query"
      ],
      "options": [
        "--iterations",
        "--cold-cache"
      ]
    }
  ],
  "examples": [
    "daxstudio.exe -c \"Data Source=localhost\\SSAS\"",
    "EVALUATE SUMMARIZECOLUMNS(Sales[Region], \"Total\", SUM(Sales[Amount]))",
    "tabular-editor model.bim --script analyze.csx",
    "pbi-tools extract report.pbix --output ./extracted"
  ],
  "relatedCommands": [
    "powerquery",
    "sql",
    "powershell"
  ]
}
