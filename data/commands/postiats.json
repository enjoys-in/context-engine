{
  "language": "postiats",
  "name": "patscc",
  "description": "ATS/Postiats — Applied Type System compiler with dependent types",
  "category": "language",
  "platforms": [
    "linux",
    "macos"
  ],
  "shells": [
    "bash",
    "zsh"
  ],
  "globalOptions": [
    {
      "name": "-o",
      "description": "Set output file name"
    },
    {
      "name": "-tcats",
      "description": "Type-check only"
    },
    {
      "name": "-ccats",
      "description": "Compile to C only"
    },
    {
      "name": "-DATS",
      "description": "Define an ATS compile-time symbol"
    },
    {
      "name": "-IATS",
      "description": "Add ATS include search path"
    },
    {
      "name": "-cleanaft",
      "description": "Clean generated C files after compilation"
    },
    {
      "name": "-atsccomp",
      "description": "Specify the C compiler to use"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    }
  ],
  "subcommands": [
    {
      "name": "file.dats",
      "description": "Compile an ATS dynamic file",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "-o output file.dats",
      "description": "Compile with named output executable",
      "args": [
        "output",
        "file"
      ],
      "options": []
    },
    {
      "name": "-tcats file.dats",
      "description": "Type-check only without compiling to C",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "-ccats file.dats",
      "description": "Compile to C without generating executable",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "file.dats -DATS_MEMALLOC_LIBC",
      "description": "Compile with libc memory allocation",
      "args": [
        "file"
      ],
      "options": []
    }
  ],
  "examples": [
    "patscc -o hello hello.dats",
    "patscc -tcats mylib.dats",
    "patscc -DATS_MEMALLOC_LIBC -o app main.dats utils.dats",
    "patscc -ccats module.dats",
    "patsopt --dynamic file.dats"
  ],
  "relatedCommands": [
    "gcc",
    "make",
    "c"
  ]
}
