{
  "name": "pulumi",
  "description": "Infrastructure as Code using real programming languages (TypeScript, Python, Go, C#, Java)",
  "category": "devops",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell",
    "fish"
  ],
  "subcommands": [
    {
      "name": "new",
      "description": "Create a new Pulumi project",
      "args": [
        {
          "name": "template",
          "description": "Template name",
          "required": false
        }
      ],
      "options": [
        {
          "name": "--name",
          "shorthand": "-n",
          "description": "Project name",
          "takesValue": true
        },
        {
          "name": "--dir",
          "description": "Target directory",
          "takesValue": true
        },
        {
          "name": "--description",
          "shorthand": "-d",
          "description": "Project description",
          "takesValue": true
        },
        {
          "name": "--stack",
          "shorthand": "-s",
          "description": "Stack name",
          "takesValue": true
        },
        {
          "name": "--yes",
          "shorthand": "-y",
          "description": "Skip prompts"
        },
        {
          "name": "--force",
          "shorthand": "-f",
          "description": "Force create in non-empty dir"
        }
      ]
    },
    {
      "name": "up",
      "description": "Create or update resources",
      "options": [
        {
          "name": "--stack",
          "shorthand": "-s",
          "description": "Stack name",
          "takesValue": true
        },
        {
          "name": "--yes",
          "shorthand": "-y",
          "description": "Skip confirmation"
        },
        {
          "name": "--parallel",
          "shorthand": "-p",
          "description": "Parallelism",
          "takesValue": true
        },
        {
          "name": "--refresh",
          "shorthand": "-r",
          "description": "Refresh state first"
        },
        {
          "name": "--target",
          "shorthand": "-t",
          "description": "Target specific resources",
          "takesValue": true
        },
        {
          "name": "--diff",
          "description": "Show detailed diff"
        },
        {
          "name": "--replace",
          "description": "Force replace resource",
          "takesValue": true
        }
      ]
    },
    {
      "name": "preview",
      "description": "Show preview of updates",
      "options": [
        {
          "name": "--stack",
          "shorthand": "-s",
          "description": "Stack name",
          "takesValue": true
        },
        {
          "name": "--diff",
          "description": "Show detailed diff"
        },
        {
          "name": "--json",
          "shorthand": "-j",
          "description": "JSON output"
        }
      ]
    },
    {
      "name": "destroy",
      "description": "Destroy all resources",
      "options": [
        {
          "name": "--stack",
          "shorthand": "-s",
          "description": "Stack name",
          "takesValue": true
        },
        {
          "name": "--yes",
          "shorthand": "-y",
          "description": "Skip confirmation"
        },
        {
          "name": "--target",
          "shorthand": "-t",
          "description": "Target specific resources",
          "takesValue": true
        }
      ]
    },
    {
      "name": "stack",
      "description": "Manage stacks",
      "subcommands": [
        {
          "name": "init",
          "description": "Create new stack",
          "args": [
            {
              "name": "name",
              "description": "Stack name",
              "required": true
            }
          ]
        },
        {
          "name": "ls",
          "description": "List stacks"
        },
        {
          "name": "select",
          "description": "Switch stack",
          "args": [
            {
              "name": "name",
              "description": "Stack name",
              "required": true
            }
          ]
        },
        {
          "name": "rm",
          "description": "Remove a stack"
        },
        {
          "name": "output",
          "description": "Show stack outputs"
        },
        {
          "name": "export",
          "description": "Export stack state"
        },
        {
          "name": "import",
          "description": "Import stack state"
        },
        {
          "name": "tag",
          "description": "Manage stack tags"
        },
        {
          "name": "history",
          "description": "Show update history"
        }
      ]
    },
    {
      "name": "config",
      "description": "Manage configuration",
      "subcommands": [
        {
          "name": "set",
          "description": "Set config value"
        },
        {
          "name": "get",
          "description": "Get config value"
        },
        {
          "name": "rm",
          "description": "Remove config key"
        },
        {
          "name": "refresh",
          "description": "Update config from current values"
        }
      ]
    },
    {
      "name": "refresh",
      "description": "Refresh state with actual cloud state"
    },
    {
      "name": "import",
      "description": "Import existing resource"
    },
    {
      "name": "cancel",
      "description": "Cancel in-progress update"
    },
    {
      "name": "login",
      "description": "Login to Pulumi Cloud",
      "options": [
        {
          "name": "--local",
          "shorthand": "-l",
          "description": "Use local backend"
        }
      ]
    },
    {
      "name": "logout",
      "description": "Logout from Pulumi Cloud"
    },
    {
      "name": "whoami",
      "description": "Show current user"
    },
    {
      "name": "plugin",
      "description": "Plugin management",
      "subcommands": [
        {
          "name": "install",
          "description": "Install plugin"
        },
        {
          "name": "ls",
          "description": "List plugins"
        },
        {
          "name": "rm",
          "description": "Remove plugin"
        }
      ]
    },
    {
      "name": "watch",
      "description": "Watch for file changes and update"
    },
    {
      "name": "logs",
      "description": "Show aggregated logs"
    },
    {
      "name": "about",
      "description": "Show environment info"
    }
  ],
  "globalOptions": [
    {
      "name": "--cwd",
      "shorthand": "-C",
      "description": "Working directory",
      "takesValue": true
    },
    {
      "name": "--stack",
      "shorthand": "-s",
      "description": "Stack name",
      "takesValue": true
    },
    {
      "name": "--color",
      "description": "Colorize output (always, never, raw, auto)",
      "takesValue": true
    },
    {
      "name": "--logflow",
      "description": "Log to stderr"
    },
    {
      "name": "--logtostderr",
      "description": "Log to stderr"
    },
    {
      "name": "--verbose",
      "shorthand": "-v",
      "description": "Verbose (0-9)",
      "takesValue": true
    },
    {
      "name": "--help",
      "shorthand": "-h",
      "description": "Show help"
    }
  ],
  "examples": [
    {
      "command": "pulumi new typescript",
      "description": "Create TypeScript project"
    },
    {
      "command": "pulumi up",
      "description": "Deploy infrastructure"
    },
    {
      "command": "pulumi up -y",
      "description": "Deploy without confirmation"
    },
    {
      "command": "pulumi preview --diff",
      "description": "Preview with diff"
    },
    {
      "command": "pulumi destroy -y",
      "description": "Destroy all resources"
    },
    {
      "command": "pulumi stack ls",
      "description": "List stacks"
    },
    {
      "command": "pulumi config set aws:region us-east-1",
      "description": "Set config"
    },
    {
      "command": "pulumi stack output",
      "description": "Show outputs"
    }
  ],
  "relatedCommands": [
    "terraform",
    "terragrunt"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "stacks",
        "description": "Available stacks",
        "command": "pulumi stack ls --json 2>/dev/null",
        "parser": "json",
        "cacheFor": 30,
        "requiresCmd": "pulumi"
      },
      {
        "name": "current_stack",
        "description": "Current stack",
        "command": "pulumi stack --show-name 2>/dev/null",
        "parser": "text",
        "cacheFor": 15,
        "requiresCmd": "pulumi"
      },
      {
        "name": "config",
        "description": "Stack configuration",
        "command": "pulumi config --json 2>/dev/null",
        "parser": "json",
        "cacheFor": 30,
        "requiresCmd": "pulumi"
      },
      {
        "name": "project",
        "description": "Project configuration",
        "command": "cat Pulumi.yaml 2>/dev/null",
        "parser": "text",
        "cacheFor": 60
      },
      {
        "name": "outputs",
        "description": "Stack outputs",
        "command": "pulumi stack output --json 2>/dev/null",
        "parser": "json",
        "cacheFor": 30,
        "requiresCmd": "pulumi"
      }
    ]
  }
}
