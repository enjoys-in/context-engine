{
  "language": "mdx",
  "name": "mdx",
  "description": "MDX — Markdown with JSX components, compiler and CLI",
  "category": "development",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--output-format",
      "description": "Output format: program or function-body"
    },
    {
      "name": "--jsx",
      "description": "Keep JSX instead of compiling to React.createElement"
    },
    {
      "name": "--development",
      "description": "Enable development mode with extra diagnostics"
    },
    {
      "name": "--remarkPlugins",
      "description": "Remark plugins to use"
    },
    {
      "name": "--rehypePlugins",
      "description": "Rehype plugins to use"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    }
  ],
  "subcommands": [
    {
      "name": "compile",
      "description": "Compile MDX files to JavaScript",
      "args": [
        "file.mdx"
      ],
      "options": [
        "--output-format",
        "--jsx"
      ]
    },
    {
      "name": "evaluate",
      "description": "Compile and evaluate MDX in one step",
      "args": [
        "file.mdx"
      ],
      "options": []
    },
    {
      "name": "lint",
      "description": "Lint MDX files with remark-lint",
      "args": [
        "files"
      ],
      "options": [
        "--config"
      ]
    },
    {
      "name": "format",
      "description": "Format MDX files with prettier",
      "args": [
        "files"
      ],
      "options": [
        "--write"
      ]
    },
    {
      "name": "build",
      "description": "Build MDX content with next-mdx-remote or contentlayer",
      "args": [],
      "options": [
        "--config"
      ]
    }
  ],
  "examples": [
    "npx @mdx-js/mdx compile doc.mdx",
    "npx prettier --write '**/*.mdx'",
    "npx remark --use remark-mdx --use remark-lint 'docs/**/*.mdx'",
    "next build  # with @next/mdx configured",
    "npx contentlayer build"
  ],
  "relatedCommands": [
    "markdown",
    "react",
    "next",
    "prettier"
  ]
}
