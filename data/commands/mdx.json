{
  "name": "mdx",
  "description": "MDX — Markdown with JSX components, compiler and CLI",
  "category": "development",
  "platforms": ["linux", "macos", "windows"],
  "shells": ["bash", "zsh", "powershell"],
  "subcommands": [
    { "name": "compile", "description": "Compile MDX files to JavaScript", "args": ["file.mdx"], "options": ["--output-format", "--jsx"] },
    { "name": "evaluate", "description": "Compile and evaluate MDX in one step", "args": ["file.mdx"], "options": [] },
    { "name": "lint", "description": "Lint MDX files with remark-lint", "args": ["files"], "options": ["--config"] },
    { "name": "format", "description": "Format MDX files with prettier", "args": ["files"], "options": ["--write"] },
    { "name": "build", "description": "Build MDX content with next-mdx-remote or contentlayer", "args": [], "options": ["--config"] }
  ],
  "globalOptions": [
    { "name": "--output-format", "description": "Output format: program or function-body" },
    { "name": "--jsx", "description": "Keep JSX instead of compiling to React.createElement" },
    { "name": "--development", "description": "Enable development mode with extra diagnostics" },
    { "name": "--remarkPlugins", "description": "Remark plugins to use" },
    { "name": "--rehypePlugins", "description": "Rehype plugins to use" }
  ],
  "examples": [
    "npx @mdx-js/mdx compile doc.mdx",
    "npx prettier --write '**/*.mdx'",
    "npx remark --use remark-mdx --use remark-lint 'docs/**/*.mdx'",
    "next build  # with @next/mdx configured",
    "npx contentlayer build"
  ],
  "relatedCommands": ["markdown", "react", "next", "prettier"]
}