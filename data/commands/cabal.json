{
  "name": "cabal",
  "description": "Haskell build tool and package manager",
  "category": "languages",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "init",
      "description": "Initialize project",
      "examples": [
        "cabal init"
      ]
    },
    {
      "name": "build",
      "description": "Build project",
      "examples": [
        "cabal build"
      ]
    },
    {
      "name": "run",
      "description": "Build and run",
      "examples": [
        "cabal run"
      ]
    },
    {
      "name": "test",
      "description": "Run tests",
      "examples": [
        "cabal test"
      ]
    },
    {
      "name": "install",
      "description": "Install packages",
      "examples": [
        "cabal install pandoc"
      ]
    },
    {
      "name": "update",
      "description": "Update package list",
      "examples": [
        "cabal update"
      ]
    },
    {
      "name": "clean",
      "description": "Clean build artifacts",
      "examples": [
        "cabal clean"
      ]
    },
    {
      "name": "repl",
      "description": "Start interactive session",
      "examples": [
        "cabal repl"
      ]
    },
    {
      "name": "haddock",
      "description": "Generate documentation",
      "examples": [
        "cabal haddock"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--enable-tests",
      "description": "Enable test suites"
    },
    {
      "name": "--enable-benchmarks",
      "description": "Enable benchmarks"
    },
    {
      "name": "-j",
      "description": "Parallel build jobs",
      "type": "number"
    },
    {
      "name": "-O",
      "description": "Optimization level",
      "type": "number"
    }
  ],
  "examples": [
    "cabal init",
    "cabal build",
    "cabal run",
    "cabal test",
    "cabal update && cabal install pandoc"
  ],
  "relatedCommands": [
    "ghc",
    "stack",
    "ghci",
    "haskell"
  ]
}
