{
  "name": "django-admin",
  "description": "Django's command-line utility for administrative tasks",
  "category": "python-ecosystem",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell",
    "fish"
  ],
  "subcommands": [
    {
      "name": "startproject",
      "description": "Create a new Django project",
      "args": [
        {
          "name": "name",
          "description": "Project name",
          "required": true
        },
        {
          "name": "directory",
          "description": "Target directory",
          "required": false
        }
      ],
      "options": [
        {
          "name": "--template",
          "description": "Project template",
          "takesValue": true
        }
      ]
    },
    {
      "name": "startapp",
      "description": "Create a new Django app",
      "args": [
        {
          "name": "name",
          "description": "App name",
          "required": true
        },
        {
          "name": "directory",
          "description": "Target directory",
          "required": false
        }
      ]
    },
    {
      "name": "runserver",
      "description": "Start development server",
      "args": [
        {
          "name": "addrport",
          "description": "Address:port (default 127.0.0.1:8000)",
          "required": false
        }
      ],
      "options": [
        {
          "name": "--noreload",
          "description": "Disable auto-reload"
        },
        {
          "name": "--nothreading",
          "description": "Disable threading"
        }
      ]
    },
    {
      "name": "migrate",
      "description": "Run database migrations",
      "args": [
        {
          "name": "app_label",
          "description": "App to migrate",
          "required": false
        },
        {
          "name": "migration_name",
          "description": "Target migration",
          "required": false
        }
      ],
      "options": [
        {
          "name": "--fake",
          "description": "Mark migrations as applied"
        },
        {
          "name": "--fake-initial",
          "description": "Fake if tables exist"
        },
        {
          "name": "--plan",
          "description": "Show migration plan"
        },
        {
          "name": "--run-syncdb",
          "description": "Create tables for unmanaged apps"
        },
        {
          "name": "--database",
          "description": "Database alias",
          "takesValue": true
        }
      ]
    },
    {
      "name": "makemigrations",
      "description": "Create new migrations",
      "args": [
        {
          "name": "app_label",
          "description": "App to make migrations for",
          "required": false
        }
      ],
      "options": [
        {
          "name": "--empty",
          "description": "Create empty migration"
        },
        {
          "name": "--dry-run",
          "description": "Preview without writing"
        },
        {
          "name": "--merge",
          "description": "Merge conflicting migrations"
        },
        {
          "name": "--name",
          "shorthand": "-n",
          "description": "Migration name",
          "takesValue": true
        },
        {
          "name": "--check",
          "description": "Exit with error if changes detected"
        }
      ]
    },
    {
      "name": "showmigrations",
      "description": "Show all migrations",
      "args": [
        {
          "name": "app_label",
          "description": "App to show",
          "required": false
        }
      ],
      "options": [
        {
          "name": "--list",
          "shorthand": "-l",
          "description": "List format"
        },
        {
          "name": "--plan",
          "shorthand": "-p",
          "description": "Plan format"
        }
      ]
    },
    {
      "name": "createsuperuser",
      "description": "Create a superuser",
      "options": [
        {
          "name": "--username",
          "description": "Username",
          "takesValue": true
        },
        {
          "name": "--email",
          "description": "Email",
          "takesValue": true
        },
        {
          "name": "--noinput",
          "description": "Non-interactive mode"
        }
      ]
    },
    {
      "name": "shell",
      "description": "Open Django shell",
      "options": [
        {
          "name": "--interface",
          "shorthand": "-i",
          "description": "Interface (ipython, bpython, python)",
          "takesValue": true
        }
      ]
    },
    {
      "name": "dbshell",
      "description": "Open database shell",
      "options": [
        {
          "name": "--database",
          "description": "Database alias",
          "takesValue": true
        }
      ]
    },
    {
      "name": "collectstatic",
      "description": "Collect static files",
      "options": [
        {
          "name": "--noinput",
          "description": "No prompts"
        },
        {
          "name": "--clear",
          "description": "Clear before collecting"
        },
        {
          "name": "--link",
          "shorthand": "-l",
          "description": "Symlink instead of copy"
        },
        {
          "name": "--dry-run",
          "description": "Preview changes"
        }
      ]
    },
    {
      "name": "test",
      "description": "Run tests",
      "args": [
        {
          "name": "test_label",
          "description": "Test module/class/method",
          "required": false
        }
      ],
      "options": [
        {
          "name": "--verbosity",
          "shorthand": "-v",
          "description": "Verbosity level",
          "takesValue": true
        },
        {
          "name": "--keepdb",
          "description": "Preserve test database"
        },
        {
          "name": "--parallel",
          "description": "Run tests in parallel",
          "takesValue": true
        },
        {
          "name": "--failfast",
          "description": "Stop on first failure"
        },
        {
          "name": "--reverse",
          "shorthand": "-r",
          "description": "Reverse test order"
        }
      ]
    },
    {
      "name": "check",
      "description": "Check for project issues",
      "options": [
        {
          "name": "--deploy",
          "description": "Check deployment settings"
        },
        {
          "name": "--tag",
          "shorthand": "-t",
          "description": "Filter by tag",
          "takesValue": true
        }
      ]
    },
    {
      "name": "inspectdb",
      "description": "Generate models from existing database",
      "options": [
        {
          "name": "--database",
          "description": "Database alias",
          "takesValue": true
        }
      ]
    },
    {
      "name": "dumpdata",
      "description": "Export data as fixtures",
      "args": [
        {
          "name": "app_label",
          "description": "App to export",
          "required": false
        }
      ],
      "options": [
        {
          "name": "--format",
          "description": "Format (json, xml, yaml)",
          "takesValue": true
        },
        {
          "name": "--indent",
          "description": "Indentation",
          "takesValue": true
        },
        {
          "name": "--output",
          "shorthand": "-o",
          "description": "Output file",
          "takesValue": true
        }
      ]
    },
    {
      "name": "loaddata",
      "description": "Load fixture data",
      "args": [
        {
          "name": "fixture",
          "description": "Fixture file",
          "required": true
        }
      ]
    },
    {
      "name": "flush",
      "description": "Clear all data from database"
    },
    {
      "name": "sqlmigrate",
      "description": "Show SQL for a migration",
      "args": [
        {
          "name": "app_label",
          "description": "App",
          "required": true
        },
        {
          "name": "migration_name",
          "description": "Migration",
          "required": true
        }
      ]
    },
    {
      "name": "sendtestemail",
      "description": "Send a test email",
      "args": [
        {
          "name": "email",
          "description": "Email address",
          "required": true
        }
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--settings",
      "description": "Settings module",
      "takesValue": true
    },
    {
      "name": "--pythonpath",
      "description": "Python path",
      "takesValue": true
    },
    {
      "name": "--traceback",
      "description": "Show full traceback"
    },
    {
      "name": "--verbosity",
      "shorthand": "-v",
      "description": "Verbosity (0-3)",
      "takesValue": true
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--help",
      "shorthand": "-h",
      "description": "Show help"
    },
    {
      "name": "--version",
      "description": "Show version"
    }
  ],
  "examples": [
    {
      "command": "django-admin startproject mysite",
      "description": "Create a new project"
    },
    {
      "command": "python manage.py runserver",
      "description": "Start dev server"
    },
    {
      "command": "python manage.py makemigrations",
      "description": "Create migrations"
    },
    {
      "command": "python manage.py migrate",
      "description": "Apply migrations"
    },
    {
      "command": "python manage.py createsuperuser",
      "description": "Create admin user"
    },
    {
      "command": "python manage.py test myapp.tests.TestUser",
      "description": "Run specific test"
    },
    {
      "command": "python manage.py collectstatic --noinput",
      "description": "Collect static files"
    },
    {
      "command": "python manage.py shell",
      "description": "Open Django shell"
    }
  ],
  "relatedCommands": [
    "python",
    "gunicorn",
    "uvicorn"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "django_apps",
        "description": "Installed Django apps",
        "command": "python manage.py showmigrations --list 2>/dev/null | grep '^[a-z]' | head -20",
        "parser": "lines",
        "cacheFor": 60
      },
      {
        "name": "manage_py",
        "description": "Django manage.py existence",
        "command": "ls manage.py 2>/dev/null",
        "parser": "text",
        "cacheFor": 30
      },
      {
        "name": "settings_module",
        "description": "Django settings module",
        "command": "grep 'DJANGO_SETTINGS_MODULE' manage.py 2>/dev/null",
        "parser": "text",
        "cacheFor": 120
      },
      {
        "name": "migrations_status",
        "description": "Migration status",
        "command": "python manage.py showmigrations --plan 2>/dev/null | tail -10",
        "parser": "text",
        "cacheFor": 30
      },
      {
        "name": "urls",
        "description": "URL patterns",
        "command": "find . -name 'urls.py' -not -path '*/venv/*' 2>/dev/null",
        "parser": "lines",
        "cacheFor": 60
      }
    ]
  }
}
