{
  "language": "graphql",
  "name": "graphql-codegen",
  "description": "GraphQL Code Generator and CLI tools for schema management",
  "category": "development",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--config",
      "description": "Path to codegen config file (default: codegen.ts)"
    },
    {
      "name": "--watch",
      "description": "Watch for changes and regenerate"
    },
    {
      "name": "--overwrite",
      "description": "Overwrite existing generated files"
    },
    {
      "name": "--profile",
      "description": "Enable performance profiling"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose logging"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    }
  ],
  "subcommands": [
    {
      "name": "generate",
      "description": "Generate code from GraphQL schema and operations",
      "args": [],
      "options": [
        "--config",
        "--watch",
        "--overwrite"
      ]
    },
    {
      "name": "init",
      "description": "Initialize a codegen configuration file",
      "args": [],
      "options": []
    },
    {
      "name": "get-schema",
      "description": "Download and save GraphQL schema from endpoint",
      "args": [
        "endpoint"
      ],
      "options": [
        "--header",
        "--output"
      ]
    },
    {
      "name": "validate",
      "description": "Validate GraphQL operations against schema",
      "args": [
        "schema",
        "documents"
      ],
      "options": [
        "--strict"
      ]
    },
    {
      "name": "inspect",
      "description": "Inspect a GraphQL schema and display type information",
      "args": [
        "schema"
      ],
      "options": [
        "--format"
      ]
    },
    {
      "name": "diff",
      "description": "Compare two GraphQL schemas for breaking changes",
      "args": [
        "old-schema",
        "new-schema"
      ],
      "options": [
        "--fail-on-breaking"
      ]
    }
  ],
  "examples": [
    "npx graphql-codegen --config codegen.ts",
    "npx graphql-codegen --watch",
    "npx graphql-codegen init",
    "graphql-inspector diff old.graphql new.graphql --fail-on-breaking",
    "npx get-graphql-schema https://api.example.com/graphql > schema.graphql"
  ],
  "relatedCommands": [
    "npm",
    "typescript",
    "node",
    "apollo"
  ]
}
