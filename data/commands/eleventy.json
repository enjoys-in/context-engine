{
  "name": "eleventy",
  "description": "Simple static site generator (11ty)",
  "category": "static-site",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "--input",
      "description": "Input directory",
      "type": "string"
    },
    {
      "name": "--output",
      "description": "Output directory",
      "type": "string"
    },
    {
      "name": "--serve",
      "description": "Start dev server with live reload"
    },
    {
      "name": "--watch",
      "description": "Watch for changes"
    },
    {
      "name": "--port",
      "description": "Server port",
      "type": "number"
    },
    {
      "name": "--formats",
      "description": "Template formats to process",
      "type": "string"
    },
    {
      "name": "--quiet",
      "description": "Suppress output"
    },
    {
      "name": "--config",
      "description": "Config file path",
      "type": "file"
    },
    {
      "name": "--dryrun",
      "description": "Simulate without writing"
    }
  ],
  "examples": [
    "eleventy",
    "eleventy --serve",
    "npx @11ty/eleventy --serve",
    "eleventy --input=src --output=dist",
    "eleventy --serve --port=8080"
  ],
  "relatedCommands": [
    "hugo",
    "jekyll",
    "gatsby",
    "astro"
  ]
}
