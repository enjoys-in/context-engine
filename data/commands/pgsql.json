{
  "language": "pgsql",
  "name": "psql",
  "description": "PostgreSQL command-line tool",
  "category": "development",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--help",
      "description": "Show help information"
    },
    {
      "name": "--version",
      "description": "Show version information"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    },
    {
      "name": "--working-dir",
      "description": "Set the working directory",
      "valueHint": "dir",
      "alias": "-d"
    }
  ],
  "subcommands": [
    {
      "name": "-U user -d dbname",
      "description": "Connect to database",
      "args": [],
      "options": []
    },
    {
      "name": "-f file.sql",
      "description": "Execute SQL file",
      "args": [],
      "options": []
    },
    {
      "name": "-c 'query'",
      "description": "Execute single query",
      "args": [],
      "options": []
    },
    {
      "name": "--list",
      "description": "List databases",
      "args": [],
      "options": []
    },
    {
      "name": "connect",
      "description": "Connect to database",
      "usage": "psql -h localhost -U user dbname"
    },
    {
      "name": "dump",
      "description": "Dump database",
      "usage": "pg_dump -h localhost -U user dbname > backup.sql"
    },
    {
      "name": "restore",
      "description": "Restore database",
      "usage": "pg_restore -h localhost -U user -d dbname backup.dump"
    },
    {
      "name": "vacuum",
      "description": "Vacuum database",
      "usage": "vacuumdb -h localhost -U user dbname"
    }
  ],
  "examples": [
    {
      "command": "psql -h localhost -U postgres mydb",
      "description": "Connect to PostgreSQL database"
    },
    {
      "command": "pg_dump -h localhost -U postgres mydb > backup.sql",
      "description": "Dump database to SQL"
    },
    {
      "command": "pg_restore -d mydb backup.dump",
      "description": "Restore from dump file"
    },
    {
      "command": "createdb mydb",
      "description": "Create a new database"
    }
  ],
  "relatedCommands": []
}
