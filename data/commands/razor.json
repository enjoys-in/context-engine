{
  "language": "razor",
  "name": "dotnet",
  "description": "Razor Pages — ASP.NET Core web framework via .NET CLI",
  "category": "development",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--configuration",
      "description": "Build configuration (Debug, Release)"
    },
    {
      "name": "--output",
      "description": "Output directory"
    },
    {
      "name": "--urls",
      "description": "Set listening URLs"
    },
    {
      "name": "--launch-profile",
      "description": "Launch profile from launchSettings.json"
    },
    {
      "name": "--no-https",
      "description": "Disable HTTPS in project template"
    },
    {
      "name": "--auth",
      "description": "Authentication type (None, Individual, etc.)"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    }
  ],
  "subcommands": [
    {
      "name": "new razor -o project",
      "description": "Create a new Razor Pages project",
      "args": [
        "name"
      ],
      "options": [
        "--auth",
        "--no-https"
      ]
    },
    {
      "name": "run",
      "description": "Build and run the Razor Pages application",
      "args": [],
      "options": [
        "--urls",
        "--launch-profile"
      ]
    },
    {
      "name": "watch run",
      "description": "Run with hot reload on file changes",
      "args": [],
      "options": []
    },
    {
      "name": "build",
      "description": "Build the Razor Pages project",
      "args": [],
      "options": [
        "--configuration"
      ]
    },
    {
      "name": "publish",
      "description": "Publish for deployment",
      "args": [],
      "options": [
        "--output",
        "--configuration"
      ]
    },
    {
      "name": "add package",
      "description": "Add a NuGet package",
      "args": [
        "package"
      ],
      "options": [
        "--version"
      ]
    }
  ],
  "examples": [
    "dotnet new razor -o MyWebApp",
    "dotnet run --urls 'https://localhost:5001'",
    "dotnet watch run",
    "dotnet publish -c Release -o ./publish",
    "dotnet add package Microsoft.AspNetCore.Identity.UI"
  ],
  "relatedCommands": [
    "dotnet",
    "csharp",
    "html",
    "css"
  ]
}
