{
  "name": "dotnet",
  "description": "Razor Pages — ASP.NET Core web framework via .NET CLI",
  "category": "development",
  "platforms": ["linux", "macos", "windows"],
  "shells": ["bash", "zsh", "powershell"],
  "subcommands": [
    { "name": "new razor -o project", "description": "Create a new Razor Pages project", "args": ["name"], "options": ["--auth", "--no-https"] },
    { "name": "run", "description": "Build and run the Razor Pages application", "args": [], "options": ["--urls", "--launch-profile"] },
    { "name": "watch run", "description": "Run with hot reload on file changes", "args": [], "options": [] },
    { "name": "build", "description": "Build the Razor Pages project", "args": [], "options": ["--configuration"] },
    { "name": "publish", "description": "Publish for deployment", "args": [], "options": ["--output", "--configuration"] },
    { "name": "add package", "description": "Add a NuGet package", "args": ["package"], "options": ["--version"] }
  ],
  "globalOptions": [
    { "name": "--configuration", "description": "Build configuration (Debug, Release)" },
    { "name": "--output", "description": "Output directory" },
    { "name": "--urls", "description": "Set listening URLs" },
    { "name": "--launch-profile", "description": "Launch profile from launchSettings.json" },
    { "name": "--no-https", "description": "Disable HTTPS in project template" },
    { "name": "--auth", "description": "Authentication type (None, Individual, etc.)" }
  ],
  "examples": [
    "dotnet new razor -o MyWebApp",
    "dotnet run --urls 'https://localhost:5001'",
    "dotnet watch run",
    "dotnet publish -c Release -o ./publish",
    "dotnet add package Microsoft.AspNetCore.Identity.UI"
  ],
  "relatedCommands": ["dotnet", "csharp", "html", "css"]
}