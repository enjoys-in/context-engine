{
  "name": "composer",
  "description": "Dependency Manager for PHP",
  "category": "PHP & Ruby Ecosystems",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell",
    "fish"
  ],
  "subcommands": [
    {
      "name": "install",
      "description": "Installs the project dependencies from the composer.lock file"
    },
    {
      "name": "update",
      "description": "Updates dependencies to latest versions and updates composer.lock"
    },
    {
      "name": "require",
      "description": "Adds packages to composer.json and installs them"
    },
    {
      "name": "dump-autoload",
      "description": "Dumps the autoloader"
    }
  ],
  "globalOptions": [
    {
      "name": "--no-dev",
      "description": "Disables installation of require-dev packages"
    },
    {
      "name": "--optimize-autoloader",
      "shorthand": "-o",
      "description": "Optimize autoloader during install/update"
    }
  ],
  "examples": [
    {
      "command": "composer install",
      "description": "Install project dependencies"
    },
    {
      "command": "composer require guzzlehttp/guzzle",
      "description": "Add a new dependency"
    },
    {
      "command": "composer update",
      "description": "Update all dependencies"
    }
  ],
  "relatedCommands": [
    "php",
    "artisan"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "composer_json",
        "description": "Composer dependencies",
        "command": "cat composer.json 2>/dev/null | grep 'require' -A 10 | head -10",
        "parser": "text",
        "cacheFor": 300
      }
    ]
  }
}