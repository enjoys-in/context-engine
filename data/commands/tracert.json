{
  "name": "tracert",
  "description": "Trace route to a network host (Windows)",
  "category": "networking",
  "platforms": [
    "windows"
  ],
  "shells": [
    "powershell",
    "cmd"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "-d",
      "description": "Do not resolve addresses"
    },
    {
      "name": "-h",
      "description": "Maximum hops",
      "type": "number"
    },
    {
      "name": "-w",
      "description": "Timeout in milliseconds",
      "type": "number"
    },
    {
      "name": "-4",
      "description": "Force IPv4"
    },
    {
      "name": "-6",
      "description": "Force IPv6"
    }
  ],
  "examples": [
    "tracert google.com",
    "tracert -d 8.8.8.8",
    "tracert -h 15 example.com",
    "tracert -w 3000 server.local"
  ],
  "relatedCommands": [
    "traceroute",
    "ping",
    "pathping",
    "netstat"
  ]
}
