{
  "name": "semgrep",
  "description": "Lightweight static analysis for finding bugs and enforcing code standards",
  "category": "devops",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "scan",
      "description": "Scan code",
      "examples": [
        "semgrep scan",
        "semgrep scan --config auto"
      ]
    },
    {
      "name": "ci",
      "description": "Run in CI mode",
      "examples": [
        "semgrep ci"
      ]
    },
    {
      "name": "login",
      "description": "Login to Semgrep Cloud",
      "examples": [
        "semgrep login"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--config",
      "description": "Rule configuration (auto, p/default, file)",
      "type": "string"
    },
    {
      "name": "--lang",
      "description": "Target language",
      "type": "string"
    },
    {
      "name": "--json",
      "description": "JSON output"
    },
    {
      "name": "--sarif",
      "description": "SARIF output"
    },
    {
      "name": "--severity",
      "description": "Filter by severity",
      "type": "string"
    },
    {
      "name": "--exclude",
      "description": "Exclude paths",
      "type": "string"
    },
    {
      "name": "--include",
      "description": "Include paths",
      "type": "string"
    },
    {
      "name": "--autofix",
      "description": "Apply autofixes"
    },
    {
      "name": "-e",
      "description": "Pattern to search for",
      "type": "string"
    }
  ],
  "examples": [
    "semgrep scan --config auto",
    "semgrep scan --config p/owasp-top-ten",
    "semgrep scan --config p/typescript",
    "semgrep ci",
    "semgrep scan -e '$X == $X' --lang python"
  ],
  "relatedCommands": [
    "eslint",
    "sonar",
    "codeql",
    "bandit"
  ]
}
