{
  "name": "nvm",
  "description": "Node Version Manager — manage multiple Node.js versions",
  "category": "version-manager",
  "platforms": [
    "linux",
    "macos"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish"
  ],
  "subcommands": [
    {
      "name": "install",
      "description": "Install a Node.js version",
      "examples": [
        "nvm install 20",
        "nvm install --lts",
        "nvm install 18.17.0"
      ]
    },
    {
      "name": "use",
      "description": "Switch to a Node.js version",
      "examples": [
        "nvm use 20",
        "nvm use --lts",
        "nvm use default"
      ]
    },
    {
      "name": "ls",
      "description": "List installed versions",
      "examples": [
        "nvm ls"
      ]
    },
    {
      "name": "ls-remote",
      "description": "List available remote versions",
      "examples": [
        "nvm ls-remote --lts"
      ]
    },
    {
      "name": "alias",
      "description": "Set an alias",
      "examples": [
        "nvm alias default 20"
      ]
    },
    {
      "name": "uninstall",
      "description": "Uninstall a version",
      "examples": [
        "nvm uninstall 16"
      ]
    },
    {
      "name": "current",
      "description": "Show currently active version",
      "examples": [
        "nvm current"
      ]
    },
    {
      "name": "which",
      "description": "Show path for installed version",
      "examples": [
        "nvm which 20"
      ]
    }
  ],
  "globalOptions": [],
  "examples": [
    "nvm install --lts",
    "nvm use 20",
    "nvm ls",
    "nvm alias default 20",
    "nvm ls-remote --lts",
    "nvm current"
  ],
  "relatedCommands": [
    "fnm",
    "volta",
    "node",
    "npm"
  ]
}
