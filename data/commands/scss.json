{
  "name": "sass",
  "description": "Dart Sass — SCSS/Sass CSS preprocessor compiler",
  "category": "development",
  "platforms": ["linux", "macos", "windows"],
  "shells": ["bash", "zsh", "powershell"],
  "subcommands": [
    { "name": "input.scss output.css", "description": "Compile SCSS to CSS", "args": ["input", "output"], "options": [] },
    { "name": "--watch input.scss:output.css", "description": "Watch for changes and recompile", "args": ["mapping"], "options": [] },
    { "name": "--style compressed input.scss", "description": "Compile with minified/compressed output", "args": ["file"], "options": [] },
    { "name": "--update src/:dist/", "description": "Compile only changed files", "args": ["dirs"], "options": [] },
    { "name": "--source-map input.scss output.css", "description": "Compile with source map for debugging", "args": ["input", "output"], "options": [] }
  ],
  "globalOptions": [
    { "name": "--style", "description": "Output style: expanded (default) or compressed" },
    { "name": "--source-map", "description": "Generate source map (on by default)" },
    { "name": "--no-source-map", "description": "Disable source map generation" },
    { "name": "--watch", "description": "Watch for file changes and recompile" },
    { "name": "--load-path", "description": "Add import path for @use and @import resolution" },
    { "name": "--charset", "description": "Emit @charset or BOM for non-ASCII CSS" },
    { "name": "--update", "description": "Only compile changed stylesheets" },
    { "name": "--quiet", "description": "Suppress warning messages" }
  ],
  "examples": [
    "sass src/styles.scss dist/styles.css",
    "sass --watch src/:dist/ --style compressed",
    "sass --style compressed input.scss output.min.css",
    "sass --load-path=node_modules/ src/main.scss dist/main.css",
    "npx sass src/theme.scss dist/theme.css --no-source-map"
  ],
  "relatedCommands": ["less", "css", "postcss", "tailwindcss"]
}