{
  "name": "helmfile",
  "description": "Deploy Kubernetes Helm charts declaratively",
  "category": "containers",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "sync",
      "description": "Sync releases to cluster",
      "examples": [
        "helmfile sync",
        "helmfile -f helmfile.yaml sync",
        "helmfile -e production sync"
      ]
    },
    {
      "name": "apply",
      "description": "Apply changes (sync with diff)",
      "examples": [
        "helmfile apply",
        "helmfile -e staging apply"
      ]
    },
    {
      "name": "diff",
      "description": "Show diff of pending changes",
      "examples": [
        "helmfile diff",
        "helmfile -e production diff"
      ]
    },
    {
      "name": "template",
      "description": "Template releases locally",
      "examples": [
        "helmfile template",
        "helmfile template --output-dir ./out"
      ]
    },
    {
      "name": "lint",
      "description": "Lint releases",
      "examples": [
        "helmfile lint"
      ]
    },
    {
      "name": "list",
      "description": "List releases",
      "examples": [
        "helmfile list",
        "helmfile -e production list"
      ]
    },
    {
      "name": "status",
      "description": "Show status of releases",
      "examples": [
        "helmfile status"
      ]
    },
    {
      "name": "destroy",
      "description": "Destroy releases",
      "examples": [
        "helmfile destroy",
        "helmfile -e staging destroy"
      ]
    },
    {
      "name": "repos",
      "description": "Add/update chart repos",
      "examples": [
        "helmfile repos"
      ]
    },
    {
      "name": "deps",
      "description": "Build chart dependencies",
      "examples": [
        "helmfile deps"
      ]
    },
    {
      "name": "build",
      "description": "Build helmfile state",
      "examples": [
        "helmfile build"
      ]
    },
    {
      "name": "fetch",
      "description": "Fetch charts",
      "examples": [
        "helmfile fetch",
        "helmfile fetch --output-dir charts/"
      ]
    },
    {
      "name": "write-values",
      "description": "Write computed values",
      "examples": [
        "helmfile write-values"
      ]
    },
    {
      "name": "test",
      "description": "Test releases",
      "examples": [
        "helmfile test"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--file",
      "short": "-f",
      "description": "Helmfile path",
      "type": "string"
    },
    {
      "name": "--environment",
      "short": "-e",
      "description": "Environment name",
      "type": "string"
    },
    {
      "name": "--selector",
      "short": "-l",
      "description": "Label selector for releases",
      "type": "string"
    },
    {
      "name": "--interactive",
      "description": "Interactive mode"
    },
    {
      "name": "--debug",
      "description": "Debug output"
    },
    {
      "name": "--state-values-set",
      "description": "Set state values",
      "type": "string"
    },
    {
      "name": "--concurrency",
      "description": "Max concurrent helm executions",
      "type": "number"
    }
  ],
  "examples": [
    "helmfile sync",
    "helmfile apply",
    "helmfile diff",
    "helmfile template",
    "helmfile -e production apply",
    "helmfile -l name=my-release apply",
    "helmfile list",
    "helmfile destroy"
  ],
  "relatedCommands": [
    "helm",
    "kubectl",
    "kustomize",
    "argocd"
  ]
}
