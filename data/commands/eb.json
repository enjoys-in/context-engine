{
  "name": "eb",
  "description": "AWS Elastic Beanstalk CLI",
  "category": "cloud",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "init",
      "description": "Initialize EB app",
      "examples": [
        "eb init",
        "eb init my-app --platform node.js-18 --region us-west-2"
      ]
    },
    {
      "name": "create",
      "description": "Create an environment",
      "examples": [
        "eb create my-env",
        "eb create my-env --instance-type t3.small",
        "eb create my-env --single --instance-type t3.micro",
        "eb create --envvars KEY1=val1,KEY2=val2"
      ]
    },
    {
      "name": "deploy",
      "description": "Deploy application",
      "examples": [
        "eb deploy",
        "eb deploy my-env",
        "eb deploy --staged"
      ]
    },
    {
      "name": "status",
      "description": "Show environment status",
      "examples": [
        "eb status",
        "eb status my-env"
      ]
    },
    {
      "name": "health",
      "description": "Show detailed health info",
      "examples": [
        "eb health",
        "eb health --refresh"
      ]
    },
    {
      "name": "logs",
      "description": "View logs",
      "examples": [
        "eb logs",
        "eb logs --all",
        "eb logs -cw enable"
      ]
    },
    {
      "name": "open",
      "description": "Open app in browser",
      "examples": [
        "eb open"
      ]
    },
    {
      "name": "ssh",
      "description": "SSH into instance",
      "examples": [
        "eb ssh",
        "eb ssh my-env"
      ]
    },
    {
      "name": "config",
      "description": "Modify configuration",
      "examples": [
        "eb config",
        "eb config save",
        "eb config put my-config"
      ]
    },
    {
      "name": "scale",
      "description": "Scale environment",
      "examples": [
        "eb scale 3",
        "eb scale 3 my-env"
      ]
    },
    {
      "name": "setenv",
      "description": "Set environment variables",
      "examples": [
        "eb setenv KEY=value",
        "eb setenv DB_HOST=mydb.rds.amazonaws.com DB_PORT=5432"
      ]
    },
    {
      "name": "printenv",
      "description": "Print environment variables",
      "examples": [
        "eb printenv"
      ]
    },
    {
      "name": "terminate",
      "description": "Terminate environment",
      "examples": [
        "eb terminate",
        "eb terminate my-env --force"
      ]
    },
    {
      "name": "list",
      "description": "List environments",
      "examples": [
        "eb list"
      ]
    },
    {
      "name": "use",
      "description": "Set default environment",
      "examples": [
        "eb use my-env"
      ]
    },
    {
      "name": "clone",
      "description": "Clone an environment",
      "examples": [
        "eb clone my-env --clone-name my-env-clone"
      ]
    },
    {
      "name": "swap",
      "description": "Swap environment CNAMEs",
      "examples": [
        "eb swap my-env --destination-name my-env-clone"
      ]
    },
    {
      "name": "restore",
      "description": "Restore terminated environment",
      "examples": [
        "eb restore env-id"
      ]
    },
    {
      "name": "abort",
      "description": "Abort environment update",
      "examples": [
        "eb abort"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--profile",
      "description": "AWS CLI profile",
      "type": "string"
    },
    {
      "name": "--region",
      "description": "AWS region",
      "type": "string"
    },
    {
      "name": "--verbose",
      "description": "Verbose output"
    }
  ],
  "examples": [
    "eb init my-app --platform node.js-18",
    "eb create my-env",
    "eb deploy",
    "eb status",
    "eb logs --all",
    "eb ssh",
    "eb open",
    "eb setenv NODE_ENV=production",
    "eb scale 3",
    "eb health --refresh"
  ],
  "relatedCommands": [
    "aws",
    "copilot",
    "docker",
    "heroku"
  ]
}
