{
  "name": "stack",
  "description": "Haskell build tool with reproducible builds",
  "category": "language",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "new",
      "description": "Create new project",
      "examples": [
        "stack new myproject"
      ]
    },
    {
      "name": "build",
      "description": "Build project",
      "examples": [
        "stack build"
      ]
    },
    {
      "name": "run",
      "description": "Build and run",
      "examples": [
        "stack run"
      ]
    },
    {
      "name": "test",
      "description": "Run tests",
      "examples": [
        "stack test"
      ]
    },
    {
      "name": "setup",
      "description": "Install GHC",
      "examples": [
        "stack setup"
      ]
    },
    {
      "name": "ghci",
      "description": "Start REPL",
      "examples": [
        "stack ghci"
      ]
    },
    {
      "name": "install",
      "description": "Install executables",
      "examples": [
        "stack install hlint"
      ]
    },
    {
      "name": "clean",
      "description": "Clean project",
      "examples": [
        "stack clean"
      ]
    },
    {
      "name": "exec",
      "description": "Execute command in stack env",
      "examples": [
        "stack exec ghc -- --version"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--resolver",
      "description": "LTS resolver version",
      "type": "string"
    },
    {
      "name": "-j",
      "description": "Parallel build jobs",
      "type": "number"
    },
    {
      "name": "--fast",
      "description": "Build without optimization"
    },
    {
      "name": "--pedantic",
      "description": "Turn on -Wall -Werror"
    }
  ],
  "examples": [
    "stack new myproject",
    "stack build",
    "stack run",
    "stack test",
    "stack ghci",
    "stack setup"
  ],
  "relatedCommands": [
    "cabal",
    "ghc",
    "ghci",
    "haskell"
  ]
}
