{
  "language": "ignore",
  "name": "ignore",
  "description": "Ignore file patterns (.gitignore, .dockerignore, .prettierignore, .eslintignore)",
  "category": "development",
  "platforms": ["linux", "macos", "windows"],
  "shells": ["bash", "zsh", "fish", "powershell", "cmd"],
  "subcommands": [],
  "contextEngine": {
    "detectors": [
      {
        "name": "git_version",
        "description": "Installed Git version",
        "command": "git --version 2>/dev/null",
        "parser": "text",
        "cacheFor": 3600,
        "requiresCmd": "git"
      },
      {
        "name": "gitignore_exists",
        "description": "Check if .gitignore exists in current directory",
        "command": "test -f .gitignore && echo 'true' || echo 'false'",
        "parser": "text",
        "cacheFor": 60
      },
      {
        "name": "dockerignore_exists",
        "description": "Check if .dockerignore exists in current directory",
        "command": "test -f .dockerignore && echo 'true' || echo 'false'",
        "parser": "text",
        "cacheFor": 60
      }
    ]
  }
}