{
  "name": "devspace",
  "description": "DevSpace — develop, deploy, and debug apps on Kubernetes",
  "category": "containers",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "init",
      "description": "Initialize DevSpace in a project",
      "examples": [
        "devspace init"
      ]
    },
    {
      "name": "dev",
      "description": "Start development mode",
      "examples": [
        "devspace dev",
        "devspace dev --no-warn",
        "devspace dev -n my-ns"
      ]
    },
    {
      "name": "deploy",
      "description": "Deploy the project",
      "examples": [
        "devspace deploy",
        "devspace deploy --skip-build",
        "devspace deploy -p production"
      ]
    },
    {
      "name": "build",
      "description": "Build images",
      "examples": [
        "devspace build",
        "devspace build --skip-push"
      ]
    },
    {
      "name": "purge",
      "description": "Delete deployed resources",
      "examples": [
        "devspace purge"
      ]
    },
    {
      "name": "enter",
      "description": "Start a shell in container",
      "examples": [
        "devspace enter",
        "devspace enter -c my-container"
      ]
    },
    {
      "name": "logs",
      "description": "View container logs",
      "examples": [
        "devspace logs",
        "devspace logs -f",
        "devspace logs -c my-container"
      ]
    },
    {
      "name": "sync",
      "description": "Start file sync",
      "examples": [
        "devspace sync --local-path=. --container-path=/app"
      ]
    },
    {
      "name": "open",
      "description": "Open app in browser",
      "examples": [
        "devspace open"
      ]
    },
    {
      "name": "ui",
      "description": "Start DevSpace UI",
      "examples": [
        "devspace ui"
      ]
    },
    {
      "name": "use",
      "description": "Set context/namespace/profile",
      "examples": [
        "devspace use context my-context",
        "devspace use namespace my-ns",
        "devspace use profile my-profile"
      ]
    },
    {
      "name": "list",
      "description": "List resources",
      "examples": [
        "devspace list commands",
        "devspace list profiles",
        "devspace list vars",
        "devspace list deployments"
      ]
    },
    {
      "name": "run",
      "description": "Run custom command",
      "examples": [
        "devspace run my-command"
      ]
    },
    {
      "name": "reset",
      "description": "Reset cluster state",
      "examples": [
        "devspace reset vars",
        "devspace reset pods"
      ]
    },
    {
      "name": "cleanup",
      "description": "Clean images",
      "examples": [
        "devspace cleanup images"
      ]
    },
    {
      "name": "upgrade",
      "description": "Upgrade DevSpace",
      "examples": [
        "devspace upgrade"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--config",
      "description": "Config file path",
      "type": "string"
    },
    {
      "name": "--namespace",
      "short": "-n",
      "description": "Namespace",
      "type": "string"
    },
    {
      "name": "--kube-context",
      "description": "Kubernetes context",
      "type": "string"
    },
    {
      "name": "--profile",
      "short": "-p",
      "description": "Profile to use",
      "type": "string"
    },
    {
      "name": "--var",
      "description": "Set variables",
      "type": "string"
    },
    {
      "name": "--debug",
      "description": "Debug mode"
    },
    {
      "name": "--silent",
      "description": "Silent mode"
    }
  ],
  "examples": [
    "devspace init",
    "devspace dev",
    "devspace deploy",
    "devspace build",
    "devspace enter",
    "devspace logs -f",
    "devspace purge",
    "devspace use namespace my-ns",
    "devspace ui"
  ],
  "relatedCommands": [
    "skaffold",
    "tilt",
    "telepresence",
    "kubectl"
  ]
}
