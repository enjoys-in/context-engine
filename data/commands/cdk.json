{
  "name": "cdk",
  "description": "AWS Cloud Development Kit CLI",
  "category": "cloud",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "init",
      "description": "Create a new CDK project",
      "examples": [
        "cdk init app --language typescript"
      ]
    },
    {
      "name": "synth",
      "description": "Synthesize CloudFormation template",
      "examples": [
        "cdk synth"
      ]
    },
    {
      "name": "deploy",
      "description": "Deploy stack to AWS",
      "examples": [
        "cdk deploy",
        "cdk deploy --all"
      ]
    },
    {
      "name": "diff",
      "description": "Show diff between deployed and local",
      "examples": [
        "cdk diff"
      ]
    },
    {
      "name": "destroy",
      "description": "Destroy deployed stack",
      "examples": [
        "cdk destroy"
      ]
    },
    {
      "name": "bootstrap",
      "description": "Bootstrap CDK toolkit stack",
      "examples": [
        "cdk bootstrap"
      ]
    },
    {
      "name": "list",
      "description": "List stacks",
      "examples": [
        "cdk list"
      ]
    },
    {
      "name": "watch",
      "description": "Watch for changes and deploy",
      "examples": [
        "cdk watch"
      ]
    },
    {
      "name": "doctor",
      "description": "Check CDK setup",
      "examples": [
        "cdk doctor"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--profile",
      "description": "AWS profile",
      "type": "string"
    },
    {
      "name": "--region",
      "description": "AWS region",
      "type": "string"
    },
    {
      "name": "--context",
      "short": "-c",
      "description": "Context values",
      "type": "string"
    },
    {
      "name": "--require-approval",
      "description": "Approval level (never, any-change, broadening)",
      "type": "string"
    },
    {
      "name": "--hotswap",
      "description": "Use hotswap deployments"
    },
    {
      "name": "--verbose",
      "short": "-v",
      "description": "Verbose output"
    }
  ],
  "examples": [
    "cdk init app --language typescript",
    "cdk synth",
    "cdk deploy",
    "cdk diff",
    "cdk deploy --all --require-approval never"
  ],
  "relatedCommands": [
    "aws",
    "sam",
    "terraform",
    "cloudformation"
  ]
}
