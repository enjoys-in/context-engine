{
  "name": "babel",
  "description": "JavaScript compiler — transform modern JS to compatible versions",
  "category": "build-tools",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "--out-dir",
      "short": "-d",
      "description": "Output directory",
      "type": "string"
    },
    {
      "name": "--out-file",
      "short": "-o",
      "description": "Output file",
      "type": "file"
    },
    {
      "name": "--watch",
      "short": "-w",
      "description": "Watch for changes"
    },
    {
      "name": "--source-maps",
      "short": "-s",
      "description": "Generate source maps"
    },
    {
      "name": "--presets",
      "description": "Comma-separated presets",
      "type": "string"
    },
    {
      "name": "--plugins",
      "description": "Comma-separated plugins",
      "type": "string"
    },
    {
      "name": "--config-file",
      "description": "Path to config",
      "type": "file"
    },
    {
      "name": "--extensions",
      "description": "File extensions to compile",
      "type": "string"
    },
    {
      "name": "--ignore",
      "description": "Glob patterns to skip",
      "type": "string"
    },
    {
      "name": "--copy-files",
      "description": "Copy non-compilable files"
    }
  ],
  "examples": [
    "babel src -d dist",
    "babel src/index.js -o dist/index.js",
    "babel src -d dist -w",
    "babel src -d dist --presets @babel/preset-env",
    "babel src -d dist --copy-files -s"
  ],
  "relatedCommands": [
    "swc",
    "esbuild",
    "tsc",
    "webpack"
  ]
}
