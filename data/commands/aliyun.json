{
  "name": "aliyun",
  "description": "Alibaba Cloud CLI",
  "category": "cloud",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "configure",
      "description": "Configure credentials",
      "examples": [
        "aliyun configure",
        "aliyun configure set --profile default --mode AK --access-key-id xxx --access-key-secret xxx --region cn-hangzhou"
      ]
    },
    {
      "name": "ecs",
      "description": "Elastic Compute Service",
      "examples": [
        "aliyun ecs DescribeInstances",
        "aliyun ecs RunInstances --ImageId ubuntu_22_04 --InstanceType ecs.t6-c1m1.large",
        "aliyun ecs StopInstance --InstanceId i-xxx",
        "aliyun ecs DeleteInstance --InstanceId i-xxx --Force true"
      ]
    },
    {
      "name": "oss",
      "description": "Object Storage Service",
      "examples": [
        "aliyun oss ls",
        "aliyun oss cp ./file.txt oss://my-bucket/",
        "aliyun oss mb oss://new-bucket",
        "aliyun oss rm oss://my-bucket/file.txt"
      ]
    },
    {
      "name": "rds",
      "description": "Relational Database Service",
      "examples": [
        "aliyun rds DescribeDBInstances",
        "aliyun rds CreateDBInstance --Engine MySQL --EngineVersion 8.0"
      ]
    },
    {
      "name": "cs",
      "description": "Container Service (ACK)",
      "examples": [
        "aliyun cs DescribeClusters",
        "aliyun cs GetClusterByName --ClusterName my-cluster"
      ]
    },
    {
      "name": "vpc",
      "description": "Virtual Private Cloud",
      "examples": [
        "aliyun vpc DescribeVpcs",
        "aliyun vpc CreateVpc --CidrBlock 172.16.0.0/12"
      ]
    },
    {
      "name": "slb",
      "description": "Server Load Balancer",
      "examples": [
        "aliyun slb DescribeLoadBalancers"
      ]
    },
    {
      "name": "dns",
      "description": "DNS management",
      "examples": [
        "aliyun dns DescribeDomains",
        "aliyun dns AddDomainRecord --DomainName example.com --RR www --Type A --Value 1.2.3.4"
      ]
    },
    {
      "name": "ram",
      "description": "Resource Access Management",
      "examples": [
        "aliyun ram ListUsers",
        "aliyun ram CreateUser --UserName test"
      ]
    },
    {
      "name": "fc",
      "description": "Function Compute",
      "examples": [
        "aliyun fc ListServices",
        "aliyun fc InvokeFunction --ServiceName svc --FunctionName fn"
      ]
    },
    {
      "name": "cdn",
      "description": "Content Delivery Network",
      "examples": [
        "aliyun cdn DescribeUserDomains"
      ]
    },
    {
      "name": "cr",
      "description": "Container Registry",
      "examples": [
        "aliyun cr GetRepoList",
        "aliyun cr GetImageManifest --RepoNamespace ns --RepoName repo --Tag latest"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--profile",
      "description": "Named profile",
      "type": "string"
    },
    {
      "name": "--region",
      "description": "Region ID",
      "type": "string"
    },
    {
      "name": "--output",
      "description": "Output format (json, table, text)",
      "type": "string"
    },
    {
      "name": "--access-key-id",
      "description": "Access Key ID",
      "type": "string"
    },
    {
      "name": "--access-key-secret",
      "description": "Access Key Secret",
      "type": "string"
    }
  ],
  "examples": [
    "aliyun configure",
    "aliyun ecs DescribeInstances --output table",
    "aliyun oss ls",
    "aliyun oss cp file.txt oss://bucket/",
    "aliyun cs DescribeClusters",
    "aliyun rds DescribeDBInstances",
    "aliyun vpc DescribeVpcs"
  ],
  "relatedCommands": [
    "aws",
    "az",
    "gcloud",
    "terraform"
  ]
}
