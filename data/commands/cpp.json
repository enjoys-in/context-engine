{
  "name": "g++",
  "description": "G++ — GNU C++ Compiler toolchain",
  "category": "language",
  "platforms": ["linux", "macos", "windows"],
  "shells": ["bash", "zsh", "powershell"],
  "subcommands": [
    { "name": "file.cpp -o output", "description": "Compile C++ file to executable", "args": [], "options": [] },
    { "name": "-std=c++20 file.cpp", "description": "Compile with C++20 standard", "args": [], "options": [] },
    { "name": "-Wall -Wextra file.cpp", "description": "Compile with all warnings enabled", "args": [], "options": [] },
    { "name": "-c file.cpp", "description": "Compile to object file without linking", "args": [], "options": [] },
    { "name": "-E file.cpp", "description": "Preprocess only, output to stdout", "args": [], "options": [] },
    { "name": "-S file.cpp", "description": "Compile to assembly language", "args": [], "options": [] }
  ],
  "globalOptions": [
    { "name": "-o", "description": "Specify output file name" },
    { "name": "-O0 / -O1 / -O2 / -O3 / -Os", "description": "Optimization level" },
    { "name": "-Wall", "description": "Enable all common warnings" },
    { "name": "-Werror", "description": "Treat all warnings as errors" },
    { "name": "-std=c++17 / -std=c++20 / -std=c++23", "description": "Set C++ language standard" },
    { "name": "-I<dir>", "description": "Add include directory for header search" },
    { "name": "-L<dir>", "description": "Add library search directory" },
    { "name": "-l<lib>", "description": "Link with library" },
    { "name": "-fsanitize=address", "description": "Enable AddressSanitizer" },
    { "name": "-fno-exceptions", "description": "Disable C++ exceptions" }
  ],
  "examples": [
    "g++ -std=c++20 -Wall -Wextra main.cpp -o main",
    "g++ -O2 -o app main.cpp utils.cpp -lstdc++fs",
    "g++ -g -fsanitize=address main.cpp -o debug_app",
    "g++ -c module.cpp && g++ -c main.cpp && g++ module.o main.o -o app",
    "g++ -std=c++23 -fmodules-ts module.cppm"
  ],
  "relatedCommands": ["cmake", "make", "gdb", "clang++", "c"]
}