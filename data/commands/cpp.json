{
  "language": "cpp",
  "name": "g++",
  "description": "G++ — GNU C++ Compiler toolchain",
  "category": "language",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "-o",
      "description": "Specify output file name"
    },
    {
      "name": "-O0 / -O1 / -O2 / -O3 / -Os",
      "description": "Optimization level"
    },
    {
      "name": "-Wall",
      "description": "Enable all common warnings"
    },
    {
      "name": "-Werror",
      "description": "Treat all warnings as errors"
    },
    {
      "name": "-std=c++17 / -std=c++20 / -std=c++23",
      "description": "Set C++ language standard"
    },
    {
      "name": "-I<dir>",
      "description": "Add include directory for header search"
    },
    {
      "name": "-L<dir>",
      "description": "Add library search directory"
    },
    {
      "name": "-l<lib>",
      "description": "Link with library"
    },
    {
      "name": "-fsanitize=address",
      "description": "Enable AddressSanitizer"
    },
    {
      "name": "-fno-exceptions",
      "description": "Disable C++ exceptions"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    }
  ],
  "subcommands": [
    {
      "name": "file.cpp -o output",
      "description": "Compile C++ file to executable",
      "args": [],
      "options": []
    },
    {
      "name": "-std=c++20 file.cpp",
      "description": "Compile with C++20 standard",
      "args": [],
      "options": []
    },
    {
      "name": "-Wall -Wextra file.cpp",
      "description": "Compile with all warnings enabled",
      "args": [],
      "options": []
    },
    {
      "name": "-c file.cpp",
      "description": "Compile to object file without linking",
      "args": [],
      "options": []
    },
    {
      "name": "-E file.cpp",
      "description": "Preprocess only, output to stdout",
      "args": [],
      "options": []
    },
    {
      "name": "-S file.cpp",
      "description": "Compile to assembly language",
      "args": [],
      "options": []
    }
  ],
  "examples": [
    "g++ -std=c++20 -Wall -Wextra main.cpp -o main",
    "g++ -O2 -o app main.cpp utils.cpp -lstdc++fs",
    "g++ -g -fsanitize=address main.cpp -o debug_app",
    "g++ -c module.cpp && g++ -c main.cpp && g++ module.o main.o -o app",
    "g++ -std=c++23 -fmodules-ts module.cppm"
  ],
  "relatedCommands": [
    "cmake",
    "make",
    "gdb",
    "clang++",
    "c"
  ]
}
