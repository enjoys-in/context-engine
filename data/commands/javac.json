{
  "name": "javac",
  "description": "Java compiler",
  "category": "languages",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "-d",
      "description": "Output directory",
      "type": "string"
    },
    {
      "name": "-cp",
      "description": "Classpath",
      "type": "string"
    },
    {
      "name": "-source",
      "description": "Source version",
      "type": "string"
    },
    {
      "name": "-target",
      "description": "Target bytecode version",
      "type": "string"
    },
    {
      "name": "-g",
      "description": "Generate debug info"
    },
    {
      "name": "-Werror",
      "description": "Treat warnings as errors"
    },
    {
      "name": "-deprecation",
      "description": "Show deprecation details"
    },
    {
      "name": "-Xlint",
      "description": "Enable lint checks"
    },
    {
      "name": "-encoding",
      "description": "Source file encoding",
      "type": "string"
    },
    {
      "name": "-verbose",
      "description": "Verbose output"
    },
    {
      "name": "--release",
      "description": "Compile for specific version",
      "type": "string"
    },
    {
      "name": "-sourcepath",
      "description": "Source file path",
      "type": "string"
    }
  ],
  "examples": [
    "javac Main.java",
    "javac -d out/ src/*.java",
    "javac -cp lib/* Main.java",
    "javac --release 17 Main.java",
    "javac -Xlint:all Main.java"
  ],
  "relatedCommands": [
    "java",
    "jar",
    "gradle",
    "mvn"
  ]
}
