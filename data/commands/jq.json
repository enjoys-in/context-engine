{
  "name": "jq",
  "description": "Command-line JSON processor",
  "category": "Text Processing & Utilities",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "-r",
      "description": "Output raw strings, not JSON texts"
    },
    {
      "name": "-c",
      "description": "Compact instead of pretty-printed output"
    },
    {
      "name": "-s",
      "description": "Read (slurp) all inputs into an array"
    }
  ],
  "examples": [
    {
      "command": "cat data.json | jq '.'",
      "description": "Pretty print JSON"
    },
    {
      "command": "jq -r '.name' package.json",
      "description": "Extract specific field as raw string"
    },
    {
      "command": "curl -s api.github.com/repos/stedolan/jq/commits | jq '.[0].commit.message'",
      "description": "Parse API response"
    }
  ],
  "relatedCommands": [
    "yq",
    "cat",
    "curl"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "json_files",
        "description": "JSON files in current directory",
        "command": "ls *.json 2>/dev/null | head -5",
        "parser": "lines",
        "cacheFor": 30
      }
    ]
  }
}