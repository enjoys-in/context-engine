{
  "name": "commitlint",
  "description": "Lint commit messages against conventional commit format",
  "category": "git",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "--edit",
      "description": "Read commit message from file",
      "type": "file"
    },
    {
      "name": "--from",
      "description": "Lower end of commit range",
      "type": "string"
    },
    {
      "name": "--to",
      "description": "Upper end of commit range",
      "type": "string"
    },
    {
      "name": "--extends",
      "description": "Config modules to extend",
      "type": "string"
    },
    {
      "name": "--config",
      "description": "Path to config file",
      "type": "file"
    },
    {
      "name": "--format",
      "description": "Output format",
      "type": "string"
    }
  ],
  "examples": [
    "echo 'fix: typo' | npx commitlint",
    "npx commitlint --edit",
    "npx commitlint --from HEAD~5",
    "npx commitlint --from HEAD~1 --to HEAD"
  ],
  "relatedCommands": [
    "husky",
    "conventional-commits",
    "semantic-release"
  ]
}
