{
  "name": "flowc",
  "description": "Flow9 — functional programming language compiler (area9)",
  "category": "language",
  "platforms": ["linux", "macos", "windows"],
  "shells": ["bash", "zsh", "powershell"],
  "subcommands": [
    { "name": "file.flow", "description": "Compile Flow9 program", "args": ["file"], "options": [] },
    { "name": "--js file.flow", "description": "Compile to JavaScript target", "args": ["file"], "options": [] },
    { "name": "--bytecode file.flow", "description": "Compile to bytecode", "args": ["file"], "options": [] },
    { "name": "--java file.flow", "description": "Compile to Java target", "args": ["file"], "options": [] },
    { "name": "--html file.flow", "description": "Compile and generate HTML wrapper", "args": ["file"], "options": [] }
  ],
  "globalOptions": [
    { "name": "--js", "description": "Compile to JavaScript output" },
    { "name": "--bytecode", "description": "Compile to Flow bytecode" },
    { "name": "--java", "description": "Compile to Java output" },
    { "name": "-I", "description": "Add include path for imports" },
    { "name": "--debug", "description": "Enable debug mode" },
    { "name": "--verbose", "description": "Verbose compilation output" }
  ],
  "examples": [
    "flowc1 --js myapp.flow",
    "flowc1 --bytecode myapp.flow",
    "flowc1 --java myapp.flow",
    "flowcpp myapp.flow"
  ],
  "relatedCommands": ["node", "java", "typescript"]
}