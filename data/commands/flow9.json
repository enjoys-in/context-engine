{
  "language": "flow9",
  "name": "flowc",
  "description": "Flow9 — functional programming language compiler (area9)",
  "category": "language",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--js",
      "description": "Compile to JavaScript output"
    },
    {
      "name": "--bytecode",
      "description": "Compile to Flow bytecode"
    },
    {
      "name": "--java",
      "description": "Compile to Java output"
    },
    {
      "name": "-I",
      "description": "Add include path for imports"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode"
    },
    {
      "name": "--verbose",
      "description": "Verbose compilation output"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    }
  ],
  "subcommands": [
    {
      "name": "file.flow",
      "description": "Compile Flow9 program",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "--js file.flow",
      "description": "Compile to JavaScript target",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "--bytecode file.flow",
      "description": "Compile to bytecode",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "--java file.flow",
      "description": "Compile to Java target",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "--html file.flow",
      "description": "Compile and generate HTML wrapper",
      "args": [
        "file"
      ],
      "options": []
    }
  ],
  "examples": [
    "flowc1 --js myapp.flow",
    "flowc1 --bytecode myapp.flow",
    "flowc1 --java myapp.flow",
    "flowcpp myapp.flow"
  ],
  "relatedCommands": [
    "node",
    "java",
    "typescript"
  ]
}
