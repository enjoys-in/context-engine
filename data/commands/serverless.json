{
  "name": "serverless",
  "description": "Serverless Framework — build serverless applications",
  "category": "cloud",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "deploy",
      "description": "Deploy a service",
      "examples": [
        "serverless deploy",
        "sls deploy --stage prod"
      ]
    },
    {
      "name": "invoke",
      "description": "Invoke a function",
      "examples": [
        "sls invoke -f hello",
        "sls invoke local -f hello"
      ]
    },
    {
      "name": "logs",
      "description": "View function logs",
      "examples": [
        "sls logs -f hello -t"
      ]
    },
    {
      "name": "remove",
      "description": "Remove a deployed service",
      "examples": [
        "sls remove"
      ]
    },
    {
      "name": "info",
      "description": "Show service info",
      "examples": [
        "sls info"
      ]
    },
    {
      "name": "create",
      "description": "Create new service from template",
      "examples": [
        "sls create --template aws-nodejs --path my-service"
      ]
    },
    {
      "name": "package",
      "description": "Package the service",
      "examples": [
        "sls package"
      ]
    },
    {
      "name": "plugin install",
      "description": "Install plugin",
      "examples": [
        "sls plugin install -n serverless-offline"
      ]
    },
    {
      "name": "offline",
      "description": "Run locally (with plugin)",
      "examples": [
        "sls offline start"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--stage",
      "short": "-s",
      "description": "Deployment stage",
      "type": "string"
    },
    {
      "name": "--region",
      "short": "-r",
      "description": "AWS region",
      "type": "string"
    },
    {
      "name": "--verbose",
      "short": "-v",
      "description": "Verbose output"
    },
    {
      "name": "--config",
      "short": "-c",
      "description": "Config file",
      "type": "file"
    }
  ],
  "examples": [
    "sls deploy",
    "sls deploy --stage prod",
    "sls invoke -f hello",
    "sls logs -f hello -t",
    "sls create --template aws-nodejs --path my-svc"
  ],
  "relatedCommands": [
    "sam",
    "cdk",
    "aws",
    "lambda"
  ]
}
