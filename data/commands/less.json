{
  "name": "lessc",
  "description": "Less CSS — CSS preprocessor compiler",
  "category": "development",
  "platforms": ["linux", "macos", "windows"],
  "shells": ["bash", "zsh", "powershell"],
  "subcommands": [
    { "name": "input.less output.css", "description": "Compile Less to CSS", "args": ["input", "output"], "options": [] },
    { "name": "--source-map input.less output.css", "description": "Compile with inline source map", "args": ["input", "output"], "options": [] },
    { "name": "--clean-css input.less output.css", "description": "Compile and minify CSS output", "args": ["input", "output"], "options": [] },
    { "name": "--depends input.less", "description": "Output a list of dependencies", "args": ["input"], "options": [] },
    { "name": "--lint input.less", "description": "Check Less file for errors without compiling", "args": ["input"], "options": [] }
  ],
  "globalOptions": [
    { "name": "--source-map", "description": "Generate source map for debugging" },
    { "name": "--clean-css", "description": "Minify output with clean-css plugin" },
    { "name": "--include-path", "description": "Set include paths for @import resolution" },
    { "name": "--global-var", "description": "Define a global variable (equivalent to @var: value)" },
    { "name": "--modify-var", "description": "Override a variable defined in Less files" },
    { "name": "--math", "description": "Math mode: always, parens-division, parens, strict" },
    { "name": "--strict-units", "description": "Enable strict unit handling" }
  ],
  "examples": [
    "lessc styles.less styles.css",
    "lessc --source-map styles.less styles.css",
    "lessc --clean-css styles.less styles.min.css",
    "lessc --global-var='primary-color=#ff0000' theme.less theme.css",
    "npx lessc --include-path=node_modules/bootstrap/less bootstrap.less bootstrap.css"
  ],
  "relatedCommands": ["scss", "css", "postcss", "prettier"]
}