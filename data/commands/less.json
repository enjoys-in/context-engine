{
  "language": "less",
  "name": "lessc",
  "description": "Less CSS — CSS preprocessor compiler",
  "category": "development",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--source-map",
      "description": "Generate source map for debugging"
    },
    {
      "name": "--clean-css",
      "description": "Minify output with clean-css plugin"
    },
    {
      "name": "--include-path",
      "description": "Set include paths for @import resolution"
    },
    {
      "name": "--global-var",
      "description": "Define a global variable (equivalent to @var: value)"
    },
    {
      "name": "--modify-var",
      "description": "Override a variable defined in Less files"
    },
    {
      "name": "--math",
      "description": "Math mode: always, parens-division, parens, strict"
    },
    {
      "name": "--strict-units",
      "description": "Enable strict unit handling"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    }
  ],
  "subcommands": [
    {
      "name": "input.less output.css",
      "description": "Compile Less to CSS",
      "args": [
        "input",
        "output"
      ],
      "options": []
    },
    {
      "name": "--source-map input.less output.css",
      "description": "Compile with inline source map",
      "args": [
        "input",
        "output"
      ],
      "options": []
    },
    {
      "name": "--clean-css input.less output.css",
      "description": "Compile and minify CSS output",
      "args": [
        "input",
        "output"
      ],
      "options": []
    },
    {
      "name": "--depends input.less",
      "description": "Output a list of dependencies",
      "args": [
        "input"
      ],
      "options": []
    },
    {
      "name": "--lint input.less",
      "description": "Check Less file for errors without compiling",
      "args": [
        "input"
      ],
      "options": []
    }
  ],
  "examples": [
    "lessc styles.less styles.css",
    "lessc --source-map styles.less styles.css",
    "lessc --clean-css styles.less styles.min.css",
    "lessc --global-var='primary-color=#ff0000' theme.less theme.css",
    "npx lessc --include-path=node_modules/bootstrap/less bootstrap.less bootstrap.css"
  ],
  "relatedCommands": [
    "scss",
    "css",
    "postcss",
    "prettier"
  ]
}
