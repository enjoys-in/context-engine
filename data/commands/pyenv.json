{
  "name": "pyenv",
  "description": "Simple Python version management",
  "category": "version-manager",
  "platforms": [
    "linux",
    "macos"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish"
  ],
  "subcommands": [
    {
      "name": "install",
      "description": "Install a Python version",
      "examples": [
        "pyenv install 3.12.0",
        "pyenv install --list"
      ]
    },
    {
      "name": "versions",
      "description": "List installed versions",
      "examples": [
        "pyenv versions"
      ]
    },
    {
      "name": "global",
      "description": "Set global Python version",
      "examples": [
        "pyenv global 3.12.0"
      ]
    },
    {
      "name": "local",
      "description": "Set local (per-directory) Python version",
      "examples": [
        "pyenv local 3.11.5"
      ]
    },
    {
      "name": "shell",
      "description": "Set shell-specific version",
      "examples": [
        "pyenv shell 3.12.0"
      ]
    },
    {
      "name": "uninstall",
      "description": "Uninstall a version",
      "examples": [
        "pyenv uninstall 3.10.0"
      ]
    },
    {
      "name": "which",
      "description": "Display full path to executable",
      "examples": [
        "pyenv which python"
      ]
    },
    {
      "name": "rehash",
      "description": "Rehash shims",
      "examples": [
        "pyenv rehash"
      ]
    }
  ],
  "globalOptions": [],
  "examples": [
    "pyenv install 3.12.0",
    "pyenv global 3.12.0",
    "pyenv versions",
    "pyenv install --list",
    "pyenv local 3.11.5"
  ],
  "relatedCommands": [
    "python",
    "pip",
    "conda",
    "poetry"
  ]
}
