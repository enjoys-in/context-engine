{
  "language": "mips",
  "name": "spim",
  "description": "SPIM — MIPS assembly simulator and debugger",
  "category": "tool",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "-file",
      "description": "Assembly file to load and run"
    },
    {
      "name": "-bare",
      "description": "Simulate bare MIPS machine"
    },
    {
      "name": "-asm",
      "description": "Simulate virtual machine with extended instructions"
    },
    {
      "name": "-delayed_branches",
      "description": "Simulate delayed branches"
    },
    {
      "name": "-delayed_loads",
      "description": "Simulate delayed loads"
    },
    {
      "name": "-mapped_io",
      "description": "Enable memory-mapped IO"
    },
    {
      "name": "-stext / -sdata / -sstack",
      "description": "Set segment sizes"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    }
  ],
  "subcommands": [
    {
      "name": "-file program.s",
      "description": "Load and run a MIPS assembly program",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "-bare",
      "description": "Run in bare machine mode (no pseudoinstructions)",
      "args": [],
      "options": []
    },
    {
      "name": "-trap",
      "description": "Load trap handler before running",
      "args": [],
      "options": []
    },
    {
      "name": "-notrap",
      "description": "Do not load the trap handler",
      "args": [],
      "options": []
    },
    {
      "name": "-quiet",
      "description": "Suppress informational messages",
      "args": [],
      "options": []
    }
  ],
  "examples": [
    "spim -file program.s",
    "spim -bare -file bare_program.s",
    "mars program.s",
    "mips-linux-gnu-gcc -o program program.c",
    "qemu-mips ./program"
  ],
  "relatedCommands": [
    "gcc",
    "gdb",
    "qemu",
    "systemverilog"
  ]
}
