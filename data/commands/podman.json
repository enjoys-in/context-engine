{
  "name": "podman",
  "description": "Daemonless container engine compatible with Docker CLI",
  "category": "containers",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "run",
      "description": "Run a container",
      "examples": [
        "podman run -it ubuntu bash",
        "podman run -d -p 8080:80 nginx"
      ]
    },
    {
      "name": "build",
      "description": "Build an image",
      "examples": [
        "podman build -t myapp ."
      ]
    },
    {
      "name": "ps",
      "description": "List containers",
      "examples": [
        "podman ps",
        "podman ps -a"
      ]
    },
    {
      "name": "images",
      "description": "List images",
      "examples": [
        "podman images"
      ]
    },
    {
      "name": "pull",
      "description": "Pull an image",
      "examples": [
        "podman pull docker.io/library/nginx"
      ]
    },
    {
      "name": "push",
      "description": "Push an image",
      "examples": [
        "podman push myimage registry.example.com/myimage"
      ]
    },
    {
      "name": "exec",
      "description": "Execute command in container",
      "examples": [
        "podman exec -it mycontainer bash"
      ]
    },
    {
      "name": "stop",
      "description": "Stop a container",
      "examples": [
        "podman stop mycontainer"
      ]
    },
    {
      "name": "rm",
      "description": "Remove a container",
      "examples": [
        "podman rm mycontainer"
      ]
    },
    {
      "name": "rmi",
      "description": "Remove an image",
      "examples": [
        "podman rmi myimage"
      ]
    },
    {
      "name": "logs",
      "description": "Fetch container logs",
      "examples": [
        "podman logs mycontainer"
      ]
    },
    {
      "name": "pod",
      "description": "Manage pods",
      "examples": [
        "podman pod create --name mypod",
        "podman pod list"
      ]
    },
    {
      "name": "generate",
      "description": "Generate Kubernetes YAML",
      "examples": [
        "podman generate kube mypod > pod.yaml"
      ]
    },
    {
      "name": "play",
      "description": "Play Kubernetes YAML",
      "examples": [
        "podman play kube pod.yaml"
      ]
    },
    {
      "name": "compose",
      "description": "Run compose files",
      "examples": [
        "podman compose up -d"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--root",
      "description": "Storage root dir",
      "type": "string"
    },
    {
      "name": "--log-level",
      "description": "Log level",
      "type": "string"
    }
  ],
  "examples": [
    "podman run -it ubuntu bash",
    "podman build -t myapp .",
    "podman ps -a",
    "podman compose up -d",
    "podman generate kube mypod"
  ],
  "relatedCommands": [
    "docker",
    "buildah",
    "skopeo",
    "kubectl"
  ]
}
