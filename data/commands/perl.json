{
  "name": "perl",
  "description": "Perl — practical extraction and report language interpreter",
  "category": "language",
  "platforms": ["linux", "macos", "windows"],
  "shells": ["bash", "zsh", "powershell"],
  "subcommands": [
    { "name": "script.pl", "description": "Run a Perl script", "args": ["file"], "options": [] },
    { "name": "-e \"code\"", "description": "Execute a one-liner expression", "args": ["code"], "options": [] },
    { "name": "-c script.pl", "description": "Syntax check without executing", "args": ["file"], "options": [] },
    { "name": "-n -e \"code\"", "description": "Process each input line with expression", "args": ["code"], "options": [] },
    { "name": "-p -i -e 's/old/new/g' file", "description": "In-place edit with regex substitution", "args": ["pattern", "file"], "options": [] },
    { "name": "-MCPAN -e 'install Module'", "description": "Install a CPAN module", "args": ["module"], "options": [] }
  ],
  "globalOptions": [
    { "name": "-e", "description": "Execute the given string as Perl code" },
    { "name": "-n", "description": "Wrap code in 'while (<>) { ... }' loop" },
    { "name": "-p", "description": "Like -n but also prints each line" },
    { "name": "-i[ext]", "description": "Edit files in-place (optionally create backup)" },
    { "name": "-w", "description": "Enable warnings" },
    { "name": "-c", "description": "Check syntax without executing" },
    { "name": "-d", "description": "Run under the Perl debugger" },
    { "name": "-I<dir>", "description": "Add directory to @INC module search path" },
    { "name": "-M<module>", "description": "Load a module before executing" }
  ],
  "examples": [
    "perl script.pl",
    "perl -e 'print \"Hello, World!\\n\"'",
    "perl -pi -e 's/foo/bar/g' *.txt",
    "perl -ne 'print if /pattern/' file.log",
    "cpanm install JSON::XS",
    "perl -c script.pl"
  ],
  "relatedCommands": ["sed", "awk", "python", "ruby", "grep"]
}