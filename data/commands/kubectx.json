{
  "name": "kubectx",
  "description": "Switch between Kubernetes contexts quickly",
  "category": "containers",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "(none — use directly)",
      "description": "List or switch contexts",
      "examples": [
        "kubectx",
        "kubectx my-context",
        "kubectx -",
        "kubectx -c",
        "kubectx -d old-context",
        "kubectx new-name=old-name"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "-c",
      "description": "Show current context"
    },
    {
      "name": "-d",
      "description": "Delete context",
      "type": "string"
    },
    {
      "name": "-u",
      "description": "Unset current context"
    }
  ],
  "examples": [
    "kubectx",
    "kubectx my-context",
    "kubectx -",
    "kubectx -c",
    "kubectx -d old-context",
    "kubectx new-name=old-name"
  ],
  "relatedCommands": [
    "kubectl",
    "kubens",
    "k9s"
  ]
}
