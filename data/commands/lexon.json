{
  "name": "lexon",
  "description": "Lexon — natural language smart contract compiler",
  "category": "language",
  "platforms": ["linux", "macos", "windows"],
  "shells": ["bash", "zsh", "powershell"],
  "subcommands": [
    { "name": "compile", "description": "Compile Lexon contract to Solidity or other target", "args": ["file.lex"], "options": ["--target", "--output"] },
    { "name": "check", "description": "Validate Lexon contract syntax", "args": ["file.lex"], "options": [] },
    { "name": "deploy", "description": "Deploy compiled contract to a blockchain network", "args": ["file.lex"], "options": ["--network", "--account"] },
    { "name": "explain", "description": "Show human-readable interpretation of compiled contract", "args": ["file.lex"], "options": [] },
    { "name": "version", "description": "Display Lexon compiler version", "args": [], "options": [] }
  ],
  "globalOptions": [
    { "name": "--target", "description": "Target language output (solidity, sophia, javascript)" },
    { "name": "--output", "description": "Output file path" },
    { "name": "--network", "description": "Blockchain network (mainnet, ropsten, local)" },
    { "name": "--verbose", "description": "Enable verbose logging" },
    { "name": "--version", "description": "Display version information" }
  ],
  "examples": [
    "lexon compile contract.lex --target solidity --output contract.sol",
    "lexon check agreement.lex",
    "lexon deploy contract.lex --network ropsten",
    "lexon explain contract.lex"
  ],
  "relatedCommands": ["sol", "node", "truffle", "hardhat"]
}