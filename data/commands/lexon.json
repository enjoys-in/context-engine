{
  "language": "lexon",
  "name": "lexon",
  "description": "Lexon — natural language smart contract compiler",
  "category": "language",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--target",
      "description": "Target language output (solidity, sophia, javascript)"
    },
    {
      "name": "--output",
      "description": "Output file path"
    },
    {
      "name": "--network",
      "description": "Blockchain network (mainnet, ropsten, local)"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose logging"
    },
    {
      "name": "--version",
      "description": "Display version information"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    },
    {
      "name": "--working-dir",
      "description": "Set the working directory",
      "valueHint": "dir",
      "alias": "-d"
    },
    {
      "name": "--env",
      "description": "Set environment (development, staging, production)",
      "valueHint": "name"
    }
  ],
  "subcommands": [
    {
      "name": "compile",
      "description": "Compile Lexon contract to Solidity or other target",
      "args": [
        "file.lex"
      ],
      "options": [
        "--target",
        "--output"
      ]
    },
    {
      "name": "check",
      "description": "Validate Lexon contract syntax",
      "args": [
        "file.lex"
      ],
      "options": []
    },
    {
      "name": "deploy",
      "description": "Deploy compiled contract to a blockchain network",
      "args": [
        "file.lex"
      ],
      "options": [
        "--network",
        "--account"
      ]
    },
    {
      "name": "explain",
      "description": "Show human-readable interpretation of compiled contract",
      "args": [
        "file.lex"
      ],
      "options": []
    },
    {
      "name": "version",
      "description": "Display Lexon compiler version",
      "args": [],
      "options": []
    }
  ],
  "examples": [
    "lexon compile contract.lex --target solidity --output contract.sol",
    "lexon check agreement.lex",
    "lexon deploy contract.lex --network ropsten",
    "lexon explain contract.lex"
  ],
  "relatedCommands": [
    "sol",
    "node",
    "truffle",
    "hardhat"
  ]
}
