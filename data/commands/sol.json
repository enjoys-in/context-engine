{
  "language": "sol",
  "name": "solc",
  "description": "Solidity compiler — compile smart contracts for EVM blockchains",
  "category": "language",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--optimize",
      "description": "Enable bytecode optimizer"
    },
    {
      "name": "--optimize-runs",
      "description": "Number of optimizer runs (default: 200)"
    },
    {
      "name": "--evm-version",
      "description": "Target EVM version (paris, shanghai, cancun)"
    },
    {
      "name": "--base-path",
      "description": "Root of the project for import resolution"
    },
    {
      "name": "--include-path",
      "description": "Extra import search paths (e.g., node_modules)"
    },
    {
      "name": "--allow-paths",
      "description": "Allow importing from additional paths"
    },
    {
      "name": "-o / --output-dir",
      "description": "Output directory for generated files"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    }
  ],
  "subcommands": [
    {
      "name": "--bin contract.sol",
      "description": "Compile contract to EVM bytecode",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "--abi contract.sol",
      "description": "Generate contract ABI JSON",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "--optimize contract.sol",
      "description": "Compile with optimizer enabled",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "--combined-json abi,bin contract.sol",
      "description": "Output combined ABI and bytecode as JSON",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "--ast-compact-json contract.sol",
      "description": "Output AST in compact JSON format",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "--standard-json",
      "description": "Compile with standard JSON input/output",
      "args": [],
      "options": []
    }
  ],
  "examples": [
    "solc --optimize --bin --abi contracts/Token.sol -o build/",
    "solc --standard-json < input.json > output.json",
    "forge build",
    "npx hardhat compile",
    "solc --optimize-runs 1000 --evm-version shanghai contract.sol --bin"
  ],
  "relatedCommands": [
    "forge",
    "hardhat",
    "node",
    "lexon"
  ]
}
