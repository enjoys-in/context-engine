{
  "name": "solc",
  "description": "Solidity compiler — compile smart contracts for EVM blockchains",
  "category": "language",
  "platforms": ["linux", "macos", "windows"],
  "shells": ["bash", "zsh", "powershell"],
  "subcommands": [
    { "name": "--bin contract.sol", "description": "Compile contract to EVM bytecode", "args": ["file"], "options": [] },
    { "name": "--abi contract.sol", "description": "Generate contract ABI JSON", "args": ["file"], "options": [] },
    { "name": "--optimize contract.sol", "description": "Compile with optimizer enabled", "args": ["file"], "options": [] },
    { "name": "--combined-json abi,bin contract.sol", "description": "Output combined ABI and bytecode as JSON", "args": ["file"], "options": [] },
    { "name": "--ast-compact-json contract.sol", "description": "Output AST in compact JSON format", "args": ["file"], "options": [] },
    { "name": "--standard-json", "description": "Compile with standard JSON input/output", "args": [], "options": [] }
  ],
  "globalOptions": [
    { "name": "--optimize", "description": "Enable bytecode optimizer" },
    { "name": "--optimize-runs", "description": "Number of optimizer runs (default: 200)" },
    { "name": "--evm-version", "description": "Target EVM version (paris, shanghai, cancun)" },
    { "name": "--base-path", "description": "Root of the project for import resolution" },
    { "name": "--include-path", "description": "Extra import search paths (e.g., node_modules)" },
    { "name": "--allow-paths", "description": "Allow importing from additional paths" },
    { "name": "-o / --output-dir", "description": "Output directory for generated files" }
  ],
  "examples": [
    "solc --optimize --bin --abi contracts/Token.sol -o build/",
    "solc --standard-json < input.json > output.json",
    "forge build",
    "npx hardhat compile",
    "solc --optimize-runs 1000 --evm-version shanghai contract.sol --bin"
  ],
  "relatedCommands": ["forge", "hardhat", "node", "lexon"]
}