{
  "name": "svelte",
  "description": "Svelte/SvelteKit CLI for building web applications",
  "category": "static-site",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "create",
      "description": "Create a new SvelteKit project",
      "examples": [
        "npm create svelte@latest my-app"
      ]
    },
    {
      "name": "dev",
      "description": "Start development server",
      "examples": [
        "npm run dev",
        "npm run dev -- --open"
      ]
    },
    {
      "name": "build",
      "description": "Build for production",
      "examples": [
        "npm run build"
      ]
    },
    {
      "name": "preview",
      "description": "Preview production build",
      "examples": [
        "npm run preview"
      ]
    },
    {
      "name": "check",
      "description": "Run svelte-check diagnostics",
      "examples": [
        "npx svelte-check"
      ]
    },
    {
      "name": "sync",
      "description": "Sync SvelteKit-generated files",
      "examples": [
        "npx svelte-kit sync"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--port",
      "description": "Dev server port",
      "type": "number"
    },
    {
      "name": "--host",
      "description": "Expose to network"
    },
    {
      "name": "--open",
      "description": "Open browser"
    }
  ],
  "examples": [
    "npm create svelte@latest my-app",
    "npm run dev",
    "npm run build",
    "npx svelte-check",
    "npm run dev -- --open --port 3001"
  ],
  "relatedCommands": [
    "vite",
    "astro",
    "next",
    "react"
  ]
}
