{
  "language": "makefile",
  "name": "make",
  "description": "Makefile command-line tool",
  "category": "development",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--help",
      "description": "Show help information"
    },
    {
      "name": "--version",
      "description": "Show version information"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    },
    {
      "name": "--working-dir",
      "description": "Set the working directory",
      "valueHint": "dir",
      "alias": "-d"
    }
  ],
  "subcommands": [
    {
      "name": "target",
      "description": "Build target",
      "args": [],
      "options": []
    },
    {
      "name": "-j4",
      "description": "Parallel build",
      "args": [],
      "options": []
    },
    {
      "name": "-n",
      "description": "Dry run",
      "args": [],
      "options": []
    },
    {
      "name": "clean",
      "description": "Clean build",
      "args": [],
      "options": []
    },
    {
      "name": "build",
      "description": "Build default target",
      "usage": "make"
    },
    {
      "name": "install",
      "description": "Install built files",
      "usage": "make install"
    },
    {
      "name": "dry-run",
      "description": "Show what would be done",
      "usage": "make -n"
    },
    {
      "name": "parallel",
      "description": "Build with parallel jobs",
      "usage": "make -j$(nproc)"
    }
  ],
  "examples": [
    {
      "command": "make",
      "description": "Build default target"
    },
    {
      "command": "make clean",
      "description": "Run clean target"
    },
    {
      "command": "make install",
      "description": "Install built files"
    },
    {
      "command": "make -j$(nproc)",
      "description": "Build with parallel jobs"
    },
    {
      "command": "make -n",
      "description": "Dry run — show what would execute"
    }
