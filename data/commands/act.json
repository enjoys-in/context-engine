{
  "name": "act",
  "description": "Run GitHub Actions locally",
  "category": "devops",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "-l",
      "description": "List available actions"
    },
    {
      "name": "-j",
      "description": "Run specific job",
      "type": "string"
    },
    {
      "name": "-W",
      "description": "Workflow file path",
      "type": "file"
    },
    {
      "name": "-n",
      "description": "Dry run"
    },
    {
      "name": "--secret",
      "description": "Set a secret",
      "type": "string"
    },
    {
      "name": "--env",
      "description": "Set an env var",
      "type": "string"
    },
    {
      "name": "-P",
      "description": "Platform mapping (e.g. ubuntu-latest=image)",
      "type": "string"
    },
    {
      "name": "--artifact-server-path",
      "description": "Local artifact path",
      "type": "string"
    },
    {
      "name": "-v",
      "description": "Verbose output"
    },
    {
      "name": "--container-architecture",
      "description": "Force container arch",
      "type": "string"
    }
  ],
  "examples": [
    "act",
    "act -l",
    "act -j build",
    "act push",
    "act pull_request",
    "act -n",
    "act --secret GITHUB_TOKEN=xxx",
    "act -j test -P ubuntu-latest=catthehacker/ubuntu:act-latest"
  ],
  "relatedCommands": [
    "gh",
    "docker",
    "nektos",
    "make"
  ]
}
