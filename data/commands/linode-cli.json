{
  "name": "linode-cli",
  "description": "Linode CLI for managing Akamai cloud computing services",
  "category": "cloud",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell",
    "fish"
  ],
  "subcommands": [
    {
      "name": "linodes",
      "description": "Manage Linode instances",
      "subcommands": [
        {
          "name": "create",
          "description": "Create a Linode",
          "options": [
            {
              "name": "--type",
              "description": "Plan type",
              "takesValue": true
            },
            {
              "name": "--region",
              "description": "Region",
              "takesValue": true
            },
            {
              "name": "--image",
              "description": "Image",
              "takesValue": true
            },
            {
              "name": "--root_pass",
              "description": "Root password",
              "takesValue": true
            },
            {
              "name": "--label",
              "description": "Instance label",
              "takesValue": true
            }
          ]
        },
        {
          "name": "list",
          "description": "List Linodes",
          "options": [
            {
              "name": "--json",
              "description": "Output as JSON"
            }
          ]
        },
        {
          "name": "view",
          "description": "View a Linode",
          "args": [
            {
              "name": "id",
              "description": "Linode ID",
              "required": true
            }
          ]
        },
        {
          "name": "delete",
          "description": "Delete a Linode",
          "args": [
            {
              "name": "id",
              "description": "Linode ID",
              "required": true
            }
          ]
        },
        {
          "name": "boot",
          "description": "Boot a Linode",
          "args": [
            {
              "name": "id",
              "description": "Linode ID",
              "required": true
            }
          ]
        },
        {
          "name": "shutdown",
          "description": "Shutdown a Linode",
          "args": [
            {
              "name": "id",
              "description": "Linode ID",
              "required": true
            }
          ]
        },
        {
          "name": "reboot",
          "description": "Reboot a Linode",
          "args": [
            {
              "name": "id",
              "description": "Linode ID",
              "required": true
            }
          ]
        }
      ]
    },
    {
      "name": "volumes",
      "description": "Manage block storage volumes",
      "subcommands": [
        {
          "name": "create",
          "description": "Create a volume",
          "options": [
            {
              "name": "--label",
              "description": "Volume label",
              "takesValue": true
            },
            {
              "name": "--region",
              "description": "Region",
              "takesValue": true
            },
            {
              "name": "--size",
              "description": "Size in GB",
              "takesValue": true
            }
          ]
        },
        {
          "name": "list",
          "description": "List volumes"
        },
        {
          "name": "delete",
          "description": "Delete a volume",
          "args": [
            {
              "name": "id",
              "description": "Volume ID",
              "required": true
            }
          ]
        }
      ]
    },
    {
      "name": "domains",
      "description": "Manage DNS domains",
      "subcommands": [
        {
          "name": "create",
          "description": "Create a domain",
          "options": [
            {
              "name": "--type",
              "description": "Domain type",
              "takesValue": true
            },
            {
              "name": "--domain",
              "description": "Domain name",
              "takesValue": true
            }
          ]
        },
        {
          "name": "list",
          "description": "List domains"
        },
        {
          "name": "delete",
          "description": "Delete a domain",
          "args": [
            {
              "name": "id",
              "description": "Domain ID",
              "required": true
            }
          ]
        }
      ]
    },
    {
      "name": "lke",
      "description": "Manage LKE Kubernetes clusters",
      "subcommands": [
        {
          "name": "cluster-create",
          "description": "Create a cluster",
          "options": [
            {
              "name": "--label",
              "description": "Cluster label",
              "takesValue": true
            },
            {
              "name": "--region",
              "description": "Region",
              "takesValue": true
            },
            {
              "name": "--k8s_version",
              "description": "Kubernetes version",
              "takesValue": true
            }
          ]
        },
        {
          "name": "clusters-list",
          "description": "List clusters"
        },
        {
          "name": "kubeconfig-view",
          "description": "View kubeconfig",
          "args": [
            {
              "name": "id",
              "description": "Cluster ID",
              "required": true
            }
          ]
        }
      ]
    },
    {
      "name": "databases",
      "description": "Manage managed databases",
      "subcommands": [
        {
          "name": "mysql-create",
          "description": "Create MySQL database"
        },
        {
          "name": "postgresql-create",
          "description": "Create PostgreSQL database"
        },
        {
          "name": "list",
          "description": "List databases"
        }
      ]
    },
    {
      "name": "nodebalancers",
      "description": "Manage NodeBalancers",
      "subcommands": [
        {
          "name": "create",
          "description": "Create a NodeBalancer",
          "options": [
            {
              "name": "--region",
              "description": "Region",
              "takesValue": true
            }
          ]
        },
        {
          "name": "list",
          "description": "List NodeBalancers"
        }
      ]
    },
    {
      "name": "regions",
      "description": "List available regions",
      "subcommands": [
        {
          "name": "list",
          "description": "List all regions"
        }
      ]
    },
    {
      "name": "configure",
      "description": "Configure the CLI with authentication"
    }
  ],
  "globalOptions": [
    {
      "name": "--json",
      "description": "Output as JSON"
    },
    {
      "name": "--text",
      "description": "Output as text table"
    },
    {
      "name": "--no-headers",
      "description": "Omit table headers"
    },
    {
      "name": "--help",
      "shorthand": "-h",
      "description": "Show help"
    }
  ],
  "examples": [
    {
      "command": "linode-cli linodes create --type g6-nanode-1 --region us-east --image linode/ubuntu22.04 --root_pass MyP@ss",
      "description": "Create a nanode"
    },
    {
      "command": "linode-cli linodes list --json",
      "description": "List linodes as JSON"
    },
    {
      "command": "linode-cli lke clusters-list",
      "description": "List Kubernetes clusters"
    }
  ],
  "relatedCommands": [
    "doctl",
    "aws",
    "gcloud"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "linodes",
        "description": "List running Linode instances",
        "command": "linode-cli linodes list --text --no-headers 2>/dev/null",
        "parser": "table",
        "cacheFor": 60,
        "requiresCmd": "linode-cli"
      },
      {
        "name": "regions",
        "description": "Available regions",
        "command": "linode-cli regions list --text --no-headers --format 'id,label' 2>/dev/null",
        "parser": "lines",
        "cacheFor": 3600,
        "requiresCmd": "linode-cli"
      },
      {
        "name": "databases",
        "description": "Managed databases",
        "command": "linode-cli databases list --text --no-headers 2>/dev/null",
        "parser": "lines",
        "cacheFor": 120,
        "requiresCmd": "linode-cli"
      }
    ]
  }
}
