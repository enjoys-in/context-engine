{
  "name": "fpc",
  "description": "Free Pascal Compiler — Object Pascal / Delphi compiler",
  "category": "language",
  "platforms": ["linux", "macos", "windows"],
  "shells": ["bash", "zsh", "powershell"],
  "subcommands": [
    { "name": "program.pas", "description": "Compile a Pascal program", "args": ["file"], "options": [] },
    { "name": "-O2 program.pas", "description": "Compile with optimization level 2", "args": ["file"], "options": [] },
    { "name": "-g program.pas", "description": "Compile with debug information", "args": ["file"], "options": [] },
    { "name": "-Mdelphi program.pas", "description": "Compile in Delphi compatibility mode", "args": ["file"], "options": [] },
    { "name": "-FUunits/ program.pas", "description": "Set unit output directory", "args": ["file"], "options": [] }
  ],
  "globalOptions": [
    { "name": "-O1 / -O2 / -O3", "description": "Optimization level" },
    { "name": "-g", "description": "Generate debug information" },
    { "name": "-Mdelphi / -Mobjfpc", "description": "Language compatibility mode (Delphi, ObjFPC)" },
    { "name": "-Fu<path>", "description": "Unit search path" },
    { "name": "-Fi<path>", "description": "Include file search path" },
    { "name": "-o<name>", "description": "Output executable name" },
    { "name": "-Sh", "description": "Use ansistrings by default" },
    { "name": "-Tlinux / -Twin64", "description": "Target operating system" }
  ],
  "examples": [
    "fpc program.pas",
    "fpc -O2 -o myapp program.pas",
    "fpc -Mdelphi -g program.pas",
    "fpc -FUunits/ -Fulib/ main.pas",
    "lazbuild project.lpi"
  ],
  "relatedCommands": ["lazarus", "gcc", "m3", "vb"]
}