{
  "language": "pascal",
  "name": "fpc",
  "description": "Free Pascal Compiler — Object Pascal / Delphi compiler",
  "category": "language",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "-O1 / -O2 / -O3",
      "description": "Optimization level"
    },
    {
      "name": "-g",
      "description": "Generate debug information"
    },
    {
      "name": "-Mdelphi / -Mobjfpc",
      "description": "Language compatibility mode (Delphi, ObjFPC)"
    },
    {
      "name": "-Fu<path>",
      "description": "Unit search path"
    },
    {
      "name": "-Fi<path>",
      "description": "Include file search path"
    },
    {
      "name": "-o<name>",
      "description": "Output executable name"
    },
    {
      "name": "-Sh",
      "description": "Use ansistrings by default"
    },
    {
      "name": "-Tlinux / -Twin64",
      "description": "Target operating system"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    }
  ],
  "subcommands": [
    {
      "name": "program.pas",
      "description": "Compile a Pascal program",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "-O2 program.pas",
      "description": "Compile with optimization level 2",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "-g program.pas",
      "description": "Compile with debug information",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "-Mdelphi program.pas",
      "description": "Compile in Delphi compatibility mode",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "-FUunits/ program.pas",
      "description": "Set unit output directory",
      "args": [
        "file"
      ],
      "options": []
    }
  ],
  "examples": [
    "fpc program.pas",
    "fpc -O2 -o myapp program.pas",
    "fpc -Mdelphi -g program.pas",
    "fpc -FUunits/ -Fulib/ main.pas",
    "lazbuild project.lpi"
  ],
  "relatedCommands": [
    "lazarus",
    "gcc",
    "m3",
    "vb"
  ]
}
