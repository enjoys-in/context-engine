{
  "name": "sphinx-build",
  "description": "Sphinx — reStructuredText documentation builder",
  "category": "tool",
  "platforms": ["linux", "macos", "windows"],
  "shells": ["bash", "zsh", "powershell"],
  "subcommands": [
    { "name": "-b html source build", "description": "Build HTML documentation", "args": ["source", "build"], "options": [] },
    { "name": "-b latex source build", "description": "Build LaTeX/PDF documentation", "args": ["source", "build"], "options": [] },
    { "name": "-b linkcheck source build", "description": "Check all external links for validity", "args": ["source", "build"], "options": [] },
    { "name": "-b epub source build", "description": "Build EPUB ebook output", "args": ["source", "build"], "options": [] },
    { "name": "-b man source build", "description": "Build Unix manual pages", "args": ["source", "build"], "options": [] },
    { "name": "-b doctest source build", "description": "Run doctests embedded in documentation", "args": ["source", "build"], "options": [] }
  ],
  "globalOptions": [
    { "name": "-b", "description": "Builder to use (html, latex, epub, man, linkcheck, doctest)" },
    { "name": "-j", "description": "Number of parallel build processes" },
    { "name": "-W", "description": "Turn warnings into errors" },
    { "name": "-n", "description": "Warn about all missing references" },
    { "name": "-c", "description": "Path to conf.py directory" },
    { "name": "-D", "description": "Override a conf.py setting (key=value)" },
    { "name": "-a", "description": "Write all output files (not just new/changed)" },
    { "name": "-E", "description": "Don't use saved environment, always read all files" }
  ],
  "examples": [
    "sphinx-build -b html docs/ docs/_build/html",
    "sphinx-build -b latex docs/ docs/_build/latex && cd docs/_build/latex && make",
    "sphinx-build -W -n -b linkcheck docs/ docs/_build/linkcheck",
    "sphinx-quickstart docs/",
    "rst2html.py README.rst README.html",
    "sphinx-autobuild docs/ docs/_build/html"
  ],
  "relatedCommands": ["pandoc", "python", "markdown", "pip"]
}