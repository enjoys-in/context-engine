{
  "name": "pwsh",
  "description": "PowerShell — cross-platform task automation and scripting shell",
  "category": "runtime",
  "platforms": ["linux", "macos", "windows"],
  "shells": ["bash", "zsh", "powershell"],
  "subcommands": [
    { "name": "-File script.ps1", "description": "Run a PowerShell script file", "args": ["file"], "options": [] },
    { "name": "-Command \"cmd\"", "description": "Execute a PowerShell command string", "args": ["command"], "options": [] },
    { "name": "-NoProfile", "description": "Start without loading any profile scripts", "args": [], "options": [] },
    { "name": "-ExecutionPolicy Bypass", "description": "Run with bypassed execution policy", "args": [], "options": [] },
    { "name": "-EncodedCommand", "description": "Execute a Base64-encoded command string", "args": ["encoded"], "options": [] },
    { "name": "-Interactive", "description": "Start interactive PowerShell session", "args": [], "options": [] }
  ],
  "globalOptions": [
    { "name": "-File", "description": "Execute a PowerShell script file" },
    { "name": "-Command", "description": "Execute a PowerShell command" },
    { "name": "-NoProfile", "description": "Skip loading user profile on startup" },
    { "name": "-NonInteractive", "description": "Do not present interactive prompts" },
    { "name": "-ExecutionPolicy", "description": "Set session execution policy" },
    { "name": "-NoExit", "description": "Stay open after running startup commands" },
    { "name": "-OutputFormat", "description": "Output format: Text or XML" },
    { "name": "-WorkingDirectory", "description": "Set initial working directory" }
  ],
  "examples": [
    "pwsh -File deploy.ps1",
    "pwsh -Command 'Get-Process | Sort-Object CPU -Descending | Select-Object -First 10'",
    "pwsh -NoProfile -ExecutionPolicy Bypass -File script.ps1",
    "pwsh -Command 'Install-Module -Name Az -Scope CurrentUser'",
    "pwsh -c '(Invoke-WebRequest https://example.com).StatusCode'"
