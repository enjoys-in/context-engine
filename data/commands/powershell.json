{
  "language": "powershell",
  "name": "pwsh",
  "description": "PowerShell — cross-platform task automation and scripting shell",
  "category": "runtime",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "-File",
      "description": "Execute a PowerShell script file"
    },
    {
      "name": "-Command",
      "description": "Execute a PowerShell command"
    },
    {
      "name": "-NoProfile",
      "description": "Skip loading user profile on startup"
    },
    {
      "name": "-NonInteractive",
      "description": "Do not present interactive prompts"
    },
    {
      "name": "-ExecutionPolicy",
      "description": "Set session execution policy"
    },
    {
      "name": "-NoExit",
      "description": "Stay open after running startup commands"
    },
    {
      "name": "-OutputFormat",
      "description": "Output format: Text or XML"
    },
    {
      "name": "-WorkingDirectory",
      "description": "Set initial working directory"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    }
  ],
  "subcommands": [
    {
      "name": "-File script.ps1",
      "description": "Run a PowerShell script file",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "-Command \"cmd\"",
      "description": "Execute a PowerShell command string",
      "args": [
        "command"
      ],
      "options": []
    },
    {
      "name": "-NoProfile",
      "description": "Start without loading any profile scripts",
      "args": [],
      "options": []
    },
    {
      "name": "-ExecutionPolicy Bypass",
      "description": "Run with bypassed execution policy",
      "args": [],
      "options": []
    },
    {
      "name": "-EncodedCommand",
      "description": "Execute a Base64-encoded command string",
      "args": [
        "encoded"
      ],
      "options": []
    },
    {
      "name": "-Interactive",
      "description": "Start interactive PowerShell session",
      "args": [],
      "options": []
    }
  ],
  "examples": [
    "pwsh -File deploy.ps1",
    "pwsh -Command 'Get-Process | Sort-Object CPU -Descending | Select-Object -First 10'",
    "pwsh -NoProfile -ExecutionPolicy Bypass -File script.ps1",
    "pwsh -Command 'Install-Module -Name Az -Scope CurrentUser'",
    "pwsh -c '(Invoke-WebRequest https://example.com).StatusCode'"
  ],
  "relatedCommands": [
    "bash",
    "cmd",
    "dotnet",
    "shell"
  ]
}
