{
  "name": "sam",
  "description": "AWS Serverless Application Model CLI",
  "category": "cloud",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "init",
      "description": "Initialize a new SAM project",
      "examples": [
        "sam init",
        "sam init --runtime nodejs20.x"
      ]
    },
    {
      "name": "build",
      "description": "Build serverless application",
      "examples": [
        "sam build"
      ]
    },
    {
      "name": "deploy",
      "description": "Deploy to AWS",
      "examples": [
        "sam deploy --guided",
        "sam deploy"
      ]
    },
    {
      "name": "local invoke",
      "description": "Invoke function locally",
      "examples": [
        "sam local invoke MyFunction"
      ]
    },
    {
      "name": "local start-api",
      "description": "Start local API Gateway",
      "examples": [
        "sam local start-api"
      ]
    },
    {
      "name": "local start-lambda",
      "description": "Start local Lambda endpoint",
      "examples": [
        "sam local start-lambda"
      ]
    },
    {
      "name": "validate",
      "description": "Validate template",
      "examples": [
        "sam validate"
      ]
    },
    {
      "name": "logs",
      "description": "Fetch function logs",
      "examples": [
        "sam logs -n MyFunction --tail"
      ]
    },
    {
      "name": "delete",
      "description": "Delete deployed stack",
      "examples": [
        "sam delete"
      ]
    },
    {
      "name": "sync",
      "description": "Sync local changes to AWS",
      "examples": [
        "sam sync --watch"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--region",
      "description": "AWS region",
      "type": "string"
    },
    {
      "name": "--profile",
      "description": "AWS profile",
      "type": "string"
    },
    {
      "name": "--template-file",
      "short": "-t",
      "description": "SAM template file",
      "type": "file"
    }
  ],
  "examples": [
    "sam init",
    "sam build",
    "sam deploy --guided",
    "sam local invoke MyFunction",
    "sam local start-api",
    "sam sync --watch"
  ],
  "relatedCommands": [
    "serverless",
    "cdk",
    "aws",
    "cloudformation"
  ]
}
