{
  "name": "rustc",
  "description": "Rust compiler",
  "category": "languages",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "-o",
      "description": "Output file",
      "type": "file"
    },
    {
      "name": "--edition",
      "description": "Rust edition (2015, 2018, 2021, 2024)",
      "type": "string"
    },
    {
      "name": "-O",
      "description": "Optimize"
    },
    {
      "name": "-g",
      "description": "Include debug info"
    },
    {
      "name": "--emit",
      "description": "Emit type (asm, llvm-ir, obj, link, dep-info)",
      "type": "string"
    },
    {
      "name": "--target",
      "description": "Target triple",
      "type": "string"
    },
    {
      "name": "--crate-type",
      "description": "Crate type (bin, lib, dylib, staticlib)",
      "type": "string"
    },
    {
      "name": "-C",
      "description": "Codegen option",
      "type": "string"
    },
    {
      "name": "--explain",
      "description": "Explain error code",
      "type": "string"
    },
    {
      "name": "-W",
      "description": "Set lint to warn",
      "type": "string"
    },
    {
      "name": "-A",
      "description": "Set lint to allow",
      "type": "string"
    },
    {
      "name": "-D",
      "description": "Set lint to deny",
      "type": "string"
    }
  ],
  "examples": [
    "rustc main.rs",
    "rustc -O -o app main.rs",
    "rustc --edition 2021 main.rs",
    "rustc --explain E0308",
    "rustc --emit asm main.rs"
  ],
  "relatedCommands": [
    "cargo",
    "rust",
    "rustup",
    "clippy"
  ]
}
