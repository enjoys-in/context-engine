{
  "name": "tmux",
  "description": "Terminal multiplexer",
  "category": "Text Processing & Utilities",
  "platforms": [
    "linux",
    "macos"
  ],
  "shells": [
    "bash",
    "zsh"
  ],
  "subcommands": [
    {
      "name": "new-session",
      "description": "Create a new session"
    },
    {
      "name": "attach-session",
      "description": "Attach to an existing session"
    },
    {
      "name": "list-sessions",
      "description": "List existing sessions"
    },
    {
      "name": "kill-session",
      "description": "Destroy a session"
    }
  ],
  "globalOptions": [],
  "examples": [
    {
      "command": "tmux new -s mysession",
      "description": "Start a new named session"
    },
    {
      "command": "tmux ls",
      "description": "List sessions"
    },
    {
      "command": "tmux attach -t mysession",
      "description": "Attach to session"
    }
  ],
  "relatedCommands": [],
  "contextEngine": {
    "detectors": [
      {
        "name": "sessions",
        "description": "Active tmux sessions",
        "command": "tmux ls 2>/dev/null",
        "parser": "lines",
        "cacheFor": 10
      }
    ]
  }
}