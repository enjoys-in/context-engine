{
  "name": "packer",
  "description": "HashiCorp Packer - automated machine image builder",
  "category": "devops",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell",
    "fish"
  ],
  "subcommands": [
    {
      "name": "build",
      "description": "Build image from template",
      "args": [
        {
          "name": "template",
          "description": "Template file or directory",
          "required": true
        }
      ],
      "options": [
        {
          "name": "-var",
          "description": "Set variable",
          "takesValue": true
        },
        {
          "name": "-var-file",
          "description": "Variable file",
          "takesValue": true
        },
        {
          "name": "-only",
          "description": "Build only listed builds",
          "takesValue": true
        },
        {
          "name": "-except",
          "description": "Skip listed builds",
          "takesValue": true
        },
        {
          "name": "-parallel-builds",
          "description": "Max parallel builds (0=unlimited)",
          "takesValue": true
        },
        {
          "name": "-on-error",
          "description": "On error (cleanup, abort, ask, run-cleanup-provisioner)",
          "takesValue": true
        },
        {
          "name": "-force",
          "description": "Force build even if artifacts exist"
        },
        {
          "name": "-debug",
          "description": "Debug mode"
        },
        {
          "name": "-timestamp-ui",
          "description": "Timestamp UI output"
        },
        {
          "name": "-color",
          "description": "Colorize output",
          "takesValue": true
        }
      ]
    },
    {
      "name": "validate",
      "description": "Validate template",
      "args": [
        {
          "name": "template",
          "description": "Template file or directory",
          "required": true
        }
      ],
      "options": [
        {
          "name": "-var",
          "description": "Set variable",
          "takesValue": true
        },
        {
          "name": "-var-file",
          "description": "Variable file",
          "takesValue": true
        },
        {
          "name": "-syntax-only",
          "description": "Only check syntax"
        }
      ]
    },
    {
      "name": "init",
      "description": "Install missing plugins",
      "args": [
        {
          "name": "template",
          "description": "Template directory",
          "required": true
        }
      ],
      "options": [
        {
          "name": "-upgrade",
          "description": "Upgrade already installed plugins"
        }
      ]
    },
    {
      "name": "inspect",
      "description": "Inspect template",
      "args": [
        {
          "name": "template",
          "description": "Template file",
          "required": true
        }
      ]
    },
    {
      "name": "fmt",
      "description": "Format HCL2 template files",
      "options": [
        {
          "name": "-check",
          "description": "Check if files are formatted"
        },
        {
          "name": "-diff",
          "description": "Show diff"
        },
        {
          "name": "-write",
          "description": "Write changes",
          "takesValue": true
        },
        {
          "name": "-recursive",
          "description": "Format recursively"
        }
      ]
    },
    {
      "name": "hcl2_upgrade",
      "description": "Convert JSON template to HCL2",
      "args": [
        {
          "name": "template",
          "description": "JSON template",
          "required": true
        }
      ]
    },
    {
      "name": "plugins",
      "description": "Plugin management",
      "subcommands": [
        {
          "name": "installed",
          "description": "List installed plugins"
        },
        {
          "name": "required",
          "description": "List required plugins"
        },
        {
          "name": "install",
          "description": "Install plugin"
        },
        {
          "name": "remove",
          "description": "Remove plugin"
        }
      ]
    },
    {
      "name": "version",
      "description": "Show version"
    }
  ],
  "globalOptions": [
    {
      "name": "--help",
      "shorthand": "-h",
      "description": "Show help"
    },
    {
      "name": "--version",
      "description": "Show version"
    }
  ],
  "examples": [
    {
      "command": "packer build .",
      "description": "Build from current directory"
    },
    {
      "command": "packer build -var 'region=us-east-1' aws.pkr.hcl",
      "description": "Build with variable"
    },
    {
      "command": "packer validate .",
      "description": "Validate template"
    },
    {
      "command": "packer init .",
      "description": "Install plugins"
    },
    {
      "command": "packer fmt -recursive .",
      "description": "Format all templates"
    },
    {
      "command": "packer build -only 'amazon-ebs.*' .",
      "description": "Build specific source"
    },
    {
      "command": "packer inspect template.pkr.hcl",
      "description": "Inspect template"
    }
  ],
  "relatedCommands": [
    "terraform",
    "ansible",
    "vagrant"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "templates",
        "description": "Packer template files",
        "command": "find . -maxdepth 2 \\( -name '*.pkr.hcl' -o -name '*.pkr.json' -o -name 'packer.json' \\) 2>/dev/null | head -10",
        "parser": "lines",
        "cacheFor": 30
      },
      {
        "name": "plugins",
        "description": "Installed plugins",
        "command": "packer plugins installed 2>/dev/null",
        "parser": "lines",
        "cacheFor": 120,
        "requiresCmd": "packer"
      },
      {
        "name": "variables",
        "description": "Variable files",
        "command": "find . -maxdepth 2 -name '*.pkrvars.hcl' -o -name '*.auto.pkrvars.hcl' 2>/dev/null | head -10",
        "parser": "lines",
        "cacheFor": 30
      },
      {
        "name": "version",
        "description": "Packer version",
        "command": "packer version 2>/dev/null",
        "parser": "text",
        "cacheFor": 300,
        "requiresCmd": "packer"
      }
    ]
  }
}
