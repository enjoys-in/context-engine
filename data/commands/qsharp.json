{
  "language": "qsharp",
  "name": "dotnet",
  "description": "Q# — quantum computing language via .NET SDK",
  "category": "language",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--project",
      "description": "Path to Q# project file (.csproj)"
    },
    {
      "name": "--configuration",
      "description": "Build configuration (Debug, Release)"
    },
    {
      "name": "--simulator",
      "description": "Quantum simulator to use"
    },
    {
      "name": "--verbosity",
      "description": "Output verbosity level (q, m, n, d, diag)"
    },
    {
      "name": "--output",
      "description": "Output directory"
    },
    {
      "name": "--framework",
      "description": "Target framework"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    }
  ],
  "subcommands": [
    {
      "name": "run",
      "description": "Run a Q# project",
      "args": [],
      "options": [
        "--project",
        "--simulator"
      ]
    },
    {
      "name": "build",
      "description": "Build a Q# project",
      "args": [],
      "options": [
        "--configuration"
      ]
    },
    {
      "name": "new -lang Q# -o project",
      "description": "Create a new Q# project from template",
      "args": [
        "name"
      ],
      "options": []
    },
    {
      "name": "test",
      "description": "Run Q# unit tests",
      "args": [],
      "options": [
        "--filter",
        "--logger"
      ]
    },
    {
      "name": "add package",
      "description": "Add a Q# / NuGet package to project",
      "args": [
        "package"
      ],
      "options": [
        "--version"
      ]
    },
    {
      "name": "publish",
      "description": "Publish Q# project for distribution",
      "args": [],
      "options": [
        "--output",
        "--configuration"
      ]
    }
  ],
  "examples": [
    "dotnet new console -lang Q# -o QuantumApp",
    "dotnet run --project QuantumApp",
    "dotnet build --configuration Release",
    "dotnet add package Microsoft.Quantum.Standard",
    "dotnet test --filter \"TestCategory=Quantum\""
  ],
  "relatedCommands": [
    "dotnet",
    "csharp",
    "python",
    "az"
  ]
}
