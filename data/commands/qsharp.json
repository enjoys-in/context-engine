{
  "name": "dotnet",
  "description": "Q# — quantum computing language via .NET SDK",
  "category": "language",
  "platforms": ["linux", "macos", "windows"],
  "shells": ["bash", "zsh", "powershell"],
  "subcommands": [
    { "name": "run", "description": "Run a Q# project", "args": [], "options": ["--project", "--simulator"] },
    { "name": "build", "description": "Build a Q# project", "args": [], "options": ["--configuration"] },
    { "name": "new -lang Q# -o project", "description": "Create a new Q# project from template", "args": ["name"], "options": [] },
    { "name": "test", "description": "Run Q# unit tests", "args": [], "options": ["--filter", "--logger"] },
    { "name": "add package", "description": "Add a Q# / NuGet package to project", "args": ["package"], "options": ["--version"] },
    { "name": "publish", "description": "Publish Q# project for distribution", "args": [], "options": ["--output", "--configuration"] }
  ],
  "globalOptions": [
    { "name": "--project", "description": "Path to Q# project file (.csproj)" },
    { "name": "--configuration", "description": "Build configuration (Debug, Release)" },
    { "name": "--simulator", "description": "Quantum simulator to use" },
    { "name": "--verbosity", "description": "Output verbosity level (q, m, n, d, diag)" },
    { "name": "--output", "description": "Output directory" },
    { "name": "--framework", "description": "Target framework" }
  ],
  "examples": [
    "dotnet new console -lang Q# -o QuantumApp",
    "dotnet run --project QuantumApp",
    "dotnet build --configuration Release",
    "dotnet add package Microsoft.Quantum.Standard",
    "dotnet test --filter \"TestCategory=Quantum\""
  ],
  "relatedCommands": ["dotnet", "csharp", "python", "az"]
}