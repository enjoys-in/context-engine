{
  "name": "k9s",
  "description": "K9s — terminal UI for managing Kubernetes clusters",
  "category": "containers",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "(default)",
      "description": "Launch interactive cluster UI",
      "examples": [
        "k9s",
        "k9s -n my-namespace",
        "k9s --context my-context"
      ]
    },
    {
      "name": "-c / --command",
      "description": "Jump to specific resource view",
      "examples": [
        "k9s -c pod",
        "k9s -c deploy",
        "k9s -c svc",
        "k9s -c ns",
        "k9s -c node",
        "k9s -c sts",
        "k9s -c job",
        "k9s -c cj",
        "k9s -c cm",
        "k9s -c secret",
        "k9s -c ingress",
        "k9s -c pv"
      ]
    },
    {
      "name": "--readonly",
      "description": "Launch in read-only mode",
      "examples": [
        "k9s --readonly"
      ]
    },
    {
      "name": "--all-namespaces",
      "description": "Launch watching all namespaces",
      "examples": [
        "k9s -A"
      ]
    },
    {
      "name": "--headless",
      "description": "Run without header/footer",
      "examples": [
        "k9s --headless"
      ]
    },
    {
      "name": "--write",
      "description": "Log output to file",
      "examples": [
        "k9s --write /tmp/k9s.log"
      ]
    },
    {
      "name": "info",
      "description": "Print cluster info",
      "examples": [
        "k9s info"
      ]
    },
    {
      "name": "version",
      "description": "Print version",
      "examples": [
        "k9s version"
      ]
    },
    {
      "name": "help",
      "description": "Print help",
      "examples": [
        "k9s help"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--namespace",
      "short": "-n",
      "description": "Target namespace",
      "type": "string"
    },
    {
      "name": "--context",
      "description": "Kubernetes context",
      "type": "string"
    },
    {
      "name": "--kubeconfig",
      "description": "Kubeconfig path",
      "type": "string"
    },
    {
      "name": "--command",
      "short": "-c",
      "description": "Resource view to open",
      "type": "string"
    },
    {
      "name": "--readonly",
      "description": "Read-only mode"
    },
    {
      "name": "--all-namespaces",
      "short": "-A",
      "description": "All namespaces"
    },
    {
      "name": "--headless",
      "description": "No header/footer"
    },
    {
      "name": "--write",
      "description": "Log file path",
      "type": "string"
    },
    {
      "name": "--crumbsless",
      "description": "Hide breadcrumbs"
    },
    {
      "name": "--logoless",
      "description": "Hide logo"
    },
    {
      "name": "--refresh",
      "short": "-r",
      "description": "Refresh rate",
      "type": "number"
    }
  ],
  "examples": [
    "k9s",
    "k9s -n production",
    "k9s --context staging",
    "k9s -c pod",
    "k9s -c deploy",
    "k9s -A",
    "k9s --readonly",
    "k9s -c svc -n default",
    "k9s info",
    "k9s version"
  ],
  "relatedCommands": [
    "kubectl",
    "kubectx",
    "kubens",
    "stern",
    "helm"
  ]
}
