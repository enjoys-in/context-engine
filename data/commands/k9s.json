{
  "name": "k9s",
  "description": "Kubernetes CLI To Manage Your Clusters In Style",
  "category": "Containers / Kubernetes",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "info",
      "description": "Print configuration info"
    },
    {
      "name": "version",
      "description": "Print version info"
    }
  ],
  "globalOptions": [
    {
      "name": "-n",
      "description": "Namespace",
      "takesValue": true
    },
    {
      "name": "-c",
      "description": "Context",
      "takesValue": true
    }
  ],
  "examples": [
    {
      "command": "k9s",
      "description": "Start K9s dashboard"
    },
    {
      "command": "k9s -n default",
      "description": "Start K9s in default namespace"
    }
  ],
  "relatedCommands": [
    "kubectl",
    "helm"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "clusters",
        "description": "Available Clusters",
        "command": "kubectl config get-contexts -o name 2>/dev/null",
        "parser": "lines",
        "cacheFor": 300
      }
    ]
  }
}