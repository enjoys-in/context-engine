{
  "language": "javascript",
  "name": "node",
  "description": "Node.js — JavaScript runtime CLI",
  "category": "runtime",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--inspect",
      "description": "Activate inspector on default port (9229)"
    },
    {
      "name": "--inspect-brk",
      "description": "Activate inspector and break on first line"
    },
    {
      "name": "--watch",
      "description": "Run in watch mode, restart on file changes"
    },
    {
      "name": "--experimental-modules",
      "description": "Enable experimental ES module support"
    },
    {
      "name": "--max-old-space-size=<MB>",
      "description": "Set V8 heap memory limit"
    },
    {
      "name": "--env-file",
      "description": "Load environment variables from a file"
    },
    {
      "name": "--test",
      "description": "Run Node.js built-in test runner"
    },
    {
      "name": "-r / --require",
      "description": "Preload a module before executing"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    }
  ],
  "subcommands": [
    {
      "name": "file.js",
      "description": "Run a JavaScript file",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "-e \"code\"",
      "description": "Evaluate JavaScript expression",
      "args": [
        "code"
      ],
      "options": []
    },
    {
      "name": "--inspect file.js",
      "description": "Run with Chrome DevTools debugger attached",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "-p \"expression\"",
      "description": "Evaluate and print expression result",
      "args": [
        "expression"
      ],
      "options": []
    },
    {
      "name": "--watch file.js",
      "description": "Watch for file changes and restart",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "--test",
      "description": "Run built-in test runner",
      "args": [],
      "options": [
        "--test-reporter"
      ]
    }
  ],
  "examples": [
    "node server.js",
    "node -e \"console.log(process.version)\"",
    "node --inspect-brk app.js",
    "node --watch src/index.js",
    "node --test 'test/**/*.test.js'",
    "node --max-old-space-size=4096 build.js"
  ],
  "relatedCommands": [
    "npm",
    "npx",
    "deno",
    "bun",
    "typescript"
  ]
}
