{
  "name": "terragrunt",
  "description": "Thin wrapper for Terraform providing extra tools for keeping configurations DRY",
  "category": "devops",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell",
    "fish"
  ],
  "subcommands": [
    {
      "name": "plan",
      "description": "Generate and show execution plan (wraps terraform plan)"
    },
    {
      "name": "apply",
      "description": "Apply changes (wraps terraform apply)",
      "options": [
        {
          "name": "--auto-approve",
          "description": "Skip approval prompt"
        }
      ]
    },
    {
      "name": "destroy",
      "description": "Destroy infrastructure (wraps terraform destroy)"
    },
    {
      "name": "init",
      "description": "Initialize Terraform (wraps terraform init)"
    },
    {
      "name": "validate",
      "description": "Validate configuration"
    },
    {
      "name": "output",
      "description": "Show output values"
    },
    {
      "name": "run-all",
      "description": "Run command in all subdirectories",
      "subcommands": [
        {
          "name": "plan",
          "description": "Plan across all modules"
        },
        {
          "name": "apply",
          "description": "Apply across all modules"
        },
        {
          "name": "destroy",
          "description": "Destroy across all modules"
        },
        {
          "name": "init",
          "description": "Init across all modules"
        },
        {
          "name": "validate",
          "description": "Validate across all modules"
        },
        {
          "name": "output",
          "description": "Show outputs across all modules"
        }
      ]
    },
    {
      "name": "graph-dependencies",
      "description": "Show dependency graph"
    },
    {
      "name": "hclfmt",
      "description": "Format HCL files"
    },
    {
      "name": "render-json",
      "description": "Render terragrunt.hcl as JSON"
    },
    {
      "name": "aws-provider-patch",
      "description": "Patch AWS provider configs"
    },
    {
      "name": "scaffold",
      "description": "Scaffold new module configuration"
    },
    {
      "name": "catalog",
      "description": "Browse module catalog"
    }
  ],
  "globalOptions": [
    {
      "name": "--terragrunt-config",
      "description": "Path to terragrunt.hcl",
      "takesValue": true
    },
    {
      "name": "--terragrunt-working-dir",
      "description": "Working directory",
      "takesValue": true
    },
    {
      "name": "--terragrunt-source",
      "description": "Override source in terragrunt.hcl",
      "takesValue": true
    },
    {
      "name": "--terragrunt-non-interactive",
      "description": "Non-interactive mode"
    },
    {
      "name": "--terragrunt-log-level",
      "description": "Log level (trace, debug, info, warn, error)",
      "takesValue": true
    },
    {
      "name": "--terragrunt-no-auto-init",
      "description": "Don't auto-run init"
    },
    {
      "name": "--terragrunt-no-auto-retry",
      "description": "Don't auto-retry on errors"
    },
    {
      "name": "--terragrunt-parallelism",
      "description": "Number of parallel modules for run-all",
      "takesValue": true
    },
    {
      "name": "--terragrunt-exclude-dir",
      "description": "Exclude directory from run-all",
      "takesValue": true
    },
    {
      "name": "--terragrunt-include-dir",
      "description": "Include only this directory in run-all",
      "takesValue": true
    }
  ],
  "examples": [
    {
      "command": "terragrunt plan",
      "description": "Run plan"
    },
    {
      "command": "terragrunt apply --auto-approve",
      "description": "Apply without prompt"
    },
    {
      "command": "terragrunt run-all apply",
      "description": "Apply all modules"
    },
    {
      "command": "terragrunt graph-dependencies",
      "description": "Show dependency graph"
    },
    {
      "command": "terragrunt hclfmt",
      "description": "Format HCL files"
    },
    {
      "command": "terragrunt run-all plan --terragrunt-parallelism 4",
      "description": "Parallel plan"
    },
    {
      "command": "terragrunt render-json",
      "description": "Render config as JSON"
    }
  ],
  "relatedCommands": [
    "terraform",
    "pulumi"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "config_file",
        "description": "Terragrunt configuration",
        "command": "cat terragrunt.hcl 2>/dev/null | head -30",
        "parser": "text",
        "cacheFor": 30
      },
      {
        "name": "modules",
        "description": "Terragrunt modules in subdirectories",
        "command": "find . -name 'terragrunt.hcl' -not -path './.terragrunt-cache/*' 2>/dev/null | head -20",
        "parser": "lines",
        "cacheFor": 30
      },
      {
        "name": "dependencies",
        "description": "Module dependencies",
        "command": "grep -r 'dependency' terragrunt.hcl 2>/dev/null | head -10",
        "parser": "lines",
        "cacheFor": 30
      },
      {
        "name": "terraform_source",
        "description": "Terraform source modules",
        "command": "grep 'source' terragrunt.hcl 2>/dev/null",
        "parser": "text",
        "cacheFor": 60
      }
    ]
  }
}
