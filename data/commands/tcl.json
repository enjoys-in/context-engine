{
  "language": "tcl",
  "name": "tclsh",
  "description": "Tcl — Tool Command Language interpreter",
  "category": "language",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "-encoding",
      "description": "Set the encoding for script files"
    },
    {
      "name": "argv0",
      "description": "Tcl variable containing the script name"
    },
    {
      "name": "argc",
      "description": "Tcl variable with number of arguments"
    },
    {
      "name": "auto_path",
      "description": "Tcl variable with package search paths"
    },
    {
      "name": "tcl_interactive",
      "description": "Variable indicating interactive mode"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    }
  ],
  "subcommands": [
    {
      "name": "script.tcl",
      "description": "Run a Tcl script file",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "<< 'puts hello'",
      "description": "Evaluate Tcl commands from stdin",
      "args": [],
      "options": []
    },
    {
      "name": "script.tcl arg1 arg2",
      "description": "Run Tcl script with command-line arguments",
      "args": [
        "file",
        "args"
      ],
      "options": []
    },
    {
      "name": "-encoding utf-8 script.tcl",
      "description": "Run with specified file encoding",
      "args": [
        "file"
      ],
      "options": []
    }
  ],
  "examples": [
    "tclsh script.tcl",
    "wish gui_app.tcl",
    "echo 'puts [expr {2 + 3}]' | tclsh",
    "expect script.exp",
    "tclsh -encoding utf-8 unicode_script.tcl"
  ],
  "relatedCommands": [
    "expect",
    "wish",
    "python",
    "perl"
  ]
}
