{
  "name": "pg_dump",
  "description": "PostgreSQL database backup/dump utility",
  "category": "database",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell",
    "fish"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "--host",
      "shorthand": "-h",
      "description": "Database server host",
      "takesValue": true
    },
    {
      "name": "--port",
      "shorthand": "-p",
      "description": "Database server port",
      "takesValue": true
    },
    {
      "name": "--username",
      "shorthand": "-U",
      "description": "Database user",
      "takesValue": true
    },
    {
      "name": "--dbname",
      "shorthand": "-d",
      "description": "Database name",
      "takesValue": true
    },
    {
      "name": "--password",
      "shorthand": "-W",
      "description": "Prompt for password"
    },
    {
      "name": "--no-password",
      "shorthand": "-w",
      "description": "Never prompt for password"
    },
    {
      "name": "--format",
      "shorthand": "-F",
      "description": "Output format (p=plain, c=custom, d=directory, t=tar)",
      "takesValue": true
    },
    {
      "name": "--file",
      "shorthand": "-f",
      "description": "Output file or directory",
      "takesValue": true
    },
    {
      "name": "--schema",
      "shorthand": "-n",
      "description": "Dump specific schema(s)",
      "takesValue": true
    },
    {
      "name": "--exclude-schema",
      "shorthand": "-N",
      "description": "Exclude schema(s)",
      "takesValue": true
    },
    {
      "name": "--table",
      "shorthand": "-t",
      "description": "Dump specific table(s)",
      "takesValue": true
    },
    {
      "name": "--exclude-table",
      "shorthand": "-T",
      "description": "Exclude table(s)",
      "takesValue": true
    },
    {
      "name": "--data-only",
      "shorthand": "-a",
      "description": "Dump only data, no schema"
    },
    {
      "name": "--schema-only",
      "shorthand": "-s",
      "description": "Dump only schema, no data"
    },
    {
      "name": "--clean",
      "shorthand": "-c",
      "description": "Add DROP commands before CREATE"
    },
    {
      "name": "--create",
      "shorthand": "-C",
      "description": "Include CREATE DATABASE"
    },
    {
      "name": "--if-exists",
      "description": "Use IF EXISTS with DROP"
    },
    {
      "name": "--inserts",
      "description": "Use INSERT instead of COPY"
    },
    {
      "name": "--column-inserts",
      "description": "Use INSERT with column names"
    },
    {
      "name": "--no-owner",
      "shorthand": "-O",
      "description": "Skip ownership"
    },
    {
      "name": "--no-privileges",
      "shorthand": "-x",
      "description": "Skip privileges"
    },
    {
      "name": "--compress",
      "shorthand": "-Z",
      "description": "Compression level (0-9)",
      "takesValue": true
    },
    {
      "name": "--jobs",
      "shorthand": "-j",
      "description": "Parallel dump jobs",
      "takesValue": true
    },
    {
      "name": "--verbose",
      "shorthand": "-v",
      "description": "Verbose mode"
    },
    {
      "name": "--no-comments",
      "description": "Don't dump comments"
    },
    {
      "name": "--encoding",
      "shorthand": "-E",
      "description": "Character encoding",
      "takesValue": true
    },
    {
      "name": "--section",
      "description": "Dump section (pre-data, data, post-data)",
      "takesValue": true
    }
  ],
  "examples": [
    {
      "command": "pg_dump mydb > backup.sql",
      "description": "Plain text dump"
    },
    {
      "command": "pg_dump -Fc mydb > backup.dump",
      "description": "Custom format dump"
    },
    {
      "command": "pg_dump -Fd mydb -j 4 -f backup_dir",
      "description": "Parallel directory dump"
    },
    {
      "command": "pg_dump -t users mydb > users.sql",
      "description": "Dump single table"
    },
    {
      "command": "pg_dump -s mydb > schema.sql",
      "description": "Schema only"
    },
    {
      "command": "pg_dump -h localhost -U admin -d mydb -Fc -f backup.dump",
      "description": "Full params dump"
    },
    {
      "command": "pg_dump --clean --if-exists mydb > backup.sql",
      "description": "Dump with DROP IF EXISTS"
    }
  ],
  "relatedCommands": [
    "pg_restore",
    "psql"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "databases",
        "description": "Available databases",
        "command": "psql -l -t 2>/dev/null | awk -F'|' '{print $1}' | sed 's/^ *//' | grep -v '^$' | head -20",
        "parser": "lines",
        "cacheFor": 30,
        "requiresCmd": "psql"
      },
      {
        "name": "schemas",
        "description": "Schemas in connected db",
        "command": "psql -t -c \"SELECT schema_name FROM information_schema.schemata WHERE schema_name NOT IN ('pg_catalog','information_schema')\" 2>/dev/null",
        "parser": "lines",
        "cacheFor": 60,
        "requiresCmd": "psql"
      },
      {
        "name": "tables",
        "description": "Tables in public schema",
        "command": "psql -t -c \"SELECT tablename FROM pg_tables WHERE schemaname='public'\" 2>/dev/null | head -30",
        "parser": "lines",
        "cacheFor": 30,
        "requiresCmd": "psql"
      },
      {
        "name": "pg_version",
        "description": "PostgreSQL version",
        "command": "pg_dump --version 2>/dev/null",
        "parser": "text",
        "cacheFor": 300,
        "requiresCmd": "pg_dump"
      }
    ]
  }
}
