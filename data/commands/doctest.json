{
  "language": "doctest",
  "name": "python -m doctest",
  "description": "Python doctest — test interactive examples embedded in docstrings",
  "category": "tool",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "-v",
      "description": "Verbose mode — display each test and its result"
    },
    {
      "name": "-o ELLIPSIS",
      "description": "Enable ellipsis matching in expected output"
    },
    {
      "name": "-o NORMALIZE_WHITESPACE",
      "description": "Ignore whitespace differences in output"
    },
    {
      "name": "-o IGNORE_EXCEPTION_DETAIL",
      "description": "Ignore exception message details"
    },
    {
      "name": "-o SKIP",
      "description": "Skip marked test cases"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    }
  ],
  "subcommands": [
    {
      "name": "-v file.py",
      "description": "Run doctests verbosely showing each test case",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "file.txt",
      "description": "Run doctests from a plain text file",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "file.py",
      "description": "Run doctests in a Python module (quiet mode)",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "-v module.py",
      "description": "Run doctests with verbose output",
      "args": [
        "file"
      ],
      "options": []
    }
  ],
  "examples": [
    "python -m doctest mymodule.py -v",
    "python -m doctest examples.txt",
    "python -m doctest -v utils.py",
    "pytest --doctest-modules",
    "python -c \"import doctest; doctest.testmod(mymodule, verbose=True)\""
  ],
  "relatedCommands": [
    "pytest",
    "python",
    "unittest"
  ]
}
