{
  "name": "vbc",
  "description": "Visual Basic — VB.NET compiler and .NET CLI tools",
  "category": "language",
  "platforms": ["linux", "macos", "windows"],
  "shells": ["bash", "zsh", "powershell"],
  "subcommands": [
    { "name": "/out:output.exe source.vb", "description": "Compile VB source to executable", "args": ["output", "source"], "options": [] },
    { "name": "/target:library source.vb", "description": "Compile as class library (DLL)", "args": ["source"], "options": [] },
    { "name": "/target:winexe source.vb", "description": "Compile as Windows application", "args": ["source"], "options": [] },
    { "name": "/debug+ source.vb", "description": "Compile with debug information", "args": ["source"], "options": [] },
    { "name": "/optimize+ source.vb", "description": "Compile with optimizations enabled", "args": ["source"], "options": [] }
  ],
  "globalOptions": [
    { "name": "/out:<file>", "description": "Output file name" },
    { "name": "/target:exe|library|winexe", "description": "Output type (console app, library, Windows app)" },
    { "name": "/reference:<assembly>", "description": "Reference an external assembly" },
    { "name": "/debug+", "description": "Emit debugging information" },
    { "name": "/optimize+", "description": "Enable optimizations" },
    { "name": "/imports:<namespace>", "description": "Import namespace globally" },
    { "name": "/define:<symbol>=<value>", "description": "Define conditional compilation symbol" },
    { "name": "/optionstrict+", "description": "Enforce strict type checking" }
  ],
  "examples": [
    "vbc /out:app.exe Program.vb",
    "vbc /target:library /out:MyLib.dll Module1.vb",
    "dotnet new console -lang VB -o MyApp",
    "dotnet run --project MyApp",
    "dotnet build --configuration Release"
  ],
  "relatedCommands": ["dotnet", "csharp", "sb", "msbuild"]
}