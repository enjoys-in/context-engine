{
  "language": "vb",
  "name": "vbc",
  "description": "Visual Basic — VB.NET compiler and .NET CLI tools",
  "category": "language",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "/out:<file>",
      "description": "Output file name"
    },
    {
      "name": "/target:exe|library|winexe",
      "description": "Output type (console app, library, Windows app)"
    },
    {
      "name": "/reference:<assembly>",
      "description": "Reference an external assembly"
    },
    {
      "name": "/debug+",
      "description": "Emit debugging information"
    },
    {
      "name": "/optimize+",
      "description": "Enable optimizations"
    },
    {
      "name": "/imports:<namespace>",
      "description": "Import namespace globally"
    },
    {
      "name": "/define:<symbol>=<value>",
      "description": "Define conditional compilation symbol"
    },
    {
      "name": "/optionstrict+",
      "description": "Enforce strict type checking"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    }
  ],
  "subcommands": [
    {
      "name": "/out:output.exe source.vb",
      "description": "Compile VB source to executable",
      "args": [
        "output",
        "source"
      ],
      "options": []
    },
    {
      "name": "/target:library source.vb",
      "description": "Compile as class library (DLL)",
      "args": [
        "source"
      ],
      "options": []
    },
    {
      "name": "/target:winexe source.vb",
      "description": "Compile as Windows application",
      "args": [
        "source"
      ],
      "options": []
    },
    {
      "name": "/debug+ source.vb",
      "description": "Compile with debug information",
      "args": [
        "source"
      ],
      "options": []
    },
    {
      "name": "/optimize+ source.vb",
      "description": "Compile with optimizations enabled",
      "args": [
        "source"
      ],
      "options": []
    }
  ],
  "examples": [
    "vbc /out:app.exe Program.vb",
    "vbc /target:library /out:MyLib.dll Module1.vb",
    "dotnet new console -lang VB -o MyApp",
    "dotnet run --project MyApp",
    "dotnet build --configuration Release"
  ],
  "relatedCommands": [
    "dotnet",
    "csharp",
    "sb",
    "msbuild"
  ]
}
