{
  "name": "dotnet",
  "description": ".NET CLI — build, run, publish .NET applications",
  "category": "languages",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "new",
      "description": "Create new project",
      "examples": [
        "dotnet new console",
        "dotnet new webapi -n MyApi",
        "dotnet new list"
      ]
    },
    {
      "name": "build",
      "description": "Build project",
      "examples": [
        "dotnet build",
        "dotnet build -c Release"
      ]
    },
    {
      "name": "run",
      "description": "Run project",
      "examples": [
        "dotnet run",
        "dotnet run --project src/MyApp"
      ]
    },
    {
      "name": "test",
      "description": "Run tests",
      "examples": [
        "dotnet test"
      ]
    },
    {
      "name": "publish",
      "description": "Publish for deployment",
      "examples": [
        "dotnet publish -c Release -o ./out"
      ]
    },
    {
      "name": "add",
      "description": "Add package/reference",
      "examples": [
        "dotnet add package Newtonsoft.Json",
        "dotnet add reference ../Lib/Lib.csproj"
      ]
    },
    {
      "name": "restore",
      "description": "Restore dependencies",
      "examples": [
        "dotnet restore"
      ]
    },
    {
      "name": "clean",
      "description": "Clean build output",
      "examples": [
        "dotnet clean"
      ]
    },
    {
      "name": "ef",
      "description": "Entity Framework commands",
      "examples": [
        "dotnet ef migrations add Init",
        "dotnet ef database update"
      ]
    },
    {
      "name": "tool",
      "description": "Manage .NET tools",
      "examples": [
        "dotnet tool install -g dotnet-ef",
        "dotnet tool list -g"
      ]
    },
    {
      "name": "watch",
      "description": "Watch for changes and restart",
      "examples": [
        "dotnet watch run"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "-c",
      "description": "Configuration (Debug, Release)",
      "type": "string"
    },
    {
      "name": "-o",
      "description": "Output directory",
      "type": "string"
    },
    {
      "name": "-v",
      "description": "Verbosity (q, m, n, d, diag)",
      "type": "string"
    },
    {
      "name": "--no-restore",
      "description": "Skip restore"
    }
  ],
  "examples": [
    "dotnet new webapi -n MyApi",
    "dotnet build -c Release",
    "dotnet run",
    "dotnet test",
    "dotnet publish -c Release",
    "dotnet watch run"
  ],
  "relatedCommands": [
    "msbuild",
    "nuget",
    "csharp"
  ]
}
