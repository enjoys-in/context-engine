{
  "language": "awk",
  "name": "awk",
  "description": "Pattern scanning and text processing language",
  "category": "text-processing",
  "platforms": [
    "linux",
    "macos"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish"
  ],
  "globalOptions": [
    {
      "name": "-F",
      "description": "Field separator",
      "type": "string"
    },
    {
      "name": "-v",
      "description": "Assign variable",
      "type": "string"
    },
    {
      "name": "-f",
      "description": "Program file",
      "type": "file"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    }
  ],
  "subcommands": [
    {
      "name": "print",
      "description": "Print text or field values",
      "usage": "awk '{print $1}' file.txt"
    },
    {
      "name": "printf",
      "description": "Formatted output",
      "usage": "awk '{printf \"%-10s %d\\n\", $1, $2}' file.txt"
    },
    {
      "name": "split",
      "description": "Split string into array",
      "usage": "awk '{split($0, a, \":\"); print a[1]}' file.txt"
    },
    {
      "name": "gsub",
      "description": "Global string substitution",
      "usage": "awk '{gsub(/old/, \"new\"); print}' file.txt"
    },
    {
      "name": "match",
      "description": "Pattern matching",
      "usage": "awk '/pattern/ {print}' file.txt"
    },
    {
      "name": "substr",
      "description": "Extract substring",
      "usage": "awk '{print substr($0, 1, 10)}' file.txt"
    },
    {
      "name": "length",
      "description": "Get string length",
      "usage": "awk '{print length($0)}' file.txt"
    },
    {
      "name": "tolower",
      "description": "Convert to lowercase",
      "usage": "awk '{print tolower($0)}' file.txt"
    }
  ],
  "examples": [
    "awk '{print $1}' file.txt",
    "awk -F: '{print $1, $3}' /etc/passwd",
    "awk '/pattern/ {print}' file.txt",
    "awk '{sum += $1} END {print sum}' numbers.txt",
    "awk 'NR==10,NR==20' file.txt",
    "awk '{print NR, $0}' file.txt",
    "awk -F, '{print $2}' data.csv",
    "awk 'length > 80' file.txt",
    "awk '!seen[$0]++' file.txt",
    "ps aux | awk '{print $2, $11}'"
  ],
  "relatedCommands": [
    "sed",
    "grep",
    "cut",
    "sort",
    "uniq",
    "perl"
  ]
}
