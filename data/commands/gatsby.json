{
  "name": "gatsby",
  "description": "React-based static site generator framework",
  "category": "static-site",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "new",
      "description": "Create a new site",
      "examples": [
        "gatsby new my-site",
        "gatsby new my-blog https://github.com/gatsbyjs/gatsby-starter-blog"
      ]
    },
    {
      "name": "develop",
      "description": "Start development server",
      "examples": [
        "gatsby develop",
        "gatsby develop -H 0.0.0.0"
      ]
    },
    {
      "name": "build",
      "description": "Build production site",
      "examples": [
        "gatsby build"
      ]
    },
    {
      "name": "serve",
      "description": "Serve production build locally",
      "examples": [
        "gatsby serve"
      ]
    },
    {
      "name": "clean",
      "description": "Clean .cache and public dirs",
      "examples": [
        "gatsby clean"
      ]
    },
    {
      "name": "info",
      "description": "Show environment info",
      "examples": [
        "gatsby info"
      ]
    },
    {
      "name": "repl",
      "description": "Open a REPL with Gatsby context",
      "examples": [
        "gatsby repl"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "-H",
      "description": "Host",
      "type": "string"
    },
    {
      "name": "-p",
      "description": "Port",
      "type": "number"
    },
    {
      "name": "-o",
      "description": "Open in browser"
    },
    {
      "name": "--prefix-paths",
      "description": "Build with path prefix"
    },
    {
      "name": "--verbose",
      "description": "Verbose output"
    }
  ],
  "examples": [
    "gatsby new my-site",
    "gatsby develop",
    "gatsby build",
    "gatsby serve",
    "gatsby clean"
  ],
  "relatedCommands": [
    "next",
    "astro",
    "hugo",
    "eleventy"
  ]
}
