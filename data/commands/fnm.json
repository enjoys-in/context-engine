{
  "name": "fnm",
  "description": "Fast Node Manager — fast and simple Node.js version manager",
  "category": "version-manager",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "install",
      "description": "Install a Node.js version",
      "examples": [
        "fnm install 20",
        "fnm install --lts"
      ]
    },
    {
      "name": "use",
      "description": "Use an installed version",
      "examples": [
        "fnm use 20",
        "fnm use --lts"
      ]
    },
    {
      "name": "list",
      "description": "List installed versions",
      "examples": [
        "fnm list"
      ]
    },
    {
      "name": "list-remote",
      "description": "List available versions",
      "examples": [
        "fnm list-remote"
      ]
    },
    {
      "name": "default",
      "description": "Set the default version",
      "examples": [
        "fnm default 20"
      ]
    },
    {
      "name": "current",
      "description": "Show current version",
      "examples": [
        "fnm current"
      ]
    },
    {
      "name": "env",
      "description": "Print shell env setup",
      "examples": [
        "fnm env --use-on-cd"
      ]
    },
    {
      "name": "uninstall",
      "description": "Uninstall a version",
      "examples": [
        "fnm uninstall 16"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--node-dist-mirror",
      "description": "Mirror URL for downloads",
      "type": "string"
    },
    {
      "name": "--log-level",
      "description": "Log level (quiet, error, info)",
      "type": "string"
    }
  ],
  "examples": [
    "fnm install --lts",
    "fnm use 20",
    "fnm list",
    "fnm default 20",
    "fnm env --use-on-cd"
  ],
  "relatedCommands": [
    "nvm",
    "volta",
    "node"
  ]
}
