{
  "language": "xml",
  "name": "xmllint",
  "description": "XML command-line tool",
  "category": "development",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--help",
      "description": "Show help information"
    },
    {
      "name": "--version",
      "description": "Show version information"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    },
    {
      "name": "--working-dir",
      "description": "Set the working directory",
      "valueHint": "dir",
      "alias": "-d"
    }
  ],
  "subcommands": [
    {
      "name": "--format file.xml",
      "description": "Format/pretty print",
      "args": [],
      "options": []
    },
    {
      "name": "--valid file.xml",
      "description": "Validate DTD",
      "args": [],
      "options": []
    },
    {
      "name": "--schema schema.xsd file.xml",
      "description": "Validate XSD",
      "args": [],
      "options": []
    },
    {
      "name": "--xpath expr file.xml",
      "description": "Query with XPath",
      "args": [],
      "options": []
    },
    {
      "name": "validate",
      "description": "Validate XML against schema",
      "usage": "xmllint --schema schema.xsd file.xml"
    },
    {
      "name": "format",
      "description": "Format/pretty-print XML",
      "usage": "xmllint --format file.xml"
    },
    {
      "name": "xpath",
      "description": "Query XML with XPath",
      "usage": "xmllint --xpath '//element' file.xml"
    },
    {
      "name": "transform",
      "description": "Apply XSLT transformation",
      "usage": "xsltproc style.xsl file.xml"
    }
  ],
  "examples": [
    {
      "command": "xmllint --format file.xml",
      "description": "Pretty-print XML file"
    },
    {
      "command": "xmllint --schema schema.xsd file.xml",
      "description": "Validate XML against XSD schema"
    },
    {
      "command": "xmllint --xpath '//element' file.xml",
      "description": "Query XML with XPath"
    },
    {
      "command": "xsltproc style.xsl file.xml",
      "description": "Apply XSLT transformation"
    }
  ],
  "relatedCommands": []
}
