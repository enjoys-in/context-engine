{
  "language": "pla",
  "name": "pla",
  "description": "PLA — Programmable Logic Array tools and synthesis",
  "category": "tool",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "-o",
      "description": "Output file path"
    },
    {
      "name": "--method",
      "description": "Minimization method (espresso, exact, heuristic)"
    },
    {
      "name": "--verbose",
      "description": "Show detailed processing information"
    },
    {
      "name": "-f",
      "description": "Input format (pla, blif, truth-table)"
    },
    {
      "name": "-t",
      "description": "Output target format"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    }
  ],
  "subcommands": [
    {
      "name": "minimize",
      "description": "Minimize PLA logic using Espresso algorithm",
      "args": [
        "input.pla"
      ],
      "options": [
        "-o",
        "--method"
      ]
    },
    {
      "name": "simulate",
      "description": "Simulate PLA truth table with input vectors",
      "args": [
        "input.pla"
      ],
      "options": [
        "--inputs",
        "--verbose"
      ]
    },
    {
      "name": "convert",
      "description": "Convert between PLA, BLIF, and Verilog formats",
      "args": [
        "input"
      ],
      "options": [
        "-f",
        "-t"
      ]
    },
    {
      "name": "verify",
      "description": "Verify PLA against reference truth table",
      "args": [
        "design.pla",
        "reference.pla"
      ],
      "options": []
    },
    {
      "name": "stats",
      "description": "Show PLA statistics (inputs, outputs, product terms)",
      "args": [
        "input.pla"
      ],
      "options": []
    }
  ],
  "examples": [
    "espresso input.pla > output.pla",
    "espresso -Dexact input.pla",
    "abc -c 'read_pla design.pla; print_stats'",
    "espresso -oeqntott input.pla"
  ],
  "relatedCommands": [
    "systemverilog",
    "abc",
    "yosys"
  ]
}
