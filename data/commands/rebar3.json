{
  "name": "rebar3",
  "description": "Erlang build tool",
  "category": "languages",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "new",
      "description": "Create new project",
      "examples": [
        "rebar3 new app myapp",
        "rebar3 new lib mylib"
      ]
    },
    {
      "name": "compile",
      "description": "Compile project",
      "examples": [
        "rebar3 compile"
      ]
    },
    {
      "name": "eunit",
      "description": "Run EUnit tests",
      "examples": [
        "rebar3 eunit"
      ]
    },
    {
      "name": "ct",
      "description": "Run Common Test suites",
      "examples": [
        "rebar3 ct"
      ]
    },
    {
      "name": "release",
      "description": "Build release",
      "examples": [
        "rebar3 release"
      ]
    },
    {
      "name": "shell",
      "description": "Start Erlang shell with project",
      "examples": [
        "rebar3 shell"
      ]
    },
    {
      "name": "dialyzer",
      "description": "Run Dialyzer",
      "examples": [
        "rebar3 dialyzer"
      ]
    },
    {
      "name": "clean",
      "description": "Clean build",
      "examples": [
        "rebar3 clean"
      ]
    },
    {
      "name": "deps",
      "description": "List dependencies",
      "examples": [
        "rebar3 deps"
      ]
    },
    {
      "name": "upgrade",
      "description": "Upgrade dependencies",
      "examples": [
        "rebar3 upgrade"
      ]
    },
    {
      "name": "hex publish",
      "description": "Publish to Hex.pm",
      "examples": [
        "rebar3 hex publish"
      ]
    }
  ],
  "globalOptions": [],
  "examples": [
    "rebar3 new app myapp",
    "rebar3 compile",
    "rebar3 eunit",
    "rebar3 release",
    "rebar3 shell"
  ],
  "relatedCommands": [
    "erlang",
    "mix",
    "erl",
    "erlc"
  ]
}
