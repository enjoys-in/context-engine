{
  "name": "changeset",
  "description": "Manage versioning and changelogs for monorepos",
  "category": "build-tools",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "add",
      "description": "Add a new changeset",
      "examples": [
        "changeset add"
      ]
    },
    {
      "name": "version",
      "description": "Apply changesets to versions/changelogs",
      "examples": [
        "changeset version"
      ]
    },
    {
      "name": "publish",
      "description": "Publish changed packages",
      "examples": [
        "changeset publish"
      ]
    },
    {
      "name": "status",
      "description": "Show current changeset status",
      "examples": [
        "changeset status"
      ]
    },
    {
      "name": "init",
      "description": "Initialize changesets",
      "examples": [
        "changeset init"
      ]
    }
  ],
  "globalOptions": [],
  "examples": [
    "changeset",
    "changeset add",
    "changeset version",
    "changeset publish",
    "changeset status",
    "npx @changesets/cli init"
  ],
  "relatedCommands": [
    "lerna",
    "semantic-release",
    "npm",
    "pnpm"
  ]
}
