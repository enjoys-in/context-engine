{
  "language": "clojure",
  "name": "clj",
  "description": "Clojure command-line tool",
  "category": "development",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--help",
      "description": "Show help information"
    },
    {
      "name": "--version",
      "description": "Show version information"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    }
  ],
  "subcommands": [
    {
      "name": "-M:repl",
      "description": "Start REPL",
      "args": [],
      "options": []
    },
    {
      "name": "-X:test",
      "description": "Run tests",
      "args": [],
      "options": []
    },
    {
      "name": "-T:build",
      "description": "Run build tool",
      "args": [],
      "options": []
    },
    {
      "name": "-M -m namespace",
      "description": "Run main function",
      "args": [],
      "options": []
    },
    {
      "name": "test",
      "description": "Run Clojure tests",
      "usage": "lein test"
    },
    {
      "name": "deps",
      "description": "Download dependencies",
      "usage": "lein deps"
    },
    {
      "name": "jar",
      "description": "Build JAR file",
      "usage": "lein jar"
    },
    {
      "name": "uberjar",
      "description": "Build standalone JAR",
      "usage": "lein uberjar"
    },
    {
      "name": "new",
      "description": "Create new project",
      "usage": "lein new app myproject"
    }
  ],
  "examples": [
    {
      "command": "lein new app my-project",
      "description": "Create new Clojure project"
    },
    {
      "command": "lein run",
      "description": "Run Clojure project"
    },
    {
      "command": "lein test",
      "description": "Run tests"
    },
    {
      "command": "lein repl",
      "description": "Start a REPL session"
    },
    {
      "command": "lein uberjar",
      "description": "Build standalone JAR"
    }
  ],
  "relatedCommands": []
}
