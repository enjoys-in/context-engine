{
  "name": "jekyll",
  "description": "Static site generator — transform text into static websites",
  "category": "static-site",
  "platforms": [
    "linux",
    "macos"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish"
  ],
  "subcommands": [
    {
      "name": "new",
      "description": "Create a new Jekyll site",
      "examples": [
        "jekyll new myblog"
      ]
    },
    {
      "name": "build",
      "description": "Build the site",
      "examples": [
        "jekyll build",
        "jekyll build --destination ./output"
      ]
    },
    {
      "name": "serve",
      "description": "Start local server",
      "examples": [
        "jekyll serve",
        "jekyll serve --livereload"
      ]
    },
    {
      "name": "doctor",
      "description": "Check for issues",
      "examples": [
        "jekyll doctor"
      ]
    },
    {
      "name": "clean",
      "description": "Clean the build output",
      "examples": [
        "jekyll clean"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "-s",
      "description": "Source directory",
      "type": "string"
    },
    {
      "name": "-d",
      "description": "Destination directory",
      "type": "string"
    },
    {
      "name": "--drafts",
      "description": "Include drafts"
    },
    {
      "name": "--livereload",
      "description": "Enable live reload"
    },
    {
      "name": "-H",
      "description": "Host to bind to",
      "type": "string"
    },
    {
      "name": "-P",
      "description": "Port number",
      "type": "number"
    },
    {
      "name": "--baseurl",
      "description": "Base URL",
      "type": "string"
    },
    {
      "name": "--future",
      "description": "Include future-dated posts"
    }
  ],
  "examples": [
    "jekyll new myblog",
    "jekyll serve",
    "jekyll build",
    "jekyll serve --livereload",
    "jekyll serve --drafts -P 4001"
  ],
  "relatedCommands": [
    "hugo",
    "gatsby",
    "eleventy",
    "bundler"
  ]
}
