{
  "language": "typescript",
  "name": "tsc",
  "description": "TypeScript command-line tool",
  "category": "development",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--help",
      "description": "Show help information"
    },
    {
      "name": "--version",
      "description": "Show version information"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    }
  ],
  "subcommands": [
    {
      "name": "--init",
      "description": "Create tsconfig.json",
      "args": [],
      "options": []
    },
    {
      "name": "--watch",
      "description": "Watch mode",
      "args": [],
      "options": []
    },
    {
      "name": "file.ts",
      "description": "Compile file",
      "args": [],
      "options": []
    },
    {
      "name": "--noEmit",
      "description": "Type check only",
      "args": [],
      "options": []
    },
    {
      "name": "check",
      "description": "Type-check without emitting",
      "usage": "tsc --noEmit"
    },
    {
      "name": "init",
      "description": "Create tsconfig.json",
      "usage": "tsc --init"
    },
    {
      "name": "watch",
      "description": "Watch mode compilation",
      "usage": "tsc --watch"
    },
    {
      "name": "build",
      "description": "Build project references",
      "usage": "tsc --build"
    },
    {
      "name": "declaration",
      "description": "Generate declaration files",
      "usage": "tsc --declaration"
    }
  ],
  "examples": [
    {
      "command": "tsc",
      "description": "Compile TypeScript"
    },
    {
      "command": "tsc --init",
      "description": "Create tsconfig.json"
    },
    {
      "command": "tsc --noEmit",
      "description": "Type-check without emitting files"
    },
    {
      "command": "tsc --watch",
      "description": "Watch mode compilation"
    },
    {
      "command": "tsc --build",
      "description": "Build project references"
    }
  ],
  "relatedCommands": []
}
