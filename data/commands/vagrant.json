{
  "name": "vagrant",
  "description": "Build and manage reproducible development environments",
  "category": "devops",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "init",
      "description": "Initialize a Vagrantfile",
      "examples": [
        "vagrant init ubuntu/jammy64"
      ]
    },
    {
      "name": "up",
      "description": "Start and provision VM",
      "examples": [
        "vagrant up"
      ]
    },
    {
      "name": "ssh",
      "description": "SSH into the VM",
      "examples": [
        "vagrant ssh"
      ]
    },
    {
      "name": "halt",
      "description": "Stop the VM",
      "examples": [
        "vagrant halt"
      ]
    },
    {
      "name": "destroy",
      "description": "Destroy the VM",
      "examples": [
        "vagrant destroy -f"
      ]
    },
    {
      "name": "reload",
      "description": "Restart VM with new config",
      "examples": [
        "vagrant reload --provision"
      ]
    },
    {
      "name": "provision",
      "description": "Run provisioners",
      "examples": [
        "vagrant provision"
      ]
    },
    {
      "name": "status",
      "description": "Show VM status",
      "examples": [
        "vagrant status"
      ]
    },
    {
      "name": "snapshot",
      "description": "Manage snapshots",
      "examples": [
        "vagrant snapshot save clean",
        "vagrant snapshot restore clean"
      ]
    },
    {
      "name": "box",
      "description": "Manage boxes",
      "examples": [
        "vagrant box list",
        "vagrant box add ubuntu/jammy64"
      ]
    },
    {
      "name": "global-status",
      "description": "Show all VMs on host",
      "examples": [
        "vagrant global-status"
      ]
    }
  ],
  "globalOptions": [],
  "examples": [
    "vagrant init ubuntu/jammy64",
    "vagrant up",
    "vagrant ssh",
    "vagrant halt",
    "vagrant destroy -f",
    "vagrant status"
  ],
  "relatedCommands": [
    "docker",
    "virtualbox",
    "terraform",
    "ansible"
  ]
}
