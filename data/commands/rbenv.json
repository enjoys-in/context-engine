{
  "name": "rbenv",
  "description": "Simple Ruby version management",
  "category": "version-manager",
  "platforms": [
    "linux",
    "macos"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish"
  ],
  "subcommands": [
    {
      "name": "install",
      "description": "Install a Ruby version",
      "examples": [
        "rbenv install 3.3.0"
      ]
    },
    {
      "name": "versions",
      "description": "List installed versions",
      "examples": [
        "rbenv versions"
      ]
    },
    {
      "name": "global",
      "description": "Set global Ruby version",
      "examples": [
        "rbenv global 3.3.0"
      ]
    },
    {
      "name": "local",
      "description": "Set local Ruby version",
      "examples": [
        "rbenv local 3.2.0"
      ]
    },
    {
      "name": "shell",
      "description": "Set shell-specific version",
      "examples": [
        "rbenv shell 3.3.0"
      ]
    },
    {
      "name": "uninstall",
      "description": "Uninstall a version",
      "examples": [
        "rbenv uninstall 3.1.0"
      ]
    },
    {
      "name": "which",
      "description": "Show full path for command",
      "examples": [
        "rbenv which ruby"
      ]
    },
    {
      "name": "rehash",
      "description": "Rehash shims",
      "examples": [
        "rbenv rehash"
      ]
    }
  ],
  "globalOptions": [],
  "examples": [
    "rbenv install 3.3.0",
    "rbenv global 3.3.0",
    "rbenv versions",
    "rbenv local 3.2.0"
  ],
  "relatedCommands": [
    "ruby",
    "gem",
    "bundle",
    "rvm"
  ]
}
