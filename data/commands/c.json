{
  "name": "gcc",
  "description": "GCC — GNU C Compiler toolchain",
  "category": "language",
  "platforms": ["linux", "macos", "windows"],
  "shells": ["bash", "zsh", "powershell"],
  "subcommands": [
    { "name": "file.c -o output", "description": "Compile C file to executable", "args": [], "options": [] },
    { "name": "-Wall -Wextra file.c", "description": "Compile with all warnings enabled", "args": [], "options": [] },
    { "name": "-g file.c", "description": "Compile with debug information", "args": [], "options": [] },
    { "name": "-c file.c", "description": "Compile to object file without linking", "args": [], "options": [] },
    { "name": "-E file.c", "description": "Preprocess only, output to stdout", "args": [], "options": [] },
    { "name": "-S file.c", "description": "Compile to assembly language", "args": [], "options": [] }
  ],
  "globalOptions": [
    { "name": "-o", "description": "Specify output file name" },
    { "name": "-O0 / -O1 / -O2 / -O3 / -Os", "description": "Optimization level (0=none, 3=max, s=size)" },
    { "name": "-Wall", "description": "Enable all common warnings" },
    { "name": "-Werror", "description": "Treat all warnings as errors" },
    { "name": "-std=c11 / -std=c17 / -std=c23", "description": "Set C language standard" },
    { "name": "-I<dir>", "description": "Add include directory for header search" },
    { "name": "-L<dir>", "description": "Add library search directory" },
    { "name": "-l<lib>", "description": "Link with library" },
    { "name": "-D<macro>=<value>", "description": "Define preprocessor macro" },
    { "name": "-fsanitize=address", "description": "Enable AddressSanitizer for memory error detection" }
  ],
  "examples": [
    "gcc -Wall -Wextra -std=c17 main.c -o main",
    "gcc -O2 -o app main.c utils.c -lm",
    "gcc -g -fsanitize=address main.c -o debug_app",
    "gcc -c module.c && gcc -c main.c && gcc module.o main.o -o app",
    "gcc -E main.c | less"
  ],
  "relatedCommands": ["make", "cmake", "gdb", "valgrind", "cpp"]
}