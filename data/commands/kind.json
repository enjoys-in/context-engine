{
  "name": "kind",
  "description": "Kubernetes IN Docker — local Kubernetes clusters",
  "category": "containers",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "create cluster",
      "description": "Create a cluster",
      "examples": [
        "kind create cluster",
        "kind create cluster --name my-cluster"
      ]
    },
    {
      "name": "delete cluster",
      "description": "Delete a cluster",
      "examples": [
        "kind delete cluster"
      ]
    },
    {
      "name": "get clusters",
      "description": "List clusters",
      "examples": [
        "kind get clusters"
      ]
    },
    {
      "name": "get nodes",
      "description": "List cluster nodes",
      "examples": [
        "kind get nodes"
      ]
    },
    {
      "name": "load docker-image",
      "description": "Load Docker image into cluster",
      "examples": [
        "kind load docker-image myapp:latest"
      ]
    },
    {
      "name": "export kubeconfig",
      "description": "Export kubeconfig",
      "examples": [
        "kind export kubeconfig --name my-cluster"
      ]
    },
    {
      "name": "export logs",
      "description": "Export cluster logs",
      "examples": [
        "kind export logs ./logs"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--name",
      "description": "Cluster name",
      "type": "string"
    },
    {
      "name": "--config",
      "description": "Config file path",
      "type": "file"
    },
    {
      "name": "--image",
      "description": "Node image to use",
      "type": "string"
    }
  ],
  "examples": [
    "kind create cluster",
    "kind create cluster --config kind-config.yaml",
    "kind get clusters",
    "kind load docker-image myapp:latest",
    "kind delete cluster"
  ],
  "relatedCommands": [
    "kubectl",
    "minikube",
    "docker",
    "k3d"
  ]
}
