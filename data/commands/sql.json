{
  "language": "sql",
  "name": "sql",
  "description": "SQL — Structured Query Language for relational databases",
  "category": "database",
  "contextEngine": {
    "detectors": []
  },
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "-h / --host",
      "description": "Database server hostname"
    },
    {
      "name": "-p / --port",
      "description": "Database server port"
    },
    {
      "name": "-U / --user",
      "description": "Database username"
    },
    {
      "name": "-d / --database",
      "description": "Target database name"
    },
    {
      "name": "-f / --file",
      "description": "Execute SQL from file"
    },
    {
      "name": "-o / --output",
      "description": "Write results to output file"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    }
  ],
  "subcommands": [
    {
      "name": "sqlite3",
      "description": "SQLite3 interactive shell and command-line tool",
      "args": [
        "database"
      ],
      "options": [
        "-cmd",
        "-csv",
        "-json",
        "-header"
      ]
    },
    {
      "name": "mysql",
      "description": "MySQL command-line client",
      "args": [
        "database"
      ],
      "options": [
        "-u",
        "-p",
        "-h",
        "-e",
        "--batch"
      ]
    },
    {
      "name": "psql",
      "description": "PostgreSQL interactive terminal",
      "args": [
        "database"
      ],
      "options": [
        "-U",
        "-h",
        "-c",
        "-f",
        "--csv"
      ]
    },
    {
      "name": "sqlcmd",
      "description": "SQL Server command-line utility",
      "args": [],
      "options": [
        "-S",
        "-U",
        "-P",
        "-Q",
        "-i"
      ]
    },
    {
      "name": "sqlfmt",
      "description": "SQL formatter for standardized code style",
      "args": [
        "file.sql"
      ],
      "options": [
        "--uppercase",
        "--indent"
      ]
    },
    {
      "name": "sqlfluff",
      "description": "SQL linter and auto-fixer",
      "args": [
        "file.sql"
      ],
      "options": [
        "--dialect",
        "--fix"
      ]
    }
  ],
  "examples": [
    "SELECT * FROM users;",
    "SELECT id, name FROM users WHERE active = 1;",
    "INSERT INTO users (name, email) VALUES ('John', 'john@example.com');",
    "UPDATE users SET active = 0 WHERE id = 5;",
    "DELETE FROM users WHERE id = 5;",
    "CREATE TABLE users (id INT PRIMARY KEY, name VARCHAR(100));",
    "ALTER TABLE users ADD COLUMN email VARCHAR(255);",
    "DROP TABLE IF EXISTS temp_users;",
    "CREATE INDEX idx_email ON users(email);",
    "SELECT u.name, o.total FROM users u JOIN orders o ON u.id = o.user_id;",
    "SELECT department, COUNT(*) FROM employees GROUP BY department HAVING COUNT(*) > 5;",
    "SELECT * FROM users ORDER BY created_at DESC LIMIT 10;",
    "BEGIN TRANSACTION; UPDATE accounts SET balance = balance - 100 WHERE id = 1; COMMIT;",
    "CREATE VIEW active_users AS SELECT * FROM users WHERE active = 1;",
    "EXPLAIN ANALYZE SELECT * FROM users WHERE email = 'test@example.com';",
    "WITH cte AS (SELECT * FROM users WHERE active = 1) SELECT * FROM cte;",
    "SELECT COALESCE(nickname, name) AS display_name FROM users;",
    "GRANT SELECT, INSERT ON users TO readonly_user;",
    "CREATE TRIGGER log_update AFTER UPDATE ON users FOR EACH ROW EXECUTE FUNCTION log_changes();"
  ],
  "relatedCommands": [
    "psql",
    "mysql",
    "sqlite3",
    "mongosh",
    "redis-cli"
  ]
}
