{
  "name": "remix",
  "description": "Full-stack React framework with nested routing",
  "category": "static-site",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "init",
      "description": "Create a new Remix project",
      "examples": [
        "npx create-remix@latest"
      ]
    },
    {
      "name": "dev",
      "description": "Start development server",
      "examples": [
        "remix dev",
        "npx remix dev"
      ]
    },
    {
      "name": "build",
      "description": "Build for production",
      "examples": [
        "remix build"
      ]
    },
    {
      "name": "routes",
      "description": "Show application routes",
      "examples": [
        "remix routes"
      ]
    },
    {
      "name": "reveal",
      "description": "Reveal Remix entry files",
      "examples": [
        "remix reveal entry.server",
        "remix reveal entry.client"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--port",
      "description": "Dev server port",
      "type": "number"
    },
    {
      "name": "--app-directory",
      "description": "App directory path",
      "type": "string"
    }
  ],
  "examples": [
    "npx create-remix@latest",
    "remix dev",
    "remix build",
    "remix routes",
    "remix reveal entry.server"
  ],
  "relatedCommands": [
    "next",
    "astro",
    "vite",
    "react-router"
  ]
}
