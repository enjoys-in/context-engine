      ]
    },
    {
      "name": "option delete",
      "description": "Delete a site option",
      "args": [{"name": "key", "type": "string", "required": true, "description": "Option key to delete"}],
      "options": [],
      "examples": [
        "wp option delete my_custom_option"
      ]
    },
    {
      "name": "option list",
      "description": "List site options",
