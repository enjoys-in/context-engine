        "gunzip < backup.sql.gz | wp db import -"
      ]
    },
    {
      "name": "db query",
      "description": "Execute a SQL query against the database",
      "args": [{"name": "query", "type": "string", "required": false, "description": "SQL query to execute"}],
      "options": [],
