{
  "name": "prisma",
  "description": "Next-generation ORM for Node.js and TypeScript",
  "category": "Database ORMs & Migrations",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "generate",
      "description": "Generate artifacts (e.g. Prisma Client)"
    },
    {
      "name": "migrate",
      "description": "Update the database schema with migrations"
    },
    {
      "name": "db",
      "description": "Manage your database schema and lifecycle"
    },
    {
      "name": "studio",
      "description": "Browse your data with Prisma Studio"
    }
  ],
  "globalOptions": [],
  "examples": [
    {
      "command": "npx prisma generate",
      "description": "Generate Prisma Client"
    },
    {
      "command": "npx prisma migrate dev --name init",
      "description": "Create a dev migration"
    },
    {
      "command": "npx prisma db push",
      "description": "Push state to DB"
    }
  ],
  "relatedCommands": [
    "node",
    "npm"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "schema",
        "description": "Schema file",
        "command": "cat prisma/schema.prisma 2>/dev/null | head -15",
        "parser": "text",
        "cacheFor": 30
      }
    ]
  }
}