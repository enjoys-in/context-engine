{
  "name": "echo",
  "description": "Display text to standard output",
  "category": "coreutils",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "-n",
      "description": "Do not output trailing newline"
    },
    {
      "name": "-e",
      "description": "Enable interpretation of backslash escapes"
    },
    {
      "name": "-E",
      "description": "Disable interpretation of backslash escapes"
    }
  ],
  "examples": [
    "echo 'Hello World'",
    "echo -n 'no newline'",
    "echo -e 'line1\\nline2'",
    "echo $HOME",
    "echo \"Value: $VAR\"",
    "echo 'text' > file.txt",
    "echo 'append' >> file.txt"
  ],
  "relatedCommands": [
    "printf",
    "cat",
    "tee"
  ]
}
