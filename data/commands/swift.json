{
  "name": "swift",
  "description": "Swift — safe, fast, expressive language by Apple",
  "category": "language",
  "platforms": ["linux", "macos"],
  "shells": ["bash", "zsh", "fish"],
  "subcommands": [
    {"name": "build", "description": "Build Swift package"},
    {"name": "run", "description": "Build and run an executable product"},
    {"name": "test", "description": "Run package tests"},
    {"name": "package", "description": "Perform operations on Swift packages"},
    {"name": "package init", "description": "Initialize a new Swift package"},
    {"name": "package update", "description": "Update package dependencies"},
    {"name": "package resolve", "description": "Resolve package dependencies"},
    {"name": "package show-dependencies", "description": "Show resolved package dependencies"},
    {"name": "package clean", "description": "Delete build artifacts"},
    {"name": "package reset", "description": "Reset the complete cache/build directory"},
    {"name": "package generate-xcodeproj", "description": "Generate an Xcode project"}
  ],
  "globalOptions": [
    {"name": "-O", "description": "Compile with optimizations"},
    {"name": "-g", "description": "Include debug information in compilation"},
    {"name": "-Onone", "description": "Compile without any optimizations"},
    {"name": "-Ounchecked", "description": "Compile with optimizations and remove runtime safety checks"},
    {"name": "-whole-module-optimization", "description": "Enable whole module optimization"},
    {"name": "-target", "description": "Generate code for the given target triple", "type": "string"},
    {"name": "-sdk", "description": "Compile against the given SDK path", "type": "string"},
    {"name": "-I", "description": "Add directory to import search path", "type": "string"},
    {"name": "-L", "description": "Add directory to library link search path", "type": "string"},
    {"name": "-F", "description": "Add directory to framework search path", "type": "string"},
    {"name": "-swift-version", "description": "Specify Swift language version", "type": "string"},
    {"name": "-warnings-as-errors", "description": "Treat warnings as errors"},
    {"name": "-suppress-warnings", "description": "Suppress all warnings"},
    {"name": "-module-name", "description": "Specify the module name", "type": "string"},
    {"name": "-emit-library", "description": "Emit a linked library"},
    {"name": "-emit-executable", "description": "Emit a linked executable"},
    {"name": "-parse-as-library", "description": "Parse input files as libraries"},
    {"name": "-c", "description": "Build in the specified configuration (debug|release)", "type": "string"},
    {"name": "--product", "description": "Build the specified product", "type": "string"},
    {"name": "--parallel", "description": "Build with parallelism enabled"}
  ],
  "examples": [
    "swift main.swift",
    "swiftc -o app main.swift",
    "swiftc -O -o app main.swift",
    "swift build",
    "swift build -c release",
    "swift run",
    "swift run MyApp",
    "swift test",
    "swift test --filter MyTests",
    "swift package init --type executable",
    "swift package init --type library",
    "swift package resolve",
    "swift package update",
    "swift package show-dependencies",
    "swift package clean",
    "swift package generate-xcodeproj"
  ],
  "relatedCommands": ["swiftc", "xcodebuild", "swift-format", "sourcekit-lsp", "xcrun", "xcode-select"],
  "contextEngine": {
    "detectors": [
      {"name": "version", "description": "Swift version", "command": "swift --version 2>&1 | head -1", "parser": "text", "cacheFor": 300, "requiresCmd": "swift"},
      {"name": "package_dump", "description": "Swift Package.swift dump", "command": "swift package dump-package 2>/dev/null | head -5", "parser": "json", "cacheFor": 60, "requiresCmd": "swift"}
    ]
  }
}