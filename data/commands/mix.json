{
  "name": "mix",
  "description": "Elixir build tool and task runner",
  "category": "language",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "new",
      "description": "Create new project",
      "examples": [
        "mix new myapp",
        "mix new myapp --sup"
      ]
    },
    {
      "name": "compile",
      "description": "Compile project",
      "examples": [
        "mix compile"
      ]
    },
    {
      "name": "test",
      "description": "Run tests",
      "examples": [
        "mix test",
        "mix test --cover"
      ]
    },
    {
      "name": "deps.get",
      "description": "Fetch dependencies",
      "examples": [
        "mix deps.get"
      ]
    },
    {
      "name": "deps.update",
      "description": "Update dependencies",
      "examples": [
        "mix deps.update --all"
      ]
    },
    {
      "name": "format",
      "description": "Format code",
      "examples": [
        "mix format"
      ]
    },
    {
      "name": "ecto.create",
      "description": "Create database",
      "examples": [
        "mix ecto.create"
      ]
    },
    {
      "name": "ecto.migrate",
      "description": "Run migrations",
      "examples": [
        "mix ecto.migrate"
      ]
    },
    {
      "name": "phx.new",
      "description": "Create Phoenix project",
      "examples": [
        "mix phx.new myapp"
      ]
    },
    {
      "name": "phx.server",
      "description": "Start Phoenix server",
      "examples": [
        "mix phx.server"
      ]
    },
    {
      "name": "release",
      "description": "Build release",
      "examples": [
        "mix release"
      ]
    },
    {
      "name": "hex.publish",
      "description": "Publish to Hex.pm",
      "examples": [
        "mix hex.publish"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--no-deps-check",
      "description": "Skip dependency check"
    },
    {
      "name": "--force",
      "description": "Force operation"
    }
  ],
  "examples": [
    "mix new myapp",
    "mix deps.get",
    "mix compile",
    "mix test",
    "mix phx.server",
    "iex -S mix"
  ],
  "relatedCommands": [
    "elixir",
    "iex",
    "rebar3",
    "hex"
  ]
}
