{
  "name": "clickhouse-client",
  "description": "ClickHouse native command-line client for analytics queries",
  "category": "database",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell",
    "fish"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "--host",
      "shorthand": "-h",
      "description": "Server hostname",
      "takesValue": true
    },
    {
      "name": "--port",
      "description": "Server port (default: 9000 native, 8123 HTTP)",
      "takesValue": true
    },
    {
      "name": "--user",
      "shorthand": "-u",
      "description": "Username",
      "takesValue": true
    },
    {
      "name": "--password",
      "description": "Password",
      "takesValue": true
    },
    {
      "name": "--database",
      "shorthand": "-d",
      "description": "Database name",
      "takesValue": true
    },
    {
      "name": "--query",
      "shorthand": "-q",
      "description": "Execute query and exit",
      "takesValue": true
    },
    {
      "name": "--multiquery",
      "shorthand": "-n",
      "description": "Allow multiple queries separated by semicolons"
    },
    {
      "name": "--multiline",
      "shorthand": "-m",
      "description": "Multiline mode (use ;; to execute)"
    },
    {
      "name": "--format",
      "shorthand": "-f",
      "description": "Output format (TabSeparated, CSV, JSON, Pretty, etc.)",
      "takesValue": true
    },
    {
      "name": "--vertical",
      "shorthand": "-E",
      "description": "Vertical format"
    },
    {
      "name": "--time",
      "shorthand": "-t",
      "description": "Print query execution time"
    },
    {
      "name": "--stacktrace",
      "description": "Show stack trace on exceptions"
    },
    {
      "name": "--progress",
      "description": "Show query progress"
    },
    {
      "name": "--secure",
      "description": "Use TLS"
    },
    {
      "name": "--config-file",
      "shorthand": "-C",
      "description": "Config file path",
      "takesValue": true
    },
    {
      "name": "--history_file",
      "description": "Path to command history file",
      "takesValue": true
    },
    {
      "name": "--max_insert_block_size",
      "description": "Max rows per insert block",
      "takesValue": true
    },
    {
      "name": "--max_threads",
      "description": "Max query threads",
      "takesValue": true
    }
  ],
  "examples": [
    {
      "command": "clickhouse-client",
      "description": "Connect to local server"
    },
    {
      "command": "clickhouse-client -q 'SELECT 1'",
      "description": "Execute query"
    },
    {
      "command": "clickhouse-client -h analytics.example.com -u admin --password secret -d mydb",
      "description": "Remote connection"
    },
    {
      "command": "clickhouse-client -q 'SELECT * FROM events' --format JSON",
      "description": "JSON output"
    },
    {
      "command": "clickhouse-client -n -q 'CREATE TABLE t(x UInt32) ENGINE=MergeTree ORDER BY x; INSERT INTO t VALUES (1)'",
      "description": "Multiple queries"
    },
    {
      "command": "cat data.csv | clickhouse-client -q 'INSERT INTO events FORMAT CSV'",
      "description": "Import CSV"
    },
    {
      "command": "clickhouse-client -q 'SHOW DATABASES'",
      "description": "List databases"
    }
  ],
  "relatedCommands": [
    "psql",
    "mysql",
    "influx"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "databases",
        "description": "Available databases",
        "command": "clickhouse-client -q 'SHOW DATABASES' --format=TabSeparatedRaw 2>/dev/null",
        "parser": "lines",
        "cacheFor": 30,
        "requiresCmd": "clickhouse-client"
      },
      {
        "name": "tables",
        "description": "Tables in current database",
        "command": "clickhouse-client -q 'SHOW TABLES' --format=TabSeparatedRaw 2>/dev/null | head -30",
        "parser": "lines",
        "cacheFor": 30,
        "requiresCmd": "clickhouse-client"
      },
      {
        "name": "version",
        "description": "ClickHouse version",
        "command": "clickhouse-client -q 'SELECT version()' 2>/dev/null",
        "parser": "text",
        "cacheFor": 300,
        "requiresCmd": "clickhouse-client"
      },
      {
        "name": "engines",
        "description": "Available table engines",
        "command": "clickhouse-client -q 'SELECT name FROM system.table_engines ORDER BY name' --format=TabSeparatedRaw 2>/dev/null | head -20",
        "parser": "lines",
        "cacheFor": 300,
        "requiresCmd": "clickhouse-client"
      }
    ]
  }
}
