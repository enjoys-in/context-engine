{
  "name": "shopify",
  "description": "Shopify CLI — Liquid template development and theme management",
  "category": "development",
  "platforms": ["linux", "macos", "windows"],
  "shells": ["bash", "zsh", "powershell"],
  "subcommands": [
    { "name": "theme dev", "description": "Start local development server for Shopify theme", "args": [], "options": ["--store", "--port", "--theme"] },
    { "name": "theme push", "description": "Upload theme to Shopify store", "args": [], "options": ["--store", "--theme", "--allow-live"] },
    { "name": "theme pull", "description": "Download theme from Shopify store", "args": [], "options": ["--store", "--theme", "--path"] },
    { "name": "theme check", "description": "Lint Liquid and JSON theme files", "args": [], "options": ["--config", "--category", "--auto-correct"] },
    { "name": "theme init", "description": "Clone a theme to start development", "args": ["name"], "options": ["--clone-url"] },
    { "name": "theme list", "description": "List all themes in the connected store", "args": [], "options": ["--store"] },
    { "name": "theme package", "description": "Package theme into a zip file", "args": [], "options": ["--path"] }
  ],
  "globalOptions": [
    { "name": "--store", "description": "Shopify store URL (mystore.myshopify.com)" },
    { "name": "--path", "description": "Path to theme directory" },
    { "name": "--verbose", "description": "Enable verbose output" },
    { "name": "--no-color", "description": "Disable color output" },
    { "name": "--environment", "description": "Environment to use from shopify.theme.toml" }
  ],
  "examples": [
    "shopify theme dev --store mystore.myshopify.com",
    "shopify theme check --auto-correct",
    "shopify theme push --store mystore.myshopify.com --allow-live",
    "shopify theme pull --store mystore.myshopify.com --theme 12345",
    "shopify theme init my-theme --clone-url https://github.com/Shopify/dawn.git"
  ],
  "relatedCommands": ["node", "npm", "html", "css"]
}