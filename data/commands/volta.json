{
  "name": "volta",
  "description": "JavaScript tool manager — fast, reliable Node.js management",
  "category": "version-manager",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "install",
      "description": "Install a tool",
      "examples": [
        "volta install node@20",
        "volta install npm",
        "volta install yarn"
      ]
    },
    {
      "name": "pin",
      "description": "Pin tool versions in package.json",
      "examples": [
        "volta pin node@20",
        "volta pin npm@10"
      ]
    },
    {
      "name": "list",
      "description": "List installed tools",
      "examples": [
        "volta list",
        "volta list node"
      ]
    },
    {
      "name": "fetch",
      "description": "Fetch a tool without installing",
      "examples": [
        "volta fetch node@20"
      ]
    },
    {
      "name": "run",
      "description": "Run a tool with specific version",
      "examples": [
        "volta run node@18 -- script.js"
      ]
    },
    {
      "name": "which",
      "description": "Show path of installed tool",
      "examples": [
        "volta which node"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--verbose",
      "description": "Verbose output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output"
    }
  ],
  "examples": [
    "volta install node@20",
    "volta pin node@20",
    "volta install yarn",
    "volta list",
    "volta which node"
  ],
  "relatedCommands": [
    "nvm",
    "fnm",
    "node",
    "npm"
  ]
}
