{
  "name": "clang",
  "description": "Clang — Objective-C compiler (LLVM)",
  "category": "language",
  "platforms": ["linux", "macos"],
  "shells": ["bash", "zsh"],
  "subcommands": [
    { "name": "-fobjc-arc file.m -o output", "description": "Compile with Automatic Reference Counting", "args": ["file", "output"], "options": [] },
    { "name": "-framework Foundation file.m", "description": "Compile linking Foundation framework", "args": ["file"], "options": [] },
    { "name": "-framework UIKit file.m", "description": "Compile linking UIKit framework (iOS)", "args": ["file"], "options": [] },
    { "name": "-ObjC file.m", "description": "Force load all Objective-C classes and categories", "args": ["file"], "options": [] },
    { "name": "-fobjc-exceptions file.m", "description": "Enable Objective-C exceptions", "args": ["file"], "options": [] }
  ],
  "globalOptions": [
    { "name": "-fobjc-arc", "description": "Enable Automatic Reference Counting" },
    { "name": "-framework", "description": "Link with a named framework" },
    { "name": "-ObjC", "description": "Load all Objective-C classes and categories from static libs" },
    { "name": "-fmodules", "description": "Enable Clang modules for faster compilation" },
    { "name": "-isysroot", "description": "Set SDK root directory" },
    { "name": "-mios-version-min", "description": "Minimum iOS version target" },
    { "name": "-Wall -Wextra", "description": "Enable all common warnings" }
  ],
  "examples": [
    "clang -fobjc-arc -framework Foundation main.m -o main",
    "clang -fobjc-arc -framework UIKit -framework Foundation app.m -o app",
    "clang -c -fobjc-arc module.m -o module.o",
    "xcodebuild -project MyApp.xcodeproj -scheme MyApp build",
    "clang -fobjc-arc -fmodules main.m -o main"
  ],
  "relatedCommands": ["xcodebuild", "swift", "gcc", "c"]
}