{
  "language": "hcl",
  "name": "terraform",
  "description": "HCL command-line tool",
  "category": "development",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--help",
      "description": "Show help information"
    },
    {
      "name": "--version",
      "description": "Show version information"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    },
    {
      "name": "--working-dir",
      "description": "Set the working directory",
      "valueHint": "dir",
      "alias": "-d"
    },
    {
      "name": "--env",
      "description": "Set environment (development, staging, production)",
      "valueHint": "name"
    },
    {
      "name": "--timeout",
      "description": "Set operation timeout in seconds",
      "valueHint": "seconds"
    }
  ],
  "subcommands": [
    {
      "name": "init",
      "description": "Initialize config",
      "args": [],
      "options": []
    },
    {
      "name": "plan",
      "description": "Create execution plan",
      "args": [],
      "options": []
    },
    {
      "name": "apply",
      "description": "Apply changes",
      "args": [],
      "options": []
    },
    {
      "name": "destroy",
      "description": "Destroy infrastructure",
      "args": [],
      "options": []
    },
    {
      "name": "fmt",
      "description": "Format files",
      "args": [],
      "options": []
    },
    {
      "name": "validate",
      "description": "Validate config",
      "args": [],
      "options": []
    }
  ],
  "examples": [
    {
      "command": "terraform init",
      "description": "Initialize Terraform configuration"
    },
    {
      "command": "terraform plan",
      "description": "Preview infrastructure changes"
    },
    {
      "command": "terraform apply",
      "description": "Apply infrastructure changes"
    },
    {
      "command": "terraform fmt",
      "description": "Format HCL files"
    },
    {
      "command": "terraform validate",
      "description": "Validate configuration"
    }
  ],
  "relatedCommands": []
}
