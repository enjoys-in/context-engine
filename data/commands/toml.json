{
  "language": "toml",
  "name": "toml",
  "description": "TOML file manipulation and validation tools (taplo, toml-cli, dasel)",
  "category": "tool",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--config",
      "description": "Path to taplo configuration file"
    },
    {
      "name": "--schema",
      "description": "JSON Schema URL or path for validation"
    },
    {
      "name": "--check",
      "description": "Check formatting without writing changes"
    },
    {
      "name": "--output",
      "description": "Output file path"
    },
    {
      "name": "--colors",
      "description": "Enable or disable colored output"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    }
  ],
  "subcommands": [
    {
      "name": "format",
      "description": "Format TOML files with taplo",
      "args": [
        "files"
      ],
      "options": [
        "--config",
        "--check"
      ]
    },
    {
      "name": "lint",
      "description": "Lint TOML files for schema compliance",
      "args": [
        "files"
      ],
      "options": [
        "--schema"
      ]
    },
    {
      "name": "get",
      "description": "Get a value from a TOML file by key path",
      "args": [
        "file",
        "key"
      ],
      "options": []
    },
    {
      "name": "set",
      "description": "Set a value in a TOML file",
      "args": [
        "file",
        "key",
        "value"
      ],
      "options": [
        "--type"
      ]
    },
    {
      "name": "validate",
      "description": "Validate TOML file syntax",
      "args": [
        "file"
      ],
      "options": [
        "--schema"
      ]
    },
    {
      "name": "convert",
      "description": "Convert TOML to JSON or YAML",
      "args": [
        "file"
      ],
      "options": [
        "--to"
      ]
    }
  ],
  "examples": [
    "taplo format Cargo.toml",
    "taplo lint pyproject.toml --schema https://json.schemastore.org/pyproject",
    "taplo format --check '**/*.toml'",
    "toml get Cargo.toml package.version",
    "dasel -f config.toml '.database.port'"
  ],
  "relatedCommands": [
    "yaml",
    "json",
    "ini",
    "jq"
  ]
}
