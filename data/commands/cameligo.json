{
  "language": "cameligo",
  "name": "ligo",
  "description": "CameLIGO command-line tool",
  "category": "development",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--help",
      "description": "Show help information"
    },
    {
      "name": "--version",
      "description": "Show version information"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    },
    {
      "name": "--working-dir",
      "description": "Set the working directory",
      "valueHint": "dir",
      "alias": "-d"
    },
    {
      "name": "--env",
      "description": "Set environment (development, staging, production)",
      "valueHint": "name"
    },
    {
      "name": "--timeout",
      "description": "Set operation timeout in seconds",
      "valueHint": "seconds"
    },
    {
      "name": "--parallel",
      "description": "Run operations in parallel where possible"
    }
  ],
  "subcommands": [
    {
      "name": "compile contract",
      "description": "Compile a CameLIGO contract",
      "args": [],
      "options": []
    },
    {
      "name": "compile storage",
      "description": "Compile storage expression",
      "args": [],
      "options": []
    },
    {
      "name": "compile parameter",
      "description": "Compile parameter expression",
      "args": [],
      "options": []
    },
    {
      "name": "run dry-run",
      "description": "Dry run a contract",
      "args": [],
      "options": []
    },
    {
      "name": "run test",
      "description": "Run contract tests",
      "args": [],
      "options": []
    }
  ],
  "examples": [
    {
      "command": "ligo compile contract main.mligo",
      "description": "Compile a CameLIGO contract"
    },
    {
      "command": "ligo run dry-run main.mligo 'Main(unit)' '0'",
      "description": "Dry run a CameLIGO entry point"
    },
    {
      "command": "ligo run test test.mligo",
      "description": "Run CameLIGO tests"
    }
  ],
  "relatedCommands": []
}
