{
  "name": "stripe",
  "description": "Stripe CLI for managing Stripe resources and testing webhooks",
  "category": "Security & APIs",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "login",
      "description": "Authenticate with Stripe"
    },
    {
      "name": "listen",
      "description": "Listen for webhook events"
    },
    {
      "name": "trigger",
      "description": "Trigger webhook events"
    },
    {
      "name": "logs",
      "description": "Tail API request logs from your account"
    }
  ],
  "globalOptions": [],
  "examples": [
    {
      "command": "stripe listen --forward-to localhost:4242/webhook",
      "description": "Forward webhooks to local server"
    },
    {
      "command": "stripe trigger payment_intent.succeeded",
      "description": "Trigger a mock event"
    }
  ],
  "relatedCommands": [],
  "contextEngine": {
    "detectors": [
      {
        "name": "status",
        "description": "Stripe Login Status",
        "command": "stripe config --list | grep 'account_id' 2>/dev/null",
        "parser": "text",
        "cacheFor": 3600
      }
    ]
  }
}