{
  "name": "crystal",
  "description": "Crystal programming language compiler",
  "category": "language",
  "platforms": [
    "linux",
    "macos"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish"
  ],
  "subcommands": [
    {
      "name": "build",
      "description": "Compile program",
      "examples": [
        "crystal build src/main.cr"
      ]
    },
    {
      "name": "run",
      "description": "Compile and run",
      "examples": [
        "crystal run src/main.cr"
      ]
    },
    {
      "name": "spec",
      "description": "Run spec tests",
      "examples": [
        "crystal spec"
      ]
    },
    {
      "name": "init",
      "description": "Create new project",
      "examples": [
        "crystal init app myapp",
        "crystal init lib mylib"
      ]
    },
    {
      "name": "docs",
      "description": "Generate documentation",
      "examples": [
        "crystal docs"
      ]
    },
    {
      "name": "eval",
      "description": "Evaluate code from arguments",
      "examples": [
        "crystal eval 'puts 1 + 1'"
      ]
    },
    {
      "name": "tool format",
      "description": "Format source code",
      "examples": [
        "crystal tool format"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--release",
      "description": "Release build"
    },
    {
      "name": "-o",
      "description": "Output file",
      "type": "file"
    },
    {
      "name": "--error-trace",
      "description": "Show full error trace"
    },
    {
      "name": "-s",
      "description": "Silent mode"
    },
    {
      "name": "--static",
      "description": "Static linking"
    }
  ],
  "examples": [
    "crystal run src/main.cr",
    "crystal build --release src/main.cr",
    "crystal spec",
    "crystal init app myapp",
    "shards install"
  ],
  "relatedCommands": [
    "ruby",
    "nim",
    "zig",
    "shards"
  ]
}
