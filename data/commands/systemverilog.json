{
  "language": "systemverilog",
  "name": "vlog",
  "description": "SystemVerilog — HDL compiler and simulation tools (ModelSim/QuestaSim, Verilator, Icarus)",
  "category": "language",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "-sv",
      "description": "Enable SystemVerilog features"
    },
    {
      "name": "+incdir+<path>",
      "description": "Add include search directory"
    },
    {
      "name": "+define+<macro>",
      "description": "Define a preprocessor macro"
    },
    {
      "name": "-work",
      "description": "Target library for compilation"
    },
    {
      "name": "-lint",
      "description": "Enable lint-style warnings"
    },
    {
      "name": "-timescale",
      "description": "Set default timescale"
    },
    {
      "name": "-Wall",
      "description": "Enable all warnings (Verilator)"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    }
  ],
  "subcommands": [
    {
      "name": "file.sv",
      "description": "Compile SystemVerilog file",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "-sv file.sv",
      "description": "Force SystemVerilog language mode",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "-lint file.sv",
      "description": "Run lint checks on SystemVerilog",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "+incdir+path file.sv",
      "description": "Compile with include directory",
      "args": [
        "path",
        "file"
      ],
      "options": []
    },
    {
      "name": "-work library file.sv",
      "description": "Compile into a named library",
      "args": [
        "library",
        "file"
      ],
      "options": []
    }
  ],
  "examples": [
    "vlog -sv design.sv testbench.sv",
    "verilator --lint-only -Wall design.sv",
    "iverilog -g2012 -o sim design.sv testbench.sv && vvp sim",
    "vlog +incdir+./rtl -sv top.sv && vsim work.top",
    "verilator --cc --exe --build design.sv sim_main.cpp"
  ],
  "relatedCommands": [
    "make",
    "gtkwave",
    "pla",
    "mips"
  ]
}
