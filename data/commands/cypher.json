{
  "language": "cypher",
  "name": "cypher-shell",
  "description": "Cypher Shell — Neo4j graph database command-line client",
  "category": "tool",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "-u / --username",
      "description": "Neo4j username"
    },
    {
      "name": "-p / --password",
      "description": "Neo4j password"
    },
    {
      "name": "-a / --address",
      "description": "Server address (bolt://host:port)"
    },
    {
      "name": "--database",
      "description": "Target database name"
    },
    {
      "name": "--format",
      "description": "Output format (auto, verbose, plain)"
    },
    {
      "name": "--encryption",
      "description": "Connection encryption (true, false, default)"
    },
    {
      "name": "-f / --file",
      "description": "Cypher script file to execute"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    }
  ],
  "subcommands": [
    {
      "name": "-u neo4j -p pass",
      "description": "Connect to Neo4j with credentials",
      "args": [],
      "options": []
    },
    {
      "name": "--format plain",
      "description": "Output results in plain text format",
      "args": [],
      "options": []
    },
    {
      "name": "-f script.cypher",
      "description": "Execute Cypher script from file",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "--database neo4j",
      "description": "Connect to a specific database",
      "args": [
        "database"
      ],
      "options": []
    },
    {
      "name": "-a bolt://host:7687",
      "description": "Connect to specific server address",
      "args": [
        "address"
      ],
      "options": []
    }
  ],
  "examples": [
    "cypher-shell -u neo4j -p password",
    "cypher-shell -u neo4j -p password -f import.cypher",
    "echo 'MATCH (n) RETURN count(n);' | cypher-shell -u neo4j -p password",
    "cypher-shell -a bolt://localhost:7687 --database mydb",
    "cypher-shell --format plain -u neo4j -p password <<< 'MATCH (n:Person) RETURN n.name LIMIT 10;'"
  ],
  "relatedCommands": [
    "sql",
    "mongosh",
    "redis-cli",
    "psql"
  ]
}
