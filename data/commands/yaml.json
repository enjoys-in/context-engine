{
  "language": "yaml",
  "name": "yq",
  "description": "yq — YAML/JSON/XML processor (like jq for YAML)",
  "category": "tool",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "-i / --inplace",
      "description": "Edit file in-place"
    },
    {
      "name": "-o / --output-format",
      "description": "Output format: yaml, json, xml, tsv, csv, props"
    },
    {
      "name": "-P / --prettyPrint",
      "description": "Pretty print output"
    },
    {
      "name": "-C / --colors",
      "description": "Force color output"
    },
    {
      "name": "-N / --no-doc",
      "description": "Remove document separators (---)"
    },
    {
      "name": "-e / --expression",
      "description": "yq expression to evaluate"
    },
    {
      "name": "--front-matter",
      "description": "Process YAML front matter in files"
    },
    {
      "name": "--indent",
      "description": "Set indentation level (default: 2)"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    }
  ],
  "subcommands": [
    {
      "name": ".key file.yaml",
      "description": "Extract a value by key path",
      "args": [
        "expression",
        "file"
      ],
      "options": []
    },
    {
      "name": "-i '.key = val' file.yaml",
      "description": "Update a value in-place",
      "args": [
        "expression",
        "file"
      ],
      "options": []
    },
    {
      "name": "eval '.' file.yaml",
      "description": "Pretty-print YAML file",
      "args": [
        "expression",
        "file"
      ],
      "options": []
    },
    {
      "name": "eval-all 'select(.kind==\"Deployment\")' *.yaml",
      "description": "Filter across multiple YAML files",
      "args": [
        "expression",
        "files"
      ],
      "options": []
    },
    {
      "name": "-o json file.yaml",
      "description": "Convert YAML to JSON",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "-P file.json",
      "description": "Convert JSON to YAML (pretty print)",
      "args": [
        "file"
      ],
      "options": []
    }
  ],
  "examples": [
    "yq '.metadata.name' deployment.yaml",
    "yq -i '.spec.replicas = 3' deployment.yaml",
    "yq -o json config.yaml > config.json",
    "yq eval-all 'select(.kind == \"Service\")' *.yaml",
    "yq '. *= load(\"overrides.yaml\")' base.yaml",
    "cat values.yaml | yq '.image.tag'"
  ],
  "relatedCommands": [
    "jq",
    "toml",
    "ini",
    "kubectl"
  ]
}
