{
  "language": "python",
  "name": "python",
  "description": "Interpreted, high-level, general-purpose programming language",
  "category": "runtime",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--version",
      "short": "-V",
      "description": "Print Python version"
    },
    {
      "name": "-c",
      "description": "Execute code passed as string",
      "type": "string"
    },
    {
      "name": "-m",
      "description": "Run library module as script",
      "type": "string"
    },
    {
      "name": "-i",
      "description": "Inspect interactively after running script"
    },
    {
      "name": "-u",
      "description": "Unbuffered binary stdout and stderr"
    },
    {
      "name": "-B",
      "description": "Don't write .pyc files"
    },
    {
      "name": "-O",
      "description": "Optimize bytecode"
    },
    {
      "name": "-W",
      "description": "Warning control",
      "type": "string"
    },
    {
      "name": "--help",
      "short": "-h",
      "description": "Show help"
    },
    {
      "name": "-E",
      "description": "Ignore PYTHON* environment variables"
    },
    {
      "name": "-q",
      "description": "Don't print version on interactive startup"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    }
  ],
  "subcommands": [],
  "examples": [
    "python script.py",
    "python -c \"print('hello')\"",
    "python -m http.server 8080",
    "python -m venv .venv",
    "python -m pytest",
    "python -m pip install requests"
  ],
  "relatedCommands": [
    "pip",
    "python3",
    "pipx",
    "poetry",
    "conda",
    "virtualenv",
    "pyenv"
  ]
}
