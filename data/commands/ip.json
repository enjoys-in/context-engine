{
  "name": "ip",
  "description": "Show/manipulate routing, network devices, interfaces and tunnels",
  "category": "networking",
  "platforms": [
    "linux"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish"
  ],
  "subcommands": [
    {
      "name": "addr",
      "description": "Protocol address management",
      "examples": [
        "ip addr show",
        "ip addr add 192.168.1.10/24 dev eth0",
        "ip addr del 192.168.1.10/24 dev eth0"
      ]
    },
    {
      "name": "link",
      "description": "Network device configuration",
      "examples": [
        "ip link show",
        "ip link set eth0 up",
        "ip link set eth0 down"
      ]
    },
    {
      "name": "route",
      "description": "Routing table management",
      "examples": [
        "ip route show",
        "ip route add default via 192.168.1.1",
        "ip route del 10.0.0.0/8"
      ]
    },
    {
      "name": "neigh",
      "description": "Neighbor/ARP table management",
      "examples": [
        "ip neigh show"
      ]
    },
    {
      "name": "rule",
      "description": "Routing policy database management",
      "examples": [
        "ip rule show"
      ]
    },
    {
      "name": "tunnel",
      "description": "Tunnel configuration",
      "examples": [
        "ip tunnel show"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "-4",
      "description": "IPv4 only"
    },
    {
      "name": "-6",
      "description": "IPv6 only"
    },
    {
      "name": "-s",
      "description": "More information (statistics)"
    },
    {
      "name": "-c",
      "description": "Color output"
    },
    {
      "name": "-br",
      "description": "Brief output"
    },
    {
      "name": "-j",
      "description": "JSON output"
    }
  ],
  "examples": [
    "ip addr show",
    "ip -br addr",
    "ip route show",
    "ip link set eth0 up",
    "ip -s link",
    "ip -j addr show"
  ],
  "relatedCommands": [
    "ifconfig",
    "route",
    "netstat",
    "ss"
  ]
}
