{
  "name": "pm2",
  "description": "Advanced Process Manager for Node.js",
  "category": "Node Version & Process Managers",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "start",
      "description": "Start and daemonize an app"
    },
    {
      "name": "stop",
      "description": "Stop a process"
    },
    {
      "name": "restart",
      "description": "Restart a process"
    },
    {
      "name": "list",
      "description": "List all processes"
    },
    {
      "name": "logs",
      "description": "Stream logs"
    },
    {
      "name": "monit",
      "description": "Monitor processes in a terminal UI"
    }
  ],
  "globalOptions": [],
  "examples": [
    {
      "command": "pm2 start app.js",
      "description": "Start an app"
    },
    {
      "command": "pm2 list",
      "description": "List running apps"
    },
    {
      "command": "pm2 logs app",
      "description": "Tail logs for app"
    }
  ],
  "relatedCommands": [
    "node",
    "npm"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "processes",
        "description": "PM2 Managed Processes",
        "command": "pm2 jlist 2>/dev/null | jq '.[].name' -r 2>/dev/null || pm2 ls | grep 'online'",
        "parser": "lines",
        "cacheFor": 10
      }
    ]
  }
}