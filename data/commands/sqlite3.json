{
  "name": "sqlite3",
  "description": "SQLite command-line interface for managing SQLite databases",
  "category": "database",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell",
    "fish"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "-cmd",
      "description": "Run command before reading stdin",
      "takesValue": true
    },
    {
      "name": "-csv",
      "description": "CSV output mode"
    },
    {
      "name": "-column",
      "description": "Column-aligned output"
    },
    {
      "name": "-html",
      "description": "HTML table output"
    },
    {
      "name": "-json",
      "description": "JSON output"
    },
    {
      "name": "-line",
      "description": "One value per line"
    },
    {
      "name": "-list",
      "description": "Delimiter-separated output"
    },
    {
      "name": "-markdown",
      "description": "Markdown table output"
    },
    {
      "name": "-table",
      "description": "ASCII table output"
    },
    {
      "name": "-tabs",
      "description": "Tab-separated output"
    },
    {
      "name": "-separator",
      "description": "Column separator",
      "takesValue": true
    },
    {
      "name": "-header",
      "description": "Show column headers"
    },
    {
      "name": "-noheader",
      "description": "Hide column headers"
    },
    {
      "name": "-readonly",
      "description": "Open database in read-only mode"
    },
    {
      "name": "-batch",
      "description": "Batch mode (non-interactive)"
    },
    {
      "name": "-init",
      "description": "Read and execute init file",
      "takesValue": true
    },
    {
      "name": "-echo",
      "description": "Echo commands"
    },
    {
      "name": "-bail",
      "description": "Stop on error"
    },
    {
      "name": "-version",
      "description": "Show version"
    },
    {
      "name": "-help",
      "description": "Show help"
    }
  ],
  "examples": [
    {
      "command": "sqlite3 mydb.db",
      "description": "Open or create database"
    },
    {
      "command": "sqlite3 mydb.db '.tables'",
      "description": "List tables"
    },
    {
      "command": "sqlite3 mydb.db '.schema users'",
      "description": "Show table schema"
    },
    {
      "command": "sqlite3 -json mydb.db 'SELECT * FROM users'",
      "description": "JSON query output"
    },
    {
      "command": "sqlite3 mydb.db < schema.sql",
      "description": "Import SQL file"
    },
    {
      "command": "sqlite3 mydb.db '.dump' > backup.sql",
      "description": "Dump database"
    },
    {
      "command": "sqlite3 -csv mydb.db 'SELECT * FROM users' > users.csv",
      "description": "Export CSV"
    },
    {
      "command": "sqlite3 :memory:",
      "description": "In-memory database"
    }
  ],
  "relatedCommands": [
    "mysql",
    "psql"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "db_files",
        "description": "SQLite database files",
        "command": "find . -maxdepth 2 -name '*.db' -o -name '*.sqlite' -o -name '*.sqlite3' 2>/dev/null | head -10",
        "parser": "lines",
        "cacheFor": 30
      },
      {
        "name": "tables",
        "description": "Tables in database",
        "command": "sqlite3 $(find . -maxdepth 1 -name '*.db' -o -name '*.sqlite' -o -name '*.sqlite3' 2>/dev/null | head -1) '.tables' 2>/dev/null",
        "parser": "text",
        "cacheFor": 30,
        "requiresCmd": "sqlite3"
      },
      {
        "name": "version",
        "description": "SQLite version",
        "command": "sqlite3 --version 2>/dev/null",
        "parser": "text",
        "cacheFor": 300,
        "requiresCmd": "sqlite3"
      }
    ]
  }
}
