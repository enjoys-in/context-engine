{
  "language": "ecl",
  "name": "ecl",
  "description": "ECL — HPCC Systems Enterprise Control Language CLI",
  "category": "language",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--server",
      "description": "HPCC server address"
    },
    {
      "name": "--port",
      "description": "Server port number"
    },
    {
      "name": "--username",
      "description": "Authentication username"
    },
    {
      "name": "--password",
      "description": "Authentication password"
    },
    {
      "name": "--cluster",
      "description": "Target cluster name (thor, roxie, hthor)"
    },
    {
      "name": "--target",
      "description": "Target environment"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    }
  ],
  "subcommands": [
    {
      "name": "run",
      "description": "Run an ECL program on a cluster",
      "args": [
        "file.ecl"
      ],
      "options": [
        "--target",
        "--cluster"
      ]
    },
    {
      "name": "publish",
      "description": "Publish ECL query to a Roxie cluster",
      "args": [
        "file.ecl"
      ],
      "options": [
        "--name",
        "--cluster"
      ]
    },
    {
      "name": "deploy",
      "description": "Deploy ECL workunit to target cluster",
      "args": [
        "wuid"
      ],
      "options": [
        "--cluster"
      ]
    },
    {
      "name": "compile",
      "description": "Compile ECL code without running",
      "args": [
        "file.ecl"
      ],
      "options": [
        "--target"
      ]
    },
    {
      "name": "status",
      "description": "Check status of a workunit",
      "args": [
        "wuid"
      ],
      "options": []
    },
    {
      "name": "results",
      "description": "Retrieve results from a completed workunit",
      "args": [
        "wuid"
      ],
      "options": [
        "--format"
      ]
    }
  ],
  "examples": [
    "ecl run --target thor myquery.ecl",
    "ecl publish --cluster roxie --name MyQuery myquery.ecl",
    "ecl status W20240101-000001",
    "ecl results W20240101-000001 --format csv",
    "eclcc -o output.so myquery.ecl"
  ],
  "relatedCommands": [
    "sql",
    "sparql",
    "hive"
  ]
}
