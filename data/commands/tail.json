{
  "name": "tail",
  "description": "Output the last part of files",
  "category": "coreutils",
  "platforms": [
    "linux",
    "macos"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "-n",
      "description": "Output the last N lines",
      "type": "number"
    },
    {
      "name": "-c",
      "description": "Output the last N bytes",
      "type": "number"
    },
    {
      "name": "-f",
      "description": "Follow file as it grows (live)"
    },
    {
      "name": "-F",
      "description": "Follow by name (retry if renamed)"
    },
    {
      "name": "--pid",
      "description": "Terminate after process PID dies",
      "type": "number"
    },
    {
      "name": "-q",
      "description": "Never print headers"
    }
  ],
  "examples": [
    "tail file.txt",
    "tail -n 50 file.txt",
    "tail -f /var/log/syslog",
    "tail -F app.log",
    "tail -n +10 file.txt",
    "tail -f log1.txt log2.txt"
  ],
  "relatedCommands": [
    "head",
    "cat",
    "less",
    "journalctl"
  ]
}
