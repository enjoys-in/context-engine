      "description": "Push the migration directory to Atlas Cloud for versioned schema management, CI/CD integration, and team collaboration.",
      "args": [
        {
          "name": "name",
          "type": "string",
          "required": true,
          "description": "Name/tag for the migration directory in Atlas Cloud"
        }
