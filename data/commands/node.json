{
  "name": "node",
  "description": "JavaScript runtime built on Chrome's V8 JavaScript engine",
  "category": "runtime",
  "platforms": ["linux", "macos", "windows"],
  "shells": ["bash", "zsh", "fish", "powershell"],
  "subcommands": [
    {
      "name": "run",
      "description": "Execute a script file",
      "args": [{ "name": "<script>", "type": "file", "required": true, "description": "Script file to run" }],
      "examples": ["node app.js", "node src/index.js"]
    },
    {
      "name": "eval",
      "description": "Evaluate a string as JavaScript",
      "args": [{ "name": "<code>", "type": "string", "required": true, "description": "JavaScript code" }],
      "examples": ["node -e \"console.log('hello')\"", "node -e \"process.versions\""]
    }
  ],
  "globalOptions": [
    { "name": "--version", "short": "-v", "description": "Print Node.js version" },
    { "name": "--eval", "short": "-e", "description": "Evaluate string as JS", "type": "string" },
    { "name": "--print", "short": "-p", "description": "Evaluate and print result", "type": "string" },
    { "name": "--check", "short": "-c", "description": "Syntax check without executing" },
    { "name": "--inspect", "description": "Activate inspector on host:port", "type": "string" },
    { "name": "--inspect-brk", "description": "Activate inspector and break on first line", "type": "string" },
    { "name": "--require", "short": "-r", "description": "Preload module at startup", "type": "string" },
    { "name": "--experimental-modules", "description": "Enable ES module support" },
    { "name": "--max-old-space-size", "description": "Set V8 max old space size (MB)", "type": "number" },
    { "name": "--env-file", "description": "Load environment variables from file", "type": "file" },
    { "name": "--watch", "description": "Run in watch mode (restart on file changes)" },
    { "name": "--test", "description": "Run test runner" }
  ],
  "examples": [
    "node app.js",
    "node --inspect app.js",
    "node -e \"console.log(process.version)\"",
    "node --max-old-space-size=4096 build.js",
    "node --watch src/server.js"
  ],
  "relatedCommands": ["npm", "npx", "yarn", "pnpm", "nvm", "fnm", "deno", "bun"]
}
