{
  "language": "crontab",
  "name": "crontab",
  "description": "Crontab — schedule recurring tasks on Unix-like systems",
  "category": "runtime",
  "platforms": [
    "linux",
    "macos"
  ],
  "shells": [
    "bash",
    "zsh"
  ],
  "globalOptions": [
    {
      "name": "-u",
      "description": "Specify the user whose crontab to operate on"
    },
    {
      "name": "-i",
      "description": "Prompt before removing crontab (with -r)"
    },
    {
      "name": "-s",
      "description": "Append SELinux context to crontab (Linux)"
    },
    {
      "name": "-n",
      "description": "Set host in cluster to run jobs (Linux)"
    },
    {
      "name": "-c",
      "description": "Get host in cluster to run jobs (Linux)"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    }
  ],
  "subcommands": [
    {
      "name": "-l",
      "description": "List current user's cron jobs",
      "args": [],
      "options": []
    },
    {
      "name": "-e",
      "description": "Edit current user's crontab",
      "args": [],
      "options": []
    },
    {
      "name": "-r",
      "description": "Remove current user's crontab entirely",
      "args": [],
      "options": []
    },
    {
      "name": "-l -u user",
      "description": "List crontab for a specific user",
      "args": [
        "user"
      ],
      "options": []
    },
    {
      "name": "file",
      "description": "Install crontab from a file",
      "args": [
        "file"
      ],
      "options": []
    }
  ],
  "examples": [
    "crontab -l",
    "crontab -e",
    "echo '0 2 * * * /usr/bin/backup.sh' | crontab -",
    "crontab -l -u www-data",
    "crontab -r -i",
    "crontab /path/to/crontab-file"
  ],
  "relatedCommands": [
    "systemctl",
    "at",
    "anacron",
    "systemd"
  ]
}
