{
  "language": "st",
  "name": "st",
  "description": "Structured Text — IEC 61131-3 PLC programming tools (CODESYS, OpenPLC, matiec)",
  "category": "language",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--target",
      "description": "Target PLC platform"
    },
    {
      "name": "--output",
      "description": "Output file or directory"
    },
    {
      "name": "-I",
      "description": "Include directory for library files"
    },
    {
      "name": "-T",
      "description": "Build output directory for matiec"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose compilation output"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    },
    {
      "name": "--working-dir",
      "description": "Set the working directory",
      "valueHint": "dir",
      "alias": "-d"
    }
  ],
  "subcommands": [
    {
      "name": "compile",
      "description": "Compile Structured Text to PLC bytecode",
      "args": [
        "file.st"
      ],
      "options": [
        "--target",
        "--output"
      ]
    },
    {
      "name": "check",
      "description": "Syntax-check Structured Text source files",
      "args": [
        "file.st"
      ],
      "options": [
        "--strict"
      ]
    },
    {
      "name": "simulate",
      "description": "Run PLC simulation with Structured Text program",
      "args": [
        "file.st"
      ],
      "options": [
        "--cycle-time",
        "--duration"
      ]
    },
    {
      "name": "download",
      "description": "Download compiled program to PLC controller",
      "args": [
        "file"
      ],
      "options": [
        "--target-ip",
        "--protocol"
      ]
    },
    {
      "name": "generate",
      "description": "Generate C code from Structured Text using matiec",
      "args": [
        "file.st"
      ],
      "options": [
        "-I",
        "-T"
      ]
    }
  ],
  "examples": [
    "iec2c -I lib/ -T build/ program.st",
    "matiec program.st -o output.c",
    "openplc_editor program.st",
    "codesys --build project.project --compile"
  ],
  "relatedCommands": [
    "gcc",
    "make",
    "systemverilog"
  ]
}
