{
  "name": "sdkman",
  "description": "Software Development Kit Manager for JVM languages",
  "category": "version-manager",
  "platforms": [
    "linux",
    "macos"
  ],
  "shells": [
    "bash",
    "zsh"
  ],
  "subcommands": [
    {
      "name": "install",
      "description": "Install a SDK version",
      "examples": [
        "sdk install java 21.0.1-tem",
        "sdk install gradle"
      ]
    },
    {
      "name": "use",
      "description": "Use a specific version in current shell",
      "examples": [
        "sdk use java 21.0.1-tem"
      ]
    },
    {
      "name": "default",
      "description": "Set default version",
      "examples": [
        "sdk default java 21.0.1-tem"
      ]
    },
    {
      "name": "list",
      "description": "List available versions",
      "examples": [
        "sdk list java",
        "sdk list gradle"
      ]
    },
    {
      "name": "current",
      "description": "Show current versions",
      "examples": [
        "sdk current",
        "sdk current java"
      ]
    },
    {
      "name": "uninstall",
      "description": "Uninstall a version",
      "examples": [
        "sdk uninstall java 17.0.1-tem"
      ]
    },
    {
      "name": "env",
      "description": "Load from .sdkmanrc",
      "examples": [
        "sdk env",
        "sdk env init"
      ]
    },
    {
      "name": "upgrade",
      "description": "Upgrade outdated versions",
      "examples": [
        "sdk upgrade"
      ]
    }
  ],
  "globalOptions": [],
  "examples": [
    "sdk install java 21.0.1-tem",
    "sdk list java",
    "sdk use java 21.0.1-tem",
    "sdk current",
    "sdk default java 21.0.1-tem"
  ],
  "relatedCommands": [
    "java",
    "gradle",
    "mvn",
    "kotlin"
  ]
}
