{
  "language": "dotenv",
  "name": "dotenv",
  "description": "dotenv — environment variable management from .env files",
  "category": "tool",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--env-file",
      "description": "Specify path to .env file (default: .env)"
    },
    {
      "name": "--override",
      "description": "Override existing environment variables"
    },
    {
      "name": "--no-expand",
      "description": "Disable variable expansion"
    },
    {
      "name": "--debug",
      "description": "Enable debug output"
    },
    {
      "name": "--encoding",
      "description": "Specify file encoding (default: utf-8)"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    }
  ],
  "subcommands": [
    {
      "name": "run",
      "description": "Run a command with .env variables loaded",
      "args": [
        "command"
      ],
      "options": [
        "--env-file"
      ]
    },
    {
      "name": "list",
      "description": "List all variables in .env file",
      "args": [],
      "options": [
        "--env-file"
      ]
    },
    {
      "name": "set",
      "description": "Set a variable in .env file",
      "args": [
        "KEY=VALUE"
      ],
      "options": []
    },
    {
      "name": "get",
      "description": "Get a specific variable value",
      "args": [
        "KEY"
      ],
      "options": []
    },
    {
      "name": "check",
      "description": "Validate .env file against .env.example",
      "args": [],
      "options": [
        "--strict"
      ]
    }
  ],
  "examples": [
    "dotenv run -- node server.js",
    "dotenv --env-file .env.production run -- npm start",
    "dotenv list",
    "dotenv set DATABASE_URL=postgres://localhost/mydb",
    "dotenv check --strict"
  ],
  "relatedCommands": [
    "env",
    "export",
    "direnv",
    "shell"
  ]
}
