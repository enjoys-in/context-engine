{
  "name": "dotenv",
  "description": "dotenv — environment variable management from .env files",
  "category": "tool",
  "platforms": ["linux", "macos", "windows"],
  "shells": ["bash", "zsh", "powershell"],
  "subcommands": [
    { "name": "run", "description": "Run a command with .env variables loaded", "args": ["command"], "options": ["--env-file"] },
    { "name": "list", "description": "List all variables in .env file", "args": [], "options": ["--env-file"] },
    { "name": "set", "description": "Set a variable in .env file", "args": ["KEY=VALUE"], "options": [] },
    { "name": "get", "description": "Get a specific variable value", "args": ["KEY"], "options": [] },
    { "name": "check", "description": "Validate .env file against .env.example", "args": [], "options": ["--strict"] }
  ],
  "globalOptions": [
    { "name": "--env-file", "description": "Specify path to .env file (default: .env)" },
    { "name": "--override", "description": "Override existing environment variables" },
    { "name": "--no-expand", "description": "Disable variable expansion" },
    { "name": "--debug", "description": "Enable debug output" },
    { "name": "--encoding", "description": "Specify file encoding (default: utf-8)" }
  ],
  "examples": [
    "dotenv run -- node server.js",
    "dotenv --env-file .env.production run -- npm start",
    "dotenv list",
    "dotenv set DATABASE_URL=postgres://localhost/mydb",
    "dotenv check --strict"
  ],
  "relatedCommands": ["env", "export", "direnv", "shell"]
}