{
  "name": "husky",
  "description": "Modern native Git hooks made easy",
  "category": "git",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "init",
      "description": "Initialize Husky in a project",
      "examples": [
        "npx husky init"
      ]
    },
    {
      "name": "add",
      "description": "Add a hook",
      "examples": [
        "npx husky add .husky/pre-commit 'npm test'"
      ]
    },
    {
      "name": "install",
      "description": "Install Git hooks",
      "examples": [
        "npx husky install"
      ]
    }
  ],
  "globalOptions": [],
  "examples": [
    "npx husky init",
    "npx husky add .husky/pre-commit 'npm test'",
    "npx husky add .husky/commit-msg 'npx commitlint --edit $1'",
    "npx husky install"
  ],
  "relatedCommands": [
    "commitlint",
    "lint-staged",
    "git",
    "pre-commit"
  ]
}
