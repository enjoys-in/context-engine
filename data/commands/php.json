{
  "name": "php",
  "description": "PHP command-line interface",
  "category": "PHP & Ruby Ecosystems",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell",
    "fish"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "-v",
      "description": "Version information"
    },
    {
      "name": "-a",
      "description": "Interactive shell"
    },
    {
      "name": "-m",
      "description": "Show compiled in modules"
    },
    {
      "name": "-i",
      "description": "PHP information"
    },
    {
      "name": "-r",
      "description": "Run PHP code without using script tags",
      "takesValue": true
    },
    {
      "name": "-S",
      "description": "Start built-in web server",
      "takesValue": true
    }
  ],
  "examples": [
    {
      "command": "php -v",
      "description": "Check PHP version"
    },
    {
      "command": "php -S localhost:8000",
      "description": "Start local development server"
    },
    {
      "command": "php script.php",
      "description": "Run a PHP script"
    }
  ],
  "relatedCommands": [
    "composer",
    "artisan"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "version",
        "description": "PHP Version",
        "command": "php -v | head -n 1 2>/dev/null",
        "parser": "text",
        "cacheFor": 3600
      },
      {
        "name": "ini",
        "description": "Loaded Configuration File",
        "command": "php --ini | grep 'Loaded Configuration File' 2>/dev/null",
        "parser": "text",
        "cacheFor": 3600
      }
    ]
  }
}