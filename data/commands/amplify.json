{
  "name": "amplify",
  "description": "AWS Amplify CLI — full-stack cloud development framework",
  "category": "cloud",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "init",
      "description": "Initialize Amplify in a project",
      "examples": [
        "amplify init",
        "amplify init --envName dev"
      ]
    },
    {
      "name": "add",
      "description": "Add a category/resource",
      "examples": [
        "amplify add auth",
        "amplify add api",
        "amplify add storage",
        "amplify add function",
        "amplify add hosting",
        "amplify add analytics",
        "amplify add notifications"
      ]
    },
    {
      "name": "push",
      "description": "Push local changes to cloud",
      "examples": [
        "amplify push",
        "amplify push --yes"
      ]
    },
    {
      "name": "pull",
      "description": "Pull backend environment",
      "examples": [
        "amplify pull",
        "amplify pull --appId xxx --envName dev"
      ]
    },
    {
      "name": "publish",
      "description": "Build and publish (hosting)",
      "examples": [
        "amplify publish"
      ]
    },
    {
      "name": "status",
      "description": "Show current backend status",
      "examples": [
        "amplify status"
      ]
    },
    {
      "name": "remove",
      "description": "Remove a category/resource",
      "examples": [
        "amplify remove auth",
        "amplify remove api"
      ]
    },
    {
      "name": "delete",
      "description": "Delete entire Amplify project",
      "examples": [
        "amplify delete"
      ]
    },
    {
      "name": "env",
      "description": "Manage environments",
      "examples": [
        "amplify env list",
        "amplify env add --envName staging",
        "amplify env checkout dev",
        "amplify env remove staging"
      ]
    },
    {
      "name": "configure",
      "description": "Configure CLI and project",
      "examples": [
        "amplify configure",
        "amplify configure project"
      ]
    },
    {
      "name": "mock",
      "description": "Run local mock server",
      "examples": [
        "amplify mock api",
        "amplify mock function"
      ]
    },
    {
      "name": "codegen",
      "description": "Generate API code",
      "examples": [
        "amplify codegen add",
        "amplify codegen generate"
      ]
    },
    {
      "name": "update",
      "description": "Update a category",
      "examples": [
        "amplify update auth",
        "amplify update api",
        "amplify update function"
      ]
    },
    {
      "name": "console",
      "description": "Open Amplify console",
      "examples": [
        "amplify console"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--yes",
      "short": "-y",
      "description": "Skip prompts with defaults"
    },
    {
      "name": "--envName",
      "description": "Environment name",
      "type": "string"
    },
    {
      "name": "--appId",
      "description": "Amplify app ID",
      "type": "string"
    },
    {
      "name": "--providers",
      "description": "Provider plugins",
      "type": "string"
    }
  ],
  "examples": [
    "amplify init",
    "amplify add api",
    "amplify add auth",
    "amplify push",
    "amplify publish",
    "amplify status",
    "amplify env list",
    "amplify mock api",
    "amplify console",
    "amplify codegen generate"
  ],
  "relatedCommands": [
    "aws",
    "firebase",
    "cdk",
    "serverless"
  ]
}
