{
  "name": "swc",
  "description": "Super-fast TypeScript/JavaScript compiler written in Rust",
  "category": "build-tools",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "compile",
      "description": "Compile files (default)",
      "examples": [
        "swc src -d dist"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "-d",
      "description": "Output directory",
      "type": "string"
    },
    {
      "name": "-s",
      "description": "Generate source maps"
    },
    {
      "name": "--config-file",
      "description": "Path to .swcrc config",
      "type": "file"
    },
    {
      "name": "-w",
      "description": "Watch for changes"
    },
    {
      "name": "--only",
      "description": "Only compile matching files",
      "type": "string"
    },
    {
      "name": "--ignore",
      "description": "Skip matching files",
      "type": "string"
    },
    {
      "name": "-C",
      "description": "Override config values",
      "type": "string"
    }
  ],
  "examples": [
    "swc src -d dist",
    "swc src/index.ts -o dist/index.js",
    "swc src -d dist -w",
    "swc src -d dist -s",
    "npx @swc/cli src -d dist"
  ],
  "relatedCommands": [
    "esbuild",
    "babel",
    "tsc",
    "webpack"
  ]
}
