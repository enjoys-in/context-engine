{
  "name": "argo",
  "description": "Argo Workflows CLI for running workflows on Kubernetes",
  "category": "containers",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "submit",
      "description": "Submit a workflow",
      "examples": [
        "argo submit workflow.yaml",
        "argo submit workflow.yaml -p message=hello",
        "argo submit workflow.yaml --watch",
        "argo submit workflow.yaml --wait"
      ]
    },
    {
      "name": "list",
      "description": "List workflows",
      "examples": [
        "argo list",
        "argo list -n my-ns",
        "argo list --status Running",
        "argo list --completed"
      ]
    },
    {
      "name": "get",
      "description": "Get workflow details",
      "examples": [
        "argo get my-workflow",
        "argo get my-workflow -o json",
        "argo get my-workflow -o yaml"
      ]
    },
    {
      "name": "logs",
      "description": "View workflow logs",
      "examples": [
        "argo logs my-workflow",
        "argo logs my-workflow --follow",
        "argo logs my-workflow -c main"
      ]
    },
    {
      "name": "watch",
      "description": "Watch a workflow",
      "examples": [
        "argo watch my-workflow"
      ]
    },
    {
      "name": "delete",
      "description": "Delete workflows",
      "examples": [
        "argo delete my-workflow",
        "argo delete --all",
        "argo delete --completed"
      ]
    },
    {
      "name": "retry",
      "description": "Retry a workflow",
      "examples": [
        "argo retry my-workflow"
      ]
    },
    {
      "name": "resubmit",
      "description": "Resubmit a workflow",
      "examples": [
        "argo resubmit my-workflow"
      ]
    },
    {
      "name": "suspend",
      "description": "Suspend a workflow",
      "examples": [
        "argo suspend my-workflow"
      ]
    },
    {
      "name": "resume",
      "description": "Resume a workflow",
      "examples": [
        "argo resume my-workflow"
      ]
    },
    {
      "name": "stop",
      "description": "Stop a workflow",
      "examples": [
        "argo stop my-workflow"
      ]
    },
    {
      "name": "terminate",
      "description": "Terminate a workflow",
      "examples": [
        "argo terminate my-workflow"
      ]
    },
    {
      "name": "lint",
      "description": "Lint workflow files",
      "examples": [
        "argo lint workflow.yaml",
        "argo lint ./workflows/"
      ]
    },
    {
      "name": "cron",
      "description": "Manage cron workflows",
      "examples": [
        "argo cron list",
        "argo cron create cron-workflow.yaml",
        "argo cron get my-cron",
        "argo cron delete my-cron",
        "argo cron suspend my-cron",
        "argo cron resume my-cron"
      ]
    },
    {
      "name": "template",
      "description": "Manage workflow templates",
      "examples": [
        "argo template list",
        "argo template create template.yaml",
        "argo template get my-template",
        "argo template delete my-template"
      ]
    },
    {
      "name": "cluster-template",
      "description": "Manage cluster workflow templates",
      "examples": [
        "argo cluster-template list",
        "argo cluster-template create template.yaml"
      ]
    },
    {
      "name": "server",
      "description": "Start Argo UI server",
      "examples": [
        "argo server"
      ]
    },
    {
      "name": "archive",
      "description": "Manage workflow archives",
      "examples": [
        "argo archive list",
        "argo archive get uid"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--namespace",
      "short": "-n",
      "description": "Namespace",
      "type": "string"
    },
    {
      "name": "--kubeconfig",
      "description": "Kubeconfig path",
      "type": "string"
    },
    {
      "name": "--server",
      "description": "Argo server address",
      "type": "string"
    },
    {
      "name": "--token",
      "description": "Bearer token",
      "type": "string"
    },
    {
      "name": "--output",
      "short": "-o",
      "description": "Output format (json, yaml, wide, name)",
      "type": "string"
    }
  ],
  "examples": [
    "argo submit workflow.yaml --watch",
    "argo list",
    "argo get my-workflow",
    "argo logs my-workflow --follow",
    "argo delete --completed",
    "argo cron list",
    "argo lint workflow.yaml",
    "argo template list"
  ],
  "relatedCommands": [
    "kubectl",
    "argocd",
    "tkn",
    "flux"
  ]
}
