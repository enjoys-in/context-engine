{
  "name": "twig",
  "description": "Twig template engine tools — linting, debugging (Symfony, Craft CMS)",
  "category": "development",
  "platforms": ["linux", "macos", "windows"],
  "shells": ["bash", "zsh", "powershell"],
  "subcommands": [
    { "name": "lint", "description": "Lint Twig template files for syntax errors", "args": ["path"], "options": ["--format", "--show-deprecations"] },
    { "name": "debug", "description": "Display Twig functions, filters, and tests available", "args": [], "options": ["--filter", "--format"] },
    { "name": "render", "description": "Render a Twig template with given data", "args": ["template"], "options": ["--data", "--output"] },
    { "name": "cache:clear", "description": "Clear compiled Twig template cache", "args": [], "options": [] },
    { "name": "check", "description": "Check Twig templates for deprecated features", "args": ["path"], "options": ["--show-deprecations"] }
  ],
  "globalOptions": [
    { "name": "--format", "description": "Output format (txt, json, github)" },
    { "name": "--show-deprecations", "description": "Show deprecation warnings" },
    { "name": "--env", "description": "Symfony environment (dev, prod, test)" },
    { "name": "--no-debug", "description": "Disable debug mode" },
    { "name": "--ansi", "description": "Force colored output" }
  ],
  "examples": [
    "php bin/console lint:twig templates/",
    "php bin/console debug:twig --filter=date",
    "php bin/console lint:twig templates/ --format=json",
    "php bin/console cache:clear",
    "twig-lint lint templates/"
  ],
  "relatedCommands": ["php", "composer", "symfony", "html"]
}