{
  "language": "twig",
  "name": "twig",
  "description": "Twig template engine tools — linting, debugging (Symfony, Craft CMS)",
  "category": "development",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--format",
      "description": "Output format (txt, json, github)"
    },
    {
      "name": "--show-deprecations",
      "description": "Show deprecation warnings"
    },
    {
      "name": "--env",
      "description": "Symfony environment (dev, prod, test)"
    },
    {
      "name": "--no-debug",
      "description": "Disable debug mode"
    },
    {
      "name": "--ansi",
      "description": "Force colored output"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    }
  ],
  "subcommands": [
    {
      "name": "lint",
      "description": "Lint Twig template files for syntax errors",
      "args": [
        "path"
      ],
      "options": [
        "--format",
        "--show-deprecations"
      ]
    },
    {
      "name": "debug",
      "description": "Display Twig functions, filters, and tests available",
      "args": [],
      "options": [
        "--filter",
        "--format"
      ]
    },
    {
      "name": "render",
      "description": "Render a Twig template with given data",
      "args": [
        "template"
      ],
      "options": [
        "--data",
        "--output"
      ]
    },
    {
      "name": "cache:clear",
      "description": "Clear compiled Twig template cache",
      "args": [],
      "options": []
    },
    {
      "name": "check",
      "description": "Check Twig templates for deprecated features",
      "args": [
        "path"
      ],
      "options": [
        "--show-deprecations"
      ]
    }
  ],
  "examples": [
    "php bin/console lint:twig templates/",
    "php bin/console debug:twig --filter=date",
    "php bin/console lint:twig templates/ --format=json",
    "php bin/console cache:clear",
    "twig-lint lint templates/"
  ],
  "relatedCommands": [
    "php",
    "composer",
    "symfony",
    "html"
  ]
}
