{
  "name": "prettier",
  "description": "Prettier - opinionated code formatter for JS, TS, CSS, HTML, JSON, and more",
  "category": "node-ecosystem",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell",
    "fish"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "--write",
      "shorthand": "-w",
      "description": "Edit files in place"
    },
    {
      "name": "--check",
      "shorthand": "-c",
      "description": "Check if files are formatted"
    },
    {
      "name": "--list-different",
      "shorthand": "-l",
      "description": "List files that differ from formatting"
    },
    {
      "name": "--config",
      "description": "Config file path",
      "takesValue": true
    },
    {
      "name": "--no-config",
      "description": "Ignore config files"
    },
    {
      "name": "--ignore-path",
      "description": "Ignore file path",
      "takesValue": true
    },
    {
      "name": "--no-editorconfig",
      "description": "Ignore .editorconfig"
    },
    {
      "name": "--single-quote",
      "description": "Use single quotes"
    },
    {
      "name": "--no-semi",
      "description": "Omit semicolons"
    },
    {
      "name": "--trailing-comma",
      "description": "Trailing commas (all, es5, none)",
      "takesValue": true
    },
    {
      "name": "--tab-width",
      "description": "Spaces per indentation",
      "takesValue": true
    },
    {
      "name": "--use-tabs",
      "description": "Use tabs instead of spaces"
    },
    {
      "name": "--print-width",
      "description": "Line width",
      "takesValue": true
    },
    {
      "name": "--bracket-spacing",
      "description": "Spaces in object literals"
    },
    {
      "name": "--jsx-single-quote",
      "description": "Use single quotes in JSX"
    },
    {
      "name": "--arrow-parens",
      "description": "Arrow function parens (always, avoid)",
      "takesValue": true
    },
    {
      "name": "--end-of-line",
      "description": "Line endings (lf, crlf, cr, auto)",
      "takesValue": true
    },
    {
      "name": "--parser",
      "description": "Parser to use",
      "takesValue": true
    },
    {
      "name": "--plugin",
      "description": "Plugin to use",
      "takesValue": true
    },
    {
      "name": "--cache",
      "description": "Enable file caching"
    },
    {
      "name": "--cache-location",
      "description": "Cache file location",
      "takesValue": true
    },
    {
      "name": "--cache-strategy",
      "description": "Cache strategy (content, metadata)",
      "takesValue": true
    },
    {
      "name": "--find-config-path",
      "description": "Find config path for a file",
      "takesValue": true
    },
    {
      "name": "--file-info",
      "description": "Get file info",
      "takesValue": true
    },
    {
      "name": "--log-level",
      "description": "Log level (silent, error, warn, log, debug)",
      "takesValue": true
    },
    {
      "name": "--help",
      "shorthand": "-h",
      "description": "Show help"
    },
    {
      "name": "--version",
      "shorthand": "-v",
      "description": "Show version"
    }
  ],
  "examples": [
    {
      "command": "prettier --write .",
      "description": "Format all files"
    },
    {
      "command": "prettier --check src/",
      "description": "Check if files are formatted"
    },
    {
      "command": "prettier --write '**/*.{ts,tsx}'",
      "description": "Format TypeScript files"
    },
    {
      "command": "prettier --single-quote --no-semi --write .",
      "description": "Format with options"
    },
    {
      "command": "prettier --list-different .",
      "description": "List unformatted files"
    },
    {
      "command": "prettier --cache --write .",
      "description": "Format with caching"
    }
  ],
  "relatedCommands": [
    "eslint",
    "tsc"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "prettier_config",
        "description": "Prettier configuration",
        "command": "cat .prettierrc 2>/dev/null || cat .prettierrc.json 2>/dev/null || cat .prettierrc.js 2>/dev/null || cat .prettierrc.yml 2>/dev/null || cat prettier.config.js 2>/dev/null || cat prettier.config.mjs 2>/dev/null",
        "parser": "text",
        "cacheFor": 60
      },
      {
        "name": "prettier_ignore",
        "description": "Prettier ignore patterns",
        "command": "cat .prettierignore 2>/dev/null",
        "parser": "lines",
        "cacheFor": 60
      },
      {
        "name": "prettier_plugins",
        "description": "Installed Prettier plugins",
        "command": "node -e \"const p=require('./package.json');Object.keys({...p.dependencies,...p.devDependencies}).filter(d=>d.startsWith('prettier-plugin')||d.includes('prettier')).forEach(d=>console.log(d))\" 2>/dev/null",
        "parser": "lines",
        "cacheFor": 120
      }
    ]
  }
}
