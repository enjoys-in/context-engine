{
  "name": "crossplane",
  "description": "Crossplane CLI for composing cloud infrastructure from Kubernetes",
  "category": "containers",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "install provider",
      "description": "Install a Provider",
      "examples": [
        "crossplane install provider crossplane/provider-aws:v0.40.0",
        "crossplane install provider crossplane/provider-gcp:v0.22.0"
      ]
    },
    {
      "name": "install configuration",
      "description": "Install a Configuration",
      "examples": [
        "crossplane install configuration my-org/my-platform:v1.0.0"
      ]
    },
    {
      "name": "install function",
      "description": "Install a Composition Function",
      "examples": [
        "crossplane install function crossplane-contrib/function-patch-and-transform:v0.1.0"
      ]
    },
    {
      "name": "xpkg build",
      "description": "Build a Crossplane package",
      "examples": [
        "crossplane xpkg build --package-root=. --examples-root=./examples"
      ]
    },
    {
      "name": "xpkg push",
      "description": "Push a Crossplane package",
      "examples": [
        "crossplane xpkg push my-org/my-config:v1.0.0 -f package.xpkg"
      ]
    },
    {
      "name": "xpkg init",
      "description": "Initialize a new package",
      "examples": [
        "crossplane xpkg init my-provider provider-template"
      ]
    },
    {
      "name": "beta trace",
      "description": "Trace a composite resource",
      "examples": [
        "crossplane beta trace compositeresource.apiextensions.crossplane.io/my-resource"
      ]
    },
    {
      "name": "beta validate",
      "description": "Validate compositions",
      "examples": [
        "crossplane beta validate extensions/ claims/"
      ]
    },
    {
      "name": "beta convert",
      "description": "Convert resources between versions",
      "examples": [
        "crossplane beta convert composition composition.yaml"
      ]
    },
    {
      "name": "beta top",
      "description": "Resource usage",
      "examples": [
        "crossplane beta top"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--kubeconfig",
      "description": "Kubeconfig path",
      "type": "string"
    },
    {
      "name": "--namespace",
      "short": "-n",
      "description": "Namespace",
      "type": "string"
    },
    {
      "name": "--verbose",
      "description": "Verbose output"
    }
  ],
  "examples": [
    "crossplane install provider crossplane/provider-aws:v0.40.0",
    "crossplane xpkg build",
    "crossplane xpkg push my-org/my-config:v1.0.0 -f package.xpkg",
    "crossplane beta trace compositeresource/my-resource",
    "crossplane xpkg init my-provider provider-template"
  ],
  "relatedCommands": [
    "kubectl",
    "terraform",
    "pulumi",
    "helm"
  ]
}
