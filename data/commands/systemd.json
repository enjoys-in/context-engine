{
  "language": "systemd",
  "name": "systemctl",
  "description": "systemd command-line tool",
  "category": "development",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--help",
      "description": "Show help information"
    },
    {
      "name": "--version",
      "description": "Show version information"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    },
    {
      "name": "--working-dir",
      "description": "Set the working directory",
      "valueHint": "dir",
      "alias": "-d"
    },
    {
      "name": "--env",
      "description": "Set environment (development, staging, production)",
      "valueHint": "name"
    },
    {
      "name": "--timeout",
      "description": "Set operation timeout in seconds",
      "valueHint": "seconds"
    }
  ],
  "subcommands": [
    {
      "name": "start service",
      "description": "Start service",
      "args": [],
      "options": []
    },
    {
      "name": "stop service",
      "description": "Stop service",
      "args": [],
      "options": []
    },
    {
      "name": "restart service",
      "description": "Restart service",
      "args": [],
      "options": []
    },
    {
      "name": "status service",
      "description": "Check status",
      "args": [],
      "options": []
    },
    {
      "name": "enable service",
      "description": "Enable at boot",
      "args": [],
      "options": []
    },
    {
      "name": "daemon-reload",
      "description": "Reload configs",
      "args": [],
      "options": []
    }
  ],
  "examples": [
    {
      "command": "systemctl start service.service",
      "description": "Start a systemd service"
    },
    {
      "command": "systemctl enable service.service",
      "description": "Enable service at boot"
    },
    {
      "command": "journalctl -u service.service",
      "description": "View service logs"
    },
    {
      "command": "systemd-analyze",
      "description": "Analyze system boot performance"
    }
  ],
  "relatedCommands": []
}
