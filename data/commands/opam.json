{
  "name": "opam",
  "description": "OCaml package manager",
  "category": "language",
  "platforms": [
    "linux",
    "macos"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish"
  ],
  "subcommands": [
    {
      "name": "init",
      "description": "Initialize opam",
      "examples": [
        "opam init"
      ]
    },
    {
      "name": "install",
      "description": "Install packages",
      "examples": [
        "opam install dune merlin",
        "opam install ."
      ]
    },
    {
      "name": "switch",
      "description": "Manage OCaml installations",
      "examples": [
        "opam switch create 5.1.0",
        "opam switch list"
      ]
    },
    {
      "name": "update",
      "description": "Update package list",
      "examples": [
        "opam update"
      ]
    },
    {
      "name": "upgrade",
      "description": "Upgrade installed packages",
      "examples": [
        "opam upgrade"
      ]
    },
    {
      "name": "env",
      "description": "Show environment setup",
      "examples": [
        "eval $(opam env)"
      ]
    },
    {
      "name": "list",
      "description": "List installed packages",
      "examples": [
        "opam list"
      ]
    },
    {
      "name": "search",
      "description": "Search for packages",
      "examples": [
        "opam search json"
      ]
    },
    {
      "name": "pin",
      "description": "Pin a package",
      "examples": [
        "opam pin add mylib ."
      ]
    },
    {
      "name": "remove",
      "description": "Remove packages",
      "examples": [
        "opam remove package"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "-y",
      "description": "Auto-confirm prompts"
    },
    {
      "name": "--verbose",
      "description": "Verbose output"
    }
  ],
  "examples": [
    "opam init",
    "opam install dune merlin",
    "opam switch create 5.1.0",
    "eval $(opam env)",
    "opam update && opam upgrade"
  ],
  "relatedCommands": [
    "ocaml",
    "dune",
    "ocamlfind",
    "utop"
  ]
}
