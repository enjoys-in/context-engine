{
  "name": "pytest",
  "description": "Python testing framework with powerful fixtures and plugin architecture",
  "category": "python-ecosystem",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell",
    "fish"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "-x",
      "description": "Stop on first failure"
    },
    {
      "name": "-v",
      "description": "Verbose output"
    },
    {
      "name": "-vv",
      "description": "Extra verbose output"
    },
    {
      "name": "-q",
      "description": "Quiet output"
    },
    {
      "name": "-s",
      "description": "Don't capture stdout"
    },
    {
      "name": "-k",
      "description": "Filter tests by expression",
      "takesValue": true
    },
    {
      "name": "-m",
      "description": "Filter by marker expression",
      "takesValue": true
    },
    {
      "name": "--markers",
      "description": "Show available markers"
    },
    {
      "name": "--fixtures",
      "description": "Show available fixtures"
    },
    {
      "name": "--collect-only",
      "description": "Only collect tests, don't run"
    },
    {
      "name": "--lf",
      "description": "Rerun last failures only"
    },
    {
      "name": "--ff",
      "description": "Run failures first"
    },
    {
      "name": "--nf",
      "description": "Run new tests first"
    },
    {
      "name": "-n",
      "description": "Parallel workers (pytest-xdist)",
      "takesValue": true
    },
    {
      "name": "--cov",
      "description": "Coverage for package",
      "takesValue": true
    },
    {
      "name": "--cov-report",
      "description": "Coverage report type (html, xml, term)",
      "takesValue": true
    },
    {
      "name": "--maxfail",
      "description": "Stop after N failures",
      "takesValue": true
    },
    {
      "name": "--tb",
      "description": "Traceback mode (short, long, line, no, auto)",
      "takesValue": true
    },
    {
      "name": "--durations",
      "description": "Show N slowest tests",
      "takesValue": true
    },
    {
      "name": "--timeout",
      "description": "Test timeout in seconds",
      "takesValue": true
    },
    {
      "name": "-p",
      "description": "Load plugin",
      "takesValue": true
    },
    {
      "name": "--no-header",
      "description": "Suppress header"
    },
    {
      "name": "--co",
      "description": "Collect only (alias)"
    },
    {
      "name": "--rootdir",
      "description": "Root directory",
      "takesValue": true
    },
    {
      "name": "-c",
      "description": "Config file",
      "takesValue": true
    },
    {
      "name": "--junitxml",
      "description": "Generate JUnit XML report",
      "takesValue": true
    },
    {
      "name": "--html",
      "description": "Generate HTML report (pytest-html)",
      "takesValue": true
    },
    {
      "name": "--pdb",
      "description": "Drop to debugger on failure"
    },
    {
      "name": "--trace",
      "description": "Drop to debugger at start of each test"
    },
    {
      "name": "--help",
      "shorthand": "-h",
      "description": "Show help"
    },
    {
      "name": "--version",
      "description": "Show version"
    }
  ],
  "examples": [
    {
      "command": "pytest",
      "description": "Run all tests"
    },
    {
      "command": "pytest tests/test_api.py",
      "description": "Run tests in specific file"
    },
    {
      "command": "pytest -x -v",
      "description": "Verbose, stop on first failure"
    },
    {
      "command": "pytest -k 'test_login or test_auth'",
      "description": "Run tests matching expression"
    },
    {
      "command": "pytest -m slow",
      "description": "Run tests marked as slow"
    },
    {
      "command": "pytest --cov=myapp --cov-report=html",
      "description": "Run with coverage"
    },
    {
      "command": "pytest -n 4",
      "description": "Run in 4 parallel workers"
    },
    {
      "command": "pytest --lf -x",
      "description": "Rerun last failures"
    },
    {
      "command": "pytest --durations=10",
      "description": "Show 10 slowest tests"
    }
  ],
  "relatedCommands": [
    "python",
    "pip",
    "poetry"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "test_files",
        "description": "Test files in the project",
        "command": "find . -name 'test_*.py' -o -name '*_test.py' 2>/dev/null | head -20",
        "parser": "lines",
        "cacheFor": 30
      },
      {
        "name": "pytest_config",
        "description": "Pytest configuration",
        "command": "cat pytest.ini 2>/dev/null || cat setup.cfg 2>/dev/null | grep -A20 '\\[tool:pytest\\]' || grep -A20 '\\[tool.pytest' pyproject.toml 2>/dev/null",
        "parser": "text",
        "cacheFor": 60
      },
      {
        "name": "conftest",
        "description": "Conftest fixtures",
        "command": "cat conftest.py 2>/dev/null | head -30",
        "parser": "text",
        "cacheFor": 30
      },
      {
        "name": "markers",
        "description": "Available markers",
        "command": "python -m pytest --markers 2>/dev/null | head -20",
        "parser": "text",
        "cacheFor": 120
      },
      {
        "name": "plugins",
        "description": "Installed pytest plugins",
        "command": "pip list 2>/dev/null | grep pytest",
        "parser": "lines",
        "cacheFor": 300
      }
    ]
  }
}
