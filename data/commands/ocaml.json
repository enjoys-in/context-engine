{
  "name": "ocaml",
  "description": "OCaml programming language compiler and toplevel",
  "category": "languages",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "-c",
      "description": "Compile only (produce .cmo/.cmi)"
    },
    {
      "name": "-o",
      "description": "Output file",
      "type": "file"
    },
    {
      "name": "-I",
      "description": "Add include directory",
      "type": "string"
    },
    {
      "name": "-g",
      "description": "Include debug info"
    },
    {
      "name": "-O",
      "description": "Optimize"
    },
    {
      "name": "-pp",
      "description": "Preprocessor",
      "type": "string"
    },
    {
      "name": "-thread",
      "description": "Enable threading"
    },
    {
      "name": "-rectypes",
      "description": "Allow recursive types"
    }
  ],
  "examples": [
    "ocaml",
    "ocaml script.ml",
    "ocamlfind ocamlopt -package core -linkpkg main.ml -o main",
    "ocamlopt -o hello hello.ml",
    "dune build",
    "dune exec ./main.exe"
  ],
  "relatedCommands": [
    "opam",
    "dune",
    "ocamlfind",
    "utop"
  ]
}
