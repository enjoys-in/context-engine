{
  "name": "artisan",
  "description": "Laravel framework command-line interface",
  "category": "PHP & Ruby Ecosystems",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell",
    "fish"
  ],
  "subcommands": [
    {
      "name": "serve",
      "description": "Serve the application on the PHP development server"
    },
    {
      "name": "make:controller",
      "description": "Create a new controller class"
    },
    {
      "name": "make:model",
      "description": "Create a new Eloquent model class"
    },
    {
      "name": "migrate",
      "description": "Run the database migrations"
    },
    {
      "name": "route:list",
      "description": "List all registered routes"
    },
    {
      "name": "tinker",
      "description": "Interact with your application"
    }
  ],
  "globalOptions": [],
  "examples": [
    {
      "command": "php artisan serve",
      "description": "Start dev server"
    },
    {
      "command": "php artisan migrate",
      "description": "Run migrations"
    },
    {
      "command": "php artisan make:model User -m",
      "description": "Create model with migration"
    }
  ],
  "relatedCommands": [
    "php",
    "composer"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "laravel_version",
        "description": "Laravel Version",
        "command": "php artisan --version 2>/dev/null",
        "parser": "text",
        "cacheFor": 3600
      },
      {
        "name": "env",
        "description": "Environment variables",
        "command": "cat .env 2>/dev/null | grep -v '^#' | grep '=' | head -10",
        "parser": "text",
        "cacheFor": 30
      }
    ]
  }
}