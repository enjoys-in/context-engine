{
  "name": "zip",
  "description": "Package and compress files into ZIP archives",
  "category": "coreutils",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell",
    "fish"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "-r",
      "description": "Recurse into directories"
    },
    {
      "name": "-e",
      "description": "Encrypt with password"
    },
    {
      "name": "-P",
      "description": "Password (visible in process list!)",
      "takesValue": true
    },
    {
      "name": "-j",
      "description": "Junk directory names (store files only)"
    },
    {
      "name": "-9",
      "description": "Maximum compression"
    },
    {
      "name": "-0",
      "description": "No compression (store only)"
    },
    {
      "name": "-u",
      "description": "Update existing entries"
    },
    {
      "name": "-d",
      "description": "Delete entries from archive"
    },
    {
      "name": "-f",
      "description": "Freshen (update only changed files)"
    },
    {
      "name": "-m",
      "description": "Move files into archive (delete originals)"
    },
    {
      "name": "-x",
      "description": "Exclude files matching pattern",
      "takesValue": true
    },
    {
      "name": "-i",
      "description": "Include only files matching pattern",
      "takesValue": true
    },
    {
      "name": "-q",
      "description": "Quiet mode"
    },
    {
      "name": "-v",
      "description": "Verbose mode"
    },
    {
      "name": "-T",
      "description": "Test archive integrity"
    },
    {
      "name": "-s",
      "description": "Split size for split archives",
      "takesValue": true
    },
    {
      "name": "-l",
      "description": "Convert LF to CRLF"
    },
    {
      "name": "-ll",
      "description": "Convert CRLF to LF"
    },
    {
      "name": "-y",
      "description": "Store symbolic links"
    },
    {
      "name": "--symlinks",
      "description": "Store symbolic links"
    }
  ],
  "examples": [
    {
      "command": "zip archive.zip file1.txt file2.txt",
      "description": "Zip files"
    },
    {
      "command": "zip -r project.zip src/",
      "description": "Zip directory recursively"
    },
    {
      "command": "zip -r app.zip . -x '*.git*' -x 'node_modules/*'",
      "description": "Zip excluding patterns"
    },
    {
      "command": "zip -9 -r compressed.zip dir/",
      "description": "Maximum compression"
    },
    {
      "command": "zip -e secure.zip secret.txt",
      "description": "Encrypt zip"
    },
    {
      "command": "zip -d archive.zip unwanted.txt",
      "description": "Delete from archive"
    },
    {
      "command": "zip -u archive.zip updated.txt",
      "description": "Update file in archive"
    },
    {
      "command": "zip -j flat.zip dir/a.txt dir/b.txt",
      "description": "Flatten directory structure"
    }
  ],
  "relatedCommands": [
    "unzip",
    "tar"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "zip_files",
        "description": "Existing ZIP archives",
        "command": "find . -maxdepth 2 -name '*.zip' 2>/dev/null | head -10",
        "parser": "lines",
        "cacheFor": 15
      },
      {
        "name": "current_files",
        "description": "Files in current directory",
        "command": "ls -1 2>/dev/null | head -30",
        "parser": "lines",
        "cacheFor": 10
      }
    ]
  }
}
