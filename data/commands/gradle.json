{
  "name": "gradle",
  "description": "Build automation tool for multi-language software development",
  "category": "build-tools",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "build",
      "description": "Assemble and test the project",
      "examples": [
        "gradle build",
        "./gradlew build"
      ]
    },
    {
      "name": "clean",
      "description": "Delete build directory",
      "examples": [
        "gradle clean"
      ]
    },
    {
      "name": "test",
      "description": "Run tests",
      "examples": [
        "gradle test"
      ]
    },
    {
      "name": "assemble",
      "description": "Assemble archives",
      "examples": [
        "gradle assemble"
      ]
    },
    {
      "name": "check",
      "description": "Run all checks",
      "examples": [
        "gradle check"
      ]
    },
    {
      "name": "run",
      "description": "Run the application",
      "examples": [
        "gradle run"
      ]
    },
    {
      "name": "bootRun",
      "description": "Run Spring Boot application",
      "examples": [
        "gradle bootRun"
      ]
    },
    {
      "name": "dependencies",
      "description": "Show project dependencies",
      "examples": [
        "gradle dependencies"
      ]
    },
    {
      "name": "tasks",
      "description": "List available tasks",
      "examples": [
        "gradle tasks",
        "gradle tasks --all"
      ]
    },
    {
      "name": "init",
      "description": "Initialize a new Gradle project",
      "examples": [
        "gradle init --type java-application"
      ]
    },
    {
      "name": "wrapper",
      "description": "Generate Gradle wrapper files",
      "examples": [
        "gradle wrapper --gradle-version 8.5"
      ]
    },
    {
      "name": "publish",
      "description": "Publish to repository",
      "examples": [
        "gradle publish"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--help",
      "short": "-h",
      "description": "Show help"
    },
    {
      "name": "--version",
      "short": "-v",
      "description": "Show version"
    },
    {
      "name": "--build-file",
      "short": "-b",
      "description": "Build file path",
      "type": "file"
    },
    {
      "name": "--project-dir",
      "short": "-p",
      "description": "Project directory",
      "type": "directory"
    },
    {
      "name": "--parallel",
      "description": "Build projects in parallel"
    },
    {
      "name": "--daemon",
      "description": "Use Gradle daemon"
    },
    {
      "name": "--no-daemon",
      "description": "Don't use Gradle daemon"
    },
    {
      "name": "--stacktrace",
      "short": "-s",
      "description": "Show stacktrace"
    },
    {
      "name": "--info",
      "short": "-i",
      "description": "Info log level"
    },
    {
      "name": "--debug",
      "short": "-d",
      "description": "Debug log level"
    },
    {
      "name": "-x",
      "description": "Exclude task",
      "type": "string"
    },
    {
      "name": "--offline",
      "description": "Don't access network"
    },
    {
      "name": "--refresh-dependencies",
      "description": "Refresh dependencies"
    }
  ],
  "examples": [
    "./gradlew clean build",
    "./gradlew test",
    "./gradlew bootRun",
    "./gradlew build -x test",
    "./gradlew dependencies --configuration runtimeClasspath"
  ],
  "relatedCommands": [
    "mvn",
    "java",
    "javac",
    "ant",
    "sbt"
  ]
}
