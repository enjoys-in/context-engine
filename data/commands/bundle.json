{
  "name": "bundle",
  "description": "Ruby dependency manager (Bundler)",
  "category": "PHP & Ruby Ecosystems",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell",
    "fish"
  ],
  "subcommands": [
    {
      "name": "install",
      "description": "Install dependencies from Gemfile"
    },
    {
      "name": "update",
      "description": "Update dependencies"
    },
    {
      "name": "exec",
      "description": "Execute a command in the context of the bundle"
    }
  ],
  "globalOptions": [],
  "examples": [
    {
      "command": "bundle install",
      "description": "Install gems"
    },
    {
      "command": "bundle exec rspec",
      "description": "Run rspec from bundle"
    }
  ],
  "relatedCommands": [
    "ruby",
    "gem",
    "rails"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "gemfile",
        "description": "Gemfile contents",
        "command": "cat Gemfile 2>/dev/null | grep '^gem' | head -10",
        "parser": "text",
        "cacheFor": 300
      }
    ]
  }
}