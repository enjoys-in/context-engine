{
  "name": "mvn",
  "description": "Apache Maven build automation and project management tool for Java",
  "category": "build-tools",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "clean",
      "description": "Clean build output",
      "examples": [
        "mvn clean"
      ]
    },
    {
      "name": "compile",
      "description": "Compile source code",
      "examples": [
        "mvn compile"
      ]
    },
    {
      "name": "test",
      "description": "Run tests",
      "examples": [
        "mvn test"
      ]
    },
    {
      "name": "package",
      "description": "Package compiled code (JAR/WAR)",
      "examples": [
        "mvn package"
      ]
    },
    {
      "name": "install",
      "description": "Install to local repository",
      "examples": [
        "mvn install"
      ]
    },
    {
      "name": "deploy",
      "description": "Deploy to remote repository",
      "examples": [
        "mvn deploy"
      ]
    },
    {
      "name": "verify",
      "description": "Run integration tests",
      "examples": [
        "mvn verify"
      ]
    },
    {
      "name": "site",
      "description": "Generate project site documentation",
      "examples": [
        "mvn site"
      ]
    },
    {
      "name": "dependency:tree",
      "description": "Show dependency tree",
      "examples": [
        "mvn dependency:tree"
      ]
    },
    {
      "name": "dependency:resolve",
      "description": "Resolve dependencies",
      "examples": [
        "mvn dependency:resolve"
      ]
    },
    {
      "name": "versions:display-dependency-updates",
      "description": "Show available dependency updates",
      "examples": [
        "mvn versions:display-dependency-updates"
      ]
    },
    {
      "name": "archetype:generate",
      "description": "Generate project from archetype",
      "examples": [
        "mvn archetype:generate -DgroupId=com.example -DartifactId=myapp -DarchetypeArtifactId=maven-archetype-quickstart"
      ]
    },
    {
      "name": "spring-boot:run",
      "description": "Run Spring Boot application",
      "examples": [
        "mvn spring-boot:run"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--help",
      "short": "-h",
      "description": "Show help"
    },
    {
      "name": "--version",
      "short": "-v",
      "description": "Show version"
    },
    {
      "name": "-DskipTests",
      "description": "Skip running tests"
    },
    {
      "name": "-Dmaven.test.skip",
      "description": "Skip compiling and running tests"
    },
    {
      "name": "-P",
      "description": "Activate profile",
      "type": "string"
    },
    {
      "name": "-pl",
      "description": "Build specific modules",
      "type": "string"
    },
    {
      "name": "-am",
      "description": "Also build dependencies"
    },
    {
      "name": "-U",
      "description": "Force update of snapshots"
    },
    {
      "name": "-o",
      "description": "Offline mode"
    },
    {
      "name": "-X",
      "description": "Debug output"
    },
    {
      "name": "-f",
      "description": "Use alternate POM file",
      "type": "file"
    },
    {
      "name": "-T",
      "description": "Thread count for parallel build",
      "type": "string"
    }
  ],
  "examples": [
    "mvn clean install",
    "mvn clean package -DskipTests",
    "mvn test -pl module-name",
    "mvn clean install -P production",
    "mvn dependency:tree",
    "mvn clean package -T 4"
  ],
  "relatedCommands": [
    "gradle",
    "java",
    "javac",
    "ant"
  ]
}
