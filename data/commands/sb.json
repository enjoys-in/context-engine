{
  "language": "sb",
  "name": "smallbasic",
  "description": "Small Basic — beginner programming language and IDE tools",
  "category": "language",
  "platforms": [
    "windows"
  ],
  "shells": [
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--output",
      "description": "Output file path"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode"
    },
    {
      "name": "--verbose",
      "description": "Show detailed output"
    },
    {
      "name": "--version",
      "description": "Display version"
    },
    {
      "name": "--no-graphics",
      "description": "Run in text-only mode"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    },
    {
      "name": "--working-dir",
      "description": "Set the working directory",
      "valueHint": "dir",
      "alias": "-d"
    },
    {
      "name": "--env",
      "description": "Set environment (development, staging, production)",
      "valueHint": "name"
    },
    {
      "name": "--timeout",
      "description": "Set operation timeout in seconds",
      "valueHint": "seconds"
    }
  ],
  "subcommands": [
    {
      "name": "run",
      "description": "Run a Small Basic program",
      "args": [
        "file.sb"
      ],
      "options": []
    },
    {
      "name": "compile",
      "description": "Compile Small Basic program to executable",
      "args": [
        "file.sb"
      ],
      "options": [
        "--output"
      ]
    },
    {
      "name": "check",
      "description": "Syntax check a Small Basic program",
      "args": [
        "file.sb"
      ],
      "options": []
    },
    {
      "name": "export",
      "description": "Export Small Basic program to Visual Basic",
      "args": [
        "file.sb"
      ],
      "options": [
        "--output"
      ]
    },
    {
      "name": "help",
      "description": "Display help for Small Basic commands and objects",
      "args": [
        "topic"
      ],
      "options": []
    }
  ],
  "examples": [
    "SmallBasicCompiler.exe program.sb",
    "SmallBasicCompiler.exe /r program.sb",
    "sbasicg program.sb",
    "sbasic program.sb"
  ],
  "relatedCommands": [
    "vb",
    "csharp",
    "powershell"
  ]
}
