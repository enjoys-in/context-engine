{
  "language": "freemarker2",
  "name": "freemarker-cli",
  "description": "FreeMarker CLI — Apache FreeMarker template processing tool",
  "category": "tool",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "-t / --template",
      "description": "FreeMarker template file path"
    },
    {
      "name": "-d / --data",
      "description": "Data source file (JSON, YAML, CSV, XML)"
    },
    {
      "name": "-o / --output",
      "description": "Output file path (default: stdout)"
    },
    {
      "name": "--encoding",
      "description": "Template file encoding"
    },
    {
      "name": "--locale",
      "description": "Locale for template rendering"
    },
    {
      "name": "--config",
      "description": "FreeMarker configuration file path"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    }
  ],
  "subcommands": [
    {
      "name": "-t template.ftl -d data.json",
      "description": "Process template with JSON data",
      "args": [
        "template",
        "data"
      ],
      "options": []
    },
    {
      "name": "-t template.ftl -d data.yaml",
      "description": "Process template with YAML data",
      "args": [
        "template",
        "data"
      ],
      "options": []
    },
    {
      "name": "-t template.ftl -d data.csv",
      "description": "Process template with CSV data",
      "args": [
        "template",
        "data"
      ],
      "options": []
    },
    {
      "name": "-t template.ftl -d data.xml",
      "description": "Process template with XML data",
      "args": [
        "template",
        "data"
      ],
      "options": []
    },
    {
      "name": "--interactive",
      "description": "Run in interactive REPL mode",
      "args": [],
      "options": []
    }
  ],
  "examples": [
    "freemarker-cli -t template.ftl -d data.json",
    "freemarker-cli -t report.ftl -d data.csv -o report.html",
    "freemarker-cli -t email.ftl -d users.yaml --encoding UTF-8",
    "freemarker-cli -t config.ftl -d env.json -o application.properties"
  ],
  "relatedCommands": [
    "java",
    "mvn",
    "twig",
    "html"
  ]
}
