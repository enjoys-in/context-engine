{
  "name": "freemarker-cli",
  "description": "FreeMarker CLI — Apache FreeMarker template processing tool",
  "category": "tool",
  "platforms": ["linux", "macos", "windows"],
  "shells": ["bash", "zsh", "powershell"],
  "subcommands": [
    { "name": "-t template.ftl -d data.json", "description": "Process template with JSON data", "args": ["template", "data"], "options": [] },
    { "name": "-t template.ftl -d data.yaml", "description": "Process template with YAML data", "args": ["template", "data"], "options": [] },
    { "name": "-t template.ftl -d data.csv", "description": "Process template with CSV data", "args": ["template", "data"], "options": [] },
    { "name": "-t template.ftl -d data.xml", "description": "Process template with XML data", "args": ["template", "data"], "options": [] },
    { "name": "--interactive", "description": "Run in interactive REPL mode", "args": [], "options": [] }
  ],
  "globalOptions": [
    { "name": "-t / --template", "description": "FreeMarker template file path" },
    { "name": "-d / --data", "description": "Data source file (JSON, YAML, CSV, XML)" },
    { "name": "-o / --output", "description": "Output file path (default: stdout)" },
    { "name": "--encoding", "description": "Template file encoding" },
    { "name": "--locale", "description": "Locale for template rendering" },
    { "name": "--config", "description": "FreeMarker configuration file path" }
  ],
  "examples": [
    "freemarker-cli -t template.ftl -d data.json",
    "freemarker-cli -t report.ftl -d data.csv -o report.html",
    "freemarker-cli -t email.ftl -d users.yaml --encoding UTF-8",
    "freemarker-cli -t config.ftl -d env.json -o application.properties"
  ],
  "relatedCommands": ["java", "mvn", "twig", "html"]
}