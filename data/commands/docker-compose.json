{
  "name": "docker-compose",
  "description": "Define and run multi-container applications with Docker",
  "category": "Containers / Kubernetes",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "up",
      "description": "Builds, (re)creates, starts, and attaches to containers for a service"
    },
    {
      "name": "down",
      "description": "Stops containers and removes containers, networks, volumes, and images"
    },
    {
      "name": "build",
      "description": "Build or rebuild services"
    },
    {
      "name": "logs",
      "description": "View output from containers"
    },
    {
      "name": "ps",
      "description": "List containers"
    },
    {
      "name": "exec",
      "description": "Execute a command in a running container"
    }
  ],
  "globalOptions": [
    {
      "name": "-f",
      "description": "Specify an alternate compose file",
      "takesValue": true
    },
    {
      "name": "-d",
      "description": "Detached mode: Run containers in the background"
    }
  ],
  "examples": [
    {
      "command": "docker-compose up -d",
      "description": "Start services in detached mode"
    },
    {
      "command": "docker-compose down",
      "description": "Stop and remove containers"
    },
    {
      "command": "docker-compose logs -f",
      "description": "Tail logs for all services"
    }
  ],
  "relatedCommands": [
    "docker"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "services",
        "description": "Configured Services",
        "command": "docker-compose config --services 2>/dev/null",
        "parser": "lines",
        "cacheFor": 30
      },
      {
        "name": "running",
        "description": "Running Services",
        "command": "docker-compose ps --services --filter 'status=running' 2>/dev/null",
        "parser": "lines",
        "cacheFor": 10
      }
    ]
  }
}