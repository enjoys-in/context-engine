{
  "name": "skaffold",
  "description": "Skaffold — continuous development for Kubernetes-native applications",
  "category": "containers",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "init",
      "description": "Generate Skaffold config",
      "examples": [
        "skaffold init",
        "skaffold init --compose-file docker-compose.yml"
      ]
    },
    {
      "name": "dev",
      "description": "Continuous development mode",
      "examples": [
        "skaffold dev",
        "skaffold dev --port-forward",
        "skaffold dev --tail",
        "skaffold dev --trigger polling",
        "skaffold dev --cleanup=false"
      ]
    },
    {
      "name": "run",
      "description": "Build and deploy once",
      "examples": [
        "skaffold run",
        "skaffold run --tail",
        "skaffold run --tag v1.0.0"
      ]
    },
    {
      "name": "build",
      "description": "Build artifacts",
      "examples": [
        "skaffold build",
        "skaffold build --push",
        "skaffold build -q | skaffold deploy --build-artifacts -"
      ]
    },
    {
      "name": "deploy",
      "description": "Deploy artifacts",
      "examples": [
        "skaffold deploy",
        "skaffold deploy --images my-image:latest"
      ]
    },
    {
      "name": "debug",
      "description": "Dev mode with debug support",
      "examples": [
        "skaffold debug",
        "skaffold debug --port-forward"
      ]
    },
    {
      "name": "render",
      "description": "Render manifests",
      "examples": [
        "skaffold render",
        "skaffold render --output rendered.yaml"
      ]
    },
    {
      "name": "test",
      "description": "Run tests",
      "examples": [
        "skaffold test"
      ]
    },
    {
      "name": "delete",
      "description": "Delete deployed resources",
      "examples": [
        "skaffold delete"
      ]
    },
    {
      "name": "config",
      "description": "Manage global config",
      "examples": [
        "skaffold config list",
        "skaffold config set local-cluster true"
      ]
    },
    {
      "name": "fix",
      "description": "Fix config to latest version",
      "examples": [
        "skaffold fix"
      ]
    },
    {
      "name": "diagnose",
      "description": "Diagnose config issues",
      "examples": [
        "skaffold diagnose"
      ]
    },
    {
      "name": "inspect",
      "description": "Inspect Skaffold config",
      "examples": [
        "skaffold inspect profiles",
        "skaffold inspect build-env list"
      ]
    },
    {
      "name": "verify",
      "description": "Verify deployed resources",
      "examples": [
        "skaffold verify"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "--filename",
      "short": "-f",
      "description": "Config file path",
      "type": "string"
    },
    {
      "name": "--profile",
      "short": "-p",
      "description": "Activate profiles",
      "type": "string"
    },
    {
      "name": "--namespace",
      "short": "-n",
      "description": "Namespace",
      "type": "string"
    },
    {
      "name": "--default-repo",
      "short": "-d",
      "description": "Default image repo",
      "type": "string"
    },
    {
      "name": "--kube-context",
      "description": "Kubernetes context",
      "type": "string"
    },
    {
      "name": "--tail",
      "description": "Stream logs"
    },
    {
      "name": "--port-forward",
      "description": "Port forward services"
    },
    {
      "name": "--cleanup",
      "description": "Clean up on exit"
    }
  ],
  "examples": [
    "skaffold dev",
    "skaffold dev --port-forward --tail",
    "skaffold run --tag v1.0.0",
    "skaffold build",
    "skaffold deploy",
    "skaffold debug",
    "skaffold render --output rendered.yaml",
    "skaffold delete"
  ],
  "relatedCommands": [
    "kubectl",
    "docker",
    "helm",
    "tilt"
  ]
}
