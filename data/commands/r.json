{
  "language": "r",
  "name": "Rscript",
  "description": "R scripting front-end — execute R scripts from the command line",
  "category": "language",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell",
    "cmd"
  ],
  "globalOptions": [
    {
      "name": "--help",
      "description": "Print usage information"
    },
    {
      "name": "--version",
      "description": "Print version information"
    },
    {
      "name": "--vanilla",
      "description": "Combine --no-save, --no-restore, --no-site-file, --no-init-file, --no-environ"
    },
    {
      "name": "--no-save",
      "description": "Do not save workspace at end of session"
    },
    {
      "name": "--no-restore",
      "description": "Do not restore previously saved objects"
    },
    {
      "name": "--no-site-file",
      "description": "Do not read the site-wide Rprofile"
    },
    {
      "name": "--no-init-file",
      "description": "Do not read the user R profile"
    },
    {
      "name": "--no-environ",
      "description": "Do not read the R environment files"
    },
    {
      "name": "-e",
      "description": "Execute an R expression",
      "type": "string"
    },
    {
      "name": "--default-packages",
      "description": "Comma-separated list of packages to attach",
      "type": "string"
    },
    {
      "name": "--max-ppsize",
      "description": "Set max size of the pointer protection stack",
      "type": "string"
    },
    {
      "name": "--max-connections",
      "description": "Set maximum number of connections",
      "type": "string"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    }
  ],
  "subcommands": [
    {
      "name": "run",
      "description": "Execute an R script file",
      "args": [
        {
          "name": "<script>",
          "type": "file",
          "required": true,
          "description": "R script to execute"
        }
      ],
      "examples": [
        "Rscript script.R",
        "Rscript --vanilla script.R arg1 arg2"
      ]
    }
  ],
  "examples": [
    {
      "command": "Rscript script.R",
      "description": "Run an R script"
    },
    {
      "command": "R -e 'install.packages(\"tidyverse\")'",
      "description": "Install a package"
    },
    {
      "command": "R CMD check mypackage",
      "description": "Check an R package"
    },
    {
      "command": "R CMD build mypackage",
      "description": "Build an R package"
    }
  ],
  "relatedCommands": [
    {
      "name": "R",
      "description": "Start an interactive R session",
      "examples": [
        "R",
        "R --vanilla",
        "R --no-save --no-restore",
        "R -e 'print(1+1)'"
      ]
    },
    {
      "name": "Rterm",
      "description": "R terminal interface (Windows)",
      "examples": [
        "Rterm --vanilla"
      ]
    },
    {
      "name": "devtools",
      "description": "R package development tools",
      "examples": [
        "Rscript -e 'devtools::install()'",
        "Rscript -e 'devtools::test()'",
        "Rscript -e 'devtools::check()'",
        "Rscript -e 'devtools::document()'",
        "Rscript -e 'devtools::build()'",
        "Rscript -e 'devtools::load_all()'"
      ]
    },
    {
      "name": "renv",
      "description": "R project environment management",
      "examples": [
        "Rscript -e 'renv::init()'",
        "Rscript -e 'renv::snapshot()'",
        "Rscript -e 'renv::restore()'",
        "Rscript -e 'renv::install(\"dplyr\")'",
        "Rscript -e 'renv::status()'"
      ]
    },
    {
      "name": "testthat",
      "description": "Unit testing framework for R",
      "examples": [
        "Rscript -e 'testthat::test_dir(\"tests\")'",
        "Rscript -e 'testthat::test_file(\"tests/test-myfile.R\")'",
        "Rscript -e 'devtools::test()'"
      ]
    },
    {
      "name": "roxygen2",
      "description": "Generate package documentation from inline comments",
      "examples": [
        "Rscript -e 'roxygen2::roxygenise()'",
        "Rscript -e 'devtools::document()'"
      ]
    },
    {
      "name": "pkgdown",
      "description": "Build a website for an R package",
      "examples": [
        "Rscript -e 'pkgdown::build_site()'",
        "Rscript -e 'pkgdown::build_articles()'",
        "Rscript -e 'pkgdown::build_reference()'"
      ]
    },
    {
      "name": "usethis",
      "description": "Automate R package and project setup tasks",
      "examples": [
        "Rscript -e 'usethis::create_package(\"mypackage\")'",
        "Rscript -e 'usethis::use_testthat()'",
        "Rscript -e 'usethis::use_readme_md()'",
        "Rscript -e 'usethis::use_github_action_check_standard()'"
      ]
    }
  ]
}
