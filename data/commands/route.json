{
  "name": "route",
  "description": "Show/manipulate the IP routing table",
  "category": "networking",
  "platforms": [
    "linux",
    "macos"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish"
  ],
  "subcommands": [
    {
      "name": "add",
      "description": "Add a new route",
      "examples": [
        "route add default gw 192.168.1.1",
        "route add -net 10.0.0.0/8 gw 192.168.1.1"
      ]
    },
    {
      "name": "del",
      "description": "Delete a route",
      "examples": [
        "route del default",
        "route del -net 10.0.0.0/8"
      ]
    }
  ],
  "globalOptions": [
    {
      "name": "-n",
      "description": "Show numerical addresses"
    },
    {
      "name": "-v",
      "description": "Verbose"
    }
  ],
  "examples": [
    "route -n",
    "route add default gw 192.168.1.1",
    "route del default",
    "route add -net 10.0.0.0/8 gw 192.168.1.1"
  ],
  "relatedCommands": [
    "ip",
    "netstat",
    "ifconfig"
  ]
}
