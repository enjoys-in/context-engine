{
  "language": "markdown",
  "name": "markdownlint",
  "description": "Markdown linting, formatting, and conversion tools (markdownlint, pandoc, markdown-it)",
  "category": "tool",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--config",
      "description": "Path to markdownlint configuration file"
    },
    {
      "name": "--fix",
      "description": "Automatically fix lint violations"
    },
    {
      "name": "--ignore",
      "description": "Glob pattern of files to ignore"
    },
    {
      "name": "--output",
      "description": "Output file path"
    },
    {
      "name": "--dot",
      "description": "Include dotfiles in file search"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    }
  ],
  "subcommands": [
    {
      "name": "lint",
      "description": "Lint markdown files for style violations",
      "args": [
        "files"
      ],
      "options": [
        "--config",
        "--fix",
        "--ignore"
      ]
    },
    {
      "name": "fix",
      "description": "Automatically fix markdown lint violations",
      "args": [
        "files"
      ],
      "options": [
        "--config"
      ]
    },
    {
      "name": "convert",
      "description": "Convert markdown to other formats using pandoc",
      "args": [
        "input"
      ],
      "options": [
        "-f",
        "-t",
        "-o"
      ]
    },
    {
      "name": "render",
      "description": "Render markdown to HTML with markdown-it",
      "args": [
        "file"
      ],
      "options": [
        "--html",
        "--linkify"
      ]
    },
    {
      "name": "toc",
      "description": "Generate table of contents for markdown file",
      "args": [
        "file"
      ],
      "options": [
        "--maxdepth",
        "--bullets"
      ]
    },
    {
      "name": "check-links",
      "description": "Check for broken links in markdown files",
      "args": [
        "files"
      ],
      "options": [
        "--alive",
        "--retry"
      ]
    }
  ],
  "examples": [
    "npx markdownlint '**/*.md' --fix",
    "npx markdownlint --config .markdownlint.json README.md",
    "pandoc README.md -f markdown -t html -o README.html",
    "pandoc input.md -o output.pdf",
    "npx markdown-link-check README.md"
  ],
  "relatedCommands": [
    "prettier",
    "pandoc",
    "html",
    "mdx"
  ]
}
