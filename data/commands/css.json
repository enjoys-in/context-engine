{
  "language": "css",
  "name": "stylelint",
  "description": "CSS linter and formatter",
  "category": "development",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--help",
      "description": "Show help information"
    },
    {
      "name": "--version",
      "description": "Show version information"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    }
  ],
  "subcommands": [
    {
      "name": "\"**/*.css\"",
      "description": "Lint CSS files using glob",
      "args": [],
      "options": []
    },
    {
      "name": "--fix \"**/*.css\"",
      "description": "Auto-fix CSS lint issues",
      "args": [],
      "options": []
    },
    {
      "name": "--config path/to/.stylelintrc",
      "description": "Use a custom Stylelint config",
      "args": [],
      "options": []
    },
    {
      "name": "--syntax css",
      "description": "Force CSS syntax",
      "args": [],
      "options": []
    },
    {
      "name": "lint",
      "description": "Lint CSS files",
      "usage": "stylelint '**/*.css'"
    },
    {
      "name": "format",
      "description": "Format CSS files",
      "usage": "prettier --write '**/*.css'"
    },
    {
      "name": "minify",
      "description": "Minify CSS",
      "usage": "cssnano input.css output.css"
    },
    {
      "name": "prefix",
      "description": "Add vendor prefixes",
      "usage": "postcss input.css --use autoprefixer -o output.css"
    },
    {
      "name": "purge",
      "description": "Remove unused CSS",
      "usage": "purgecss --css style.css --content index.html"
    }
  ],
  "examples": [
    {
      "command": "stylelint '**/*.css'",
      "description": "Lint all CSS files"
    },
    {
      "command": "prettier --write '**/*.css'",
      "description": "Format CSS files"
    },
    {
      "command": "postcss input.css -o output.css",
      "description": "Process CSS with PostCSS"
    },
    {
      "command": "cssnano input.css output.css",
      "description": "Minify CSS"
    }
  ],
  "relatedCommands": []
}
