{
  "language": "m3",
  "name": "cm3",
  "description": "Modula-3 compiler and build tools (Critical Mass Modula-3)",
  "category": "language",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "-g",
      "description": "Generate debugging information"
    },
    {
      "name": "-O",
      "description": "Enable optimization"
    },
    {
      "name": "-verbose",
      "description": "Show compilation commands"
    },
    {
      "name": "-keep",
      "description": "Keep intermediate files"
    },
    {
      "name": "-DROOT",
      "description": "Set the root directory for package search"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    }
  ],
  "subcommands": [
    {
      "name": "-make",
      "description": "Build the current package and its dependencies",
      "args": [],
      "options": []
    },
    {
      "name": "-build",
      "description": "Compile files listed in m3makefile",
      "args": [],
      "options": []
    },
    {
      "name": "-clean",
      "description": "Remove derived files from build directory",
      "args": [],
      "options": []
    },
    {
      "name": "-ship",
      "description": "Install the package in the system package pool",
      "args": [],
      "options": []
    },
    {
      "name": "-find",
      "description": "Search for a package in the known package paths",
      "args": [
        "package"
      ],
      "options": []
    },
    {
      "name": "-depend",
      "description": "Show package dependencies",
      "args": [],
      "options": []
    }
  ],
  "examples": [
    "cm3 -make",
    "cm3 -build -verbose",
    "cm3 -clean",
    "cm3 -ship",
    "cm3 -make -g -O"
  ],
  "relatedCommands": [
    "gcc",
    "make",
    "pascal"
  ]
}
