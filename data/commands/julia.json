{
  "language": "julia",
  "name": "julia",
  "description": "Julia command-line tool",
  "category": "development",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--help",
      "description": "Show help information"
    },
    {
      "name": "--version",
      "description": "Show version information"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    },
    {
      "name": "--strict",
      "description": "Enable strict mode with additional checks"
    },
    {
      "name": "--color",
      "description": "Force colored output even when not a TTY"
    },
    {
      "name": "--working-dir",
      "description": "Set the working directory",
      "valueHint": "dir",
      "alias": "-d"
    }
  ],
  "subcommands": [
    {
      "name": "script.jl",
      "description": "Run Julia script",
      "args": [],
      "options": []
    },
    {
      "name": "-e 'expression'",
      "description": "Evaluate expression",
      "args": [],
      "options": []
    },
    {
      "name": "--project=.",
      "description": "Activate project environment",
      "args": [],
      "options": []
    },
    {
      "name": "-t auto",
      "description": "Start with auto threads",
      "args": [],
      "options": []
    },
    {
      "name": "test",
      "description": "Run package tests",
      "usage": "julia -e 'using Pkg; Pkg.test()'"
    },
    {
      "name": "add",
      "description": "Add a package",
      "usage": "julia -e 'using Pkg; Pkg.add(\"PackageName\")'"
    },
    {
      "name": "build",
      "description": "Build a package",
      "usage": "julia -e 'using Pkg; Pkg.build()'"
    },
    {
      "name": "precompile",
      "description": "Precompile packages",
      "usage": "julia -e 'using Pkg; Pkg.precompile()'"
    }
  ],
  "examples": [
    {
      "command": "julia script.jl",
      "description": "Run a Julia script"
    },
    {
      "command": "julia -e 'using Pkg; Pkg.add(\"DataFrames\")'",
      "description": "Install a package"
    },
    {
      "command": "julia -e 'using Pkg; Pkg.test()'",
      "description": "Run package tests"
    },
    {
      "command": "julia --project=. -e 'using Pkg; Pkg.instantiate()'",
      "description": "Install project dependencies"
    }
  ],
  "relatedCommands": []
}
