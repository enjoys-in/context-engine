{
  "name": "mount",
  "description": "Mount a filesystem",
  "category": "system",
  "platforms": [
    "linux",
    "macos"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "-t",
      "description": "Filesystem type (ext4, ntfs, nfs, etc.)",
      "type": "string"
    },
    {
      "name": "-o",
      "description": "Mount options (ro, rw, noexec, etc.)",
      "type": "string"
    },
    {
      "name": "-a",
      "description": "Mount all filesystems in /etc/fstab"
    },
    {
      "name": "-r",
      "description": "Mount read-only"
    },
    {
      "name": "-w",
      "description": "Mount read-write"
    },
    {
      "name": "-v",
      "description": "Verbose mode"
    },
    {
      "name": "--bind",
      "description": "Bind mount a directory"
    }
  ],
  "examples": [
    "mount",
    "mount /dev/sdb1 /mnt/usb",
    "mount -t ext4 /dev/sdb1 /mnt",
    "mount -o ro /dev/sdb1 /mnt",
    "mount -a",
    "mount --bind /src /dst",
    "sudo mount -t nfs server:/share /mnt/nfs"
  ],
  "relatedCommands": [
    "umount",
    "df",
    "lsblk",
    "fstab",
    "findmnt"
  ]
}
