{
  "name": "uvicorn",
  "description": "Lightning-fast ASGI server for Python web applications",
  "category": "python-ecosystem",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell",
    "fish"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "--host",
      "description": "Bind host",
      "takesValue": true
    },
    {
      "name": "--port",
      "description": "Bind port",
      "takesValue": true
    },
    {
      "name": "--uds",
      "description": "Unix domain socket",
      "takesValue": true
    },
    {
      "name": "--fd",
      "description": "File descriptor",
      "takesValue": true
    },
    {
      "name": "--reload",
      "description": "Enable auto-reload"
    },
    {
      "name": "--reload-dir",
      "description": "Directories to watch",
      "takesValue": true
    },
    {
      "name": "--reload-include",
      "description": "File patterns to watch",
      "takesValue": true
    },
    {
      "name": "--reload-exclude",
      "description": "File patterns to exclude",
      "takesValue": true
    },
    {
      "name": "--workers",
      "description": "Number of worker processes",
      "takesValue": true
    },
    {
      "name": "--loop",
      "description": "Event loop (auto, asyncio, uvloop)",
      "takesValue": true
    },
    {
      "name": "--http",
      "description": "HTTP protocol (auto, h11, httptools)",
      "takesValue": true
    },
    {
      "name": "--ws",
      "description": "WebSocket protocol (auto, none, websockets, wsproto)",
      "takesValue": true
    },
    {
      "name": "--ws-max-size",
      "description": "WebSocket max message size",
      "takesValue": true
    },
    {
      "name": "--lifespan",
      "description": "Lifespan mode (auto, on, off)",
      "takesValue": true
    },
    {
      "name": "--interface",
      "description": "Application interface (auto, asgi3, asgi2, wsgi)",
      "takesValue": true
    },
    {
      "name": "--log-level",
      "description": "Log level (critical, error, warning, info, debug, trace)",
      "takesValue": true
    },
    {
      "name": "--log-config",
      "description": "Logging config file",
      "takesValue": true
    },
    {
      "name": "--access-log",
      "description": "Enable access log"
    },
    {
      "name": "--no-access-log",
      "description": "Disable access log"
    },
    {
      "name": "--proxy-headers",
      "description": "Enable proxy headers"
    },
    {
      "name": "--ssl-keyfile",
      "description": "SSL key file",
      "takesValue": true
    },
    {
      "name": "--ssl-certfile",
      "description": "SSL cert file",
      "takesValue": true
    },
    {
      "name": "--ssl-keyfile-password",
      "description": "SSL key password",
      "takesValue": true
    },
    {
      "name": "--root-path",
      "description": "ASGI root_path",
      "takesValue": true
    },
    {
      "name": "--limit-concurrency",
      "description": "Max concurrent connections",
      "takesValue": true
    },
    {
      "name": "--limit-max-requests",
      "description": "Max requests before restart",
      "takesValue": true
    },
    {
      "name": "--timeout-keep-alive",
      "description": "Keep-alive timeout",
      "takesValue": true
    },
    {
      "name": "--factory",
      "description": "Treat APP as a factory function"
    },
    {
      "name": "--help",
      "shorthand": "-h",
      "description": "Show help"
    },
    {
      "name": "--version",
      "description": "Show version"
    }
  ],
  "examples": [
    {
      "command": "uvicorn main:app",
      "description": "Run ASGI app"
    },
    {
      "command": "uvicorn main:app --reload --port 8000",
      "description": "Dev server with hot reload"
    },
    {
      "command": "uvicorn main:app --host 0.0.0.0 --workers 4",
      "description": "Production with 4 workers"
    },
    {
      "command": "uvicorn main:app --ssl-keyfile=key.pem --ssl-certfile=cert.pem",
      "description": "Run with HTTPS"
    },
    {
      "command": "uvicorn app.main:create_app --factory",
      "description": "Run factory app"
    }
  ],
  "relatedCommands": [
    "gunicorn",
    "python",
    "flask"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "asgi_apps",
        "description": "ASGI application entry points",
        "command": "grep -rl 'FastAPI\\|Starlette\\|app\\s*=' *.py 2>/dev/null | head -5",
        "parser": "lines",
        "cacheFor": 30
      },
      {
        "name": "pyproject",
        "description": "Project configuration",
        "command": "cat pyproject.toml 2>/dev/null | head -20",
        "parser": "text",
        "cacheFor": 60
      },
      {
        "name": "virtualenv",
        "description": "Active virtual environment",
        "command": "echo $VIRTUAL_ENV 2>/dev/null",
        "parser": "text",
        "cacheFor": 30
      }
    ]
  }
}
