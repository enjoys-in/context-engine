{
  "name": "ghc",
  "description": "Glasgow Haskell Compiler",
  "category": "language",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "-o",
      "description": "Output file",
      "type": "file"
    },
    {
      "name": "-O",
      "description": "Optimize (0, 1, 2)"
    },
    {
      "name": "-c",
      "description": "Compile only (no link)"
    },
    {
      "name": "-e",
      "description": "Evaluate expression",
      "type": "string"
    },
    {
      "name": "--make",
      "description": "Build program and dependencies"
    },
    {
      "name": "-i",
      "description": "Add directory to import path",
      "type": "string"
    },
    {
      "name": "-Wall",
      "description": "Enable all warnings"
    },
    {
      "name": "-Werror",
      "description": "Treat warnings as errors"
    },
    {
      "name": "-dynamic",
      "description": "Dynamically linked"
    },
    {
      "name": "-threaded",
      "description": "Enable threaded runtime"
    },
    {
      "name": "-prof",
      "description": "Enable profiling"
    }
  ],
  "examples": [
    "ghc -o hello Main.hs",
    "ghc --make Main.hs",
    "ghc -O2 -o app Main.hs",
    "ghci",
    "ghc -e 'putStrLn \"Hello\"'"
  ],
  "relatedCommands": [
    "cabal",
    "stack",
    "ghci",
    "haskell"
  ]
}
