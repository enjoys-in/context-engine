{
  "language": "scheme",
  "name": "scheme",
  "description": "Scheme — Lisp-dialect interpreter (Chez Scheme, Guile, MIT/GNU Scheme, Racket)",
  "category": "language",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--script",
      "description": "Run file as a script"
    },
    {
      "name": "--program",
      "description": "Run file as R6RS program"
    },
    {
      "name": "--optimize-level",
      "description": "Optimization level (0-3)"
    },
    {
      "name": "--libdirs",
      "description": "Colon-separated library directories"
    },
    {
      "name": "--compile-imported-libraries",
      "description": "Compile imported libraries to .so files"
    },
    {
      "name": "--debug-on-exception",
      "description": "Enter debugger on unhandled exceptions"
    },
    {
      "name": "--help",
      "description": "Show help information",
      "alias": "-h"
    },
    {
      "name": "--version",
      "description": "Show version number",
      "alias": "-v"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    }
  ],
  "subcommands": [
    {
      "name": "--script file.scm",
      "description": "Run a Scheme script file",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "--program file.scm",
      "description": "Run as R6RS program",
      "args": [
        "file"
      ],
      "options": []
    },
    {
      "name": "-e '(expression)'",
      "description": "Evaluate a single Scheme expression",
      "args": [
        "expr"
      ],
      "options": []
    },
    {
      "name": "--compile-imported-libraries",
      "description": "Compile all imported libraries",
      "args": [],
      "options": []
    },
    {
      "name": "--optimize-level 3",
      "description": "Set optimization level",
      "args": [
        "level"
      ],
      "options": []
    }
  ],
  "examples": [
    "scheme --script program.scm",
    "guile script.scm",
    "racket program.rkt",
    "mit-scheme --load program.scm",
    "chez-scheme --optimize-level 3 --program app.scm"
  ],
  "relatedCommands": [
    "clojure",
    "racket",
    "lua",
    "python"
  ]
}
