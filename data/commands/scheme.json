{
  "name": "scheme",
  "description": "Scheme — Lisp-dialect interpreter (Chez Scheme, Guile, MIT/GNU Scheme, Racket)",
  "category": "language",
  "platforms": ["linux", "macos", "windows"],
  "shells": ["bash", "zsh", "powershell"],
  "subcommands": [
    { "name": "--script file.scm", "description": "Run a Scheme script file", "args": ["file"], "options": [] },
    { "name": "--program file.scm", "description": "Run as R6RS program", "args": ["file"], "options": [] },
    { "name": "-e '(expression)'", "description": "Evaluate a single Scheme expression", "args": ["expr"], "options": [] },
    { "name": "--compile-imported-libraries", "description": "Compile all imported libraries", "args": [], "options": [] },
    { "name": "--optimize-level 3", "description": "Set optimization level", "args": ["level"], "options": [] }
  ],
  "globalOptions": [
    { "name": "--script", "description": "Run file as a script" },
    { "name": "--program", "description": "Run file as R6RS program" },
    { "name": "--optimize-level", "description": "Optimization level (0-3)" },
    { "name": "--libdirs", "description": "Colon-separated library directories" },
    { "name": "--compile-imported-libraries", "description": "Compile imported libraries to .so files" },
    { "name": "--debug-on-exception", "description": "Enter debugger on unhandled exceptions" }
  ],
  "examples": [
    "scheme --script program.scm",
    "guile script.scm",
    "racket program.rkt",
    "mit-scheme --load program.scm",
    "chez-scheme --optimize-level 3 --program app.scm"
  ],
  "relatedCommands": ["clojure", "racket", "lua", "python"]
}