{
  "name": "gofmt",
  "description": "Go source code formatter",
  "category": "go-ecosystem",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell",
    "fish"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "-d",
      "description": "Display diffs instead of rewriting files"
    },
    {
      "name": "-e",
      "description": "Report all errors (not just first 10)"
    },
    {
      "name": "-l",
      "description": "List files whose formatting differs"
    },
    {
      "name": "-s",
      "description": "Simplify code"
    },
    {
      "name": "-w",
      "description": "Write result to source file"
    },
    {
      "name": "-r",
      "description": "Rewrite rule (e.g. 'a[b:len(a)] -> a[b:]')",
      "takesValue": true
    },
    {
      "name": "-cpuprofile",
      "description": "Write CPU profile to file",
      "takesValue": true
    }
  ],
  "examples": [
    {
      "command": "gofmt -w .",
      "description": "Format all Go files in current directory"
    },
    {
      "command": "gofmt -d main.go",
      "description": "Show diff for a file"
    },
    {
      "command": "gofmt -l .",
      "description": "List unformatted files"
    },
    {
      "command": "gofmt -s -w .",
      "description": "Format and simplify all files"
    },
    {
      "command": "gofmt -r 'bytes.Compare(a, b) == 0 -> bytes.Equal(a, b)' -w .",
      "description": "Apply rewrite rule"
    }
  ],
  "relatedCommands": [
    "go",
    "golangci-lint"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "go_files",
        "description": "Go source files",
        "command": "find . -name '*.go' -not -path './vendor/*' 2>/dev/null | head -20",
        "parser": "lines",
        "cacheFor": 30
      },
      {
        "name": "unformatted",
        "description": "Unformatted Go files",
        "command": "gofmt -l . 2>/dev/null | head -10",
        "parser": "lines",
        "cacheFor": 15,
        "requiresCmd": "gofmt"
      },
      {
        "name": "go_module",
        "description": "Go module name",
        "command": "head -1 go.mod 2>/dev/null",
        "parser": "text",
        "cacheFor": 120
      }
    ]
  }
}
