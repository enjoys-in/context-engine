{
  "name": "ruby",
  "description": "Ruby interpreter",
  "category": "PHP & Ruby Ecosystems",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell",
    "fish"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "-v",
      "description": "Print version number, then turn on verbose mode"
    },
    {
      "name": "-e",
      "description": "Execute provided inline code",
      "takesValue": true
    }
  ],
  "examples": [
    {
      "command": "ruby -v",
      "description": "Check Ruby version"
    },
    {
      "command": "ruby script.rb",
      "description": "Run a Ruby script"
    },
    {
      "command": "ruby -e 'puts \"Hello\"'",
      "description": "Run inline Ruby"
    }
  ],
  "relatedCommands": [
    "gem",
    "bundle",
    "rails"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "version",
        "description": "Ruby Version",
        "command": "ruby -v 2>/dev/null",
        "parser": "text",
        "cacheFor": 3600
      }
    ]
  }
}