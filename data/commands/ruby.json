{
  "language": "ruby",
  "name": "ruby",
  "description": "Ruby Programming Language",
  "category": "language",
  "contextEngine": {
    "detectors": [
      {
        "name": "version",
        "description": "Ruby Version",
        "command": "ruby -v 2>/dev/null",
        "parser": "text",
        "cacheFor": 3600
      },
      {
        "name": "scripts",
        "description": "Ruby scripts in current directory",
        "command": "ls *.rb 2>/dev/null | head -10",
        "parser": "lines",
        "cacheFor": 30
      }
    ]
  },
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "fish",
    "powershell"
  ],
  "globalOptions": [
    {
      "name": "--version",
      "short": "-v",
      "description": "print version number, then turn on inspect mode"
    },
    {
      "name": "--help",
      "short": "-h",
      "description": "show this message, -h for short message"
    },
    {
      "name": "-e",
      "description": "one line of script. Several -e's allowed. Omit [programfile]",
      "type": "string"
    },
    {
      "name": "-r",
      "description": "require the library before executing your script",
      "type": "string"
    },
    {
      "name": "-I",
      "description": "specify $LOAD_PATH directory (may be used more than once)",
      "type": "path"
    },
    {
      "name": "-c",
      "description": "check syntax only"
    },
    {
      "name": "-w",
      "description": "turn warnings on for your script"
    },
    {
      "name": "-W",
      "description": "set warning level; 0=silence, 1=medium, 2=verbose",
      "type": "number"
    },
    {
      "name": "-d",
      "description": "set debugging flags (set $DEBUG to true)"
    },
    {
      "name": "-0",
      "description": "specify record separator (\\0, if no argument)",
      "type": "string"
    },
    {
      "name": "-E",
      "description": "specify the default external and internal character encodings",
      "type": "string"
    },
    {
      "name": "-U",
      "description": "set default internal encoding to UTF-8"
    },
    {
      "name": "--jit",
      "description": "enable JIT compiler"
    },
    {
      "name": "--verbose",
      "description": "Enable verbose/detailed output"
    },
    {
      "name": "--quiet",
      "description": "Suppress non-error output",
      "alias": "-q"
    },
    {
      "name": "--debug",
      "description": "Enable debug mode for troubleshooting"
    },
    {
      "name": "--config",
      "description": "Specify configuration file path",
      "valueHint": "path"
    },
    {
      "name": "--output",
      "description": "Specify output directory or file",
      "valueHint": "path",
      "alias": "-o"
    },
    {
      "name": "--force",
      "description": "Force operation without confirmation",
      "alias": "-f"
    },
    {
      "name": "--dry-run",
      "description": "Preview what would happen without making changes"
    },
    {
      "name": "--no-color",
      "description": "Disable colored output"
    },
    {
      "name": "--format",
      "description": "Specify output format (json, text, table)",
      "valueHint": "format"
    },
    {
      "name": "--log-level",
      "description": "Set logging level (error, warn, info, debug)",
      "valueHint": "level"
    },
    {
      "name": "--interactive",
      "description": "Enable interactive prompts",
      "alias": "-i"
    },
    {
      "name": "--silent",
      "description": "Suppress all output except errors"
    }
  ],
  "subcommands": [],
  "examples": [
    "ruby -v",
    "ruby script.rb",
    "ruby -e 'puts \"Hello World\"'",
    "ruby -cw my_script.rb"
  ],
  "relatedCommands": [
    "gem",
    "bundle",
    "rails"
  ]
}
