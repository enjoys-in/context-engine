{
  "name": "flutter",
  "description": "Flutter framework cross-platform SDK",
  "category": "Mobile Development",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell"
  ],
  "subcommands": [
    {
      "name": "run",
      "description": "Run your Flutter app on an attached device"
    },
    {
      "name": "build",
      "description": "Build an executable app or install bundle"
    },
    {
      "name": "doctor",
      "description": "Show information about the installed tooling"
    },
    {
      "name": "pub",
      "description": "Commands for managing Flutter packages"
    },
    {
      "name": "create",
      "description": "Create a new Flutter project"
    }
  ],
  "globalOptions": [
    {
      "name": "-d",
      "description": "Target device id or name",
      "takesValue": true
    },
    {
      "name": "-v",
      "description": "Verbose mode"
    }
  ],
  "examples": [
    {
      "command": "flutter doctor",
      "description": "Check tooling status"
    },
    {
      "command": "flutter run",
      "description": "Run app"
    },
    {
      "command": "flutter pub get",
      "description": "Fetch dependencies"
    }
  ],
  "relatedCommands": [
    "dart",
    "adb",
    "pod"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "devices",
        "description": "Connected Devices",
        "command": "flutter devices | grep '\u2022' 2>/dev/null",
        "parser": "lines",
        "cacheFor": 10
      },
      {
        "name": "pubspec",
        "description": "Dependencies",
        "command": "cat pubspec.yaml 2>/dev/null | grep -A 10 '^dependencies:'",
        "parser": "text",
        "cacheFor": 30
      }
    ]
  }
}