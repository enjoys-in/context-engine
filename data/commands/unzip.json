{
  "name": "unzip",
  "description": "Extract files from ZIP archives",
  "category": "coreutils",
  "platforms": [
    "linux",
    "macos",
    "windows"
  ],
  "shells": [
    "bash",
    "zsh",
    "powershell",
    "fish"
  ],
  "subcommands": [],
  "globalOptions": [
    {
      "name": "-d",
      "description": "Extract to specified directory",
      "takesValue": true
    },
    {
      "name": "-o",
      "description": "Overwrite without prompting"
    },
    {
      "name": "-n",
      "description": "Never overwrite existing files"
    },
    {
      "name": "-l",
      "description": "List archive contents"
    },
    {
      "name": "-t",
      "description": "Test archive integrity"
    },
    {
      "name": "-v",
      "description": "Verbose listing or extraction"
    },
    {
      "name": "-q",
      "description": "Quiet mode"
    },
    {
      "name": "-j",
      "description": "Junk paths (don't create directories)"
    },
    {
      "name": "-x",
      "description": "Exclude files matching pattern",
      "takesValue": true
    },
    {
      "name": "-p",
      "description": "Extract to stdout (pipe)"
    },
    {
      "name": "-P",
      "description": "Extract absolute paths (DANGEROUS)"
    },
    {
      "name": "-Z",
      "description": "zipinfo mode"
    },
    {
      "name": "-c",
      "description": "Extract to stdout with filenames"
    },
    {
      "name": "-a",
      "description": "Auto-convert text files"
    },
    {
      "name": "-B",
      "description": "Backup existing files before overwrite"
    },
    {
      "name": "-C",
      "description": "Case-insensitive matching"
    },
    {
      "name": "-K",
      "description": "Preserve setuid/setgid/sticky bits"
    },
    {
      "name": "-L",
      "description": "Convert filenames to lowercase"
    },
    {
      "name": "-X",
      "description": "Restore UID/GID info"
    }
  ],
  "examples": [
    {
      "command": "unzip archive.zip",
      "description": "Extract to current directory"
    },
    {
      "command": "unzip archive.zip -d output/",
      "description": "Extract to directory"
    },
    {
      "command": "unzip -l archive.zip",
      "description": "List contents"
    },
    {
      "command": "unzip -o archive.zip",
      "description": "Extract overwriting files"
    },
    {
      "command": "unzip archive.zip '*.txt'",
      "description": "Extract only txt files"
    },
    {
      "command": "unzip -t archive.zip",
      "description": "Test integrity"
    },
    {
      "command": "unzip archive.zip -x '*.log'",
      "description": "Extract excluding pattern"
    },
    {
      "command": "unzip -p archive.zip file.txt | head",
      "description": "Extract to stdout"
    }
  ],
  "relatedCommands": [
    "zip",
    "tar"
  ],
  "contextEngine": {
    "detectors": [
      {
        "name": "zip_files",
        "description": "Available ZIP archives",
        "command": "find . -maxdepth 2 -name '*.zip' 2>/dev/null | head -10",
        "parser": "lines",
        "cacheFor": 15
      },
      {
        "name": "archive_contents",
        "description": "Contents of most recent zip",
        "command": "unzip -l $(ls -t *.zip 2>/dev/null | head -1) 2>/dev/null | tail -n +4 | head -20",
        "parser": "lines",
        "cacheFor": 15,
        "requiresCmd": "unzip"
      }
    ]
  }
}
