{
  "language": "r",
  "defaultToken": "invalid",
  "tokenPostfix": ".r",
  "ignoreCase": false,
  "keywords": [
    "if",
    "else",
    "repeat",
    "while",
    "function",
    "for",
    "in",
    "next",
    "break",
    "TRUE",
    "FALSE",
    "NULL",
    "Inf",
    "NaN",
    "NA",
    "NA_integer_",
    "NA_real_",
    "NA_complex_",
    "NA_character_",
    "return",
    "invisible",
    "library",
    "require",
    "source",
    "switch",
    "tryCatch",
    "stop",
    "warning",
    "message",
    "cat",
    "print",
    "paste",
    "paste0",
    "sprintf",
    "class",
    "inherits",
    "is",
    "as",
    "new",
    "setClass",
    "setGeneric",
    "setMethod",
    "setRefClass",
    "R6Class",
    "UseMethod",
    "NextMethod"
  ],
  "typeKeywords": [],
  "operators": [
    "=",
    "!=",
    "==",
    ">",
    "<",
    ">=",
    "<=",
    "+",
    "-",
    "*",
    "/",
    "%"
  ],
  "symbols": "[-=><!~?:&|+\\-*\\/\\^%]+",
  "escapes": "\\\\(?:[abfnrtv\\\\\"'\\\\]|x[0-9A-Fa-f]{1,4}|u[0-9A-Fa-f]{4}|U[0-9A-Fa-f]{8})",
  "digits": "\\d*\\.?\\d+([eE][\\-+]?\\d+)?",
  "brackets": [
    {
      "open": "{",
      "close": "}",
      "token": "delimiter.curly"
    },
    {
      "open": "[",
      "close": "]",
      "token": "delimiter.square"
    },
    {
      "open": "(",
      "close": ")",
      "token": "delimiter.parenthesis"
    }
  ],
  "tokenizer": {
    "root": [
      {
        "include": "@whitespace"
      },
      [
        "[{}()\\[\\]]",
        "@brackets"
      ],
      [
        "[a-zA-Z_]\\w*",
        {
          "cases": {
            "@keywords": "keyword",
            "@typeKeywords": "type",
            "@default": "identifier"
          }
        }
      ],
      [
        "@digits",
        "number"
      ],
      [
        "0[xX][0-9a-fA-F]+",
        "number.hex"
      ],
      [
        "\"",
        "string",
        "@string_double"
      ],
      [
        "'",
        "string",
        "@string_single"
      ],
      [
        "@symbols",
        {
          "cases": {
            "@operators": "operator",
            "@default": ""
          }
        }
      ],
      [
        "[;,.]",
        "delimiter"
      ]
    ],
    "whitespace": [
      [
        "[ \\t\\r\\n]+",
        "white"
      ],
      [
        "#.*$",
        "comment"
      ],
      [
        "/\\*",
        "comment",
        "@comment"
      ]
    ],
    "comment": [],
    "string_double": [
      [
        "[^\\\\\"]+",
        "string"
      ],
      [
        "@escapes",
        "string.escape"
      ],
      [
        "\"",
        "string",
        "@pop"
      ]
    ],
    "string_single": [
      [
        "[^\\\\']+",
        "string"
      ],
      [
        "@escapes",
        "string.escape"
      ],
      [
        "'",
        "string",
        "@pop"
      ]
    ]
  }
}
