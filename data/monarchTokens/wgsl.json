{
  "language": "wgsl",
  "tokenPostfix": ".wgsl",
  "defaultToken": "invalid",
  "keywords": [
    "alias",
    "break",
    "case",
    "const",
    "const_assert",
    "continue",
    "continuing",
    "default",
    "diagnostic",
    "discard",
    "else",
    "enable",
    "false",
    "fn",
    "for",
    "if",
    "let",
    "loop",
    "override",
    "requires",
    "return",
    "struct",
    "switch",
    "true",
    "var",
    "while",
    "array",
    "atomic",
    "bool",
    "f16",
    "f32",
    "i32",
    "mat2x2",
    "mat2x3",
    "mat2x4",
    "mat3x2",
    "mat3x3",
    "mat3x4",
    "mat4x2",
    "mat4x3",
    "mat4x4",
    "ptr",
    "sampler",
    "sampler_comparison",
    "texture_1d",
    "texture_2d",
    "texture_2d_array",
    "texture_3d",
    "texture_cube",
    "texture_cube_array",
    "texture_multisampled_2d",
    "texture_storage_1d",
    "texture_storage_2d",
    "texture_storage_2d_array",
    "texture_storage_3d",
    "u32",
    "vec2",
    "vec3",
    "vec4",
    "read",
    "read_write",
    "write",
    "function",
    "private",
    "workgroup",
    "uniform",
    "storage",
    "vertex",
    "fragment",
    "compute",
    "workgroup_size",
    "binding",
    "group",
    "location",
    "builtin"
  ],
  "typeKeywords": [
    "int",
    "float",
    "double",
    "string",
    "bool",
    "boolean",
    "void",
    "null",
    "char",
    "byte",
    "long",
    "short",
    "array",
    "list",
    "map",
    "set",
    "object",
    "class",
    "type",
    "function",
    "module",
    "tuple",
    "record",
    "enum",
    "struct",
    "interface",
    "trait",
    "any",
    "never",
    "unknown",
    "optional",
    "result",
    "error",
    "promise",
    "future",
    "stream",
    "iterator",
    "callable",
    "undefined",
    "none",
    "unit",
    "variant"
  ],
  "operators": [
    "+",
    "-",
    "*",
    "/",
    "=",
    "!",
    "<",
    ">",
    "&",
    "|",
    "^",
    "~",
    "%",
    "==",
    "!=",
    "<=",
    ">=",
    "&&",
    "||",
    "++",
    "--",
    "+=",
    "-=",
    "*=",
    "/=",
    "<<",
    ">>",
    "??",
    "?.",
    "=>"
  ],
  "symbols": "[-=><!~?:&|+\\-*\\/\\^%]+",
  "escapes": "\\\\(?:[abfnrtv\\\\\"'\\\\]|x[0-9A-Fa-f]{1,4}|u[0-9A-Fa-f]{4}|U[0-9A-Fa-f]{8})",
  "digits": "\\d*\\.?\\d+([eE][\\-+]?\\d+)?",
  "brackets": [
    {
      "open": "{",
      "close": "}",
      "token": "delimiter.curly"
    },
    {
      "open": "[",
      "close": "]",
      "token": "delimiter.square"
    },
    {
      "open": "(",
      "close": ")",
      "token": "delimiter.parenthesis"
    }
  ],
  "tokenizer": {
    "root": [
      [
        "[ \\t\\r\\n]+",
        "",
        "@whitespace"
      ],
      [
        "[{}()\\[\\]]",
        "delimiter.bracket"
      ],
      [
        "/\\*",
        "comment",
        "@comment"
      ],
      [
        "//.*$",
        "comment"
      ],
      [
        "\"",
        "string",
        "@string_double"
      ],
      [
        "'",
        "string",
        "@string_single"
      ],
      [
        "0[xX][0-9a-fA-F]+",
        "number.hex"
      ],
      [
        "0[oO]?[0-7]+",
        "number.octal"
      ],
      [
        "0[bB][01]+",
        "number.binary"
      ],
      [
        "\\d+\\.\\d*([eE][+-]?\\d+)?",
        "number.float"
      ],
      [
        "\\d+",
        "number"
      ],
      [
        "[a-zA-Z_$][\\w$]*",
        {
          "cases": {
            "@keywords": "keyword",
            "@typeKeywords": "type",
            "@default": "identifier"
          }
        }
      ],
      [
        "@symbols",
        {
          "cases": {
            "@operators": "operator",
            "@default": ""
          }
        }
      ]
    ],
    "whitespace": [
      [
        "[ \\t\\r\\n]+",
        ""
      ]
    ],
    "comment": [
      [
        "\\*/",
        "comment",
        "@pop"
      ],
      [
        ".",
        "comment"
      ]
    ],
    "string_double": [
      [
        "[^\"\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt\"']",
        "string.escape"
      ],
      [
        "\"",
        "string",
        "@pop"
      ]
    ],
    "string_single": [
      [
        "[^'\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt\"']",
        "string.escape"
      ],
      [
        "'",
        "string",
        "@pop"
      ]
    ],
    "string_backtick": [
      [
        "[^`\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt]",
        "string.escape"
      ],
      [
        "`",
        "string",
        "@pop"
      ]
    ],
    "string_triple": [
      [
        "[^\"]+",
        "string"
      ],
      [
        "\"\"\"",
        "string",
        "@pop"
      ],
      [
        "\"",
        "string"
      ]
    ]
  }
}
