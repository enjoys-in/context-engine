{
  "language": "prisma",
  "displayName": "Prisma",
  "tokenTypes": [
    "keyword",
    "string",
    "comment",
    "number",
    "operator",
    "identifier",
    "type",
    "delimiter",
    "variable",
    "function"
  ],
  "rules": {
    "root": [
      {
        "regex": "model",
        "action": {
          "token": "keyword"
        }
      },
      {
        "regex": "enum",
        "action": {
          "token": "keyword"
        }
      },
      {
        "regex": "datasource",
        "action": {
          "token": "keyword"
        }
      },
      {
        "regex": "generator",
        "action": {
          "token": "keyword"
        }
      },
      {
        "regex": "@id",
        "action": {
          "token": "keyword"
        }
      },
      {
        "regex": "@unique",
        "action": {
          "token": "keyword"
        }
      },
      {
        "regex": "@relation",
        "action": {
          "token": "keyword"
        }
      },
      {
        "regex": "@default",
        "action": {
          "token": "keyword"
        }
      },
      {
        "regex": "@map",
        "action": {
          "token": "keyword"
        }
      },
      {
        "regex": "@updatedAt",
        "action": {
          "token": "keyword"
        }
      },
      {
        "regex": "\"([^\"\\\\]|\\\\.)*\"",
        "action": {
          "token": "string"
        }
      },
      {
        "regex": "'([^'\\\\]|\\\\.)*'",
        "action": {
          "token": "string"
        }
      },
      {
        "regex": "//.*$",
        "action": {
          "token": "comment"
        }
      },
      {
        "regex": "/\\*",
        "action": {
          "token": "comment",
          "next": "@comment"
        }
      },
      {
        "regex": "\\d+(\\.\\d+)?",
        "action": {
          "token": "number"
        }
      },
      {
        "regex": "[{}()\\[\\]]",
        "action": {
          "token": "delimiter"
        }
      },
      {
        "regex": "[a-zA-Z_]\\w*",
        "action": {
          "token": "identifier"
        }
      }
    ],
    "comment": [
      {
        "regex": "\\*/",
        "action": {
          "token": "comment",
          "next": "@pop"
        }
      },
      {
        "regex": ".",
        "action": {
          "token": "comment"
        }
      }
    ]
  }
}
