{
  "language": "abap",
  "defaultToken": "invalid",
  "tokenPostfix": ".abap",
  "ignoreCase": true,
  "keywords": [
    "REPORT",
    "DATA",
    "TYPE",
    "TYPES",
    "BEGIN",
    "END",
    "OF",
    "TABLE",
    "STRUCTURE",
    "CLASS",
    "DEFINITION",
    "IMPLEMENTATION",
    "PUBLIC",
    "PRIVATE",
    "PROTECTED",
    "METHODS",
    "METHOD",
    "ENDMETHOD",
    "ENDCLASS",
    "FORM",
    "ENDFORM",
    "PERFORM",
    "DO",
    "ENDDO",
    "WHILE",
    "ENDWHILE",
    "LOOP",
    "ENDLOOP",
    "AT",
    "ENDAT",
    "IF",
    "ELSEIF",
    "ELSE",
    "ENDIF",
    "CASE",
    "WHEN",
    "ENDCASE",
    "SELECT",
    "ENDSELECT",
    "FROM",
    "WHERE",
    "INTO",
    "APPENDING",
    "CORRESPONDING",
    "FIELDS",
    "GROUP",
    "BY",
    "HAVING",
    "ORDER",
    "JOIN",
    "INNER",
    "LEFT",
    "OUTER",
    "ON",
    "WRITE",
    "MOVE",
    "CLEAR",
    "REFRESH",
    "FREE",
    "CALL",
    "FUNCTION",
    "MODULE",
    "RAISE",
    "EVENT",
    "TRY",
    "CATCH",
    "ENDTRY",
    "IMPORT",
    "EXPORT",
    "CHANGING",
    "RETURNING",
    "EXPORTING",
    "IMPORTING",
    "APPEND",
    "INSERT",
    "MODIFY",
    "DELETE",
    "READ",
    "SORT",
    "DESCRIBE",
    "FIELD-SYMBOLS",
    "ASSIGN",
    "UNASSIGN",
    "NEW",
    "CREATE",
    "OBJECT",
    "INTERFACE",
    "ENDINTERFACE",
    "ABSTRACT",
    "FINAL",
    "INHERITING",
    "REDEFINITION"
  ],
  "typeKeywords": [],
  "operators": [
    "=",
    "!=",
    "==",
    ">",
    "<",
    ">=",
    "<=",
    "+",
    "-",
    "*",
    "/",
    "%"
  ],
  "symbols": "[-=><!~?:&|+\\-*\\/\\^%]+",
  "escapes": "\\\\(?:[abfnrtv\\\\\"'\\\\]|x[0-9A-Fa-f]{1,4}|u[0-9A-Fa-f]{4}|U[0-9A-Fa-f]{8})",
  "digits": "\\d*\\.?\\d+([eE][\\-+]?\\d+)?",
  "brackets": [
    {
      "open": "{",
      "close": "}",
      "token": "delimiter.curly"
    },
    {
      "open": "[",
      "close": "]",
      "token": "delimiter.square"
    },
    {
      "open": "(",
      "close": ")",
      "token": "delimiter.parenthesis"
    }
  ],
  "tokenizer": {
    "root": [
      {
        "include": "@whitespace"
      },
      [
        "[{}()\\[\\]]",
        "@brackets"
      ],
      [
        "[a-zA-Z_]\\w*",
        {
          "cases": {
            "@keywords": "keyword",
            "@typeKeywords": "type",
            "@default": "identifier"
          }
        }
      ],
      [
        "@digits",
        "number"
      ],
      [
        "0[xX][0-9a-fA-F]+",
        "number.hex"
      ],
      [
        "\"",
        "string",
        "@string_double"
      ],
      [
        "'",
        "string",
        "@string_single"
      ],
      [
        "@symbols",
        {
          "cases": {
            "@operators": "operator",
            "@default": ""
          }
        }
      ],
      [
        "[;,.]",
        "delimiter"
      ]
    ],
    "whitespace": [
      [
        "[ \\t\\r\\n]+",
        "white"
      ],
      [
        "//.*$",
        "comment"
      ],
      [
        "/\\*",
        "comment",
        "@comment"
      ]
    ],
    "comment": [],
    "string_double": [
      [
        "[^\\\\\"]+",
        "string"
      ],
      [
        "@escapes",
        "string.escape"
      ],
      [
        "\"",
        "string",
        "@pop"
      ]
    ],
    "string_single": [
      [
        "[^\\\\']+",
        "string"
      ],
      [
        "@escapes",
        "string.escape"
      ],
      [
        "'",
        "string",
        "@pop"
      ]
    ]
  }
}
