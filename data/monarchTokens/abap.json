{
  "language": "abap",
  "tokenPostfix": ".abap",
  "defaultToken": "invalid",
  "keywords": [
    "REPORT",
    "DATA",
    "TYPE",
    "TYPES",
    "BEGIN",
    "END",
    "OF",
    "TABLE",
    "STRUCTURE",
    "CLASS",
    "DEFINITION",
    "IMPLEMENTATION",
    "PUBLIC",
    "PRIVATE",
    "PROTECTED",
    "METHODS",
    "METHOD",
    "ENDMETHOD",
    "ENDCLASS",
    "FORM",
    "ENDFORM",
    "PERFORM",
    "DO",
    "ENDDO",
    "WHILE",
    "ENDWHILE",
    "LOOP",
    "ENDLOOP",
    "AT",
    "ENDAT",
    "IF",
    "ELSEIF",
    "ELSE",
    "ENDIF",
    "CASE",
    "WHEN",
    "ENDCASE",
    "SELECT",
    "ENDSELECT",
    "FROM",
    "WHERE",
    "INTO",
    "APPENDING",
    "CORRESPONDING",
    "FIELDS",
    "GROUP",
    "BY",
    "HAVING",
    "ORDER",
    "JOIN",
    "INNER",
    "LEFT",
    "OUTER",
    "ON",
    "WRITE",
    "MOVE",
    "CLEAR",
    "REFRESH",
    "FREE",
    "CALL",
    "FUNCTION",
    "MODULE",
    "RAISE",
    "EVENT",
    "TRY",
    "CATCH",
    "ENDTRY",
    "IMPORT",
    "EXPORT",
    "CHANGING",
    "RETURNING",
    "EXPORTING",
    "IMPORTING",
    "APPEND",
    "INSERT",
    "MODIFY",
    "DELETE",
    "READ",
    "SORT",
    "DESCRIBE",
    "FIELD-SYMBOLS",
    "ASSIGN",
    "UNASSIGN",
    "NEW",
    "CREATE",
    "OBJECT",
    "INTERFACE",
    "ENDINTERFACE",
    "ABSTRACT",
    "FINAL",
    "INHERITING",
    "REDEFINITION"
  ],
  "typeKeywords": [
    "int",
    "float",
    "double",
    "string",
    "bool",
    "boolean",
    "void",
    "null",
    "char",
    "byte",
    "long",
    "short",
    "array",
    "list",
    "map",
    "set",
    "object",
    "class",
    "type",
    "function",
    "module",
    "tuple",
    "record",
    "enum",
    "struct",
    "interface",
    "trait",
    "any",
    "never",
    "unknown",
    "optional",
    "result",
    "error",
    "promise",
    "future",
    "stream",
    "iterator",
    "callable",
    "undefined",
    "none",
    "unit",
    "variant"
  ],
  "operators": [
    "+",
    "-",
    "*",
    "/",
    "=",
    "!",
    "<",
    ">",
    "&",
    "|",
    "^",
    "~",
    "%",
    "==",
    "!=",
    "<=",
    ">=",
    "&&",
    "||",
    "++",
    "--",
    "+=",
    "-=",
    "*=",
    "/=",
    "<<",
    ">>",
    "??",
    "?.",
    "=>"
  ],
  "symbols": "[-=><!~?:&|+\\-*\\/\\^%]+",
  "escapes": "\\\\(?:[abfnrtv\\\\\"'\\\\]|x[0-9A-Fa-f]{1,4}|u[0-9A-Fa-f]{4}|U[0-9A-Fa-f]{8})",
  "digits": "\\d*\\.?\\d+([eE][\\-+]?\\d+)?",
  "brackets": [
    {
      "open": "{",
      "close": "}",
      "token": "delimiter.curly"
    },
    {
      "open": "[",
      "close": "]",
      "token": "delimiter.square"
    },
    {
      "open": "(",
      "close": ")",
      "token": "delimiter.parenthesis"
    }
  ],
  "tokenizer": {
    "root": [
      [
        "[ \\t\\r\\n]+",
        "",
        "@whitespace"
      ],
      [
        "[{}()\\[\\]]",
        "delimiter.bracket"
      ],
      [
        "/\\*",
        "comment",
        "@comment"
      ],
      [
        "//.*$",
        "comment"
      ],
      [
        "\"",
        "string",
        "@string_double"
      ],
      [
        "'",
        "string",
        "@string_single"
      ],
      [
        "0[xX][0-9a-fA-F]+",
        "number.hex"
      ],
      [
        "0[oO]?[0-7]+",
        "number.octal"
      ],
      [
        "0[bB][01]+",
        "number.binary"
      ],
      [
        "\\d+\\.\\d*([eE][+-]?\\d+)?",
        "number.float"
      ],
      [
        "\\d+",
        "number"
      ],
      [
        "[a-zA-Z_$][\\w$]*",
        {
          "cases": {
            "@keywords": "keyword",
            "@typeKeywords": "type",
            "@default": "identifier"
          }
        }
      ],
      [
        "@symbols",
        {
          "cases": {
            "@operators": "operator",
            "@default": ""
          }
        }
      ]
    ],
    "whitespace": [
      [
        "[ \\t\\r\\n]+",
        ""
      ]
    ],
    "comment": [
      [
        "\\*/",
        "comment",
        "@pop"
      ],
      [
        ".",
        "comment"
      ]
    ],
    "string_double": [
      [
        "[^\"\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt\"']",
        "string.escape"
      ],
      [
        "\"",
        "string",
        "@pop"
      ]
    ],
    "string_single": [
      [
        "[^'\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt\"']",
        "string.escape"
      ],
      [
        "'",
        "string",
        "@pop"
      ]
    ],
    "string_backtick": [
      [
        "[^`\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt]",
        "string.escape"
      ],
      [
        "`",
        "string",
        "@pop"
      ]
    ],
    "string_triple": [
      [
        "[^\"]+",
        "string"
      ],
      [
        "\"\"\"",
        "string",
        "@pop"
      ],
      [
        "\"",
        "string"
      ]
    ]
  }
}
