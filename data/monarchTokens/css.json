{
  "language": "css",
  "tokenPostfix": ".css",
  "defaultToken": "invalid",
  "keywords": [
    "and",
    "animation",
    "background",
    "border",
    "bottom",
    "box",
    "calc",
    "clear",
    "clip",
    "color",
    "column",
    "content",
    "counter",
    "cursor",
    "direction",
    "display",
    "empty",
    "filter",
    "flex",
    "float",
    "font",
    "gap",
    "grid",
    "height",
    "hyphens",
    "image",
    "justify",
    "left",
    "letter",
    "line",
    "list",
    "margin",
    "mask",
    "max",
    "min",
    "mix",
    "object",
    "offset",
    "opacity",
    "order",
    "orphans",
    "outline",
    "overflow",
    "padding",
    "page",
    "perspective",
    "place",
    "pointer",
    "position",
    "quotes",
    "resize",
    "right",
    "rotate",
    "row",
    "scale",
    "scroll",
    "shape",
    "tab",
    "table",
    "text",
    "top",
    "transform",
    "transition",
    "translate",
    "unicode",
    "user",
    "vertical",
    "visibility",
    "white",
    "widows",
    "width",
    "will",
    "word",
    "writing",
    "z-index",
    "align-content",
    "align-items",
    "align-self",
    "aspect-ratio"
  ],
  "typeKeywords": [
    "px",
    "em",
    "rem",
    "vh",
    "vw",
    "vmin",
    "vmax",
    "ch",
    "ex",
    "cm",
    "mm",
    "in",
    "pt",
    "pc",
    "deg",
    "rad",
    "grad",
    "turn",
    "ms",
    "s",
    "Hz",
    "kHz",
    "dpi",
    "dpcm",
    "dppx",
    "fr",
    "auto",
    "inherit",
    "initial",
    "unset",
    "revert",
    "none",
    "normal",
    "bold",
    "italic",
    "hidden",
    "visible",
    "block",
    "inline",
    "flex",
    "grid",
    "absolute",
    "relative",
    "fixed",
    "sticky",
    "static",
    "transparent",
    "currentColor"
  ],
  "operators": [
    "+",
    "-",
    "*",
    "/",
    "=",
    "!",
    "<",
    ">",
    "&",
    "|",
    "^",
    "~",
    "%",
    "==",
    "!=",
    "<=",
    ">=",
    "&&",
    "||",
    "++",
    "--",
    "+=",
    "-=",
    "*=",
    "/=",
    "<<",
    ">>",
    "??",
    "?.",
    "=>"
  ],
  "symbols": "[=><!~?:&|+\\-*/^%]+",
  "escapes": "\\\\(?:[abfnrtv\\\\\"'`]|x[0-9a-fA-F]{1,4}|u[0-9a-fA-F]{4}|U[0-9a-fA-F]{8})",
  "digits": "\\d+(_+\\d+)*",
  "brackets": [
    {
      "open": "{",
      "close": "}",
      "token": "delimiter.curly"
    },
    {
      "open": "[",
      "close": "]",
      "token": "delimiter.square"
    },
    {
      "open": "(",
      "close": ")",
      "token": "delimiter.parenthesis"
    }
  ],
  "tokenizer": {
    "root": [
      [
        "[ \\t\\r\\n]+",
        "",
        "@whitespace"
      ],
      [
        "[{}()\\[\\]]",
        "delimiter.bracket"
      ],
      [
        "/\\*",
        "comment",
        "@comment"
      ],
      [
        "\"",
        "string",
        "@string_double"
      ],
      [
        "'",
        "string",
        "@string_single"
      ],
      [
        "0[xX][0-9a-fA-F]+",
        "number.hex"
      ],
      [
        "0[oO]?[0-7]+",
        "number.octal"
      ],
      [
        "0[bB][01]+",
        "number.binary"
      ],
      [
        "\\d+\\.\\d*([eE][+-]?\\d+)?",
        "number.float"
      ],
      [
        "\\d+",
        "number"
      ],
      [
        "[a-zA-Z_$][\\w$]*",
        {
          "cases": {
            "@keywords": "keyword",
            "@typeKeywords": "type",
            "@default": "identifier"
          }
        }
      ],
      [
        "@symbols",
        {
          "cases": {
            "@operators": "operator",
            "@default": ""
          }
        }
      ]
    ],
    "whitespace": [
      [
        "[ \\t\\r\\n]+",
        ""
      ]
    ],
    "comment": [
      [
        "\\*/",
        "comment",
        "@pop"
      ],
      [
        ".",
        "comment"
      ]
    ],
    "string_double": [
      [
        "[^\"\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt\"']",
        "string.escape"
      ],
      [
        "\"",
        "string",
        "@pop"
      ]
    ],
    "string_single": [
      [
        "[^'\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt\"']",
        "string.escape"
      ],
      [
        "'",
        "string",
        "@pop"
      ]
    ],
    "string_backtick": [
      [
        "[^`\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt]",
        "string.escape"
      ],
      [
        "`",
        "string",
        "@pop"
      ]
    ],
    "string_triple": [
      [
        "[^\"]+",
        "string"
      ],
      [
        "\"\"\"",
        "string",
        "@pop"
      ],
      [
        "\"",
        "string"
      ]
    ]
  }
}
