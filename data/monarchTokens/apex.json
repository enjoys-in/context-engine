{
  "language": "apex",
  "tokenPostfix": ".apex",
  "defaultToken": "invalid",
  "keywords": [
    "abstract",
    "after",
    "and",
    "before",
    "break",
    "bulk",
    "by",
    "case",
    "cast",
    "catch",
    "class",
    "continue",
    "default",
    "delete",
    "do",
    "else",
    "enum",
    "extends",
    "false",
    "final",
    "finally",
    "for",
    "from",
    "future",
    "get",
    "global",
    "having",
    "if",
    "implements",
    "import",
    "in",
    "inner",
    "insert",
    "instanceof",
    "interface",
    "into",
    "join",
    "last_90_days",
    "last_month",
    "last_n_days",
    "last_week",
    "limit",
    "list",
    "long",
    "map",
    "merge",
    "new",
    "next_90_days",
    "next_month",
    "next_n_days",
    "next_week",
    "not",
    "null",
    "nulls",
    "on",
    "or",
    "outer",
    "override",
    "package",
    "private",
    "protected",
    "public",
    "return",
    "rollback",
    "save",
    "scope",
    "search",
    "select",
    "set",
    "sharing",
    "size",
    "sort",
    "static",
    "super",
    "switch",
    "system",
    "testmethod",
    "then",
    "this",
    "throw",
    "today",
    "tolabel",
    "tomorrow",
    "transient",
    "trigger",
    "true",
    "try",
    "type",
    "undelete",
    "update",
    "upsert",
    "using",
    "virtual",
    "void",
    "webservice",
    "when",
    "where",
    "while",
    "with",
    "without",
    "yesterday"
  ],
  "typeKeywords": [
    "int",
    "float",
    "double",
    "string",
    "bool",
    "boolean",
    "void",
    "null",
    "char",
    "byte",
    "long",
    "short",
    "array",
    "list",
    "map",
    "set",
    "object",
    "class",
    "type",
    "function",
    "module",
    "tuple",
    "record",
    "enum",
    "struct",
    "interface",
    "trait",
    "any",
    "never",
    "unknown",
    "optional",
    "result",
    "error",
    "promise",
    "future",
    "stream",
    "iterator",
    "callable",
    "undefined",
    "none",
    "unit",
    "variant"
  ],
  "operators": [
    "+",
    "-",
    "*",
    "/",
    "=",
    "!",
    "<",
    ">",
    "&",
    "|",
    "^",
    "~",
    "%",
    "==",
    "!=",
    "<=",
    ">=",
    "&&",
    "||",
    "++",
    "--",
    "+=",
    "-=",
    "*=",
    "/=",
    "<<",
    ">>",
    "??",
    "?.",
    "=>"
  ],
  "symbols": "[-=><!~?:&|+\\-*\\/\\^%]+",
  "escapes": "\\\\(?:[abfnrtv\\\\\"'\\\\]|x[0-9A-Fa-f]{1,4}|u[0-9A-Fa-f]{4}|U[0-9A-Fa-f]{8})",
  "digits": "\\d*\\.?\\d+([eE][\\-+]?\\d+)?",
  "brackets": [
    {
      "open": "{",
      "close": "}",
      "token": "delimiter.curly"
    },
    {
      "open": "[",
      "close": "]",
      "token": "delimiter.square"
    },
    {
      "open": "(",
      "close": ")",
      "token": "delimiter.parenthesis"
    }
  ],
  "tokenizer": {
    "root": [
      [
        "[ \\t\\r\\n]+",
        "",
        "@whitespace"
      ],
      [
        "[{}()\\[\\]]",
        "delimiter.bracket"
      ],
      [
        "/\\*",
        "comment",
        "@comment"
      ],
      [
        "//.*$",
        "comment"
      ],
      [
        "\"",
        "string",
        "@string_double"
      ],
      [
        "'",
        "string",
        "@string_single"
      ],
      [
        "0[xX][0-9a-fA-F]+",
        "number.hex"
      ],
      [
        "0[oO]?[0-7]+",
        "number.octal"
      ],
      [
        "0[bB][01]+",
        "number.binary"
      ],
      [
        "\\d+\\.\\d*([eE][+-]?\\d+)?",
        "number.float"
      ],
      [
        "\\d+",
        "number"
      ],
      [
        "[a-zA-Z_$][\\w$]*",
        {
          "cases": {
            "@keywords": "keyword",
            "@typeKeywords": "type",
            "@default": "identifier"
          }
        }
      ],
      [
        "@symbols",
        {
          "cases": {
            "@operators": "operator",
            "@default": ""
          }
        }
      ]
    ],
    "whitespace": [
      [
        "[ \\t\\r\\n]+",
        ""
      ]
    ],
    "comment": [
      [
        "\\*/",
        "comment",
        "@pop"
      ],
      [
        ".",
        "comment"
      ]
    ],
    "string_double": [
      [
        "[^\"\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt\"']",
        "string.escape"
      ],
      [
        "\"",
        "string",
        "@pop"
      ]
    ],
    "string_single": [
      [
        "[^'\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt\"']",
        "string.escape"
      ],
      [
        "'",
        "string",
        "@pop"
      ]
    ],
    "string_backtick": [
      [
        "[^`\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt]",
        "string.escape"
      ],
      [
        "`",
        "string",
        "@pop"
      ]
    ],
    "string_triple": [
      [
        "[^\"]+",
        "string"
      ],
      [
        "\"\"\"",
        "string",
        "@pop"
      ],
      [
        "\"",
        "string"
      ]
    ]
  }
}
