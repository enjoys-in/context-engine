{
  "language": "html",
  "tokenPostfix": ".html",
  "defaultToken": "invalid",
  "keywords": [
    "a",
    "abbr",
    "address",
    "area",
    "article",
    "aside",
    "audio",
    "b",
    "base",
    "bdi",
    "bdo",
    "blockquote",
    "body",
    "br",
    "button",
    "canvas",
    "caption",
    "cite",
    "code",
    "col",
    "colgroup",
    "data",
    "datalist",
    "dd",
    "del",
    "details",
    "dfn",
    "dialog",
    "div",
    "dl",
    "dt",
    "em",
    "embed",
    "fieldset",
    "figcaption",
    "figure",
    "footer",
    "form",
    "h1",
    "h2",
    "h3",
    "h4",
    "h5",
    "h6",
    "head",
    "header",
    "hgroup",
    "hr",
    "html",
    "i",
    "iframe",
    "img",
    "input",
    "ins",
    "kbd",
    "label",
    "legend",
    "li",
    "link",
    "main",
    "map",
    "mark",
    "meta",
    "meter",
    "nav",
    "noscript",
    "object",
    "ol",
    "optgroup",
    "option",
    "output",
    "p",
    "picture",
    "pre",
    "progress",
    "q",
    "rp",
    "rt",
    "ruby",
    "s",
    "samp",
    "script",
    "section",
    "select",
    "slot",
    "small",
    "source",
    "span",
    "strong",
    "style",
    "sub",
    "summary",
    "sup",
    "table",
    "tbody",
    "td",
    "template",
    "textarea",
    "tfoot",
    "th",
    "thead",
    "time",
    "title",
    "tr",
    "track",
    "u",
    "ul",
    "var",
    "video",
    "wbr"
  ],
  "typeKeywords": [
    "CDATA",
    "DOCTYPE",
    "ELEMENT",
    "ATTLIST",
    "ENTITY",
    "NOTATION",
    "SYSTEM",
    "PUBLIC",
    "NDATA",
    "REQUIRED",
    "IMPLIED",
    "FIXED",
    "PCDATA",
    "EMPTY",
    "ANY"
  ],
  "operators": [
    "+",
    "-",
    "*",
    "/",
    "=",
    "!",
    "<",
    ">",
    "&",
    "|",
    "^",
    "~",
    "%",
    "==",
    "!=",
    "<=",
    ">=",
    "&&",
    "||",
    "++",
    "--",
    "+=",
    "-=",
    "*=",
    "/=",
    "<<",
    ">>",
    "??",
    "?.",
    "=>"
  ],
  "symbols": "[=><!~?:&|+\\-*/^%]+",
  "escapes": "\\\\(?:[abfnrtv\\\\\"'`]|x[0-9a-fA-F]{1,4}|u[0-9a-fA-F]{4}|U[0-9a-fA-F]{8})",
  "digits": "\\d+(_+\\d+)*",
  "brackets": [
    {
      "open": "<!--",
      "close": "-->",
      "token": "comment"
    },
    {
      "open": "<",
      "close": ">",
      "token": "delimiter.angle"
    }
  ],
  "tokenizer": {
    "root": [
      [
        "<!DOCTYPE",
        "metatag",
        "@doctype"
      ],
      [
        "<!--",
        "comment",
        "@comment"
      ],
      [
        "(<)(script)",
        [
          "delimiter",
          {
            "token": "tag",
            "next": "@script"
          }
        ]
      ],
      [
        "(<)(style)",
        [
          "delimiter",
          {
            "token": "tag",
            "next": "@style"
          }
        ]
      ],
      [
        "(<)(\\/?)(\\w+)",
        [
          "delimiter",
          "delimiter",
          {
            "token": "tag",
            "next": "@otherTag"
          }
        ]
      ],
      [
        "[^<]+",
        ""
      ]
    ],
    "doctype": [
      [
        ">",
        "metatag",
        "@pop"
      ],
      [
        ".",
        "metatag"
      ]
    ],
    "comment": [
      [
        "-->",
        "comment",
        "@pop"
      ],
      [
        ".",
        "comment"
      ]
    ],
    "otherTag": [
      [
        "\\/?>",
        "delimiter",
        "@pop"
      ],
      [
        "\"[^\"]*\"",
        "attribute.value"
      ],
      [
        "'[^']*'",
        "attribute.value"
      ],
      [
        "=",
        "delimiter"
      ],
      [
        "[\\w-]+",
        "attribute.name"
      ],
      [
        "[ \\t\\r\\n]+",
        "white"
      ]
    ],
    "script": [
      [
        ">",
        "delimiter",
        "@scriptBody"
      ],
      [
        "\"[^\"]*\"",
        "attribute.value"
      ],
      [
        "'[^']*'",
        "attribute.value"
      ],
      [
        "=",
        "delimiter"
      ],
      [
        "[\\w-]+",
        "attribute.name"
      ]
    ],
    "scriptBody": [
      [
        "<\\/script\\s*>",
        {
          "token": "@rematch",
          "next": "@pop"
        }
      ],
      [
        ".",
        {
          "token": "",
          "next": "@pop"
        }
      ]
    ],
    "style": [
      [
        ">",
        "delimiter",
        "@styleBody"
      ],
      [
        "\"[^\"]*\"",
        "attribute.value"
      ],
      [
        "'[^']*'",
        "attribute.value"
      ],
      [
        "=",
        "delimiter"
      ],
      [
        "[\\w-]+",
        "attribute.name"
      ]
    ],
    "styleBody": [
      [
        "<\\/style\\s*>",
        {
          "token": "@rematch",
          "next": "@pop"
        }
      ],
      [
        ".",
        {
          "token": "",
          "next": "@pop"
        }
      ]
    ]
  }
}
