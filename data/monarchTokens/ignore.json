{
  "language": "ignore",
  "displayName": "Ignore Files",
  "tokenTypes": [
    "keyword",
    "string",
    "comment",
    "number",
    "operator",
    "identifier",
    "type",
    "delimiter",
    "variable",
    "function"
  ],
  "rules": {
    "root": [
      {
        "regex": "\\.gitignore",
        "action": {
          "token": "keyword"
        }
      },
      {
        "regex": "\\.dockerignore",
        "action": {
          "token": "keyword"
        }
      },
      {
        "regex": "\\.npmignore",
        "action": {
          "token": "keyword"
        }
      },
      {
        "regex": "#",
        "action": {
          "token": "keyword"
        }
      },
      {
        "regex": "!",
        "action": {
          "token": "keyword"
        }
      },
      {
        "regex": "\\*",
        "action": {
          "token": "keyword"
        }
      },
      {
        "regex": "\\*\\*",
        "action": {
          "token": "keyword"
        }
      },
      {
        "regex": "\\?",
        "action": {
          "token": "keyword"
        }
      },
      {
        "regex": "\"([^\"\\\\]|\\\\.)*\"",
        "action": {
          "token": "string"
        }
      },
      {
        "regex": "'([^'\\\\]|\\\\.)*'",
        "action": {
          "token": "string"
        }
      },
      {
        "regex": "//.*$",
        "action": {
          "token": "comment"
        }
      },
      {
        "regex": "/\\*",
        "action": {
          "token": "comment",
          "next": "@comment"
        }
      },
      {
        "regex": "\\d+(\\.\\d+)?",
        "action": {
          "token": "number"
        }
      },
      {
        "regex": "[{}()\\[\\]]",
        "action": {
          "token": "delimiter"
        }
      },
      {
        "regex": "[a-zA-Z_]\\w*",
        "action": {
          "token": "identifier"
        }
      }
    ],
    "comment": [
      {
        "regex": "\\*/",
        "action": {
          "token": "comment",
          "next": "@pop"
        }
      },
      {
        "regex": ".",
        "action": {
          "token": "comment"
        }
      }
    ]
  }
}
