{
  "language": "pascal",
  "tokenPostfix": ".pascal",
  "defaultToken": "invalid",
  "keywords": [
    "program",
    "unit",
    "uses",
    "interface",
    "implementation",
    "begin",
    "end",
    "var",
    "const",
    "type",
    "array",
    "record",
    "set",
    "file",
    "class",
    "object",
    "procedure",
    "function",
    "constructor",
    "destructor",
    "property",
    "inherited",
    "override",
    "virtual",
    "abstract",
    "dynamic",
    "reintroduce",
    "overload",
    "forward",
    "external",
    "inline",
    "operator",
    "label",
    "goto",
    "if",
    "then",
    "else",
    "case",
    "of",
    "for",
    "to",
    "downto",
    "do",
    "while",
    "repeat",
    "until",
    "with",
    "try",
    "except",
    "finally",
    "raise",
    "on",
    "div",
    "mod",
    "and",
    "or",
    "xor",
    "not",
    "shl",
    "shr",
    "in",
    "is",
    "as",
    "nil",
    "true",
    "false",
    "self",
    "result"
  ],
  "typeKeywords": [
    "int",
    "float",
    "double",
    "string",
    "bool",
    "boolean",
    "void",
    "null",
    "char",
    "byte",
    "long",
    "short",
    "array",
    "list",
    "map",
    "set",
    "object",
    "class",
    "type",
    "function",
    "module",
    "tuple",
    "record",
    "enum",
    "struct",
    "interface",
    "trait",
    "any",
    "never",
    "unknown",
    "optional",
    "result",
    "error",
    "promise",
    "future",
    "stream",
    "iterator",
    "callable",
    "undefined",
    "none",
    "unit",
    "variant"
  ],
  "operators": [
    "+",
    "-",
    "*",
    "/",
    "=",
    "!",
    "<",
    ">",
    "&",
    "|",
    "^",
    "~",
    "%",
    "==",
    "!=",
    "<=",
    ">=",
    "&&",
    "||",
    "++",
    "--",
    "+=",
    "-=",
    "*=",
    "/=",
    "<<",
    ">>",
    "??",
    "?.",
    "=>"
  ],
  "symbols": "[-=><!~?:&|+\\-*\\/\\^%]+",
  "escapes": "\\\\(?:[abfnrtv\\\\\"'\\\\]|x[0-9A-Fa-f]{1,4}|u[0-9A-Fa-f]{4}|U[0-9A-Fa-f]{8})",
  "digits": "\\d*\\.?\\d+([eE][\\-+]?\\d+)?",
  "brackets": [
    {
      "open": "{",
      "close": "}",
      "token": "delimiter.curly"
    },
    {
      "open": "[",
      "close": "]",
      "token": "delimiter.square"
    },
    {
      "open": "(",
      "close": ")",
      "token": "delimiter.parenthesis"
    }
  ],
  "tokenizer": {
    "root": [
      [
        "[ \\t\\r\\n]+",
        "",
        "@whitespace"
      ],
      [
        "[{}()\\[\\]]",
        "delimiter.bracket"
      ],
      [
        "/\\*",
        "comment",
        "@comment"
      ],
      [
        "//.*$",
        "comment"
      ],
      [
        "\"",
        "string",
        "@string_double"
      ],
      [
        "'",
        "string",
        "@string_single"
      ],
      [
        "0[xX][0-9a-fA-F]+",
        "number.hex"
      ],
      [
        "0[oO]?[0-7]+",
        "number.octal"
      ],
      [
        "0[bB][01]+",
        "number.binary"
      ],
      [
        "\\d+\\.\\d*([eE][+-]?\\d+)?",
        "number.float"
      ],
      [
        "\\d+",
        "number"
      ],
      [
        "[a-zA-Z_$][\\w$]*",
        {
          "cases": {
            "@keywords": "keyword",
            "@typeKeywords": "type",
            "@default": "identifier"
          }
        }
      ],
      [
        "@symbols",
        {
          "cases": {
            "@operators": "operator",
            "@default": ""
          }
        }
      ]
    ],
    "whitespace": [
      [
        "[ \\t\\r\\n]+",
        ""
      ]
    ],
    "comment": [
      [
        "\\*/",
        "comment",
        "@pop"
      ],
      [
        ".",
        "comment"
      ]
    ],
    "string_double": [
      [
        "[^\"\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt\"']",
        "string.escape"
      ],
      [
        "\"",
        "string",
        "@pop"
      ]
    ],
    "string_single": [
      [
        "[^'\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt\"']",
        "string.escape"
      ],
      [
        "'",
        "string",
        "@pop"
      ]
    ],
    "string_backtick": [
      [
        "[^`\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt]",
        "string.escape"
      ],
      [
        "`",
        "string",
        "@pop"
      ]
    ],
    "string_triple": [
      [
        "[^\"]+",
        "string"
      ],
      [
        "\"\"\"",
        "string",
        "@pop"
      ],
      [
        "\"",
        "string"
      ]
    ]
  }
}
