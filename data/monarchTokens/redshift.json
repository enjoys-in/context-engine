{
  "language": "redshift",
  "tokenPostfix": ".redshift",
  "defaultToken": "invalid",
  "keywords": [
    "SELECT",
    "FROM",
    "WHERE",
    "AND",
    "OR",
    "NOT",
    "INSERT",
    "INTO",
    "VALUES",
    "UPDATE",
    "SET",
    "DELETE",
    "CREATE",
    "ALTER",
    "DROP",
    "TABLE",
    "INDEX",
    "VIEW",
    "DATABASE",
    "SCHEMA",
    "GRANT",
    "REVOKE",
    "JOIN",
    "INNER",
    "LEFT",
    "RIGHT",
    "OUTER",
    "FULL",
    "CROSS",
    "ON",
    "AS",
    "IS",
    "NULL",
    "IN",
    "BETWEEN",
    "LIKE",
    "EXISTS",
    "HAVING",
    "GROUP",
    "BY",
    "ORDER",
    "ASC",
    "DESC",
    "LIMIT",
    "OFFSET",
    "UNION",
    "ALL",
    "DISTINCT",
    "CASE",
    "WHEN",
    "THEN",
    "ELSE",
    "END",
    "IF",
    "BEGIN",
    "COMMIT",
    "ROLLBACK",
    "SAVEPOINT",
    "TRIGGER",
    "PROCEDURE",
    "FUNCTION",
    "DECLARE",
    "CURSOR",
    "FETCH",
    "OPEN",
    "CLOSE",
    "EXEC",
    "EXECUTE",
    "WITH",
    "RECURSIVE",
    "MERGE",
    "USING",
    "MATCHED",
    "PARTITION",
    "OVER",
    "WINDOW",
    "ROW_NUMBER",
    "RANK",
    "DENSE_RANK",
    "NTILE",
    "LAG",
    "LEAD",
    "FIRST_VALUE",
    "LAST_VALUE",
    "PIVOT",
    "UNPIVOT",
    "TOP",
    "RETURNING",
    "CONFLICT",
    "LATERAL",
    "TABLESAMPLE",
    "EXPLAIN",
    "ANALYZE",
    "VACUUM",
    "TRUNCATE",
    "COMMENT",
    "COPY",
    "IMPORT",
    "EXPORT",
    "TEMPORARY",
    "TEMP",
    "REPLACE",
    "IGNORE",
    "CASCADE",
    "RESTRICT",
    "FOREIGN",
    "PRIMARY",
    "KEY",
    "REFERENCES",
    "UNIQUE",
    "CHECK",
    "CONSTRAINT",
    "DEFAULT",
    "AUTO_INCREMENT",
    "SERIAL",
    "IDENTITY",
    "SEQUENCE",
    "NEXTVAL",
    "CURRVAL",
    "GENERATED",
    "ALWAYS",
    "STORED",
    "VIRTUAL",
    "MATERIALIZED",
    "ILIKE"
  ],
  "typeKeywords": [
    "BIGINT",
    "BIT",
    "DECIMAL",
    "INT",
    "MONEY",
    "NUMERIC",
    "SMALLINT",
    "SMALLMONEY",
    "TINYINT",
    "FLOAT",
    "REAL",
    "DATE",
    "DATETIME",
    "DATETIME2",
    "DATETIMEOFFSET",
    "SMALLDATETIME",
    "TIME",
    "CHAR",
    "NCHAR",
    "TEXT",
    "NTEXT",
    "VARCHAR",
    "NVARCHAR",
    "BINARY",
    "IMAGE",
    "VARBINARY",
    "CURSOR",
    "HIERARCHYID",
    "SQL_VARIANT",
    "TABLE",
    "TIMESTAMP",
    "UNIQUEIDENTIFIER",
    "XML",
    "GEOGRAPHY",
    "GEOMETRY",
    "ROWVERSION",
    "BOOLEAN",
    "JSON",
    "JSONB",
    "UUID",
    "SERIAL",
    "BIGSERIAL",
    "INTERVAL",
    "ARRAY",
    "BYTEA",
    "INET",
    "CIDR",
    "MACADDR",
    "POINT",
    "LINE",
    "POLYGON",
    "CIRCLE",
    "TSQUERY",
    "TSVECTOR"
  ],
  "operators": [
    "+",
    "-",
    "*",
    "/",
    "=",
    "!",
    "<",
    ">",
    "&",
    "|",
    "^",
    "~",
    "%",
    "==",
    "!=",
    "<=",
    ">=",
    "&&",
    "||",
    "++",
    "--",
    "+=",
    "-=",
    "*=",
    "/=",
    "<<",
    ">>",
    "??",
    "?.",
    "=>"
  ],
  "symbols": "[-=><!~?:&|+\\-*\\/\\^%@#]+",
  "escapes": "\\\\(?:[abfnrtv\\\\\"'`]|x[0-9a-fA-F]{1,4}|u[0-9a-fA-F]{4}|U[0-9a-fA-F]{8})",
  "digits": "\\d+(_+\\d+)*",
  "brackets": [
    {
      "open": "{",
      "close": "}",
      "token": "delimiter.curly"
    },
    {
      "open": "[",
      "close": "]",
      "token": "delimiter.square"
    },
    {
      "open": "(",
      "close": ")",
      "token": "delimiter.parenthesis"
    }
  ],
  "tokenizer": {
    "root": [
      [
        "[ \\t\\r\\n]+",
        "",
        "@whitespace"
      ],
      [
        "[{}()\\[\\]]",
        "delimiter.bracket"
      ],
      [
        "/\\*",
        "comment",
        "@comment"
      ],
      [
        "--.*$",
        "comment"
      ],
      [
        "\"",
        "string",
        "@string_double"
      ],
      [
        "'",
        "string",
        "@string_single"
      ],
      [
        "0[xX][0-9a-fA-F]+",
        "number.hex"
      ],
      [
        "0[oO]?[0-7]+",
        "number.octal"
      ],
      [
        "0[bB][01]+",
        "number.binary"
      ],
      [
        "\\d+\\.\\d*([eE][+-]?\\d+)?",
        "number.float"
      ],
      [
        "\\d+",
        "number"
      ],
      [
        "[a-zA-Z_$][\\w$]*",
        {
          "cases": {
            "@keywords": "keyword",
            "@typeKeywords": "type",
            "@default": "identifier"
          }
        }
      ],
      [
        "@symbols",
        {
          "cases": {
            "@operators": "operator",
            "@default": ""
          }
        }
      ]
    ],
    "whitespace": [
      [
        "[ \\t\\r\\n]+",
        ""
      ]
    ],
    "comment": [
      [
        "\\*/",
        "comment",
        "@pop"
      ],
      [
        ".",
        "comment"
      ]
    ],
    "string_double": [
      [
        "[^\"\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt\"']",
        "string.escape"
      ],
      [
        "\"",
        "string",
        "@pop"
      ]
    ],
    "string_single": [
      [
        "[^'\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt\"']",
        "string.escape"
      ],
      [
        "'",
        "string",
        "@pop"
      ]
    ],
    "string_backtick": [
      [
        "[^`\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt]",
        "string.escape"
      ],
      [
        "`",
        "string",
        "@pop"
      ]
    ],
    "string_triple": [
      [
        "[^\"]+",
        "string"
      ],
      [
        "\"\"\"",
        "string",
        "@pop"
      ],
      [
        "\"",
        "string"
      ]
    ]
  }
}
