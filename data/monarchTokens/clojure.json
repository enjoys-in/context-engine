{
  "language": "clojure",
  "defaultToken": "invalid",
  "tokenPostfix": ".clj",
  "keywords": [
    "def",
    "defn",
    "defn-",
    "defmacro",
    "defonce",
    "defmulti",
    "defmethod",
    "defprotocol",
    "defrecord",
    "deftype",
    "defstruct",
    "definterface",
    "extend-type",
    "extend-protocol",
    "reify",
    "fn",
    "let",
    "loop",
    "recur",
    "do",
    "if",
    "cond",
    "condp",
    "case",
    "when",
    "when-not",
    "when-let",
    "when-first",
    "when-some",
    "if-let",
    "if-not",
    "if-some",
    "and",
    "or",
    "not",
    "quote",
    "var",
    "try",
    "catch",
    "finally",
    "throw",
    "monitor-enter",
    "monitor-exit",
    "new",
    "set!",
    "ns",
    "in-ns",
    "require",
    "use",
    "import",
    "refer",
    "alias",
    "for",
    "doseq",
    "dotimes",
    "while",
    "lazy-seq",
    "lazy-cat",
    "map",
    "filter",
    "reduce",
    "apply",
    "partial",
    "comp",
    "juxt",
    "identity",
    "constantly",
    "complement",
    "memoize",
    "trampoline",
    "atom",
    "deref",
    "swap!",
    "reset!",
    "compare-and-set!",
    "agent",
    "send",
    "send-off",
    "await",
    "ref",
    "dosync",
    "alter",
    "commute",
    "ensure",
    "binding",
    "with-bindings",
    "future",
    "promise",
    "deliver",
    "pmap",
    "pcalls",
    "pvalues"
  ],
  "typeKeywords": [],
  "operators": [],
  "symbols": "[=><!+\\-*/]+",
  "brackets": [
    {
      "open": "(",
      "close": ")",
      "token": "delimiter.parenthesis"
    },
    {
      "open": "[",
      "close": "]",
      "token": "delimiter.square"
    },
    {
      "open": "{",
      "close": "}",
      "token": "delimiter.curly"
    }
  ],
  "tokenizer": {
    "root": [
      {
        "include": "@whitespace"
      },
      [
        "[()\\[\\]{}]",
        "@brackets"
      ],
      [
        ":[a-zA-Z][\\w-/.*+!?<>=]*",
        "string.symbol"
      ],
      [
        "::[a-zA-Z][\\w-/.*+!?<>=]*",
        "string.symbol.auto"
      ],
      [
        "#\"",
        "regexp",
        "@regexp"
      ],
      [
        "\"",
        "string",
        "@string_double"
      ],
      [
        "\\\\[a-zA-Z]+",
        "string.char"
      ],
      [
        "#'",
        "tag"
      ],
      [
        "@[a-zA-Z_]\\w*",
        "annotation"
      ],
      [
        "[a-zA-Z_][\\w-/.*+!?<>=]*",
        {
          "cases": {
            "@keywords": "keyword",
            "@default": "identifier"
          }
        }
      ],
      [
        "[-+]?0[xX][0-9a-fA-F]+N?",
        "number.hex"
      ],
      [
        "[-+]?0[0-7]+N?",
        "number.octal"
      ],
      [
        "[-+]?\\d+\\.?\\d*([eE][\\-+]?\\d+)?M?",
        "number"
      ],
      [
        "[-+]?\\d+/\\d+",
        "number.fraction"
      ]
    ],
    "whitespace": [
      [
        "[ \\t\\r\\n,]+",
        "white"
      ],
      [
        ";.*$",
        "comment"
      ]
    ],
    "string_double": [
      [
        "[^\\\\\"]+",
        "string"
      ],
      [
        "\\\\.",
        "string.escape"
      ],
      [
        "\"",
        "string",
        "@pop"
      ]
    ],
    "regexp": [
      [
        "[^\\\\\"]+",
        "regexp"
      ],
      [
        "\\\\.",
        "regexp.escape"
      ],
      [
        "\"",
        "regexp",
        "@pop"
      ]
    ]
  }
}
