{
  "language": "clojure",
  "tokenPostfix": ".clj",
  "defaultToken": "invalid",
  "keywords": [
    "def",
    "defn",
    "defn-",
    "defmacro",
    "defonce",
    "defmulti",
    "defmethod",
    "defprotocol",
    "defrecord",
    "deftype",
    "defstruct",
    "definterface",
    "extend-type",
    "extend-protocol",
    "reify",
    "fn",
    "let",
    "loop",
    "recur",
    "do",
    "if",
    "cond",
    "condp",
    "case",
    "when",
    "when-not",
    "when-let",
    "when-first",
    "when-some",
    "if-let",
    "if-not",
    "if-some",
    "and",
    "or",
    "not",
    "quote",
    "var",
    "try",
    "catch",
    "finally",
    "throw",
    "monitor-enter",
    "monitor-exit",
    "new",
    "set!",
    "ns",
    "in-ns",
    "require",
    "use",
    "import",
    "refer",
    "alias",
    "for",
    "doseq",
    "dotimes",
    "while",
    "lazy-seq",
    "lazy-cat",
    "map",
    "filter",
    "reduce",
    "apply",
    "partial",
    "comp",
    "juxt",
    "identity",
    "constantly",
    "complement",
    "memoize",
    "trampoline",
    "atom",
    "deref",
    "swap!",
    "reset!",
    "compare-and-set!",
    "agent",
    "send",
    "send-off",
    "await",
    "ref",
    "dosync",
    "alter",
    "commute",
    "ensure",
    "binding",
    "with-bindings",
    "future",
    "promise",
    "deliver",
    "pmap",
    "pcalls",
    "pvalues"
  ],
  "typeKeywords": [
    "int",
    "float",
    "double",
    "string",
    "bool",
    "boolean",
    "void",
    "null",
    "char",
    "byte",
    "long",
    "short",
    "array",
    "list",
    "map",
    "set",
    "object",
    "class",
    "type",
    "function",
    "module",
    "tuple",
    "record",
    "enum",
    "struct",
    "interface",
    "trait",
    "any",
    "never",
    "unknown",
    "optional",
    "result",
    "error",
    "promise",
    "future",
    "stream",
    "iterator",
    "callable",
    "undefined",
    "none",
    "unit",
    "variant"
  ],
  "operators": [
    "+",
    "-",
    "*",
    "/",
    "=",
    "!",
    "<",
    ">",
    "&",
    "|",
    "^",
    "~",
    "%",
    "==",
    "!=",
    "<=",
    ">=",
    "&&",
    "||",
    "++",
    "--",
    "+=",
    "-=",
    "*=",
    "/=",
    "<<",
    ">>",
    "??",
    "?.",
    "=>"
  ],
  "symbols": "[=><!+\\-*/]+",
  "escapes": "\\\\(?:[abfnrtv\\\\\"'`]|x[0-9a-fA-F]{1,4}|u[0-9a-fA-F]{4}|U[0-9a-fA-F]{8})",
  "digits": "\\d+(_+\\d+)*",
  "brackets": [
    {
      "open": "(",
      "close": ")",
      "token": "delimiter.parenthesis"
    },
    {
      "open": "[",
      "close": "]",
      "token": "delimiter.square"
    },
    {
      "open": "{",
      "close": "}",
      "token": "delimiter.curly"
    }
  ],
  "tokenizer": {
    "root": [
      [
        "[ \\t\\r\\n]+",
        "",
        "@whitespace"
      ],
      [
        "[{}()\\[\\]]",
        "delimiter.bracket"
      ],
      [
        ";.*$",
        "comment"
      ],
      [
        "\"",
        "string",
        "@string_double"
      ],
      [
        "'",
        "string",
        "@string_single"
      ],
      [
        "0[xX][0-9a-fA-F]+",
        "number.hex"
      ],
      [
        "0[oO]?[0-7]+",
        "number.octal"
      ],
      [
        "0[bB][01]+",
        "number.binary"
      ],
      [
        "\\d+\\.\\d*([eE][+-]?\\d+)?",
        "number.float"
      ],
      [
        "\\d+",
        "number"
      ],
      [
        "[a-zA-Z_$][\\w$]*",
        {
          "cases": {
            "@keywords": "keyword",
            "@typeKeywords": "type",
            "@default": "identifier"
          }
        }
      ],
      [
        "@symbols",
        {
          "cases": {
            "@operators": "operator",
            "@default": ""
          }
        }
      ]
    ],
    "whitespace": [
      [
        "[ \\t\\r\\n]+",
        ""
      ]
    ],
    "comment": [
      [
        ";.*$",
        "comment"
      ]
    ],
    "string_double": [
      [
        "[^\"\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt\"']",
        "string.escape"
      ],
      [
        "\"",
        "string",
        "@pop"
      ]
    ],
    "string_single": [
      [
        "[^'\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt\"']",
        "string.escape"
      ],
      [
        "'",
        "string",
        "@pop"
      ]
    ],
    "string_backtick": [
      [
        "[^`\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt]",
        "string.escape"
      ],
      [
        "`",
        "string",
        "@pop"
      ]
    ],
    "string_triple": [
      [
        "[^\"]+",
        "string"
      ],
      [
        "\"\"\"",
        "string",
        "@pop"
      ],
      [
        "\"",
        "string"
      ]
    ]
  }
}
