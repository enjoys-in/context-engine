{
  "language": "sql",
  "defaultToken": "invalid",
  "tokenPostfix": ".sql",
  "ignoreCase": true,
  "keywords": [
    "SELECT",
    "FROM",
    "WHERE",
    "AND",
    "OR",
    "NOT",
    "INSERT",
    "INTO",
    "VALUES",
    "UPDATE",
    "SET",
    "DELETE",
    "CREATE",
    "ALTER",
    "DROP",
    "TABLE",
    "INDEX",
    "VIEW",
    "DATABASE",
    "SCHEMA",
    "GRANT",
    "REVOKE",
    "JOIN",
    "INNER",
    "LEFT",
    "RIGHT",
    "OUTER",
    "FULL",
    "CROSS",
    "ON",
    "AS",
    "IS",
    "NULL",
    "IN",
    "BETWEEN",
    "LIKE",
    "EXISTS",
    "HAVING",
    "GROUP",
    "BY",
    "ORDER",
    "ASC",
    "DESC",
    "LIMIT",
    "OFFSET",
    "UNION",
    "ALL",
    "DISTINCT",
    "CASE",
    "WHEN",
    "THEN",
    "ELSE",
    "END",
    "IF",
    "BEGIN",
    "COMMIT",
    "ROLLBACK",
    "SAVEPOINT",
    "TRIGGER",
    "PROCEDURE",
    "FUNCTION",
    "DECLARE",
    "CURSOR",
    "FETCH",
    "OPEN",
    "CLOSE",
    "EXEC",
    "EXECUTE",
    "WITH",
    "RECURSIVE",
    "MERGE",
    "USING",
    "MATCHED",
    "PARTITION",
    "OVER",
    "WINDOW",
    "ROW_NUMBER",
    "RANK",
    "DENSE_RANK",
    "NTILE",
    "LAG",
    "LEAD",
    "FIRST_VALUE",
    "LAST_VALUE",
    "PIVOT",
    "UNPIVOT",
    "TOP",
    "RETURNING",
    "CONFLICT",
    "LATERAL",
    "TABLESAMPLE",
    "EXPLAIN",
    "ANALYZE",
    "VACUUM",
    "TRUNCATE",
    "COMMENT",
    "COPY",
    "IMPORT",
    "EXPORT",
    "TEMPORARY",
    "TEMP",
    "REPLACE",
    "IGNORE",
    "CASCADE",
    "RESTRICT",
    "FOREIGN",
    "PRIMARY",
    "KEY",
    "REFERENCES",
    "UNIQUE",
    "CHECK",
    "CONSTRAINT",
    "DEFAULT",
    "AUTO_INCREMENT",
    "SERIAL",
    "IDENTITY",
    "SEQUENCE",
    "NEXTVAL",
    "CURRVAL",
    "GENERATED",
    "ALWAYS",
    "STORED",
    "VIRTUAL",
    "MATERIALIZED",
    "ILIKE"
  ],
  "typeKeywords": [
    "INT",
    "INTEGER",
    "BIGINT",
    "SMALLINT",
    "TINYINT",
    "FLOAT",
    "REAL",
    "DOUBLE",
    "DECIMAL",
    "NUMERIC",
    "CHAR",
    "VARCHAR",
    "TEXT",
    "CLOB",
    "BLOB",
    "BINARY",
    "VARBINARY",
    "DATE",
    "TIME",
    "TIMESTAMP",
    "DATETIME",
    "INTERVAL",
    "BOOLEAN",
    "BOOL",
    "JSON",
    "JSONB",
    "XML",
    "UUID",
    "ARRAY",
    "ENUM",
    "SERIAL",
    "BIGSERIAL",
    "MONEY",
    "BYTEA",
    "INET",
    "CIDR",
    "MACADDR",
    "BIT",
    "VARBIT",
    "POINT",
    "LINE",
    "LSEG",
    "BOX",
    "PATH",
    "POLYGON",
    "CIRCLE",
    "TSQUERY",
    "TSVECTOR",
    "HSTORE",
    "GEOGRAPHY",
    "GEOMETRY"
  ],
  "operators": [
    "=",
    "<>",
    "!=",
    ">",
    "<",
    ">=",
    "<=",
    "||",
    "+",
    "-",
    "*",
    "/",
    "^",
    "%",
    "::",
    "->",
    "->>",
    "#>",
    "#>>",
    "@>",
    "<@",
    "?",
    "?&",
    "?|",
    "&&"
  ],
  "symbols": "[-=><!~?:&|+\\-*\\/\\^%@#]+",
  "brackets": [
    {
      "open": "{",
      "close": "}",
      "token": "delimiter.curly"
    },
    {
      "open": "[",
      "close": "]",
      "token": "delimiter.square"
    },
    {
      "open": "(",
      "close": ")",
      "token": "delimiter.parenthesis"
    }
  ],
  "tokenizer": {
    "root": [
      {
        "include": "@whitespace"
      },
      [
        "[{}()\\[\\]]",
        "@brackets"
      ],
      [
        "[a-zA-Z_]\\w*",
        {
          "cases": {
            "@keywords": "keyword",
            "@typeKeywords": "type",
            "@default": "identifier"
          }
        }
      ],
      [
        "\\d+\\.?\\d*",
        "number"
      ],
      [
        "'",
        "string",
        "@string_single"
      ],
      [
        "@symbols",
        {
          "cases": {
            "@operators": "operator",
            "@default": ""
          }
        }
      ],
      [
        "[;,.]",
        "delimiter"
      ]
    ],
    "whitespace": [
      [
        "[ \\t\\r\\n]+",
        "white"
      ],
      [
        "--.*$",
        "comment"
      ],
      [
        "\\/\\*",
        "comment",
        "@comment"
      ]
    ],
    "comment": [
      [
        "[^/]+",
        "comment"
      ],
      [
        "\\*/",
        "comment",
        "@pop"
      ],
      [
        ".",
        "comment"
      ]
    ],
    "string_single": [
      [
        "[^']+",
        "string"
      ],
      [
        "''",
        "string.escape"
      ],
      [
        "'",
        "string",
        "@pop"
      ]
    ]
  }
}
