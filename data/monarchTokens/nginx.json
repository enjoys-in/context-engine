{
  "language": "nginx",
  "tokenPostfix": ".nginx",
  "defaultToken": "invalid",
  "keywords": [
    "server",
    "location",
    "upstream",
    "http",
    "events",
    "worker_processes",
    "worker_connections",
    "include",
    "error_log",
    "access_log",
    "pid",
    "user",
    "daemon",
    "master_process",
    "types",
    "default_type",
    "sendfile",
    "tcp_nopush",
    "tcp_nodelay",
    "keepalive_timeout",
    "gzip",
    "proxy_pass",
    "proxy_set_header",
    "proxy_redirect",
    "proxy_buffering",
    "fastcgi_pass",
    "uwsgi_pass",
    "ssl_certificate",
    "ssl_certificate_key",
    "ssl_protocols",
    "ssl_ciphers",
    "root",
    "index",
    "try_files",
    "rewrite",
    "return",
    "if",
    "set",
    "map",
    "geo",
    "limit_req",
    "limit_conn",
    "add_header",
    "expires",
    "log_format",
    "error_page",
    "deny",
    "allow",
    "auth_basic",
    "listen",
    "server_name",
    "charset",
    "resolver",
    "client_max_body_size"
  ],
  "typeKeywords": [
    "int",
    "float",
    "double",
    "string",
    "bool",
    "boolean",
    "void",
    "null",
    "char",
    "byte",
    "long",
    "short",
    "array",
    "list",
    "map",
    "set",
    "object",
    "class",
    "type",
    "function",
    "module",
    "tuple",
    "record",
    "enum",
    "struct",
    "interface",
    "trait",
    "any",
    "never",
    "unknown",
    "optional",
    "result",
    "error",
    "promise",
    "future",
    "stream",
    "iterator",
    "callable",
    "undefined",
    "none",
    "unit",
    "variant"
  ],
  "operators": [
    "+",
    "-",
    "*",
    "/",
    "=",
    "!",
    "<",
    ">",
    "&",
    "|",
    "^",
    "~",
    "%",
    "==",
    "!=",
    "<=",
    ">=",
    "&&",
    "||",
    "++",
    "--",
    "+=",
    "-=",
    "*=",
    "/=",
    "<<",
    ">>",
    "??",
    "?.",
    "=>"
  ],
  "symbols": "[-=><!~?:&|+\\-*\\/\\^%]+",
  "escapes": "\\\\(?:[abfnrtv\\\\\"'\\\\]|x[0-9A-Fa-f]{1,4}|u[0-9A-Fa-f]{4}|U[0-9A-Fa-f]{8})",
  "digits": "\\d*\\.?\\d+([eE][\\-+]?\\d+)?",
  "brackets": [
    {
      "open": "{",
      "close": "}",
      "token": "delimiter.curly"
    },
    {
      "open": "[",
      "close": "]",
      "token": "delimiter.square"
    },
    {
      "open": "(",
      "close": ")",
      "token": "delimiter.parenthesis"
    }
  ],
  "tokenizer": {
    "root": [
      [
        "[ \\t\\r\\n]+",
        "",
        "@whitespace"
      ],
      [
        "[{}()\\[\\]]",
        "delimiter.bracket"
      ],
      [
        "/\\*",
        "comment",
        "@comment"
      ],
      [
        "//.*$",
        "comment"
      ],
      [
        "\"",
        "string",
        "@string_double"
      ],
      [
        "'",
        "string",
        "@string_single"
      ],
      [
        "0[xX][0-9a-fA-F]+",
        "number.hex"
      ],
      [
        "0[oO]?[0-7]+",
        "number.octal"
      ],
      [
        "0[bB][01]+",
        "number.binary"
      ],
      [
        "\\d+\\.\\d*([eE][+-]?\\d+)?",
        "number.float"
      ],
      [
        "\\d+",
        "number"
      ],
      [
        "[a-zA-Z_$][\\w$]*",
        {
          "cases": {
            "@keywords": "keyword",
            "@typeKeywords": "type",
            "@default": "identifier"
          }
        }
      ],
      [
        "@symbols",
        {
          "cases": {
            "@operators": "operator",
            "@default": ""
          }
        }
      ]
    ],
    "whitespace": [
      [
        "[ \\t\\r\\n]+",
        ""
      ]
    ],
    "comment": [
      [
        "\\*/",
        "comment",
        "@pop"
      ],
      [
        ".",
        "comment"
      ]
    ],
    "string_double": [
      [
        "[^\"\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt\"']",
        "string.escape"
      ],
      [
        "\"",
        "string",
        "@pop"
      ]
    ],
    "string_single": [
      [
        "[^'\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt\"']",
        "string.escape"
      ],
      [
        "'",
        "string",
        "@pop"
      ]
    ],
    "string_backtick": [
      [
        "[^`\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt]",
        "string.escape"
      ],
      [
        "`",
        "string",
        "@pop"
      ]
    ],
    "string_triple": [
      [
        "[^\"]+",
        "string"
      ],
      [
        "\"\"\"",
        "string",
        "@pop"
      ],
      [
        "\"",
        "string"
      ]
    ]
  }
}
