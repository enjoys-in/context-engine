{
  "language": "csharp",
  "tokenPostfix": ".cs",
  "defaultToken": "invalid",
  "keywords": [
    "abstract",
    "as",
    "base",
    "bool",
    "break",
    "byte",
    "case",
    "catch",
    "char",
    "checked",
    "class",
    "const",
    "continue",
    "decimal",
    "default",
    "delegate",
    "do",
    "double",
    "else",
    "enum",
    "event",
    "explicit",
    "extern",
    "false",
    "finally",
    "fixed",
    "float",
    "for",
    "foreach",
    "goto",
    "if",
    "implicit",
    "in",
    "int",
    "interface",
    "internal",
    "is",
    "lock",
    "long",
    "namespace",
    "new",
    "null",
    "object",
    "operator",
    "out",
    "override",
    "params",
    "private",
    "protected",
    "public",
    "readonly",
    "record",
    "ref",
    "return",
    "sbyte",
    "sealed",
    "short",
    "sizeof",
    "stackalloc",
    "static",
    "string",
    "struct",
    "switch",
    "this",
    "throw",
    "true",
    "try",
    "typeof",
    "uint",
    "ulong",
    "unchecked",
    "unsafe",
    "ushort",
    "using",
    "var",
    "virtual",
    "void",
    "volatile",
    "when",
    "while",
    "yield",
    "add",
    "alias",
    "ascending",
    "async",
    "await",
    "by",
    "descending",
    "dynamic",
    "equals",
    "from",
    "get",
    "global",
    "group",
    "init",
    "into",
    "join",
    "let",
    "nameof",
    "not",
    "notnull",
    "on",
    "or",
    "orderby",
    "partial",
    "remove",
    "required",
    "scoped",
    "select",
    "set",
    "unmanaged",
    "value",
    "where",
    "with"
  ],
  "typeKeywords": [
    "bool",
    "byte",
    "sbyte",
    "char",
    "decimal",
    "double",
    "float",
    "int",
    "uint",
    "long",
    "ulong",
    "nint",
    "nuint",
    "object",
    "short",
    "ushort",
    "string",
    "void",
    "dynamic",
    "var",
    "Task",
    "ValueTask",
    "IEnumerable",
    "IEnumerator",
    "ICollection",
    "IList",
    "IDictionary",
    "IDisposable",
    "IAsyncDisposable",
    "IComparable",
    "IEquatable",
    "Func",
    "Action",
    "Predicate",
    "Span",
    "ReadOnlySpan",
    "Memory",
    "ReadOnlyMemory",
    "Nullable",
    "Tuple",
    "ValueTuple",
    "CancellationToken"
  ],
  "operators": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    "&=",
    "|=",
    "^=",
    "<<=",
    ">>=",
    "==",
    "!=",
    ">",
    "<",
    ">=",
    "<=",
    "&&",
    "||",
    "!",
    "??",
    "?.",
    "?",
    "::",
    "++",
    "--",
    "+",
    "-",
    "*",
    "/",
    "%",
    "&",
    "|",
    "^",
    "~",
    "<<",
    ">>",
    "->",
    "is",
    "as",
    ".."
  ],
  "symbols": "[-=><!~?:&|+\\-*\\/\\^%]+",
  "escapes": "\\\\(?:[abfnrtv\\\\\"'\\\\]|x[0-9A-Fa-f]{1,4}|u[0-9A-Fa-f]{4}|U[0-9A-Fa-f]{8})",
  "digits": "\\d*\\.?\\d+([eE][\\-+]?\\d+)?",
  "brackets": [
    {
      "open": "{",
      "close": "}",
      "token": "delimiter.curly"
    },
    {
      "open": "[",
      "close": "]",
      "token": "delimiter.square"
    },
    {
      "open": "(",
      "close": ")",
      "token": "delimiter.parenthesis"
    },
    {
      "open": "<",
      "close": ">",
      "token": "delimiter.angle"
    }
  ],
  "tokenizer": {
    "root": [
      {
        "include": "@whitespace"
      },
      [
        "[{}()\\[\\]]",
        "@brackets"
      ],
      [
        "[a-zA-Z_$][\\w$]*",
        {
          "cases": {
            "@keywords": "keyword",
            "@typeKeywords": "type",
            "@default": "identifier"
          }
        }
      ],
      [
        "@digits",
        "number"
      ],
      [
        "0[xX][0-9a-fA-F]+",
        "number.hex"
      ],
      [
        "0[oO][0-7]+",
        "number.octal"
      ],
      [
        "0[bB][01]+",
        "number.binary"
      ],
      [
        "\"",
        "string",
        "@string_double"
      ],
      [
        "'",
        "string",
        "@string_single"
      ],
      [
        "@symbols",
        {
          "cases": {
            "@operators": "operator",
            "@default": ""
          }
        }
      ],
      [
        "[;,.]",
        "delimiter"
      ],
      [
        "@[A-Za-z_]\\w*",
        "annotation"
      ],
      [
        "\\$\"",
        "string",
        "@string_interpolated"
      ],
      [
        "@\"",
        "string",
        "@string_verbatim"
      ],
      [
        "\\$@\"",
        "string",
        "@string_interpolated_verbatim"
      ]
    ],
    "whitespace": [
      [
        "[ \\t\\r\\n]+",
        "white"
      ],
      [
        "//.*$",
        "comment"
      ],
      [
        "/\\*",
        "comment",
        "@comment"
      ]
    ],
    "comment": [
      [
        "[^/]+",
        "comment"
      ],
      [
        "\\*/",
        "comment",
        "@pop"
      ],
      [
        ".",
        "comment"
      ]
    ],
    "string_double": [
      [
        "[^\\\\\"]+",
        "string"
      ],
      [
        "@escapes",
        "string.escape"
      ],
      [
        "\"",
        "string",
        "@pop"
      ]
    ],
    "string_single": [
      [
        "[^\\\\']+",
        "string"
      ],
      [
        "@escapes",
        "string.escape"
      ],
      [
        "'",
        "string",
        "@pop"
      ]
    ],
    "string_verbatim": [
      [
        "[^\"]+",
        "string"
      ],
      [
        "\"\"",
        "string.escape"
      ],
      [
        "\"",
        "string",
        "@pop"
      ]
    ],
    "string_interpolated": [
      [
        "\\{\\{",
        "string.escape"
      ],
      [
        "\\{",
        {
          "token": "delimiter.bracket",
          "next": "@bracketCounting"
        }
      ],
      [
        "[^\\\\\"{]+",
        "string"
      ],
      [
        "@escapes",
        "string.escape"
      ],
      [
        "\"",
        "string",
        "@pop"
      ]
    ],
    "string_interpolated_verbatim": [
      [
        "\\{\\{",
        "string.escape"
      ],
      [
        "\\{",
        {
          "token": "delimiter.bracket",
          "next": "@bracketCounting"
        }
      ],
      [
        "[^\"{]+",
        "string"
      ],
      [
        "\"\"",
        "string.escape"
      ],
      [
        "\"",
        "string",
        "@pop"
      ]
    ],
    "bracketCounting": [
      [
        "\\{",
        "delimiter.bracket",
        "@bracketCounting"
      ],
      [
        "\\}",
        "delimiter.bracket",
        "@pop"
      ],
      {
        "include": "root"
      }
    ]
  }
}
