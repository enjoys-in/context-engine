{
  "language": "systemverilog",
  "tokenPostfix": ".systemverilog",
  "defaultToken": "invalid",
  "keywords": [
    "module",
    "endmodule",
    "class",
    "endclass",
    "function",
    "endfunction",
    "task",
    "endtask",
    "interface",
    "endinterface",
    "package",
    "endpackage",
    "program",
    "endprogram",
    "generate",
    "endgenerate",
    "begin",
    "end",
    "if",
    "else",
    "for",
    "while",
    "do",
    "repeat",
    "forever",
    "case",
    "casex",
    "casez",
    "endcase",
    "default",
    "return",
    "break",
    "continue",
    "fork",
    "join",
    "join_any",
    "join_none",
    "wait",
    "disable",
    "input",
    "output",
    "inout",
    "reg",
    "wire",
    "logic",
    "bit",
    "byte",
    "shortint",
    "int",
    "longint",
    "integer",
    "real",
    "realtime",
    "time",
    "string",
    "event",
    "genvar",
    "parameter",
    "localparam",
    "typedef",
    "enum",
    "struct",
    "union",
    "packed",
    "signed",
    "unsigned",
    "void",
    "const",
    "static",
    "automatic",
    "virtual",
    "extends",
    "implements",
    "import",
    "export",
    "extern",
    "chandle",
    "constraint",
    "covergroup",
    "coverpoint",
    "cross",
    "property",
    "sequence",
    "always",
    "always_ff",
    "always_comb",
    "always_latch",
    "initial",
    "final",
    "assign",
    "posedge",
    "negedge",
    "edge",
    "clocking",
    "endclocking",
    "assert",
    "assume",
    "cover",
    "new",
    "null",
    "this",
    "super",
    "rand",
    "randc",
    "with",
    "inside",
    "dist",
    "unique",
    "priority",
    "tagged"
  ],
  "typeKeywords": [
    "int",
    "float",
    "double",
    "string",
    "bool",
    "boolean",
    "void",
    "null",
    "char",
    "byte",
    "long",
    "short",
    "array",
    "list",
    "map",
    "set",
    "object",
    "class",
    "type",
    "function",
    "module",
    "tuple",
    "record",
    "enum",
    "struct",
    "interface",
    "trait",
    "any",
    "never",
    "unknown",
    "optional",
    "result",
    "error",
    "promise",
    "future",
    "stream",
    "iterator",
    "callable",
    "undefined",
    "none",
    "unit",
    "variant"
  ],
  "operators": [
    "+",
    "-",
    "*",
    "/",
    "=",
    "!",
    "<",
    ">",
    "&",
    "|",
    "^",
    "~",
    "%",
    "==",
    "!=",
    "<=",
    ">=",
    "&&",
    "||",
    "++",
    "--",
    "+=",
    "-=",
    "*=",
    "/=",
    "<<",
    ">>",
    "??",
    "?.",
    "=>"
  ],
  "symbols": "[-=><!~?:&|+\\-*\\/\\^%]+",
  "escapes": "\\\\(?:[abfnrtv\\\\\"'\\\\]|x[0-9A-Fa-f]{1,4}|u[0-9A-Fa-f]{4}|U[0-9A-Fa-f]{8})",
  "digits": "\\d*\\.?\\d+([eE][\\-+]?\\d+)?",
  "brackets": [
    {
      "open": "{",
      "close": "}",
      "token": "delimiter.curly"
    },
    {
      "open": "[",
      "close": "]",
      "token": "delimiter.square"
    },
    {
      "open": "(",
      "close": ")",
      "token": "delimiter.parenthesis"
    }
  ],
  "tokenizer": {
    "root": [
      [
        "[ \\t\\r\\n]+",
        "",
        "@whitespace"
      ],
      [
        "[{}()\\[\\]]",
        "delimiter.bracket"
      ],
      [
        "/\\*",
        "comment",
        "@comment"
      ],
      [
        "//.*$",
        "comment"
      ],
      [
        "\"",
        "string",
        "@string_double"
      ],
      [
        "'",
        "string",
        "@string_single"
      ],
      [
        "0[xX][0-9a-fA-F]+",
        "number.hex"
      ],
      [
        "0[oO]?[0-7]+",
        "number.octal"
      ],
      [
        "0[bB][01]+",
        "number.binary"
      ],
      [
        "\\d+\\.\\d*([eE][+-]?\\d+)?",
        "number.float"
      ],
      [
        "\\d+",
        "number"
      ],
      [
        "[a-zA-Z_$][\\w$]*",
        {
          "cases": {
            "@keywords": "keyword",
            "@typeKeywords": "type",
            "@default": "identifier"
          }
        }
      ],
      [
        "@symbols",
        {
          "cases": {
            "@operators": "operator",
            "@default": ""
          }
        }
      ]
    ],
    "whitespace": [
      [
        "[ \\t\\r\\n]+",
        ""
      ]
    ],
    "comment": [
      [
        "\\*/",
        "comment",
        "@pop"
      ],
      [
        ".",
        "comment"
      ]
    ],
    "string_double": [
      [
        "[^\"\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt\"']",
        "string.escape"
      ],
      [
        "\"",
        "string",
        "@pop"
      ]
    ],
    "string_single": [
      [
        "[^'\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt\"']",
        "string.escape"
      ],
      [
        "'",
        "string",
        "@pop"
      ]
    ],
    "string_backtick": [
      [
        "[^`\\\\]+",
        "string"
      ],
      [
        "\\\\[\\\\nrt]",
        "string.escape"
      ],
      [
        "`",
        "string",
        "@pop"
      ]
    ],
    "string_triple": [
      [
        "[^\"]+",
        "string"
      ],
      [
        "\"\"\"",
        "string",
        "@pop"
      ],
      [
        "\"",
        "string"
      ]
    ]
  }
}
