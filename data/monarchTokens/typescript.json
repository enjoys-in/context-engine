{
  "language": "typescript",
  "tokenPostfix": ".ts",
  "defaultToken": "invalid",
  "keywords": [
    "abstract",
    "async",
    "await",
    "boolean",
    "break",
    "byte",
    "case",
    "catch",
    "char",
    "class",
    "const",
    "continue",
    "debugger",
    "default",
    "delete",
    "do",
    "double",
    "else",
    "enum",
    "export",
    "extends",
    "false",
    "final",
    "finally",
    "float",
    "for",
    "function",
    "goto",
    "if",
    "implements",
    "import",
    "in",
    "instanceof",
    "int",
    "interface",
    "let",
    "long",
    "native",
    "new",
    "null",
    "of",
    "package",
    "private",
    "protected",
    "public",
    "return",
    "short",
    "static",
    "super",
    "switch",
    "synchronized",
    "this",
    "throw",
    "throws",
    "transient",
    "true",
    "try",
    "typeof",
    "undefined",
    "var",
    "void",
    "volatile",
    "while",
    "with",
    "yield",
    "abstract",
    "as",
    "asserts",
    "declare",
    "enum",
    "get",
    "global",
    "infer",
    "is",
    "keyof",
    "module",
    "namespace",
    "never",
    "override",
    "readonly",
    "require",
    "satisfies",
    "set",
    "type",
    "unique",
    "unknown"
  ],
  "typeKeywords": [
    "any",
    "boolean",
    "number",
    "object",
    "string",
    "undefined",
    "bigint",
    "symbol",
    "void",
    "never",
    "unknown",
    "null",
    "Array",
    "Promise",
    "Map",
    "Set",
    "WeakMap",
    "WeakSet",
    "RegExp",
    "Date",
    "Error",
    "Function",
    "Iterable",
    "Iterator",
    "Generator",
    "AsyncGenerator",
    "Record",
    "Tuple",
    "ReadonlyArray",
    "Partial",
    "Required",
    "Readonly",
    "Pick",
    "Omit",
    "Exclude",
    "Extract",
    "InstanceType",
    "ReturnType",
    "Parameters",
    "ConstructorParameters",
    "Awaited",
    "NonNullable"
  ],
  "operators": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    "**=",
    "<<=",
    ">>=",
    ">>>=",
    "&=",
    "^=",
    "|=",
    "&&=",
    "||=",
    "??=",
    "==",
    "!=",
    "===",
    "!==",
    ">",
    "<",
    ">=",
    "<=",
    "&&",
    "||",
    "!",
    "??",
    "?.",
    "...",
    "++",
    "--",
    "+",
    "-",
    "*",
    "/",
    "%",
    "**",
    "<<",
    ">>",
    ">>>",
    "&",
    "^",
    "|",
    "~"
  ],
  "symbols": "[-=><!~?:&|+\\-*\\/\\^%]+",
  "escapes": "\\\\(?:[abfnrtv\\\\\"'\\\\]|x[0-9A-Fa-f]{1,4}|u[0-9A-Fa-f]{4}|U[0-9A-Fa-f]{8})",
  "digits": "\\d*\\.?\\d+([eE][\\-+]?\\d+)?",
  "brackets": [
    {
      "open": "{",
      "close": "}",
      "token": "delimiter.curly"
    },
    {
      "open": "[",
      "close": "]",
      "token": "delimiter.square"
    },
    {
      "open": "(",
      "close": ")",
      "token": "delimiter.parenthesis"
    }
  ],
  "tokenizer": {
    "root": [
      {
        "include": "@whitespace"
      },
      [
        "[{}()\\[\\]]",
        "@brackets"
      ],
      [
        "[a-zA-Z_$][\\w$]*",
        {
          "cases": {
            "@keywords": "keyword",
            "@typeKeywords": "type",
            "@default": "identifier"
          }
        }
      ],
      [
        "@digits",
        "number"
      ],
      [
        "0[xX][0-9a-fA-F]+",
        "number.hex"
      ],
      [
        "0[oO][0-7]+",
        "number.octal"
      ],
      [
        "0[bB][01]+",
        "number.binary"
      ],
      [
        "\"",
        "string",
        "@string_double"
      ],
      [
        "'",
        "string",
        "@string_single"
      ],
      [
        "@symbols",
        {
          "cases": {
            "@operators": "operator",
            "@default": ""
          }
        }
      ],
      [
        "[;,.]",
        "delimiter"
      ],
      [
        "`",
        "string",
        "@string_backtick"
      ],
      [
        "\\/(\\\\.|[^\\/])+\\/[gimsuy]*",
        "regexp"
      ]
    ],
    "whitespace": [
      [
        "[ \\t\\r\\n]+",
        "white"
      ],
      [
        "//.*$",
        "comment"
      ],
      [
        "/\\*",
        "comment",
        "@comment"
      ]
    ],
    "comment": [
      [
        "[^/]+",
        "comment"
      ],
      [
        "\\*/",
        "comment",
        "@pop"
      ],
      [
        ".",
        "comment"
      ]
    ],
    "string_double": [
      [
        "[^\\\\\"]+",
        "string"
      ],
      [
        "@escapes",
        "string.escape"
      ],
      [
        "\\\\.",
        "string.escape.invalid"
      ],
      [
        "\"",
        "string",
        "@pop"
      ]
    ],
    "string_single": [
      [
        "[^\\\\']+",
        "string"
      ],
      [
        "@escapes",
        "string.escape"
      ],
      [
        "\\\\.",
        "string.escape.invalid"
      ],
      [
        "'",
        "string",
        "@pop"
      ]
    ],
    "string_backtick": [
      [
        "\\$\\{",
        {
          "token": "delimiter.bracket",
          "next": "@bracketCounting"
        }
      ],
      [
        "[^\\\\`$]+",
        "string"
      ],
      [
        "@escapes",
        "string.escape"
      ],
      [
        "\\\\.",
        "string.escape.invalid"
      ],
      [
        "`",
        "string",
        "@pop"
      ]
    ],
    "bracketCounting": [
      [
        "\\{",
        "delimiter.bracket",
        "@bracketCounting"
      ],
      [
        "\\}",
        "delimiter.bracket",
        "@pop"
      ],
      {
        "include": "root"
      }
    ]
  }
}
