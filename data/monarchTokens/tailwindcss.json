{
  "language": "tailwindcss",
  "defaultToken": "",
  "tokenPostfix": ".tailwind.css",
  "keywords": [],
  "typeKeywords": [],
  "operators": [],
  "symbols": "",
  "brackets": [
    {
      "open": "{",
      "close": "}",
      "token": "delimiter.curly"
    },
    {
      "open": "[",
      "close": "]",
      "token": "delimiter.square"
    },
    {
      "open": "(",
      "close": ")",
      "token": "delimiter.parenthesis"
    }
  ],
  "tokenizer": {
    "root": [
      [
        "[ \\t\\r\\n]+",
        ""
      ],
      [
        "\\/\\*",
        "comment",
        "@comment"
      ],
      [
        "@[\\w-]+",
        "keyword"
      ],
      [
        "#[\\w-]+",
        "tag.id"
      ],
      [
        "\\.[\\w-]+",
        "tag.class"
      ],
      [
        "[\\w-]+",
        "tag"
      ],
      [
        "[{}()\\[\\]]",
        "@brackets"
      ],
      [
        "[:;,]",
        "delimiter"
      ],
      [
        "\"[^\"]*\"",
        "string"
      ],
      [
        "'[^']*'",
        "string"
      ],
      [
        "#[0-9a-fA-F]{3,8}",
        "number.hex"
      ],
      [
        "-?\\d*\\.?\\d+(%|em|rem|px|pt|vh|vw|vmin|vmax|ch|ex|cm|mm|in|pc|deg|rad|grad|turn|s|ms|Hz|kHz|dpi|dpcm|dppx|fr)?",
        "number"
      ],
      [
        "!important",
        "keyword"
      ]
    ],
    "comment": [
      [
        "\\*\\/",
        "comment",
        "@pop"
      ],
      [
        ".",
        "comment"
      ]
    ]
  }
}
