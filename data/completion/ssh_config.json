{
  "language": "ssh_config",
  "completions": [
    {
      "label": "Host block",
      "kind": 28,
      "detail": "SSH host config",
      "documentation": {
        "value": "Configure settings for a specific host."
      },
      "insertText": "Host ${1:myserver}\n    HostName ${2:192.168.1.100}\n    User ${3:root}\n    Port ${4:22}\n    IdentityFile ${5:~/.ssh/id_rsa}",
      "insertTextRules": 4,
      "sortText": "00_host"
    },
    {
      "label": "Host *",
      "kind": 28,
      "detail": "Global defaults",
      "documentation": {
        "value": "Default options for all hosts."
      },
      "insertText": "Host *\n    ServerAliveInterval 60\n    ServerAliveCountMax 3\n    AddKeysToAgent yes",
      "insertTextRules": 4,
      "sortText": "00_host"
    },
    {
      "label": "Host jump pattern",
      "kind": 28,
      "detail": "Jump host pattern",
      "documentation": {
        "value": "Multi-hop SSH config with bastion."
      },
      "insertText": "Host ${1:internal}\n    HostName ${2:10.0.0.5}\n    User ${3:admin}\n    ProxyJump ${4:bastion}",
      "insertTextRules": 4,
      "sortText": "00_host"
    },
    {
      "label": "Host wildcard",
      "kind": 28,
      "detail": "Wildcard host",
      "documentation": {
        "value": "Pattern-matched host group."
      },
      "insertText": "Host ${1:*.example.com}\n    User ${2:deploy}\n    IdentityFile ~/.ssh/${3:deploy_key}",
      "insertTextRules": 4,
      "sortText": "00_host"
    },
    {
