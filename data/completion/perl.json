      "insertText": "open(my $${1:fh}, '<', '${2:file.txt}') or die \"Cannot open: $!\";\nwhile (my $line = <$${1:fh}>) {\n    chomp $line;\n    ${3:print \"$line\\n\";}\n}\nclose($${1:fh});",
