    {
      "label": "always_ff_block",
      "kind": 14,
      "detail": "snippet always_ff",
      "documentation": {
        "value": "Sequential always block"
      },
      "insertText": "always_ff @(posedge ${1:clk} or negedge ${2:rst_n}) begin\n    if (!${2:rst_n}) begin\n        ${3:// reset}\n    end else begin\n        ${0}\n    end\nend",
      "insertTextRules": 4,
      "sortText": "03_snip"
    },
