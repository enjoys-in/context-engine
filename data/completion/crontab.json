{
  "language": "crontab",
  "completions": [
    {
      "label": "cron expression",
      "kind": 15,
      "detail": "Cron schedule",
      "documentation": {
        "value": "A cron expression: minute hour day-of-month month day-of-week command."
      },
      "insertText": "${1:0} ${2:*} ${3:*} ${4:*} ${5:*} ${6:command}",
      "insertTextRules": 4,
      "sortText": "00_expr"
    },
    {
      "label": "every minute",
      "kind": 15,
      "detail": "Every minute",
      "documentation": {
        "value": "Run a command every minute."
      },
      "insertText": "* * * * * ${1:command}",
      "insertTextRules": 4,
      "sortText": "01_everymin"
    },
    {
      "label": "every 5 minutes",
      "kind": 15,
      "detail": "Every 5 minutes",
      "documentation": {
        "value": "Run every 5 minutes."
      },
      "insertText": "*/5 * * * * ${1:command}",
      "insertTextRules": 4,
      "sortText": "01_every5"
    },
    {
      "label": "every hour",
      "kind": 15,
      "detail": "Every hour",
      "documentation": {
        "value": "Run at the start of every hour."
      },
      "insertText": "0 * * * * ${1:command}",
      "insertTextRules": 4,
      "sortText": "01_hourly"
    },
    {
      "label": "daily at midnight",
      "kind": 15,
      "detail": "Daily at midnight",
      "documentation": {
        "value": "Run once daily at midnight."
      },
      "insertText": "0 0 * * * ${1:command}",
      "insertTextRules": 4,
      "sortText": "01_daily"
    },
    {
      "label": "daily at specific time",
      "kind": 15,
      "detail": "Daily at time",
      "documentation": {
        "value": "Run daily at a specific hour and minute."
      },
      "insertText": "${1:30} ${2:2} * * * ${3:command}",
      "insertTextRules": 4,
      "sortText": "01_dailytime"
    },
    {
      "label": "weekly (Sunday)",
      "kind": 15,
      "detail": "Weekly on Sunday",
      "documentation": {
        "value": "Run once a week on Sunday at midnight."
      },
      "insertText": "0 0 * * 0 ${1:command}",
      "insertTextRules": 4,
      "sortText": "02_weekly"
    },
    {
      "label": "monthly",
      "kind": 15,
      "detail": "Monthly (1st)",
      "documentation": {
        "value": "Run on the first of every month."
      },
      "insertText": "0 0 1 * * ${1:command}",
      "insertTextRules": 4,
      "sortText": "02_monthly"
    },
    {
      "label": "weekdays only",
      "kind": 15,
      "detail": "Weekdays at 9 AM",
      "documentation": {
        "value": "Run Monday through Friday at 9 AM."
      },
      "insertText": "0 9 * * 1-5 ${1:command}",
      "insertTextRules": 4,
      "sortText": "02_weekdays"
    },
    {
      "label": "with logging",
      "kind": 15,
      "detail": "Cron with logging",
      "documentation": {
        "value": "Run a command and log output to a file."
      },
      "insertText": "${1:0 2 * * *} ${2:command} >> ${3:/var/log/cronjob.log} 2>&1",
      "insertTextRules": 4,
      "sortText": "03_logging"
    },
    {
      "label": "with lock (flock)",
      "kind": 15,
      "detail": "Prevent overlap",
      "documentation": {
        "value": "Use flock to prevent overlapping runs."
      },
      "insertText": "*/5 * * * * flock -n /tmp/${1:job}.lock ${2:command}",
      "insertTextRules": 4,
      "sortText": "03_flock"
    },
    {
      "label": "MAILTO",
      "kind": 14,
      "detail": "Email recipient",
      "documentation": {
        "value": "Set the email address for cron output."
      },
      "insertText": "MAILTO=${1:admin@example.com}",
      "insertTextRules": 4,
      "sortText": "04_mailto"
    },
    {
      "label": "PATH",
      "kind": 14,
      "detail": "PATH variable",
      "documentation": {
        "value": "Set the PATH for cron commands."
      },
      "insertText": "PATH=/usr/local/bin:/usr/bin:/bin",
      "insertTextRules": 4,
      "sortText": "04_path"
    },
    {
      "label": "SHELL",
      "kind": 14,
      "detail": "Shell variable",
      "documentation": {
        "value": "Set the shell for cron commands."
      },
      "insertText": "SHELL=/bin/bash",
      "insertTextRules": 4,
      "sortText": "04_shell"
    },
    {
      "label": "@reboot",
      "kind": 14,
      "detail": "Run on reboot",
      "documentation": {
        "value": "Run once when the system starts/reboots."
      },
      "insertText": "@reboot ${1:command}",
      "insertTextRules": 4,
      "sortText": "05_reboot"
    },
    {
      "label": "@daily",
      "kind": 14,
      "detail": "Run daily",
      "documentation": {
        "value": "Run once a day (equivalent to 0 0 * * *)."
      },
      "insertText": "@daily ${1:command}",
      "insertTextRules": 4,
      "sortText": "05_daily"
    },
    {
      "label": "@hourly",
      "kind": 14,
      "detail": "Run hourly",
      "documentation": {
        "value": "Run once an hour (equivalent to 0 * * * *)."
      },
      "insertText": "@hourly ${1:command}",
      "insertTextRules": 4,
      "sortText": "05_hourly"
    },
    {
      "label": "@weekly",
      "kind": 14,
      "detail": "Run weekly",
      "documentation": {
        "value": "Run once a week (equivalent to 0 0 * * 0)."
      },
      "insertText": "@weekly ${1:command}",
      "insertTextRules": 4,
      "sortText": "05_weekly"
    },
    {
      "label": "every 10 minutes",
      "kind": 28,
      "detail": "Every 10 min",
      "documentation": {
        "value": "Run every 10 minutes."
      },
      "insertText": "*/10 * * * * ${1:command}",
      "insertTextRules": 4,
      "sortText": "01_sched"
    },
    {
      "label": "every 15 minutes",
      "kind": 28,
      "detail": "Every 15 min",
      "documentation": {
        "value": "Run every 15 minutes."
      },
      "insertText": "*/15 * * * * ${1:command}",
      "insertTextRules": 4,
      "sortText": "01_sched"
    },
    {
      "label": "every 30 minutes",
      "kind": 28,
      "detail": "Every 30 min",
      "documentation": {
        "value": "Run every 30 minutes."
      },
      "insertText": "*/30 * * * * ${1:command}",
      "insertTextRules": 4,
      "sortText": "01_sched"
    },
    {
      "label": "every 2 hours",
      "kind": 28,
      "detail": "Every 2 hours",
      "documentation": {
        "value": "Run every 2 hours."
      },
      "insertText": "0 */2 * * * ${1:command}",
      "insertTextRules": 4,
      "sortText": "01_sched"
    },
    {
      "label": "every 6 hours",
      "kind": 28,
      "detail": "Every 6 hours",
      "documentation": {
        "value": "Run every 6 hours."
      },
      "insertText": "0 */6 * * * ${1:command}",
      "insertTextRules": 4,
      "sortText": "01_sched"
    },
    {
      "label": "every 12 hours",
      "kind": 28,
      "detail": "Twice daily",
      "documentation": {
        "value": "Run every 12 hours."
      },
      "insertText": "0 0,12 * * * ${1:command}",
      "insertTextRules": 4,
      "sortText": "01_sched"
    },
    {
      "label": "twice daily",
      "kind": 28,
      "detail": "At 8am and 8pm",
      "documentation": {
        "value": "Run at 8am and 8pm."
      },
      "insertText": "0 8,20 * * * ${1:command}",
      "insertTextRules": 4,
      "sortText": "01_sched"
    },
    {
      "label": "workdays at 6am",
      "kind": 28,
      "detail": "Workdays 6am",
      "documentation": {
        "value": "Weekdays at 6:00 AM."
      },
      "insertText": "0 6 * * 1-5 ${1:command}",
      "insertTextRules": 4,
      "sortText": "02_work"
    },
    {
      "label": "workdays at noon",
      "kind": 28,
      "detail": "Workdays noon",
      "documentation": {
        "value": "Weekdays at noon."
      },
      "insertText": "0 12 * * 1-5 ${1:command}",
      "insertTextRules": 4,
      "sortText": "02_work"
    },
    {
      "label": "weekends",
      "kind": 28,
      "detail": "Weekends only",
      "documentation": {
        "value": "Saturday and Sunday."
      },
      "insertText": "0 ${1:0} * * 6,0 ${2:command}",
      "insertTextRules": 4,
      "sortText": "02_work"
    },
    {
      "label": "first day quarter",
      "kind": 28,
      "detail": "Quarterly",
      "documentation": {
        "value": "First day of each quarter."
      },
      "insertText": "0 0 1 1,4,7,10 * ${1:command}",
      "insertTextRules": 4,
      "sortText": "02_period"
    },
    {
      "label": "yearly",
      "kind": 28,
      "detail": "Yearly",
      "documentation": {
        "value": "Once a year January 1st."
      },
      "insertText": "0 0 1 1 * ${1:command}",
      "insertTextRules": 4,
      "sortText": "02_period"
    },
    {
      "label": "last day of month",
      "kind": 28,
      "detail": "Last day",
      "documentation": {
        "value": "Approximate last day of month."
      },
      "insertText": "0 0 28-31 * * [ $(date -d tomorrow +%d) -eq 01 ] && ${1:command}",
      "insertTextRules": 4,
      "sortText": "02_period"
    },
    {
      "label": "15th and last",
      "kind": 28,
      "detail": "Bi-monthly",
      "documentation": {
        "value": "15th and last day of month."
      },
      "insertText": "0 0 15,28-31 * * ${1:command}",
      "insertTextRules": 4,
      "sortText": "02_period"
    },
    {
      "label": "every N days",
      "kind": 28,
      "detail": "Every N days",
      "documentation": {
        "value": "Run every N days."
      },
      "insertText": "0 0 */${1:3} * * ${2:command}",
      "insertTextRules": 4,
      "sortText": "01_sched"
    },
    {
      "label": "business hours",
      "kind": 28,
      "detail": "Business hours",
      "documentation": {
        "value": "Every 30 min during business hours."
      },
      "insertText": "*/30 9-17 * * 1-5 ${1:command}",
      "insertTextRules": 4,
      "sortText": "02_work"
    },
    {
      "label": "suppress output",
      "kind": 28,
      "detail": "No output",
      "documentation": {
        "value": "Suppress all output."
      },
      "insertText": "${1:0 * * * *} ${2:command} > /dev/null 2>&1",
      "insertTextRules": 4,
      "sortText": "03_opt"
    },
    {
      "label": "error only",
      "kind": 28,
      "detail": "Errors only",
      "documentation": {
        "value": "Only capture error output."
      },
      "insertText": "${1:0 * * * *} ${2:command} > /dev/null",
      "insertTextRules": 4,
      "sortText": "03_opt"
    },
    {
      "label": "with timestamp",
      "kind": 28,
      "detail": "Timestamped log",
      "documentation": {
        "value": "Log with timestamp."
      },
      "insertText": "${1:*/5 * * * *} echo \"$(date): running\" >> ${2:/var/log/cron.log} && ${3:command} >> ${2:/var/log/cron.log} 2>&1",
      "insertTextRules": 4,
      "sortText": "03_opt"
    },
    {
      "label": "with timeout",
      "kind": 28,
      "detail": "With timeout",
      "documentation": {
        "value": "Run with timeout."
      },
      "insertText": "${1:*/5 * * * *} timeout ${2:300} ${3:command}",
      "insertTextRules": 4,
      "sortText": "03_opt"
    },
    {
      "label": "with nice",
      "kind": 28,
      "detail": "Low priority",
      "documentation": {
        "value": "Run with low CPU priority."
      },
      "insertText": "${1:0 2 * * *} nice -n 19 ${2:command}",
      "insertTextRules": 4,
      "sortText": "03_opt"
    },
    {
      "label": "with ionice",
      "kind": 28,
      "detail": "Low IO priority",
      "documentation": {
        "value": "Run with low IO priority."
      },
      "insertText": "${1:0 2 * * *} ionice -c3 ${2:command}",
      "insertTextRules": 4,
      "sortText": "03_opt"
    },
    {
      "label": "conditional",
      "kind": 28,
      "detail": "With condition",
      "documentation": {
        "value": "Run only if condition met."
      },
      "insertText": "${1:*/5 * * * *} [ -f ${2:/tmp/flag} ] && ${3:command}",
      "insertTextRules": 4,
      "sortText": "03_opt"
    },
    {
      "label": "@monthly",
      "kind": 28,
      "detail": "Run monthly",
      "documentation": {
        "value": "Shorthand for monthly."
      },
      "insertText": "@monthly ${1:command}",
      "insertTextRules": 4,
      "sortText": "05_special"
    },
    {
      "label": "@yearly",
      "kind": 28,
      "detail": "Run yearly",
      "documentation": {
        "value": "Shorthand for yearly."
      },
      "insertText": "@yearly ${1:command}",
      "insertTextRules": 4,
      "sortText": "05_special"
    },
    {
      "label": "@annually",
      "kind": 28,
      "detail": "Run annually",
      "documentation": {
        "value": "Alias for @yearly."
      },
      "insertText": "@annually ${1:command}",
      "insertTextRules": 4,
      "sortText": "05_special"
    },
    {
      "label": "HOME",
      "kind": 28,
      "detail": "HOME variable",
      "documentation": {
        "value": "Set HOME directory."
      },
      "insertText": "HOME=${1:/home/user}",
      "insertTextRules": 4,
      "sortText": "04_env"
    },
    {
      "label": "LOGNAME",
      "kind": 28,
      "detail": "LOGNAME",
      "documentation": {
        "value": "Set log name."
      },
      "insertText": "LOGNAME=${1:user}",
      "insertTextRules": 4,
      "sortText": "04_env"
    },
    {
      "label": "CRON_TZ",
      "kind": 28,
      "detail": "Timezone",
      "documentation": {
        "value": "Set cron timezone."
      },
      "insertText": "CRON_TZ=${1:America/New_York}",
      "insertTextRules": 4,
      "sortText": "04_env"
    },
    {
      "label": "backup database",
      "kind": 28,
      "detail": "DB backup",
      "documentation": {
        "value": "Database backup cron."
      },
      "insertText": "0 2 * * * pg_dump -U ${1:user} ${2:dbname} | gzip > ${3:/backups/db}-$(date +\\%Y\\%m\\%d).sql.gz",
      "insertTextRules": 4,
      "sortText": "06_task"
    },
    {
      "label": "rotate logs",
      "kind": 28,
      "detail": "Log rotation",
      "documentation": {
        "value": "Rotate log files."
      },
      "insertText": "0 0 * * * find ${1:/var/log/app} -name \"*.log\" -mtime +${2:30} -delete",
      "insertTextRules": 4,
      "sortText": "06_task"
    },
    {
      "label": "cleanup tmp",
      "kind": 28,
      "detail": "Cleanup temp",
      "documentation": {
        "value": "Clean temp files."
      },
      "insertText": "0 3 * * * find ${1:/tmp} -type f -mtime +${2:7} -delete",
      "insertTextRules": 4,
      "sortText": "06_task"
    },
    {
      "label": "SSL cert renew",
      "kind": 28,
      "detail": "Certbot renew",
      "documentation": {
        "value": "Renew SSL certificates."
      },
      "insertText": "0 3 * * 1 certbot renew --quiet && systemctl reload nginx",
      "insertTextRules": 4,
      "sortText": "06_task"
    },
    {
      "label": "health check",
      "kind": 28,
      "detail": "Health check",
      "documentation": {
        "value": "Periodic health check."
      },
      "insertText": "*/5 * * * * curl -sf ${1:http://localhost:3000/health} || echo \"Service down\" | mail -s \"Alert\" ${2:admin@example.com}",
      "insertTextRules": 4,
      "sortText": "06_task"
    },
    {
      "label": "git pull",
      "kind": 28,
      "detail": "Git pull deploy",
      "documentation": {
        "value": "Auto pull latest code."
      },
      "insertText": "*/10 * * * * cd ${1:/opt/app} && git pull origin ${2:main} && ${3:npm run build}",
      "insertTextRules": 4,
      "sortText": "06_task"
    },
    {
      "label": "sync files",
      "kind": 28,
      "detail": "Rsync backup",
      "documentation": {
        "value": "Rsync file synchronization."
      },
      "insertText": "0 1 * * * rsync -avz ${1:/data/} ${2:user@backup:/backups/data/}",
      "insertTextRules": 4,
      "sortText": "06_task"
    },
    {
      "label": "docker prune",
      "kind": 28,
      "detail": "Docker cleanup",
      "documentation": {
        "value": "Docker system cleanup."
      },
      "insertText": "0 4 * * 0 docker system prune -af --volumes",
      "insertTextRules": 4,
      "sortText": "06_task"
    },
    {
      "label": "send report",
      "kind": 28,
      "detail": "Daily report",
      "documentation": {
        "value": "Send daily report email."
      },
      "insertText": "0 8 * * * ${1:/opt/scripts/report.sh} | mail -s \"${2:Daily Report}\" ${3:team@example.com}",
      "insertTextRules": 4,
      "sortText": "06_task"
    },
    {
      "label": "disk check",
      "kind": 28,
      "detail": "Disk space check",
      "documentation": {
        "value": "Check disk space."
      },
      "insertText": "0 */4 * * * df -h / | awk 'NR==2 && $5+0 > 80 { print \"Disk usage:\", $5 }' | mail -s \"Disk Alert\" ${1:admin@example.com}",
      "insertTextRules": 4,
      "sortText": "06_task"
    },
    {
      "label": "pip output",
      "kind": 28,
      "detail": "Pipe to mail",
      "documentation": {
        "value": "Pipe output to mail."
      },
      "insertText": "${1:0 6 * * *} ${2:command} 2>&1 | mail -s \"${3:Cron output}\" ${4:user@example.com}",
      "insertTextRules": 4,
      "sortText": "03_opt"
    },
    {
      "label": "multiple commands",
      "kind": 28,
      "detail": "Run multiple",
      "documentation": {
        "value": "Multiple commands."
      },
      "insertText": "${1:0 2 * * *} ${2:command1} && ${3:command2} && ${4:command3}",
      "insertTextRules": 4,
      "sortText": "03_opt"
    },
    {
      "label": "random delay",
      "kind": 28,
      "detail": "Random delay",
      "documentation": {
        "value": "Add random delay to avoid thundering herd."
      },
      "insertText": "${1:*/5 * * * *} sleep $((RANDOM \\% ${2:60})) && ${3:command}",
      "insertTextRules": 4,
      "sortText": "03_opt"
    },
    {
      "label": "cron header",
      "kind": 28,
      "detail": "Section header",
      "documentation": {
        "value": "Comment section header."
      },
      "insertText": "# ============================================\n# ${1:Section Name}\n# Schedule: ${2:description}\n# ============================================",
      "insertTextRules": 4,
      "sortText": "00_header"
    },
    {
      "label": "# field reference",
      "kind": 28,
      "detail": "Field reference",
      "documentation": {
        "value": "Cron field reference comment."
      },
      "insertText": "# .---------------- minute (0-59)\n# |  .------------- hour (0-23)\n# |  |  .---------- day of month (1-31)\n# |  |  |  .------- month (1-12)\n# |  |  |  |  .---- day of week (0-7, Sun=0/7)\n# |  |  |  |  |\n# *  *  *  *  *  command",
      "insertTextRules": 4,
      "sortText": "00_header"
    },
    {
      "label": "full crontab",
      "kind": 28,
      "detail": "Complete crontab",
      "documentation": {
        "value": "Full crontab template."
      },
      "insertText": "# Environment\nSHELL=/bin/bash\nPATH=/usr/local/bin:/usr/bin:/bin\nMAILTO=${1:admin@example.com}\n\n# Schedules\n*/5 * * * * ${2:/opt/scripts/health.sh} > /dev/null 2>&1\n0 2 * * * ${3:/opt/scripts/backup.sh} >> /var/log/backup.log 2>&1\n0 0 * * 0 ${4:/opt/scripts/weekly.sh}",
      "insertTextRules": 4,
      "sortText": "07_tpl"
    },
    {
      "label": "at midnight",
      "kind": 28,
      "detail": "Daily midnight",
      "documentation": {
        "value": "Run daily at midnight."
      },
      "insertText": "0 0 * * * ${1:command}",
      "insertTextRules": 4,
      "sortText": "01_sched"
    },
    {
      "label": "at 3am",
      "kind": 28,
      "detail": "Daily 3 AM",
      "documentation": {
        "value": "Run daily at 3:00 AM."
      },
      "insertText": "0 3 * * * ${1:command}",
      "insertTextRules": 4,
      "sortText": "01_sched"
    },
    {
      "label": "at 6am",
      "kind": 28,
      "detail": "Daily 6 AM",
      "documentation": {
        "value": "Run daily at 6:00 AM."
      },
      "insertText": "0 6 * * * ${1:command}",
      "insertTextRules": 4,
      "sortText": "01_sched"
    },
    {
      "label": "at 9pm",
      "kind": 28,
      "detail": "Daily 9 PM",
      "documentation": {
        "value": "Run at 9:00 PM."
      },
      "insertText": "0 21 * * * ${1:command}",
      "insertTextRules": 4,
      "sortText": "01_sched"
    },
    {
      "label": "monday 5am",
      "kind": 28,
      "detail": "Monday 5 AM",
      "documentation": {
        "value": "Every Monday at 5:00 AM."
      },
      "insertText": "0 5 * * 1 ${1:command}",
      "insertTextRules": 4,
      "sortText": "02_work"
    },
    {
      "label": "friday evening",
      "kind": 28,
      "detail": "Friday 6 PM",
      "documentation": {
        "value": "Every Friday at 6:00 PM."
      },
      "insertText": "0 18 * * 5 ${1:command}",
      "insertTextRules": 4,
      "sortText": "02_work"
    },
    {
      "label": "first monday",
      "kind": 28,
      "detail": "First Monday",
      "documentation": {
        "value": "First Monday of month."
      },
      "insertText": "0 0 1-7 * 1 ${1:command}",
      "insertTextRules": 4,
      "sortText": "02_period"
    },
    {
      "label": "biweekly",
      "kind": 28,
      "detail": "Biweekly",
      "documentation": {
        "value": "Every two weeks."
      },
      "insertText": "0 0 1,15 * * ${1:command}",
      "insertTextRules": 4,
      "sortText": "02_period"
    },
    {
      "label": "monitor memory",
      "kind": 28,
      "detail": "Memory monitor",
      "documentation": {
        "value": "Check memory usage."
      },
      "insertText": "*/15 * * * * free -m | awk 'NR==2{if($3/$2*100>${1:80})print \"Memory:\",$3/$2*100\"%\"}' | mail -s \"Memory Alert\" ${2:admin@example.com}",
      "insertTextRules": 4,
      "sortText": "06_task"
    },
    {
      "label": "compress logs",
      "kind": 28,
      "detail": "Compress logs",
      "documentation": {
        "value": "Compress old log files."
      },
      "insertText": "0 1 * * * find ${1:/var/log} -name \"*.log\" -mtime +${2:1} ! -name \"*.gz\" -exec gzip {} \\;",
      "insertTextRules": 4,
      "sortText": "06_task"
    },
    {
      "label": "truncate log",
      "kind": 28,
      "detail": "Truncate log",
      "documentation": {
        "value": "Truncate large log files."
      },
      "insertText": "0 4 * * * for f in ${1:/var/log/app}/*.log; do [ $(stat -f%z \"$$f\" 2>/dev/null || stat -c%s \"$$f\") -gt ${2:104857600} ] && : > \"$$f\"; done",
      "insertTextRules": 4,
      "sortText": "06_task"
    },
    {
      "label": "mysql backup",
      "kind": 28,
      "detail": "MySQL backup",
      "documentation": {
        "value": "MySQL dump backup."
      },
      "insertText": "0 2 * * * mysqldump -u ${1:root} -p${2:password} ${3:dbname} | gzip > ${4:/backups}/mysql-$(date +\\%Y\\%m\\%d).sql.gz",
      "insertTextRules": 4,
      "sortText": "06_task"
    },
    {
      "label": "redis backup",
      "kind": 28,
      "detail": "Redis backup",
      "documentation": {
        "value": "Redis RDB backup."
      },
      "insertText": "0 3 * * * redis-cli BGSAVE && cp ${1:/var/lib/redis/dump.rdb} ${2:/backups}/redis-$(date +\\%Y\\%m\\%d).rdb",
      "insertTextRules": 4,
      "sortText": "06_task"
    },
    {
      "label": "container restart",
      "kind": 28,
      "detail": "Restart container",
      "documentation": {
        "value": "Restart Docker container."
      },
      "insertText": "0 4 * * 0 docker restart ${1:container_name}",
      "insertTextRules": 4,
      "sortText": "06_task"
    },
    {
      "label": "apt update",
      "kind": 28,
      "detail": "Apt update",
      "documentation": {
        "value": "Auto update packages."
      },
      "insertText": "0 3 * * 0 apt-get update && apt-get upgrade -y >> /var/log/apt-auto.log 2>&1",
      "insertTextRules": 4,
      "sortText": "06_task"
    },
    {
      "label": "with lock",
      "kind": 28,
      "detail": "With flock",
      "documentation": {
        "value": "Prevent overlapping runs."
      },
      "insertText": "${1:*/5 * * * *} flock -n ${2:/tmp/myjob.lock} ${3:command}",
      "insertTextRules": 4,
      "sortText": "03_opt"
    }
  ]
}
