      },
      "insertText": "# Configuration File\n\n[DEFAULT]\nlog_level = ${1:info}\n\n[${2:section1}]\n${3:key1} = ${4:value1}\n${5:key2} = ${6:value2}\n\n[${7:section2}]\n${8:key} = ${9:value}",
      "insertTextRules": 4,
      "sortText": "03_template"
