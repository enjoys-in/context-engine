      "label": "[testenv]",
      "kind": 28,
      "detail": "Tox test env",
      "documentation": {
        "value": "Tox test environment."
      },
      "insertText": "[testenv]\ndeps = pytest\ncommands = pytest ${1:tests/}",
      "insertTextRules": 4,
      "sortText": "02_tox"
