      "label": "[wsl]",
      "kind": 28,
      "detail": "WSL config",
      "documentation": {
        "value": "WSL configuration (wsl.conf)."
      },
      "insertText": "[wsl2]\nmemory = ${1:4GB}\nprocessors = ${2:2}\nswap = ${3:0}",
      "insertTextRules": 4,
      "sortText": "02_wsl"
    },
    {
      "label": "[network]",
      "kind": 28,
      "detail": "WSL network",
      "documentation": {
        "value": "WSL network config."
      },
      "insertText": "[network]\ngenerateHosts = true\ngenerateResolvConf = true",
      "insertTextRules": 4,
      "sortText": "02_wsl"
