    {
      "label": "setup.cfg template",
      "kind": 28,
      "detail": "Python setup.cfg",
      "documentation": {
        "value": "Python setup.cfg template."
      },
      "insertText": "[metadata]\nname = ${1:mypackage}\nversion = ${2:0.1.0}\n\n[options]\npackages = find:\npython_requires = >=3.8\n\n[tool:pytest]\ntestpaths = tests\n\n[flake8]\nmax-line-length = 120",
      "insertTextRules": 4,
      "sortText": "03_template"
