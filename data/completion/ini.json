      "label": "[filter \"lfs\"]",
      "kind": 28,
      "detail": "Git LFS",
      "documentation": {
        "value": "Git LFS filter config."
      },
      "insertText": "[filter \"lfs\"]\n    clean = git-lfs clean -- %f\n    smudge = git-lfs smudge -- %f\n    process = git-lfs filter-process\n    required = true",
      "insertTextRules": 4,
      "sortText": "02_git"
    },
