      "label": "[editorconfig]",
      "kind": 28,
      "detail": "EditorConfig root",
      "documentation": {
        "value": "EditorConfig root."
      },
      "insertText": "root = true\n\n[*]\nindent_style = ${1:space}\nindent_size = ${2:4}\nend_of_line = ${3:lf}\ncharset = utf-8\ntrim_trailing_whitespace = true\ninsert_final_newline = true",
      "insertTextRules": 4,
      "sortText": "02_editor"
    },
    {
      "label": "[*.py]",
      "kind": 28,
      "detail": "EditorConfig Python",
      "documentation": {
        "value": "EditorConfig for Python files."
      },
      "insertText": "[*.py]\nindent_size = 4\nmax_line_length = ${1:120}",
      "insertTextRules": 4,
      "sortText": "02_editor"
    },
    {
      "label": "[*.js]",
      "kind": 28,
      "detail": "EditorConfig JS",
      "documentation": {
        "value": "EditorConfig for JS files."
      },
      "insertText": "[*.js]\nindent_size = 2",
