{
  "language": "ini",
  "completions": [
    {
      "label": "[section]",
      "kind": 28,
      "detail": "Section header",
      "documentation": {
        "value": "Define a new INI section."
      },
      "insertText": "[${1:section}]\n${2:key} = ${3:value}",
      "insertTextRules": 4,
      "sortText": "00_section"
    },
    {
      "label": "key = value",
      "kind": 28,
      "detail": "Key-value pair",
      "documentation": {
        "value": "Configuration key-value pair."
      },
      "insertText": "${1:key} = ${2:value}",
      "insertTextRules": 4,
      "sortText": "00_kv"
    },
    {
      "label": "; comment",
      "kind": 28,
      "detail": "Semicolon comment",
      "documentation": {
        "value": "Comment with semicolon."
      },
      "insertText": "; ${1:comment}",
      "insertTextRules": 4,
      "sortText": "00_comment"
    },
    {
      "label": "# comment",
      "kind": 28,
      "detail": "Hash comment",
      "documentation": {
        "value": "Comment with hash."
      },
      "insertText": "# ${1:comment}",
      "insertTextRules": 4,
      "sortText": "00_comment"
    },
    {
      "label": "[DEFAULT]",
      "kind": 28,
      "detail": "Default section",
      "documentation": {
        "value": "Fallback values for all sections."
      },
      "insertText": "[DEFAULT]\n${1:key} = ${2:value}",
      "insertTextRules": 4,
      "sortText": "01_section"
    },
    {
      "label": "multiline",
      "kind": 28,
      "detail": "Multi-line value",
      "documentation": {
        "value": "Continuation with indentation."
      },
      "insertText": "${1:key} = ${2:first line}\n    ${3:continuation}",
      "insertTextRules": 4,
      "sortText": "01_multi"
    },
    {
      "label": "interpolation",
      "kind": 28,
      "detail": "Variable interpolation",
      "documentation": {
        "value": "Reference another key (Python configparser)."
      },
      "insertText": "${1:key} = %(${2:other_key})s${3:suffix}",
      "insertTextRules": 4,
      "sortText": "01_interp"
    },
    {
      "label": "[mysqld]",
      "kind": 28,
      "detail": "MySQL server config",
      "documentation": {
        "value": "MySQL server configuration section (my.cnf)."
      },
      "insertText": "[mysqld]\nport = ${1:3306}\nbind-address = ${2:127.0.0.1}\nmax_connections = ${3:151}\ninnodb_buffer_pool_size = ${4:128M}",
      "insertTextRules": 4,
      "sortText": "02_mysql"
    },
    {
      "label": "[mysqld_safe]",
      "kind": 28,
      "detail": "MySQL safe config",
      "documentation": {
        "value": "MySQL safe mode config."
      },
      "insertText": "[mysqld_safe]\nlog-error = /var/log/mysqld.log\npid-file = /var/run/mysqld/mysqld.pid",
      "insertTextRules": 4,
      "sortText": "02_mysql"
    },
    {
      "label": "[client]",
      "kind": 28,
      "detail": "MySQL client config",
      "documentation": {
        "value": "MySQL client defaults."
      },
      "insertText": "[client]\nport = ${1:3306}\nsocket = /var/lib/mysql/mysql.sock\ndefault-character-set = utf8mb4",
      "insertTextRules": 4,
      "sortText": "02_mysql"
    },
    {
      "label": "[php]",
      "kind": 28,
      "detail": "PHP configuration",
      "documentation": {
        "value": "PHP config section (php.ini)."
      },
      "insertText": "[PHP]\nengine = On\nmemory_limit = ${1:128M}\nupload_max_filesize = ${2:2M}\npost_max_size = ${3:8M}\nmax_execution_time = ${4:30}",
      "insertTextRules": 4,
      "sortText": "02_php"
    },
    {
      "label": "[Date]",
      "kind": 28,
      "detail": "PHP date config",
      "documentation": {
        "value": "PHP date/time config."
      },
      "insertText": "[Date]\ndate.timezone = ${1:UTC}",
      "insertTextRules": 4,
      "sortText": "02_php"
    },
    {
      "label": "[Session]",
      "kind": 28,
      "detail": "PHP session",
      "documentation": {
        "value": "PHP session config."
      },
      "insertText": "[Session]\nsession.save_handler = files\nsession.save_path = \"${1:/tmp}\"\nsession.gc_maxlifetime = ${2:1440}",
      "insertTextRules": 4,
      "sortText": "02_php"
    },
    {
      "label": "[opcache]",
      "kind": 28,
      "detail": "PHP OPcache",
      "documentation": {
        "value": "PHP OPcache config."
      },
      "insertText": "[opcache]\nopcache.enable = 1\nopcache.memory_consumption = ${1:128}\nopcache.max_accelerated_files = ${2:10000}\nopcache.revalidate_freq = ${3:2}",
      "insertTextRules": 4,
      "sortText": "02_php"
    },
    {
      "label": "[supervisord]",
      "kind": 28,
      "detail": "Supervisord config",
      "documentation": {
        "value": "Supervisor daemon config."
      },
      "insertText": "[supervisord]\nlogfile = /var/log/supervisord.log\npidfile = /var/run/supervisord.pid\nchildlogdir = /var/log/supervisor",
      "insertTextRules": 4,
      "sortText": "02_supervisor"
    },
    {
      "label": "[program:name]",
      "kind": 28,
      "detail": "Supervisor program",
      "documentation": {
        "value": "Supervised program block."
      },
      "insertText": "[program:${1:myapp}]\ncommand = ${2:/usr/bin/python app.py}\ndirectory = ${3:/opt/app}\nautostart = true\nautorestart = true\nstdout_logfile = /var/log/${1:myapp}.log",
      "insertTextRules": 4,
      "sortText": "02_supervisor"
    },
    {
      "label": "[group:name]",
      "kind": 28,
      "detail": "Supervisor group",
      "documentation": {
        "value": "Supervisor process group."
      },
      "insertText": "[group:${1:mygroup}]\nprograms = ${2:app1,app2}",
      "insertTextRules": 4,
      "sortText": "02_supervisor"
    },
    {
      "label": "[inet_http_server]",
      "kind": 28,
      "detail": "Supervisor HTTP",
      "documentation": {
        "value": "Supervisor web interface."
      },
      "insertText": "[inet_http_server]\nport = ${1:9001}\nusername = ${2:admin}\npassword = ${3:password}",
      "insertTextRules": 4,
      "sortText": "02_supervisor"
    },
    {
      "label": "[uwsgi]",
      "kind": 28,
      "detail": "uWSGI config",
      "documentation": {
        "value": "uWSGI application server."
      },
      "insertText": "[uwsgi]\nmodule = ${1:wsgi}:${2:app}\nmaster = true\nprocesses = ${3:4}\nsocket = ${4:0.0.0.0:8000}\nvacuum = true",
      "insertTextRules": 4,
      "sortText": "02_uwsgi"
    },
    {
      "label": "[gunicorn]",
      "kind": 28,
      "detail": "Gunicorn config",
      "documentation": {
        "value": "Gunicorn config section."
      },
      "insertText": "[gunicorn]\nbind = ${1:0.0.0.0:8000}\nworkers = ${2:4}\nworker-class = ${3:sync}\ntimeout = ${4:30}",
      "insertTextRules": 4,
      "sortText": "02_gunicorn"
    },
    {
      "label": "[user]",
      "kind": 28,
      "detail": "Git user config",
      "documentation": {
        "value": "Git user configuration."
      },
      "insertText": "[user]\n    name = ${1:Your Name}\n    email = ${2:your@email.com}",
      "insertTextRules": 4,
      "sortText": "02_git"
    },
    {
      "label": "[core]",
      "kind": 28,
      "detail": "Git core config",
      "documentation": {
        "value": "Git core settings."
      },
      "insertText": "[core]\n    editor = ${1:vim}\n    autocrlf = ${2:input}\n    whitespace = fix",
      "insertTextRules": 4,
      "sortText": "02_git"
    },
    {
      "label": "[alias]",
      "kind": 28,
      "detail": "Git aliases",
      "documentation": {
        "value": "Git command aliases."
      },
      "insertText": "[alias]\n    co = checkout\n    br = branch\n    ci = commit\n    st = status\n    lg = log --oneline --graph",
      "insertTextRules": 4,
      "sortText": "02_git"
    },
    {
      "label": "[push]",
      "kind": 28,
      "detail": "Git push config",
      "documentation": {
        "value": "Git push defaults."
      },
      "insertText": "[push]\n    default = ${1:current}\n    autoSetupRemote = true",
      "insertTextRules": 4,
      "sortText": "02_git"
    },
    {
      "label": "[pull]",
      "kind": 28,
      "detail": "Git pull config",
      "documentation": {
        "value": "Git pull defaults."
      },
      "insertText": "[pull]\n    rebase = ${1:true}",
      "insertTextRules": 4,
      "sortText": "02_git"
    },
    {
      "label": "[remote \"origin\"]",
      "kind": 28,
      "detail": "Git remote",
      "documentation": {
        "value": "Git remote origin."
      },
      "insertText": "[remote \"origin\"]\n    url = ${1:git@github.com:user/repo.git}\n    fetch = +refs/heads/*:refs/remotes/origin/*",
      "insertTextRules": 4,
      "sortText": "02_git"
    },
    {
      "label": "[branch \"main\"]",
      "kind": 28,
      "detail": "Git branch config",
      "documentation": {
        "value": "Git branch tracking."
      },
      "insertText": "[branch \"${1:main}\"]\n    remote = origin\n    merge = refs/heads/${1:main}",
      "insertTextRules": 4,
      "sortText": "02_git"
    },
    {
      "label": "[Unit]",
      "kind": 28,
      "detail": "Systemd unit",
      "documentation": {
        "value": "Systemd unit section."
      },
      "insertText": "[Unit]\nDescription = ${1:My Service}\nAfter = ${2:network.target}",
      "insertTextRules": 4,
      "sortText": "02_systemd"
    },
    {
      "label": "[Service]",
      "kind": 28,
      "detail": "Systemd service",
      "documentation": {
        "value": "Systemd service section."
      },
      "insertText": "[Service]\nType = ${1:simple}\nExecStart = ${2:/usr/bin/myapp}\nRestart = ${3:on-failure}\nUser = ${4:nobody}\nWorkingDirectory = ${5:/opt/app}",
      "insertTextRules": 4,
      "sortText": "02_systemd"
    },
    {
      "label": "[Install]",
      "kind": 28,
      "detail": "Systemd install",
      "documentation": {
        "value": "Systemd install section."
      },
      "insertText": "[Install]\nWantedBy = ${1:multi-user.target}",
      "insertTextRules": 4,
      "sortText": "02_systemd"
    },
    {
      "label": "[Timer]",
      "kind": 28,
      "detail": "Systemd timer",
      "documentation": {
        "value": "Systemd timer section."
      },
      "insertText": "[Timer]\nOnCalendar = ${1:daily}\nPersistent = true\n\n[Install]\nWantedBy = timers.target",
      "insertTextRules": 4,
      "sortText": "02_systemd"
    },
    {
      "label": "[Desktop Entry]",
      "kind": 28,
      "detail": "Desktop entry",
      "documentation": {
        "value": "XDG desktop entry."
      },
      "insertText": "[Desktop Entry]\nType = Application\nName = ${1:My App}\nExec = ${2:/usr/bin/myapp}\nIcon = ${3:myapp}\nCategories = ${4:Utility};",
      "insertTextRules": 4,
      "sortText": "02_desktop"
    },
    {
      "label": "[global]",
      "kind": 28,
      "detail": "Pip config",
      "documentation": {
        "value": "Pip global config."
      },
      "insertText": "[global]\nindex-url = ${1:https://pypi.org/simple}\ntrusted-host = ${2:pypi.org}",
      "insertTextRules": 4,
      "sortText": "02_pip"
    },
    {
      "label": "[tool:pytest]",
      "kind": 28,
      "detail": "Pytest config",
      "documentation": {
        "value": "Pytest configuration (setup.cfg)."
      },
      "insertText": "[tool:pytest]\ntestpaths = ${1:tests}\naddopts = ${2:-v --tb=short}",
      "insertTextRules": 4,
      "sortText": "02_pytest"
    },
    {
      "label": "[flake8]",
      "kind": 28,
      "detail": "Flake8 config",
      "documentation": {
        "value": "Flake8 linter config."
      },
      "insertText": "[flake8]\nmax-line-length = ${1:120}\nexclude = ${2:.git,__pycache__,build}\nignore = ${3:E501,W503}",
      "insertTextRules": 4,
      "sortText": "02_flake8"
    },
    {
      "label": "[mypy]",
      "kind": 28,
      "detail": "Mypy config",
      "documentation": {
        "value": "Mypy type checker config."
      },
      "insertText": "[mypy]\npython_version = ${1:3.11}\nwarn_return_any = True\nwarn_unused_configs = True\ndisallow_untyped_defs = True",
      "insertTextRules": 4,
      "sortText": "02_mypy"
    },
    {
      "label": "[isort]",
      "kind": 28,
      "detail": "Isort config",
      "documentation": {
        "value": "Import sorter config."
      },
      "insertText": "[isort]\nprofile = ${1:black}\nmulti_line_output = 3\ninclude_trailing_comma = True\nline_length = ${2:88}",
      "insertTextRules": 4,
      "sortText": "02_isort"
    },
    {
      "label": "[coverage:run]",
      "kind": 28,
      "detail": "Coverage run",
      "documentation": {
        "value": "Coverage.py run config."
      },
      "insertText": "[coverage:run]\nsource = ${1:src}\nomit = ${2:tests/*}",
      "insertTextRules": 4,
      "sortText": "02_coverage"
    },
    {
      "label": "[coverage:report]",
      "kind": 28,
      "detail": "Coverage report",
      "documentation": {
        "value": "Coverage report config."
      },
      "insertText": "[coverage:report]\nshow_missing = True\nfail_under = ${1:80}",
      "insertTextRules": 4,
      "sortText": "02_coverage"
    },
