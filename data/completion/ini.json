      "label": "[tox]",
      "kind": 28,
      "detail": "Tox config",
      "documentation": {
        "value": "Tox testing config."
      },
      "insertText": "[tox]\nenvlist = ${1:py39,py310,py311}",
      "insertTextRules": 4,
      "sortText": "02_tox"
    },
