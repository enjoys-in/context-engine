{
  "language": "toml",
  "completions": [
    {
      "label": "[table]",
      "kind": 15,
      "detail": "Define a TOML table",
      "documentation": {
        "value": "Tables (also known as hash tables or dictionaries) are collections of key/value pairs. They appear in square brackets on a line by themselves."
      },
      "insertText": "[${1:table_name}]\n${2:key} = ${3:value}",
      "insertTextRules": 4,
      "sortText": "00_table"
    },
    {
      "label": "[[array_of_tables]]",
      "kind": 15,
      "detail": "Define an array of tables",
      "documentation": {
        "value": "Any reference to an array of tables points to the most recently defined table element of the array. Double brackets define an array of TOML tables."
      },
      "insertText": "[[${1:table_name}]]\n${2:key} = ${3:value}",
      "insertTextRules": 4,
      "sortText": "01_array_of_tables"
    },
    {
      "label": "key = value",
      "kind": 14,
      "detail": "Key-value pair",
      "documentation": {
        "value": "The primary building block of a TOML document. Keys are on the left of the equals sign and values are on the right."
      },
      "insertText": "${1:key} = ${2:value}",
      "insertTextRules": 4,
      "sortText": "02_key_value"
    },
    {
      "label": "dotted.key",
      "kind": 14,
      "detail": "Dotted key (nested access)",
      "documentation": {
        "value": "Dotted keys are a sequence of bare or quoted keys joined with a dot. This allows grouping similar properties together."
      },
      "insertText": "${1:parent}.${2:child} = ${3:value}",
      "insertTextRules": 4,
      "sortText": "03_dotted_key"
    },
    {
      "label": "inline_table",
      "kind": 15,
      "detail": "Inline table { key = value }",
      "documentation": {
        "value": "Inline tables provide a more compact syntax for expressing tables. They appear on the same line in curly braces."
      },
      "insertText": "${1:key} = { ${2:k1} = ${3:v1}, ${4:k2} = ${5:v2} }",
      "insertTextRules": 4,
      "sortText": "04_inline_table"
    },
    {
      "label": "string (basic)",
      "kind": 14,
      "detail": "Basic string with double quotes",
      "documentation": {
        "value": "Basic strings are surrounded by double quotes. Any Unicode character may be used except those that must be escaped: quotation mark, backslash, and control characters."
      },
      "insertText": "${1:key} = \"${2:value}\"",
      "insertTextRules": 4,
      "sortText": "05_string_basic"
    },
    {
      "label": "string (literal)",
      "kind": 14,
      "detail": "Literal string with single quotes",
      "documentation": {
        "value": "Literal strings are surrounded by single quotes. No escaping is performed — what you see is what you get."
      },
      "insertText": "${1:key} = '${2:value}'",
      "insertTextRules": 4,
      "sortText": "06_string_literal"
    },
    {
      "label": "string (multi-line basic)",
      "kind": 15,
      "detail": "Multi-line basic string with triple double quotes",
      "documentation": {
        "value": "Multi-line basic strings are surrounded by three double quotes on each side and allow newlines. A newline immediately following the opening delimiter will be trimmed."
      },
      "insertText": "${1:key} = \"\"\"\n${2:content}\n\"\"\"",
      "insertTextRules": 4,
      "sortText": "07_string_multiline_basic"
    },
    {
      "label": "string (multi-line literal)",
      "kind": 15,
      "detail": "Multi-line literal string with triple single quotes",
      "documentation": {
        "value": "Multi-line literal strings are surrounded by three single quotes on each side and allow newlines. No escaping is performed."
      },
      "insertText": "${1:key} = '''\n${2:content}\n'''",
      "insertTextRules": 4,
      "sortText": "08_string_multiline_literal"
    },
    {
      "label": "integer",
      "kind": 14,
      "detail": "Integer value",
      "documentation": {
        "value": "Integers are whole numbers. Positive numbers may be prefixed with a plus sign. Underscores between digits are allowed for readability."
      },
      "insertText": "${1:key} = ${2:42}",
      "insertTextRules": 4,
      "sortText": "09_integer"
    },
    {
      "label": "float",
      "kind": 14,
      "detail": "Float value",
      "documentation": {
        "value": "Floats should be implemented as IEEE 754 64-bit values. A float consists of an integer part followed by a fractional part and/or an exponent part."
      },
      "insertText": "${1:key} = ${2:3.14}",
      "insertTextRules": 4,
      "sortText": "10_float"
    },
    {
      "label": "boolean",
      "kind": 14,
      "detail": "Boolean true/false",
      "documentation": {
        "value": "Booleans are just the tokens you're used to. Always lowercase: true or false."
      },
      "insertText": "${1:key} = ${2|true,false|}",
      "insertTextRules": 4,
      "sortText": "11_boolean"
    },
    {
      "label": "datetime (offset)",
      "kind": 14,
      "detail": "Offset Date-Time (RFC 3339)",
      "documentation": {
        "value": "An offset date-time specifies an exact instant in time with a timezone offset. Format: YYYY-MM-DDThh:mm:ss±hh:mm or YYYY-MM-DDThh:mm:ssZ."
      },
      "insertText": "${1:key} = ${2:2024-01-15T10:30:00+00:00}",
      "insertTextRules": 4,
      "sortText": "12_datetime_offset"
    },
    {
      "label": "datetime (local)",
      "kind": 14,
      "detail": "Local Date-Time",
      "documentation": {
        "value": "A local date-time omits the timezone offset. It represents a date-time without relation to a specific time zone. Format: YYYY-MM-DDThh:mm:ss."
      },
      "insertText": "${1:key} = ${2:2024-01-15T10:30:00}",
      "insertTextRules": 4,
      "sortText": "13_datetime_local"
    },
    {
      "label": "date (local)",
      "kind": 14,
      "detail": "Local Date",
      "documentation": {
        "value": "A local date represents a full calendar date without a time component. Format: YYYY-MM-DD."
      },
      "insertText": "${1:key} = ${2:2024-01-15}",
      "insertTextRules": 4,
      "sortText": "14_date_local"
    },
    {
      "label": "time (local)",
      "kind": 14,
      "detail": "Local Time",
      "documentation": {
        "value": "A local time represents a time of day without any date or timezone. Format: hh:mm:ss."
      },
      "insertText": "${1:key} = ${2:10:30:00}",
      "insertTextRules": 4,
      "sortText": "15_time_local"
    },
    {
      "label": "array",
      "kind": 15,
      "detail": "Array of values",
      "documentation": {
        "value": "Arrays are square brackets with values inside. Whitespace is ignored. Elements are separated by commas. Arrays can contain values of the same data types or mixed types."
      },
      "insertText": "${1:key} = [${2:\"value1\"}, ${3:\"value2\"}]",
      "insertTextRules": 4,
      "sortText": "16_array"
    },
    {
      "label": "# comment",
      "kind": 14,
      "detail": "Comment",
      "documentation": {
        "value": "A hash symbol marks the rest of the line as a comment. Comments can appear on their own line or at the end of a key-value pair."
      },
      "insertText": "# ${1:comment}",
      "insertTextRules": 4,
      "sortText": "17_comment"
    },
    {
      "label": "[package] (Cargo.toml)",
      "kind": 27,
      "detail": "Rust Cargo package metadata",
      "documentation": {
        "value": "Defines the Rust package metadata in Cargo.toml, including name, version, edition, authors, and more."
      },
      "insertText": "[package]\nname = \"${1:my-crate}\"\nversion = \"${2:0.1.0}\"\nedition = \"${3|2021,2024,2018,2015|}\"\ndescription = \"${4:A Rust project}\"\nlicense = \"${5:MIT}\"\nauthors = [\"${6:Author Name <email@example.com>}\"]\nrepository = \"${7:https://github.com/user/repo}\"",
      "insertTextRules": 4,
      "sortText": "20_cargo_package"
    },
    {
      "label": "[dependencies] (Cargo.toml)",
      "kind": 27,
      "detail": "Rust Cargo dependencies",
      "documentation": {
        "value": "Specifies runtime dependencies in Cargo.toml. Each dependency is a key-value pair of crate name and version or detailed specification."
      },
      "insertText": "[dependencies]\n${1:serde} = { version = \"${2:1.0}\", features = [\"${3:derive}\"] }\n${4:tokio} = { version = \"${5:1}\", features = [\"${6:full}\"] }",
      "insertTextRules": 4,
      "sortText": "21_cargo_dependencies"
    },
    {
      "label": "[dev-dependencies] (Cargo.toml)",
      "kind": 27,
      "detail": "Rust Cargo dev dependencies",
      "documentation": {
        "value": "Specifies development-only dependencies in Cargo.toml. These are only used for compiling tests, examples, and benchmarks."
      },
      "insertText": "[dev-dependencies]\n${1:criterion} = \"${2:0.5}\"",
      "insertTextRules": 4,
      "sortText": "22_cargo_dev_dependencies"
    },
    {
      "label": "[build-dependencies] (Cargo.toml)",
      "kind": 27,
      "detail": "Rust Cargo build dependencies",
      "documentation": {
        "value": "Specifies dependencies for build scripts (build.rs) in Cargo.toml."
      },
      "insertText": "[build-dependencies]\n${1:cc} = \"${2:1.0}\"",
      "insertTextRules": 4,
      "sortText": "23_cargo_build_dependencies"
    },
    {
      "label": "[features] (Cargo.toml)",
      "kind": 27,
      "detail": "Rust Cargo features",
      "documentation": {
        "value": "Conditional compilation features for the Rust crate. Features allow optional dependencies and conditional code compilation."
      },
      "insertText": "[features]\ndefault = [\"${1:std}\"]\n${2:full} = [\"${3:feature1}\", \"${4:feature2}\"]",
      "insertTextRules": 4,
      "sortText": "24_cargo_features"
    },
    {
      "label": "[workspace] (Cargo.toml)",
      "kind": 27,
      "detail": "Rust Cargo workspace",
      "documentation": {
        "value": "Defines a Cargo workspace for managing multiple related Rust packages. A workspace shares a common Cargo.lock and output directory."
      },
      "insertText": "[workspace]\nmembers = [\n\t\"${1:crate1}\",\n\t\"${2:crate2}\",\n]\nresolver = \"${3:2}\"",
      "insertTextRules": 4,
      "sortText": "25_cargo_workspace"
    },
    {
      "label": "[lib] (Cargo.toml)",
      "kind": 27,
      "detail": "Rust Cargo library target",
      "documentation": {
        "value": "Configures the library target for the Rust crate, including lib name, path, and crate-type."
      },
      "insertText": "[lib]\nname = \"${1:my_lib}\"\npath = \"${2:src/lib.rs}\"\ncrate-type = [\"${3|lib,cdylib,staticlib,dylib,rlib,proc-macro|}\"]",
      "insertTextRules": 4,
      "sortText": "26_cargo_lib"
    },
    {
      "label": "[[bin]] (Cargo.toml)",
      "kind": 27,
      "detail": "Rust Cargo binary target",
      "documentation": {
        "value": "Defines a binary target for the Rust crate. Multiple [[bin]] sections can define multiple binaries."
      },
      "insertText": "[[bin]]\nname = \"${1:my-bin}\"\npath = \"${2:src/main.rs}\"",
      "insertTextRules": 4,
      "sortText": "27_cargo_bin"
    },
    {
      "label": "[profile.release] (Cargo.toml)",
      "kind": 27,
      "detail": "Rust Cargo release profile",
      "documentation": {
        "value": "Customizes compiler settings for the release build profile in Cargo.toml. Common options include optimization level, LTO, and debug info."
      },
      "insertText": "[profile.release]\nopt-level = ${1|3,2,1,\"s\",\"z\"|}\nlto = ${2|true,false,\"thin\",\"fat\"|}\nstrip = ${3|true,false,\"symbols\",\"debuginfo\"|}",
      "insertTextRules": 4,
      "sortText": "28_cargo_profile_release"
    },
    {
      "label": "[profile.dev] (Cargo.toml)",
      "kind": 27,
      "detail": "Rust Cargo dev profile",
      "documentation": {
        "value": "Customizes compiler settings for the development build profile in Cargo.toml. Default profile used by `cargo build`."
      },
      "insertText": "[profile.dev]\nopt-level = ${1|0,1,2|}\ndebug = ${2|true,false,2,1,0|}",
      "insertTextRules": 4,
      "sortText": "29_cargo_profile_dev"
    },
    {
      "label": "[build-system] (pyproject.toml)",
      "kind": 27,
      "detail": "Python build system requirements",
      "documentation": {
        "value": "Specifies the build system requirements for a Python project as defined in PEP 517/518. Includes the build backend and its dependencies."
      },
      "insertText": "[build-system]\nrequires = [\"${1:setuptools>=68.0}\", \"${2:wheel}\"]\nbuild-backend = \"${3:setuptools.build_meta}\"",
      "insertTextRules": 4,
      "sortText": "30_pyproject_build_system"
    },
    {
      "label": "[project] (pyproject.toml)",
      "kind": 27,
      "detail": "Python project metadata",
      "documentation": {
        "value": "Core metadata for a Python project as defined in PEP 621. Includes name, version, description, Python version requirement, and dependencies."
      },
      "insertText": "[project]\nname = \"${1:my-project}\"\nversion = \"${2:0.1.0}\"\ndescription = \"${3:A Python project}\"\nrequires-python = \">=${4:3.9}\"\ndependencies = [\n\t\"${5:requests>=2.28}\",\n]",
      "insertTextRules": 4,
      "sortText": "31_pyproject_project"
    },
    {
      "label": "[project.optional-dependencies] (pyproject.toml)",
      "kind": 27,
      "detail": "Python optional dependency groups",
      "documentation": {
        "value": "Defines optional dependency groups for a Python project. Users can install these extras with pip install package[extra]."
      },
      "insertText": "[project.optional-dependencies]\n${1:dev} = [\n\t\"${2:pytest>=7.0}\",\n\t\"${3:black>=23.0}\",\n]\n${4:docs} = [\n\t\"${5:sphinx>=6.0}\",\n]",
      "insertTextRules": 4,
      "sortText": "32_pyproject_optional_deps"
    },
    {
      "label": "[tool.pytest.ini_options] (pyproject.toml)",
      "kind": 27,
      "detail": "Pytest configuration",
      "documentation": {
        "value": "Configures Pytest options within pyproject.toml. Replaces the traditional pytest.ini or setup.cfg configuration."
      },
      "insertText": "[tool.pytest.ini_options]\ntestpaths = [\"${1:tests}\"]\npython_files = [\"${2:test_*.py}\"]\naddopts = \"${3:-v --tb=short}\"",
      "insertTextRules": 4,
      "sortText": "33_pyproject_pytest"
    },
    {
      "label": "[tool.black] (pyproject.toml)",
      "kind": 27,
      "detail": "Black formatter configuration",
      "documentation": {
        "value": "Configures the Black Python code formatter within pyproject.toml."
      },
      "insertText": "[tool.black]\nline-length = ${1:88}\ntarget-version = [\"${2:py311}\"]\ninclude = '${3:\\.pyi?$}'",
      "insertTextRules": 4,
      "sortText": "34_pyproject_black"
    },
    {
      "label": "[tool.ruff] (pyproject.toml)",
      "kind": 27,
      "detail": "Ruff linter configuration",
      "documentation": {
        "value": "Configures the Ruff Python linter within pyproject.toml. Ruff is a fast Python linter written in Rust."
      },
      "insertText": "[tool.ruff]\nline-length = ${1:88}\ntarget-version = \"${2:py311}\"\n\n[tool.ruff.lint]\nselect = [\"${3:E}\", \"${4:F}\", \"${5:I}\"]\nignore = [\"${6:E501}\"]",
      "insertTextRules": 4,
      "sortText": "35_pyproject_ruff"
    },
    {
      "label": "[tool.mypy] (pyproject.toml)",
      "kind": 27,
      "detail": "Mypy type checker configuration",
      "documentation": {
        "value": "Configures the Mypy static type checker within pyproject.toml."
      },
      "insertText": "[tool.mypy]\npython_version = \"${1:3.11}\"\nstrict = ${2|true,false|}\nwarn_return_any = true\nwarn_unused_configs = true",
      "insertTextRules": 4,
      "sortText": "36_pyproject_mypy"
    },
    {
      "label": "[tool.setuptools] (pyproject.toml)",
      "kind": 27,
      "detail": "Setuptools configuration",
      "documentation": {
        "value": "Configures setuptools within pyproject.toml for package discovery and data files."
      },
      "insertText": "[tool.setuptools]\npackages = { find = { where = [\"${1:src}\"] } }\n\n[tool.setuptools.package-data]\n\"${2:*}\" = [\"${3:py.typed}\"]",
      "insertTextRules": 4,
      "sortText": "37_pyproject_setuptools"
    },
    {
      "label": "[tool.poetry] (pyproject.toml)",
      "kind": 27,
      "detail": "Poetry project configuration",
      "documentation": {
        "value": "Configures a Python project managed by Poetry within pyproject.toml. Includes project metadata and dependency management."
      },
      "insertText": "[tool.poetry]\nname = \"${1:my-project}\"\nversion = \"${2:0.1.0}\"\ndescription = \"${3:A Python project}\"\nauthors = [\"${4:Author Name <email@example.com>}\"]\nreadme = \"README.md\"\n\n[tool.poetry.dependencies]\npython = \"^${5:3.9}\"",
      "insertTextRules": 4,
      "sortText": "38_pyproject_poetry"
    },
    {
      "label": "[server]",
      "kind": 15,
      "detail": "Server configuration section",
      "documentation": {
        "value": "Common server configuration pattern with host, port, and TLS/SSL settings."
      },
      "insertText": "[server]\nhost = \"${1:0.0.0.0}\"\nport = ${2:8080}\nssl = ${3|true,false|}\ncert_file = \"${4:certs/server.crt}\"\nkey_file = \"${5:certs/server.key}\"",
      "insertTextRules": 4,
      "sortText": "40_config_server"
    },
    {
      "label": "[database]",
      "kind": 15,
      "detail": "Database configuration section",
      "documentation": {
        "value": "Common database configuration pattern with connection URL, pool settings, and timeouts."
      },
      "insertText": "[database]\nurl = \"${1:postgres://user:pass@localhost:5432/dbname}\"\npool_size = ${2:10}\nmax_idle = ${3:5}\ntimeout = ${4:30}",
      "insertTextRules": 4,
      "sortText": "41_config_database"
    },
    {
      "label": "[logging]",
      "kind": 15,
      "detail": "Logging configuration section",
      "documentation": {
        "value": "Common logging configuration pattern with log level, output file, and format."
      },
      "insertText": "[logging]\nlevel = \"${1|debug,info,warn,error|}\"\nfile = \"${2:logs/app.log}\"\nformat = \"${3|json,text,pretty|}\"",
      "insertTextRules": 4,
      "sortText": "42_config_logging"
    },
    {
      "label": "[auth]",
      "kind": 15,
      "detail": "Authentication configuration section",
      "documentation": {
        "value": "Common authentication configuration pattern with JWT secret, token expiry, and refresh settings."
      },
      "insertText": "[auth]\nsecret = \"${1:your-secret-key}\"\ntoken_expiry = ${2:3600}\nrefresh_expiry = ${3:86400}\nissuer = \"${4:my-app}\"",
      "insertTextRules": 4,
      "sortText": "43_config_auth"
    },
    {
      "label": "array (multi-line)",
      "kind": 15,
      "detail": "Multi-line array",
      "documentation": {
        "value": "Arrays can span multiple lines for readability. A trailing comma after the last value is allowed."
      },
      "insertText": "${1:key} = [\n\t\"${2:value1}\",\n\t\"${3:value2}\",\n\t\"${4:value3}\",\n]",
      "insertTextRules": 4,
      "sortText": "18_array_multiline"
    },
    {
      "label": "integer (hex)",
      "kind": 14,
      "detail": "Hexadecimal integer",
      "documentation": {
        "value": "Hexadecimal integers are prefixed with 0x. Underscores between digits are allowed."
      },
      "insertText": "${1:key} = 0x${2:DEADBEEF}",
      "insertTextRules": 4,
      "sortText": "09_integer_hex"
    },
    {
      "label": "integer (octal)",
      "kind": 14,
      "detail": "Octal integer",
      "documentation": {
        "value": "Octal integers are prefixed with 0o. Only digits 0-7 are allowed."
      },
      "insertText": "${1:key} = 0o${2:755}",
      "insertTextRules": 4,
      "sortText": "09_integer_oct"
    },
    {
      "label": "integer (binary)",
      "kind": 14,
      "detail": "Binary integer",
      "documentation": {
        "value": "Binary integers are prefixed with 0b. Only digits 0 and 1 are allowed."
      },
      "insertText": "${1:key} = 0b${2:11010110}",
      "insertTextRules": 4,
      "sortText": "09_integer_bin"
    },
    {
      "label": "float (inf/nan)",
      "kind": 14,
      "detail": "Special float values",
      "documentation": {
        "value": "TOML supports special float values: inf, +inf, -inf, nan, +nan, -nan for IEEE 754 special values."
      },
      "insertText": "${1:key} = ${2|inf,-inf,nan|}",
      "insertTextRules": 4,
      "sortText": "10_float_special"
    },
    {
      "label": "float (exponent)",
      "kind": 14,
      "detail": "Float with exponent notation",
      "documentation": {
        "value": "Floats can use E notation for exponents. Both 'e' and 'E' are accepted."
      },
      "insertText": "${1:key} = ${2:5e+22}",
      "insertTextRules": 4,
      "sortText": "10_float_exponent"
    },
    {
      "label": "offset_datetime",
      "kind": "value",
      "detail": "Offset date-time",
      "insertText": "${1:key} = ${2:1979}-${3:05}-${4:27}T${5:07}:${6:32}:${7:00}Z"
    },
    {
      "label": "local_datetime",
      "kind": "value",
      "detail": "Local date-time",
      "insertText": "${1:key} = ${2:1979}-${3:05}-${4:27}T${5:07}:${6:32}:${7:00}"
    },
    {
      "label": "local_date",
      "kind": "value",
      "detail": "Local date",
      "insertText": "${1:key} = ${2:1979}-${3:05}-${4:27}"
    },
    {
      "label": "local_time",
      "kind": "value",
      "detail": "Local time",
      "insertText": "${1:key} = ${2:07}:${3:32}:${4:00}"
    },
    {
      "label": "array_of_tables",
      "kind": "keyword",
      "detail": "Array of tables",
      "insertText": "[[${1:table}]]\n${2:key} = ${3:value}"
    },
    {
      "label": "dotted_key",
      "kind": "keyword",
      "detail": "Dotted key",
      "insertText": "${1:a}.${2:b} = ${3:value}"
    },
    {
      "label": "hex_integer",
      "kind": "value",
      "detail": "Hexadecimal integer",
      "insertText": "${1:key} = 0x${2:DEADBEEF}"
    },
    {
      "label": "octal_integer",
      "kind": "value",
      "detail": "Octal integer",
      "insertText": "${1:key} = 0o${2:755}"
    },
    {
      "label": "binary_integer",
      "kind": "value",
      "detail": "Binary integer",
      "insertText": "${1:key} = 0b${2:11010110}"
    },
    {
      "label": "inf",
      "kind": "value",
      "detail": "Infinity float",
      "insertText": "${1:key} = inf"
    },
    {
      "label": "nan",
      "kind": "value",
      "detail": "Not a number",
      "insertText": "${1:key} = nan"
    },
    {
      "label": "multiline_basic",
      "kind": "value",
      "detail": "Multi-line basic string",
      "insertText": "${1:key} = \"\"\"\\\n${2:content}\\\n\"\"\""
    }
  ]
}
