    {
      "label": "plpgsql_fn",
      "kind": 14,
      "detail": "snippet PL/pgSQL Function",
      "documentation": {
        "value": "PL/pgSQL function"
      },
      "insertText": "CREATE OR REPLACE FUNCTION ${1:func_name}(${2:param} ${3:INTEGER})\nRETURNS ${4:TABLE(col1 INTEGER)} AS $$\nBEGIN\n    ${0}\nEND;\n$$ LANGUAGE plpgsql;",
      "insertTextRules": 4,
      "sortText": "03_snip"
    },
    {
      "label": "cte",
      "kind": 14,
      "detail": "snippet WITH CTE",
      "documentation": {
        "value": "Common table expression"
      },
      "insertText": "WITH ${1:cte_name} AS (\n    SELECT ${2:columns}\n    FROM ${3:table}\n    WHERE ${4:condition}\n)\nSELECT * FROM ${1:cte_name};",
