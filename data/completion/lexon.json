    {
      "label": "payment clause",
      "kind": 28,
      "detail": "Payment clause",
      "documentation": {
        "value": "Payment obligation clause."
      },
      "insertText": "${1:Payer} SHALL PAY ${2:Amount} TO ${3:Payee} WITHIN ${4:30} DAYS OF ${5:Invoice Date}.",
      "insertTextRules": 4,
      "sortText": "05_clause"
    },
    {
      "label": "escrow",
      "kind": 28,
      "detail": "Escrow clause",
      "documentation": {
        "value": "Escrow agreement."
      },
      "insertText": "${1:Escrow Agent} SHALL HOLD ${2:Amount} IN ESCROW\nUNTIL ${3:Condition} IS SATISFIED,\nTHEN TRANSFER ${2:Amount} TO ${4:Beneficiary}.",
      "insertTextRules": 4,
      "sortText": "05_clause"
    },
    {
      "label": "service agreement",
      "kind": 28,
      "detail": "Service agreement",
      "documentation": {
        "value": "Service level agreement."
      },
      "insertText": "${1:Provider} SHALL PROVIDE ${2:Service}\nTO ${3:Client}\nFOR ${4:Duration}\nAT ${5:Fee} PER ${6:Month}.",
      "insertTextRules": 4,
      "sortText": "05_clause"
    },
    {
      "label": "NDA",
      "kind": 28,
      "detail": "NDA clause",
      "documentation": {
        "value": "Non-disclosure clause."
      },
      "insertText": "${1:Receiving Party} SHALL NOT DISCLOSE ${2:Confidential Information}\nTO ANY THIRD PARTY\nFOR A PERIOD OF ${3:2} YEARS.",
      "insertTextRules": 4,
      "sortText": "05_clause"
    },
    {
      "label": "license grant",
      "kind": 28,
      "detail": "License grant",
      "documentation": {
        "value": "License grant clause."
      },
      "insertText": "${1:Licensor} GRANTS ${2:Licensee}\nA ${3|non-exclusive,exclusive|} LICENSE\nTO USE ${4:Licensed Material}\nFOR ${5:Purpose}.",
      "insertTextRules": 4,
      "sortText": "05_clause"
    },
    {
      "label": "warranty",
      "kind": 28,
      "detail": "Warranty clause",
      "documentation": {
        "value": "Warranty provision."
      },
      "insertText": "${1:Warrantor} WARRANTS THAT ${2:Subject}\nSHALL BE FREE FROM DEFECTS\nFOR A PERIOD OF ${3:12} MONTHS FROM ${4:Delivery Date}.",
      "insertTextRules": 4,
      "sortText": "05_clause"
    },
    {
      "label": "indemnity",
      "kind": 28,
      "detail": "Indemnity clause",
      "documentation": {
        "value": "Indemnification clause."
      },
      "insertText": "${1:Indemnitor} SHALL INDEMNIFY ${2:Indemnitee}\nAGAINST ALL ${3:Claims, Damages, and Expenses}\nARISING FROM ${4:Breach of this Agreement}.",
      "insertTextRules": 4,
      "sortText": "05_clause"
    },
    {
      "label": "termination",
      "kind": 28,
      "detail": "Termination clause",
      "documentation": {
        "value": "Termination provision."
      },
      "insertText": "EITHER PARTY MAY TERMINATE THIS AGREEMENT\nBY PROVIDING ${1:30} DAYS WRITTEN NOTICE\nIF ${2:the other Party} BREACHES ${3:any Material Term}.",
      "insertTextRules": 4,
      "sortText": "05_clause"
    },
    {
      "label": "force majeure",
      "kind": 28,
      "detail": "Force majeure",
      "documentation": {
        "value": "Force majeure clause."
      },
      "insertText": "NEITHER PARTY SHALL BE LIABLE FOR\nFAILURE TO PERFORM OBLIGATIONS\nIF CAUSED BY ${1:Force Majeure Events}\nINCLUDING ${2:natural disasters, pandemics, or government actions}.",
      "insertTextRules": 4,
      "sortText": "05_clause"
    },
    {
      "label": "penalty",
      "kind": 28,
      "detail": "Penalty clause",
      "documentation": {
        "value": "Penalty for breach."
      },
      "insertText": "IF ${1:Party} FAILS TO ${2:Perform Obligation},\n${1:Party} SHALL PAY ${3:Penalty Amount}\nAS LIQUIDATED DAMAGES TO ${4:Other Party}.",
      "insertTextRules": 4,
      "sortText": "05_clause"
    },
    {
      "label": "assignment",
      "kind": 28,
      "detail": "Assignment clause",
      "documentation": {
        "value": "Assignment restriction."
      },
      "insertText": "${1:Party} SHALL NOT ASSIGN THIS AGREEMENT\nWITHOUT PRIOR WRITTEN CONSENT OF ${2:Other Party}.",
      "insertTextRules": 4,
      "sortText": "05_clause"
    },
    {
      "label": "governing law",
      "kind": 28,
      "detail": "Governing law",
      "documentation": {
        "value": "Choice of law clause."
      },
      "insertText": "THIS AGREEMENT SHALL BE GOVERNED BY\nTHE LAWS OF ${1:Jurisdiction}.",
      "insertTextRules": 4,
      "sortText": "05_clause"
    },
    {
      "label": "dispute resolution",
      "kind": 28,
      "detail": "Dispute resolution",
      "documentation": {
        "value": "Dispute resolution provision."
      },
      "insertText": "ANY DISPUTE ARISING UNDER THIS AGREEMENT\nSHALL BE RESOLVED BY ${1|Arbitration,Mediation,Litigation|}\nIN ${2:Venue}.",
      "insertTextRules": 4,
      "sortText": "05_clause"
    },
    {
      "label": "entire agreement",
      "kind": 28,
      "detail": "Entire agreement",
      "documentation": {
        "value": "Integration clause."
      },
      "insertText": "THIS AGREEMENT CONSTITUTES THE ENTIRE AGREEMENT\nBETWEEN THE PARTIES AND SUPERSEDES\nALL PRIOR ${1:Agreements and Understandings}.",
      "insertTextRules": 4,
      "sortText": "05_clause"
    },
    {
      "label": "amendment",
      "kind": 28,
      "detail": "Amendment clause",
      "documentation": {
        "value": "Amendment provision."
      },
      "insertText": "THIS AGREEMENT MAY ONLY BE AMENDED\nBY WRITTEN INSTRUMENT SIGNED BY ${1:Both Parties}.",
      "insertTextRules": 4,
      "sortText": "05_clause"
    },
    {
      "label": "severability",
      "kind": 28,
      "detail": "Severability",
      "documentation": {
        "value": "Severability clause."
      },
      "insertText": "IF ANY PROVISION OF THIS AGREEMENT\nIS HELD TO BE INVALID OR UNENFORCEABLE,\nTHE REMAINING PROVISIONS SHALL CONTINUE IN FULL FORCE.",
      "insertTextRules": 4,
      "sortText": "05_clause"
    },
    {
      "label": "waiver",
      "kind": 28,
      "detail": "Waiver clause",
      "documentation": {
        "value": "Waiver provision."
      },
      "insertText": "FAILURE OF ${1:Party} TO ENFORCE ANY PROVISION\nSHALL NOT CONSTITUTE A WAIVER OF ${2:that Provision}.",
      "insertTextRules": 4,
      "sortText": "05_clause"
    },
    {
      "label": "notice",
      "kind": 28,
      "detail": "Notice clause",
      "documentation": {
        "value": "Notice requirement."
      },
      "insertText": "ALL NOTICES UNDER THIS AGREEMENT SHALL BE\nIN WRITING AND DELIVERED TO ${1:Address}\nBY ${2|certified mail,email,courier|}.",
      "insertTextRules": 4,
      "sortText": "05_clause"
    },
    {
      "label": "renewal",
      "kind": 28,
      "detail": "Auto-renewal",
      "documentation": {
        "value": "Auto-renewal clause."
      },
      "insertText": "THIS AGREEMENT SHALL AUTOMATICALLY RENEW\nFOR SUCCESSIVE ${1:1}-YEAR TERMS\nUNLESS ${2:Either Party} PROVIDES ${3:60} DAYS NOTICE OF NON-RENEWAL.",
      "insertTextRules": 4,
      "sortText": "05_clause"
    },
    {
      "label": "insurance",
      "kind": 28,
      "detail": "Insurance requirement",
      "documentation": {
        "value": "Insurance obligation."
      },
      "insertText": "${1:Party} SHALL MAINTAIN ${2:Insurance Coverage}\nIN THE AMOUNT OF AT LEAST ${3:Amount}\nFOR THE DURATION OF THIS AGREEMENT.",
      "insertTextRules": 4,
      "sortText": "05_clause"
    },
    {
      "label": "compliance",
      "kind": 28,
      "detail": "Compliance clause",
      "documentation": {
        "value": "Regulatory compliance."
      },
      "insertText": "${1:Party} SHALL COMPLY WITH ALL APPLICABLE\n${2:Laws, Regulations, and Industry Standards}.",
      "insertTextRules": 4,
      "sortText": "05_clause"
    }
  ]
}