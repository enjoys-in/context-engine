    {
      "label": "aws_instance",
      "kind": 15,
      "detail": "AWS EC2 instance",
      "documentation": {
        "value": "AWS EC2 instance resource."
      },
      "insertText": "resource \"aws_instance\" \"${1:web}\" {\n  ami           = \"${2:ami-0c55b159cbfafe1f0}\"\n  instance_type = \"${3:t2.micro}\"\n  key_name      = \"${4:my-key}\"\n\n  tags = {\n    Name = \"${1:web}\"\n  }\n}",
