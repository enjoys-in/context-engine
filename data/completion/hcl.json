    {
      "label": "aws_vpc",
      "kind": 28,
      "detail": "AWS VPC",
      "documentation": {
        "value": "AWS VPC resource."
      },
      "insertText": "resource \"aws_vpc\" \"${1:main}\" {\n  cidr_block = \"${2:10.0.0.0/16}\"\n\n  tags = {\n    Name = \"${1:main}\"\n  }\n}",
      "insertTextRules": 4,
      "sortText": "04_aws"
    },
    {
      "label": "aws_subnet",
      "kind": 28,
      "detail": "AWS Subnet",
      "documentation": {
        "value": "AWS subnet resource."
      },
      "insertText": "resource \"aws_subnet\" \"${1:public}\" {\n  vpc_id            = aws_vpc.${2:main}.id\n  cidr_block        = \"${3:10.0.1.0/24}\"\n  availability_zone = \"${4:us-east-1a}\"\n\n  tags = {\n    Name = \"${1:public}\"\n  }\n}",
      "insertTextRules": 4,
      "sortText": "04_aws"
    },
    {
      "label": "aws_iam_role",
      "kind": 28,
      "detail": "AWS IAM role",
      "documentation": {
        "value": "IAM role resource."
      },
      "insertText": "resource \"aws_iam_role\" \"${1:role}\" {\n  name = \"${1:role}\"\n\n  assume_role_policy = jsonencode({\n    Version = \"2012-10-17\"\n    Statement = [{\n      Action = \"sts:AssumeRole\"\n      Effect = \"Allow\"\n      Principal = {\n        Service = \"${2:lambda.amazonaws.com}\"\n      }\n    }]\n  })\n}",
      "insertTextRules": 4,
      "sortText": "04_aws"
    },
    {
      "label": "aws_lambda",
      "kind": 28,
      "detail": "AWS Lambda",
      "documentation": {
        "value": "Lambda function resource."
      },
      "insertText": "resource \"aws_lambda_function\" \"${1:func}\" {\n  filename      = \"${2:lambda.zip}\"\n  function_name = \"${1:func}\"\n  role          = aws_iam_role.${3:role}.arn\n  handler       = \"${4:index.handler}\"\n  runtime       = \"${5:nodejs18.x}\"\n}",
      "insertTextRules": 4,
      "sortText": "04_aws"
    },
    {
      "label": "aws_rds",
      "kind": 28,
      "detail": "AWS RDS",
      "documentation": {
        "value": "RDS database instance."
      },
      "insertText": "resource \"aws_db_instance\" \"${1:db}\" {\n  identifier        = \"${1:db}\"\n  engine            = \"${2:postgres}\"\n  engine_version    = \"${3:15}\"\n  instance_class    = \"${4:db.t3.micro}\"\n  allocated_storage = ${5:20}\n  db_name           = \"${6:mydb}\"\n  username          = var.db_username\n  password          = var.db_password\n  skip_final_snapshot = true\n}",
      "insertTextRules": 4,
      "sortText": "04_aws"
    },
    {
      "label": "aws_lb",
      "kind": 28,
      "detail": "AWS ALB",
      "documentation": {
