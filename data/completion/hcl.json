      },
      "insertText": "resource \"aws_lb\" \"${1:alb}\" {\n  name               = \"${1:alb}\"\n  internal           = false\n  load_balancer_type = \"application\"\n  security_groups    = [aws_security_group.${2:sg}.id]\n  subnets            = aws_subnet.${3:public}[*].id\n}",
      "insertTextRules": 4,
      "sortText": "04_aws"
    },
