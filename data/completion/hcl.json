      "documentation": {
        "value": "Generate repeated nested blocks dynamically."
      },
      "insertText": "dynamic \"${1:block_name}\" {\n  for_each = ${2:var.items}\n  content {\n    ${3:key} = ${1:block_name}.value\n  }\n}",
      "insertTextRules": 4,
      "sortText": "02_dynamic"
