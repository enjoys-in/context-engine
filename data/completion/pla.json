      "insertText": "module ${1:name}(\n    input ${2:clk},\n    input ${3:rst},\n    input [${4:7}:0] ${5:data_in},\n    output reg [${4:7}:0] ${6:data_out}\n);\n\n${7:// logic}\n\nendmodule",
