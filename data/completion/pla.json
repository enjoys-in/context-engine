      "detail": "Full adder",
      "documentation": {
        "value": "Full adder module."
      },
      "insertText": "module full_adder(\n    input ${1:a}, ${2:b}, ${3:cin},\n    output ${4:sum}, ${5:cout}\n);\n    assign ${4:sum} = ${1:a} ^ ${2:b} ^ ${3:cin};\n    assign ${5:cout} = (${1:a} & ${2:b}) | (${3:cin} & (${1:a} ^ ${2:b}));\nendmodule",
