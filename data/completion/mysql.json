      "detail": "snippet SELECT JOIN",
      "documentation": {
        "value": "Select with join"
      },
      "insertText": "SELECT ${1:a.*}, ${2:b.column}\nFROM ${3:table_a} a\nINNER JOIN ${4:table_b} b ON a.${5:id} = b.${6:foreign_id}\nWHERE ${7:condition};",
