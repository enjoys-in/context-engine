      "insertText": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<web-app xmlns=\"http://xmlns.jcp.org/xml/ns/javaee\" version=\"4.0\">\n  <servlet>\n    <servlet-name>${1:app}</servlet-name>\n    <servlet-class>${2:com.example.MyServlet}</servlet-class>\n  </servlet>\n  <servlet-mapping>\n    <servlet-name>${1:app}</servlet-name>\n    <url-pattern>${3:/api/*}</url-pattern>\n  </servlet-mapping>\n</web-app>",
      "insertTextRules": 4,
      "sortText": "06_java"
    },
    {
      "label": "AndroidManifest",
      "kind": 28,
      "detail": "Android manifest",
      "documentation": {
        "value": "Android manifest template."
