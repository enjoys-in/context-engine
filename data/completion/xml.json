      "label": "plugin",
      "kind": 28,
      "detail": "Maven plugin",
      "documentation": {
        "value": "Maven build plugin."
      },
      "insertText": "<plugin>\n  <groupId>${1:org.apache.maven.plugins}</groupId>\n  <artifactId>${2:maven-compiler-plugin}</artifactId>\n  <version>${3:3.11.0}</version>\n  <configuration>\n    <source>${4:17}</source>\n    <target>${4:17}</target>\n  </configuration>\n</plugin>",
      "insertTextRules": 4,
      "sortText": "06_maven"
    },
