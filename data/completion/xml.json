      "insertText": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<urlset xmlns=\"http://www.sitemaps.org/schemas/sitemap/0.9\">\n  <url>\n    <loc>${1:https://example.com/}</loc>\n    <lastmod>${2:2024-01-01}</lastmod>\n    <changefreq>${3:weekly}</changefreq>\n    <priority>${4:1.0}</priority>\n  </url>\n</urlset>",
