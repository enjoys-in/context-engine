      "insertText": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Configuration status=\"WARN\">\n  <Appenders>\n    <Console name=\"Console\" target=\"SYSTEM_OUT\">\n      <PatternLayout pattern=\"%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n\" />\n    </Console>\n  </Appenders>\n  <Loggers>\n    <Root level=\"${1:info}\">\n      <AppenderRef ref=\"Console\" />\n    </Root>\n  </Loggers>\n</Configuration>",
      "insertTextRules": 4,
      "sortText": "08_config"
    },
