    {
      "label": "xs:schema",
      "kind": 28,
      "detail": "XSD schema",
      "documentation": {
        "value": "XML Schema root element."
      },
      "insertText": "<xs:schema xmlns:xs=\"http://www.w3.org/2001/XMLSchema\"\n  targetNamespace=\"${1:http://example.com}\"\n  elementFormDefault=\"qualified\">\n  ${2}\n</xs:schema>",
      "insertTextRules": 4,
      "sortText": "03_xsd"
    },
