      "insertText": "<xs:complexType name=\"${1:TypeName}\">\n  <xs:sequence>\n    <xs:element name=\"${2:field}\" type=\"${3:xs:string}\" />\n  </xs:sequence>\n</xs:complexType>",
      "insertTextRules": 4,
      "sortText": "03_xsd"
