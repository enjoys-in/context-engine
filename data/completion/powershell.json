    {
      "label": "function",
      "kind": 15,
      "detail": "Function",
      "documentation": {
        "value": "Define a PowerShell function."
      },
      "insertText": "function ${1:Name} {\n    param(\n        [Parameter(Mandatory)]\n        [string]$${2:Param}\n    )\n    ${3:# body}\n}",
      "insertTextRules": 4,
      "sortText": "00_func"
    },
