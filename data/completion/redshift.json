    {
      "label": "copy_s3",
      "kind": 14,
      "detail": "snippet COPY from S3",
      "documentation": {
        "value": "Load data from S3"
      },
      "insertText": "COPY ${1:table}\nFROM 's3://${2:bucket}/${3:path}'\nIAM_ROLE '${4:arn:aws:iam::account:role/role}'\nFORMAT AS ${5|PARQUET,CSV,JSON|};",
      "insertTextRules": 4,
      "sortText": "03_snip"
    },
    {
      "label": "unload_s3",
      "kind": 14,
      "detail": "snippet UNLOAD to S3",
      "documentation": {
        "value": "Unload data to S3"
      },
      "insertText": "UNLOAD ('SELECT * FROM ${1:table}')\nTO 's3://${2:bucket}/${3:path}'\nIAM_ROLE '${4:arn}'\nFORMAT AS PARQUET;",
      "insertTextRules": 4,
      "sortText": "03_snip"
    },
    {
      "label": "create_table",
      "kind": 14,
      "detail": "snippet CREATE TABLE",
      "documentation": {
        "value": "Create Redshift table"
      },
      "insertText": "CREATE TABLE ${1:schema}.${2:table} (\n    ${3:id} INTEGER IDENTITY(1,1),\n    ${4:column} VARCHAR(${5:256})\n)\nDISTSTYLE ${6|AUTO,KEY,EVEN,ALL|}\nSORTKEY (${7:column});",
      "insertTextRules": 4,
      "sortText": "03_snip"
    }
