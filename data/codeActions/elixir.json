{
  "language": "elixir",
  "codeActions": [
    {
      "title": "Extract to variable",
      "kind": "refactor.extract",
      "description": "Extract expression into a variable",
      "pattern": ".*",
      "isPreferred": false
    },
    {
      "title": "Fix all auto-fixable problems",
      "kind": "source.fixAll",
      "description": "Apply all available quick-fixes",
      "pattern": ".*",
      "isPreferred": false
    },
    {
      "title": "Extract to function",
      "kind": "refactor.extract",
      "description": "Extract expression into a new function",
      "pattern": ".*",
      "isPreferred": false
    },
    {
      "title": "Convert to pipe operator",
      "kind": "refactor",
      "description": "Refactor nested calls to pipe syntax",
      "pattern": "\\w+\\(\\w+\\(",
      "isPreferred": false
    },
    {
      "title": "Add typespec",
      "kind": "quickfix",
      "description": "Add @spec annotation to function",
      "pattern": "def\\s+\\w+",
      "isPreferred": false
    }
  ],
  "providedCodeActionKinds": [
    "quickfix",
    "refactor",
    "refactor.extract",
    "source",
    "source.fixAll"
  ]
}
