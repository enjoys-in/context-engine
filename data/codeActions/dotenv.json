{
  "language": "dotenv",
  "codeActions": [
    {
      "title": "Extract to variable",
      "kind": "refactor.extract",
      "description": "Extract expression into a variable",
      "pattern": ".*",
      "isPreferred": false
    },
    {
      "title": "Fix all auto-fixable problems",
      "kind": "source.fixAll",
      "description": "Apply all available quick-fixes",
      "pattern": ".*",
      "isPreferred": false
    },
    {
      "title": "Quote value",
      "kind": "quickfix",
      "description": "Wrap value in quotes",
      "pattern": "=\\s*[^\"']",
      "isPreferred": true
    },
    {
      "title": "Unquote value",
      "kind": "quickfix",
      "description": "Remove quotes from value",
      "pattern": "=\\s*[\"']",
      "isPreferred": false
    },
    {
      "title": "Sort variables",
      "kind": "source.organizeImports",
      "description": "Sort environment variables alphabetically",
      "pattern": "^\\w+=",
      "isPreferred": false
    }
  ],
  "providedCodeActionKinds": [
    "quickfix",
    "refactor",
    "refactor.extract",
    "refactor.inline",
    "source",
    "source.fixAll",
    "source.organizeImports"
  ]
}
