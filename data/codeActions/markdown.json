{
  "language": "markdown",
  "codeActions": [
    {
      "title": "Extract to variable",
      "kind": "refactor.extract",
      "description": "Extract expression into a variable",
      "pattern": ".*",
      "isPreferred": false
    },
    {
      "title": "Fix all auto-fixable problems",
      "kind": "source.fixAll",
      "description": "Apply all available quick-fixes",
      "pattern": ".*",
      "isPreferred": false
    },
    {
      "title": "Toggle heading level",
      "kind": "refactor",
      "description": "Increase or decrease heading level",
      "pattern": "^#+\\s",
      "isPreferred": false
    },
    {
      "title": "Convert to link",
      "kind": "refactor",
      "description": "Convert URL text to markdown link",
      "pattern": "https?://",
      "isPreferred": false
    },
    {
      "title": "Convert list style",
      "kind": "refactor",
      "description": "Toggle between ordered and unordered list",
      "pattern": "^\\s*[-*\\d]",
      "isPreferred": false
    }
  ],
  "providedCodeActionKinds": [
    "quickfix",
    "refactor",
    "refactor.extract",
    "refactor.inline",
    "source",
    "source.fixAll"
  ]
}
