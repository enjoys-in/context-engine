{
  "language": "yaml",
  "codeActions": [
    {
      "title": "Extract to variable",
      "kind": "refactor.extract",
      "description": "Extract expression into a variable",
      "pattern": ".*",
      "isPreferred": false
    },
    {
      "title": "Fix all auto-fixable problems",
      "kind": "source.fixAll",
      "description": "Apply all available quick-fixes",
      "pattern": ".*",
      "isPreferred": false
    },
    {
      "title": "Convert to flow style",
      "kind": "refactor",
      "description": "Convert block mapping to flow style",
      "pattern": ":\\s*$",
      "isPreferred": false
    },
    {
      "title": "Convert to block style",
      "kind": "refactor",
      "description": "Convert flow mapping to block style",
      "pattern": "\\{.*\\}",
      "isPreferred": false
    },
    {
      "title": "Sort keys",
      "kind": "source.organizeImports",
      "description": "Sort YAML keys alphabetically",
      "pattern": "\\w+:",
      "isPreferred": false
    }
  ],
  "providedCodeActionKinds": [
    "quickfix",
    "refactor",
    "refactor.extract",
    "refactor.inline",
    "source",
    "source.fixAll",
    "source.organizeImports"
  ]
}
