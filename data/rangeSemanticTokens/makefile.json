{
  "language": "makefile",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "property", "function", "macro", "keyword", "comment", "string", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "function",
      "pattern": "^([a-zA-Z_][a-zA-Z0-9_.-]*)\\s*:",
      "modifiers": ["declaration"],
      "description": "Make target declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "variable",
      "pattern": "^([A-Z_][A-Z0-9_]*)\\s*[:?+]?=",
      "modifiers": ["declaration"],
      "description": "Variable assignments (=, :=, ?=, +=)",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "^\\t(.+)$",
      "modifiers": [],
      "description": "Recipe commands (tab-indented lines)",
      "rangeScope": "block"
    },
    {
      "type": "macro",
      "pattern": "\\$[@<^?*%+|]",
      "modifiers": ["readonly", "defaultLibrary"],
      "description": "Automatic variables ($@, $<, $^, etc.)",
      "rangeScope": "expression"
    },
    {
      "type": "variable",
      "pattern": "\\$\\(([a-zA-Z_][a-zA-Z0-9_]*)\\)",
      "modifiers": [],
      "description": "Variable references $(VAR)",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "^(\\.PHONY|\\.DEFAULT|\\.PRECIOUS|\\.INTERMEDIATE|\\.SECONDARY|\\.SUFFIXES)\\s*:",
      "modifiers": ["defaultLibrary"],
      "description": "Special built-in targets",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\b(include|sinclude|-include|ifdef|ifndef|ifeq|ifneq|else|endif|define|endef|override|export|unexport|vpath)\\b",
      "modifiers": [],
      "description": "Make directives",
      "rangeScope": "statement"
    },
    {
      "type": "comment",
      "pattern": "#.*$",
      "modifiers": [],
      "description": "Comments",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}