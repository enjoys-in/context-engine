{
  "language": "html",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["type", "variable", "property", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly"]
  },
  "rangeTokenRules": [
    {
      "type": "keyword",
      "pattern": "<([a-zA-Z][a-zA-Z0-9-]*)(?:\\s|>|/>)",
      "modifiers": [],
      "description": "Opening HTML tags",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "</([a-zA-Z][a-zA-Z0-9-]*)>",
      "modifiers": [],
      "description": "Closing HTML tags",
      "rangeScope": "block"
    },
    {
      "type": "property",
      "pattern": "\\b([a-zA-Z_:-][a-zA-Z0-9_:-]*)\\s*=",
      "modifiers": [],
      "description": "HTML attribute names",
      "rangeScope": "expression"
    },
    {
      "type": "string",
      "pattern": "&[a-zA-Z]+;|&#[0-9]+;|&#x[0-9a-fA-F]+;",
      "modifiers": [],
      "description": "HTML entities",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "<script[^>]*>[\\s\\S]*?</script>",
      "modifiers": [],
      "description": "Script blocks",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "<style[^>]*>[\\s\\S]*?</style>",
      "modifiers": [],
      "description": "Style blocks",
      "rangeScope": "block"
    },
    {
      "type": "comment",
      "pattern": "<!--[\\s\\S]*?-->",
      "modifiers": [],
      "description": "HTML comments",
      "rangeScope": "block"
    },
    {
      "type": "type",
      "pattern": "<!DOCTYPE\\s+[^>]+>",
      "modifiers": [],
      "description": "DOCTYPE declaration",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}