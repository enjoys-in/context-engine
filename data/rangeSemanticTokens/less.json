{
  "language": "less",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "property", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly"]
  },
  "rangeTokenRules": [
    {
      "type": "variable",
      "pattern": "@([a-zA-Z_-][a-zA-Z0-9_-]*)\\s*:",
      "modifiers": ["declaration"],
      "description": "Less variable declarations @var: value",
      "rangeScope": "declaration"
    },
    {
      "type": "variable",
      "pattern": "@([a-zA-Z_-][a-zA-Z0-9_-]*)",
      "modifiers": [],
      "description": "Less variable references",
      "rangeScope": "expression"
    },
    {
      "type": "function",
      "pattern": "\\.([a-zA-Z_-][a-zA-Z0-9_-]*)\\s*\\(",
      "modifiers": ["declaration"],
      "description": "Mixin definitions and calls",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "([.#&][a-zA-Z_-][a-zA-Z0-9_-]*(?:\\s*[>+~]\\s*[.#&]?[a-zA-Z_-][a-zA-Z0-9_-]*)*)",
      "modifiers": [],
      "description": "CSS selectors",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\bwhen\\s*\\(",
      "modifiers": [],
      "description": "Mixin guards",
      "rangeScope": "expression"
    },
    {
      "type": "property",
      "pattern": "\\b([a-z-]+)\\s*:",
      "modifiers": [],
      "description": "CSS property declarations",
      "rangeScope": "statement"
    },
    {
      "type": "function",
      "pattern": "\\b(darken|lighten|saturate|desaturate|fadein|fadeout|mix|contrast)\\s*\\(",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in Less functions",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "@(import|media|charset|keyframes)\\b",
      "modifiers": [],
      "description": "At-rules",
      "rangeScope": "statement"
    },
    {
      "type": "comment",
      "pattern": "//.*$|/\\*[\\s\\S]*?\\*/",
      "modifiers": [],
      "description": "Single and multi-line comments",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}