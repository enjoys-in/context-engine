{
  "language": "dotenv",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "documentation"]
  },
  "rangeTokenRules": [
    {
      "type": "variable",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*=.*$",
      "modifiers": ["declaration"],
      "description": "Key=value assignment statements",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "^export\\s+[A-Za-z_][A-Za-z0-9_]*=.*$",
      "modifiers": ["declaration"],
      "description": "Exported variable declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "comment",
      "pattern": "^\\s*#.*$",
      "modifiers": ["documentation"],
      "description": "Comment lines",
      "rangeScope": "statement"
    },
    {
      "type": "string",
      "pattern": "\"[^\"]*\"|'[^']*'",
      "modifiers": [],
      "description": "Quoted value strings",
      "rangeScope": "expression"
    },
    {
      "type": "variable",
      "pattern": "\\$\\{[^}]+\\}|\\$[A-Za-z_][A-Za-z0-9_]*",
      "modifiers": [],
      "description": "Variable reference/interpolation expressions",
      "rangeScope": "expression"
    },
    {
      "type": "string",
      "pattern": "\"[^\"]*\\n[^\"]*\"",
      "modifiers": [],
      "description": "Multiline quoted values",
      "rangeScope": "expression"
    }
  ],
  "supportedRangeScopes": ["statement", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
