{
  "language": "c",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["type", "enum", "struct", "parameter", "variable", "property", "enumMember", "function", "macro", "keyword", "modifier", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "modification", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "function",
      "pattern": "\\b\\w+\\s+\\w+\\s*\\([^)]*\\)\\s*\\{[\\s\\S]*?\\}",
      "modifiers": ["definition"],
      "description": "Function body definitions",
      "rangeScope": "block"
    },
    {
      "type": "type",
      "pattern": "\\btypedef\\s+[^;]+;",
      "modifiers": ["declaration"],
      "description": "Typedef declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "struct",
      "pattern": "\\bstruct\\s+\\w+\\s*\\{[\\s\\S]*?\\}",
      "modifiers": ["declaration"],
      "description": "Struct declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "enum",
      "pattern": "\\benum\\s+\\w*\\s*\\{[\\s\\S]*?\\}",
      "modifiers": ["declaration"],
      "description": "Enum declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "macro",
      "pattern": "#\\s*(define|ifdef|ifndef|if|elif|else|endif|include|pragma)\\b[^\\n]*",
      "modifiers": [],
      "description": "Preprocessor directive statements",
      "rangeScope": "statement"
    },
    {
      "type": "variable",
      "pattern": "\\b(int|char|float|double|long|short|unsigned|void|size_t)\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Variable declaration expressions",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\bif\\s*\\([^)]*\\)\\s*\\{[\\s\\S]*?\\}",
      "modifiers": [],
      "description": "If conditional blocks",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\b(for|while)\\s*\\([^)]*\\)\\s*\\{[\\s\\S]*?\\}",
      "modifiers": [],
      "description": "Loop blocks",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\bswitch\\s*\\([^)]*\\)\\s*\\{[\\s\\S]*?\\}",
      "modifiers": [],
      "description": "Switch statement blocks",
      "rangeScope": "block"
    },
    {
      "type": "function",
      "pattern": "\\b\\w+\\s+\\w+\\s*\\([^)]*\\)\\s*;",
      "modifiers": ["declaration"],
      "description": "Function prototype declarations",
      "rangeScope": "declaration"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
