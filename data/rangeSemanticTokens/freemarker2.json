{
  "language": "freemarker2",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "property", "function", "macro", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "keyword",
      "pattern": "<#(if|else|elseif|list|switch|case|break|default|assign|local|global)\\b",
      "modifiers": [],
      "description": "FreeMarker directives like <#if>, <#list>",
      "rangeScope": "block"
    },
    {
      "type": "function",
      "pattern": "\\?([a-z_]+)",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in functions like ?string, ?number, ?size",
      "rangeScope": "expression"
    },
    {
      "type": "variable",
      "pattern": "\\$\\{([a-zA-Z_][a-zA-Z0-9_.]*)\\}",
      "modifiers": [],
      "description": "Interpolation expressions ${var}",
      "rangeScope": "expression"
    },
    {
      "type": "macro",
      "pattern": "<#macro\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "modifiers": ["declaration"],
      "description": "Macro definitions",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "</#([a-z]+)>",
      "modifiers": [],
      "description": "Closing directive tags",
      "rangeScope": "block"
    },
    {
      "type": "function",
      "pattern": "<@([a-zA-Z_][a-zA-Z0-9_]*)",
      "modifiers": [],
      "description": "User-defined directive calls",
      "rangeScope": "expression"
    },
    {
      "type": "comment",
      "pattern": "<#--[\\s\\S]*?-->",
      "modifiers": [],
      "description": "FreeMarker comments",
      "rangeScope": "block"
    },
    {
      "type": "string",
      "pattern": "\"(?:[^\"\\\\]|\\\\.)*\"",
      "modifiers": [],
      "description": "String literals",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "<#import\\s+",
      "modifiers": [],
      "description": "Import directives",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}