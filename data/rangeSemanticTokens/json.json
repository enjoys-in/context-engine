{
  "language": "json",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["property", "string", "number", "keyword", "operator"],
    "tokenModifiers": ["readonly"]
  },
  "rangeTokenRules": [
    {
      "type": "property",
      "pattern": "\"([^\"]+)\"\\s*:",
      "modifiers": ["readonly"],
      "description": "JSON object keys",
      "rangeScope": "expression"
    },
    {
      "type": "string",
      "pattern": ":\\s*\"([^\"\\\\]|\\\\.)*\"",
      "modifiers": [],
      "description": "String values",
      "rangeScope": "expression"
    },
    {
      "type": "number",
      "pattern": ":\\s*-?[0-9]+(?:\\.[0-9]+)?(?:[eE][+-]?[0-9]+)?",
      "modifiers": [],
      "description": "Numeric values",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": ":\\s*(true|false|null)\\b",
      "modifiers": ["readonly"],
      "description": "Boolean and null literal values",
      "rangeScope": "expression"
    },
    {
      "type": "operator",
      "pattern": "\\[",
      "modifiers": [],
      "description": "Array opening brackets",
      "rangeScope": "block"
    },
    {
      "type": "operator",
      "pattern": "\\{",
      "modifiers": [],
      "description": "Object opening braces",
      "rangeScope": "block"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["string"]
}