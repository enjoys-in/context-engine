{
  "language": "qsharp",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "typeParameter", "parameter", "variable", "function", "keyword", "modifier", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "function",
      "pattern": "\\boperation\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Quantum operation declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "function",
      "pattern": "\\bfunction\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Classical function declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\b(use|borrow)\\s+\\w+\\s*=\\s*(Qubit|Qubit\\[\\])",
      "modifiers": [],
      "description": "Qubit allocation statements",
      "rangeScope": "statement"
    },
    {
      "type": "function",
      "pattern": "\\b(H|X|Y|Z|CNOT|SWAP|T|S|Rx|Ry|Rz|Measure|MResetZ|Reset|Adjoint|Controlled)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Quantum gate operations and measurement",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\b(if|elif|else|for|in|while|repeat|until|fixup|return|fail)\\b",
      "modifiers": [],
      "description": "Control flow statements",
      "rangeScope": "statement"
    },
    {
      "type": "namespace",
      "pattern": "\\bnamespace\\s+[\\w.]+",
      "modifiers": ["declaration"],
      "description": "Namespace declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bopen\\s+[\\w.]+",
      "modifiers": [],
      "description": "Open (import) statements",
      "rangeScope": "statement"
    },
    {
      "type": "type",
      "pattern": "\\b(newtype|struct)\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "User-defined type declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "comment",
      "pattern": "//.*$",
      "modifiers": [],
      "description": "Single-line comments",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
