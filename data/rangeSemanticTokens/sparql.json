{
  "language": "sparql",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "variable", "property", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "keyword",
      "pattern": "\\bSELECT\\s+(DISTINCT\\s+)?[?*]",
      "modifiers": [],
      "description": "SELECT query statements",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\bCONSTRUCT\\s*\\{",
      "modifiers": [],
      "description": "CONSTRUCT query statements",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\bASK\\s*\\{",
      "modifiers": [],
      "description": "ASK query statements",
      "rangeScope": "statement"
    },
    {
      "type": "namespace",
      "pattern": "\\bPREFIX\\s+[a-zA-Z_][a-zA-Z0-9_]*:\\s*<[^>]+>",
      "modifiers": ["declaration"],
      "description": "PREFIX namespace declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "variable",
      "pattern": "\\?[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": [],
      "description": "SPARQL variable references",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\bWHERE\\s*\\{",
      "modifiers": [],
      "description": "WHERE clause blocks",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\bOPTIONAL\\s*\\{",
      "modifiers": [],
      "description": "OPTIONAL pattern blocks",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\bFILTER\\s*\\(",
      "modifiers": [],
      "description": "FILTER constraint expressions",
      "rangeScope": "expression"
    },
    {
      "type": "property",
      "pattern": "<[^>]+>|[a-zA-Z_][a-zA-Z0-9_]*:[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": [],
      "description": "URI and prefixed name references",
      "rangeScope": "expression"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
