{
  "language": "csharp",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "keyword", "modifier", "comment", "string", "number", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "documentation", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "class",
      "pattern": "\\b(public|internal|private|protected)?\\s*(static\\s+)?(partial\\s+)?class\\s+\\w+[^{]*\\{[\\s\\S]*?\\}",
      "modifiers": ["declaration"],
      "description": "Class declarations with body",
      "rangeScope": "declaration"
    },
    {
      "type": "interface",
      "pattern": "\\b(public|internal)?\\s*interface\\s+\\w+[^{]*\\{[\\s\\S]*?\\}",
      "modifiers": ["declaration"],
      "description": "Interface declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\b\\w+\\.Where\\([^)]*\\)(\\.\\w+\\([^)]*\\))*",
      "modifiers": [],
      "description": "LINQ method chain expressions",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\bfrom\\s+\\w+\\s+in\\s+[\\s\\S]*?\\bselect\\b[^;]*",
      "modifiers": [],
      "description": "LINQ query syntax expressions",
      "rangeScope": "expression"
    },
    {
      "type": "method",
      "pattern": "\\b(public|private|protected|internal)?\\s*(static\\s+)?(async\\s+)?(Task(<[^>]+>)?|void|\\w+)\\s+\\w+\\s*\\([^)]*\\)\\s*\\{[\\s\\S]*?\\}",
      "modifiers": ["definition", "async"],
      "description": "Async method definitions",
      "rangeScope": "block"
    },
    {
      "type": "property",
      "pattern": "\\b(public|private|protected|internal)?\\s*(static\\s+)?\\w+\\s+\\w+\\s*\\{\\s*(get|set)[^}]*\\}",
      "modifiers": ["declaration"],
      "description": "Property declarations with accessors",
      "rangeScope": "declaration"
    },
    {
      "type": "decorator",
      "pattern": "\\[\\w+(\\([^)]*\\))?\\]",
      "modifiers": [],
      "description": "Attribute annotations",
      "rangeScope": "declaration"
    },
    {
      "type": "struct",
      "pattern": "\\b(public|internal)?\\s*(readonly\\s+)?struct\\s+\\w+[^{]*\\{[\\s\\S]*?\\}",
      "modifiers": ["declaration"],
      "description": "Struct declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "enum",
      "pattern": "\\b(public|internal)?\\s*enum\\s+\\w+\\s*\\{[\\s\\S]*?\\}",
      "modifiers": ["declaration"],
      "description": "Enum declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\btry\\s*\\{[\\s\\S]*?\\}\\s*(catch\\s*\\([^)]*\\)\\s*\\{[\\s\\S]*?\\}\\s*)*(finally\\s*\\{[\\s\\S]*?\\})?",
      "modifiers": [],
      "description": "Try-catch-finally blocks",
      "rangeScope": "block"
    },
    {
      "type": "namespace",
      "pattern": "\\bnamespace\\s+[\\w.]+\\s*\\{[\\s\\S]*?\\}",
      "modifiers": ["declaration"],
      "description": "Namespace declarations",
      "rangeScope": "block"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
