{
  "language": "wgsl",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["type", "struct", "parameter", "variable", "property", "function", "keyword", "modifier", "comment", "string", "number", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "function",
      "pattern": "\\bfn\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Function declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "struct",
      "pattern": "\\bstruct\\s+[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Struct declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "decorator",
      "pattern": "@(vertex|fragment|compute|binding|group|location|builtin|workgroup_size)",
      "modifiers": [],
      "description": "Attribute annotations",
      "rangeScope": "expression"
    },
    {
      "type": "variable",
      "pattern": "\\bvar(<[a-zA-Z_]+>)?\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Variable declarations with var",
      "rangeScope": "statement"
    },
    {
      "type": "variable",
      "pattern": "\\blet\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration", "readonly"],
      "description": "Immutable bindings with let",
      "rangeScope": "statement"
    },
    {
      "type": "variable",
      "pattern": "\\bconst\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration", "readonly"],
      "description": "Compile-time constant declarations",
      "rangeScope": "statement"
    },
    {
      "type": "type",
      "pattern": "\\b(vec[234]|mat[234]x[234]|f32|i32|u32|bool|array|texture_[a-z_]+|sampler)",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in type expressions",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\b(if|else|for|while|loop|switch|return|break|continue)\\b",
      "modifiers": [],
      "description": "Control flow blocks",
      "rangeScope": "block"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
