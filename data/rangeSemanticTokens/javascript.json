{
  "language": "javascript",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "parameter", "variable", "property", "function", "method", "keyword", "comment", "string", "number", "regexp", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "async", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "function",
      "pattern": "\\bfunction\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*\\(",
      "modifiers": ["declaration"],
      "description": "Named function declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "class",
      "pattern": "\\bclass\\s+([A-Z][a-zA-Z0-9_$]*)\\b",
      "modifiers": ["declaration"],
      "description": "Class declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "function",
      "pattern": "(?:const|let|var)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*=\\s*(?:async\\s+)?\\(?[^)]*\\)?\\s*=>",
      "modifiers": ["declaration"],
      "description": "Arrow function expressions",
      "rangeScope": "expression"
    },
    {
      "type": "string",
      "pattern": "`(?:[^`\\\\]|\\\\.)*`",
      "modifiers": [],
      "description": "Template literal expressions",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\b(import|export)\\s+",
      "modifiers": [],
      "description": "Import and export declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "variable",
      "pattern": "\\b(const|let|var)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)",
      "modifiers": ["definition"],
      "description": "Variable declarations",
      "rangeScope": "statement"
    },
    {
      "type": "method",
      "pattern": "\\b([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*\\([^)]*\\)\\s*\\{",
      "modifiers": ["declaration"],
      "description": "Object/class method definitions",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\basync\\s+function\\b",
      "modifiers": ["async"],
      "description": "Async function declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "regexp",
      "pattern": "/(?:[^/\\\\]|\\\\.)+/[gimsuy]*",
      "modifiers": [],
      "description": "Regular expression literals",
      "rangeScope": "expression"
    },
    {
      "type": "comment",
      "pattern": "//.*$|/\\*[\\s\\S]*?\\*/",
      "modifiers": [],
      "description": "Single and multi-line comments",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}