{
  "language": "julia",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "struct", "typeParameter", "parameter", "variable", "property", "function", "method", "macro", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "abstract", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "function",
      "pattern": "\\bfunction\\s+([a-zA-Z_][a-zA-Z0-9_!]*)\\s*\\(",
      "modifiers": ["declaration"],
      "description": "Function declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "macro",
      "pattern": "\\bmacro\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Macro definitions",
      "rangeScope": "declaration"
    },
    {
      "type": "struct",
      "pattern": "\\b(?:mutable\\s+)?struct\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Struct declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "type",
      "pattern": "::\\s*([A-Z][a-zA-Z0-9_{}]*)",
      "modifiers": [],
      "description": "Type annotations",
      "rangeScope": "expression"
    },
    {
      "type": "operator",
      "pattern": "\\.([a-zA-Z_][a-zA-Z0-9_]*\\.)",
      "modifiers": [],
      "description": "Broadcasting dot operator",
      "rangeScope": "expression"
    },
    {
      "type": "namespace",
      "pattern": "\\bmodule\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Module declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\b(using|import)\\s+",
      "modifiers": [],
      "description": "Using and import statements",
      "rangeScope": "statement"
    },
    {
      "type": "type",
      "pattern": "\\babstract\\s+type\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["abstract", "declaration"],
      "description": "Abstract type declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "comment",
      "pattern": "#=.*?=#|#.*$",
      "modifiers": [],
      "description": "Single and multi-line comments",
      "rangeScope": "statement"
    },
    {
      "type": "macro",
      "pattern": "@([a-zA-Z_][a-zA-Z0-9_]*)",
      "modifiers": ["defaultLibrary"],
      "description": "Macro invocations",
      "rangeScope": "expression"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}