{
  "language": "mips",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "variable", "property", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "function",
      "pattern": "^([a-zA-Z_][a-zA-Z0-9_]*):\\s*$",
      "modifiers": ["declaration"],
      "description": "Label declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "^\\s*(add|addi|addiu|addu|and|andi|beq|bne|j|jal|jr|lw|sw|lb|sb|lui|ori|sll|srl|slt|slti|sub|subu|or|nor|xor|mult|div|mfhi|mflo|syscall|nop|move|li|la|blt|bgt|ble|bge)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "MIPS instruction mnemonics",
      "rangeScope": "statement"
    },
    {
      "type": "variable",
      "pattern": "\\$(zero|at|v[01]|a[0-3]|t[0-9]|s[0-7]|k[01]|gp|sp|fp|ra)",
      "modifiers": ["readonly"],
      "description": "Named register references",
      "rangeScope": "expression"
    },
    {
      "type": "variable",
      "pattern": "\\$([0-9]{1,2})",
      "modifiers": ["readonly"],
      "description": "Numbered register references",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "^\\s*\\.(text|data|globl|word|byte|half|ascii|asciiz|space|align|float|double)\\b",
      "modifiers": ["declaration"],
      "description": "Assembler directives",
      "rangeScope": "declaration"
    },
    {
      "type": "number",
      "pattern": "\\b(0x[0-9a-fA-F]+|0b[01]+|[0-9]+)\\b",
      "modifiers": [],
      "description": "Numeric literals (decimal, hex, binary)",
      "rangeScope": "expression"
    },
    {
      "type": "comment",
      "pattern": "#.*$",
      "modifiers": [],
      "description": "Comments",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}