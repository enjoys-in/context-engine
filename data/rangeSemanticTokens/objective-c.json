{
  "language": "objective-c",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "parameter", "variable", "property", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "interface",
      "pattern": "@interface\\s+\\w+(\\s*\\(\\w*\\))?",
      "modifiers": ["declaration"],
      "description": "Objective-C @interface declarations and categories",
      "rangeScope": "declaration"
    },
    {
      "type": "class",
      "pattern": "@implementation\\s+\\w+(\\s*\\(\\w*\\))?",
      "modifiers": ["declaration"],
      "description": "Objective-C @implementation blocks",
      "rangeScope": "declaration"
    },
    {
      "type": "method",
      "pattern": "^\\s*[-+]\\s*\\([^)]+\\)\\s*\\w+",
      "modifiers": ["declaration"],
      "description": "Instance and class method signatures",
      "rangeScope": "declaration"
    },
    {
      "type": "macro",
      "pattern": "#import\\s+[<\"][^>\"]+[>\"]",
      "modifiers": [],
      "description": "#import directives for header inclusion",
      "rangeScope": "statement"
    },
    {
      "type": "property",
      "pattern": "@property\\s*\\([^)]*\\)\\s+\\w+\\s*\\*?\\s*\\w+",
      "modifiers": ["declaration"],
      "description": "Property declarations with attributes",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "@(protocol|end|synthesize|dynamic|optional|required|autoreleasepool)\\b",
      "modifiers": [],
      "description": "Objective-C specific directives and keywords",
      "rangeScope": "statement"
    },
    {
      "type": "string",
      "pattern": "@\"[^\"]*\"",
      "modifiers": [],
      "description": "NSString literals",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\b(dispatch_async|dispatch_sync|dispatch_queue_create)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Grand Central Dispatch calls",
      "rangeScope": "expression"
    },
    {
      "type": "enum",
      "pattern": "\\b(NS_ENUM|NS_OPTIONS)\\s*\\([^)]+\\)",
      "modifiers": ["declaration"],
      "description": "NS_ENUM and NS_OPTIONS enum declarations",
      "rangeScope": "declaration"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
