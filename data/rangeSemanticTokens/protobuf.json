{
  "language": "protobuf",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "enum", "enumMember", "property", "function", "method", "keyword", "modifier", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "deprecated"]
  },
  "rangeTokenRules": [
    {
      "type": "class",
      "pattern": "\\bmessage\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Message type declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "enum",
      "pattern": "\\benum\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Enum type declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "interface",
      "pattern": "\\bservice\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Service declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "method",
      "pattern": "\\brpc\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "RPC method declarations within services",
      "rangeScope": "declaration"
    },
    {
      "type": "property",
      "pattern": "\\b(optional|required|repeated)\\s+\\w+\\s+\\w+\\s*=\\s*\\d+",
      "modifiers": ["declaration"],
      "description": "Field declarations with labels and field numbers",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\[\\w+\\s*=\\s*[^\\]]+\\]",
      "modifiers": [],
      "description": "Field options in brackets",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\b(syntax|package|import|option)\\b",
      "modifiers": [],
      "description": "File-level directives",
      "rangeScope": "statement"
    },
    {
      "type": "type",
      "pattern": "\\b(oneof|map|extend|extensions|reserved)\\b",
      "modifiers": [],
      "description": "Advanced type features and reserved declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "comment",
      "pattern": "//.*$|/\\*[\\s\\S]*?\\*/",
      "modifiers": [],
      "description": "Single-line and block comments",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
