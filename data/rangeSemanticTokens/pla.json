{
  "language": "pla",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "keyword", "comment", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly"]
  },
  "rangeTokenRules": [
    {
      "type": "keyword",
      "pattern": "^\\.i\\s+\\d+",
      "modifiers": ["declaration"],
      "description": "Input count directive (.i)",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "^\\.o\\s+\\d+",
      "modifiers": ["declaration"],
      "description": "Output count directive (.o)",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "^\\.p\\s+\\d+",
      "modifiers": ["declaration"],
      "description": "Product term count directive (.p)",
      "rangeScope": "declaration"
    },
    {
      "type": "number",
      "pattern": "^[01-]+\\s+[01-]+",
      "modifiers": [],
      "description": "Truth table entries (input-output rows)",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "^\\.e",
      "modifiers": [],
      "description": "End of PLA description directive (.e)",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "^\\.(ilb|ob|type|phase)\\b",
      "modifiers": ["declaration"],
      "description": "Additional PLA directives (labels, type, phase)",
      "rangeScope": "declaration"
    },
    {
      "type": "comment",
      "pattern": "#.*$",
      "modifiers": [],
      "description": "Comment lines",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
