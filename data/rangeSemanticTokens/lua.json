{
  "language": "lua",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "variable", "property", "function", "method", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "function",
      "pattern": "\\bfunction\\s+([a-zA-Z_][a-zA-Z0-9_.:]*)\\s*\\(",
      "modifiers": ["declaration"],
      "description": "Global function declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "function",
      "pattern": "\\blocal\\s+function\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "modifiers": ["declaration"],
      "description": "Local function declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "variable",
      "pattern": "\\blocal\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*=\\s*\\{",
      "modifiers": ["definition"],
      "description": "Table constructor assignments",
      "rangeScope": "expression"
    },
    {
      "type": "function",
      "pattern": "\\brequire\\s*[\"'(]",
      "modifiers": ["defaultLibrary"],
      "description": "Module require statements",
      "rangeScope": "statement"
    },
    {
      "type": "variable",
      "pattern": "\\blocal\\s+([a-zA-Z_][a-zA-Z0-9_,\\s]*)(?:\\s*=)?",
      "modifiers": ["definition"],
      "description": "Local variable declarations",
      "rangeScope": "statement"
    },
    {
      "type": "method",
      "pattern": "\\bfunction\\s+([a-zA-Z_][a-zA-Z0-9_]*):([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "modifiers": ["declaration"],
      "description": "Method declarations with colon syntax",
      "rangeScope": "declaration"
    },
    {
      "type": "comment",
      "pattern": "--\\[\\[[\\s\\S]*?\\]\\]|--.*$",
      "modifiers": [],
      "description": "Single-line and multi-line Lua comments",
      "rangeScope": "statement"
    },
    {
      "type": "string",
      "pattern": "\\[\\[[\\s\\S]*?\\]\\]",
      "modifiers": [],
      "description": "Multi-line string literals",
      "rangeScope": "expression"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}