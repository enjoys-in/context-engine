{
  "language": "pascal",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "interface", "parameter", "variable", "property", "function", "method", "keyword", "modifier", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "function",
      "pattern": "\\b(procedure|function)\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Procedure and function declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "type",
      "pattern": "\\btype\\s+\\w+\\s*=",
      "modifiers": ["declaration"],
      "description": "Type definitions and aliases",
      "rangeScope": "declaration"
    },
    {
      "type": "struct",
      "pattern": "\\brecord\\b",
      "modifiers": ["declaration"],
      "description": "Record type declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\b(begin|end)\\b",
      "modifiers": [],
      "description": "Begin/end compound statement blocks",
      "rangeScope": "block"
    },
    {
      "type": "variable",
      "pattern": "\\bvar\\s+\\w+\\s*:",
      "modifiers": ["declaration"],
      "description": "Variable declarations in var sections",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\b(if|then|else|while|do|for|to|downto|repeat|until|case|of)\\b",
      "modifiers": [],
      "description": "Control flow statements",
      "rangeScope": "statement"
    },
    {
      "type": "namespace",
      "pattern": "\\b(unit|program|library|uses)\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Unit, program, and library declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "class",
      "pattern": "\\bclass\\b",
      "modifiers": ["declaration"],
      "description": "Class type declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "comment",
      "pattern": "\\{[^}]*\\}|\\(\\*[\\s\\S]*?\\*\\)|//.*$",
      "modifiers": [],
      "description": "Block and single-line comments",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
