{
  "language": "bicep",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "variable", "property", "function", "keyword", "modifier", "comment", "string", "number", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "documentation", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "type",
      "pattern": "\\bresource\\s+\\w+\\s+'[^']+@[^']+'\\s*=\\s*\\{[\\s\\S]*?\\}",
      "modifiers": ["declaration"],
      "description": "Resource block declarations with API version",
      "rangeScope": "declaration"
    },
    {
      "type": "variable",
      "pattern": "\\bparam\\s+\\w+\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Parameter declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "variable",
      "pattern": "\\bvar\\s+\\w+\\s*=",
      "modifiers": ["declaration"],
      "description": "Variable declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "property",
      "pattern": "\\boutput\\s+\\w+\\s+\\w+\\s*=",
      "modifiers": ["declaration"],
      "description": "Output declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bmodule\\s+\\w+\\s+'[^']+'\\s*=\\s*\\{[\\s\\S]*?\\}",
      "modifiers": ["declaration"],
      "description": "Module block declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "function",
      "pattern": "\\b(resourceGroup|subscription|tenant|managementGroup|reference|listKeys|concat|format|uniqueString)\\s*\\(",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in function call expressions",
      "rangeScope": "expression"
    },
    {
      "type": "decorator",
      "pattern": "@\\w+(\\([^)]*\\))?",
      "modifiers": [],
      "description": "Decorator annotations like @description, @secure",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bif\\s*\\([^)]*\\)\\s*\\{[\\s\\S]*?\\}",
      "modifiers": [],
      "description": "Conditional deployment blocks",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\bfor\\s+\\w+\\s+in\\s+[^:]+:\\s*\\{[\\s\\S]*?\\}",
      "modifiers": [],
      "description": "For loop expressions for iterating over collections",
      "rangeScope": "expression"
    },
    {
      "type": "type",
      "pattern": "\\bexisting\\b",
      "modifiers": ["readonly"],
      "description": "Existing resource references",
      "rangeScope": "expression"
    }
  ],
  "supportedRangeScopes": ["expression", "declaration", "block"],
  "multilineTokens": ["comment", "string"]
}
