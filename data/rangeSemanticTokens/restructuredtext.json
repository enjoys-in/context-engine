{
  "language": "restructuredtext",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["type", "variable", "function", "keyword", "comment", "string", "operator"],
    "tokenModifiers": ["declaration", "definition", "documentation"]
  },
  "rangeTokenRules": [
    {
      "type": "keyword",
      "pattern": "^\\.\\.\\s+\\w+::",
      "modifiers": ["declaration"],
      "description": "reStructuredText directives (.. directive::)",
      "rangeScope": "declaration"
    },
    {
      "type": "function",
      "pattern": ":\\w+:`[^`]+`",
      "modifiers": [],
      "description": "Interpreted text roles (:role:`text`)",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "^[=\\-~`'\"^_*+#]+$",
      "modifiers": ["declaration"],
      "description": "Section headings (underline/overline characters)",
      "rangeScope": "declaration"
    },
    {
      "type": "string",
      "pattern": "``[^`]+``",
      "modifiers": [],
      "description": "Inline literal text",
      "rangeScope": "expression"
    },
    {
      "type": "variable",
      "pattern": "\\|\\w+\\|",
      "modifiers": [],
      "description": "Substitution references",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "^\\.\\.\\s+\\|\\w+\\|\\s+\\w+::",
      "modifiers": ["declaration"],
      "description": "Substitution definitions",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "^\\.\\.\\s+_[^:]+:",
      "modifiers": ["declaration"],
      "description": "Hyperlink targets and footnotes",
      "rangeScope": "declaration"
    },
    {
      "type": "comment",
      "pattern": "^\\.\\.\\s+[^\\w\\|_].*$",
      "modifiers": [],
      "description": "reStructuredText comments",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
