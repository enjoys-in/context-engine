{
  "language": "doctest",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["definition", "readonly", "documentation", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "keyword",
      "pattern": "^>>>\\s+.+$",
      "modifiers": [],
      "description": "Primary doctest prompt lines with code",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "^\\.\\.\\.\\s+.+$",
      "modifiers": [],
      "description": "Continuation lines in a doctest block",
      "rangeScope": "block"
    },
    {
      "type": "string",
      "pattern": "^(?!>>>|\\.\\.\\.)[^\\n]+$",
      "modifiers": ["readonly"],
      "description": "Expected output expressions",
      "rangeScope": "expression"
    },
    {
      "type": "comment",
      "pattern": "^\\s*#.*$",
      "modifiers": ["documentation"],
      "description": "Comment lines within doctest",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": ">>>\\s+(def|class)\\s+\\w+",
      "modifiers": ["definition"],
      "description": "Function/class definitions within doctest",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": ">>>\\s+import\\s+\\w+",
      "modifiers": [],
      "description": "Import statements within doctest",
      "rangeScope": "statement"
    },
    {
      "type": "string",
      "pattern": "Traceback \\(most recent call last\\):[\\s\\S]*?\\w+Error:[^\\n]*",
      "modifiers": [],
      "description": "Expected exception output blocks",
      "rangeScope": "expression"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression"],
  "multilineTokens": ["comment", "string"]
}
