{
  "language": "toml",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "property", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly"]
  },
  "rangeTokenRules": [
    {
      "type": "keyword",
      "pattern": "^\\s*\\[[a-zA-Z_][a-zA-Z0-9_.\\-]*\\]",
      "modifiers": ["declaration"],
      "description": "Table header declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "^\\s*\\[\\[[a-zA-Z_][a-zA-Z0-9_.\\-]*\\]\\]",
      "modifiers": ["declaration"],
      "description": "Array of tables declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "property",
      "pattern": "^\\s*[a-zA-Z_][a-zA-Z0-9_\\-]*\\s*=",
      "modifiers": [],
      "description": "Key=value pair statements",
      "rangeScope": "statement"
    },
    {
      "type": "property",
      "pattern": "^\\s*\"[^\"]+\"\\s*=",
      "modifiers": [],
      "description": "Quoted key=value pair statements",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\{\\s*[a-zA-Z_][a-zA-Z0-9_\\-]*\\s*=",
      "modifiers": [],
      "description": "Inline table expressions",
      "rangeScope": "expression"
    },
    {
      "type": "property",
      "pattern": "[a-zA-Z_][a-zA-Z0-9_\\-]*\\.[a-zA-Z_][a-zA-Z0-9_\\-]*\\s*=",
      "modifiers": [],
      "description": "Dotted key statements",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
