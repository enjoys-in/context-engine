{
  "language": "apex",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["class", "enum", "interface", "typeParameter", "parameter", "variable", "property", "function", "method", "keyword", "modifier", "comment", "string", "number", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "documentation", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "keyword",
      "pattern": "\\btrigger\\s+\\w+\\s+on\\s+\\w+\\s*\\([^)]*\\)\\s*\\{[\\s\\S]*?\\}",
      "modifiers": ["declaration"],
      "description": "Trigger declarations with event context",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\[\\s*SELECT\\b[\\s\\S]*?\\]",
      "modifiers": [],
      "description": "Inline SOQL query expressions",
      "rangeScope": "expression"
    },
    {
      "type": "class",
      "pattern": "\\b(public|private|global)\\s+(virtual|abstract)?\\s*class\\s+\\w+\\s*\\{[\\s\\S]*?\\}",
      "modifiers": ["declaration"],
      "description": "Class body declarations",
      "rangeScope": "block"
    },
    {
      "type": "decorator",
      "pattern": "@\\w+(\\([^)]*\\))?",
      "modifiers": ["declaration"],
      "description": "Annotation declarations like @isTest, @AuraEnabled",
      "rangeScope": "declaration"
    },
    {
      "type": "method",
      "pattern": "\\b(public|private|protected|global)\\s+(static\\s+)?\\w+\\s+\\w+\\s*\\([^)]*\\)\\s*\\{[\\s\\S]*?\\}",
      "modifiers": ["definition"],
      "description": "Method body definitions",
      "rangeScope": "block"
    },
    {
      "type": "variable",
      "pattern": "\\b(List|Set|Map)<[^>]+>\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Collection variable declarations",
      "rangeScope": "statement"
    },
    {
      "type": "property",
      "pattern": "\\b\\w+\\s+\\w+\\s*\\{\\s*get\\s*;\\s*set\\s*;\\s*\\}",
      "modifiers": ["declaration"],
      "description": "Property declarations with getter/setter",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bfor\\s*\\([^)]+\\)\\s*\\{[\\s\\S]*?\\}",
      "modifiers": [],
      "description": "For loop blocks including SOQL for loops",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\btry\\s*\\{[\\s\\S]*?\\}\\s*catch\\s*\\([^)]*\\)\\s*\\{[\\s\\S]*?\\}",
      "modifiers": [],
      "description": "Try-catch exception handling blocks",
      "rangeScope": "block"
    },
    {
      "type": "enum",
      "pattern": "\\b(public|private|global)\\s+enum\\s+\\w+\\s*\\{[^}]*\\}",
      "modifiers": ["declaration"],
      "description": "Enum type declarations",
      "rangeScope": "declaration"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
