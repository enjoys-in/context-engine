{
  "language": "redis-cli",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "keyword",
      "pattern": "\\b(GET|SET|DEL|HGET|HSET|LPUSH|RPUSH|LPOP|RPOP|LRANGE|SADD|SMEMBERS|ZADD|ZRANGE|KEYS|EXISTS|INCR|DECR|EXPIRE|TTL|TYPE|PING|ECHO|DBSIZE|FLUSHDB|FLUSHALL|SELECT)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Redis CLI commands for data operations",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\bAUTH\\s+\\S+",
      "modifiers": [],
      "description": "AUTH command for authentication",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\b(MULTI|EXEC|DISCARD|WATCH|UNWATCH)\\b",
      "modifiers": [],
      "description": "Transaction block commands",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\b(SUBSCRIBE|UNSUBSCRIBE|PUBLISH|PSUBSCRIBE|PUNSUBSCRIBE|MONITOR)\\b",
      "modifiers": [],
      "description": "Pub/sub and monitoring commands",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\b(CONFIG\\s+GET|CONFIG\\s+SET|CONFIG\\s+RESETSTAT|INFO|CLIENT\\s+LIST|CLIENT\\s+KILL|SLOWLOG)\\b",
      "modifiers": [],
      "description": "Server administration commands",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\b(SAVE|BGSAVE|BGREWRITEAOF|LASTSAVE|SHUTDOWN)\\b",
      "modifiers": [],
      "description": "Persistence and shutdown commands",
      "rangeScope": "statement"
    },
    {
      "type": "comment",
      "pattern": "#.*$",
      "modifiers": [],
      "description": "Comment lines",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
