{
  "language": "ecl",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "variable", "property", "function", "keyword", "modifier", "comment", "string", "number", "operator", "macro"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "documentation", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "type",
      "pattern": "\\bRECORD\\b[\\s\\S]*?\\bEND\\b",
      "modifiers": ["declaration"],
      "description": "RECORD structure declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "type",
      "pattern": "\\bDATASET\\s*\\([^)]*\\)",
      "modifiers": ["declaration"],
      "description": "DATASET declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\b(OUTPUT|SORT|DEDUP|JOIN|TRANSFORM|PROJECT|ROLLUP|TABLE)\\s*\\(",
      "modifiers": ["defaultLibrary"],
      "description": "Action and transform statements",
      "rangeScope": "statement"
    },
    {
      "type": "variable",
      "pattern": "\\b\\w+\\s*:=\\s*",
      "modifiers": ["declaration"],
      "description": "Attribute assignment declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "function",
      "pattern": "\\b\\w+\\s*\\([^)]*\\)\\s*:=\\s*FUNCTION\\b[\\s\\S]*?\\bENDMACRO\\b|\\bENDFUNCTION\\b",
      "modifiers": ["definition"],
      "description": "Function definitions",
      "rangeScope": "declaration"
    },
    {
      "type": "macro",
      "pattern": "\\bMACRO\\b[\\s\\S]*?\\bENDMACRO\\b",
      "modifiers": ["definition"],
      "description": "Macro definitions",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bIMPORT\\s+\\w+",
      "modifiers": [],
      "description": "Module import statements",
      "rangeScope": "statement"
    },
    {
      "type": "namespace",
      "pattern": "\\bMODULE\\s*\\([^)]*\\)[\\s\\S]*?\\bEND\\b",
      "modifiers": ["declaration"],
      "description": "Module definition blocks",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bIF\\s*\\([^)]*\\)[\\s\\S]*?\\bEND\\b",
      "modifiers": [],
      "description": "IF conditional blocks",
      "rangeScope": "block"
    },
    {
      "type": "comment",
      "pattern": "//.*$|/\\*[\\s\\S]*?\\*/",
      "modifiers": ["documentation"],
      "description": "Single-line and block comments",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "declaration"],
  "multilineTokens": ["comment", "string"]
}
