{
  "language": "typescript",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "enum", "interface", "typeParameter", "parameter", "variable", "property", "enumMember", "function", "method", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "documentation", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "class",
      "pattern": "\\bclass\\s+[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Class declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "interface",
      "pattern": "\\binterface\\s+[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Interface declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "type",
      "pattern": "\\btype\\s+[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Type alias declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "enum",
      "pattern": "\\benum\\s+[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Enum declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "typeParameter",
      "pattern": "<[A-Z][a-zA-Z0-9_]*(\\s+extends\\s+[^>]+)?>",
      "modifiers": [],
      "description": "Generic type parameter expressions",
      "rangeScope": "expression"
    },
    {
      "type": "decorator",
      "pattern": "@[a-zA-Z_][a-zA-Z0-9_]*(\\(.*?\\))?",
      "modifiers": ["declaration"],
      "description": "Decorator declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "function",
      "pattern": "\\basync\\s+function\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration", "async"],
      "description": "Async function declarations",
      "rangeScope": "block"
    },
    {
      "type": "function",
      "pattern": "\\bfunction\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Function declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "variable",
      "pattern": "\\b(const|let|var)\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Variable declarations",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\bawait\\s+",
      "modifiers": ["async"],
      "description": "Await expressions in async context",
      "rangeScope": "expression"
    },
    {
      "type": "namespace",
      "pattern": "\\bnamespace\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Namespace declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bimport\\s+.*?\\bfrom\\b",
      "modifiers": [],
      "description": "Import statements",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
