{
  "language": "dart",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "enum", "typeParameter", "parameter", "variable", "property", "enumMember", "function", "method", "keyword", "modifier", "comment", "string", "number", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "documentation", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "class",
      "pattern": "\\b(abstract\\s+)?class\\s+\\w+[^{]*\\{[\\s\\S]*?\\}",
      "modifiers": ["declaration"],
      "description": "Class declarations including abstract classes",
      "rangeScope": "declaration"
    },
    {
      "type": "class",
      "pattern": "\\bmixin\\s+\\w+[^{]*\\{[\\s\\S]*?\\}",
      "modifiers": ["declaration"],
      "description": "Mixin declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "method",
      "pattern": "\\b(Future|Stream)(<[^>]+>)?\\s+\\w+\\s*\\([^)]*\\)\\s+async\\s*\\*?\\s*\\{[\\s\\S]*?\\}",
      "modifiers": ["definition", "async"],
      "description": "Async method definitions returning Future/Stream",
      "rangeScope": "block"
    },
    {
      "type": "operator",
      "pattern": "\\w+\\?\\.|\\w+\\?\\.\\w+|\\w+\\s*\\?\\?\\s*\\w+|\\w+!",
      "modifiers": [],
      "description": "Null safety operator expressions (?., ??, !)",
      "rangeScope": "expression"
    },
    {
      "type": "enum",
      "pattern": "\\benum\\s+\\w+\\s*\\{[\\s\\S]*?\\}",
      "modifiers": ["declaration"],
      "description": "Enum declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "function",
      "pattern": "\\b\\w+\\s+\\w+\\s*\\([^)]*\\)\\s*\\{[\\s\\S]*?\\}",
      "modifiers": ["definition"],
      "description": "Top-level function definitions",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\bextension\\s+\\w+\\s+on\\s+\\w+\\s*\\{[\\s\\S]*?\\}",
      "modifiers": ["declaration"],
      "description": "Extension declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "decorator",
      "pattern": "@\\w+(\\([^)]*\\))?",
      "modifiers": [],
      "description": "Annotation decorators like @override, @required",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bswitch\\s*\\([^)]*\\)\\s*\\{[\\s\\S]*?\\}",
      "modifiers": [],
      "description": "Switch statement blocks",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\btry\\s*\\{[\\s\\S]*?\\}\\s*(catch\\s*\\([^)]*\\)\\s*\\{[\\s\\S]*?\\}\\s*)*(finally\\s*\\{[\\s\\S]*?\\})?",
      "modifiers": [],
      "description": "Try-catch-finally blocks",
      "rangeScope": "block"
    },
    {
      "type": "variable",
      "pattern": "\\b(final|const|var|late)\\s+\\w+\\s*=",
      "modifiers": ["declaration"],
      "description": "Variable declarations with modifiers",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
