{
  "language": "scala",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "enum", "typeParameter", "parameter", "variable", "property", "function", "method", "keyword", "modifier", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "documentation", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "method",
      "pattern": "\\bdef\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Method/function declarations with def",
      "rangeScope": "declaration"
    },
    {
      "type": "variable",
      "pattern": "\\bval\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration", "readonly"],
      "description": "Immutable value declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "variable",
      "pattern": "\\bvar\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Mutable variable declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "class",
      "pattern": "\\bcase\\s+class\\s+[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Case class declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "class",
      "pattern": "\\b(class|object|trait)\\s+[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Class, object, and trait declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bmatch\\s*\\{",
      "modifiers": [],
      "description": "Pattern match expressions",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\bcase\\s+[^c]",
      "modifiers": [],
      "description": "Pattern match case clauses",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\bfor\\s*\\{",
      "modifiers": [],
      "description": "For comprehensions",
      "rangeScope": "expression"
    },
    {
      "type": "namespace",
      "pattern": "\\bpackage\\s+[a-zA-Z_][a-zA-Z0-9_.]*",
      "modifiers": ["declaration"],
      "description": "Package declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bimport\\s+[a-zA-Z_][a-zA-Z0-9_.{}_, ]*",
      "modifiers": [],
      "description": "Import statements",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
