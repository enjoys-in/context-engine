{
  "language": "sql",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "variable", "property", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "keyword",
      "pattern": "\\bCREATE\\s+(TABLE|VIEW|INDEX|DATABASE|SCHEMA)\\b",
      "modifiers": ["declaration"],
      "description": "DDL create statements",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bALTER\\s+(TABLE|VIEW|INDEX)\\b",
      "modifiers": [],
      "description": "DDL alter statements",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bDROP\\s+(TABLE|VIEW|INDEX|DATABASE)\\b",
      "modifiers": [],
      "description": "DDL drop statements",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\b(SELECT|INSERT|UPDATE|DELETE)\\b",
      "modifiers": [],
      "description": "DML statements",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\b(INNER|LEFT|RIGHT|FULL|CROSS)\\s+JOIN\\b",
      "modifiers": [],
      "description": "JOIN expressions",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\(\\s*SELECT\\b",
      "modifiers": [],
      "description": "Subquery expressions",
      "rangeScope": "expression"
    },
    {
      "type": "function",
      "pattern": "\\bCREATE\\s+(OR\\s+REPLACE\\s+)?(PROCEDURE|FUNCTION)\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Stored procedure and function declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bWHERE\\s+",
      "modifiers": [],
      "description": "WHERE clause conditions",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\bGROUP\\s+BY\\b",
      "modifiers": [],
      "description": "GROUP BY clauses",
      "rangeScope": "statement"
    },
    {
      "type": "function",
      "pattern": "\\b(COUNT|SUM|AVG|MAX|MIN)\\s*\\(",
      "modifiers": ["defaultLibrary"],
      "description": "Aggregate function expressions",
      "rangeScope": "expression"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
