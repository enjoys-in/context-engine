{
  "language": "abap",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["class", "interface", "variable", "property", "function", "method", "keyword", "modifier", "comment", "string", "number", "operator", "event"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "documentation", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "variable",
      "pattern": "\\bDATA\\s+\\w+\\b",
      "modifiers": ["declaration"],
      "description": "DATA variable declarations",
      "rangeScope": "statement"
    },
    {
      "type": "function",
      "pattern": "\\bFORM\\s+\\w+[\\s\\S]*?ENDFORM\\b",
      "modifiers": ["definition"],
      "description": "FORM/ENDFORM subroutine blocks",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\bSELECT\\b[\\s\\S]*?\\bENDSELECT\\b|\\bSELECT\\b.*\\.",
      "modifiers": [],
      "description": "SELECT query expressions",
      "rangeScope": "expression"
    },
    {
      "type": "method",
      "pattern": "\\bCLASS-METHODS\\s+\\w+\\b",
      "modifiers": ["declaration", "static"],
      "description": "CLASS-METHODS declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "class",
      "pattern": "\\bCLASS\\s+\\w+\\s+DEFINITION[\\s\\S]*?ENDCLASS\\b",
      "modifiers": ["declaration"],
      "description": "CLASS definition blocks",
      "rangeScope": "declaration"
    },
    {
      "type": "interface",
      "pattern": "\\bINTERFACE\\s+\\w+[\\s\\S]*?ENDINTERFACE\\b",
      "modifiers": ["declaration"],
      "description": "INTERFACE definition blocks",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bIF\\b[\\s\\S]*?\\bENDIF\\b",
      "modifiers": [],
      "description": "IF/ENDIF conditional blocks",
      "rangeScope": "block"
    },
    {
      "type": "comment",
      "pattern": "^\\*.*$|\".*$",
      "modifiers": ["documentation"],
      "description": "Line comments starting with * or inline with double-quote",
      "rangeScope": "statement"
    },
    {
      "type": "event",
      "pattern": "\\b(START-OF-SELECTION|END-OF-SELECTION|AT\\s+SELECTION-SCREEN)\\b",
      "modifiers": [],
      "description": "Event block keywords",
      "rangeScope": "block"
    },
    {
      "type": "method",
      "pattern": "\\bMETHOD\\s+\\w+[\\s\\S]*?ENDMETHOD\\b",
      "modifiers": ["definition"],
      "description": "METHOD implementation blocks",
      "rangeScope": "block"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
