{
  "language": "cypher",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["type", "variable", "property", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "keyword",
      "pattern": "\\bMATCH\\s+\\([^)]*\\)(\\s*-\\[[^\\]]*\\]->?\\s*\\([^)]*\\))*",
      "modifiers": [],
      "description": "MATCH pattern expressions including node and relationship patterns",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\bRETURN\\b[^;]*",
      "modifiers": [],
      "description": "RETURN clause statements",
      "rangeScope": "statement"
    },
    {
      "type": "variable",
      "pattern": "\\(\\w+\\s*:\\s*\\w+\\s*(\\{[^}]*\\})?\\)",
      "modifiers": [],
      "description": "Node pattern expressions with label and properties",
      "rangeScope": "expression"
    },
    {
      "type": "variable",
      "pattern": "-\\[\\w*\\s*:\\s*\\w+(\\s*\\{[^}]*\\})?\\]->?",
      "modifiers": [],
      "description": "Relationship pattern expressions",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\bWHERE\\b[^\\n]*",
      "modifiers": [],
      "description": "WHERE filter clause expressions",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\bCREATE\\s+\\([^)]*\\)",
      "modifiers": ["modification"],
      "description": "CREATE node statements",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\bMERGE\\s+\\([^)]*\\)",
      "modifiers": ["modification"],
      "description": "MERGE upsert statements",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\bWITH\\b[^\\n]*",
      "modifiers": [],
      "description": "WITH projection clauses",
      "rangeScope": "statement"
    },
    {
      "type": "function",
      "pattern": "\\b(count|collect|sum|avg|min|max|size|length|type|id|labels|keys|nodes|relationships)\\s*\\(",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in aggregation and utility function calls",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\bUNWIND\\s+\\S+\\s+AS\\s+\\w+",
      "modifiers": [],
      "description": "UNWIND list expansion expressions",
      "rangeScope": "expression"
    }
  ],
  "supportedRangeScopes": ["statement", "expression"],
  "multilineTokens": ["comment", "string"]
}
