{
  "language": "crontab",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "property", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "number",
      "pattern": "^\\s*[\\d*,/-]+\\s+[\\d*,/-]+\\s+[\\d*,/-]+\\s+[\\d*,/-]+\\s+[\\d*,/-]+",
      "modifiers": [],
      "description": "Timing field expressions (minute hour day month weekday)",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "(?<=^\\s*([\\d*,/-]+\\s+){5})\\S+.*$",
      "modifiers": [],
      "description": "Command statements following timing fields",
      "rangeScope": "statement"
    },
    {
      "type": "variable",
      "pattern": "^\\s*[A-Z_][A-Z0-9_]*=.*$",
      "modifiers": ["declaration"],
      "description": "Environment variable declarations",
      "rangeScope": "statement"
    },
    {
      "type": "comment",
      "pattern": "^\\s*#.*$",
      "modifiers": ["documentation"],
      "description": "Comment lines",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "@(reboot|yearly|annually|monthly|weekly|daily|midnight|hourly)",
      "modifiers": ["defaultLibrary"],
      "description": "Special schedule shorthand keywords",
      "rangeScope": "expression"
    },
    {
      "type": "operator",
      "pattern": "[,\\-/]",
      "modifiers": [],
      "description": "Range and step operators in timing fields",
      "rangeScope": "expression"
    },
    {
      "type": "number",
      "pattern": "\\*",
      "modifiers": [],
      "description": "Wildcard any-value in timing fields",
      "rangeScope": "expression"
    }
  ],
  "supportedRangeScopes": ["statement", "expression"],
  "multilineTokens": ["comment"]
}
