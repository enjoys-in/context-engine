{
  "language": "kotlin",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "enum", "interface", "typeParameter", "parameter", "variable", "property", "enumMember", "function", "method", "keyword", "modifier", "comment", "string", "number", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "function",
      "pattern": "\\bfun\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*[(<]",
      "modifiers": ["declaration"],
      "description": "Function declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "class",
      "pattern": "\\bclass\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Class declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "class",
      "pattern": "\\bobject\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration", "static"],
      "description": "Object declarations (singletons)",
      "rangeScope": "declaration"
    },
    {
      "type": "class",
      "pattern": "\\bcompanion\\s+object\\b",
      "modifiers": ["declaration", "static"],
      "description": "Companion object declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\b(launch|async|withContext|runBlocking|coroutineScope)\\s*[{(]",
      "modifiers": ["async"],
      "description": "Coroutine builder expressions",
      "rangeScope": "expression"
    },
    {
      "type": "class",
      "pattern": "\\bdata\\s+class\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Data class declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "enum",
      "pattern": "\\benum\\s+class\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Enum class declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "interface",
      "pattern": "\\binterface\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Interface declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "decorator",
      "pattern": "@([A-Z][a-zA-Z0-9_]*)",
      "modifiers": [],
      "description": "Annotations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bsuspend\\s+fun\\b",
      "modifiers": ["async", "declaration"],
      "description": "Suspend function declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "comment",
      "pattern": "//.*$|/\\*[\\s\\S]*?\\*/",
      "modifiers": [],
      "description": "Single and multi-line comments",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}