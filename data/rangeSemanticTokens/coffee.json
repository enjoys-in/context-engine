{
  "language": "coffee",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["class", "parameter", "variable", "property", "function", "method", "keyword", "comment", "string", "number", "regexp", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "class",
      "pattern": "\\bclass\\s+\\w+(\\s+extends\\s+\\w+)?",
      "modifiers": ["declaration"],
      "description": "Class declarations with optional extends",
      "rangeScope": "block"
    },
    {
      "type": "function",
      "pattern": "\\([^)]*\\)\\s*=>|\\([^)]*\\)\\s*->",
      "modifiers": ["definition"],
      "description": "Fat arrow and thin arrow function expressions",
      "rangeScope": "expression"
    },
    {
      "type": "variable",
      "pattern": "\\b\\w+\\s*=\\s*(?!>)",
      "modifiers": ["declaration"],
      "description": "Variable assignment statements",
      "rangeScope": "statement"
    },
    {
      "type": "method",
      "pattern": "\\b\\w+\\s*:\\s*\\([^)]*\\)\\s*[-=]>",
      "modifiers": ["definition"],
      "description": "Method definitions in class bodies",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\bif\\b[^\\n]*\\bthen\\b|\\bif\\b[\\s\\S]*?(?=\\belse\\b|$)",
      "modifiers": [],
      "description": "If conditional blocks",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\bfor\\s+\\w+\\s+in\\b",
      "modifiers": [],
      "description": "For-in comprehension expressions",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\bswitch\\b[\\s\\S]*?(?=\\bswitch\\b|$)",
      "modifiers": [],
      "description": "Switch/when blocks",
      "rangeScope": "block"
    },
    {
      "type": "string",
      "pattern": "\"\"\"[\\s\\S]*?\"\"\"|'''[\\s\\S]*?'''",
      "modifiers": [],
      "description": "Heredoc/block string literals",
      "rangeScope": "expression"
    },
    {
      "type": "comment",
      "pattern": "###[\\s\\S]*?###",
      "modifiers": ["documentation"],
      "description": "Block comments",
      "rangeScope": "statement"
    },
    {
      "type": "variable",
      "pattern": "\\[.*\\]\\s*=",
      "modifiers": ["declaration"],
      "description": "Destructuring assignment statements",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression"],
  "multilineTokens": ["comment", "string"]
}
