{
  "language": "rust",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "enum", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "async", "documentation", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "function",
      "pattern": "\\bfn\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Function declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "struct",
      "pattern": "\\bstruct\\s+[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Struct declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "enum",
      "pattern": "\\benum\\s+[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Enum declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "type",
      "pattern": "\\btrait\\s+[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Trait declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bimpl\\s+(<[^>]+>\\s+)?[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Impl blocks",
      "rangeScope": "declaration"
    },
    {
      "type": "typeParameter",
      "pattern": "'[a-z][a-zA-Z0-9_]*",
      "modifiers": [],
      "description": "Lifetime annotations",
      "rangeScope": "expression"
    },
    {
      "type": "macro",
      "pattern": "[a-zA-Z_][a-zA-Z0-9_]*!",
      "modifiers": [],
      "description": "Macro invocations",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\bunsafe\\s*\\{",
      "modifiers": [],
      "description": "Unsafe blocks",
      "rangeScope": "block"
    },
    {
      "type": "variable",
      "pattern": "\\blet\\s+(mut\\s+)?[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Variable bindings with let",
      "rangeScope": "statement"
    },
    {
      "type": "namespace",
      "pattern": "\\bmod\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Module declarations",
      "rangeScope": "declaration"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
