{
  "language": "azcli",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "variable", "property", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "function",
      "pattern": "\\baz\\s+[a-z][a-z-]*\\s+[a-z][a-z-]*",
      "modifiers": ["defaultLibrary"],
      "description": "Azure CLI command groups and subcommands",
      "rangeScope": "statement"
    },
    {
      "type": "property",
      "pattern": "--[a-z][a-z-]*(\\s+[^-\\s]\\S*)?",
      "modifiers": [],
      "description": "Parameter flags with optional values",
      "rangeScope": "expression"
    },
    {
      "type": "namespace",
      "pattern": "--resource-group\\s+\\S+",
      "modifiers": ["declaration"],
      "description": "Resource group declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "variable",
      "pattern": "\\$[A-Za-z_][A-Za-z0-9_]*",
      "modifiers": [],
      "description": "Shell variable references in commands",
      "rangeScope": "expression"
    },
    {
      "type": "string",
      "pattern": "(\"[^\"]*\"|'[^']*')",
      "modifiers": [],
      "description": "Quoted string values for parameters",
      "rangeScope": "expression"
    },
    {
      "type": "comment",
      "pattern": "#.*$",
      "modifiers": ["documentation"],
      "description": "Line comments",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\baz\\b",
      "modifiers": ["defaultLibrary"],
      "description": "The az command prefix keyword",
      "rangeScope": "statement"
    },
    {
      "type": "property",
      "pattern": "-[a-z]\\s+\\S+",
      "modifiers": [],
      "description": "Short-form parameter flags with values",
      "rangeScope": "expression"
    },
    {
      "type": "operator",
      "pattern": "\\|\\s*az\\b",
      "modifiers": [],
      "description": "Piped az commands",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "--query\\s+'[^']*'|--query\\s+\"[^\"]*\"",
      "modifiers": [],
      "description": "JMESPath query expressions",
      "rangeScope": "expression"
    }
  ],
  "supportedRangeScopes": ["statement", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
