{
  "language": "cameligo",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "typeParameter", "parameter", "variable", "property", "enumMember", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "documentation", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "variable",
      "pattern": "\\blet\\s+\\w+\\s*[^=]*=",
      "modifiers": ["declaration"],
      "description": "Let binding declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "function",
      "pattern": "\\blet\\s+\\w+\\s*\\([^)]*\\)\\s*[^=]*=[\\s\\S]*?(?=\\blet\\b|$)",
      "modifiers": ["definition"],
      "description": "Function let binding definitions",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bmatch\\b[\\s\\S]*?\\bwith\\b[\\s\\S]*?(?=\\blet\\b|$)",
      "modifiers": [],
      "description": "Match expression with pattern arms",
      "rangeScope": "expression"
    },
    {
      "type": "type",
      "pattern": "\\btype\\s+\\w+\\s*=\\s*[\\s\\S]*?(?=\\blet\\b|\\btype\\b|$)",
      "modifiers": ["declaration"],
      "description": "Type definitions",
      "rangeScope": "declaration"
    },
    {
      "type": "type",
      "pattern": "\\btype\\s+\\w+\\s*=\\s*\\|[\\s\\S]*?(?=\\blet\\b|\\btype\\b|$)",
      "modifiers": ["declaration"],
      "description": "Variant/sum type declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bif\\b[^\\n]*\\bthen\\b[\\s\\S]*?\\belse\\b",
      "modifiers": [],
      "description": "If-then-else conditional expressions",
      "rangeScope": "expression"
    },
    {
      "type": "type",
      "pattern": "\\btype\\s+\\w+\\s*=\\s*\\{[\\s\\S]*?\\}",
      "modifiers": ["declaration"],
      "description": "Record type declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "function",
      "pattern": "\\blet\\s+rec\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Recursive function declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "namespace",
      "pattern": "\\bmodule\\s+\\w+\\s*=\\s*struct[\\s\\S]*?end",
      "modifiers": ["declaration"],
      "description": "Module structure declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "comment",
      "pattern": "\\(\\*[\\s\\S]*?\\*\\)",
      "modifiers": ["documentation"],
      "description": "Block comments",
      "rangeScope": "expression"
    }
  ],
  "supportedRangeScopes": ["expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
