{
  "language": "elixir",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "variable", "property", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "documentation", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "namespace",
      "pattern": "\\bdefmodule\\s+[\\w.]+\\s+do[\\s\\S]*?\\bend\\b",
      "modifiers": ["declaration"],
      "description": "Module declarations with defmodule",
      "rangeScope": "declaration"
    },
    {
      "type": "function",
      "pattern": "\\bdef\\s+\\w+[^\\n]*do[\\s\\S]*?\\bend\\b",
      "modifiers": ["definition"],
      "description": "Public function definitions with def",
      "rangeScope": "declaration"
    },
    {
      "type": "function",
      "pattern": "\\bdefp\\s+\\w+[^\\n]*do[\\s\\S]*?\\bend\\b",
      "modifiers": ["definition", "static"],
      "description": "Private function definitions with defp",
      "rangeScope": "declaration"
    },
    {
      "type": "operator",
      "pattern": "\\|>\\s*\\w+",
      "modifiers": [],
      "description": "Pipe operator chain expressions",
      "rangeScope": "expression"
    },
    {
      "type": "macro",
      "pattern": "\\bdefmacro\\s+\\w+[^\\n]*do[\\s\\S]*?\\bend\\b",
      "modifiers": ["definition"],
      "description": "Macro definitions",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bcase\\s+[^\\n]+\\s+do[\\s\\S]*?\\bend\\b",
      "modifiers": [],
      "description": "Case expression blocks",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\bcond\\s+do[\\s\\S]*?\\bend\\b",
      "modifiers": [],
      "description": "Cond expression blocks",
      "rangeScope": "expression"
    },
    {
      "type": "decorator",
      "pattern": "@\\w+\\s+[^\\n]+",
      "modifiers": ["documentation"],
      "description": "Module attributes like @moduledoc, @doc, @spec",
      "rangeScope": "declaration"
    },
    {
      "type": "type",
      "pattern": "@spec\\s+\\w+[^\\n]+",
      "modifiers": ["declaration"],
      "description": "Type specification declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bwith\\s+[\\s\\S]*?\\bdo[\\s\\S]*?\\bend\\b",
      "modifiers": [],
      "description": "With expression blocks for pattern matching chains",
      "rangeScope": "expression"
    },
    {
      "type": "string",
      "pattern": "~[a-z]\"\"\"[\\s\\S]*?\"\"\"|~[a-z]\"[^\"]*\"",
      "modifiers": [],
      "description": "Sigil string expressions",
      "rangeScope": "expression"
    }
  ],
  "supportedRangeScopes": ["expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
