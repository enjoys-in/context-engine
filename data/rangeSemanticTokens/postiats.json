{
  "language": "postiats",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "typeParameter", "parameter", "variable", "function", "macro", "keyword", "modifier", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static"]
  },
  "rangeTokenRules": [
    {
      "type": "function",
      "pattern": "\\b(fun|fn|implement|primplement)\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Function and implementation declarations (fun, fn)",
      "rangeScope": "declaration"
    },
    {
      "type": "type",
      "pattern": "\\b(datatype|datavtype|datasort|typedef|abstype|absvtype)\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Datatype and abstract type declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "variable",
      "pattern": "\\b(val|var|macdef)\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Value and variable bindings",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\b(case|case\\+|case-|ifcase)\\b",
      "modifiers": [],
      "description": "Pattern matching expressions",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\b(if|then|else|when|while|for)\\b",
      "modifiers": [],
      "description": "Control flow keywords",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\b(let|in|end|local|where)\\b",
      "modifiers": [],
      "description": "Let/in/end block structure",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\b(staload|dynload|#include)\\b",
      "modifiers": [],
      "description": "Module loading and include directives",
      "rangeScope": "statement"
    },
    {
      "type": "comment",
      "pattern": "\\(\\*[\\s\\S]*?\\*\\)|//.*$",
      "modifiers": [],
      "description": "Block and line comments",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
