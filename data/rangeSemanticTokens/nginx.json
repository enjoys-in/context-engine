{
  "language": "nginx",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "property", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly"]
  },
  "rangeTokenRules": [
    {
      "type": "keyword",
      "pattern": "\\b(server|location|upstream|map|geo|limit_req_zone)\\s*\\{",
      "modifiers": ["declaration"],
      "description": "Server, location, upstream, and other configuration blocks",
      "rangeScope": "block"
    },
    {
      "type": "property",
      "pattern": "^\\s*(listen|server_name|root|index|proxy_pass|fastcgi_pass|return|rewrite|add_header|expires|access_log|error_log)\\b",
      "modifiers": [],
      "description": "Nginx directives as statements",
      "rangeScope": "statement"
    },
    {
      "type": "variable",
      "pattern": "\\$[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": [],
      "description": "Nginx variables prefixed with $",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\b(if|set|return|rewrite|break)\\b",
      "modifiers": [],
      "description": "Control flow and rewrite directives",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\b(http|events|stream|mail)\\s*\\{",
      "modifiers": ["declaration"],
      "description": "Top-level context blocks",
      "rangeScope": "block"
    },
    {
      "type": "string",
      "pattern": "\"[^\"]*\"|'[^']*'",
      "modifiers": [],
      "description": "Quoted string values in directives",
      "rangeScope": "expression"
    },
    {
      "type": "comment",
      "pattern": "#.*$",
      "modifiers": [],
      "description": "Single-line comments",
      "rangeScope": "statement"
    },
    {
      "type": "regexp",
      "pattern": "[~*^]\\s+[^;{]+",
      "modifiers": [],
      "description": "Regex patterns in location and rewrite directives",
      "rangeScope": "expression"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
