{
  "language": "sol",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["type", "class", "enum", "interface", "struct", "parameter", "variable", "property", "enumMember", "event", "function", "method", "keyword", "modifier", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "documentation", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "class",
      "pattern": "\\bcontract\\s+[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Contract declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "interface",
      "pattern": "\\binterface\\s+[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Interface declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "function",
      "pattern": "\\bfunction\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Function declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "modifier",
      "pattern": "\\bmodifier\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Modifier declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "event",
      "pattern": "\\bevent\\s+[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Event declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "struct",
      "pattern": "\\bstruct\\s+[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Struct declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "enum",
      "pattern": "\\benum\\s+[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Enum declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "type",
      "pattern": "\\bmapping\\s*\\(",
      "modifiers": [],
      "description": "Mapping type expressions",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\bpragma\\s+solidity\\s+",
      "modifiers": [],
      "description": "Pragma directives",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\bemit\\s+[A-Z][a-zA-Z0-9_]*",
      "modifiers": [],
      "description": "Event emission statements",
      "rangeScope": "expression"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
