{
  "language": "powershell",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "enum", "parameter", "variable", "property", "function", "method", "keyword", "modifier", "comment", "string", "number", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "function",
      "pattern": "\\bfunction\\s+[\\w-]+",
      "modifiers": ["declaration"],
      "description": "Function declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "function",
      "pattern": "\\b[A-Z][a-z]+-[A-Z][a-z]\\w*",
      "modifiers": ["defaultLibrary"],
      "description": "Cmdlet invocations (Verb-Noun pattern)",
      "rangeScope": "statement"
    },
    {
      "type": "variable",
      "pattern": "\\$[a-zA-Z_]\\w*|\\$\\{[^}]+\\}",
      "modifiers": [],
      "description": "PowerShell variables prefixed with $",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\bparam\\s*\\(",
      "modifiers": ["declaration"],
      "description": "Parameter block declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "variable",
      "pattern": "\\$(PSVersionTable|PSScriptRoot|PSCommandPath|_|args|input|MyInvocation|Host|Error|null|true|false)\\b",
      "modifiers": ["readonly", "defaultLibrary"],
      "description": "Automatic and preference variables",
      "rangeScope": "expression"
    },
    {
      "type": "decorator",
      "pattern": "\\[[A-Z]\\w+\\(.*?\\)\\]|\\[Parameter\\(.*?\\)\\]|\\[CmdletBinding\\(.*?\\)\\]",
      "modifiers": [],
      "description": "Attributes and parameter decorators",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\b(begin|process|end|clean)\\s*\\{",
      "modifiers": [],
      "description": "Pipeline processing blocks",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\b(if|elseif|else|switch|foreach|for|while|do|try|catch|finally)\\b",
      "modifiers": [],
      "description": "Control flow statements",
      "rangeScope": "statement"
    },
    {
      "type": "class",
      "pattern": "\\bclass\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "PowerShell class declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "comment",
      "pattern": "#.*$|<#[\\s\\S]*?#>",
      "modifiers": [],
      "description": "Single-line and block comments",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
