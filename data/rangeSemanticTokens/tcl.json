{
  "language": "tcl",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "variable", "parameter", "property", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "function",
      "pattern": "\\bproc\\s+[a-zA-Z_:][a-zA-Z0-9_:]*",
      "modifiers": ["declaration"],
      "description": "Procedure declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "namespace",
      "pattern": "\\bnamespace\\s+eval\\s+[a-zA-Z_:][a-zA-Z0-9_:]*",
      "modifiers": ["declaration"],
      "description": "Namespace declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bexpr\\s+\\{",
      "modifiers": [],
      "description": "Expression evaluation",
      "rangeScope": "expression"
    },
    {
      "type": "variable",
      "pattern": "\\$[a-zA-Z_:][a-zA-Z0-9_:]*",
      "modifiers": [],
      "description": "Variable references",
      "rangeScope": "expression"
    },
    {
      "type": "variable",
      "pattern": "\\bset\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Variable assignment with set",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\bif\\s+\\{",
      "modifiers": [],
      "description": "If conditional blocks",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\bforeach\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": [],
      "description": "Foreach loop blocks",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\bswitch\\s+",
      "modifiers": [],
      "description": "Switch statement blocks",
      "rangeScope": "block"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
