{
  "language": "mysql",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "variable", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "function",
      "pattern": "\\b(CREATE\\s+(OR\\s+REPLACE\\s+)?PROCEDURE|CREATE\\s+(OR\\s+REPLACE\\s+)?FUNCTION)\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Stored procedure and function declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\b(SELECT|INSERT\\s+INTO|UPDATE|DELETE\\s+FROM|REPLACE\\s+INTO)\\b",
      "modifiers": [],
      "description": "DML statements (SELECT, INSERT, UPDATE, DELETE)",
      "rangeScope": "statement"
    },
    {
      "type": "variable",
      "pattern": "@\\w+",
      "modifiers": [],
      "description": "User-defined variables prefixed with @",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\b(BEGIN|END)\\b",
      "modifiers": [],
      "description": "BEGIN/END blocks in stored routines",
      "rangeScope": "block"
    },
    {
      "type": "type",
      "pattern": "\\b(INT|VARCHAR|TEXT|BLOB|DATE|DATETIME|TIMESTAMP|DECIMAL|FLOAT|DOUBLE|BOOLEAN|ENUM|SET)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in MySQL data types",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\b(CREATE\\s+TABLE|ALTER\\s+TABLE|DROP\\s+TABLE|CREATE\\s+INDEX)\\b",
      "modifiers": ["declaration"],
      "description": "DDL statements for table and index management",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\b(IF|THEN|ELSE|ELSEIF|END\\s+IF|WHILE|LOOP|END\\s+LOOP|CASE|WHEN)\\b",
      "modifiers": [],
      "description": "Control flow keywords in stored routines",
      "rangeScope": "block"
    },
    {
      "type": "comment",
      "pattern": "--.*$|/\\*[\\s\\S]*?\\*/|#.*$",
      "modifiers": [],
      "description": "Single-line and multi-line comments",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
