{
  "language": "flow9",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "interface", "typeParameter", "variable", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "type",
      "pattern": "\\b([A-Z][a-zA-Z0-9]*)\\s*(?::\\s*|::)",
      "modifiers": ["declaration"],
      "description": "Type declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "function",
      "pattern": "\\b([a-z][a-zA-Z0-9]*)\\s*\\(",
      "modifiers": ["declaration"],
      "description": "Function definitions",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\b(import|export|require|forbid)\\b",
      "modifiers": [],
      "description": "Import and export statements",
      "rangeScope": "statement"
    },
    {
      "type": "variable",
      "pattern": "\\b([a-z][a-zA-Z0-9]*)\\s*=",
      "modifiers": ["definition"],
      "description": "Variable assignments",
      "rangeScope": "expression"
    },
    {
      "type": "type",
      "pattern": "\\b(Material|MGroup|MText|MLines)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "UI material types",
      "rangeScope": "expression"
    },
    {
      "type": "interface",
      "pattern": "\\binterface\\s+([A-Z][a-zA-Z0-9]*)",
      "modifiers": ["declaration"],
      "description": "Interface declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "namespace",
      "pattern": "\\b([a-z][a-zA-Z0-9]*)\\s*/",
      "modifiers": [],
      "description": "Namespace path references",
      "rangeScope": "expression"
    },
    {
      "type": "comment",
      "pattern": "//.*$|/\\*[\\s\\S]*?\\*/",
      "modifiers": [],
      "description": "Single and multi-line comments",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}