{
  "language": "systemd",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "property", "keyword", "comment", "string", "number"],
    "tokenModifiers": ["declaration", "definition", "readonly"]
  },
  "rangeTokenRules": [
    {
      "type": "keyword",
      "pattern": "^\\s*\\[(Unit|Service|Install|Timer|Socket|Mount|Path|Swap|Slice|Scope)\\]",
      "modifiers": ["declaration"],
      "description": "Section header declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "property",
      "pattern": "^\\s*[A-Z][a-zA-Z]+\\s*=",
      "modifiers": [],
      "description": "Key=value directive statements",
      "rangeScope": "statement"
    },
    {
      "type": "property",
      "pattern": "^\\s*ExecStart(Pre|Post)?\\s*=",
      "modifiers": [],
      "description": "ExecStart execution directives",
      "rangeScope": "expression"
    },
    {
      "type": "property",
      "pattern": "^\\s*ExecStop(Pre|Post)?\\s*=",
      "modifiers": [],
      "description": "ExecStop execution directives",
      "rangeScope": "expression"
    },
    {
      "type": "property",
      "pattern": "^\\s*ExecReload\\s*=",
      "modifiers": [],
      "description": "ExecReload execution directive",
      "rangeScope": "expression"
    },
    {
      "type": "variable",
      "pattern": "%[nNpPiIfcrRtTsSCdDhubBeEgGHjJlLmMoOTuUvVwW]",
      "modifiers": ["readonly"],
      "description": "Systemd specifier variables",
      "rangeScope": "expression"
    },
    {
      "type": "property",
      "pattern": "^\\s*(Wants|Requires|After|Before|Conflicts)\\s*=",
      "modifiers": [],
      "description": "Unit dependency directives",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
