{
  "language": "ssh_config",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "property", "keyword", "comment", "string", "number"],
    "tokenModifiers": ["declaration", "definition"]
  },
  "rangeTokenRules": [
    {
      "type": "keyword",
      "pattern": "^\\s*Host\\s+\\S+",
      "modifiers": ["declaration"],
      "description": "Host block declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "^\\s*Match\\s+.+",
      "modifiers": ["declaration"],
      "description": "Match conditional block declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "property",
      "pattern": "^\\s*(HostName|User|Port|IdentityFile|ProxyCommand|ForwardAgent)\\s+",
      "modifiers": [],
      "description": "Common connection directives",
      "rangeScope": "statement"
    },
    {
      "type": "property",
      "pattern": "^\\s*(ServerAliveInterval|ServerAliveCountMax|ConnectTimeout)\\s+",
      "modifiers": [],
      "description": "Timeout and keepalive directives",
      "rangeScope": "statement"
    },
    {
      "type": "property",
      "pattern": "^\\s*(StrictHostKeyChecking|UserKnownHostsFile|PreferredAuthentications)\\s+",
      "modifiers": [],
      "description": "Security-related directives",
      "rangeScope": "statement"
    },
    {
      "type": "property",
      "pattern": "^\\s*(LocalForward|RemoteForward|DynamicForward)\\s+",
      "modifiers": [],
      "description": "Port forwarding directives",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
