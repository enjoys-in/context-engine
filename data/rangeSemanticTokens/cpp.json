{
  "language": "cpp",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "enum", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "modification", "documentation", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "keyword",
      "pattern": "\\btemplate\\s*<[^>]*>\\s*(class|struct|typename)",
      "modifiers": ["declaration"],
      "description": "Template declarations with parameter lists",
      "rangeScope": "declaration"
    },
    {
      "type": "namespace",
      "pattern": "\\bnamespace\\s+\\w+\\s*\\{[\\s\\S]*?\\}",
      "modifiers": ["declaration"],
      "description": "Namespace blocks",
      "rangeScope": "block"
    },
    {
      "type": "class",
      "pattern": "\\bclass\\s+\\w+[^{]*\\{[\\s\\S]*?\\};",
      "modifiers": ["declaration"],
      "description": "Class declarations with body",
      "rangeScope": "declaration"
    },
    {
      "type": "struct",
      "pattern": "\\bstruct\\s+\\w+[^{]*\\{[\\s\\S]*?\\};",
      "modifiers": ["declaration"],
      "description": "Struct declarations with body",
      "rangeScope": "declaration"
    },
    {
      "type": "function",
      "pattern": "\\b\\w+\\s+\\w+::\\w+\\s*\\([^)]*\\)\\s*(const)?\\s*\\{[\\s\\S]*?\\}",
      "modifiers": ["definition"],
      "description": "Member function definitions",
      "rangeScope": "block"
    },
    {
      "type": "macro",
      "pattern": "#\\s*(define|ifdef|ifndef|if|elif|else|endif|include|pragma)\\b[^\\n]*",
      "modifiers": [],
      "description": "Preprocessor directive statements",
      "rangeScope": "statement"
    },
    {
      "type": "variable",
      "pattern": "\\b(auto|const|static|volatile)\\s+\\w+\\s*=",
      "modifiers": ["declaration"],
      "description": "Variable declarations with type qualifiers",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\btry\\s*\\{[\\s\\S]*?\\}\\s*catch\\s*\\([^)]*\\)\\s*\\{[\\s\\S]*?\\}",
      "modifiers": [],
      "description": "Try-catch exception handling blocks",
      "rangeScope": "block"
    },
    {
      "type": "enum",
      "pattern": "\\benum\\s+(class\\s+)?\\w*\\s*\\{[\\s\\S]*?\\};",
      "modifiers": ["declaration"],
      "description": "Enum and enum class declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bfor\\s*\\([^)]*\\)\\s*\\{[\\s\\S]*?\\}",
      "modifiers": [],
      "description": "For loop blocks including range-based for",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\b(public|private|protected)\\s*:",
      "modifiers": [],
      "description": "Access specifier labels",
      "rangeScope": "statement"
    },
    {
      "type": "function",
      "pattern": "\\[([^\\]]*)\\]\\s*\\([^)]*\\)\\s*(->\\s*\\w+)?\\s*\\{[\\s\\S]*?\\}",
      "modifiers": ["definition"],
      "description": "Lambda expressions with captures",
      "rangeScope": "expression"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
