{
  "language": "go",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "interface", "struct", "typeParameter", "parameter", "variable", "property", "function", "method", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "function",
      "pattern": "\\bfunc\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "modifiers": ["declaration"],
      "description": "Function declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "method",
      "pattern": "\\bfunc\\s*\\([^)]+\\)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "modifiers": ["declaration"],
      "description": "Method declarations with receiver",
      "rangeScope": "declaration"
    },
    {
      "type": "struct",
      "pattern": "\\btype\\s+([A-Z][a-zA-Z0-9_]*)\\s+struct\\b",
      "modifiers": ["declaration"],
      "description": "Struct type declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "interface",
      "pattern": "\\btype\\s+([A-Z][a-zA-Z0-9_]*)\\s+interface\\b",
      "modifiers": ["declaration"],
      "description": "Interface type declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bgo\\s+",
      "modifiers": ["async"],
      "description": "Goroutine launch expressions",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\bdefer\\s+",
      "modifiers": [],
      "description": "Defer statements",
      "rangeScope": "statement"
    },
    {
      "type": "namespace",
      "pattern": "\\bpackage\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "modifiers": ["declaration"],
      "description": "Package declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bimport\\s*\\(",
      "modifiers": [],
      "description": "Import blocks",
      "rangeScope": "statement"
    },
    {
      "type": "variable",
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*:=",
      "modifiers": ["definition"],
      "description": "Short variable declarations",
      "rangeScope": "statement"
    },
    {
      "type": "comment",
      "pattern": "//.*$|/\\*[\\s\\S]*?\\*/",
      "modifiers": [],
      "description": "Single and multi-line comments",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}