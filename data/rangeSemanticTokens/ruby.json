{
  "language": "ruby",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "parameter", "variable", "property", "function", "method", "keyword", "modifier", "comment", "string", "number", "regexp", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "method",
      "pattern": "\\bdef\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Method definitions",
      "rangeScope": "declaration"
    },
    {
      "type": "class",
      "pattern": "\\bclass\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Class definitions",
      "rangeScope": "declaration"
    },
    {
      "type": "namespace",
      "pattern": "\\bmodule\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Module definitions",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\b(do|\\{)\\s*\\|[^|]*\\|",
      "modifiers": [],
      "description": "Block expressions with do/end or braces and block parameters",
      "rangeScope": "block"
    },
    {
      "type": "variable",
      "pattern": ":[a-zA-Z_]\\w*",
      "modifiers": ["readonly"],
      "description": "Symbol literals",
      "rangeScope": "expression"
    },
    {
      "type": "variable",
      "pattern": "@{1,2}[a-zA-Z_]\\w*",
      "modifiers": [],
      "description": "Instance (@) and class (@@) variables",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\b(if|elsif|else|unless|case|when|while|until|for|in|begin|rescue|ensure|end|return|yield)\\b",
      "modifiers": [],
      "description": "Control flow and exception handling keywords",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\b(require|require_relative|include|extend|prepend|load)\\b",
      "modifiers": [],
      "description": "Module and file loading statements",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\b(attr_reader|attr_writer|attr_accessor)\\s+",
      "modifiers": ["declaration"],
      "description": "Attribute accessor declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "regexp",
      "pattern": "/[^/]+/[imxo]*",
      "modifiers": [],
      "description": "Regular expression literals",
      "rangeScope": "expression"
    },
    {
      "type": "comment",
      "pattern": "#.*$|^=begin[\\s\\S]*?^=end",
      "modifiers": [],
      "description": "Single-line and multi-line comments",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
