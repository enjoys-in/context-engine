{
  "language": "java",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "enum", "interface", "typeParameter", "parameter", "variable", "property", "enumMember", "method", "keyword", "modifier", "comment", "string", "number", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "class",
      "pattern": "\\bclass\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Class declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "interface",
      "pattern": "\\binterface\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Interface declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "enum",
      "pattern": "\\benum\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Enum declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "method",
      "pattern": "\\b(?:public|private|protected|static|final|abstract|synchronized)?\\s*(?:[A-Z][a-zA-Z0-9_<>]*|void|int|long|boolean|double|float|char|byte|short)\\s+([a-z][a-zA-Z0-9_]*)\\s*\\(",
      "modifiers": ["declaration"],
      "description": "Method declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "decorator",
      "pattern": "@([A-Z][a-zA-Z0-9_]*)",
      "modifiers": [],
      "description": "Annotations like @Override, @Deprecated",
      "rangeScope": "declaration"
    },
    {
      "type": "typeParameter",
      "pattern": "<([A-Z][a-zA-Z0-9_,\\s?]*)>",
      "modifiers": [],
      "description": "Generic type parameters",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\b(import|package)\\s+",
      "modifiers": [],
      "description": "Import and package statements",
      "rangeScope": "statement"
    },
    {
      "type": "modifier",
      "pattern": "\\b(public|private|protected|static|final|abstract|synchronized|volatile|transient)\\b",
      "modifiers": [],
      "description": "Access and non-access modifiers",
      "rangeScope": "expression"
    },
    {
      "type": "comment",
      "pattern": "//.*$|/\\*[\\s\\S]*?\\*/|/\\*\\*[\\s\\S]*?\\*/",
      "modifiers": [],
      "description": "Single-line, multi-line, and Javadoc comments",
      "rangeScope": "statement"
    },
    {
      "type": "variable",
      "pattern": "\\b(?:var|final)\\s+([a-z][a-zA-Z0-9_]*)\\s*=",
      "modifiers": ["definition"],
      "description": "Local variable declarations",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}