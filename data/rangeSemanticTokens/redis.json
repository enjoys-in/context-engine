{
  "language": "redis",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "keyword",
      "pattern": "\\b(GET|SET|DEL|MGET|MSET|HGET|HSET|HGETALL|LPUSH|RPUSH|LPOP|RPOP|LRANGE|SADD|SMEMBERS|ZADD|ZRANGE|EXPIRE|TTL|KEYS|EXISTS|INCR|DECR|APPEND)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Core Redis commands for data manipulation",
      "rangeScope": "statement"
    },
    {
      "type": "function",
      "pattern": "\\bEVAL\\s+\"[^\"]*\"",
      "modifiers": [],
      "description": "Lua scripting with EVAL command",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\b(SUBSCRIBE|UNSUBSCRIBE|PUBLISH|PSUBSCRIBE|PUNSUBSCRIBE)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Pub/sub commands",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\b(MULTI|EXEC|DISCARD|WATCH|UNWATCH)\\b",
      "modifiers": [],
      "description": "Transaction commands",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\b(CLUSTER|SENTINEL|CONFIG|INFO|DEBUG|SLOWLOG|CLIENT|MEMORY)\\b",
      "modifiers": [],
      "description": "Administration and cluster commands",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\b(XADD|XREAD|XRANGE|XLEN|XGROUP|XREADGROUP|XACK|XCLAIM)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Redis Streams commands",
      "rangeScope": "statement"
    },
    {
      "type": "comment",
      "pattern": "#.*$",
      "modifiers": [],
      "description": "Comment lines",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
