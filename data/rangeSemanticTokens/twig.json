{
  "language": "twig",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "property", "function", "macro", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "keyword",
      "pattern": "\\{%\\s*(if|elseif|else|endif)\\b",
      "modifiers": [],
      "description": "Conditional tag blocks",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\{%\\s*(for|endfor)\\b",
      "modifiers": [],
      "description": "Loop tag blocks",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\{%\\s*(block|endblock)\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": [],
      "description": "Template block inheritance tags",
      "rangeScope": "block"
    },
    {
      "type": "variable",
      "pattern": "\\{\\{\\s*[a-zA-Z_][a-zA-Z0-9_.]*\\s*\\}\\}",
      "modifiers": [],
      "description": "Output expression tags",
      "rangeScope": "expression"
    },
    {
      "type": "variable",
      "pattern": "\\{\\{\\s*[a-zA-Z_][a-zA-Z0-9_.]*\\s*\\|\\s*[a-zA-Z_]+",
      "modifiers": [],
      "description": "Filtered output expressions",
      "rangeScope": "expression"
    },
    {
      "type": "macro",
      "pattern": "\\{%\\s*macro\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Macro declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\{%\\s*import\\s+",
      "modifiers": [],
      "description": "Import statements",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\{%\\s*extends\\s+",
      "modifiers": [],
      "description": "Template extends statements",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\{%\\s*set\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Variable set declarations",
      "rangeScope": "declaration"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
