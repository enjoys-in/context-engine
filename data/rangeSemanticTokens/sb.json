{
  "language": "sb",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "property", "function", "method", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "function",
      "pattern": "\\bSub\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Sub routine declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bEndSub\\b",
      "modifiers": [],
      "description": "End of Sub routine",
      "rangeScope": "declaration"
    },
    {
      "type": "property",
      "pattern": "\\bTextWindow\\.[a-zA-Z]+",
      "modifiers": ["defaultLibrary"],
      "description": "TextWindow object access",
      "rangeScope": "expression"
    },
    {
      "type": "property",
      "pattern": "\\bGraphicsWindow\\.[a-zA-Z]+",
      "modifiers": ["defaultLibrary"],
      "description": "GraphicsWindow object access",
      "rangeScope": "expression"
    },
    {
      "type": "variable",
      "pattern": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\s*=",
      "modifiers": ["declaration"],
      "description": "Variable assignments",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\b(If|Then|Else|ElseIf|EndIf|For|EndFor|While|EndWhile|Goto)\\b",
      "modifiers": [],
      "description": "Control flow keywords",
      "rangeScope": "block"
    },
    {
      "type": "property",
      "pattern": "\\bMath\\.[a-zA-Z]+",
      "modifiers": ["defaultLibrary"],
      "description": "Math object access",
      "rangeScope": "expression"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
