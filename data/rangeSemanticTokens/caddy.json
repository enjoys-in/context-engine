{
  "language": "caddy",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "variable", "property", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "keyword",
      "pattern": "\\b(reverse_proxy|file_server|encode|header|rewrite|respond|redir|tls|log)\\s*\\{[\\s\\S]*?\\}",
      "modifiers": ["defaultLibrary"],
      "description": "Directive blocks with named directives",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "@\\w+\\s+[^\\n]+",
      "modifiers": [],
      "description": "Named matcher expressions",
      "rangeScope": "expression"
    },
    {
      "type": "namespace",
      "pattern": "\\(\\w+\\)\\s*\\{[\\s\\S]*?\\}",
      "modifiers": ["declaration"],
      "description": "Snippet declaration blocks",
      "rangeScope": "declaration"
    },
    {
      "type": "namespace",
      "pattern": "\\S+:\\d+\\s*\\{[\\s\\S]*?\\}",
      "modifiers": ["declaration"],
      "description": "Site address block declarations",
      "rangeScope": "block"
    },
    {
      "type": "property",
      "pattern": "\\b(root|try_files|php_fastcgi|basicauth)\\b\\s+[^\\n]+",
      "modifiers": [],
      "description": "Directive statement with inline arguments",
      "rangeScope": "statement"
    },
    {
      "type": "variable",
      "pattern": "\\{[a-z][a-z.]*\\}",
      "modifiers": ["readonly"],
      "description": "Placeholder variable expressions like {host}, {path}",
      "rangeScope": "expression"
    },
    {
      "type": "comment",
      "pattern": "#.*$",
      "modifiers": [],
      "description": "Line comments",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\bimport\\s+\\S+",
      "modifiers": [],
      "description": "Import statements for snippets or files",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
