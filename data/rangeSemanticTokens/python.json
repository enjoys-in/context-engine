{
  "language": "python",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "enum", "typeParameter", "parameter", "variable", "property", "function", "method", "keyword", "modifier", "comment", "string", "number", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "documentation", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "function",
      "pattern": "\\bdef\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Function definitions",
      "rangeScope": "declaration"
    },
    {
      "type": "class",
      "pattern": "\\bclass\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Class definitions",
      "rangeScope": "declaration"
    },
    {
      "type": "decorator",
      "pattern": "@[\\w.]+",
      "modifiers": ["declaration"],
      "description": "Decorator expressions",
      "rangeScope": "declaration"
    },
    {
      "type": "variable",
      "pattern": "\\[.+\\bfor\\b.+\\bin\\b.+\\]|\\{.+\\bfor\\b.+\\bin\\b.+\\}|\\(.+\\bfor\\b.+\\bin\\b.+\\)",
      "modifiers": [],
      "description": "List, dict, set comprehensions and generator expressions",
      "rangeScope": "expression"
    },
    {
      "type": "type",
      "pattern": ":\\s*(List|Dict|Tuple|Set|Optional|Union|Any|Callable|Iterator|Generator|Sequence|Mapping)\\b|->\\s*\\w+",
      "modifiers": [],
      "description": "Type hints and return type annotations",
      "rangeScope": "expression"
    },
    {
      "type": "function",
      "pattern": "\\basync\\s+def\\s+\\w+",
      "modifiers": ["declaration", "async"],
      "description": "Async function definitions",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\b(import|from\\s+\\w+\\s+import)\\b",
      "modifiers": [],
      "description": "Import statements",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\b(if|elif|else|for|while|try|except|finally|with|match|case)\\b",
      "modifiers": [],
      "description": "Control flow statements",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\blambda\\b",
      "modifiers": [],
      "description": "Lambda expressions",
      "rangeScope": "expression"
    },
    {
      "type": "string",
      "pattern": "\"\"\"[\\s\\S]*?\"\"\"|'''[\\s\\S]*?'''",
      "modifiers": ["documentation"],
      "description": "Docstrings and multi-line strings",
      "rangeScope": "expression"
    },
    {
      "type": "comment",
      "pattern": "#.*$",
      "modifiers": [],
      "description": "Single-line comments",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
