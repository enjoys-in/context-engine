{
  "language": "php",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "enum", "interface", "typeParameter", "parameter", "variable", "property", "function", "method", "keyword", "modifier", "comment", "string", "number", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "documentation", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "class",
      "pattern": "\\b(class|abstract\\s+class|final\\s+class)\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Class declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "function",
      "pattern": "\\bfunction\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Function declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "namespace",
      "pattern": "\\bnamespace\\s+[\\w\\\\]+",
      "modifiers": ["declaration"],
      "description": "Namespace declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "variable",
      "pattern": "\\$[a-zA-Z_]\\w*",
      "modifiers": [],
      "description": "PHP variables prefixed with $",
      "rangeScope": "expression"
    },
    {
      "type": "comment",
      "pattern": "/\\*\\*[\\s\\S]*?\\*/",
      "modifiers": ["documentation"],
      "description": "PHPDoc documentation blocks",
      "rangeScope": "declaration"
    },
    {
      "type": "interface",
      "pattern": "\\binterface\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Interface declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "enum",
      "pattern": "\\benum\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Enum declarations (PHP 8.1+)",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\b(use|require|require_once|include|include_once)\\b",
      "modifiers": [],
      "description": "Import and inclusion statements",
      "rangeScope": "statement"
    },
    {
      "type": "decorator",
      "pattern": "#\\[\\w+[^\\]]*\\]",
      "modifiers": [],
      "description": "PHP 8 attributes",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\b(try|catch|finally|throw)\\b",
      "modifiers": [],
      "description": "Exception handling blocks",
      "rangeScope": "block"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
