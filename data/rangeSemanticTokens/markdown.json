{
  "language": "markdown",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "variable", "property", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly"]
  },
  "rangeTokenRules": [
    {
      "type": "namespace",
      "pattern": "^#{1,6}\\s+.+$",
      "modifiers": ["declaration"],
      "description": "Heading declarations (h1-h6)",
      "rangeScope": "declaration"
    },
    {
      "type": "string",
      "pattern": "^```[a-zA-Z]*\\n[\\s\\S]*?^```",
      "modifiers": [],
      "description": "Fenced code blocks",
      "rangeScope": "block"
    },
    {
      "type": "property",
      "pattern": "\\[([^\\]]+)\\]\\(([^)]+)\\)",
      "modifiers": [],
      "description": "Inline links [text](url)",
      "rangeScope": "expression"
    },
    {
      "type": "property",
      "pattern": "!\\[([^\\]]*)\\]\\(([^)]+)\\)",
      "modifiers": [],
      "description": "Image links ![alt](url)",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "^\\s*[-*+]\\s+",
      "modifiers": [],
      "description": "Unordered list items",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "^\\s*[0-9]+\\.\\s+",
      "modifiers": [],
      "description": "Ordered list items",
      "rangeScope": "block"
    },
    {
      "type": "comment",
      "pattern": "<!--[\\s\\S]*?-->",
      "modifiers": [],
      "description": "HTML comments in Markdown",
      "rangeScope": "block"
    },
    {
      "type": "operator",
      "pattern": "^\\s*>\\s+",
      "modifiers": [],
      "description": "Blockquotes",
      "rangeScope": "block"
    },
    {
      "type": "string",
      "pattern": "`[^`]+`",
      "modifiers": [],
      "description": "Inline code spans",
      "rangeScope": "expression"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}