{
  "language": "st",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["class", "variable", "property", "function", "method", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "method",
      "pattern": "[a-zA-Z_][a-zA-Z0-9_]*\\s*:\\s*[a-zA-Z_]",
      "modifiers": ["declaration"],
      "description": "Keyword method definitions",
      "rangeScope": "declaration"
    },
    {
      "type": "method",
      "pattern": "[a-zA-Z_][a-zA-Z0-9_]*\\s*\\[",
      "modifiers": ["declaration"],
      "description": "Unary method definitions",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\[\\s*:[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": [],
      "description": "Block closures with parameters",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\[\\s*\\|[^|]+\\|",
      "modifiers": [],
      "description": "Block closures with temporary variables",
      "rangeScope": "block"
    },
    {
      "type": "variable",
      "pattern": "[a-zA-Z_][a-zA-Z0-9_]*\\s+[a-zA-Z_][a-zA-Z0-9_]*:",
      "modifiers": [],
      "description": "Keyword message sends",
      "rangeScope": "expression"
    },
    {
      "type": "variable",
      "pattern": "\\|\\s*[a-zA-Z_][a-zA-Z0-9_ ]*\\|",
      "modifiers": ["declaration"],
      "description": "Temporary variable declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "variable",
      "pattern": "[a-zA-Z_][a-zA-Z0-9_]*\\s*:=",
      "modifiers": [],
      "description": "Variable assignment expressions",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\^\\s*[a-zA-Z_]",
      "modifiers": [],
      "description": "Return expressions",
      "rangeScope": "expression"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
