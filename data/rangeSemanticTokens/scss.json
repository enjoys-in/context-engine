{
  "language": "scss",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "property", "function", "keyword", "comment", "string", "number", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "variable",
      "pattern": "\\$[a-zA-Z_][a-zA-Z0-9_-]*\\s*:",
      "modifiers": ["declaration"],
      "description": "SCSS variable declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "function",
      "pattern": "@mixin\\s+[a-zA-Z_][a-zA-Z0-9_-]*",
      "modifiers": ["declaration"],
      "description": "Mixin declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "@include\\s+[a-zA-Z_][a-zA-Z0-9_-]*",
      "modifiers": [],
      "description": "Mixin include directives",
      "rangeScope": "declaration"
    },
    {
      "type": "function",
      "pattern": "@function\\s+[a-zA-Z_][a-zA-Z0-9_-]*",
      "modifiers": ["declaration"],
      "description": "SCSS function declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "property",
      "pattern": "[a-zA-Z-]+\\s*:",
      "modifiers": [],
      "description": "CSS property declarations",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "&[.:#\\[][a-zA-Z0-9_-]*",
      "modifiers": [],
      "description": "Nested selectors with parent reference",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\.[a-zA-Z_][a-zA-Z0-9_-]*\\s*\\{",
      "modifiers": [],
      "description": "Class selectors with nested block",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "@(if|else|for|each|while)\\b",
      "modifiers": [],
      "description": "Control flow directives",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "@extend\\s+[.%][a-zA-Z_][a-zA-Z0-9_-]*",
      "modifiers": [],
      "description": "Extend directives",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
