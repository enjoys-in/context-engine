{
  "language": "liquid",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "property", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "keyword",
      "pattern": "\\{%[-~]?\\s*(if|elsif|else|endif|for|endfor|unless|endunless|case|when|endcase|capture|endcapture|tablerow|endtablerow)\\b",
      "modifiers": [],
      "description": "Liquid tag blocks {% if %}, {% for %}",
      "rangeScope": "block"
    },
    {
      "type": "variable",
      "pattern": "\\{\\{[-~]?\\s*([a-zA-Z_][a-zA-Z0-9_.]*)\\s*",
      "modifiers": [],
      "description": "Output expressions {{ variable }}",
      "rangeScope": "expression"
    },
    {
      "type": "function",
      "pattern": "\\|\\s*([a-z_][a-z0-9_]*)",
      "modifiers": ["defaultLibrary"],
      "description": "Filter functions like | upcase, | date",
      "rangeScope": "expression"
    },
    {
      "type": "property",
      "pattern": "([a-zA-Z_][a-zA-Z0-9_]*)\\.([a-zA-Z_][a-zA-Z0-9_]*)",
      "modifiers": [],
      "description": "Object property access",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\{%[-~]?\\s*(assign|increment|decrement)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "modifiers": ["definition"],
      "description": "Variable assignment tags",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\{%[-~]?\\s*(include|render|layout|section)\\s+",
      "modifiers": [],
      "description": "Include and render tags",
      "rangeScope": "statement"
    },
    {
      "type": "comment",
      "pattern": "\\{%[-~]?\\s*comment\\s*[-~]?%\\}[\\s\\S]*?\\{%[-~]?\\s*endcomment\\s*[-~]?%\\}",
      "modifiers": [],
      "description": "Liquid comment blocks",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\{%[-~]?\\s*raw\\s*[-~]?%\\}[\\s\\S]*?\\{%[-~]?\\s*endraw\\s*[-~]?%\\}",
      "modifiers": [],
      "description": "Raw blocks",
      "rangeScope": "block"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}