{
  "language": "perl",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "variable", "function", "method", "keyword", "comment", "string", "number", "regexp", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "function",
      "pattern": "\\bsub\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Subroutine declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "regexp",
      "pattern": "(?:m|qr)?/[^/]*/[gimsxce]*|s/[^/]*/[^/]*/[gimsxce]*|tr/[^/]*/[^/]*/[cds]*",
      "modifiers": [],
      "description": "Regular expression patterns, substitutions, and transliterations",
      "rangeScope": "expression"
    },
    {
      "type": "variable",
      "pattern": "\\$[_a-zA-Z]\\w*|\\$\\{[^}]+\\}",
      "modifiers": [],
      "description": "Scalar variables",
      "rangeScope": "expression"
    },
    {
      "type": "variable",
      "pattern": "@[_a-zA-Z]\\w*|%[_a-zA-Z]\\w*",
      "modifiers": [],
      "description": "Array and hash variables",
      "rangeScope": "expression"
    },
    {
      "type": "variable",
      "pattern": "\\$[_!@&`'+\\-\\[\\]\\\\;,./|]|\\$\\d+|\\$\\^[A-Z]",
      "modifiers": ["readonly", "defaultLibrary"],
      "description": "Special Perl variables ($_, $!, $@, etc.)",
      "rangeScope": "expression"
    },
    {
      "type": "namespace",
      "pattern": "\\bpackage\\s+[\\w:]+",
      "modifiers": ["declaration"],
      "description": "Package declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\b(use|require|no)\\s+[\\w:]+",
      "modifiers": [],
      "description": "Module import statements",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\b(my|our|local)\\s+[\\$@%]\\w+",
      "modifiers": ["declaration"],
      "description": "Lexical and dynamic variable declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "comment",
      "pattern": "#.*$|^=[a-zA-Z].*?^=cut",
      "modifiers": ["documentation"],
      "description": "Comments and POD documentation",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
