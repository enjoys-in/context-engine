{
  "language": "m3",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "interface", "typeParameter", "variable", "property", "function", "method", "keyword", "modifier", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "abstract"]
  },
  "rangeTokenRules": [
    {
      "type": "interface",
      "pattern": "\\bINTERFACE\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Interface declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "type",
      "pattern": "\\bOBJECT\\b",
      "modifiers": ["declaration"],
      "description": "Object type declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "namespace",
      "pattern": "\\bMODULE\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Module declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "function",
      "pattern": "\\bPROCEDURE\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "modifiers": ["declaration"],
      "description": "Procedure declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bREVEAL\\b",
      "modifiers": [],
      "description": "Reveal statements for opaque types",
      "rangeScope": "statement"
    },
    {
      "type": "type",
      "pattern": "\\bTYPE\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Type declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "variable",
      "pattern": "\\bVAR\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "modifiers": ["definition"],
      "description": "Variable declarations",
      "rangeScope": "statement"
    },
    {
      "type": "variable",
      "pattern": "\\bCONST\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "modifiers": ["readonly", "definition"],
      "description": "Constant declarations",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\b(IMPORT|FROM|EXPORT)\\b",
      "modifiers": [],
      "description": "Import and export keywords",
      "rangeScope": "statement"
    },
    {
      "type": "comment",
      "pattern": "\\(\\*[\\s\\S]*?\\*\\)",
      "modifiers": [],
      "description": "Block comments (* ... *)",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}