{
  "language": "msdax",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "property", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "variable",
      "pattern": "([a-zA-Z_][a-zA-Z0-9_ ]*)\\s*:=",
      "modifiers": ["declaration"],
      "description": "Measure definitions",
      "rangeScope": "declaration"
    },
    {
      "type": "function",
      "pattern": "\\b(CALCULATE|SUMX|AVERAGEX|COUNTROWS|FILTER|ALL|ALLEXCEPT|RELATED|RELATEDTABLE|VALUES|DISTINCT|EARLIER|EARLIEST|SUM|AVERAGE|COUNT|COUNTA|MIN|MAX|IF|SWITCH|DIVIDE|BLANK|ISBLANK|FORMAT|DATE|YEAR|MONTH|DAY|NOW|TODAY|DATESYTD|DATEADD|TOTALYTD|SAMEPERIODLASTYEAR)\\s*\\(",
      "modifiers": ["defaultLibrary"],
      "description": "DAX built-in functions",
      "rangeScope": "expression"
    },
    {
      "type": "property",
      "pattern": "'?([a-zA-Z_][a-zA-Z0-9_ ]*)'?\\[([a-zA-Z_][a-zA-Z0-9_ ]*)\\]",
      "modifiers": [],
      "description": "Table[Column] references",
      "rangeScope": "expression"
    },
    {
      "type": "property",
      "pattern": "\\[([a-zA-Z_][a-zA-Z0-9_ ]*)\\]",
      "modifiers": [],
      "description": "Column references [Column]",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\b(VAR|RETURN|DEFINE|MEASURE|EVALUATE|ORDER BY|ASC|DESC|START AT)\\b",
      "modifiers": [],
      "description": "DAX keywords",
      "rangeScope": "statement"
    },
    {
      "type": "operator",
      "pattern": "(&&|\\|\\||<>|>=|<=|[+\\-*/=<>&])",
      "modifiers": [],
      "description": "DAX operators",
      "rangeScope": "expression"
    },
    {
      "type": "comment",
      "pattern": "//.*$|/\\*[\\s\\S]*?\\*/|--.*$",
      "modifiers": [],
      "description": "Single and multi-line comments",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}