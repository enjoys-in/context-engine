{
  "language": "awk",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "function", "keyword", "comment", "string", "number", "regexp", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "keyword",
      "pattern": "/[^/]+/\\s*\\{[\\s\\S]*?\\}",
      "modifiers": [],
      "description": "Pattern-action rule blocks",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\bBEGIN\\s*\\{[\\s\\S]*?\\}",
      "modifiers": [],
      "description": "BEGIN block executed before input processing",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\bEND\\s*\\{[\\s\\S]*?\\}",
      "modifiers": [],
      "description": "END block executed after input processing",
      "rangeScope": "block"
    },
    {
      "type": "variable",
      "pattern": "\\$[0-9]+",
      "modifiers": ["readonly"],
      "description": "Field reference expressions like $0, $1, $2",
      "rangeScope": "expression"
    },
    {
      "type": "function",
      "pattern": "\\bfunction\\s+\\w+\\s*\\([^)]*\\)\\s*\\{[\\s\\S]*?\\}",
      "modifiers": ["definition"],
      "description": "User-defined function definitions",
      "rangeScope": "block"
    },
    {
      "type": "function",
      "pattern": "\\b(gsub|sub|match|split|sprintf|printf|print|getline|length|substr|index|tolower|toupper)\\s*\\(",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in function calls",
      "rangeScope": "expression"
    },
    {
      "type": "regexp",
      "pattern": "/[^/\\n]+/",
      "modifiers": [],
      "description": "Regular expression patterns",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\bif\\s*\\([^)]*\\)\\s*\\{[\\s\\S]*?\\}(\\s*else\\s*\\{[\\s\\S]*?\\})?",
      "modifiers": [],
      "description": "If-else conditional blocks",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\b(for|while)\\s*\\([^)]*\\)\\s*\\{[\\s\\S]*?\\}",
      "modifiers": [],
      "description": "Loop blocks (for/while)",
      "rangeScope": "block"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression"],
  "multilineTokens": ["comment", "string"]
}
