{
  "language": "docker-compose",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "variable", "property", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "documentation"]
  },
  "rangeTokenRules": [
    {
      "type": "namespace",
      "pattern": "\\bservices:\\s*\\n(\\s+\\w+:[\\s\\S]*?)(?=\\n\\w|$)",
      "modifiers": ["declaration"],
      "description": "Service definition blocks under services key",
      "rangeScope": "block"
    },
    {
      "type": "property",
      "pattern": "\\benvironment:\\s*\\n(\\s+-\\s+\\S+=[^\\n]*\\n?)+",
      "modifiers": ["declaration"],
      "description": "Environment variable declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "property",
      "pattern": "\\bvolumes:\\s*\\n(\\s+-\\s+[^\\n]+\\n?)+",
      "modifiers": ["declaration"],
      "description": "Volume mount declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "property",
      "pattern": "\\bports:\\s*\\n(\\s+-\\s+[^\\n]+\\n?)+",
      "modifiers": ["declaration"],
      "description": "Port mapping declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\b(build|image|container_name|restart|depends_on|networks|command|entrypoint)\\s*:",
      "modifiers": [],
      "description": "Service configuration key directives",
      "rangeScope": "statement"
    },
    {
      "type": "type",
      "pattern": "\\bnetworks:\\s*\\n(\\s+\\w+:[\\s\\S]*?)(?=\\n\\w|$)",
      "modifiers": ["declaration"],
      "description": "Network definition blocks",
      "rangeScope": "block"
    },
    {
      "type": "type",
      "pattern": "\\bvolumes:\\s*\\n(\\s+\\w+:[\\s\\S]*?)(?=\\n\\w|$)",
      "modifiers": ["declaration"],
      "description": "Top-level named volume declarations",
      "rangeScope": "block"
    },
    {
      "type": "variable",
      "pattern": "\\$\\{[^}]+\\}",
      "modifiers": [],
      "description": "Variable interpolation expressions",
      "rangeScope": "expression"
    },
    {
      "type": "comment",
      "pattern": "#.*$",
      "modifiers": ["documentation"],
      "description": "Line comments",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
