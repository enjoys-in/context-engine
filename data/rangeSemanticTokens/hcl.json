{
  "language": "hcl",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["type", "variable", "property", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly"]
  },
  "rangeTokenRules": [
    {
      "type": "keyword",
      "pattern": "\\b(resource)\\s+\"([^\"]+)\"\\s+\"([^\"]+)\"",
      "modifiers": ["declaration"],
      "description": "Resource block declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\b(data)\\s+\"([^\"]+)\"\\s+\"([^\"]+)\"",
      "modifiers": ["declaration"],
      "description": "Data source block declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "variable",
      "pattern": "\\b(variable)\\s+\"([^\"]+)\"",
      "modifiers": ["declaration"],
      "description": "Variable declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "variable",
      "pattern": "\\b(output)\\s+\"([^\"]+)\"",
      "modifiers": ["declaration"],
      "description": "Output declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "variable",
      "pattern": "\\$\\{([^}]+)\\}",
      "modifiers": [],
      "description": "Interpolation expressions",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\b(module)\\s+\"([^\"]+)\"",
      "modifiers": ["declaration"],
      "description": "Module block declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "function",
      "pattern": "\\b([a-z_][a-z0-9_]*)\\s*\\(",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in function calls",
      "rangeScope": "expression"
    },
    {
      "type": "property",
      "pattern": "^\\s*([a-z_][a-z0-9_]*)\\s*=",
      "modifiers": [],
      "description": "Attribute assignments",
      "rangeScope": "statement"
    },
    {
      "type": "comment",
      "pattern": "#.*$|//.*$|/\\*[\\s\\S]*?\\*/",
      "modifiers": [],
      "description": "Single and multi-line comments",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}