{
  "language": "clojure",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "variable", "property", "function", "method", "macro", "keyword", "comment", "string", "number", "regexp", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "deprecated", "documentation", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "function",
      "pattern": "\\(defn-?\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Function declarations with defn/defn-",
      "rangeScope": "declaration"
    },
    {
      "type": "variable",
      "pattern": "\\(def\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Var definitions with def",
      "rangeScope": "declaration"
    },
    {
      "type": "namespace",
      "pattern": "\\(ns\\s+[\\w.-]+[\\s\\S]*?\\)",
      "modifiers": ["declaration"],
      "description": "Namespace declarations with require/import",
      "rangeScope": "declaration"
    },
    {
      "type": "macro",
      "pattern": "\\(defmacro\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Macro definitions",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\(let\\s*\\[[^\\]]*\\]",
      "modifiers": [],
      "description": "Let binding expressions",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\(cond[\\s\\S]*?\\)",
      "modifiers": [],
      "description": "Cond conditional expressions",
      "rangeScope": "expression"
    },
    {
      "type": "function",
      "pattern": "\\([\\w./-]+\\s+",
      "modifiers": [],
      "description": "S-expression function call forms",
      "rangeScope": "expression"
    },
    {
      "type": "type",
      "pattern": "\\(defrecord\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Record type declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "type",
      "pattern": "\\(defprotocol\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "Protocol declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "function",
      "pattern": "\\(fn\\s*\\[[^\\]]*\\]",
      "modifiers": ["definition"],
      "description": "Anonymous function expressions",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "\\(->\\s+|\\(->>\\s+",
      "modifiers": [],
      "description": "Threading macro expressions",
      "rangeScope": "expression"
    }
  ],
  "supportedRangeScopes": ["expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
