{
  "language": "powerquery",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["type", "parameter", "variable", "property", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "keyword",
      "pattern": "\\blet\\b[\\s\\S]*?\\bin\\b",
      "modifiers": [],
      "description": "Let/in expression blocks",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\beach\\b",
      "modifiers": [],
      "description": "Each shorthand expression (syntactic sugar for (_) =>)",
      "rangeScope": "expression"
    },
    {
      "type": "type",
      "pattern": "\\btype\\s+(table|record|list|text|number|logical|date|datetime|duration|time|binary|type|function|action|anynonnull|none|null)\\b",
      "modifiers": ["declaration"],
      "description": "Type declarations and annotations",
      "rangeScope": "declaration"
    },
    {
      "type": "variable",
      "pattern": "#\"[^\"]+\"",
      "modifiers": [],
      "description": "Quoted identifiers with special characters",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "#shared",
      "modifiers": ["defaultLibrary"],
      "description": "#shared environment reference",
      "rangeScope": "expression"
    },
    {
      "type": "function",
      "pattern": "\\([^)]*\\)\\s*=>|\\beach\\b",
      "modifiers": ["declaration"],
      "description": "Function expressions (lambda syntax)",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\b(if|then|else|try|otherwise|error)\\b",
      "modifiers": [],
      "description": "Conditional and error handling keywords",
      "rangeScope": "statement"
    },
    {
      "type": "function",
      "pattern": "\\b(Table|List|Record|Text|Number|Date|DateTime|Duration|Time|Binary|Lines|Splitter|Combiner|Comparer|Expression|Function|Value)\\.[A-Z]\\w+",
      "modifiers": ["defaultLibrary"],
      "description": "Standard library M function calls",
      "rangeScope": "expression"
    },
    {
      "type": "comment",
      "pattern": "//.*$|/\\*[\\s\\S]*?\\*/",
      "modifiers": [],
      "description": "Single-line and block comments",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
