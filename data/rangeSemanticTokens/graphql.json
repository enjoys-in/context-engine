{
  "language": "graphql",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["type", "enum", "interface", "typeParameter", "variable", "property", "enumMember", "function", "keyword", "comment", "string", "number", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "deprecated"]
  },
  "rangeTokenRules": [
    {
      "type": "type",
      "pattern": "\\btype\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Type definitions",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\binput\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Input type definitions",
      "rangeScope": "declaration"
    },
    {
      "type": "enum",
      "pattern": "\\benum\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Enum type definitions",
      "rangeScope": "declaration"
    },
    {
      "type": "function",
      "pattern": "\\b(query|mutation|subscription)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "modifiers": ["declaration"],
      "description": "Query, mutation, and subscription declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "property",
      "pattern": "^\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*[:(]",
      "modifiers": [],
      "description": "Field definitions and selections",
      "rangeScope": "expression"
    },
    {
      "type": "decorator",
      "pattern": "@([a-zA-Z_][a-zA-Z0-9_]*)",
      "modifiers": [],
      "description": "Directives like @deprecated, @skip, @include",
      "rangeScope": "expression"
    },
    {
      "type": "interface",
      "pattern": "\\binterface\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Interface definitions",
      "rangeScope": "declaration"
    },
    {
      "type": "variable",
      "pattern": "\\$([a-zA-Z_][a-zA-Z0-9_]*)",
      "modifiers": [],
      "description": "Variable references",
      "rangeScope": "expression"
    },
    {
      "type": "comment",
      "pattern": "#.*$|\"\"\"[\\s\\S]*?\"\"\"",
      "modifiers": [],
      "description": "Comments and description strings",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}