{
  "language": "razor",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "parameter", "variable", "property", "function", "method", "keyword", "modifier", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "keyword",
      "pattern": "@model\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "@model directive declaring the page model type",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "@inject\\s+\\w+\\s+\\w+",
      "modifiers": ["declaration"],
      "description": "@inject directive for dependency injection",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "@\\{[\\s\\S]*?\\}",
      "modifiers": [],
      "description": "Razor code blocks @{ ... }",
      "rangeScope": "block"
    },
    {
      "type": "variable",
      "pattern": "@\\([^)]+\\)",
      "modifiers": [],
      "description": "Explicit Razor expressions @(...)",
      "rangeScope": "expression"
    },
    {
      "type": "keyword",
      "pattern": "@(using|namespace|inherits|implements|attribute|layout|page|section|addTagHelper|removeTagHelper)\\b",
      "modifiers": [],
      "description": "Razor directives",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "@(if|else|elseif|foreach|for|while|switch|case|try|catch|finally|lock|using)\\b",
      "modifiers": [],
      "description": "Razor control flow statements",
      "rangeScope": "block"
    },
    {
      "type": "function",
      "pattern": "@functions\\s*\\{",
      "modifiers": ["declaration"],
      "description": "@functions block for defining methods",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "@(Html|Url|Component|ViewBag|ViewData|Model)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in Razor helpers and properties",
      "rangeScope": "expression"
    },
    {
      "type": "comment",
      "pattern": "@\\*[\\s\\S]*?\\*@|//.*$|/\\*[\\s\\S]*?\\*/",
      "modifiers": [],
      "description": "Razor and C# comments",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
