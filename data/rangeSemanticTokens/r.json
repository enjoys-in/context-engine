{
  "language": "r",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "parameter", "variable", "property", "function", "method", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "function",
      "pattern": "\\w+\\s*<-\\s*function\\s*\\(",
      "modifiers": ["declaration"],
      "description": "Function definitions via <- assignment",
      "rangeScope": "declaration"
    },
    {
      "type": "variable",
      "pattern": "\\w+\\s*(<-|<<-|=)\\s*",
      "modifiers": [],
      "description": "Variable assignment with <- or <<- operators",
      "rangeScope": "statement"
    },
    {
      "type": "class",
      "pattern": "\\b(setClass|setRefClass|R6Class|setGeneric|setMethod)\\s*\\(",
      "modifiers": ["declaration"],
      "description": "S4 class, R6 class, and generic method declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\b(if|else|for|in|while|repeat|next|break|return)\\b",
      "modifiers": [],
      "description": "Control flow keywords",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\b(library|require|source)\\s*\\(",
      "modifiers": [],
      "description": "Package loading and source statements",
      "rangeScope": "statement"
    },
    {
      "type": "operator",
      "pattern": "%[^%]+%|\\|>",
      "modifiers": [],
      "description": "Pipe operators and custom infix operators",
      "rangeScope": "expression"
    },
    {
      "type": "function",
      "pattern": "\\b(apply|sapply|lapply|vapply|tapply|mapply|Map|Reduce|Filter)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Apply family and functional programming functions",
      "rangeScope": "expression"
    },
    {
      "type": "string",
      "pattern": "~\\s*[\\w.+*:|]+",
      "modifiers": [],
      "description": "Formula expressions",
      "rangeScope": "expression"
    },
    {
      "type": "comment",
      "pattern": "#.*$",
      "modifiers": [],
      "description": "Single-line comments",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
