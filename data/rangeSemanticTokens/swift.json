{
  "language": "swift",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "enum", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "function", "method", "keyword", "modifier", "comment", "string", "number", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "async", "documentation", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "function",
      "pattern": "\\bfunc\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Function declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "class",
      "pattern": "\\bclass\\s+[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Class declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "struct",
      "pattern": "\\bstruct\\s+[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Struct declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bprotocol\\s+[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Protocol declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "enum",
      "pattern": "\\benum\\s+[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Enum declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\bguard\\s+let\\b",
      "modifiers": [],
      "description": "Guard-let unwrapping blocks",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\bif\\s+let\\b",
      "modifiers": [],
      "description": "If-let optional binding blocks",
      "rangeScope": "block"
    },
    {
      "type": "function",
      "pattern": "\\{\\s*(\\[\\w+\\]\\s+)?\\(.*?\\)\\s+(->\\s+\\w+\\s+)?in",
      "modifiers": [],
      "description": "Closure expressions",
      "rangeScope": "expression"
    },
    {
      "type": "variable",
      "pattern": "\\blet\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration", "readonly"],
      "description": "Constant declarations",
      "rangeScope": "statement"
    },
    {
      "type": "variable",
      "pattern": "\\bvar\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Variable declarations",
      "rangeScope": "statement"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
