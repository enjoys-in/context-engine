{
  "language": "systemverilog",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "enum", "interface", "parameter", "variable", "property", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "documentation", "defaultLibrary"]
  },
  "rangeTokenRules": [
    {
      "type": "keyword",
      "pattern": "\\bmodule\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Module declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "interface",
      "pattern": "\\binterface\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Interface declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "class",
      "pattern": "\\bclass\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Class declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "keyword",
      "pattern": "\\balways(_ff|_comb|_latch)?\\b",
      "modifiers": [],
      "description": "Always procedural blocks",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\binitial\\b",
      "modifiers": [],
      "description": "Initial procedural blocks",
      "rangeScope": "block"
    },
    {
      "type": "keyword",
      "pattern": "\\bassign\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": [],
      "description": "Continuous assign statements",
      "rangeScope": "statement"
    },
    {
      "type": "function",
      "pattern": "\\b(task|function)\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Task and function declarations",
      "rangeScope": "declaration"
    },
    {
      "type": "variable",
      "pattern": "\\b(wire|reg|logic|bit|integer)\\s+[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Signal and variable declarations",
      "rangeScope": "statement"
    },
    {
      "type": "keyword",
      "pattern": "\\bgenerate\\b",
      "modifiers": [],
      "description": "Generate blocks",
      "rangeScope": "block"
    },
    {
      "type": "macro",
      "pattern": "`[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": [],
      "description": "Compiler directive macros",
      "rangeScope": "expression"
    }
  ],
  "supportedRangeScopes": ["statement", "block", "expression", "declaration"],
  "multilineTokens": ["comment", "string"]
}
