{
  "language": "lua",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent contents within do/end, function/end, if/end blocks",
      "pattern": "\\b(do|function|if|then|elseif|else|for|while|repeat|until|end)\\b",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Normalize spacing around operators",
      "pattern": "\\s*(==|~=|>=|<=|\\.\\.|[+\\-*/%]=?|=)\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Align consecutive local variable declarations",
      "pattern": "^\\s*local\\s+\\w+\\s*=",
      "action": "align",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
