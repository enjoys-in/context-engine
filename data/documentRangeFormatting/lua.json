{
  "language": "lua",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "lua indentation",
      "action": "reindent",
      "options": {
        "tabSize": 2,
        "insertSpaces": true
      }
    },
    {
      "description": "Indent block contents",
      "action": "indent",
      "pattern": "\\{[^}]*\\}"
    },
    {
      "description": "Normalize operator spacing",
      "action": "normalizeSpacing",
      "pattern": "\\s*([+\\-*/%=<>!&|^]=?)\\s*"
    },
    {
      "description": "Align assignments",
      "action": "align",
      "pattern": "\\s*=\\s*",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Indent function/end blocks",
      "action": "indent",
      "pattern": "function.*$"
    },
    {
      "description": "Indent if/then blocks",
      "action": "indent",
      "pattern": "then\\s*$"
    },
    {
      "description": "Format table constructors",
      "action": "indent",
      "pattern": "\\{\\s*$"
    },
    {
      "description": "Align assignments",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "comment",
    "selection"
  ]
}
