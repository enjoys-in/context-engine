{
  "language": "nginx",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent block contents within braces",
      "pattern": "\\{[^}]*\\}",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Align consecutive directive values",
      "pattern": "^\\s*\\w+\\s+",
      "action": "align",
      "options": { "alignOn": " " }
    },
    {
      "description": "Normalize spacing between directive and value",
      "pattern": "^\\s*\\w+\\s{2,}",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block"]
}
