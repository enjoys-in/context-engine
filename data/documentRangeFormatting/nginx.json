{
  "language": "nginx",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent server/location blocks",
      "action": "indent",
      "pattern": "(server|location|upstream|events|http|map)\\s*.*\\{"
    },
    {
      "description": "Align directive values",
      "action": "align",
      "pattern": "^\\s*\\w+\\s+.+;$"
    },
    {
      "description": "Format proxy_pass directives",
      "action": "normalizeSpacing",
      "pattern": "proxy_pass\\s+"
    },
    {
      "description": "Align listen directives",
      "action": "align",
      "pattern": "^\\s*listen\\s+"
    },
    {
      "description": "Indent nested location blocks",
      "action": "indent",
      "pattern": "location\\s+[~=^]*\\s*/"
    },
    {
      "description": "Format SSL directives",
      "action": "align",
      "pattern": "^\\s*ssl_\\w+\\s+"
    },
    {
      "description": "Normalize include directives",
      "action": "normalizeSpacing",
      "pattern": "include\\s+"
    },
    {
      "description": "Align log directives",
      "action": "align",
      "pattern": "^\\s*(access|error)_log\\s+"
    },
    {
      "description": "Format try_files fallback",
      "action": "normalizeSpacing",
      "pattern": "try_files\\s+"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "block",
    "directive",
    "comment",
    "selection",
    "server",
    "location",
    "upstream"
  ]
}
