{
  "language": "protobuf",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent message body fields",
      "pattern": "\\bmessage\\b\\s+\\w+\\s*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Align field numbers in message definitions",
      "pattern": "\\b(optional|required|repeated)?\\s*\\w+\\s+\\w+\\s*=\\s*\\d+",
      "action": "align",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Indent enum body values",
      "pattern": "\\benum\\b\\s+\\w+\\s*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Indent service and rpc definitions",
      "pattern": "\\bservice\\b\\s+\\w+\\s*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Format option declarations",
      "pattern": "\\boption\\b\\s+[\\w.()]+\\s*=",
      "action": "normalizeSpacing",
      "options": {
        "around": "="
      }
    },
    {
      "description": "Indent oneof body fields",
      "pattern": "\\boneof\\b\\s+\\w+\\s*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "message",
    "service",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
