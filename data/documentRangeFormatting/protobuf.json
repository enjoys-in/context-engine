{
  "language": "protobuf",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent message fields",
      "action": "indent",
      "pattern": "(message|enum|service|oneof)\\s+\\w+\\s*\\{"
    },
    {
      "description": "Align field numbers",
      "action": "align",
      "pattern": "=\\s*\\d+;$",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Format RPC declarations",
      "action": "indent",
      "pattern": "rpc\\s+\\w+"
    },
    {
      "description": "Normalize option values",
      "action": "normalizeSpacing",
      "pattern": "option\\s+\\w+\\s*="
    },
    {
      "description": "Align field types",
      "action": "align",
      "pattern": "^\\s*(repeated|optional|required)?\\s*\\w+\\s+\\w+",
      "options": {
        "alignOn": "\\w+\\s*="
      }
    },
    {
      "description": "Format service methods",
      "action": "indent",
      "pattern": "rpc\\s+\\w+\\s*\\("
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "message",
    "enum",
    "service",
    "rpc",
    "comment",
    "selection"
  ]
}
