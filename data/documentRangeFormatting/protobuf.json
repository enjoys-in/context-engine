{
  "language": "protobuf",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent message body fields",
      "pattern": "\\bmessage\\b\\s+\\w+\\s*\\{",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Align field numbers in message definitions",
      "pattern": "\\b(optional|required|repeated)?\\s*\\w+\\s+\\w+\\s*=\\s*\\d+",
      "action": "align",
      "options": { "alignOn": "=" }
    },
    {
      "description": "Indent enum body values",
      "pattern": "\\benum\\b\\s+\\w+\\s*\\{",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Indent service and rpc definitions",
      "pattern": "\\bservice\\b\\s+\\w+\\s*\\{",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Format option declarations",
      "pattern": "\\boption\\b\\s+[\\w.()]+\\s*=",
      "action": "normalizeSpacing",
      "options": { "around": "=" }
    },
    {
      "description": "Indent oneof body fields",
      "pattern": "\\boneof\\b\\s+\\w+\\s*\\{",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "message", "service"]
}
