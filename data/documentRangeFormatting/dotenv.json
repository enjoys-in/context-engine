{
  "language": "dotenv",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Align consecutive variable assignments",
      "pattern": "^\\s*[A-Z_][A-Z0-9_]*\\s*=",
      "action": "align",
      "options": { "alignOn": "=" }
    },
    {
      "description": "Normalize spacing around equals sign",
      "pattern": "\\s*=\\s*",
      "action": "normalizeSpacing",
      "options": { "spacesAroundEquals": false }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": ["statement"]
}
