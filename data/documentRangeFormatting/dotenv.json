{
  "language": "dotenv",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Align variable assignments",
      "action": "align",
      "pattern": "^\\w+=",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Normalize quoting style",
      "action": "normalizeSpacing",
      "pattern": "=\"[^\"]*\"|='[^']*'"
    },
    {
      "description": "Sort alphabetically (optional)",
      "action": "sort",
      "pattern": "^\\w+="
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": [
    "assignment",
    "comment",
    "selection"
  ]
}
