{
  "language": "dotenv",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Align consecutive variable assignments",
      "pattern": "^\\s*[A-Z_][A-Z0-9_]*\\s*=",
      "action": "align",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Normalize spacing around equals sign",
      "pattern": "\\s*=\\s*",
      "action": "normalizeSpacing",
      "options": {
        "spacesAroundEquals": false
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
