{
  "language": "ruby",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent def/class/module bodies",
      "pattern": "\\b(def|class|module)\\b\\s+\\w+",
      "action": "indent",
      "options": {
        "indentBody": true,
        "endKeyword": "end"
      }
    },
    {
      "description": "Indent do..end block bodies",
      "pattern": "\\bdo\\b(\\s*\\|[^|]*\\|)?",
      "action": "indent",
      "options": {
        "indentBody": true,
        "endKeyword": "end"
      }
    },
    {
      "description": "Align hash rocket key-value pairs",
      "pattern": "\\w+\\s*=>\\s*",
      "action": "align",
      "options": {
        "alignOn": "=>"
      }
    },
    {
      "description": "Indent if/unless/case/begin blocks",
      "pattern": "\\b(if|unless|case|begin|while|until)\\b",
      "action": "indent",
      "options": {
        "indentBody": true,
        "endKeyword": "end"
      }
    },
    {
      "description": "Format method chaining with dot operator",
      "pattern": "\\.\\w+[({]?",
      "action": "wrapLine",
      "options": {
        "breakBefore": "."
      }
    },
    {
      "description": "Normalize spacing around heredoc declarations",
      "pattern": "<<[~-]?\\w+",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
