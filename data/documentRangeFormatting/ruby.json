{
  "language": "ruby",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "RuboCop 2-space indentation",
      "action": "reindent",
      "options": {
        "tabSize": 2,
        "insertSpaces": true
      }
    },
    {
      "description": "Normalize operator spacing",
      "action": "normalizeSpacing",
      "pattern": "\\s*(==|!=|>=|<=|&&|\\|\\||=>|<=>|=~|!~|[+\\-*/%&|^]=?|=)\\s*"
    },
    {
      "description": "Wrap lines at 120 characters",
      "action": "wrapLine",
      "pattern": ".{120,}",
      "options": {
        "maxLineLength": 120
      }
    },
    {
      "description": "Align hash rocket pairs",
      "action": "align",
      "pattern": "^\\s*[:\\w]+\\s*=>",
      "options": {
        "alignOn": "=>"
      }
    },
    {
      "description": "Align keyword-style hash values",
      "action": "align",
      "pattern": "^\\s*\\w+:\\s*",
      "options": {
        "alignOn": ":"
      }
    },
    {
      "description": "Indent do..end blocks",
      "action": "indent",
      "pattern": "\\bdo\\b.*$"
    },
    {
      "description": "Indent method chains",
      "action": "indent",
      "pattern": "\\.[a-z]\\w*",
      "options": {
        "continuationIndent": 2
      }
    },
    {
      "description": "Format string interpolation",
      "action": "normalizeSpacing",
      "pattern": "#\\{[^}]+\\}"
    },
    {
      "description": "Indent case-when branches",
      "action": "indent",
      "pattern": "when\\s+.+"
    },
    {
      "description": "Align assignments",
      "action": "align",
      "pattern": "\\s*=\\s*",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Normalize heredoc indentation",
      "action": "reindent",
      "pattern": "<<[~-]?\\w+"
    },
    {
      "description": "Format proc/lambda expressions",
      "action": "normalizeSpacing",
      "pattern": "(proc|lambda|->)\\s*[{(]"
    },
    {
      "description": "Indent rescue/ensure blocks",
      "action": "indent",
      "pattern": "^\\s*(rescue|ensure)\\b"
    },
    {
      "description": "Format array/hash comprehensions",
      "action": "indent",
      "pattern": "\\.(map|select|reject|each)\\s*[{]"
    },
    {
      "description": "Normalize ternary expressions",
      "action": "normalizeSpacing",
      "pattern": ".+\\?.+:.+"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "module",
    "comment",
    "selection",
    "expression",
    "do_end",
    "begin_rescue"
  ]
}
