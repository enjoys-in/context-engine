{
  "language": "redshift",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Uppercase SQL keywords",
      "pattern": "\\b(select|from|where|join|left|right|inner|outer|cross|on|group|order|by|having|limit|insert|update|delete|create|alter|drop|into|values|set|and|or|not|in|exists|between|like|is|null|as|union|intersect|except|with|copy|unload|vacuum|analyze|distkey|sortkey|diststyle)\\b",
      "action": "normalizeSpacing",
      "options": {
        "uppercase": true
      }
    },
    {
      "description": "Align major SQL clauses on new lines",
      "pattern": "\\b(SELECT|FROM|WHERE|JOIN|LEFT JOIN|RIGHT JOIN|GROUP BY|ORDER BY|HAVING|LIMIT|COPY|UNLOAD)\\b",
      "action": "indent",
      "options": {
        "clauseNewline": true
      }
    },
    {
      "description": "Indent subquery blocks",
      "pattern": "\\(\\s*SELECT[\\s\\S]*?\\)",
      "action": "indent",
      "options": {
        "indentLevel": 1
      }
    },
    {
      "description": "Align DISTKEY and SORTKEY definitions",
      "pattern": "\\b(DISTKEY|SORTKEY|DISTSTYLE)\\b\\s*\\(",
      "action": "normalizeSpacing",
      "options": {
        "before": true
      }
    },
    {
      "description": "Format COPY/UNLOAD command options",
      "pattern": "\\b(DELIMITER|IGNOREHEADER|CSV|GZIP|MANIFEST|REGION|IAM_ROLE)\\b",
      "action": "align",
      "options": {
        "alignTo": "option"
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "query",
    "clause",
    "subquery",
    "function",
    "statement",
    "block",
    "class",
    "comment",
    "selection"
  ]
}
