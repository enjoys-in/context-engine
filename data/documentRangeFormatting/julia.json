{
  "language": "julia",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Julia 4-space indentation",
      "action": "reindent"
    },
    {
      "description": "Normalize operator spacing",
      "action": "normalizeSpacing",
      "pattern": "\\s*(==|!=|>=|<=|&&|\\|\\||=>|<:|>:|[+\\-*/^%]=?|=)\\s*"
    },
    {
      "description": "Format function signatures",
      "action": "indent",
      "pattern": "function\\s+\\w+\\([^)]*$"
    },
    {
      "description": "Indent do blocks",
      "action": "indent",
      "pattern": "\\bdo\\b.*$"
    },
    {
      "description": "Align array comprehensions",
      "action": "indent",
      "pattern": "\\[.+for\\s+.+in\\s+"
    },
    {
      "description": "Format multiple dispatch types",
      "action": "normalizeSpacing",
      "pattern": "::\\w+"
    },
    {
      "description": "Indent module bodies",
      "action": "indent",
      "pattern": "module\\s+\\w+"
    },
    {
      "description": "Format macro invocations",
      "action": "normalizeSpacing",
      "pattern": "@\\w+\\s+"
    },
    {
      "description": "Align struct fields",
      "action": "align",
      "pattern": "^\\s*\\w+::\\w+"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "struct",
    "module",
    "comment",
    "selection",
    "expression"
  ]
}
