{
  "language": "julia",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent contents within function/end blocks",
      "pattern": "\\b(function|if|elseif|else|for|while|begin|let|try|catch|finally|do|module|struct|end)\\b",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Normalize spacing around operators",
      "pattern": "\\s*(==|!=|>=|<=|=>|[+\\-*/%]=?|=)\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Align consecutive assignment statements",
      "pattern": "^\\s*\\w+\\s*=",
      "action": "align",
      "options": { "alignOn": "=" }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Wrap long function signatures",
      "pattern": "\\([^)]{80,}\\)",
      "action": "wrapLine",
      "options": { "maxLineLength": 92 }
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "function"]
}
