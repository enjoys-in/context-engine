{
  "language": "julia",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent contents within function/end blocks",
      "pattern": "\\b(function|if|elseif|else|for|while|begin|let|try|catch|finally|do|module|struct|end)\\b",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Normalize spacing around operators",
      "pattern": "\\s*(==|!=|>=|<=|=>|[+\\-*/%]=?|=)\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Align consecutive assignment statements",
      "pattern": "^\\s*\\w+\\s*=",
      "action": "align",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Wrap long function signatures",
      "pattern": "\\([^)]{80,}\\)",
      "action": "wrapLine",
      "options": {
        "maxLineLength": 92
      }
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
