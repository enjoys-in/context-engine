{
  "language": "flow9",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": false
  },
  "rangeFormattingRules": [
    {
      "description": "Indent block contents within braces",
      "pattern": "\\{[^}]*\\}",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Normalize spacing around operators",
      "pattern": "\\s*(==|!=|>=|<=|->|=)\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Indent switch/case blocks",
      "pattern": "\\b(switch|case|default)\\b",
      "action": "indent",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "function"]
}
