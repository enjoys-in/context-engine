{
  "language": "dockerfile",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Align instruction keywords",
      "action": "indent",
      "pattern": "^(FROM|RUN|CMD|COPY|ADD|ENV|ARG|EXPOSE|WORKDIR|VOLUME|USER|LABEL|ENTRYPOINT|HEALTHCHECK|SHELL)\\s+"
    },
    {
      "description": "Format multi-line RUN commands",
      "action": "indent",
      "pattern": "RUN\\s+.*\\\\\\s*$",
      "options": {
        "continuationIndent": 4
      }
    },
    {
      "description": "Align LABEL key-value pairs",
      "action": "align",
      "pattern": "^\\s*\\w+=\"[^\"]*\""
    },
    {
      "description": "Format COPY --from stages",
      "action": "normalizeSpacing",
      "pattern": "COPY\\s+--from=\\w+"
    },
    {
      "description": "Normalize ENV variable assignments",
      "action": "align",
      "pattern": "^ENV\\s+\\w+=",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Indent HEALTHCHECK options",
      "action": "indent",
      "pattern": "HEALTHCHECK\\s+--"
    },
    {
      "description": "Format ARG default values",
      "action": "normalizeSpacing",
      "pattern": "ARG\\s+\\w+="
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "instruction",
    "comment",
    "selection",
    "stage"
  ]
}
