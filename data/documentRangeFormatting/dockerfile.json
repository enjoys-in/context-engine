{
  "language": "dockerfile",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent continuation lines after backslash",
      "pattern": "\\\\\\s*$",
      "action": "indent",
      "options": {
        "continuationIndent": 4
      }
    },
    {
      "description": "Normalize spacing after Dockerfile instructions",
      "pattern": "^\\s*(FROM|RUN|COPY|ADD|CMD|ENTRYPOINT|ENV|EXPOSE|WORKDIR|ARG|LABEL|VOLUME|USER|HEALTHCHECK)\\s+",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Align consecutive ENV or LABEL declarations",
      "pattern": "^\\s*(ENV|LABEL)\\s+\\w+=",
      "action": "align",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
