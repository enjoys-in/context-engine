{
  "language": "dockerfile",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent continuation lines after backslash",
      "pattern": "\\\\\\s*$",
      "action": "indent",
      "options": { "continuationIndent": 4 }
    },
    {
      "description": "Normalize spacing after Dockerfile instructions",
      "pattern": "^\\s*(FROM|RUN|COPY|ADD|CMD|ENTRYPOINT|ENV|EXPOSE|WORKDIR|ARG|LABEL|VOLUME|USER|HEALTHCHECK)\\s+",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Align consecutive ENV or LABEL declarations",
      "pattern": "^\\s*(ENV|LABEL)\\s+\\w+=",
      "action": "align",
      "options": { "alignOn": "=" }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block"]
}
