{
  "language": "restructuredtext",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent directive body content",
      "pattern": "^\\.\\.\\s+\\w+::",
      "action": "indent",
      "options": {
        "indentBody": true,
        "indentLevel": 1
      }
    },
    {
      "description": "Align field list entries",
      "pattern": "^:\\w[^:]*:\\s+",
      "action": "align",
      "options": {
        "alignOn": ":"
      }
    },
    {
      "description": "Normalize bullet list indentation",
      "pattern": "^\\s*[-*+]\\s+",
      "action": "indent",
      "options": {
        "consistent": true
      }
    },
    {
      "description": "Format table column alignment",
      "pattern": "^\\s*[+=]+\\s*$",
      "action": "align",
      "options": {
        "alignColumns": true
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": [
    "block",
    "statement",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
