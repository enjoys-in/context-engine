{
  "language": "restructuredtext",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent directive body content",
      "pattern": "^\\.\\.\\s+\\w+::",
      "action": "indent",
      "options": { "indentBody": true, "indentLevel": 1 }
    },
    {
      "description": "Align field list entries",
      "pattern": "^:\\w[^:]*:\\s+",
      "action": "align",
      "options": { "alignOn": ":" }
    },
    {
      "description": "Normalize bullet list indentation",
      "pattern": "^\\s*[-*+]\\s+",
      "action": "indent",
      "options": { "consistent": true }
    },
    {
      "description": "Format table column alignment",
      "pattern": "^\\s*[+=]+\\s*$",
      "action": "align",
      "options": { "alignColumns": true }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": ["block", "statement"]
}
