{
  "language": "restructuredtext",
  "defaultOptions": {
    "tabSize": 3,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent directive content",
      "action": "indent",
      "pattern": "^\\s*\\.\\.\\s+\\w+::"
    },
    {
      "description": "Format heading underlines",
      "action": "normalizeSpacing",
      "pattern": "^[=\\-~^`]+$"
    },
    {
      "description": "Indent field lists",
      "action": "indent",
      "pattern": "^\\s*:\\w+:"
    },
    {
      "description": "Format definition lists",
      "action": "indent",
      "pattern": "^\\w.*$\\n^\\s+"
    },
    {
      "description": "Normalize literal blocks",
      "action": "indent",
      "pattern": "::\\s*$"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "section",
    "directive",
    "paragraph",
    "list",
    "table",
    "comment",
    "selection"
  ]
}
