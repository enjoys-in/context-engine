{
  "language": "pla",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent input/output table rows",
      "pattern": "^[01-]+\\s*\\|\\s*[01-]+",
      "action": "align",
      "options": {
        "alignOn": "|"
      }
    },
    {
      "description": "Align PLA header directives",
      "pattern": "^\\.(i|o|ilb|ob|p|type|e)\\b",
      "action": "indent",
      "options": {
        "indentLevel": 0
      }
    },
    {
      "description": "Normalize spacing between input and output columns",
      "pattern": "[01-]+\\s+[01-]+",
      "action": "normalizeSpacing",
      "options": {
        "columnSeparator": true
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
