{
  "language": "crontab",
  "defaultOptions": {
    "tabSize": 0,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Align cron fields",
      "action": "align",
      "pattern": "^[*0-9/,-]+\\s+[*0-9/,-]+\\s+"
    },
    {
      "description": "Normalize field spacing",
      "action": "normalizeSpacing",
      "pattern": "\\s+"
    },
    {
      "description": "Format @-directives",
      "action": "normalizeSpacing",
      "pattern": "^@\\w+\\s+"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": [
    "schedule",
    "command",
    "comment",
    "selection"
  ]
}
