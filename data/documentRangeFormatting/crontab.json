{
  "language": "crontab",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Align cron schedule fields",
      "pattern": "^[\\d*,\\-/]+\\s+",
      "action": "align",
      "options": { "alignOn": " " }
    },
    {
      "description": "Normalize spacing between cron fields",
      "pattern": "\\s{2,}",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": ["statement"]
}
