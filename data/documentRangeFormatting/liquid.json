{
  "language": "liquid",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent contents within block tags",
      "pattern": "\\{%[-\\s]*(if|unless|for|case|capture|comment|block|form|paginate|tablerow|raw)\\b",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Indent contents within end block tags",
      "pattern": "\\{%[-\\s]*(endif|endunless|endfor|endcase|endcapture|endcomment|endblock|endform|endpaginate|endtablerow|endraw)\\b",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Normalize spacing within output tags",
      "pattern": "\\{\\{[^}]+\\}\\}",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
