{
  "language": "liquid",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "liquid indentation",
      "action": "reindent",
      "options": {
        "tabSize": 2,
        "insertSpaces": true
      }
    },
    {
      "description": "Indent block contents",
      "action": "indent",
      "pattern": "\\{[^}]*\\}"
    },
    {
      "description": "Normalize operator spacing",
      "action": "normalizeSpacing",
      "pattern": "\\s*([+\\-*/%=<>!&|^]=?)\\s*"
    },
    {
      "description": "Align assignments",
      "action": "align",
      "pattern": "\\s*=\\s*",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Indent Liquid blocks",
      "action": "indent",
      "pattern": "\\{%\\s*(if|for|case|unless|capture|paginate)"
    },
    {
      "description": "Format output tags",
      "action": "normalizeSpacing",
      "pattern": "\\{\\{[^}]+\\}\\}"
    },
    {
      "description": "Format tag arguments",
      "action": "normalizeSpacing",
      "pattern": "\\{%[^%]+%\\}"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "comment",
    "selection"
  ]
}
