{
  "language": "shell",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Shell 2-space indentation",
      "action": "reindent",
      "options": {
        "tabSize": 2,
        "insertSpaces": true
      }
    },
    {
      "description": "Indent if/then/else blocks",
      "action": "indent",
      "pattern": "(then|else)\\s*$"
    },
    {
      "description": "Indent case branches",
      "action": "indent",
      "pattern": "^\\s*\\w+\\)"
    },
    {
      "description": "Format function bodies",
      "action": "indent",
      "pattern": "\\w+\\s*\\(\\)\\s*\\{"
    },
    {
      "description": "Align variable assignments",
      "action": "align",
      "pattern": "^\\s*\\w+=",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Indent heredoc content",
      "action": "indent",
      "pattern": "<<[-~]?\\w+"
    },
    {
      "description": "Normalize test brackets",
      "action": "normalizeSpacing",
      "pattern": "\\[\\[\\s+.+\\s+\\]\\]"
    },
    {
      "description": "Format pipe chains",
      "action": "indent",
      "pattern": "\\|\\s*$",
      "options": {
        "continuationIndent": 4
      }
    },
    {
      "description": "Normalize command substitution",
      "action": "normalizeSpacing",
      "pattern": "\\$\\([^)]+\\)"
    },
    {
      "description": "Indent for/while/until loops",
      "action": "indent",
      "pattern": "^\\s*(for|while|until)\\s+.+;?\\s*do\\s*$"
    },
    {
      "description": "Format array declarations",
      "action": "indent",
      "pattern": "\\w+=\\([^)]*$"
    },
    {
      "description": "Normalize redirection spacing",
      "action": "normalizeSpacing",
      "pattern": "\\s*(>>?|2>>?|&>>?|<)\\s*"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "case",
    "if_block",
    "loop",
    "comment",
    "selection",
    "pipeline"
  ]
}
