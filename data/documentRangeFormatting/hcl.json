{
  "language": "hcl",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "terraform fmt 2-space indentation",
      "action": "reindent",
      "options": {
        "tabSize": 2,
        "insertSpaces": true
      }
    },
    {
      "description": "Align block arguments",
      "action": "align",
      "pattern": "^\\s*\\w+\\s*=",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Indent resource blocks",
      "action": "indent",
      "pattern": "(resource|data|variable|output|module|provider|locals|terraform)\\s+.*\\{"
    },
    {
      "description": "Format for expressions",
      "action": "indent",
      "pattern": "\\[for\\s+"
    },
    {
      "description": "Normalize interpolation",
      "action": "normalizeSpacing",
      "pattern": "\\$\\{[^}]+\\}"
    },
    {
      "description": "Align lifecycle rules",
      "action": "indent",
      "pattern": "lifecycle\\s*\\{"
    },
    {
      "description": "Format conditional expressions",
      "action": "normalizeSpacing",
      "pattern": ".+\\?.+:.+"
    },
    {
      "description": "Indent dynamic blocks",
      "action": "indent",
      "pattern": "dynamic\\s+\"\\w+\"\\s*\\{"
    },
    {
      "description": "Normalize heredoc strings",
      "action": "indent",
      "pattern": "<<-?\\w+"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "block",
    "attribute",
    "expression",
    "comment",
    "selection",
    "resource",
    "variable"
  ]
}
