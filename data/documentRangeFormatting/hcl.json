{
  "language": "hcl",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent block contents within braces",
      "pattern": "\\{[^}]*\\}",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Align consecutive attribute assignments",
      "pattern": "^\\s*\\w+\\s*=",
      "action": "align",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Normalize spacing around equals sign",
      "pattern": "\\s*=\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Indent nested blocks within resource/data definitions",
      "pattern": "\\b(resource|data|variable|output|module|locals|provider)\\b",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
