{
  "language": "cypher",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent clauses within queries",
      "pattern": "\\b(MATCH|WHERE|RETURN|WITH|CREATE|MERGE|DELETE|SET|ORDER BY|LIMIT|SKIP|UNWIND)\\b",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Normalize spacing around relationship arrows",
      "pattern": "\\s*(-\\[.*\\]->?|-+>?)\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Wrap long RETURN clauses",
      "pattern": "RETURN\\s+.{80,}",
      "action": "wrapLine",
      "options": { "maxLineLength": 100 }
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block"]
}
