{
  "language": "cypher",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent clauses within queries",
      "pattern": "\\b(MATCH|WHERE|RETURN|WITH|CREATE|MERGE|DELETE|SET|ORDER BY|LIMIT|SKIP|UNWIND)\\b",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Normalize spacing around relationship arrows",
      "pattern": "\\s*(-\\[.*\\]->?|-+>?)\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Wrap long RETURN clauses",
      "pattern": "RETURN\\s+.{80,}",
      "action": "wrapLine",
      "options": {
        "maxLineLength": 100
      }
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
