{
  "language": "mysql",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent SQL clauses on new lines",
      "pattern": "\\b(SELECT|FROM|WHERE|JOIN|LEFT JOIN|RIGHT JOIN|INNER JOIN|ON|GROUP BY|HAVING|ORDER BY|LIMIT|INSERT|UPDATE|SET|DELETE|VALUES|UNION|EXCEPT|INTERSECT)\\b",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Align consecutive column definitions in CREATE TABLE",
      "pattern": "^\\s+`?\\w+`?\\s+\\w+",
      "action": "align",
      "options": { "alignOn": " " }
    },
    {
      "description": "Normalize spacing around comparison operators",
      "pattern": "\\s*(=|<>|!=|>=|<=|<|>|LIKE|IN|BETWEEN)\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Wrap long SELECT column lists",
      "pattern": "SELECT\\s+.{80,}\\s+FROM",
      "action": "wrapLine",
      "options": { "maxLineLength": 100 }
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block"]
}
