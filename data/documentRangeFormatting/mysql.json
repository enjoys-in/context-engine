{
  "language": "mysql",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Uppercase SQL keywords",
      "action": "normalizeCase",
      "pattern": "\\b(SELECT|FROM|WHERE|INSERT|UPDATE|DELETE|CREATE|ALTER|DROP|JOIN|ON|AND|OR|NOT|NULL|IN|BETWEEN|LIKE|ORDER|BY|GROUP|HAVING|UNION|SET|VALUES|INTO|AS|CASE|WHEN|THEN|ELSE|END|EXISTS|DISTINCT|LIMIT|OFFSET|LEFT|RIGHT|INNER|OUTER|FULL|CROSS)\\b",
      "options": {
        "targetCase": "upper"
      }
    },
    {
      "description": "Indent subqueries",
      "action": "indent",
      "pattern": "\\(\\s*SELECT"
    },
    {
      "description": "Align SELECT columns",
      "action": "align",
      "pattern": "^\\s*\\w+\\.?\\w*\\s*,?$"
    },
    {
      "description": "One clause per line",
      "action": "wrapLine",
      "pattern": "\\b(SELECT|FROM|WHERE|JOIN|ON|GROUP BY|ORDER BY|HAVING|LIMIT)\\b"
    },
    {
      "description": "Indent JOIN conditions",
      "action": "indent",
      "pattern": "ON\\s+\\w+",
      "options": {
        "continuationIndent": 4
      }
    },
    {
      "description": "Align CASE-WHEN expressions",
      "action": "indent",
      "pattern": "WHEN\\s+.+THEN"
    },
    {
      "description": "Format IN clause values",
      "action": "indent",
      "pattern": "IN\\s*\\("
    },
    {
      "description": "Normalize comparison operators",
      "action": "normalizeSpacing",
      "pattern": "\\s*(=|<>|!=|>=|<=|>|<)\\s*"
    },
    {
      "description": "Indent INSERT column list",
      "action": "indent",
      "pattern": "INSERT\\s+INTO\\s+\\w+\\s*\\("
    },
    {
      "description": "Format CREATE TABLE columns",
      "action": "indent",
      "pattern": "^\\s*\\w+\\s+\\w+"
    },
    {
      "description": "Align UPDATE SET clauses",
      "action": "align",
      "pattern": "^\\s*\\w+\\s*=",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Normalize function calls",
      "action": "normalizeSpacing",
      "pattern": "\\w+\\s*\\("
    },
    {
      "description": "Format window functions",
      "action": "indent",
      "pattern": "OVER\\s*\\("
    },
    {
      "description": "Format CTE (WITH clause)",
      "action": "indent",
      "pattern": "WITH\\s+\\w+\\s+AS\\s*\\("
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Format DELIMITER statements",
      "action": "normalizeSpacing",
      "pattern": "DELIMITER\\s+"
    },
    {
      "description": "Format AUTO_INCREMENT",
      "action": "normalizeSpacing",
      "pattern": "AUTO_INCREMENT\\s*=?"
    },
    {
      "description": "Format ENGINE clause",
      "action": "normalizeSpacing",
      "pattern": "ENGINE\\s*="
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "query",
    "subquery",
    "expression",
    "comment",
    "selection",
    "cte",
    "procedure",
    "trigger"
  ]
}
