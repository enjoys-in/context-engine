{
  "language": "apex",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "apex indentation",
      "action": "reindent",
      "options": {
        "tabSize": 4,
        "insertSpaces": true
      }
    },
    {
      "description": "Indent block contents",
      "action": "indent",
      "pattern": "\\{[^}]*\\}"
    },
    {
      "description": "Normalize operator spacing",
      "action": "normalizeSpacing",
      "pattern": "\\s*([+\\-*/%=<>!&|^]=?)\\s*"
    },
    {
      "description": "Align assignments",
      "action": "align",
      "pattern": "\\s*=\\s*",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Indent class methods",
      "action": "indent",
      "pattern": "(public|private|protected|global)\\s+.*\\{"
    },
    {
      "description": "Format SOQL queries",
      "action": "indent",
      "pattern": "\\[\\s*SELECT"
    },
    {
      "description": "Align DML operations",
      "action": "normalizeSpacing",
      "pattern": "(insert|update|delete|upsert)\\s+"
    },
    {
      "description": "Indent trigger bodies",
      "action": "indent",
      "pattern": "trigger\\s+\\w+"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "comment",
    "selection"
  ]
}
