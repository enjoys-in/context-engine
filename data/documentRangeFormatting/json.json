{
  "language": "json",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent nested objects",
      "action": "indent",
      "pattern": "\\{[^}]*\\}"
    },
    {
      "description": "Indent nested arrays",
      "action": "indent",
      "pattern": "\\[[^\\]]*\\]"
    },
    {
      "description": "One property per line",
      "action": "wrapLine",
      "pattern": ",\\s*\""
    },
    {
      "description": "Normalize colon spacing",
      "action": "normalizeSpacing",
      "pattern": "\"\\s*:\\s*"
    },
    {
      "description": "Format trailing commas removal",
      "action": "normalizeSpacing",
      "pattern": ",\\s*[}\\]]"
    },
    {
      "description": "Align object properties",
      "action": "align",
      "pattern": "^\\s*\"\\w+\"\\s*:",
      "options": {
        "alignOn": ":"
      }
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "object",
    "array",
    "value",
    "selection"
  ]
}
