{
  "language": "json",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent nested objects and arrays",
      "pattern": "[\\[{][^\\]}]*[\\]}]",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Normalize spacing after colons in key-value pairs",
      "pattern": "\"[^\"]+\"\\s*:\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Align consecutive key-value pairs",
      "pattern": "\"[^\"]+\"\\s*:",
      "action": "align",
      "options": { "alignOn": ":" }
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block"]
}
