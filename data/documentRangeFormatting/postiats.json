{
  "language": "postiats",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent function body blocks",
      "pattern": "\\b(fun|fn|implement|val|var)\\b[^=]*=",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Align pattern match clauses",
      "pattern": "\\|\\s+\\w+.*=>",
      "action": "align",
      "options": {
        "alignOn": "=>"
      }
    },
    {
      "description": "Indent begin..end blocks",
      "pattern": "\\bbegin\\b[\\s\\S]*?\\bend\\b",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Normalize spacing around type annotations",
      "pattern": ":\\s*\\w+",
      "action": "normalizeSpacing",
      "options": {
        "afterColon": true
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
