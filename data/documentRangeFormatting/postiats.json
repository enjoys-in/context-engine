{
  "language": "postiats",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent function body blocks",
      "pattern": "\\b(fun|fn|implement|val|var)\\b[^=]*=",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Align pattern match clauses",
      "pattern": "\\|\\s+\\w+.*=>",
      "action": "align",
      "options": { "alignOn": "=>" }
    },
    {
      "description": "Indent begin..end blocks",
      "pattern": "\\bbegin\\b[\\s\\S]*?\\bend\\b",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Normalize spacing around type annotations",
      "pattern": ":\\s*\\w+",
      "action": "normalizeSpacing",
      "options": { "afterColon": true }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "function"]
}
