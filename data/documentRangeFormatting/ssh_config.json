{
  "language": "ssh_config",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent Host/Match block directives",
      "pattern": "^(Host|Match)\\b\\s+",
      "action": "indent",
      "options": { "indentBody": true, "indentLevel": 1 }
    },
    {
      "description": "Align key-value directive pairs",
      "pattern": "^\\s+\\w+\\s+",
      "action": "align",
      "options": { "alignOn": "value" }
    },
    {
      "description": "Normalize spacing between directive and value",
      "pattern": "^\\s*(\\w+)\\s+",
      "action": "normalizeSpacing",
      "options": { "singleSpace": true }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": ["block", "statement"]
}
