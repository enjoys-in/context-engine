{
  "language": "ssh_config",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent Host/Match block directives",
      "pattern": "^(Host|Match)\\b\\s+",
      "action": "indent",
      "options": {
        "indentBody": true,
        "indentLevel": 1
      }
    },
    {
      "description": "Align key-value directive pairs",
      "pattern": "^\\s+\\w+\\s+",
      "action": "align",
      "options": {
        "alignOn": "value"
      }
    },
    {
      "description": "Normalize spacing between directive and value",
      "pattern": "^\\s*(\\w+)\\s+",
      "action": "normalizeSpacing",
      "options": {
        "singleSpace": true
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": [
    "block",
    "statement",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
