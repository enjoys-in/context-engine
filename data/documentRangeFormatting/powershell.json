{
  "language": "powershell",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent script block and function bodies",
      "pattern": "\\b(function|filter|workflow)\\b\\s+\\w+[^{]*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Indent control flow block bodies",
      "pattern": "\\b(if|elseif|else|foreach|for|while|switch|try|catch|finally)\\b[^{]*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Align hashtable key-value pairs",
      "pattern": "@\\{[\\s\\S]*?\\}",
      "action": "align",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Format pipeline continuation across lines",
      "pattern": "\\|\\s*\\n\\s*\\w+-\\w+",
      "action": "indent",
      "options": {
        "continuationIndent": true
      }
    },
    {
      "description": "Normalize spacing around PowerShell operators",
      "pattern": "\\s*(-eq|-ne|-gt|-lt|-ge|-le|-like|-match|-contains|-in|-notin)\\s*",
      "action": "normalizeSpacing",
      "options": {
        "around": "operator"
      }
    },
    {
      "description": "Indent param block contents",
      "pattern": "\\bparam\\b\\s*\\([\\s\\S]*?\\)",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
