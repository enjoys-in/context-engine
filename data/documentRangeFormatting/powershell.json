{
  "language": "powershell",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "PowerShell 4-space indentation",
      "action": "reindent",
      "options": {
        "tabSize": 4,
        "insertSpaces": true
      }
    },
    {
      "description": "Indent scriptblock bodies",
      "action": "indent",
      "pattern": "\\{\\s*$"
    },
    {
      "description": "Format pipeline continuation",
      "action": "indent",
      "pattern": "\\|\\s*$",
      "options": {
        "continuationIndent": 4
      }
    },
    {
      "description": "Align hash table entries",
      "action": "align",
      "pattern": "^\\s*\\w+\\s*=",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Format splatting variables",
      "action": "indent",
      "pattern": "@\\w+\\s*=\\s*@\\{"
    },
    {
      "description": "Indent try/catch/finally blocks",
      "action": "indent",
      "pattern": "(try|catch|finally)\\s*\\{"
    },
    {
      "description": "Normalize comparison operators",
      "action": "normalizeSpacing",
      "pattern": "\\s*-(eq|ne|gt|lt|ge|le|match|like|contains|in|notin)\\s*"
    },
    {
      "description": "Format parameter blocks",
      "action": "indent",
      "pattern": "\\[Parameter\\([^)]*\\)\\]"
    },
    {
      "description": "Align function parameters",
      "action": "indent",
      "pattern": "param\\s*\\(\\s*$"
    },
    {
      "description": "Format comment-based help",
      "action": "indent",
      "pattern": "^\\s*\\.\\w+"
    },
    {
      "description": "Normalize string expansion",
      "action": "normalizeSpacing",
      "pattern": "\\$\\([^)]+\\)"
    },
    {
      "description": "Format Where-Object/ForEach-Object",
      "action": "indent",
      "pattern": "(Where-Object|ForEach-Object)\\s*\\{"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "scriptblock",
    "comment",
    "selection",
    "pipeline",
    "parameter_block"
  ]
}
