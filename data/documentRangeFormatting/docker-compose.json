{
  "language": "docker-compose",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "YAML 2-space indentation",
      "action": "reindent",
      "options": {
        "tabSize": 2,
        "insertSpaces": true
      }
    },
    {
      "description": "Align service properties",
      "action": "align",
      "pattern": "^\\s{2,}\\w+:",
      "options": {
        "alignOn": ":"
      }
    },
    {
      "description": "Indent port mappings",
      "action": "indent",
      "pattern": "^\\s*-\\s+\"?\\d+:\\d+\"?"
    },
    {
      "description": "Format environment variables",
      "action": "align",
      "pattern": "^\\s*-?\\s*\\w+=",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Indent volume mount paths",
      "action": "indent",
      "pattern": "^\\s*-\\s+[./~]"
    },
    {
      "description": "Align depends_on entries",
      "action": "indent",
      "pattern": "^\\s*-\\s+\\w+"
    },
    {
      "description": "Format deploy replicas",
      "action": "indent",
      "pattern": "deploy:\\s*$"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "service",
    "volume",
    "network",
    "comment",
    "selection"
  ]
}
