{
  "language": "docker-compose",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent nested YAML mappings",
      "pattern": "^\\s*\\w[\\w-]*:",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Align consecutive key-value pairs at same level",
      "pattern": "^\\s*\\w[\\w-]*:\\s+",
      "action": "align",
      "options": { "alignOn": ":" }
    },
    {
      "description": "Normalize spacing after colons",
      "pattern": ":\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block"]
}
