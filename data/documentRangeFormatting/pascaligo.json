{
  "language": "pascaligo",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent block contents within begin/end and block/end",
      "pattern": "\\b(begin|end|block|function|if|then|else|for|while|case|record|with)\\b",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Normalize spacing around assignment operators",
      "pattern": "\\s*(:=|=)\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Align consecutive const/var declarations",
      "pattern": "^\\s*(const|var)\\s+\\w+\\s*:",
      "action": "align",
      "options": { "alignOn": ":" }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "function"]
}
