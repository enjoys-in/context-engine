{
  "language": "sol",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent contract, library, and interface bodies",
      "pattern": "\\b(contract|library|interface)\\b\\s+\\w+[^{]*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Indent function and modifier bodies",
      "pattern": "\\b(function|modifier|constructor|receive|fallback)\\b[^{]*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Align struct and enum member definitions",
      "pattern": "\\b(struct|enum)\\b\\s+\\w+\\s*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Normalize spacing around mapping type declarations",
      "pattern": "mapping\\s*\\(\\s*\\w+\\s*=>\\s*\\w+\\s*\\)",
      "action": "normalizeSpacing",
      "options": {
        "around": "=>"
      }
    },
    {
      "description": "Indent event and error parameter lists",
      "pattern": "\\b(event|error)\\b\\s+\\w+\\s*\\(",
      "action": "align",
      "options": {
        "alignParameters": true
      }
    },
    {
      "description": "Format visibility and state mutability modifiers",
      "pattern": "\\b(public|private|internal|external|pure|view|payable)\\b",
      "action": "normalizeSpacing",
      "options": {
        "singleSpace": true
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
