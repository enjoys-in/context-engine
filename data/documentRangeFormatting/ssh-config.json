{
  "language": "ssh-config",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent host block directives",
      "action": "indent",
      "pattern": "^\\s+\\w+\\s+"
    },
    {
      "description": "Align Host blocks",
      "action": "align",
      "pattern": "^Host\\s+"
    },
    {
      "description": "Align directive values",
      "action": "align",
      "pattern": "^\\s*\\w+\\s+",
      "options": {
        "alignOn": "\\s"
      }
    },
    {
      "description": "Normalize boolean values",
      "action": "normalizeSpacing",
      "pattern": "\\s+(yes|no)\\s*$"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": [
    "host_block",
    "directive",
    "comment",
    "selection"
  ]
}
