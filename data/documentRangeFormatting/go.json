{
  "language": "go",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": false
  },
  "rangeFormattingRules": [
    {
      "description": "gofmt-style tab indentation",
      "action": "reindent",
      "options": {
        "tabSize": 4,
        "insertSpaces": false
      }
    },
    {
      "description": "Normalize operator spacing",
      "action": "normalizeSpacing",
      "pattern": "\\s*(:=|==|!=|>=|<=|&&|\\|\\||<-|[+\\-*/%&|^]=?|=)\\s*"
    },
    {
      "description": "Align struct fields",
      "action": "align",
      "pattern": "^\\s*\\w+\\s+\\w+",
      "options": {
        "alignOn": "\\w+\\s*$"
      }
    },
    {
      "description": "Align struct tags",
      "action": "align",
      "pattern": "`[^`]+`"
    },
    {
      "description": "Format short variable declarations",
      "action": "normalizeSpacing",
      "pattern": "\\w+\\s*:=\\s*"
    },
    {
      "description": "Indent select/switch cases",
      "action": "indent",
      "pattern": "case\\s+.+:|default:"
    },
    {
      "description": "Normalize interface method declarations",
      "action": "indent",
      "pattern": "^\\s*\\w+\\s*\\([^)]*\\)"
    },
    {
      "description": "Align const/var groups",
      "action": "align",
      "pattern": "^\\s*\\w+\\s*=",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Format multiple return values",
      "action": "normalizeSpacing",
      "pattern": "\\(\\s*\\w+.*,.*\\w+.*\\)"
    },
    {
      "description": "Indent composite literals",
      "action": "indent",
      "pattern": "\\w+\\{$"
    },
    {
      "description": "Normalize import groups",
      "action": "align",
      "pattern": "^\\s*\"[^\"]+\""
    },
    {
      "description": "Align map literal values",
      "action": "align",
      "pattern": "^\\s*[^:]+:",
      "options": {
        "alignOn": ":"
      }
    },
    {
      "description": "Format goroutine/defer calls",
      "action": "normalizeSpacing",
      "pattern": "(go|defer)\\s+\\w+"
    },
    {
      "description": "Normalize error checking pattern",
      "action": "indent",
      "pattern": "if\\s+err\\s*!=\\s*nil"
    },
    {
      "description": "Format function signatures",
      "action": "indent",
      "pattern": "func\\s+\\w+\\([^)]*$",
      "options": {
        "continuationIndent": 4
      }
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "struct",
    "interface",
    "comment",
    "selection",
    "expression",
    "const_group",
    "var_group"
  ]
}
