{
  "language": "go",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": false
  },
  "rangeFormattingRules": [
    {
      "description": "Indent block contents within braces",
      "pattern": "\\{[^}]*\\}",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Normalize spacing around binary operators",
      "pattern": "\\s*(==|!=|>=|<=|&&|\\|\\||:=|<-|[+\\-*/%]=?|=)\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Align consecutive var/const declarations",
      "pattern": "^\\s*(var|const)\\s+\\w+",
      "action": "align",
      "options": { "alignOn": "=" }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Align struct field tags",
      "pattern": "`[^`]+`",
      "action": "align",
      "options": { "alignOn": "`" }
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "function"]
}
