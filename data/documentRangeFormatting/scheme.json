{
  "language": "scheme",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent define and lambda bodies",
      "pattern": "\\(\\s*(define|lambda)\\b",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Indent let/let*/letrec binding bodies",
      "pattern": "\\(\\s*(let\\*?|letrec)\\b",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Indent cond/case clause bodies",
      "pattern": "\\(\\s*(cond|case)\\b",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Align nested s-expressions",
      "pattern": "\\([^)]*\\(",
      "action": "align",
      "options": { "alignToOpen": true }
    },
    {
      "description": "Indent if/when/unless expression branches",
      "pattern": "\\(\\s*(if|when|unless)\\b",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "function"]
}
