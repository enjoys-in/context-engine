{
  "language": "scheme",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent define and lambda bodies",
      "pattern": "\\(\\s*(define|lambda)\\b",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Indent let/let*/letrec binding bodies",
      "pattern": "\\(\\s*(let\\*?|letrec)\\b",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Indent cond/case clause bodies",
      "pattern": "\\(\\s*(cond|case)\\b",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Align nested s-expressions",
      "pattern": "\\([^)]*\\(",
      "action": "align",
      "options": {
        "alignToOpen": true
      }
    },
    {
      "description": "Indent if/when/unless expression branches",
      "pattern": "\\(\\s*(if|when|unless)\\b",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
