{
  "language": "typescript",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent function, class, and interface bodies",
      "pattern": "\\b(function|class|interface|enum|type)\\b[^{]*\\{",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Indent control flow block bodies",
      "pattern": "\\b(if|else|for|while|do|switch|try|catch|finally)\\b[^{]*\\{",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Normalize spacing around type annotation colons",
      "pattern": ":\\s*(string|number|boolean|void|any|unknown|never|null|undefined|\\w+(<[^>]*>)?(\\[\\])?)",
      "action": "normalizeSpacing",
      "options": { "beforeColon": false, "afterColon": true }
    },
    {
      "description": "Align generic type parameters",
      "pattern": "<[^>]{40,}>",
      "action": "wrapLine",
      "options": { "maxLength": 80 }
    },
    {
      "description": "Format object/interface property alignment",
      "pattern": "\\w+\\??:\\s*",
      "action": "align",
      "options": { "alignOn": ":" }
    },
    {
      "description": "Format arrow function expressions",
      "pattern": "\\([^)]*\\)\\s*=>\\s*",
      "action": "normalizeSpacing",
      "options": { "around": "=>" }
    },
    {
      "description": "Wrap long import statements",
      "pattern": "import\\s*\\{[^}]{60,}\\}\\s*from",
      "action": "wrapLine",
      "options": { "maxLength": 80 }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "function", "class"]
}
