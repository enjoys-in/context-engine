{
  "language": "csharp",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent block contents within braces",
      "pattern": "\\{[^}]*\\}",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Normalize spacing around binary operators",
      "pattern": "\\s*(==|!=|>=|<=|&&|\\|\\||=>|[+\\-*/%]=?|=)\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Align consecutive property declarations",
      "pattern": "^\\s*(public|private|protected|internal)\\s+\\w+\\s+\\w+",
      "action": "align",
      "options": { "alignOn": "=" }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Wrap long method signatures",
      "pattern": "\\([^)]{80,}\\)",
      "action": "wrapLine",
      "options": { "maxLineLength": 120 }
    },
    {
      "description": "Indent LINQ query expressions",
      "pattern": "\\b(from|where|select|orderby|join|group|into|let)\\b",
      "action": "indent",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "function", "class"]
}
