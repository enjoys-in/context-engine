{
  "language": "csharp",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Allman-style brace placement",
      "action": "indent",
      "pattern": "\\{[^}]*\\}"
    },
    {
      "description": "Normalize operator spacing",
      "action": "normalizeSpacing",
      "pattern": "\\s*(==|!=|>=|<=|&&|\\|\\||\\?\\?|\\?\\.|\\.\\.|is|as|[+\\-*/%&|^]=?|=)\\s*"
    },
    {
      "description": "Wrap lines at 120 characters",
      "action": "wrapLine",
      "pattern": ".{120,}",
      "options": {
        "maxLineLength": 120
      }
    },
    {
      "description": "Indent LINQ query expressions",
      "action": "indent",
      "pattern": "\\b(from|where|select|orderby|group|join|let|into)\\b",
      "options": {
        "continuationIndent": 4
      }
    },
    {
      "description": "Align property accessors",
      "action": "indent",
      "pattern": "\\b(get|set|init)\\b\\s*[{;]"
    },
    {
      "description": "Format string interpolation",
      "action": "normalizeSpacing",
      "pattern": "\\$\"[^\"]*\\{[^}]+\\}"
    },
    {
      "description": "Indent switch cases and patterns",
      "action": "indent",
      "pattern": "case\\s+.+:|default:|=>"
    },
    {
      "description": "Align attribute decorators",
      "action": "indent",
      "pattern": "^\\s*\\[[^\\]]+\\]"
    },
    {
      "description": "Normalize using directives",
      "action": "align",
      "pattern": "^using\\s+"
    },
    {
      "description": "Format lambda and delegate expressions",
      "action": "normalizeSpacing",
      "pattern": "\\s*=>\\s*"
    },
    {
      "description": "Indent XML doc comments",
      "action": "indent",
      "pattern": "^\\s*///"
    },
    {
      "description": "Align object/collection initializers",
      "action": "indent",
      "pattern": "new\\s+\\w+\\s*\\{"
    },
    {
      "description": "Normalize nullable annotations",
      "action": "normalizeSpacing",
      "pattern": "\\w+\\?(?=\\s|\\.)"
    },
    {
      "description": "Format record declarations",
      "action": "indent",
      "pattern": "record\\s+\\w+"
    },
    {
      "description": "Indent pattern matching arms",
      "action": "indent",
      "pattern": "\\s+=>\\s*",
      "options": {
        "continuationIndent": 4
      }
    },
    {
      "description": "Normalize namespace declarations",
      "action": "indent",
      "pattern": "namespace\\s+[\\w.]+"
    },
    {
      "description": "Align method parameters",
      "action": "indent",
      "pattern": "\\([^)]*$",
      "options": {
        "continuationIndent": 4
      }
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "struct",
    "interface",
    "enum",
    "record",
    "comment",
    "selection",
    "expression",
    "property",
    "namespace"
  ]
}
