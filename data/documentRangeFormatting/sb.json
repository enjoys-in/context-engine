{
  "language": "sb",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent Sub/EndSub block bodies",
      "pattern": "\\bSub\\b\\s+\\w+",
      "action": "indent",
      "options": { "indentBody": true, "endKeyword": "EndSub" }
    },
    {
      "description": "Indent If/ElseIf/Else/EndIf blocks",
      "pattern": "\\b(If|ElseIf|Else)\\b.*\\bThen\\b",
      "action": "indent",
      "options": { "indentBody": true, "endKeyword": "EndIf" }
    },
    {
      "description": "Indent For/EndFor and While/EndWhile loops",
      "pattern": "\\b(For|While)\\b",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Normalize spacing around assignment operator",
      "pattern": "\\w+\\s*=\\s*",
      "action": "normalizeSpacing",
      "options": { "around": "=" }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "function"]
}
