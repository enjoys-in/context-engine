{
  "language": "sql",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Uppercase SQL keywords",
      "pattern": "\\b(select|from|where|join|left|right|inner|outer|cross|full|on|group|order|by|having|limit|offset|insert|update|delete|create|alter|drop|into|values|set|and|or|not|in|exists|between|like|is|null|as|union|intersect|except|with|case|when|then|else|end|distinct|top|asc|desc)\\b",
      "action": "normalizeSpacing",
      "options": { "uppercase": true }
    },
    {
      "description": "Align major SQL clauses on new lines",
      "pattern": "\\b(SELECT|FROM|WHERE|JOIN|LEFT JOIN|RIGHT JOIN|INNER JOIN|FULL JOIN|GROUP BY|ORDER BY|HAVING|LIMIT|OFFSET|UNION|INSERT INTO|UPDATE|DELETE FROM|SET|VALUES)\\b",
      "action": "indent",
      "options": { "clauseNewline": true }
    },
    {
      "description": "Indent subquery blocks",
      "pattern": "\\(\\s*SELECT[\\s\\S]*?\\)",
      "action": "indent",
      "options": { "indentLevel": 1 }
    },
    {
      "description": "Align CASE/WHEN/THEN/ELSE/END expressions",
      "pattern": "\\bCASE\\b[\\s\\S]*?\\bEND\\b",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Align column lists in SELECT",
      "pattern": "SELECT\\s+[\\w.,\\s*]+FROM",
      "action": "align",
      "options": { "alignTo": "firstColumn" }
    },
    {
      "description": "Format JOIN ON conditions",
      "pattern": "\\bON\\b\\s+[\\w.]+\\s*=\\s*[\\w.]+",
      "action": "normalizeSpacing",
      "options": { "around": "=" }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["query", "clause", "subquery", "function"]
}
