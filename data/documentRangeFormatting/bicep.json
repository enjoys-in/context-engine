{
  "language": "bicep",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Bicep 2-space indentation",
      "action": "reindent",
      "options": {
        "tabSize": 2,
        "insertSpaces": true
      }
    },
    {
      "description": "Align parameter declarations",
      "action": "align",
      "pattern": "^param\\s+\\w+\\s+\\w+",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Indent resource blocks",
      "action": "indent",
      "pattern": "resource\\s+\\w+\\s+'[^']+'.+\\{"
    },
    {
      "description": "Format module references",
      "action": "indent",
      "pattern": "module\\s+\\w+\\s+'[^']+'"
    },
    {
      "description": "Align output declarations",
      "action": "align",
      "pattern": "^output\\s+\\w+",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Indent conditional deployments",
      "action": "indent",
      "pattern": "if\\s+\\w+\\s*\\{"
    },
    {
      "description": "Format loop expressions",
      "action": "indent",
      "pattern": "\\[for\\s+\\w+\\s+in\\s+"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "resource",
    "module",
    "parameter",
    "variable",
    "output",
    "comment",
    "selection"
  ]
}
