{
  "language": "bicep",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent contents of resource/module blocks",
      "pattern": "\\b(resource|module|param|var|output)\\b.*\\{",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Align property assignments within objects",
      "pattern": "^\\s*\\w+\\s*:",
      "action": "align",
      "options": { "alignOn": ":" }
    },
    {
      "description": "Normalize spacing around colons in properties",
      "pattern": "\\w\\s*:\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "function"]
}
