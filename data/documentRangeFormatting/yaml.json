{
  "language": "yaml",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent nested mapping values",
      "pattern": "^\\s*\\w[\\w.-]*:\\s*$",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Align mapping key-value pairs at same level",
      "pattern": "^\\s*\\w[\\w.-]*:\\s+",
      "action": "align",
      "options": {
        "alignOn": ":"
      }
    },
    {
      "description": "Indent sequence items consistently",
      "pattern": "^\\s*-\\s+",
      "action": "indent",
      "options": {
        "consistent": true
      }
    },
    {
      "description": "Format multiline scalar block indicators (| and >)",
      "pattern": "[|>][+-]?\\s*$",
      "action": "indent",
      "options": {
        "indentBody": true,
        "indentLevel": 1
      }
    },
    {
      "description": "Normalize spacing after colon in mappings",
      "pattern": "^(\\s*\\w[\\w.-]*):\\s*",
      "action": "normalizeSpacing",
      "options": {
        "afterColon": true,
        "singleSpace": true
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": [
    "block",
    "statement",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
