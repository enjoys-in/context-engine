{
  "language": "yaml",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "YAML 2-space indentation",
      "action": "reindent",
      "options": {
        "tabSize": 2,
        "insertSpaces": true
      }
    },
    {
      "description": "Align mapping values",
      "action": "align",
      "pattern": "^\\s*\\w[\\w-]*:\\s",
      "options": {
        "alignOn": ":"
      }
    },
    {
      "description": "Indent list items",
      "action": "indent",
      "pattern": "^\\s*-\\s+"
    },
    {
      "description": "Format multi-line strings",
      "action": "indent",
      "pattern": "[|>][+-]?\\s*$"
    },
    {
      "description": "Normalize anchor/alias references",
      "action": "normalizeSpacing",
      "pattern": "[&*]\\w+"
    },
    {
      "description": "Align environment variables",
      "action": "align",
      "pattern": "^\\s*\\w+=",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Format flow style mappings",
      "action": "normalizeSpacing",
      "pattern": "\\{[^}]+\\}"
    },
    {
      "description": "Format flow style sequences",
      "action": "normalizeSpacing",
      "pattern": "\\[[^\\]]+\\]"
    },
    {
      "description": "Indent nested mappings",
      "action": "indent",
      "pattern": "^\\s*\\w+:\\s*$"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "mapping",
    "sequence",
    "scalar",
    "comment",
    "selection",
    "document"
  ]
}
