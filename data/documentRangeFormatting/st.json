{
  "language": "st",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent method bodies",
      "pattern": "\\w+\\s*\\[",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Indent block closure bodies",
      "pattern": "\\[\\s*[:|]",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Align keyword message arguments",
      "pattern": "\\w+:\\s*\\w+",
      "action": "align",
      "options": {
        "alignOn": ":"
      }
    },
    {
      "description": "Indent conditional and loop blocks (ifTrue:/ifFalse:/whileTrue:)",
      "pattern": "\\b(ifTrue|ifFalse|whileTrue|whileFalse|timesRepeat):\\s*\\[",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Normalize spacing around assignment operator",
      "pattern": "\\w+\\s*:=\\s*",
      "action": "normalizeSpacing",
      "options": {
        "around": ":="
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
