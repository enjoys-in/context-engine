{
  "language": "ecl",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent block contents within BEGIN/END",
      "pattern": "\\b(BEGIN|END)\\b",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Normalize spacing around assignment operators",
      "pattern": "\\s*(:=|=)\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Align consecutive attribute definitions",
      "pattern": "^\\s*\\w+\\s*:=",
      "action": "align",
      "options": { "alignOn": ":=" }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "function"]
}
