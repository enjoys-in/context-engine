{
  "language": "java",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent block contents within braces",
      "pattern": "\\{[^}]*\\}",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Normalize spacing around binary operators",
      "pattern": "\\s*(==|!=|>=|<=|&&|\\|\\||->|[+\\-*/%]=?|=)\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Align consecutive field declarations",
      "pattern": "^\\s*(public|private|protected)\\s+(static\\s+)?(final\\s+)?\\w+\\s+\\w+",
      "action": "align",
      "options": { "alignOn": "=" }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Wrap long method parameter lists",
      "pattern": "\\([^)]{80,}\\)",
      "action": "wrapLine",
      "options": { "maxLineLength": 120 }
    },
    {
      "description": "Indent chained method calls",
      "pattern": "\\.[a-z]\\w*\\(",
      "action": "indent",
      "options": { "continuationIndent": 8 }
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "function", "class"]
}
