{
  "language": "java",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Java-style brace placement (same line)",
      "action": "indent",
      "pattern": "\\{[^}]*\\}"
    },
    {
      "description": "Normalize operator spacing",
      "action": "normalizeSpacing",
      "pattern": "\\s*(==|!=|>=|<=|&&|\\|\\||instanceof|[+\\-*/%&|^]=?|<<?=?|>>?=?|=)\\s*"
    },
    {
      "description": "Wrap long lines at 120 characters",
      "action": "wrapLine",
      "pattern": ".{120,}",
      "options": {
        "maxLineLength": 120
      }
    },
    {
      "description": "Indent chained method calls",
      "action": "indent",
      "pattern": "\\.[a-z]\\w*\\(",
      "options": {
        "continuationIndent": 8
      }
    },
    {
      "description": "Align annotations vertically",
      "action": "indent",
      "pattern": "^\\s*@\\w+"
    },
    {
      "description": "Format generic types",
      "action": "normalizeSpacing",
      "pattern": "<[^>]+>"
    },
    {
      "description": "Indent switch cases",
      "action": "indent",
      "pattern": "case\\s+.+:|default:",
      "options": {
        "indentInner": true
      }
    },
    {
      "description": "Align field declarations",
      "action": "align",
      "pattern": "^\\s*(private|protected|public|static|final)+\\s+\\w+\\s+\\w+"
    },
    {
      "description": "Normalize catch clause spacing",
      "action": "normalizeSpacing",
      "pattern": "catch\\s*\\("
    },
    {
      "description": "Format lambda expressions",
      "action": "normalizeSpacing",
      "pattern": "\\s*->\\s*"
    },
    {
      "description": "Indent JavaDoc comments",
      "action": "indent",
      "pattern": "^\\s*\\*\\s"
    },
    {
      "description": "Align assignment operators",
      "action": "align",
      "pattern": "\\s*=\\s*",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Normalize import statements",
      "action": "align",
      "pattern": "^import\\s+"
    },
    {
      "description": "Format method chaining",
      "action": "wrapLine",
      "pattern": "\\.\\w+\\([^)]*\\)\\.\\w+\\([^)]*\\)",
      "options": {
        "maxLineLength": 120
      }
    },
    {
      "description": "Indent enum constants",
      "action": "indent",
      "pattern": "^\\s*\\w+\\s*[,(]",
      "options": {
        "withinEnum": true
      }
    },
    {
      "description": "Normalize try-with-resources",
      "action": "indent",
      "pattern": "try\\s*\\("
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "interface",
    "enum",
    "comment",
    "selection",
    "expression",
    "annotation"
  ]
}
