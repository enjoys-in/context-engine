{
  "language": "php",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "PSR-12 4-space indentation",
      "action": "reindent",
      "options": {
        "tabSize": 4,
        "insertSpaces": true
      }
    },
    {
      "description": "Normalize operator spacing",
      "action": "normalizeSpacing",
      "pattern": "\\s*(===|!==|==|!=|>=|<=|&&|\\|\\||\\?\\?|\\?:|=>|->|::|\\.\\.\\.|[+\\-*/%&|^.]=?|=)\\s*"
    },
    {
      "description": "Wrap lines at 120 characters",
      "action": "wrapLine",
      "pattern": ".{120,}",
      "options": {
        "maxLineLength": 120
      }
    },
    {
      "description": "PSR-12 brace placement for classes/methods",
      "action": "indent",
      "pattern": "\\{[^}]*\\}"
    },
    {
      "description": "Align double-arrow in arrays",
      "action": "align",
      "pattern": "^\\s*['\"]?\\w+['\"]?\\s*=>",
      "options": {
        "alignOn": "=>"
      }
    },
    {
      "description": "Format use/namespace declarations",
      "action": "align",
      "pattern": "^(use|namespace)\\s+"
    },
    {
      "description": "Indent switch cases",
      "action": "indent",
      "pattern": "case\\s+.+:|default:"
    },
    {
      "description": "Format PHPDoc comments",
      "action": "indent",
      "pattern": "^\\s*\\*\\s"
    },
    {
      "description": "Normalize type declarations",
      "action": "normalizeSpacing",
      "pattern": "(int|string|float|bool|array|callable|void|mixed|null|self|static)\\s"
    },
    {
      "description": "Format match expressions",
      "action": "indent",
      "pattern": "match\\s*\\([^)]*\\)\\s*\\{"
    },
    {
      "description": "Indent chained method calls",
      "action": "indent",
      "pattern": "->\\w+\\(",
      "options": {
        "continuationIndent": 4
      }
    },
    {
      "description": "Align assignment operators",
      "action": "align",
      "pattern": "\\s*=\\s*",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Format named arguments",
      "action": "normalizeSpacing",
      "pattern": "\\w+:\\s*"
    },
    {
      "description": "Normalize concatenation spacing",
      "action": "normalizeSpacing",
      "pattern": "\\s*\\.\\s*"
    },
    {
      "description": "Indent closure bodies",
      "action": "indent",
      "pattern": "function\\s*\\([^)]*\\)\\s*(use\\s*\\([^)]*\\))?\\s*\\{"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "interface",
    "trait",
    "enum",
    "comment",
    "selection",
    "expression",
    "namespace"
  ]
}
