{
  "language": "php",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent control structure bodies",
      "pattern": "\\b(if|else|elseif|while|for|foreach|switch|try|catch|finally)\\b\\s*\\(.*\\)\\s*\\{",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Align associative array key-value pairs",
      "pattern": "'[^']*'\\s*=>\\s*",
      "action": "align",
      "options": { "alignOn": "=>" }
    },
    {
      "description": "Format method chaining with arrow operators",
      "pattern": "->\\w+\\(",
      "action": "wrapLine",
      "options": { "breakBefore": "->" }
    },
    {
      "description": "Normalize spacing around PHP concatenation operator",
      "pattern": "\\s*\\.\\s*",
      "action": "normalizeSpacing",
      "options": { "around": "." }
    },
    {
      "description": "Indent class and function bodies",
      "pattern": "\\b(class|function|interface|trait)\\b[^{]*\\{",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize spacing around type hints and return types",
      "pattern": "\\)\\s*:\\s*\\??(\\w+)",
      "action": "normalizeSpacing",
      "options": { "beforeColon": false, "afterColon": true }
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "function", "class"]
}
