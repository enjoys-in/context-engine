{
  "language": "less",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent nested rulesets within braces",
      "pattern": "\\{[^}]*\\}",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Align consecutive property declarations",
      "pattern": "^\\s*[\\w-]+\\s*:",
      "action": "align",
      "options": { "alignOn": ":" }
    },
    {
      "description": "Normalize spacing after colon in declarations",
      "pattern": "[\\w-]+\\s*:\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block"]
}
