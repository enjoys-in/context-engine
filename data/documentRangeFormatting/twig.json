{
  "language": "twig",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent Twig block tag contents ({% block %}...{% endblock %})",
      "pattern": "\\{%\\s*block\\b",
      "action": "indent",
      "options": { "indentBody": true, "endKeyword": "endblock" }
    },
    {
      "description": "Indent Twig for loop contents",
      "pattern": "\\{%\\s*for\\b",
      "action": "indent",
      "options": { "indentBody": true, "endKeyword": "endfor" }
    },
    {
      "description": "Indent Twig if/elseif/else contents",
      "pattern": "\\{%\\s*(if|elseif|else)\\b",
      "action": "indent",
      "options": { "indentBody": true, "endKeyword": "endif" }
    },
    {
      "description": "Indent HTML tag contents within Twig templates",
      "pattern": "<(\\w+)[^>]*>[\\s\\S]*?</\\1>",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Normalize spacing inside Twig expression tags {{ }}",
      "pattern": "\\{\\{\\s*.*?\\s*\\}\\}",
      "action": "normalizeSpacing",
      "options": { "insideBraces": true }
    },
    {
      "description": "Indent macro definitions",
      "pattern": "\\{%\\s*macro\\b",
      "action": "indent",
      "options": { "indentBody": true, "endKeyword": "endmacro" }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "function"]
}
