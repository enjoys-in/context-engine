{
  "language": "lexon",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent clause contents",
      "pattern": "\\b(CLAUSE|IF|THEN|ELSE)\\b",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Normalize spacing in declarations",
      "pattern": "\\b(LEX|LEXON|CLAUSE)\\b\\s+",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block"]
}
