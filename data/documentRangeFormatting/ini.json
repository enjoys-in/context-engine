{
  "language": "ini",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Align consecutive key-value pairs",
      "pattern": "^\\s*[\\w.-]+\\s*=",
      "action": "align",
      "options": { "alignOn": "=" }
    },
    {
      "description": "Normalize spacing around equals sign",
      "pattern": "\\s*=\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": ["statement", "block"]
}
