{
  "language": "ini",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Align key-value pairs",
      "action": "align",
      "pattern": "^\\s*\\w+\\s*=",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Format section headers",
      "action": "normalizeSpacing",
      "pattern": "^\\[[^\\]]+\\]"
    },
    {
      "description": "Normalize whitespace around equals",
      "action": "normalizeSpacing",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "section",
    "key_value",
    "comment",
    "selection"
  ]
}
