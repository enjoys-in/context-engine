{
  "language": "freemarker2",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent contents within FreeMarker directives",
      "pattern": "<#(if|list|macro|switch|assign|attempt)\\b",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Indent contents within closing directives",
      "pattern": "</#(if|list|macro|switch|assign|attempt)>",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Normalize spacing within interpolation expressions",
      "pattern": "\\$\\{[^}]+\\}",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block"]
}
