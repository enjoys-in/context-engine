{
  "language": "systemverilog",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent module/endmodule block bodies",
      "pattern": "\\bmodule\\b\\s+\\w+",
      "action": "indent",
      "options": {
        "indentBody": true,
        "endKeyword": "endmodule"
      }
    },
    {
      "description": "Indent always/initial/final block bodies",
      "pattern": "\\b(always|always_ff|always_comb|always_latch|initial|final)\\b",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Indent begin..end blocks",
      "pattern": "\\bbegin\\b",
      "action": "indent",
      "options": {
        "indentBody": true,
        "endKeyword": "end"
      }
    },
    {
      "description": "Align port declarations in module headers",
      "pattern": "\\b(input|output|inout|ref)\\b\\s+(logic|wire|reg)?",
      "action": "align",
      "options": {
        "alignOn": "type"
      }
    },
    {
      "description": "Indent case/casex/casez statement bodies",
      "pattern": "\\b(case|casex|casez)\\b\\s*\\(",
      "action": "indent",
      "options": {
        "indentBody": true,
        "endKeyword": "endcase"
      }
    },
    {
      "description": "Format class and task/function bodies",
      "pattern": "\\b(class|task|function)\\b[^;]*;",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Align assign statements",
      "pattern": "\\bassign\\b\\s+\\w+\\s*=",
      "action": "align",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
