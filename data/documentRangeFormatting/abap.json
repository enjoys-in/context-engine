{
  "language": "abap",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent nested statements within IF/ENDIF blocks",
      "pattern": "\\b(IF|ELSEIF|ELSE|ENDIF)\\b",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Align consecutive DATA declarations",
      "pattern": "^\\s*DATA\\s+\\w+",
      "action": "align",
      "options": {
        "alignOn": "TYPE"
      }
    },
    {
      "description": "Normalize spacing around operators",
      "pattern": "\\s*(=|<>|>=|<=|<|>)\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace on each line",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
