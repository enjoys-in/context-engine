{
  "language": "html",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent nested elements within parent tags",
      "pattern": "<(\\w+)[^>]*>[\\s\\S]*?</\\1>",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Align consecutive attributes on multi-line tags",
      "pattern": "\\s+\\w[\\w-]*=",
      "action": "align",
      "options": { "alignOn": "=" }
    },
    {
      "description": "Normalize spacing within attribute values",
      "pattern": "\\w+=\\s*[\"']",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Wrap tags with many attributes onto multiple lines",
      "pattern": "<\\w+\\s+[^>]{80,}>",
      "action": "wrapLine",
      "options": { "maxLineLength": 100 }
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block"]
}
