{
  "language": "html",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent nested elements within parent tags",
      "pattern": "<(\\w+)[^>]*>[\\s\\S]*?</\\1>",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Align consecutive attributes on multi-line tags",
      "pattern": "\\s+\\w[\\w-]*=",
      "action": "align",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Normalize spacing within attribute values",
      "pattern": "\\w+=\\s*[\"']",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Wrap tags with many attributes onto multiple lines",
      "pattern": "<\\w+\\s+[^>]{80,}>",
      "action": "wrapLine",
      "options": {
        "maxLineLength": 100
      }
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
