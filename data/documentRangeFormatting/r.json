{
  "language": "r",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "R 2-space indentation",
      "action": "reindent"
    },
    {
      "description": "Normalize operator spacing",
      "action": "normalizeSpacing",
      "pattern": "\\s*(<-|->|<<-|->>|==|!=|>=|<=|%%|%>%|%in%|[+\\-*/^]=?|=)\\s*"
    },
    {
      "description": "Indent function bodies",
      "action": "indent",
      "pattern": "function\\s*\\([^)]*\\)\\s*\\{"
    },
    {
      "description": "Format pipe operator chains",
      "action": "indent",
      "pattern": "%>%\\s*$",
      "options": {
        "continuationIndent": 2
      }
    },
    {
      "description": "Align assignment operators",
      "action": "align",
      "pattern": "\\s*<-\\s*",
      "options": {
        "alignOn": "<-"
      }
    },
    {
      "description": "Format formula expressions",
      "action": "normalizeSpacing",
      "pattern": "~\\s*"
    },
    {
      "description": "Indent if/else blocks",
      "action": "indent",
      "pattern": "(if|else)\\s*[({]"
    },
    {
      "description": "Format apply-family calls",
      "action": "indent",
      "pattern": "[lstv]?apply\\s*\\("
    },
    {
      "description": "Normalize comma spacing in calls",
      "action": "normalizeSpacing",
      "pattern": ",\\s*"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "comment",
    "selection",
    "expression"
  ]
}
