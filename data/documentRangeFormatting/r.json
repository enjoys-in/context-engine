{
  "language": "r",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent function body blocks",
      "pattern": "\\bfunction\\b\\s*\\([^)]*\\)\\s*\\{",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Indent control flow blocks (if, for, while, repeat)",
      "pattern": "\\b(if|else|for|while|repeat)\\b[^{]*\\{",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Align assignment operators",
      "pattern": "\\w+\\s*(<-|=|<<-)\\s*",
      "action": "align",
      "options": { "alignOn": "<-" }
    },
    {
      "description": "Format pipe operator chains",
      "pattern": "%>%\\s*\\n|\\|>\\s*\\n",
      "action": "indent",
      "options": { "continuationIndent": true }
    },
    {
      "description": "Wrap long function argument lists",
      "pattern": "\\w+\\([^)]{80,}\\)",
      "action": "wrapLine",
      "options": { "maxLength": 80 }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "function"]
}
