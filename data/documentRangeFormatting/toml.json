{
  "language": "toml",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Align key=value pairs within a table",
      "pattern": "^\\w[\\w.-]*\\s*=\\s*",
      "action": "align",
      "options": { "alignOn": "=" }
    },
    {
      "description": "Normalize spacing around = in assignments",
      "pattern": "^(\\w[\\w.-]*)\\s*=\\s*",
      "action": "normalizeSpacing",
      "options": { "around": "=" }
    },
    {
      "description": "Indent inline table and array contents",
      "pattern": "\\{[^}]+\\}|\\[[^\\]]+\\]",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Format multiline arrays with consistent indentation",
      "pattern": "\\[\\s*\\n[\\s\\S]*?\\]",
      "action": "indent",
      "options": { "indentLevel": 1 }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": ["block", "statement"]
}
