{
  "language": "toml",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Align key-value pairs",
      "action": "align",
      "pattern": "^\\s*\\w+\\s*=",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Indent inline tables",
      "action": "indent",
      "pattern": "\\{[^}]+\\}"
    },
    {
      "description": "Format array values",
      "action": "indent",
      "pattern": "\\[\\s*$"
    },
    {
      "description": "Normalize string quoting",
      "action": "normalizeSpacing",
      "pattern": "\"[^\"]*\"|'[^']*'"
    },
    {
      "description": "Align table headers",
      "action": "align",
      "pattern": "^\\[\\[?[^\\]]+\\]\\]?"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "table",
    "key_value",
    "array",
    "comment",
    "selection"
  ]
}
