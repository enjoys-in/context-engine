{
  "language": "wgsl",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "wgsl indentation",
      "action": "reindent",
      "options": {
        "tabSize": 4,
        "insertSpaces": true
      }
    },
    {
      "description": "Indent block contents",
      "action": "indent",
      "pattern": "\\{[^}]*\\}"
    },
    {
      "description": "Normalize operator spacing",
      "action": "normalizeSpacing",
      "pattern": "\\s*([+\\-*/%=<>!&|^]=?)\\s*"
    },
    {
      "description": "Align assignments",
      "action": "align",
      "pattern": "\\s*=\\s*",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Indent function bodies",
      "action": "indent",
      "pattern": "fn\\s+\\w+.*\\{"
    },
    {
      "description": "Align struct members",
      "action": "align",
      "pattern": "^\\s*\\w+:\\s*\\w+"
    },
    {
      "description": "Format attributes",
      "action": "indent",
      "pattern": "@\\w+"
    },
    {
      "description": "Format compute shader annotations",
      "action": "indent",
      "pattern": "@workgroup_size"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "comment",
    "selection"
  ]
}
