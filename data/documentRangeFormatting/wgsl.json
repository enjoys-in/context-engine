{
  "language": "wgsl",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent function bodies",
      "pattern": "\\bfn\\b\\s+\\w+[^{]*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Indent struct bodies",
      "pattern": "\\bstruct\\b\\s+\\w+\\s*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Indent control flow blocks (if, for, while, loop, switch)",
      "pattern": "\\b(if|for|while|loop|switch)\\b[^{]*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Align struct member declarations",
      "pattern": "@\\w+\\s+\\w+\\s*:\\s*\\w+",
      "action": "align",
      "options": {
        "alignOn": ":"
      }
    },
    {
      "description": "Normalize spacing around attribute annotations",
      "pattern": "@(location|builtin|group|binding)\\s*\\(\\d+\\)",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
