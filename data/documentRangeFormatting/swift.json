{
  "language": "swift",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Swift 4-space indentation",
      "action": "reindent",
      "options": {
        "tabSize": 4,
        "insertSpaces": true
      }
    },
    {
      "description": "Normalize operator spacing",
      "action": "normalizeSpacing",
      "pattern": "\\s*(==|!=|>=|<=|&&|\\|\\||\\?\\?|->|[+\\-*/%&|^]=?|=)\\s*"
    },
    {
      "description": "Wrap lines at 100 characters",
      "action": "wrapLine",
      "pattern": ".{100,}",
      "options": {
        "maxLineLength": 100
      }
    },
    {
      "description": "Indent closure bodies",
      "action": "indent",
      "pattern": "\\{\\s*$"
    },
    {
      "description": "Format guard/if-let statements",
      "action": "indent",
      "pattern": "(guard|if)\\s+let\\s+"
    },
    {
      "description": "Align switch cases",
      "action": "indent",
      "pattern": "case\\s+.+:|default:"
    },
    {
      "description": "Format protocol method declarations",
      "action": "indent",
      "pattern": "func\\s+\\w+\\([^)]*\\)\\s*->"
    },
    {
      "description": "Align computed property accessors",
      "action": "indent",
      "pattern": "\\b(get|set|willSet|didSet)\\b\\s*\\{"
    },
    {
      "description": "Format generic constraints",
      "action": "indent",
      "pattern": "where\\s+\\w+\\s*:",
      "options": {
        "continuationIndent": 4
      }
    },
    {
      "description": "Normalize attribute placement",
      "action": "indent",
      "pattern": "^\\s*@\\w+"
    },
    {
      "description": "Indent enum cases",
      "action": "indent",
      "pattern": "case\\s+\\w+"
    },
    {
      "description": "Format string interpolation",
      "action": "normalizeSpacing",
      "pattern": "\\\\\\([^)]+\\)"
    },
    {
      "description": "Align function parameters",
      "action": "indent",
      "pattern": "\\([^)]*$",
      "options": {
        "continuationIndent": 4
      }
    },
    {
      "description": "Normalize optional chaining",
      "action": "normalizeSpacing",
      "pattern": "\\?\\.(\\w+)"
    },
    {
      "description": "Format result builders",
      "action": "indent",
      "pattern": "@\\w+Builder"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "struct",
    "enum",
    "protocol",
    "extension",
    "comment",
    "selection",
    "expression",
    "closure"
  ]
}
