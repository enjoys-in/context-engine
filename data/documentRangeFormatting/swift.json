{
  "language": "swift",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent func, class, struct, enum, protocol bodies",
      "pattern": "\\b(func|class|struct|enum|protocol|extension|actor)\\b[^{]*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Indent guard/if-let statements with early return",
      "pattern": "\\bguard\\b\\s+\\blet\\b.*\\belse\\b\\s*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Indent control flow blocks (if, for, while, switch)",
      "pattern": "\\b(if|for|while|switch|do|catch)\\b[^{]*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Align switch case clauses",
      "pattern": "\\bswitch\\b[^{]*\\{[\\s\\S]*?\\}",
      "action": "align",
      "options": {
        "alignCases": true
      }
    },
    {
      "description": "Format closure expression bodies",
      "pattern": "\\{\\s*\\([^)]*\\)\\s*->\\s*\\w+\\s+in",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Normalize spacing around protocol conformance colons",
      "pattern": "\\b(class|struct|enum)\\b\\s+\\w+\\s*:\\s*\\w+",
      "action": "normalizeSpacing",
      "options": {
        "beforeColon": false,
        "afterColon": true
      }
    },
    {
      "description": "Wrap long parameter lists in function declarations",
      "pattern": "func\\s+\\w+\\([^)]{80,}\\)",
      "action": "wrapLine",
      "options": {
        "maxLength": 100
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
