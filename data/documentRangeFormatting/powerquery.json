{
  "language": "powerquery",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent let..in expression bodies",
      "pattern": "\\blet\\b[\\s\\S]*?\\bin\\b",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Align step assignments in let blocks",
      "pattern": "\\w+\\s*=\\s*",
      "action": "align",
      "options": { "alignOn": "=" }
    },
    {
      "description": "Format each..in expressions",
      "pattern": "\\beach\\b.*\\bin\\b",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Normalize spacing around fat arrow in record fields",
      "pattern": "\\[\\s*\\w+\\s*=",
      "action": "normalizeSpacing",
      "options": { "around": "=" }
    },
    {
      "description": "Wrap long record or list expressions",
      "pattern": "\\{[^}]{80,}\\}|\\[[^\\]]{80,}\\]",
      "action": "wrapLine",
      "options": { "maxLength": 80 }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "function"]
}
