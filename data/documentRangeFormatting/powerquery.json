{
  "language": "powerquery",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent let..in expression bodies",
      "pattern": "\\blet\\b[\\s\\S]*?\\bin\\b",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Align step assignments in let blocks",
      "pattern": "\\w+\\s*=\\s*",
      "action": "align",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Format each..in expressions",
      "pattern": "\\beach\\b.*\\bin\\b",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Normalize spacing around fat arrow in record fields",
      "pattern": "\\[\\s*\\w+\\s*=",
      "action": "normalizeSpacing",
      "options": {
        "around": "="
      }
    },
    {
      "description": "Wrap long record or list expressions",
      "pattern": "\\{[^}]{80,}\\}|\\[[^\\]]{80,}\\]",
      "action": "wrapLine",
      "options": {
        "maxLength": 80
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
