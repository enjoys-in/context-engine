{
  "language": "mdx",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent nested list items",
      "action": "indent",
      "pattern": "^\\s*[-*+]\\s+|^\\s*\\d+\\.\\s+"
    },
    {
      "description": "Format table columns",
      "action": "align",
      "pattern": "\\|\\s*[^|]+\\s*\\|"
    },
    {
      "description": "Normalize heading spacing",
      "action": "normalizeSpacing",
      "pattern": "^#{1,6}\\s+"
    },
    {
      "description": "Format fenced code blocks",
      "action": "indent",
      "pattern": "^```\\w*$"
    },
    {
      "description": "Normalize blank lines around blocks",
      "action": "normalizeBlankLines",
      "pattern": "^(#{1,6}|```|>|---)",
      "options": {
        "blankLines": 1
      }
    },
    {
      "description": "Normalize link formatting",
      "action": "normalizeSpacing",
      "pattern": "\\[[^\\]]+\\]\\([^)]+\\)"
    },
    {
      "description": "Align table cells",
      "action": "align",
      "pattern": "\\|.*\\|",
      "options": {
        "alignOn": "|"
      }
    },
    {
      "description": "Format blockquote nesting",
      "action": "indent",
      "pattern": "^>+\\s+"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "heading",
    "paragraph",
    "list",
    "code_block",
    "table",
    "blockquote",
    "comment",
    "selection"
  ]
}
