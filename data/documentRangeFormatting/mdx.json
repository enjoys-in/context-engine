{
  "language": "mdx",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent nested JSX elements",
      "pattern": "<(\\w+)[^>]*>[\\s\\S]*?</\\1>",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Indent nested list items",
      "pattern": "^\\s*[-*+]\\s+|^\\s*\\d+\\.\\s+",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Align table columns by pipe delimiters",
      "pattern": "^\\s*\\|.*\\|\\s*$",
      "action": "align",
      "options": { "alignOn": "|" }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block"]
}
