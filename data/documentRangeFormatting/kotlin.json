{
  "language": "kotlin",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Kotlin 4-space indentation",
      "action": "reindent",
      "options": {
        "tabSize": 4,
        "insertSpaces": true
      }
    },
    {
      "description": "Normalize operator spacing",
      "action": "normalizeSpacing",
      "pattern": "\\s*(==|!=|>=|<=|&&|\\|\\||\\?:|\\?\\.|->|[+\\-*/%]=?|=)\\s*"
    },
    {
      "description": "Wrap lines at 100 characters",
      "action": "wrapLine",
      "pattern": ".{100,}",
      "options": {
        "maxLineLength": 100
      }
    },
    {
      "description": "Indent lambda bodies",
      "action": "indent",
      "pattern": "\\{\\s*$"
    },
    {
      "description": "Format when branches",
      "action": "indent",
      "pattern": "^\\s*.+\\s*->"
    },
    {
      "description": "Align constructor parameters",
      "action": "indent",
      "pattern": "constructor\\s*\\([^)]*$",
      "options": {
        "continuationIndent": 4
      }
    },
    {
      "description": "Format safe call chains",
      "action": "normalizeSpacing",
      "pattern": "\\?\\.(\\w+)"
    },
    {
      "description": "Indent companion object",
      "action": "indent",
      "pattern": "companion\\s+object\\s*\\{"
    },
    {
      "description": "Normalize data class formatting",
      "action": "indent",
      "pattern": "data\\s+class\\s+\\w+\\("
    },
    {
      "description": "Format string templates",
      "action": "normalizeSpacing",
      "pattern": "\\$\\{[^}]+\\}"
    },
    {
      "description": "Align property delegates",
      "action": "normalizeSpacing",
      "pattern": "by\\s+\\w+"
    },
    {
      "description": "Indent sealed class variants",
      "action": "indent",
      "pattern": "^\\s*(data\\s+)?class\\s+\\w+"
    },
    {
      "description": "Format extension functions",
      "action": "indent",
      "pattern": "fun\\s+\\w+\\.\\w+\\("
    },
    {
      "description": "Normalize trailing lambda",
      "action": "indent",
      "pattern": "\\)\\s*\\{\\s*$"
    },
    {
      "description": "Align annotation parameters",
      "action": "indent",
      "pattern": "^\\s*@\\w+\\("
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "interface",
    "object",
    "enum",
    "comment",
    "selection",
    "expression",
    "when",
    "lambda"
  ]
}
