{
  "language": "javascript",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent block contents within braces",
      "pattern": "\\{[^}]*\\}",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Normalize spacing around binary and assignment operators",
      "pattern": "\\s*(===|!==|==|!=|>=|<=|&&|\\|\\||=>|[+\\-*/%]=?|=)\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Wrap long object literals and parameter lists",
      "pattern": "[({][^)}]{80,}[)}]",
      "action": "wrapLine",
      "options": { "maxLineLength": 100 }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Indent chained method calls",
      "pattern": "\\.[a-z]\\w*\\(",
      "action": "indent",
      "options": { "continuationIndent": 2 }
    },
    {
      "description": "Align consecutive const/let/var declarations",
      "pattern": "^\\s*(const|let|var)\\s+\\w+\\s*=",
      "action": "align",
      "options": { "alignOn": "=" }
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "function", "class"]
}
