{
  "language": "javascript",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent block contents within braces",
      "action": "indent",
      "pattern": "\\{[^}]*\\}"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "normalizeSpacing",
      "pattern": "\\s*(===|!==|==|!=|>=|<=|&&|\\|\\||=>|\\?\\.?|\\?\\?|[+\\-*/%]=?|=)\\s*"
    },
    {
      "description": "Wrap long lines at 100 characters",
      "action": "wrapLine",
      "pattern": "[({][^)}]{80,}[)}]",
      "options": {
        "maxLineLength": 100
      }
    },
    {
      "description": "Indent chained method calls",
      "action": "indent",
      "pattern": "\\.[a-z]\\w*\\(",
      "options": {
        "continuationIndent": 2
      }
    },
    {
      "description": "Align consecutive const/let/var declarations",
      "action": "align",
      "pattern": "^\\s*(const|let|var)\\s+\\w+\\s*=",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Align object properties",
      "action": "align",
      "pattern": "^\\s*\\w+\\s*:",
      "options": {
        "alignOn": ":"
      }
    },
    {
      "description": "Normalize spacing in arrow functions",
      "action": "normalizeSpacing",
      "pattern": "\\s*=>\\s*"
    },
    {
      "description": "Indent switch case blocks",
      "action": "indent",
      "pattern": "case\\s+.+:|default:",
      "options": {
        "indentInner": true
      }
    },
    {
      "description": "Format template literal expressions",
      "action": "normalizeSpacing",
      "pattern": "\\$\\{[^}]+\\}"
    },
    {
      "description": "Normalize ternary operator formatting",
      "action": "wrapLine",
      "pattern": ".+\\?.+:.+",
      "options": {
        "maxLineLength": 80
      }
    },
    {
      "description": "Align import statements",
      "action": "align",
      "pattern": "^import\\s+",
      "options": {
        "alignOn": "from"
      }
    },
    {
      "description": "Normalize comma spacing",
      "action": "normalizeSpacing",
      "pattern": "\\s*,\\s*"
    },
    {
      "description": "Format destructuring assignments",
      "action": "indent",
      "pattern": "(const|let|var)\\s*\\{[^}]+\\}\\s*="
    },
    {
      "description": "Space after control keywords",
      "action": "normalizeSpacing",
      "pattern": "(if|for|while|switch|catch)\\s*\\("
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection",
    "expression",
    "module",
    "array",
    "object"
  ]
}
