{
  "language": "css",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Normalize property declaration spacing",
      "pattern": "([a-z-]+)\\s*:\\s*",
      "action": "replace",
      "options": {
        "replacement": "$1: ",
        "scope": "declaration"
      }
    },
    {
      "description": "Ensure proper indentation within rule blocks",
      "pattern": "^(\\s*)([a-z-]+\\s*:)",
      "action": "reindent",
      "options": {
        "baseIndent": "parentBlock",
        "indentSize": 2,
        "scope": "block"
      }
    },
    {
      "description": "Normalize brace formatting for rule blocks",
      "pattern": "([^\\s])\\s*\\{",
      "action": "replace",
      "options": {
        "replacement": "$1 {",
        "scope": "rule"
      }
    },
    {
      "description": "Ensure closing brace alignment",
      "pattern": "^(\\s*)\\}",
      "action": "reindent",
      "options": {
        "matchIndent": "openingBrace",
        "scope": "block"
      }
    },
    {
      "description": "Ensure semicolons terminate declarations",
      "pattern": "([a-z-]+\\s*:[^;{}]+?)\\s*(?=\\n\\s*[a-z-]|\\n\\s*\\})",
      "action": "appendSemicolon",
      "options": {
        "scope": "declaration"
      }
    },
    {
      "description": "Remove extra blank lines within a rule block",
      "pattern": "\\n\\s*\\n\\s*\\n",
      "action": "replace",
      "options": {
        "replacement": "\n\n",
        "scope": "block"
      }
    },
    {
      "description": "Normalize comma-separated selectors to one per line",
      "pattern": ",\\s*([.#a-zA-Z*:\\[])",
      "action": "replace",
      "options": {
        "replacement": ",\n$1",
        "scope": "rule"
      }
    },
    {
      "description": "Remove trailing whitespace on each line",
      "pattern": "[ \\t]+$",
      "action": "replace",
      "options": {
        "replacement": "",
        "scope": "statement"
      }
    },
    {
      "description": "Normalize space in !important declarations",
      "pattern": "\\s*!\\s*important",
      "action": "replace",
      "options": {
        "replacement": " !important",
        "scope": "declaration"
      }
    },
    {
      "description": "Format multi-value properties with consistent spacing",
      "pattern": ",\\s*(?=[^\\n])",
      "action": "replace",
      "options": {
        "replacement": ", ",
        "scope": "declaration"
      }
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "rule",
    "declaration",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
