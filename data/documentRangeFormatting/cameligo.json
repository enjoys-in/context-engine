{
  "language": "cameligo",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent let/in bindings",
      "pattern": "\\b(let|in)\\b",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Indent match/with expressions",
      "pattern": "\\b(match|with)\\b",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Normalize spacing around arrows and pipes",
      "pattern": "\\s*(->|\\|)\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "function"]
}
