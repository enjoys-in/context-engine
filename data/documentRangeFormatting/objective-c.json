{
  "language": "objective-c",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent block contents within braces",
      "pattern": "\\{[^}]*\\}",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Normalize spacing around binary operators",
      "pattern": "\\s*(==|!=|>=|<=|&&|\\|\\||[+\\-*/%]=?|=)\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Align consecutive property declarations",
      "pattern": "^\\s*@property\\s+",
      "action": "align",
      "options": { "alignOn": ")" }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Wrap long method declarations with multiple parameters",
      "pattern": "^[-+]\\s*\\([^)]+\\)\\w+:.{60,}",
      "action": "wrapLine",
      "options": { "maxLineLength": 100 }
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "function", "class"]
}
