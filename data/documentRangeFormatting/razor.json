{
  "language": "razor",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent nested HTML elements",
      "action": "indent",
      "pattern": "<[a-z][^>]*>[^<]*</[a-z]+>"
    },
    {
      "description": "Wrap long attribute lists",
      "action": "wrapLine",
      "pattern": "<\\w+\\s+[^>]{80,}>",
      "options": {
        "maxLineLength": 100
      }
    },
    {
      "description": "Align HTML attributes",
      "action": "indent",
      "pattern": "^\\s+\\w+=\"[^\"]*\""
    },
    {
      "description": "Normalize self-closing tags",
      "action": "normalizeSpacing",
      "pattern": "<\\w+[^>]*/\\s*>"
    },
    {
      "description": "Indent script/style blocks",
      "action": "indent",
      "pattern": "<(script|style)[^>]*>"
    },
    {
      "description": "Format DOCTYPE declaration",
      "action": "normalizeSpacing",
      "pattern": "<!DOCTYPE[^>]+>"
    },
    {
      "description": "Normalize attribute quoting",
      "action": "normalizeSpacing",
      "pattern": "\\w+=(?:\"|')[^\"']*(?:\"|')"
    },
    {
      "description": "Indent conditional comments",
      "action": "indent",
      "pattern": "<!--\\[if[^\\]]*\\]>"
    },
    {
      "description": "Format data attributes",
      "action": "normalizeSpacing",
      "pattern": "data-[\\w-]+="
    },
    {
      "description": "Normalize void element spacing",
      "action": "normalizeSpacing",
      "pattern": "<(br|hr|img|input|meta|link)[^>]*/?>"
    },
    {
      "description": "Align table columns",
      "action": "align",
      "pattern": "<t[dh][^>]*>"
    },
    {
      "description": "Indent form elements",
      "action": "indent",
      "pattern": "<(form|fieldset|select)"
    },
    {
      "description": "Normalize class attribute lists",
      "action": "normalizeSpacing",
      "pattern": "class=\"[^\"]+\""
    },
    {
      "description": "Indent Razor code blocks",
      "action": "indent",
      "pattern": "@\\{\\s*$"
    },
    {
      "description": "Format Razor expressions",
      "action": "normalizeSpacing",
      "pattern": "@\\([^)]+\\)"
    },
    {
      "description": "Indent @if/@foreach blocks",
      "action": "indent",
      "pattern": "@(if|foreach|for|while|switch)\\s*\\("
    },
    {
      "description": "Format @model directive",
      "action": "normalizeSpacing",
      "pattern": "@model\\s+\\w+"
    },
    {
      "description": "Normalize helper function calls",
      "action": "normalizeSpacing",
      "pattern": "@Html\\.\\w+\\("
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "element",
    "code_block",
    "expression",
    "directive",
    "comment",
    "selection"
  ]
}
