{
  "language": "razor",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent Razor code blocks (@{ ... })",
      "pattern": "@\\{[\\s\\S]*?\\}",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Indent HTML tag contents",
      "pattern": "<(\\w+)[^>]*>[\\s\\S]*?</\\1>",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Format Razor control structures (@if, @foreach, @for)",
      "pattern": "@(if|foreach|for|while|switch)\\b[^{]*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Align HTML tag attributes",
      "pattern": "<\\w+\\s+[\\w-]+=\"[^\"]*\"(\\s+[\\w-]+=\"[^\"]*\")+",
      "action": "align",
      "options": {
        "alignTo": "firstAttribute"
      }
    },
    {
      "description": "Normalize spacing around Razor expressions (@Model.Property)",
      "pattern": "@(\\w+\\.)+\\w+",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
