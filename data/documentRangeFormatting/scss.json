{
  "language": "scss",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent nested selector rule bodies",
      "pattern": "[.#&\\w][\\w-]*\\s*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Align mixin and include declarations",
      "pattern": "@(mixin|include)\\s+[\\w-]+",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Group and align SCSS variable declarations",
      "pattern": "\\$[\\w-]+\\s*:",
      "action": "align",
      "options": {
        "alignOn": ":"
      }
    },
    {
      "description": "Indent @if/@else/@each/@for control directive bodies",
      "pattern": "@(if|else|each|for|while)\\b[^{]*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Normalize spacing around property colon",
      "pattern": "[\\w-]+\\s*:\\s*",
      "action": "normalizeSpacing",
      "options": {
        "beforeColon": false,
        "afterColon": true
      }
    },
    {
      "description": "Format @media query blocks",
      "pattern": "@media\\b[^{]*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
