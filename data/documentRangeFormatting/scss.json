{
  "language": "scss",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent nested selector rule bodies",
      "pattern": "[.#&\\w][\\w-]*\\s*\\{",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Align mixin and include declarations",
      "pattern": "@(mixin|include)\\s+[\\w-]+",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Group and align SCSS variable declarations",
      "pattern": "\\$[\\w-]+\\s*:",
      "action": "align",
      "options": { "alignOn": ":" }
    },
    {
      "description": "Indent @if/@else/@each/@for control directive bodies",
      "pattern": "@(if|else|each|for|while)\\b[^{]*\\{",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Normalize spacing around property colon",
      "pattern": "[\\w-]+\\s*:\\s*",
      "action": "normalizeSpacing",
      "options": { "beforeColon": false, "afterColon": true }
    },
    {
      "description": "Format @media query blocks",
      "pattern": "@media\\b[^{]*\\{",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "function"]
}
