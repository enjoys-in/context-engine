{
  "language": "pascal",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent block contents within begin/end",
      "pattern": "\\b(begin|end|procedure|function|if|then|else|for|while|do|repeat|until|case|record)\\b",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Normalize spacing around assignment operators",
      "pattern": "\\s*(:=|=)\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Align consecutive variable declarations",
      "pattern": "^\\s*\\w+\\s*:",
      "action": "align",
      "options": { "alignOn": ":" }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "function"]
}
