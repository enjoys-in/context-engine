{
  "language": "python",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "PEP8 indentation (4 spaces)",
      "action": "reindent",
      "options": {
        "tabSize": 4,
        "insertSpaces": true
      }
    },
    {
      "description": "Black-style line length limit",
      "action": "wrapLine",
      "pattern": ".{89,}",
      "options": {
        "maxLineLength": 88
      }
    },
    {
      "description": "Normalize spacing around operators",
      "action": "normalizeSpacing",
      "pattern": "\\s*(==|!=|>=|<=|\\+=|-=|\\*=|/=|//=|%=|\\*\\*=|&=|\\|=|\\^=|>>=|<<=|:=|[+\\-*/%@&|^~<>=])\\s*"
    },
    {
      "description": "Align dictionary key-value pairs",
      "action": "align",
      "pattern": "^\\s*['\"]?\\w+['\"]?\\s*:",
      "options": {
        "alignOn": ":"
      }
    },
    {
      "description": "Format f-string expressions",
      "action": "normalizeSpacing",
      "pattern": "\\{[^}]+\\}"
    },
    {
      "description": "Indent function parameters",
      "action": "indent",
      "pattern": "def\\s+\\w+\\([^)]*$",
      "options": {
        "continuationIndent": 4
      }
    },
    {
      "description": "Align decorator stack",
      "action": "indent",
      "pattern": "^\\s*@\\w+"
    },
    {
      "description": "Normalize keyword argument spacing",
      "action": "normalizeSpacing",
      "pattern": "\\w+\\s*=\\s*(?=[^=])"
    },
    {
      "description": "Format list/dict/set comprehensions",
      "action": "indent",
      "pattern": "\\[.+for\\s+.+in\\s+.+\\]"
    },
    {
      "description": "Indent multiline function calls",
      "action": "indent",
      "pattern": "\\w+\\($",
      "options": {
        "continuationIndent": 4
      }
    },
    {
      "description": "Align import statements",
      "action": "align",
      "pattern": "^from\\s+.+import\\s+"
    },
    {
      "description": "Format multi-line string concatenation",
      "action": "indent",
      "pattern": "\\($[^)]*$"
    },
    {
      "description": "Normalize trailing commas",
      "action": "normalizeSpacing",
      "pattern": ",\\s*(?=[)\\]})"
    },
    {
      "description": "Indent class body",
      "action": "indent",
      "pattern": "^class\\s+\\w+.*:$",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Format type annotations",
      "action": "normalizeSpacing",
      "pattern": ":\\s*\\w+\\[?"
    },
    {
      "description": "Indent with-statement context managers",
      "action": "indent",
      "pattern": "^\\s*with\\s+.+:$"
    },
    {
      "description": "Blank lines between top-level defs (2)",
      "action": "normalizeBlankLines",
      "pattern": "^(def|class)\\s+",
      "options": {
        "blankLines": 2
      }
    },
    {
      "description": "Blank line between methods (1)",
      "action": "normalizeBlankLines",
      "pattern": "^\\s+def\\s+",
      "options": {
        "blankLines": 1
      }
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection",
    "expression",
    "module",
    "decorator",
    "comprehension"
  ]
}
