{
  "language": "python",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent block bodies (if, for, while, with, try, class, def)",
      "pattern": "^\\s*(if|elif|else|for|while|with|try|except|finally|class|def|async\\s+def|async\\s+for|async\\s+with)\\b.*:",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Align decorator lines above function/class definitions",
      "pattern": "^\\s*@[\\w.]+",
      "action": "align",
      "options": {
        "alignTo": "nextDef"
      }
    },
    {
      "description": "Wrap long dict and list comprehensions",
      "pattern": "\\{[^}]{80,}\\}|\\[[^\\]]{80,}\\]",
      "action": "wrapLine",
      "options": {
        "maxLength": 79
      }
    },
    {
      "description": "Normalize spacing around assignment and comparison operators",
      "pattern": "\\s*(=|==|!=|<=|>=|\\+=|-=|\\*=|/=|:=)\\s*",
      "action": "normalizeSpacing",
      "options": {
        "around": "operator"
      }
    },
    {
      "description": "Format f-string expressions for readability",
      "pattern": "f['\"][^'\"]*\\{[^}]+\\}[^'\"]*['\"]",
      "action": "normalizeSpacing",
      "options": {
        "insideBraces": true
      }
    },
    {
      "description": "Align dictionary key-value pairs",
      "pattern": "'[^']*'\\s*:\\s*|\"[^\"]*\"\\s*:\\s*",
      "action": "align",
      "options": {
        "alignOn": ":"
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
