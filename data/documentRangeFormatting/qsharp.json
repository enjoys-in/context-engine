{
  "language": "qsharp",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent operation and function bodies",
      "pattern": "\\b(operation|function)\\b\\s+\\w+[^{]*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Indent control flow blocks (if, for, repeat, using, borrowing)",
      "pattern": "\\b(if|elif|else|for|repeat|until|using|borrowing)\\b[^{]*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Align qubit allocation statements",
      "pattern": "\\b(use|borrow)\\b\\s+\\w+\\s*=",
      "action": "normalizeSpacing",
      "options": {
        "around": "="
      }
    },
    {
      "description": "Format type annotations with spacing",
      "pattern": ":\\s*\\w+(\\[\\])?",
      "action": "normalizeSpacing",
      "options": {
        "afterColon": true
      }
    },
    {
      "description": "Indent namespace body",
      "pattern": "\\bnamespace\\b\\s+[\\w.]+\\s*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
