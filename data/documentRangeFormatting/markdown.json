{
  "language": "markdown",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent nested list items",
      "pattern": "^\\s*[-*+]\\s+|^\\s*\\d+\\.\\s+",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Align table columns by pipe delimiters",
      "pattern": "^\\s*\\|.*\\|\\s*$",
      "action": "align",
      "options": { "alignOn": "|" }
    },
    {
      "description": "Trim trailing whitespace except for line breaks",
      "pattern": "(?<!  )\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize spacing in headings",
      "pattern": "^#{1,6}\\s+",
      "action": "normalizeSpacing",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": ["statement", "block"]
}
