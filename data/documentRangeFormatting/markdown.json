{
  "language": "markdown",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent nested list items",
      "pattern": "^\\s*[-*+]\\s+|^\\s*\\d+\\.\\s+",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Align table columns by pipe delimiters",
      "pattern": "^\\s*\\|.*\\|\\s*$",
      "action": "align",
      "options": {
        "alignOn": "|"
      }
    },
    {
      "description": "Trim trailing whitespace except for line breaks",
      "pattern": "(?<!  )\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize spacing in headings",
      "pattern": "^#{1,6}\\s+",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
