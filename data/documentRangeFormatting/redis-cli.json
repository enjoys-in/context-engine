{
  "language": "redis-cli",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Uppercase Redis CLI commands",
      "pattern": "\\b(get|set|del|hget|hset|lpush|rpush|sadd|zadd|expire|ttl|keys|scan|multi|exec|watch|subscribe|publish|info|config|cluster|client)\\b",
      "action": "normalizeSpacing",
      "options": {
        "uppercase": true
      }
    },
    {
      "description": "Normalize spacing between command and arguments",
      "pattern": "^\\s*\\w+\\s+",
      "action": "normalizeSpacing",
      "options": {
        "singleSpace": true
      }
    },
    {
      "description": "Align multi-command pipelines",
      "pattern": "^\\s*\\w+\\s+.*$",
      "action": "align",
      "options": {
        "alignTo": "command"
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
