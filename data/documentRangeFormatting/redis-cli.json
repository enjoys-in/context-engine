{
  "language": "redis-cli",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Uppercase Redis CLI commands",
      "pattern": "\\b(get|set|del|hget|hset|lpush|rpush|sadd|zadd|expire|ttl|keys|scan|multi|exec|watch|subscribe|publish|info|config|cluster|client)\\b",
      "action": "normalizeSpacing",
      "options": { "uppercase": true }
    },
    {
      "description": "Normalize spacing between command and arguments",
      "pattern": "^\\s*\\w+\\s+",
      "action": "normalizeSpacing",
      "options": { "singleSpace": true }
    },
    {
      "description": "Align multi-command pipelines",
      "pattern": "^\\s*\\w+\\s+.*$",
      "action": "align",
      "options": { "alignTo": "command" }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": ["statement", "block"]
}
