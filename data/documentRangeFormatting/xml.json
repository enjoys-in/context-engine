{
  "language": "xml",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent nested elements",
      "action": "indent",
      "pattern": "<[a-zA-Z][^>]*>[^<]*$"
    },
    {
      "description": "Wrap long attribute lists",
      "action": "wrapLine",
      "pattern": "<\\w+\\s+[^>]{80,}>",
      "options": {
        "maxLineLength": 100
      }
    },
    {
      "description": "Align XML attributes",
      "action": "indent",
      "pattern": "^\\s+\\w+=\"[^\"]*\""
    },
    {
      "description": "Normalize self-closing tags",
      "action": "normalizeSpacing",
      "pattern": "<[^>]+/>"
    },
    {
      "description": "Format XML declaration",
      "action": "normalizeSpacing",
      "pattern": "<\\?xml[^?]+\\?>"
    },
    {
      "description": "Indent CDATA sections",
      "action": "indent",
      "pattern": "<!\\[CDATA\\["
    },
    {
      "description": "Normalize namespace prefixes",
      "action": "normalizeSpacing",
      "pattern": "\\w+:\\w+"
    },
    {
      "description": "Format processing instructions",
      "action": "normalizeSpacing",
      "pattern": "<\\?\\w+[^?]*\\?>"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "element",
    "attribute",
    "comment",
    "cdata",
    "selection",
    "processing_instruction"
  ]
}
