{
  "language": "xml",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent child element content within parent tags",
      "pattern": "<(\\w+)[^/>]*>[\\s\\S]*?</\\1>",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Align multiple attributes on separate lines",
      "pattern": "<\\w+\\s+[\\w:]+=\"[^\"]*\"(\\s+[\\w:]+=\"[^\"]*\")+",
      "action": "align",
      "options": {
        "alignTo": "firstAttribute"
      }
    },
    {
      "description": "Normalize self-closing tag spacing",
      "pattern": "<\\w+[^>]*/\\s*>",
      "action": "normalizeSpacing",
      "options": {
        "beforeSlash": true
      }
    },
    {
      "description": "Indent CDATA section content",
      "pattern": "<!\\[CDATA\\[[\\s\\S]*?\\]\\]>",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Format processing instruction spacing",
      "pattern": "<\\?\\w+[^?]*\\?>",
      "action": "normalizeSpacing",
      "options": {
        "singleSpace": true
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "element",
    "attribute",
    "block",
    "statement",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
