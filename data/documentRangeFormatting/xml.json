{
  "language": "xml",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent child element content within parent tags",
      "pattern": "<(\\w+)[^/>]*>[\\s\\S]*?</\\1>",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Align multiple attributes on separate lines",
      "pattern": "<\\w+\\s+[\\w:]+=\"[^\"]*\"(\\s+[\\w:]+=\"[^\"]*\")+",
      "action": "align",
      "options": { "alignTo": "firstAttribute" }
    },
    {
      "description": "Normalize self-closing tag spacing",
      "pattern": "<\\w+[^>]*/\\s*>",
      "action": "normalizeSpacing",
      "options": { "beforeSlash": true }
    },
    {
      "description": "Indent CDATA section content",
      "pattern": "<!\\[CDATA\\[[\\s\\S]*?\\]\\]>",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Format processing instruction spacing",
      "pattern": "<\\?\\w+[^?]*\\?>",
      "action": "normalizeSpacing",
      "options": { "singleSpace": true }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["element", "attribute", "block"]
}
