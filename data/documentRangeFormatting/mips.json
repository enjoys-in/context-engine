{
  "language": "mips",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": false
  },
  "rangeFormattingRules": [
    {
      "description": "Indent instructions under labels",
      "pattern": "^\\w+:",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Align operand columns in instructions",
      "pattern": "^\\s+\\w+\\s+",
      "action": "align",
      "options": {
        "alignOn": " "
      }
    },
    {
      "description": "Normalize spacing between instruction and operands",
      "pattern": "^\\s+\\w+\\s{2,}",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
