{
  "language": "mips",
  "defaultOptions": {
    "tabSize": 8,
    "insertSpaces": false
  },
  "rangeFormattingRules": [
    {
      "description": "mips indentation",
      "action": "reindent",
      "options": {
        "tabSize": 8,
        "insertSpaces": false
      }
    },
    {
      "description": "Indent block contents",
      "action": "indent",
      "pattern": "\\{[^}]*\\}"
    },
    {
      "description": "Normalize operator spacing",
      "action": "normalizeSpacing",
      "pattern": "\\s*([+\\-*/%=<>!&|^]=?)\\s*"
    },
    {
      "description": "Align assignments",
      "action": "align",
      "pattern": "\\s*=\\s*",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Align instruction operands",
      "action": "align",
      "pattern": "^\\s*\\w+\\s+"
    },
    {
      "description": "Format data directives",
      "action": "align",
      "pattern": "^\\s*\\.\\w+\\s+"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "comment",
    "selection"
  ]
}
