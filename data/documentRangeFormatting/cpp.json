{
  "language": "cpp",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent block contents within braces",
      "pattern": "\\{[^}]*\\}",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Normalize spacing around binary operators",
      "pattern": "\\s*(==|!=|>=|<=|&&|\\|\\||<<|>>|[+\\-*/%]=?|=)\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Align consecutive macro definitions",
      "pattern": "^\\s*#define\\s+\\w+",
      "action": "align",
      "options": {
        "alignOn": " "
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Wrap long template parameter lists",
      "pattern": "<[^>]{80,}>",
      "action": "wrapLine",
      "options": {
        "maxLineLength": 120
      }
    },
    {
      "description": "Indent access specifiers in classes",
      "pattern": "^\\s*(public|private|protected)\\s*:",
      "action": "indent",
      "options": {
        "accessSpecifierIndent": -1
      }
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
