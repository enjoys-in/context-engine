{
  "language": "cpp",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": false
  },
  "rangeFormattingRules": [
    {
      "description": "K&R brace style",
      "action": "indent",
      "pattern": "\\{[^}]*\\}"
    },
    {
      "description": "Normalize operator spacing",
      "action": "normalizeSpacing",
      "pattern": "\\s*([+\\-*/%&|^~!<>=]=?|&&|\\|\\||<<|>>|->|\\.|::|\\?|:)\\s*"
    },
    {
      "description": "Wrap lines at 80 characters",
      "action": "wrapLine",
      "pattern": ".{80,}",
      "options": {
        "maxLineLength": 80
      }
    },
    {
      "description": "Align struct members",
      "action": "align",
      "pattern": "^\\s*\\w+\\s+\\w+\\s*;",
      "options": {
        "alignOn": "\\w+"
      }
    },
    {
      "description": "Align preprocessor macros",
      "action": "align",
      "pattern": "^\\s*#define\\s+\\w+"
    },
    {
      "description": "Indent switch cases",
      "action": "indent",
      "pattern": "case\\s+.+:|default:",
      "options": {
        "indentInner": true
      }
    },
    {
      "description": "Format pointer declarations",
      "action": "normalizeSpacing",
      "pattern": "\\*\\s*\\w+"
    },
    {
      "description": "Align function parameters",
      "action": "indent",
      "pattern": "\\([^)]*$",
      "options": {
        "continuationIndent": 4
      }
    },
    {
      "description": "Normalize condition spacing",
      "action": "normalizeSpacing",
      "pattern": "(if|while|for|switch)\\s*\\("
    },
    {
      "description": "Indent multiline macros",
      "action": "indent",
      "pattern": "#define\\s+\\w+\\s*\\\\$"
    },
    {
      "description": "Align enum values",
      "action": "align",
      "pattern": "^\\s*\\w+\\s*=",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Format sizeof expressions",
      "action": "normalizeSpacing",
      "pattern": "sizeof\\s*\\("
    },
    {
      "description": "Align consecutive assignments",
      "action": "align",
      "pattern": "\\s*=\\s*",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Normalize cast expressions",
      "action": "normalizeSpacing",
      "pattern": "\\([\\w\\s*]+\\)"
    },
    {
      "description": "Indent do-while bodies",
      "action": "indent",
      "pattern": "do\\s*\\{"
    },
    {
      "description": "Format template parameters",
      "action": "normalizeSpacing",
      "pattern": "template\\s*<[^>]+>"
    },
    {
      "description": "Align namespace indentation",
      "action": "indent",
      "pattern": "namespace\\s+\\w+\\s*\\{"
    },
    {
      "description": "Format range-based for loops",
      "action": "normalizeSpacing",
      "pattern": "for\\s*\\(.*:\\s*"
    },
    {
      "description": "Indent class access specifiers",
      "action": "indent",
      "pattern": "^\\s*(public|private|protected)\\s*:"
    },
    {
      "description": "Align initializer lists",
      "action": "indent",
      "pattern": "^\\s*:\\s*\\w+\\(",
      "options": {
        "continuationIndent": 4
      }
    },
    {
      "description": "Format lambda captures",
      "action": "normalizeSpacing",
      "pattern": "\\[[^\\]]*\\]\\s*\\([^)]*\\)"
    },
    {
      "description": "Normalize std:: qualifications",
      "action": "normalizeSpacing",
      "pattern": "std::\\w+"
    },
    {
      "description": "Indent constexpr if bodies",
      "action": "indent",
      "pattern": "if\\s+constexpr\\s*\\("
    },
    {
      "description": "Format structured bindings",
      "action": "normalizeSpacing",
      "pattern": "auto\\s*\\[[^\\]]+\\]\\s*="
    },
    {
      "description": "Align using declarations",
      "action": "align",
      "pattern": "^using\\s+"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "struct",
    "enum",
    "namespace",
    "template",
    "comment",
    "selection",
    "expression"
  ]
}
