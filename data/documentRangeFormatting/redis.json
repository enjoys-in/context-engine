{
  "language": "redis",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Uppercase Redis commands",
      "pattern": "\\b(GET|SET|DEL|HGET|HSET|LPUSH|RPUSH|SADD|ZADD|EXPIRE|TTL|KEYS|SCAN|MULTI|EXEC|WATCH|SUBSCRIBE|PUBLISH|EVAL|EVALSHA)\\b",
      "action": "normalizeSpacing",
      "options": {
        "uppercase": true
      }
    },
    {
      "description": "Align command arguments on the same line",
      "pattern": "^\\s*\\w+\\s+.+",
      "action": "normalizeSpacing",
      "options": {
        "singleSpace": true
      }
    },
    {
      "description": "Indent Lua script blocks within EVAL",
      "pattern": "EVAL\\s+\"[\\s\\S]*?\"",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
