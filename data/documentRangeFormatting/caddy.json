{
  "language": "caddy",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": false
  },
  "rangeFormattingRules": [
    {
      "description": "Indent site blocks",
      "action": "indent",
      "pattern": "\\{\\s*$"
    },
    {
      "description": "Align directive arguments",
      "action": "align",
      "pattern": "^\\s*\\w+\\s+"
    },
    {
      "description": "Format matcher blocks",
      "action": "indent",
      "pattern": "@\\w+\\s*\\{"
    },
    {
      "description": "Normalize header directives",
      "action": "normalizeSpacing",
      "pattern": "header\\s+"
    },
    {
      "description": "Format reverse_proxy backends",
      "action": "indent",
      "pattern": "reverse_proxy\\s+"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "site_block",
    "directive",
    "matcher",
    "comment",
    "selection"
  ]
}
