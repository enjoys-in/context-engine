{
  "language": "nextjs",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Normalize indentation",
      "pattern": "^\\t+",
      "replacement": "  ",
      "perIndentLevel": true
    },
    {
      "description": "Remove trailing whitespace",
      "pattern": "\\s+$",
      "replacement": ""
    },
    {
      "description": "Space after keywords",
      "pattern": "\\b(if|for|while|switch|catch)\\(",
      "replacement": "$1 ("
    },
    {
      "description": "Space before opening brace",
      "pattern": "\\)\\{",
      "replacement": ") {"
    },
    {
      "description": "Consistent arrow spacing",
      "pattern": "\\)\\s*=>\\s*\\{",
      "replacement": ") => {"
    },
    {
      "description": "JSX attribute spacing",
      "pattern": "(\\w)\\s*=\\s*\\{",
      "replacement": "$1={"
    },
    {
      "description": "Normalize string quotes to double",
      "pattern": "'([^']*)'",
      "replacement": "\"$1\""
    },
    {
      "description": "JSX self-closing space",
      "pattern": "(\\w)\\/>",
      "replacement": "$1 />"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class"
  ]
}
