{
  "language": "dart",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "dartfmt 2-space indentation",
      "action": "reindent",
      "options": {
        "tabSize": 2,
        "insertSpaces": true
      }
    },
    {
      "description": "Normalize operator spacing",
      "action": "normalizeSpacing",
      "pattern": "\\s*(==|!=|>=|<=|&&|\\|\\||\\?\\?|\\?\\.|\\.\\.|=>|[+\\-*/%]=?|=)\\s*"
    },
    {
      "description": "Wrap lines at 80 characters",
      "action": "wrapLine",
      "pattern": ".{80,}",
      "options": {
        "maxLineLength": 80
      }
    },
    {
      "description": "Indent cascade notation chains",
      "action": "indent",
      "pattern": "\\.\\.[a-z]\\w*",
      "options": {
        "continuationIndent": 4
      }
    },
    {
      "description": "Align named parameters",
      "action": "indent",
      "pattern": "\\w+:\\s*",
      "options": {
        "withinCall": true
      }
    },
    {
      "description": "Format constructor initializer lists",
      "action": "indent",
      "pattern": ":\\s*\\w+\\("
    },
    {
      "description": "Indent Widget build methods",
      "action": "indent",
      "pattern": "Widget\\s+build\\("
    },
    {
      "description": "Format string interpolation",
      "action": "normalizeSpacing",
      "pattern": "\\$\\{[^}]+\\}"
    },
    {
      "description": "Align switch cases",
      "action": "indent",
      "pattern": "case\\s+.+:|default:"
    },
    {
      "description": "Normalize generic types",
      "action": "normalizeSpacing",
      "pattern": "<[^>]+>"
    },
    {
      "description": "Format trailing commas in param lists",
      "action": "wrapLine",
      "pattern": "\\([^)]*,\\s*\\)"
    },
    {
      "description": "Indent collection if/for",
      "action": "indent",
      "pattern": "(if|for)\\s*\\(.*\\)\\s*$"
    },
    {
      "description": "Align class member annotations",
      "action": "indent",
      "pattern": "^\\s*@\\w+"
    },
    {
      "description": "Format extension declarations",
      "action": "indent",
      "pattern": "extension\\s+\\w+\\s+on\\s+"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "mixin",
    "enum",
    "extension",
    "comment",
    "selection",
    "expression",
    "widget"
  ]
}
