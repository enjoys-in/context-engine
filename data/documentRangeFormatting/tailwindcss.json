{
  "language": "tailwindcss",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent rule declarations",
      "action": "indent",
      "pattern": "\\{[^}]*\\}"
    },
    {
      "description": "Align property values",
      "action": "align",
      "pattern": "^\\s*[\\w-]+\\s*:",
      "options": {
        "alignOn": ":"
      }
    },
    {
      "description": "One declaration per line",
      "action": "wrapLine",
      "pattern": "[;{][^;{]*[;{]"
    },
    {
      "description": "Normalize colon spacing",
      "action": "normalizeSpacing",
      "pattern": ":\\s*"
    },
    {
      "description": "Wrap long value lists",
      "action": "wrapLine",
      "pattern": ":\\s*.{60,};",
      "options": {
        "maxLineLength": 80
      }
    },
    {
      "description": "Format media query conditions",
      "action": "normalizeSpacing",
      "pattern": "@media\\s+[^{]+"
    },
    {
      "description": "Normalize shorthand properties",
      "action": "normalizeSpacing",
      "pattern": "(margin|padding|border|font|background):\\s*"
    },
    {
      "description": "Indent nested at-rules",
      "action": "indent",
      "pattern": "@(media|supports|layer|container)\\s*"
    },
    {
      "description": "Format color function arguments",
      "action": "normalizeSpacing",
      "pattern": "(rgb|hsl|lab|oklch|color)\\s*\\("
    },
    {
      "description": "Align multiple selectors",
      "action": "indent",
      "pattern": ",\\s*$"
    },
    {
      "description": "Normalize calc() expressions",
      "action": "normalizeSpacing",
      "pattern": "calc\\([^)]+\\)"
    },
    {
      "description": "Format custom property declarations",
      "action": "normalizeSpacing",
      "pattern": "--[\\w-]+:\\s*"
    },
    {
      "description": "Normalize important declarations",
      "action": "normalizeSpacing",
      "pattern": "!\\s*important"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "rule",
    "declaration",
    "selector",
    "at-rule",
    "comment",
    "selection",
    "media-query",
    "value"
  ]
}
