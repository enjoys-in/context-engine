{
  "language": "tailwindcss",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Sort utility classes in @apply rules within the selected range",
      "pattern": "@apply\\s+([\\w\\s:/-]+);",
      "action": "sortClasses",
      "options": {
        "order": "headwind"
      }
    },
    {
      "description": "Normalize whitespace in class lists within the selected range",
      "pattern": "class\\s*=\\s*[\"']([^\"']+)[\"']",
      "action": "normalizeWhitespace",
      "options": {
        "singleSpace": true,
        "trimEdges": true
      }
    },
    {
      "description": "Format @layer block indentation within the selected range",
      "pattern": "@layer\\s+\\w+\\s*\\{[\\s\\S]*?\\}",
      "action": "formatBlock",
      "options": {
        "indentSize": 2,
        "insertSpaces": true
      }
    },
    {
      "description": "Normalize @apply directive spacing within the selected range",
      "pattern": "@apply\\s{2,}",
      "action": "replaceWhitespace",
      "options": {
        "replacement": "@apply "
      }
    },
    {
      "description": "Format CSS rule blocks within the selected range",
      "pattern": "\\.[\\w-]+\\s*\\{[^}]*\\}",
      "action": "formatBlock",
      "options": {
        "indentSize": 2,
        "insertSpaces": true,
        "newlineAfterBrace": true
      }
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "directive",
    "declaration",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
