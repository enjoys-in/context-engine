{
  "language": "azcli",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Align continuation lines after backslash",
      "pattern": "\\\\\\s*$",
      "action": "indent",
      "options": {
        "continuationIndent": 4
      }
    },
    {
      "description": "Normalize spacing around parameter flags",
      "pattern": "--\\w[\\w-]*\\s+",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
