{
  "language": "azcli",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Align parameter flags",
      "action": "align",
      "pattern": "\\s+--\\w+"
    },
    {
      "description": "Format multi-line commands",
      "action": "indent",
      "pattern": "\\\\\\s*$",
      "options": {
        "continuationIndent": 4
      }
    },
    {
      "description": "Normalize flag spacing",
      "action": "normalizeSpacing",
      "pattern": "--\\w+\\s+"
    },
    {
      "description": "Format resource group references",
      "action": "normalizeSpacing",
      "pattern": "--resource-group\\s+"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": [
    "command",
    "parameter",
    "comment",
    "selection"
  ]
}
