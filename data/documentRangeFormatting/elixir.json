{
  "language": "elixir",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "elixir indentation",
      "action": "reindent",
      "options": {
        "tabSize": 2,
        "insertSpaces": true
      }
    },
    {
      "description": "Indent block contents",
      "action": "indent",
      "pattern": "\\{[^}]*\\}"
    },
    {
      "description": "Normalize operator spacing",
      "action": "normalizeSpacing",
      "pattern": "\\s*([+\\-*/%=<>!&|^]=?)\\s*"
    },
    {
      "description": "Align assignments",
      "action": "align",
      "pattern": "\\s*=\\s*",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Indent do/end blocks",
      "action": "indent",
      "pattern": "\\bdo\\b\\s*$"
    },
    {
      "description": "Format pipe operator chains",
      "action": "indent",
      "pattern": "\\|>\\s*$"
    },
    {
      "description": "Align pattern matches",
      "action": "align",
      "pattern": "\\s*->\\s*",
      "options": {
        "alignOn": "->"
      }
    },
    {
      "description": "Indent with clauses",
      "action": "indent",
      "pattern": "with\\s+.+<-"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "comment",
    "selection"
  ]
}
