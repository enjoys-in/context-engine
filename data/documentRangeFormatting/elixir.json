{
  "language": "elixir",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent block contents within do/end blocks",
      "pattern": "\\b(do|end)\\b",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Indent contents of case/cond/with blocks",
      "pattern": "\\b(case|cond|with|if|unless|fn)\\b",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Normalize spacing around pipe operator",
      "pattern": "\\s*\\|>\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Align consecutive pattern match clauses",
      "pattern": "\\s*->\\s*",
      "action": "align",
      "options": {
        "alignOn": "->"
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
