{
  "language": "graphql",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent field selections",
      "action": "indent",
      "pattern": "\\{\\s*$"
    },
    {
      "description": "Align field arguments",
      "action": "indent",
      "pattern": "\\([^)]*$"
    },
    {
      "description": "Format directive placements",
      "action": "normalizeSpacing",
      "pattern": "@\\w+(\\([^)]*\\))?"
    },
    {
      "description": "Indent fragment spreads",
      "action": "indent",
      "pattern": "\\.\\.\\.(\\s+on)?"
    },
    {
      "description": "Normalize type definitions",
      "action": "indent",
      "pattern": "type\\s+\\w+.*\\{"
    },
    {
      "description": "Format input object fields",
      "action": "indent",
      "pattern": "input\\s+\\w+\\s*\\{"
    },
    {
      "description": "Align enum values",
      "action": "indent",
      "pattern": "enum\\s+\\w+\\s*\\{"
    },
    {
      "description": "Format schema definition",
      "action": "indent",
      "pattern": "schema\\s*\\{"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "query",
    "mutation",
    "subscription",
    "fragment",
    "type",
    "input",
    "enum",
    "schema",
    "comment",
    "selection"
  ]
}
