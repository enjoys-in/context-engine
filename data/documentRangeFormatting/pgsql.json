{
  "language": "pgsql",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Uppercase SQL keywords",
      "pattern": "\\b(select|from|where|join|left|right|inner|outer|on|group|order|by|having|limit|offset|insert|update|delete|create|alter|drop|into|values|set|and|or|not|in|exists|between|like|is|null|as|union|intersect|except|with|returning)\\b",
      "action": "normalizeSpacing",
      "options": {
        "uppercase": true
      }
    },
    {
      "description": "Align major clauses on new lines",
      "pattern": "\\b(SELECT|FROM|WHERE|JOIN|LEFT JOIN|RIGHT JOIN|INNER JOIN|GROUP BY|ORDER BY|HAVING|LIMIT|OFFSET|RETURNING)\\b",
      "action": "indent",
      "options": {
        "clauseNewline": true
      }
    },
    {
      "description": "Indent subquery blocks",
      "pattern": "\\(\\s*SELECT[\\s\\S]*?\\)",
      "action": "indent",
      "options": {
        "indentLevel": 1
      }
    },
    {
      "description": "Align column lists after SELECT",
      "pattern": "SELECT\\s+[\\w.,\\s]+FROM",
      "action": "align",
      "options": {
        "alignTo": "firstColumn"
      }
    },
    {
      "description": "Format PL/pgSQL BEGIN..END blocks",
      "pattern": "\\bBEGIN\\b[\\s\\S]*?\\bEND\\b",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Trim trailing whitespace from lines",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "query",
    "clause",
    "subquery",
    "function",
    "block",
    "statement",
    "class",
    "comment",
    "selection"
  ]
}
