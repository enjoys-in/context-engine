{
  "language": "m3",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent block contents within BEGIN/END",
      "pattern": "\\b(BEGIN|END|PROCEDURE|IF|THEN|ELSE|FOR|WHILE|DO|LOOP|CASE|RECORD|OBJECT)\\b",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Normalize spacing around assignment operators",
      "pattern": "\\s*(:=|=)\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Align consecutive variable declarations",
      "pattern": "^\\s*\\w+\\s*:",
      "action": "align",
      "options": { "alignOn": ":" }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "function"]
}
