{
  "language": "scala",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent class, object, and trait bodies",
      "pattern": "\\b(class|object|trait|abstract\\s+class)\\b[^{]*\\{",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Indent def/val/var function bodies",
      "pattern": "\\b(def|val|var)\\b\\s+\\w+[^=]*=\\s*\\{",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Align pattern match case clauses",
      "pattern": "\\bmatch\\b\\s*\\{[\\s\\S]*?\\}",
      "action": "align",
      "options": { "alignOn": "=>" }
    },
    {
      "description": "Format for-comprehension yield expressions",
      "pattern": "\\bfor\\b\\s*\\{[\\s\\S]*?\\}\\s*\\byield\\b",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Normalize spacing around implicit parameter lists",
      "pattern": "\\(\\s*implicit\\b",
      "action": "normalizeSpacing",
      "options": { "afterKeyword": true }
    },
    {
      "description": "Wrap long parameter lists",
      "pattern": "\\([^)]{80,}\\)",
      "action": "wrapLine",
      "options": { "maxLength": 80 }
    },
    {
      "description": "Format method chaining",
      "pattern": "\\.\\w+[({]",
      "action": "wrapLine",
      "options": { "breakBefore": "." }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "function", "class"]
}
