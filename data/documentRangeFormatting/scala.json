{
  "language": "scala",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent class, object, and trait bodies",
      "pattern": "\\b(class|object|trait|abstract\\s+class)\\b[^{]*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Indent def/val/var function bodies",
      "pattern": "\\b(def|val|var)\\b\\s+\\w+[^=]*=\\s*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Align pattern match case clauses",
      "pattern": "\\bmatch\\b\\s*\\{[\\s\\S]*?\\}",
      "action": "align",
      "options": {
        "alignOn": "=>"
      }
    },
    {
      "description": "Format for-comprehension yield expressions",
      "pattern": "\\bfor\\b\\s*\\{[\\s\\S]*?\\}\\s*\\byield\\b",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Normalize spacing around implicit parameter lists",
      "pattern": "\\(\\s*implicit\\b",
      "action": "normalizeSpacing",
      "options": {
        "afterKeyword": true
      }
    },
    {
      "description": "Wrap long parameter lists",
      "pattern": "\\([^)]{80,}\\)",
      "action": "wrapLine",
      "options": {
        "maxLength": 80
      }
    },
    {
      "description": "Format method chaining",
      "pattern": "\\.\\w+[({]",
      "action": "wrapLine",
      "options": {
        "breakBefore": "."
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
