{
  "language": "scala",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Scalafmt 2-space indentation",
      "action": "reindent",
      "options": {
        "tabSize": 2,
        "insertSpaces": true
      }
    },
    {
      "description": "Normalize operator spacing",
      "action": "normalizeSpacing",
      "pattern": "\\s*(==|!=|>=|<=|&&|\\|\\||=>|<-|[+\\-*/%&|^]=?|=)\\s*"
    },
    {
      "description": "Wrap lines at 120 characters",
      "action": "wrapLine",
      "pattern": ".{120,}",
      "options": {
        "maxLineLength": 120
      }
    },
    {
      "description": "Indent match case arms",
      "action": "indent",
      "pattern": "case\\s+.+\\s*=>"
    },
    {
      "description": "Align for-comprehension generators",
      "action": "indent",
      "pattern": "<-|yield"
    },
    {
      "description": "Format implicit parameters",
      "action": "indent",
      "pattern": "\\(implicit\\s+"
    },
    {
      "description": "Indent trait/class body",
      "action": "indent",
      "pattern": "(trait|class|object)\\s+\\w+.*\\{"
    },
    {
      "description": "Format pattern matching",
      "action": "normalizeSpacing",
      "pattern": "case\\s+\\w+\\(.*\\)"
    },
    {
      "description": "Align val/var declarations",
      "action": "align",
      "pattern": "^\\s*(val|var)\\s+\\w+\\s*[:=]",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Normalize type annotations",
      "action": "normalizeSpacing",
      "pattern": ":\\s*\\w+"
    },
    {
      "description": "Format string interpolation",
      "action": "normalizeSpacing",
      "pattern": "\\$\\{[^}]+\\}"
    },
    {
      "description": "Indent extension methods",
      "action": "indent",
      "pattern": "extension\\s*\\("
    },
    {
      "description": "Format given/using clauses",
      "action": "indent",
      "pattern": "(given|using)\\s+"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "trait",
    "object",
    "match",
    "comment",
    "selection",
    "expression",
    "for_comprehension"
  ]
}
