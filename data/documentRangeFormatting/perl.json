{
  "language": "perl",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent block contents within braces",
      "pattern": "\\{[^}]*\\}",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Normalize spacing around binary operators",
      "pattern": "\\s*(==|!=|eq|ne|=~|!~|>=|<=|&&|\\|\\||=>|[+\\-*/%]=?|=)\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Align consecutive hash assignments",
      "pattern": "^\\s*\\w+\\s*=>",
      "action": "align",
      "options": {
        "alignOn": "=>"
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Wrap long regular expressions",
      "pattern": "[/ms].*[/msixgce]{60,}",
      "action": "wrapLine",
      "options": {
        "maxLineLength": 100
      }
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
