{
  "language": "prisma",
  "displayName": "Prisma",
  "capabilities": {
    "documentRangeFormatting": true,
    "rangeFormatting": true
  },
  "options": {
    "tabSize": 2,
    "insertSpaces": true,
    "trimTrailingWhitespace": true,
    "insertFinalNewline": true,
    "trimFinalNewlines": true
  }
}
