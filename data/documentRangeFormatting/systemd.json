{
  "language": "systemd",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent directives within section blocks",
      "pattern": "^\\[(Unit|Service|Install|Timer|Socket|Mount|Path|Swap|Slice|Scope|Automount|Busname)\\]",
      "action": "indent",
      "options": {
        "indentBody": false,
        "sectionHeader": true
      }
    },
    {
      "description": "Align key=value directive pairs",
      "pattern": "^\\w[\\w-]*\\s*=\\s*",
      "action": "align",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Normalize spacing around = in directives",
      "pattern": "^(\\w[\\w-]*)\\s*=\\s*",
      "action": "normalizeSpacing",
      "options": {
        "noSpaceAround": "="
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": [
    "block",
    "statement",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
