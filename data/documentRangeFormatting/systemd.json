{
  "language": "systemd",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent directives within section blocks",
      "pattern": "^\\[(Unit|Service|Install|Timer|Socket|Mount|Path|Swap|Slice|Scope|Automount|Busname)\\]",
      "action": "indent",
      "options": { "indentBody": false, "sectionHeader": true }
    },
    {
      "description": "Align key=value directive pairs",
      "pattern": "^\\w[\\w-]*\\s*=\\s*",
      "action": "align",
      "options": { "alignOn": "=" }
    },
    {
      "description": "Normalize spacing around = in directives",
      "pattern": "^(\\w[\\w-]*)\\s*=\\s*",
      "action": "normalizeSpacing",
      "options": { "noSpaceAround": "=" }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": ["block", "statement"]
}
