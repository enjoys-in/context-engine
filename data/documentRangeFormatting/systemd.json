{
  "language": "systemd",
  "defaultOptions": {
    "tabSize": 0,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Align key-value pairs",
      "action": "align",
      "pattern": "^\\w+=",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Format section headers",
      "action": "normalizeSpacing",
      "pattern": "^\\[\\w+\\]"
    },
    {
      "description": "Normalize boolean values",
      "action": "normalizeSpacing",
      "pattern": "=(true|false|yes|no)$"
    },
    {
      "description": "Format exec directives",
      "action": "normalizeSpacing",
      "pattern": "^Exec\\w+="
    },
    {
      "description": "Align environment entries",
      "action": "align",
      "pattern": "^Environment=\"?\\w+="
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": [
    "section",
    "directive",
    "comment",
    "selection"
  ]
}
