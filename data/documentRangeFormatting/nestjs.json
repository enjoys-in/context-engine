{
  "language": "nestjs",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Normalize indentation",
      "pattern": "^\\t+",
      "replacement": "  ",
      "perIndentLevel": true
    },
    {
      "description": "Remove trailing whitespace",
      "pattern": "\\s+$",
      "replacement": ""
    },
    {
      "description": "Space after keywords",
      "pattern": "\\b(if|for|while|switch|catch)\\(",
      "replacement": "$1 ("
    },
    {
      "description": "Space before opening brace",
      "pattern": "\\)\\{",
      "replacement": ") {"
    },
    {
      "description": "Consistent arrow spacing",
      "pattern": "\\)\\s*=>\\s*\\{",
      "replacement": ") => {"
    },
    {
      "description": "Consistent type annotation spacing",
      "pattern": "(\\w)\\s*:\\s*(\\w)",
      "replacement": "$1: $2"
    },
    {
      "description": "Normalize decorator spacing",
      "pattern": "@(\\w+)\\(\\s+",
      "replacement": "@$1("
    },
    {
      "description": "Single space after commas",
      "pattern": ",([^\\s])",
      "replacement": ", $1"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
