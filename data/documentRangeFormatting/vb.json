{
  "language": "vb",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent Sub/Function/Property block bodies",
      "pattern": "\\b(Sub|Function|Property)\\b\\s+\\w+",
      "action": "indent",
      "options": { "indentBody": true, "endKeyword": "End" }
    },
    {
      "description": "Indent Class/Module/Structure bodies",
      "pattern": "\\b(Class|Module|Structure|Interface|Namespace)\\b\\s+\\w+",
      "action": "indent",
      "options": { "indentBody": true, "endKeyword": "End" }
    },
    {
      "description": "Indent If/ElseIf/Else/End If blocks",
      "pattern": "\\b(If|ElseIf|Else)\\b.*\\bThen\\b",
      "action": "indent",
      "options": { "indentBody": true, "endKeyword": "End If" }
    },
    {
      "description": "Indent For/For Each/Do/While loops",
      "pattern": "\\b(For|For Each|Do|While)\\b",
      "action": "indent",
      "options": { "indentBody": true }
    },
    {
      "description": "Indent Select Case bodies",
      "pattern": "\\bSelect\\s+Case\\b",
      "action": "indent",
      "options": { "indentBody": true, "endKeyword": "End Select" }
    },
    {
      "description": "Indent Try/Catch/Finally blocks",
      "pattern": "\\b(Try|Catch|Finally)\\b",
      "action": "indent",
      "options": { "indentBody": true, "endKeyword": "End Try" }
    },
    {
      "description": "Normalize spacing around As type declarations",
      "pattern": "\\bAs\\b\\s+\\w+",
      "action": "normalizeSpacing",
      "options": { "beforeAs": true, "afterAs": true }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "function", "class"]
}
