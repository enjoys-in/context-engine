{
  "language": "vb",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "VB.NET 4-space indentation",
      "action": "reindent"
    },
    {
      "description": "Indent block structures",
      "action": "indent",
      "pattern": "^\\s*(If|For|While|Do|Select|With|Using|Try|Sub|Function|Property|Class|Module|Namespace|Enum|Structure|Interface)\\b"
    },
    {
      "description": "Align Dim declarations",
      "action": "align",
      "pattern": "^\\s*Dim\\s+\\w+\\s+As",
      "options": {
        "alignOn": "As"
      }
    },
    {
      "description": "Format line continuations",
      "action": "indent",
      "pattern": "_\\s*$"
    },
    {
      "description": "Normalize comparison operators",
      "action": "normalizeSpacing",
      "pattern": "\\s*(=|<>|>=|<=|>|<|Is|IsNot|Like|And|Or|Not|AndAlso|OrElse)\\s*"
    },
    {
      "description": "Align property accessors",
      "action": "indent",
      "pattern": "^\\s*(Get|Set)$"
    },
    {
      "description": "Format XML literals",
      "action": "indent",
      "pattern": "<[a-zA-Z]"
    },
    {
      "description": "Normalize bracket spacing",
      "action": "normalizeSpacing",
      "pattern": "\\(\\s*|\\s*\\)"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "module",
    "property",
    "enum",
    "comment",
    "selection"
  ]
}
