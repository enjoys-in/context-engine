{
  "language": "sparql",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Uppercase SPARQL keywords",
      "pattern": "\\b(select|construct|ask|describe|where|filter|optional|union|bind|values|prefix|base|order|group|having|limit|offset|distinct|reduced|from|named|graph|service|minus|exists|not exists|insert|delete|load|clear|drop|create|add|move|copy)\\b",
      "action": "normalizeSpacing",
      "options": {
        "uppercase": true
      }
    },
    {
      "description": "Align major SPARQL clauses on new lines",
      "pattern": "\\b(SELECT|WHERE|FILTER|OPTIONAL|UNION|ORDER BY|GROUP BY|HAVING|LIMIT|OFFSET|PREFIX|BIND|VALUES)\\b",
      "action": "indent",
      "options": {
        "clauseNewline": true
      }
    },
    {
      "description": "Indent WHERE clause graph patterns",
      "pattern": "WHERE\\s*\\{[\\s\\S]*?\\}",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Align triple patterns (subject predicate object)",
      "pattern": "\\?\\w+\\s+[\\w:]+\\s+",
      "action": "align",
      "options": {
        "alignTo": "predicate"
      }
    },
    {
      "description": "Indent OPTIONAL and subquery blocks",
      "pattern": "\\b(OPTIONAL|UNION|GRAPH|SERVICE)\\b\\s*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "query",
    "clause",
    "block",
    "statement",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
