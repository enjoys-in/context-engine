{
  "language": "makefile",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": false
  },
  "rangeFormattingRules": [
    {
      "description": "Indent recipe lines with tabs",
      "pattern": "^\\t",
      "action": "indent",
      "options": {
        "useTabs": true
      }
    },
    {
      "description": "Align consecutive variable assignments",
      "pattern": "^[A-Z_][A-Z0-9_]*\\s*[?:+]?=",
      "action": "align",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Normalize spacing around assignment operators",
      "pattern": "\\s*([?:+]?=)\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace except in recipe continuation",
      "pattern": "(?<!\\\\)\\s+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
