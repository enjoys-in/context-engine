{
  "language": "makefile",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": false
  },
  "rangeFormattingRules": [
    {
      "description": "Tab-indent recipe lines",
      "action": "reindent",
      "options": {
        "tabSize": 4,
        "insertSpaces": false
      }
    },
    {
      "description": "Align variable assignments",
      "action": "align",
      "pattern": "^\\w+\\s*[:+?]?=",
      "options": {
        "alignOn": "="
      }
    },
    {
      "description": "Format multi-line recipes",
      "action": "indent",
      "pattern": "\\\\\\s*$"
    },
    {
      "description": "Indent conditional directives",
      "action": "indent",
      "pattern": "^(ifeq|ifneq|ifdef|ifndef)\\s+"
    },
    {
      "description": "Normalize include directives",
      "action": "normalizeSpacing",
      "pattern": "^-?include\\s+"
    },
    {
      "description": "Align phony targets",
      "action": "normalizeSpacing",
      "pattern": "^\\.PHONY:\\s+"
    },
    {
      "description": "Format shell function calls",
      "action": "normalizeSpacing",
      "pattern": "\\$\\(shell\\s+"
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": false,
  "supportedRangeTypes": [
    "target",
    "recipe",
    "variable",
    "comment",
    "selection",
    "conditional"
  ]
}
