{
  "language": "msdax",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent nested function calls",
      "pattern": "\\w+\\s*\\(",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Normalize spacing around operators",
      "pattern": "\\s*(&&|\\|\\||[+\\-*/<>=!]+)\\s*",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Wrap long DAX expressions",
      "pattern": ".{100,}",
      "action": "wrapLine",
      "options": { "maxLineLength": 100 }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block"]
}
