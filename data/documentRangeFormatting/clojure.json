{
  "language": "clojure",
  "defaultOptions": {
    "tabSize": 2,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent nested forms within parentheses",
      "pattern": "\\([^)]*\\)",
      "action": "indent",
      "options": {}
    },
    {
      "description": "Align let binding pairs",
      "pattern": "\\(let\\s*\\[",
      "action": "align",
      "options": { "alignOn": " " }
    },
    {
      "description": "Normalize spacing around special forms",
      "pattern": "\\((defn|def|fn|let|if|when|cond|do)\\s+",
      "action": "normalizeSpacing",
      "options": {}
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "\\s+$",
      "action": "trimWhitespace",
      "options": {}
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": ["statement", "block", "function"]
}
