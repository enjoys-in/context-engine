{
  "language": "rust",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "Indent function, impl, and trait block bodies",
      "pattern": "\\b(fn|impl|trait|struct|enum)\\b[^{]*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Align match arm patterns and expressions",
      "pattern": "\\bmatch\\b\\s+\\w+[^{]*\\{[\\s\\S]*?\\}",
      "action": "align",
      "options": {
        "alignOn": "=>"
      }
    },
    {
      "description": "Normalize spacing around lifetime annotations",
      "pattern": "<'\\w+(,\\s*'\\w+)*>",
      "action": "normalizeSpacing",
      "options": {
        "afterComma": true
      }
    },
    {
      "description": "Format macro invocation bodies",
      "pattern": "\\w+!\\s*[({\\[][\\s\\S]*?[)}\\]]",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Indent control flow blocks (if, for, while, loop)",
      "pattern": "\\b(if|else|for|while|loop)\\b[^{]*\\{",
      "action": "indent",
      "options": {
        "indentBody": true
      }
    },
    {
      "description": "Wrap long generic type parameter lists",
      "pattern": "<[^>]{60,}>",
      "action": "wrapLine",
      "options": {
        "maxLength": 100
      }
    },
    {
      "description": "Format method chaining with dot operator",
      "pattern": "\\.\\w+\\(",
      "action": "wrapLine",
      "options": {
        "breakBefore": "."
      }
    },
    {
      "description": "Trim trailing whitespace",
      "pattern": "[ \\t]+$",
      "action": "trimWhitespace",
      "options": {}
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    },
    {
      "description": "Remove trailing whitespace in range",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings in range",
      "action": "normalizeEOL"
    },
    {
      "description": "Align assignments in range",
      "action": "align",
      "pattern": "\\s*=\\s*"
    },
    {
      "description": "Normalize spacing around operators",
      "action": "spaceAround",
      "pattern": "(?<=[\\w)])\\s*([+\\-*/%=<>!&|^~])\\s*(?=[\\w(])"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "class",
    "comment",
    "selection"
  ]
}
