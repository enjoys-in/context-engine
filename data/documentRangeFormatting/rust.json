{
  "language": "rust",
  "defaultOptions": {
    "tabSize": 4,
    "insertSpaces": true
  },
  "rangeFormattingRules": [
    {
      "description": "rustfmt-style 4-space indentation",
      "action": "reindent",
      "options": {
        "tabSize": 4,
        "insertSpaces": true
      }
    },
    {
      "description": "Normalize operator spacing",
      "action": "normalizeSpacing",
      "pattern": "\\s*(==|!=|>=|<=|&&|\\|\\||=>|->|::|[+\\-*/%&|^]=?|=)\\s*"
    },
    {
      "description": "Wrap lines at 100 characters",
      "action": "wrapLine",
      "pattern": ".{100,}",
      "options": {
        "maxLineLength": 100
      }
    },
    {
      "description": "Align match arms",
      "action": "align",
      "pattern": "^\\s*\\w+.*=>",
      "options": {
        "alignOn": "=>"
      }
    },
    {
      "description": "Format where clauses",
      "action": "indent",
      "pattern": "where\\s*$",
      "options": {
        "continuationIndent": 4
      }
    },
    {
      "description": "Indent trait implementations",
      "action": "indent",
      "pattern": "impl\\s+\\w+\\s+for\\s+\\w+"
    },
    {
      "description": "Align struct fields",
      "action": "align",
      "pattern": "^\\s*\\w+:\\s*\\w+",
      "options": {
        "alignOn": ":"
      }
    },
    {
      "description": "Format closure expressions",
      "action": "normalizeSpacing",
      "pattern": "\\|[^|]*\\|\\s*(->)?"
    },
    {
      "description": "Indent enum variants",
      "action": "indent",
      "pattern": "^\\s*\\w+\\s*[({]"
    },
    {
      "description": "Normalize lifetime annotations",
      "action": "normalizeSpacing",
      "pattern": "'\\w+"
    },
    {
      "description": "Format derive attributes",
      "action": "indent",
      "pattern": "#\\[derive\\([^)]+\\)\\]"
    },
    {
      "description": "Align use statements",
      "action": "align",
      "pattern": "^use\\s+"
    },
    {
      "description": "Format turbofish syntax",
      "action": "normalizeSpacing",
      "pattern": "::<[^>]+>"
    },
    {
      "description": "Indent unsafe blocks",
      "action": "indent",
      "pattern": "unsafe\\s*\\{"
    },
    {
      "description": "Format macro invocations",
      "action": "indent",
      "pattern": "\\w+!\\s*[({\\[]"
    },
    {
      "description": "Normalize trailing commas in structs",
      "action": "normalizeSpacing",
      "pattern": ",\\s*$"
    },
    {
      "description": "Format generic type parameters",
      "action": "normalizeSpacing",
      "pattern": "<[^>]+>"
    },
    {
      "description": "Align associated types",
      "action": "align",
      "pattern": "type\\s+\\w+\\s*="
    },
    {
      "description": "Remove trailing whitespace",
      "action": "trimTrailing",
      "pattern": "\\s+$"
    },
    {
      "description": "Normalize line endings",
      "action": "normalizeEOL"
    },
    {
      "description": "Normalize indentation in range",
      "action": "reindent"
    }
  ],
  "adjustToSyntaxNode": true,
  "supportedRangeTypes": [
    "statement",
    "block",
    "function",
    "struct",
    "enum",
    "trait",
    "impl",
    "match",
    "comment",
    "selection",
    "expression",
    "module",
    "macro"
  ]
}
