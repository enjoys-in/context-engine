{
  "language": "sql",
  "implementationPatterns": [
    {
      "interface": "View",
      "implementationKeyword": "CREATE VIEW",
      "pattern": "CREATE\\s+(?:OR\\s+REPLACE\\s+)?VIEW\\s+(\\w+)\\s+AS",
      "description": "View implementation"
    },
    {
      "interface": "Procedure",
      "implementationKeyword": "CREATE PROCEDURE",
      "pattern": "CREATE\\s+(?:OR\\s+REPLACE\\s+)?PROCEDURE\\s+(\\w+)",
      "description": "Stored procedure implementation"
    },
    {
      "interface": "Function",
      "implementationKeyword": "CREATE FUNCTION",
      "pattern": "CREATE\\s+(?:OR\\s+REPLACE\\s+)?FUNCTION\\s+(\\w+)",
      "description": "Function implementation"
    },
    {
      "interface": "Trigger",
      "implementationKeyword": "CREATE TRIGGER",
      "pattern": "CREATE\\s+(?:OR\\s+REPLACE\\s+)?TRIGGER\\s+(\\w+)",
      "description": "Trigger implementation"
    },
    {
      "interface": "Table",
      "implementationKeyword": "CREATE TABLE",
      "pattern": "CREATE\\s+TABLE\\s+(?:IF\\s+NOT\\s+EXISTS\\s+)?(\\w+)",
      "description": "Table definition"
    }
  ],
  "keywords": {
    "interface": [
      "TABLE",
      "VIEW",
      "TYPE"
    ],
    "implementation": [
      "CREATE VIEW",
      "CREATE PROCEDURE",
      "CREATE FUNCTION",
      "CREATE TRIGGER"
    ]
  }
}
