{
  "language": "powershell",
  "implementationPatterns": [
    {
      "interface": "Class",
      "implementationKeyword": "class",
      "pattern": "class\\s+(\\w+)(?:\\s*:\\s*\\w+)?\\s*\\{",
      "description": "PowerShell class definition"
    },
    {
      "interface": "ClassInherit",
      "implementationKeyword": ":",
      "pattern": "class\\s+(\\w+)\\s*:\\s*(\\w+)",
      "description": "Class inheriting base class or implementing interface"
    },
    {
      "interface": "Function",
      "implementationKeyword": "function",
      "pattern": "function\\s+(\\w[\\w-]*)\\s*(?:\\([^)]*\\))?\\s*\\{",
      "description": "Function definition"
    },
    {
      "interface": "CmdletBinding",
      "implementationKeyword": "[CmdletBinding()]",
      "pattern": "\\[CmdletBinding\\(\\)\\]",
      "description": "Advanced function (cmdlet implementation)"
    },
    {
      "interface": "Enum",
      "implementationKeyword": "enum",
      "pattern": "enum\\s+(\\w+)\\s*\\{",
      "description": "Enum type definition"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "class",
      "interface",
      "[CmdletBinding()]"
    ],
    "implementation": [
      "class",
      "function",
      "enum",
      "filter"
    ]
  }
}
