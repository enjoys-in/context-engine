{
  "language": "powershell",
  "implementationPatterns": [
    {
      "interface": "FunctionDef",
      "implementationKeyword": "function",
      "pattern": "function\\s+(\\w+-\\w+)\\s*\\{",
      "captureGroup": 1,
      "description": "PowerShell function (Verb-Noun)",
      "kind": "function"
    },
    {
      "interface": "ClassDecl",
      "implementationKeyword": "class",
      "pattern": "class\\s+(\\w+)(?:\\s*:\\s*[\\w,\\s]+)?\\s*\\{",
      "captureGroup": 1,
      "description": "PowerShell class",
      "kind": "class"
    },
    {
      "interface": "ClassInherit",
      "pattern": "class\\s+(\\w+)\\s*:\\s*(\\w+)",
      "captureGroup": 1,
      "description": "Class inheritance",
      "kind": "class"
    },
    {
      "interface": "InterfaceImpl",
      "pattern": "class\\s+(\\w+)\\s*:\\s*.*I\\w+",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "interface": "FilterDef",
      "implementationKeyword": "filter",
      "pattern": "filter\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Filter function",
      "kind": "filter"
    },
    {
      "interface": "DSCResource",
      "pattern": "\\[DscResource\\(\\)\\]\\s*class\\s+(\\w+)",
      "captureGroup": 1,
      "description": "DSC Resource",
      "kind": "resource"
    },
    {
      "interface": "Cmdlet",
      "pattern": "\\[Cmdlet\\([^)]+\\)\\]\\s*class\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Cmdlet implementation",
      "kind": "cmdlet"
    }
  ],
  "keywords": {
    "interface": [
      "class",
      "function",
      "filter",
      "[DscResource]",
      "[Cmdlet]"
    ],
    "implementation": [
      "class",
      "function",
      "filter",
      "New-Object"
    ]
  }
}
