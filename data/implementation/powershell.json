{
  "language": "powershell",
  "implementationPatterns": [
    {
      "interface": "Class",
      "implementationKeyword": "class",
      "pattern": "class\\s+(\\w+)(?:\\s*:\\s*\\w+)?\\s*\\{",
      "description": "PowerShell class definition"
    },
    {
      "interface": "ClassInherit",
      "implementationKeyword": ":",
      "pattern": "class\\s+(\\w+)\\s*:\\s*(\\w+)",
      "description": "Class inheriting base class or implementing interface"
    },
    {
      "interface": "Function",
      "implementationKeyword": "function",
      "pattern": "function\\s+(\\w[\\w-]*)\\s*(?:\\([^)]*\\))?\\s*\\{",
      "description": "Function definition"
    },
    {
      "interface": "CmdletBinding",
      "implementationKeyword": "[CmdletBinding()]",
      "pattern": "\\[CmdletBinding\\(\\)\\]",
      "description": "Advanced function (cmdlet implementation)"
    },
    {
      "interface": "Enum",
      "implementationKeyword": "enum",
      "pattern": "enum\\s+(\\w+)\\s*\\{",
      "description": "Enum type definition"
    }
  ],
  "keywords": {
    "interface": [
      "class",
      "interface",
      "[CmdletBinding()]"
    ],
    "implementation": [
      "class",
      "function",
      "enum",
      "filter"
    ]
  }
}
