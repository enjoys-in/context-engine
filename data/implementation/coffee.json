{
  "language": "coffee",
  "implementationPatterns": [
    {
      "interface": "ClassExtends",
      "implementationKeyword": "extends",
      "pattern": "class\\s+(\\w+)\\s+extends\\s+(\\w+)",
      "description": "Class extending a base class"
    },
    {
      "interface": "ClassDef",
      "implementationKeyword": "class",
      "pattern": "class\\s+(\\w+)",
      "description": "Class definition"
    },
    {
      "interface": "MethodDef",
      "implementationKeyword": ":",
      "pattern": "(\\w+)\\s*:\\s*(?:\\([^)]*\\))?\\s*(?:->|=>)",
      "description": "Method definition in class body"
    },
    {
      "interface": "Constructor",
      "implementationKeyword": "constructor",
      "pattern": "constructor\\s*:\\s*(?:\\([^)]*\\))?\\s*->",
      "description": "Constructor implementation"
    }
  ],
  "keywords": {
    "interface": [
      "class"
    ],
    "implementation": [
      "class...extends",
      "constructor:",
      "->",
      "=>"
    ]
  }
}
