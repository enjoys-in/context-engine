{
  "language": "coffee",
  "implementationPatterns": [
    {
      "interface": "ClassExtends",
      "implementationKeyword": "extends",
      "pattern": "class\\s+(\\w+)\\s+extends\\s+(\\w+)",
      "description": "Class extending a base class"
    },
    {
      "interface": "ClassDef",
      "implementationKeyword": "class",
      "pattern": "class\\s+(\\w+)",
      "description": "Class definition"
    },
    {
      "interface": "MethodDef",
      "implementationKeyword": ":",
      "pattern": "(\\w+)\\s*:\\s*(?:\\([^)]*\\))?\\s*(?:->|=>)",
      "description": "Method definition in class body"
    },
    {
      "interface": "Constructor",
      "implementationKeyword": "constructor",
      "pattern": "constructor\\s*:\\s*(?:\\([^)]*\\))?\\s*->",
      "description": "Constructor implementation"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "class"
    ],
    "implementation": [
      "class...extends",
      "constructor:",
      "->",
      "=>"
    ]
  }
}
