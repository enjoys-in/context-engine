{
  "language": "markdown",
  "implementationPatterns": [
    {
      "pattern": "^#{1,6}\\s+(.+)",
      "captureGroup": 1,
      "type": "heading",
      "description": "Markdown heading implementation"
    },
    {
      "pattern": "\\[([^\\]]+)\\]\\(([^)]+)\\)",
      "captureGroup": 1,
      "type": "link",
      "description": "Markdown link implementation"
    },
    {
      "pattern": "^\\[([^\\]]+)\\]:\\s*(\\S+)",
      "captureGroup": 1,
      "type": "reference",
      "description": "Reference link implementation"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "note": "Markdown is a text formatting language with no interface/implementation constructs."
  }
}
