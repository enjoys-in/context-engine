{
  "language": "restructuredtext",
  "implementationPatterns": [
    {
      "interface": "Directive",
      "implementationKeyword": ".. ",
      "pattern": "\\.\\.\\s+(\\w+)::",
      "description": "Directive usage (role implementation)"
    },
    {
      "interface": "Substitution",
      "implementationKeyword": "|",
      "pattern": "\\.\\.\\s+\\|(\\w+)\\|\\s+",
      "description": "Substitution definition"
    }
  ],
  "keywords": {
    "note": "reStructuredText is primarily a documentation markup language. Directives and substitutions are the closest to implementation patterns."
  }
}
