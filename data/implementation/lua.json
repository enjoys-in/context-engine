{
  "language": "lua",
  "implementationPatterns": [
    {
      "interface": "ClassFn",
      "pattern": "function\\s+(\\w+):(\\w+)\\s*\\(",
      "captureGroup": 2,
      "description": "Method definition (colon syntax)",
      "kind": "method"
    },
    {
      "interface": "MetamethodImpl",
      "pattern": "__(?:index|newindex|call|tostring|len|add|sub|mul|div|eq|lt|le)\\s*=\\s*function",
      "description": "Metamethod implementation",
      "kind": "metamethod"
    },
    {
      "interface": "InheritanceSetup",
      "pattern": "setmetatable\\s*\\(\\s*(\\w+)\\s*,\\s*\\{\\s*__index\\s*=\\s*(\\w+)",
      "captureGroup": 1,
      "description": "Metatable-based inheritance",
      "kind": "class"
    },
    {
      "interface": "ModuleDef",
      "pattern": "local\\s+(\\w+)\\s*=\\s*\\{\\}",
      "captureGroup": 1,
      "description": "Module table definition",
      "kind": "module"
    }
  ],
  "keywords": {
    "interface": [
      "setmetatable",
      "__index",
      "__newindex",
      "class"
    ],
    "implementation": [
      "setmetatable",
      "function",
      "return"
    ]
  }
}
