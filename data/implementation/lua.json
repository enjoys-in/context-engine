{
  "language": "lua",
  "implementationPatterns": [
    {
      "interface": "Metatable",
      "implementationKeyword": "setmetatable",
      "pattern": "setmetatable\\s*\\(\\s*(\\w+)",
      "description": "Setting metatable (OOP via metatables)"
    },
    {
      "interface": "MethodDef",
      "implementationKeyword": "function",
      "pattern": "function\\s+(\\w+):(\\w+)\\s*\\(",
      "description": "Method definition on table (colon syntax)"
    },
    {
      "interface": "ClassNew",
      "implementationKeyword": "function",
      "pattern": "function\\s+(\\w+)\\.new\\s*\\(",
      "description": "Constructor function (prototype pattern)"
    },
    {
      "interface": "Module",
      "implementationKeyword": "return",
      "pattern": "local\\s+(\\w+)\\s*=\\s*\\{\\}",
      "description": "Module table (returned from file)"
    },
    {
      "interface": "Prototype",
      "implementationKeyword": "__index",
      "pattern": "(\\w+)\\.__index\\s*=\\s*\\1",
      "description": "Prototype setup via __index metamethod"
    }
  ],
  "keywords": {
    "interface": [
      "metatable",
      "__index",
      "module"
    ],
    "implementation": [
      "setmetatable",
      "function T:method",
      "T.new",
      "__index"
    ]
  }
}
