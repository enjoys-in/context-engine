{
  "language": "shell",
  "implementationPatterns": [
    {
      "interface": "Function",
      "implementationKeyword": "function",
      "pattern": "(?:function\\s+)?(\\w+)\\s*\\(\\s*\\)\\s*\\{",
      "description": "Shell function definition"
    },
    {
      "interface": "Alias",
      "implementationKeyword": "alias",
      "pattern": "alias\\s+(\\w+)=",
      "description": "Alias definition"
    },
    {
      "interface": "Source",
      "implementationKeyword": "source",
      "pattern": "(?:source|\\.)\\s+([\\w./]+)",
      "description": "Sourcing another script (include)"
    }
  ],
  "keywords": {
    "interface": [
      "function name",
      "alias"
    ],
    "implementation": [
      "function...{}",
      "() {}",
      "alias...="
    ]
  }
}
