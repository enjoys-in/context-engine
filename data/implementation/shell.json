{
  "language": "shell",
  "implementationPatterns": [
    {
      "interface": "FunctionDef",
      "implementationKeyword": "function",
      "pattern": "(?:function\\s+)?(\\w+)\\s*\\(\\s*\\)\\s*\\{",
      "captureGroup": 1,
      "description": "Shell function definition",
      "kind": "function"
    },
    {
      "interface": "AliasCmd",
      "implementationKeyword": "alias",
      "pattern": "alias\\s+(\\w+)=",
      "captureGroup": 1,
      "description": "Alias definition",
      "kind": "alias"
    },
    {
      "interface": "TrapHandler",
      "implementationKeyword": "trap",
      "pattern": "trap\\s+['\"]?\\w+['\"]?\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Signal trap handler",
      "kind": "handler"
    },
    {
      "interface": "Sourced",
      "implementationKeyword": "source",
      "pattern": "(?:source|\\.)\\s+([\\w./]+)",
      "captureGroup": 1,
      "description": "Sourced script inclusion",
      "kind": "include"
    },
    {
      "interface": "Subcommand",
      "pattern": "case\\s+\"?\\$\\w+\"?\\s+in\\s*.*\\)\\s*(\\w+)",
      "captureGroup": 1,
      "description": "Subcommand dispatch",
      "kind": "dispatch"
    }
  ],
  "keywords": {
    "interface": [
      "function",
      "alias",
      "trap",
      "source"
    ],
    "implementation": [
      "function",
      "alias",
      "trap",
      "source",
      "."
    ]
  }
}
