{
  "language": "scala",
  "implementationPatterns": [
    {
      "interface": "TraitImpl",
      "implementationKeyword": "extends",
      "pattern": "(?:class|object)\\s+(\\w+)(?:<[^>]+>)?\\s+extends\\s+(\\w+)(?:\\s+with\\s+[\\w\\s]+)*",
      "captureGroup": 1,
      "description": "Trait/class extension",
      "kind": "trait"
    },
    {
      "interface": "TraitDecl",
      "implementationKeyword": "trait",
      "pattern": "trait\\s+(\\w+)(?:\\[[^\\]]+\\])?",
      "captureGroup": 1,
      "description": "Trait declaration",
      "kind": "trait"
    },
    {
      "interface": "AbstractClass",
      "pattern": "abstract\\s+class\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract class",
      "kind": "abstract"
    },
    {
      "interface": "OverrideMethod",
      "implementationKeyword": "override",
      "pattern": "override\\s+def\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "override"
    },
    {
      "interface": "CaseClass",
      "pattern": "case\\s+class\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Case class",
      "kind": "class"
    },
    {
      "interface": "SealedTrait",
      "pattern": "sealed\\s+trait\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Sealed trait",
      "kind": "sealed"
    },
    {
      "interface": "ImplicitClass",
      "pattern": "implicit\\s+class\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Implicit class (extension)",
      "kind": "extension"
    },
    {
      "interface": "GivenInstance",
      "implementationKeyword": "given",
      "pattern": "given\\s+(\\w+)\\s*:\\s*(\\w+)",
      "captureGroup": 1,
      "description": "Given instance (Scala 3)",
      "kind": "given"
    },
    {
      "interface": "ExtensionMethod",
      "implementationKeyword": "extension",
      "pattern": "extension\\s*\\(\\w+\\s*:\\s*(\\w+)\\)\\s*def\\s+(\\w+)",
      "captureGroup": 2,
      "description": "Extension method (Scala 3)",
      "kind": "extension"
    },
    {
      "interface": "TypeClass",
      "pattern": "trait\\s+(\\w+)\\[([^\\]]+)\\]",
      "captureGroup": 1,
      "description": "Type class pattern",
      "kind": "typeclass"
    },
    {
      "interface": "CompanionObject",
      "pattern": "object\\s+(\\w+)(?:\\s+extends\\s+[\\w\\s]+)?",
      "captureGroup": 1,
      "description": "Companion object",
      "kind": "object"
    },
    {
      "interface": "CakePattern",
      "pattern": "trait\\s+(\\w+Component|\\w+Module)",
      "captureGroup": 1,
      "description": "Cake pattern component",
      "kind": "pattern"
    }
  ],
  "keywords": {
    "interface": [
      "trait",
      "abstract",
      "extends",
      "with",
      "override",
      "sealed",
      "given",
      "extension"
    ],
    "implementation": [
      "class",
      "object",
      "trait",
      "extends",
      "with",
      "override",
      "given",
      "case class"
    ]
  }
}
