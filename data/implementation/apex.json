{
  "language": "apex",
  "implementationPatterns": [
    {
      "interface": "Interface",
      "implementationKeyword": "implements",
      "pattern": "class\\s+(\\w+)\\s+implements\\s+([\\w,\\s]+)",
      "description": "Class implementing interface(s)"
    },
    {
      "interface": "Extends",
      "implementationKeyword": "extends",
      "pattern": "class\\s+(\\w+)\\s+extends\\s+(\\w+)",
      "description": "Class extending base class"
    },
    {
      "interface": "InterfaceDecl",
      "implementationKeyword": "interface",
      "pattern": "(?:public|global)\\s+interface\\s+(\\w+)",
      "description": "Interface declaration"
    },
    {
      "interface": "AbstractClass",
      "implementationKeyword": "abstract",
      "pattern": "(?:public|global)\\s+abstract\\s+class\\s+(\\w+)",
      "description": "Abstract class declaration"
    },
    {
      "interface": "TriggerImpl",
      "implementationKeyword": "trigger",
      "pattern": "trigger\\s+(\\w+)\\s+on\\s+(\\w+)",
      "description": "Trigger implementation on SObject"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "interface",
      "abstract class",
      "virtual"
    ],
    "implementation": [
      "implements",
      "extends",
      "override",
      "trigger"
    ]
  }
}
