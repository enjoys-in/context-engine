{
  "language": "systemd",
  "implementationPatterns": [
    {
      "pattern": "^\\[([^\\]]+)\\]",
      "captureGroup": 1,
      "type": "section",
      "description": "Systemd unit section implementation"
    },
    {
      "pattern": "^(ExecStart|ExecStartPre|ExecStartPost|ExecReload|ExecStop|ExecStopPost)=(.+)",
      "captureGroup": 1,
      "type": "exec",
      "description": "Service execution directive"
    },
    {
      "pattern": "^(Type|Restart|RestartSec|WantedBy|RequiredBy|After|Before|Requires|Wants|BindsTo|PartOf|Conflicts)=(.+)",
      "captureGroup": 1,
      "type": "directive",
      "description": "Service configuration directive"
    },
    {
      "pattern": "^(Description|Documentation)=(.+)",
      "captureGroup": 1,
      "type": "metadata",
      "description": "Unit metadata directive"
    }
  ],
  "keywords": {
    "note": "systemd unit files are declarative configuration with no interface/implementation constructs."
  }
}