{
  "language": "systemd",
  "implementationPatterns": [
    {
      "pattern": "^\\[([^\\]]+)\\]",
      "captureGroup": 1,
      "type": "section",
      "description": "Systemd unit section implementation"
    },
    {
      "pattern": "^(ExecStart|ExecStartPre|ExecStartPost|ExecReload|ExecStop|ExecStopPost)=(.+)",
      "captureGroup": 1,
      "type": "exec",
      "description": "Service execution directive"
    },
    {
      "pattern": "^(Type|Restart|RestartSec|WantedBy|RequiredBy|After|Before|Requires|Wants|BindsTo|PartOf|Conflicts)=(.+)",
      "captureGroup": 1,
      "type": "directive",
      "description": "Service configuration directive"
    },
    {
      "pattern": "^(Description|Documentation)=(.+)",
      "captureGroup": 1,
      "type": "metadata",
      "description": "Unit metadata directive"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "note": "systemd unit files are declarative configuration with no interface/implementation constructs."
  }
}
