{
  "language": "vb",
  "implementationPatterns": [
    {
      "name": "Class",
      "pattern": "^\\s*(?:Public|Private|Friend)?\\s*(?:Partial\\s+)?Class\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Module",
      "pattern": "^\\s*Module\\s+(\\w+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Sub",
      "pattern": "^\\s*(?:Public|Private|Protected|Friend)?\\s*(?:Shared\\s+)?Sub\\s+(\\w+)",
      "captureGroup": 1,
      "type": "method"
    }
  ],
  "keywords": {}
}