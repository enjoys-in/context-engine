{
  "language": "redis",
  "implementationPatterns": [
    {
      "pattern": "^\\s*(GET|SET|DEL|HGET|HSET|HDEL|HGETALL|LPUSH|RPUSH|LPOP|RPOP|LRANGE|SADD|SREM|ZADD|ZREM|SUBSCRIBE|PUBLISH)\\b",
      "captureGroup": 1,
      "type": "command",
      "description": "Redis command implementation"
    },
    {
      "pattern": "^\\s*(?:SET|GET|DEL)\\s+(\\S+)",
      "captureGroup": 1,
      "type": "key",
      "description": "Redis key implementation"
    },
    {
      "pattern": "^\\s*(MULTI|EXEC|DISCARD)",
      "captureGroup": 1,
      "type": "transaction",
      "description": "Transaction command implementation"
    }
  ],
  "keywords": {
    "note": "Redis is a data store command language with no interface/implementation constructs."
  }
}