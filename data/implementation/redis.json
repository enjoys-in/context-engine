{
  "language": "redis",
  "implementationPatterns": [
    {
      "pattern": "^\\s*(GET|SET|DEL|HGET|HSET|HDEL|HGETALL|LPUSH|RPUSH|LPOP|RPOP|LRANGE|SADD|SREM|ZADD|ZREM|SUBSCRIBE|PUBLISH)\\b",
      "captureGroup": 1,
      "type": "command",
      "description": "Redis command implementation"
    },
    {
      "pattern": "^\\s*(?:SET|GET|DEL)\\s+(\\S+)",
      "captureGroup": 1,
      "type": "key",
      "description": "Redis key implementation"
    },
    {
      "pattern": "^\\s*(MULTI|EXEC|DISCARD)",
      "captureGroup": 1,
      "type": "transaction",
      "description": "Transaction command implementation"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "note": "Redis is a data store command language with no interface/implementation constructs."
  }
}
