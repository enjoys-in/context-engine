{
  "language": "abap",
  "implementationPatterns": [
    {
      "interface": "Interface",
      "implementationKeyword": "IMPLEMENTATION",
      "pattern": "CLASS\\s+(\\w+)\\s+IMPLEMENTATION",
      "description": "Class implementation block"
    },
    {
      "interface": "InterfaceDecl",
      "implementationKeyword": "INTERFACE",
      "pattern": "INTERFACE\\s+(\\w+)",
      "description": "Interface declaration"
    },
    {
      "interface": "MethodImpl",
      "implementationKeyword": "METHOD",
      "pattern": "METHOD\\s+(\\w+)",
      "description": "Method implementation"
    },
    {
      "interface": "InterfaceImpl",
      "implementationKeyword": "INTERFACES",
      "pattern": "INTERFACES\\s+(\\w+)",
      "description": "Interface incorporation in class definition"
    },
    {
      "interface": "ClassDef",
      "implementationKeyword": "CLASS",
      "pattern": "CLASS\\s+(\\w+)\\s+DEFINITION(?:\\s+INHERITING\\s+FROM\\s+\\w+)?",
      "description": "Class definition inheriting from base"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "INTERFACE",
      "ABSTRACT METHODS",
      "CLASS...DEFINITION"
    ],
    "implementation": [
      "CLASS...IMPLEMENTATION",
      "METHOD",
      "INTERFACES"
    ]
  }
}
