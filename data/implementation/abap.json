{
  "language": "abap",
  "implementationPatterns": [
    {
      "interface": "Interface",
      "implementationKeyword": "IMPLEMENTATION",
      "pattern": "CLASS\\s+(\\w+)\\s+IMPLEMENTATION",
      "description": "Class implementation block"
    },
    {
      "interface": "InterfaceDecl",
      "implementationKeyword": "INTERFACE",
      "pattern": "INTERFACE\\s+(\\w+)",
      "description": "Interface declaration"
    },
    {
      "interface": "MethodImpl",
      "implementationKeyword": "METHOD",
      "pattern": "METHOD\\s+(\\w+)",
      "description": "Method implementation"
    },
    {
      "interface": "InterfaceImpl",
      "implementationKeyword": "INTERFACES",
      "pattern": "INTERFACES\\s+(\\w+)",
      "description": "Interface incorporation in class definition"
    },
    {
      "interface": "ClassDef",
      "implementationKeyword": "CLASS",
      "pattern": "CLASS\\s+(\\w+)\\s+DEFINITION(?:\\s+INHERITING\\s+FROM\\s+\\w+)?",
      "description": "Class definition inheriting from base"
    }
  ],
  "keywords": {
    "interface": [
      "INTERFACE",
      "ABSTRACT METHODS",
      "CLASS...DEFINITION"
    ],
    "implementation": [
      "CLASS...IMPLEMENTATION",
      "METHOD",
      "INTERFACES"
    ]
  }
}
