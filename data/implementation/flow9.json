{
  "language": "flow9",
  "implementationPatterns": [
    {
      "interface": "StructDef",
      "implementationKeyword": ":",
      "pattern": "(\\w+)\\s*\\(([^)]*)\\)\\s*->",
      "description": "Struct/union constructor"
    },
    {
      "interface": "FnDef",
      "implementationKeyword": "fn",
      "pattern": "(\\w+)\\s*\\([^)]*\\)\\s*->\\s*\\w+\\s*\\{",
      "description": "Function implementation"
    },
    {
      "interface": "UnionType",
      "implementationKeyword": "::=",
      "pattern": "(\\w+)\\s*::=\\s*([\\w|\\s]+)",
      "description": "Union type declaration"
    },
    {
      "interface": "Import",
      "implementationKeyword": "import",
      "pattern": "import\\s+([\\w/]+)",
      "description": "Module import"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "::= (union)",
      "-> (type signature)"
    ],
    "implementation": [
      "function body {}",
      "struct constructor"
    ]
  }
}
