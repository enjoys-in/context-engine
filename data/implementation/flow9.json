{
  "language": "flow9",
  "implementationPatterns": [
    {
      "interface": "StructDef",
      "implementationKeyword": ":",
      "pattern": "(\\w+)\\s*\\(([^)]*)\\)\\s*->",
      "description": "Struct/union constructor"
    },
    {
      "interface": "FnDef",
      "implementationKeyword": "fn",
      "pattern": "(\\w+)\\s*\\([^)]*\\)\\s*->\\s*\\w+\\s*\\{",
      "description": "Function implementation"
    },
    {
      "interface": "UnionType",
      "implementationKeyword": "::=",
      "pattern": "(\\w+)\\s*::=\\s*([\\w|\\s]+)",
      "description": "Union type declaration"
    },
    {
      "interface": "Import",
      "implementationKeyword": "import",
      "pattern": "import\\s+([\\w/]+)",
      "description": "Module import"
    }
  ],
  "keywords": {
    "interface": [
      "::= (union)",
      "-> (type signature)"
    ],
    "implementation": [
      "function body {}",
      "struct constructor"
    ]
  }
}
