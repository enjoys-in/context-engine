{
  "language": "julia",
  "implementationPatterns": [
    {
      "interface": "AbstractType",
      "implementationKeyword": "abstract type",
      "pattern": "abstract\\s+type\\s+(\\w+)(?:\\s*<:\\s*(\\w+))?\\s+end",
      "description": "Abstract type declaration"
    },
    {
      "interface": "StructSubtype",
      "implementationKeyword": "<:",
      "pattern": "(?:mutable\\s+)?struct\\s+(\\w+)\\s*<:\\s*(\\w+)",
      "description": "Struct subtyping abstract type"
    },
    {
      "interface": "MethodDispatch",
      "implementationKeyword": "function",
      "pattern": "function\\s+(\\w+)\\((?:[^:]+)::(\\w+)",
      "description": "Method with type dispatch (multiple dispatch)"
    },
    {
      "interface": "StructDef",
      "implementationKeyword": "struct",
      "pattern": "(?:mutable\\s+)?struct\\s+(\\w+)",
      "description": "Struct definition"
    },
    {
      "interface": "MacroDef",
      "implementationKeyword": "macro",
      "pattern": "macro\\s+(\\w+)\\s*\\(",
      "description": "Macro implementation"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:defimpl|impl|instance)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Protocol/typeclass implementation",
      "kind": "protocol"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "abstract type",
      "<:",
      "function (generic)"
    ],
    "implementation": [
      "struct",
      "mutable struct",
      "function (dispatch)",
      "macro"
    ]
  }
}
