{
  "language": "julia",
  "implementationPatterns": [
    {
      "interface": "AbstractType",
      "implementationKeyword": "abstract type",
      "pattern": "abstract\\s+type\\s+(\\w+)(?:\\s*<:\\s*(\\w+))?\\s+end",
      "description": "Abstract type declaration"
    },
    {
      "interface": "StructSubtype",
      "implementationKeyword": "<:",
      "pattern": "(?:mutable\\s+)?struct\\s+(\\w+)\\s*<:\\s*(\\w+)",
      "description": "Struct subtyping abstract type"
    },
    {
      "interface": "MethodDispatch",
      "implementationKeyword": "function",
      "pattern": "function\\s+(\\w+)\\((?:[^:]+)::(\\w+)",
      "description": "Method with type dispatch (multiple dispatch)"
    },
    {
      "interface": "StructDef",
      "implementationKeyword": "struct",
      "pattern": "(?:mutable\\s+)?struct\\s+(\\w+)",
      "description": "Struct definition"
    },
    {
      "interface": "MacroDef",
      "implementationKeyword": "macro",
      "pattern": "macro\\s+(\\w+)\\s*\\(",
      "description": "Macro implementation"
    }
  ],
  "keywords": {
    "interface": [
      "abstract type",
      "<:",
      "function (generic)"
    ],
    "implementation": [
      "struct",
      "mutable struct",
      "function (dispatch)",
      "macro"
    ]
  }
}
