{
  "language": "python",
  "implementationPatterns": [
    {
      "interface": "ClassInherit",
      "implementationKeyword": "class",
      "pattern": "class\\s+(\\w+)\\s*\\(([\\w.,\\s]+)\\)\\s*:",
      "description": "Class inheriting from base class(es)"
    },
    {
      "interface": "ABC",
      "implementationKeyword": "ABC",
      "pattern": "class\\s+(\\w+)\\s*\\(.*ABC.*\\)\\s*:",
      "description": "Abstract base class implementation"
    },
    {
      "interface": "Protocol",
      "implementationKeyword": "Protocol",
      "pattern": "class\\s+(\\w+)\\s*\\(.*Protocol.*\\)\\s*:",
      "description": "Protocol (structural typing) implementation"
    },
    {
      "interface": "AbstractMethod",
      "implementationKeyword": "@abstractmethod",
      "pattern": "@abstractmethod\\s*\\ndef\\s+(\\w+)",
      "description": "Abstract method declaration"
    },
    {
      "interface": "Register",
      "implementationKeyword": "register",
      "pattern": "(\\w+)\\.register\\s*\\((\\w+)\\)",
      "description": "ABC virtual subclass registration"
    },
    {
      "interface": "Mixin",
      "implementationKeyword": "Mixin",
      "pattern": "class\\s+(\\w+Mixin)\\s*(?:\\([^)]*\\))?\\s*:",
      "description": "Mixin class definition"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "ABC",
      "ABCMeta",
      "Protocol",
      "@abstractmethod",
      "abstract"
    ],
    "implementation": [
      "class",
      "def",
      "register",
      "Mixin",
      "super()"
    ]
  }
}
