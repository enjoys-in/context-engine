{
  "language": "python",
  "implementationPatterns": [
    {
      "interface": "ClassInherit",
      "implementationKeyword": "class",
      "pattern": "class\\s+(\\w+)\\s*\\(([\\w.,\\s]+)\\)\\s*:",
      "captureGroup": 1,
      "description": "Class inheriting from base class(es)",
      "kind": "class"
    },
    {
      "interface": "ABC",
      "implementationKeyword": "ABC",
      "pattern": "class\\s+(\\w+)\\s*\\(.*(?:ABC|ABCMeta).*\\)\\s*:",
      "captureGroup": 1,
      "description": "Abstract base class implementation",
      "kind": "abstract"
    },
    {
      "interface": "Protocol",
      "implementationKeyword": "Protocol",
      "pattern": "class\\s+(\\w+)\\s*\\(.*Protocol.*\\)\\s*:",
      "captureGroup": 1,
      "description": "Protocol (structural typing) implementation",
      "kind": "protocol"
    },
    {
      "interface": "AbstractMethod",
      "implementationKeyword": "@abstractmethod",
      "pattern": "@abstractmethod\\s*\\ndef\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method declaration",
      "kind": "abstract"
    },
    {
      "interface": "AbstractProperty",
      "pattern": "@property\\s*\\n\\s*@abstractmethod\\s*\\ndef\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract property",
      "kind": "abstract"
    },
    {
      "interface": "Register",
      "implementationKeyword": "register",
      "pattern": "(\\w+)\\.register\\s*\\((\\w+)\\)",
      "captureGroup": 2,
      "description": "ABC virtual subclass registration",
      "kind": "registration"
    },
    {
      "interface": "Mixin",
      "implementationKeyword": "Mixin",
      "pattern": "class\\s+(\\w+Mixin)\\s*(?:\\([^)]*\\))?\\s*:",
      "captureGroup": 1,
      "description": "Mixin class definition",
      "kind": "mixin"
    },
    {
      "interface": "Dataclass",
      "implementationKeyword": "@dataclass",
      "pattern": "@dataclass(?:\\([^)]*\\))?\\s*\\nclass\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Dataclass implementation",
      "kind": "class"
    },
    {
      "interface": "DunderMethod",
      "pattern": "def\\s+(__\\w+__)\\s*\\(self",
      "captureGroup": 1,
      "description": "Dunder method implementation",
      "kind": "protocol"
    },
    {
      "interface": "PropertyImpl",
      "pattern": "@property\\s*\\ndef\\s+(\\w+)\\(self\\)",
      "captureGroup": 1,
      "description": "Property getter implementation",
      "kind": "accessor"
    },
    {
      "interface": "PropertySetter",
      "pattern": "@(\\w+)\\.setter\\s*\\ndef\\s+\\1\\(self",
      "captureGroup": 1,
      "description": "Property setter implementation",
      "kind": "accessor"
    },
    {
      "interface": "ContextManager",
      "pattern": "def\\s+(__enter__|__exit__)\\s*\\(self",
      "captureGroup": 1,
      "description": "Context manager protocol",
      "kind": "protocol"
    },
    {
      "interface": "Iterator",
      "pattern": "def\\s+(__iter__|__next__)\\s*\\(self",
      "captureGroup": 1,
      "description": "Iterator protocol",
      "kind": "protocol"
    },
    {
      "interface": "Descriptor",
      "pattern": "def\\s+(__get__|__set__|__delete__)\\s*\\(self",
      "captureGroup": 1,
      "description": "Descriptor protocol",
      "kind": "protocol"
    },
    {
      "interface": "MetaClass",
      "pattern": "class\\s+(\\w+)\\(type\\)",
      "captureGroup": 1,
      "description": "Metaclass implementation",
      "kind": "metaclass"
    },
    {
      "interface": "Singleton",
      "pattern": "def\\s+__new__\\s*\\(cls[^)]*\\)",
      "description": "Singleton or custom __new__",
      "kind": "pattern"
    },
    {
      "interface": "PluginRegistration",
      "pattern": "(\\w+)_registry\\.register|@register\\w*",
      "description": "Plugin/handler registration",
      "kind": "registration"
    },
    {
      "interface": "TypeVar",
      "pattern": "(\\w+)\\s*=\\s*TypeVar\\(",
      "captureGroup": 1,
      "description": "TypeVar definition",
      "kind": "type"
    },
    {
      "interface": "GenericClass",
      "pattern": "class\\s+(\\w+)\\(Generic\\[",
      "captureGroup": 1,
      "description": "Generic class implementation",
      "kind": "generic"
    },
    {
      "interface": "NamedTuple",
      "pattern": "class\\s+(\\w+)\\(NamedTuple\\)",
      "captureGroup": 1,
      "description": "NamedTuple implementation",
      "kind": "class"
    }
  ],
  "keywords": {
    "interface": [
      "ABC",
      "ABCMeta",
      "Protocol",
      "@abstractmethod",
      "abstract",
      "Generic",
      "TypeVar",
      "NamedTuple"
    ],
    "implementation": [
      "class",
      "def",
      "register",
      "super()",
      "@dataclass",
      "@property",
      "__init__",
      "__new__",
      "__enter__",
      "__exit__",
      "__iter__",
      "__next__"
    ]
  }
}
