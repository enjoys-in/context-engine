{
  "language": "m3",
  "implementationPatterns": [
    {
      "interface": "Interface",
      "implementationKeyword": "INTERFACE",
      "pattern": "INTERFACE\\s+(\\w+)",
      "description": "Interface module declaration"
    },
    {
      "interface": "Module",
      "implementationKeyword": "MODULE",
      "pattern": "MODULE\\s+(\\w+)",
      "description": "Implementation module"
    },
    {
      "interface": "RevealType",
      "implementationKeyword": "REVEAL",
      "pattern": "REVEAL\\s+(\\w+)",
      "description": "Opaque type revelation"
    },
    {
      "interface": "ObjectType",
      "implementationKeyword": "OBJECT",
      "pattern": "(\\w+)\\s*=\\s*\\w+\\s+OBJECT",
      "description": "Object type (OOP subtyping)"
    },
    {
      "interface": "Subtype",
      "implementationKeyword": "<:",
      "pattern": "(\\w+)\\s*<:\\s*(\\w+)",
      "description": "Subtype relationship"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "INTERFACE",
      "OBJECT",
      "METHODS"
    ],
    "implementation": [
      "MODULE",
      "REVEAL",
      "OBJECT",
      "OVERRIDES"
    ]
  }
}
