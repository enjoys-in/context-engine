{
  "language": "lexon",
  "implementationPatterns": [
    {
      "interface": "Clause",
      "implementationKeyword": "CLAUSE",
      "pattern": "CLAUSE:\\s+(\\w[\\w\\s]*)",
      "description": "Contract clause implementation"
    },
    {
      "interface": "Term",
      "implementationKeyword": "TERMS",
      "pattern": "TERMS:\\s*",
      "description": "Terms section"
    },
    {
      "interface": "Covenant",
      "implementationKeyword": "LEX",
      "pattern": "LEX\\s+(\\w[\\w\\s]*)",
      "description": "Legal contract (LEX) declaration"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "LEX",
      "TERMS"
    ],
    "implementation": [
      "CLAUSE",
      "TERMS"
    ]
  }
}
