{
  "language": "twig",
  "implementationPatterns": [
    {
      "interface": "Extends",
      "implementationKeyword": "{% extends",
      "pattern": "\\{%\\s*extends\\s+['\"]([^'\"]+)['\"]",
      "description": "Template extending base layout"
    },
    {
      "interface": "Block",
      "implementationKeyword": "{% block",
      "pattern": "\\{%\\s*block\\s+(\\w+)",
      "description": "Block override implementation"
    },
    {
      "interface": "Macro",
      "implementationKeyword": "{% macro",
      "pattern": "\\{%\\s*macro\\s+(\\w+)\\s*\\(",
      "description": "Macro definition"
    },
    {
      "interface": "Embed",
      "implementationKeyword": "{% embed",
      "pattern": "\\{%\\s*embed\\s+['\"]([^'\"]+)['\"]",
      "description": "Embed template with block overrides"
    },
    {
      "interface": "Include",
      "implementationKeyword": "{% include",
      "pattern": "\\{%\\s*include\\s+['\"]([^'\"]+)['\"]",
      "description": "Partial template inclusion"
    }
  ],
  "keywords": {
    "interface": [
      "{% extends %}",
      "{% block name %}"
    ],
    "implementation": [
      "{% block %}...{% endblock %}",
      "{% macro %}",
      "{% embed %}"
    ]
  }
}
