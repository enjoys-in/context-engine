{
  "language": "twig",
  "implementationPatterns": [
    {
      "interface": "Extends",
      "implementationKeyword": "{% extends",
      "pattern": "\\{%\\s*extends\\s+['\"]([^'\"]+)['\"]",
      "description": "Template extending base layout"
    },
    {
      "interface": "Block",
      "implementationKeyword": "{% block",
      "pattern": "\\{%\\s*block\\s+(\\w+)",
      "description": "Block override implementation"
    },
    {
      "interface": "Macro",
      "implementationKeyword": "{% macro",
      "pattern": "\\{%\\s*macro\\s+(\\w+)\\s*\\(",
      "description": "Macro definition"
    },
    {
      "interface": "Embed",
      "implementationKeyword": "{% embed",
      "pattern": "\\{%\\s*embed\\s+['\"]([^'\"]+)['\"]",
      "description": "Embed template with block overrides"
    },
    {
      "interface": "Include",
      "implementationKeyword": "{% include",
      "pattern": "\\{%\\s*include\\s+['\"]([^'\"]+)['\"]",
      "description": "Partial template inclusion"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "{% extends %}",
      "{% block name %}"
    ],
    "implementation": [
      "{% block %}...{% endblock %}",
      "{% macro %}",
      "{% embed %}"
    ]
  }
}
