{
  "language": "swift",
  "implementationPatterns": [
    {
      "interface": "ProtocolConformance",
      "pattern": "(?:class|struct|enum|actor)\\s+(\\w+)\\s*:\\s*([\\w,\\s]+)",
      "captureGroup": 1,
      "description": "Protocol conformance",
      "kind": "protocol"
    },
    {
      "interface": "ProtocolDecl",
      "implementationKeyword": "protocol",
      "pattern": "protocol\\s+(\\w+)(?:\\s*:\\s*[\\w,\\s]+)?",
      "captureGroup": 1,
      "description": "Protocol declaration",
      "kind": "protocol"
    },
    {
      "interface": "ExtensionConformance",
      "implementationKeyword": "extension",
      "pattern": "extension\\s+(\\w+)\\s*:\\s*(\\w+)",
      "captureGroup": 1,
      "description": "Extension protocol conformance",
      "kind": "extension"
    },
    {
      "interface": "ExtensionDecl",
      "pattern": "extension\\s+(\\w+)(?:<[^>]+>)?\\s*(?:where\\s+[^{]+)?\\{",
      "captureGroup": 1,
      "description": "Extension implementation",
      "kind": "extension"
    },
    {
      "interface": "ClassInherit",
      "pattern": "class\\s+(\\w+)\\s*:\\s*(\\w+)",
      "captureGroup": 1,
      "description": "Class inheritance",
      "kind": "class"
    },
    {
      "interface": "OverrideMethod",
      "implementationKeyword": "override",
      "pattern": "override\\s+(?:class\\s+)?func\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "override"
    },
    {
      "interface": "OverrideProperty",
      "pattern": "override\\s+(?:class\\s+)?var\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Property override",
      "kind": "override"
    },
    {
      "interface": "RequiredInit",
      "pattern": "required\\s+init\\s*\\(",
      "description": "Required initializer",
      "kind": "required"
    },
    {
      "interface": "ProtocolExtDefault",
      "pattern": "extension\\s+\\w+\\s*\\{\\s*(?://.*\\n)?\\s*func\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Protocol extension default implementation",
      "kind": "default"
    },
    {
      "interface": "AssociatedType",
      "pattern": "associatedtype\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Associated type requirement",
      "kind": "associated"
    },
    {
      "interface": "DelegatePattern",
      "pattern": "(?:weak\\s+)?var\\s+delegate\\s*:\\s*(\\w+)\\?",
      "captureGroup": 1,
      "description": "Delegate pattern",
      "kind": "delegate"
    },
    {
      "interface": "PropertyWrapper",
      "implementationKeyword": "@propertyWrapper",
      "pattern": "@propertyWrapper\\s*struct\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Property wrapper",
      "kind": "wrapper"
    },
    {
      "interface": "ResultBuilder",
      "implementationKeyword": "@resultBuilder",
      "pattern": "@resultBuilder\\s*struct\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Result builder",
      "kind": "builder"
    },
    {
      "interface": "ActorDecl",
      "implementationKeyword": "actor",
      "pattern": "actor\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Actor declaration",
      "kind": "actor"
    },
    {
      "interface": "Codable",
      "pattern": ":\\s*(?:.*,\\s*)?(?:Codable|Encodable|Decodable)",
      "description": "Codable conformance",
      "kind": "protocol"
    }
  ],
  "keywords": {
    "interface": [
      "protocol",
      "extension",
      "associatedtype",
      "override",
      "@propertyWrapper",
      "@resultBuilder",
      "actor"
    ],
    "implementation": [
      "class",
      "struct",
      "enum",
      "actor",
      "extension",
      "override",
      "required",
      "func"
    ]
  }
}
