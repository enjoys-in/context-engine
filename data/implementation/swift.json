{
  "language": "swift",
  "implementationPatterns": [
    {
      "interface": "Protocol",
      "implementationKeyword": ":",
      "pattern": "(?:class|struct|enum|actor)\\s+(\\w+)\\s*(?:<[^>]*>)?\\s*:\\s*\\w+",
      "description": "Types conforming to protocols"
    },
    {
      "interface": "Class",
      "implementationKeyword": ":",
      "pattern": "class\\s+(\\w+)\\s*(?:<[^>]*>)?\\s*:\\s*\\w+",
      "description": "Classes inheriting from a superclass"
    },
    {
      "interface": "Extension",
      "implementationKeyword": "extension",
      "pattern": "extension\\s+(\\w+)\\s*:\\s*\\w+",
      "description": "Extensions adding protocol conformance"
    },
    {
      "interface": "ProtocolExtension",
      "implementationKeyword": "extension",
      "pattern": "extension\\s+(\\w+)\\s*(?:where\\s+[^{]+)?\\s*\\{",
      "description": "Protocol extensions providing default implementations"
    },
    {
      "interface": "Actor",
      "implementationKeyword": "actor",
      "pattern": "actor\\s+(\\w+)\\s*(?:<[^>]*>)?\\s*:\\s*\\w+",
      "description": "Actors conforming to protocols"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "protocol",
      "class",
      "actor"
    ],
    "implementation": [
      "class",
      "struct",
      "enum",
      "actor",
      "extension"
    ]
  }
}
