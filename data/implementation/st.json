{
  "language": "st",
  "implementationPatterns": [
    {
      "interface": "FunctionBlock",
      "implementationKeyword": "FUNCTION_BLOCK",
      "pattern": "FUNCTION_BLOCK\\s+(\\w+)(?:\\s+EXTENDS\\s+(\\w+))?",
      "description": "Function block (may extend base)"
    },
    {
      "interface": "Interface",
      "implementationKeyword": "INTERFACE",
      "pattern": "INTERFACE\\s+(\\w+)",
      "description": "Interface declaration"
    },
    {
      "interface": "Implements",
      "implementationKeyword": "IMPLEMENTS",
      "pattern": "FUNCTION_BLOCK\\s+(\\w+)\\s+IMPLEMENTS\\s+([\\w,\\s]+)",
      "description": "Function block implementing interface(s)"
    },
    {
      "interface": "Method",
      "implementationKeyword": "METHOD",
      "pattern": "METHOD\\s+(\\w+)",
      "description": "Method implementation"
    },
    {
      "interface": "Program",
      "implementationKeyword": "PROGRAM",
      "pattern": "PROGRAM\\s+(\\w+)",
      "description": "Program implementation"
    }
  ],
  "keywords": {
    "interface": [
      "INTERFACE",
      "FUNCTION_BLOCK (abstract)",
      "METHOD"
    ],
    "implementation": [
      "FUNCTION_BLOCK...IMPLEMENTS",
      "METHOD",
      "PROGRAM",
      "FUNCTION"
    ]
  }
}
