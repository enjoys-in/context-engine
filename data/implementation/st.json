{
  "language": "st",
  "implementationPatterns": [
    {
      "interface": "FunctionBlock",
      "implementationKeyword": "FUNCTION_BLOCK",
      "pattern": "FUNCTION_BLOCK\\s+(\\w+)(?:\\s+EXTENDS\\s+(\\w+))?",
      "description": "Function block (may extend base)"
    },
    {
      "interface": "Interface",
      "implementationKeyword": "INTERFACE",
      "pattern": "INTERFACE\\s+(\\w+)",
      "description": "Interface declaration"
    },
    {
      "interface": "Implements",
      "implementationKeyword": "IMPLEMENTS",
      "pattern": "FUNCTION_BLOCK\\s+(\\w+)\\s+IMPLEMENTS\\s+([\\w,\\s]+)",
      "description": "Function block implementing interface(s)"
    },
    {
      "interface": "Method",
      "implementationKeyword": "METHOD",
      "pattern": "METHOD\\s+(\\w+)",
      "description": "Method implementation"
    },
    {
      "interface": "Program",
      "implementationKeyword": "PROGRAM",
      "pattern": "PROGRAM\\s+(\\w+)",
      "description": "Program implementation"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "INTERFACE",
      "FUNCTION_BLOCK (abstract)",
      "METHOD"
    ],
    "implementation": [
      "FUNCTION_BLOCK...IMPLEMENTS",
      "METHOD",
      "PROGRAM",
      "FUNCTION"
    ]
  }
}
