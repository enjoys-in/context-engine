{
  "language": "nestjs",
  "implementationPatterns": [
    {
      "interface": "CanActivate",
      "implementationKeyword": "implements",
      "pattern": "class\\s+(\\w+)\\s+implements\\s+CanActivate",
      "description": "Guard implementations"
    },
    {
      "interface": "PipeTransform",
      "implementationKeyword": "implements",
      "pattern": "class\\s+(\\w+)\\s+implements\\s+PipeTransform",
      "description": "Pipe implementations"
    },
    {
      "interface": "NestInterceptor",
      "implementationKeyword": "implements",
      "pattern": "class\\s+(\\w+)\\s+implements\\s+NestInterceptor",
      "description": "Interceptor implementations"
    },
    {
      "interface": "ExceptionFilter",
      "implementationKeyword": "implements",
      "pattern": "class\\s+(\\w+)\\s+implements\\s+ExceptionFilter",
      "description": "Exception filter implementations"
    },
    {
      "interface": "NestMiddleware",
      "implementationKeyword": "implements",
      "pattern": "class\\s+(\\w+)\\s+implements\\s+NestMiddleware",
      "description": "Middleware implementations"
    },
    {
      "interface": "NestModule",
      "implementationKeyword": "implements",
      "pattern": "class\\s+(\\w+)\\s+implements\\s+NestModule",
      "description": "Module configure implementations"
    },
    {
      "interface": "OnModuleInit",
      "implementationKeyword": "implements",
      "pattern": "class\\s+(\\w+)[^{]*implements[^{]*OnModuleInit",
      "description": "OnModuleInit lifecycle hook"
    },
    {
      "interface": "OnModuleDestroy",
      "implementationKeyword": "implements",
      "pattern": "class\\s+(\\w+)[^{]*implements[^{]*OnModuleDestroy",
      "description": "OnModuleDestroy lifecycle hook"
    },
    {
      "interface": "OnApplicationBootstrap",
      "implementationKeyword": "implements",
      "pattern": "class\\s+(\\w+)[^{]*implements[^{]*OnApplicationBootstrap",
      "description": "OnApplicationBootstrap lifecycle hook"
    },
    {
      "interface": "OnApplicationShutdown",
      "implementationKeyword": "implements",
      "pattern": "class\\s+(\\w+)[^{]*implements[^{]*OnApplicationShutdown",
      "description": "OnApplicationShutdown lifecycle hook"
    },
    {
      "interface": "BeforeApplicationShutdown",
      "implementationKeyword": "implements",
      "pattern": "class\\s+(\\w+)[^{]*implements[^{]*BeforeApplicationShutdown",
      "description": "BeforeApplicationShutdown lifecycle hook"
    },
    {
      "interface": "CallHandler",
      "implementationKeyword": "implements",
      "pattern": "intercept\\([^)]*\\).*Observable",
      "description": "Interceptor intercept method"
    },
    {
      "interface": "ArgumentsHost",
      "implementationKeyword": "catch",
      "pattern": "catch\\(\\s*\\w+[^,)]*,\\s*\\w+:\\s*ArgumentsHost",
      "description": "Exception filter catch method"
    },
    {
      "interface": "HealthIndicator",
      "implementationKeyword": "extends",
      "pattern": "class\\s+(\\w+)\\s+extends\\s+HealthIndicator",
      "description": "Health check implementations"
    },
    {
      "interface": "TypeOrmModuleOptions",
      "implementationKeyword": "implements",
      "pattern": "class\\s+(\\w+)\\s+implements\\s+TypeOrmOptionsFactory",
      "description": "TypeORM config factory"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "interface",
      "abstract class",
      "CanActivate",
      "PipeTransform",
      "NestInterceptor",
      "ExceptionFilter",
      "NestMiddleware",
      "NestModule",
      "OnModuleInit",
      "OnModuleDestroy"
    ],
    "implementation": [
      "implements",
      "extends",
      "class",
      "@Injectable",
      "@Controller",
      "@Module"
    ]
  }
}
