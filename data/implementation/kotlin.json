{
  "language": "kotlin",
  "implementationPatterns": [
    {
      "interface": "Interface",
      "implementationKeyword": ":",
      "pattern": "class\\s+(\\w+)\\s*(?:<[^>]*>)?\\s*:\\s*\\w+",
      "description": "Classes implementing interfaces"
    },
    {
      "interface": "AbstractClass",
      "implementationKeyword": ":",
      "pattern": "class\\s+(\\w+)\\s*(?:<[^>]*>)?\\s*:\\s*\\w+\\s*\\(",
      "description": "Classes extending abstract classes"
    },
    {
      "interface": "Sealed",
      "implementationKeyword": ":",
      "pattern": "(?:class|object|data\\s+class)\\s+(\\w+)\\s*(?:<[^>]*>)?\\s*:\\s*\\w+",
      "description": "Sealed class/interface implementations"
    },
    {
      "interface": "FunInterface",
      "implementationKeyword": "fun interface",
      "pattern": "fun\\s+interface\\s+(\\w+)",
      "description": "Functional interface declarations"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "interface",
      "abstract class",
      "sealed class",
      "sealed interface",
      "fun interface"
    ],
    "implementation": [
      "class",
      "object",
      "data class",
      "enum class",
      "value class"
    ]
  }
}
