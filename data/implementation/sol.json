{
  "language": "sol",
  "implementationPatterns": [
    {
      "interface": "Interface",
      "implementationKeyword": "interface",
      "pattern": "interface\\s+(\\w+)(?:\\s+is\\s+[\\w,\\s]+)?\\s*\\{",
      "description": "Interface declaration"
    },
    {
      "interface": "ContractImpl",
      "implementationKeyword": "is",
      "pattern": "contract\\s+(\\w+)\\s+is\\s+([\\w,\\s]+)\\s*\\{",
      "description": "Contract implementing interface(s)/inheriting"
    },
    {
      "interface": "AbstractContract",
      "implementationKeyword": "abstract",
      "pattern": "abstract\\s+contract\\s+(\\w+)",
      "description": "Abstract contract declaration"
    },
    {
      "interface": "Library",
      "implementationKeyword": "library",
      "pattern": "library\\s+(\\w+)\\s*\\{",
      "description": "Library implementation"
    },
    {
      "interface": "Override",
      "implementationKeyword": "override",
      "pattern": "function\\s+(\\w+)\\s*\\([^)]*\\)[^{]*override",
      "description": "Function overriding base implementation"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "interface",
      "abstract contract",
      "virtual"
    ],
    "implementation": [
      "contract...is",
      "override",
      "library"
    ]
  }
}
