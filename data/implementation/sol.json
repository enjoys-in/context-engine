{
  "language": "sol",
  "implementationPatterns": [
    {
      "interface": "ContractImpl",
      "pattern": "contract\\s+(\\w+)\\s+is\\s+([\\w,\\s]+)",
      "captureGroup": 1,
      "description": "Contract inheritance",
      "kind": "contract"
    },
    {
      "interface": "InterfaceDecl",
      "pattern": "interface\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Interface declaration",
      "kind": "interface"
    },
    {
      "interface": "LibraryDecl",
      "pattern": "library\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Library declaration",
      "kind": "library"
    },
    {
      "interface": "EventDecl",
      "pattern": "event\\s+(\\w+)\\s*\\(",
      "captureGroup": 1,
      "description": "Event declaration",
      "kind": "event"
    },
    {
      "interface": "ModifierDecl",
      "pattern": "modifier\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Modifier declaration",
      "kind": "modifier"
    },
    {
      "interface": "OverrideFunc",
      "pattern": "function\\s+(\\w+).*override",
      "captureGroup": 1,
      "description": "Function override",
      "kind": "override"
    }
  ],
  "keywords": {
    "interface": [
      "interface",
      "is",
      "abstract",
      "virtual",
      "override"
    ],
    "implementation": [
      "contract",
      "is",
      "library",
      "override",
      "modifier"
    ]
  }
}
