{
  "language": "sol",
  "implementationPatterns": [
    {
      "interface": "Interface",
      "implementationKeyword": "interface",
      "pattern": "interface\\s+(\\w+)(?:\\s+is\\s+[\\w,\\s]+)?\\s*\\{",
      "description": "Interface declaration"
    },
    {
      "interface": "ContractImpl",
      "implementationKeyword": "is",
      "pattern": "contract\\s+(\\w+)\\s+is\\s+([\\w,\\s]+)\\s*\\{",
      "description": "Contract implementing interface(s)/inheriting"
    },
    {
      "interface": "AbstractContract",
      "implementationKeyword": "abstract",
      "pattern": "abstract\\s+contract\\s+(\\w+)",
      "description": "Abstract contract declaration"
    },
    {
      "interface": "Library",
      "implementationKeyword": "library",
      "pattern": "library\\s+(\\w+)\\s*\\{",
      "description": "Library implementation"
    },
    {
      "interface": "Override",
      "implementationKeyword": "override",
      "pattern": "function\\s+(\\w+)\\s*\\([^)]*\\)[^{]*override",
      "description": "Function overriding base implementation"
    }
  ],
  "keywords": {
    "interface": [
      "interface",
      "abstract contract",
      "virtual"
    ],
    "implementation": [
      "contract...is",
      "override",
      "library"
    ]
  }
}
