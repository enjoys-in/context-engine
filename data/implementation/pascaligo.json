{
  "language": "pascaligo",
  "implementationPatterns": [
    {
      "interface": "TypeDecl",
      "implementationKeyword": "type",
      "pattern": "type\\s+(\\w+)\\s+is",
      "description": "Type definition"
    },
    {
      "interface": "FunctionDecl",
      "implementationKeyword": "function",
      "pattern": "function\\s+(\\w+)\\s*\\(",
      "description": "Function implementation"
    },
    {
      "interface": "Entrypoint",
      "implementationKeyword": "function",
      "pattern": "function\\s+(main|\\w+)\\s*\\(.*action",
      "description": "Contract entrypoint"
    },
    {
      "interface": "ConstDecl",
      "implementationKeyword": "const",
      "pattern": "const\\s+(\\w+)\\s*:",
      "description": "Constant definition"
    }
  ],
  "keywords": {
    "interface": [
      "type",
      "function signature"
    ],
    "implementation": [
      "function...is",
      "type...is",
      "const"
    ]
  }
}
