{
  "language": "tailwindcss",
  "implementationPatterns": [
    {
      "interface": "CustomProperty",
      "pattern": "--([\\w-]+)\\s*:",
      "captureGroup": 1,
      "description": "CSS custom property (variable)",
      "kind": "variable"
    },
    {
      "interface": "Keyframes",
      "pattern": "@keyframes\\s+([\\w-]+)",
      "captureGroup": 1,
      "description": "Animation keyframes",
      "kind": "animation"
    },
    {
      "interface": "FontFace",
      "pattern": "@font-face\\s*\\{(?:[^}]*font-family:\\s*['\"]?([\\w\\s-]+))?",
      "captureGroup": 1,
      "description": "Font face definition",
      "kind": "font"
    },
    {
      "interface": "Layer",
      "pattern": "@layer\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Cascade layer",
      "kind": "layer"
    },
    {
      "interface": "PropertyDef",
      "pattern": "@property\\s+--([\\w-]+)",
      "captureGroup": 1,
      "description": "CSS property definition",
      "kind": "property"
    }
  ],
  "keywords": {
    "interface": [
      "@property",
      "@layer",
      "@keyframes",
      "--"
    ],
    "implementation": [
      "@keyframes",
      "@font-face",
      "@layer",
      "--",
      "@property"
    ]
  }
}
