{
  "language": "cameligo",
  "implementationPatterns": [
    {
      "interface": "TypeDecl",
      "implementationKeyword": "type",
      "pattern": "type\\s+(\\w+)\\s*=",
      "description": "Type definition"
    },
    {
      "interface": "LetBinding",
      "implementationKeyword": "let",
      "pattern": "let\\s+(\\w+)\\s*(?::\\s*[^=]+)?\\s*=",
      "description": "Value/function binding implementation"
    },
    {
      "interface": "Entrypoint",
      "implementationKeyword": "[@entry]",
      "pattern": "\\[@entry\\]\\s*let\\s+(\\w+)",
      "description": "Contract entrypoint implementation"
    },
    {
      "interface": "Module",
      "implementationKeyword": "module",
      "pattern": "module\\s+(\\w+)\\s*=\\s*struct",
      "description": "Module implementation"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:defimpl|impl|instance)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Protocol/typeclass implementation",
      "kind": "protocol"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "type",
      "module type"
    ],
    "implementation": [
      "let",
      "[@entry]",
      "module...struct"
    ]
  }
}
