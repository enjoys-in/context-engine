{
  "language": "objective-c",
  "implementationPatterns": [
    {
      "interface": "Implementation",
      "implementationKeyword": "@implementation",
      "pattern": "@implementation\\s+(\\w+)",
      "description": "Class implementation block"
    },
    {
      "interface": "InterfaceDecl",
      "implementationKeyword": "@interface",
      "pattern": "@interface\\s+(\\w+)\\s*(?::\\s*(\\w+))?",
      "description": "Class interface (header) declaration"
    },
    {
      "interface": "ProtocolDecl",
      "implementationKeyword": "@protocol",
      "pattern": "@protocol\\s+(\\w+)",
      "description": "Protocol declaration"
    },
    {
      "interface": "ProtocolConformance",
      "implementationKeyword": "<protocol>",
      "pattern": "@interface\\s+(\\w+)\\s*\\([^)]*\\)\\s*<([\\w,\\s]+)>",
      "description": "Category conforming to protocol(s)"
    },
    {
      "interface": "Category",
      "implementationKeyword": "()",
      "pattern": "@implementation\\s+(\\w+)\\s*\\((\\w*)\\)",
      "description": "Category implementation"
    }
  ],
  "keywords": {
    "interface": [
      "@interface",
      "@protocol",
      "@required",
      "@optional"
    ],
    "implementation": [
      "@implementation",
      "@synthesize",
      "@dynamic"
    ]
  }
}
