{
  "language": "objective-c",
  "implementationPatterns": [
    {
      "interface": "Implementation",
      "implementationKeyword": "@implementation",
      "pattern": "@implementation\\s+(\\w+)",
      "description": "Class implementation block"
    },
    {
      "interface": "InterfaceDecl",
      "implementationKeyword": "@interface",
      "pattern": "@interface\\s+(\\w+)\\s*(?::\\s*(\\w+))?",
      "description": "Class interface (header) declaration"
    },
    {
      "interface": "ProtocolDecl",
      "implementationKeyword": "@protocol",
      "pattern": "@protocol\\s+(\\w+)",
      "description": "Protocol declaration"
    },
    {
      "interface": "ProtocolConformance",
      "implementationKeyword": "<protocol>",
      "pattern": "@interface\\s+(\\w+)\\s*\\([^)]*\\)\\s*<([\\w,\\s]+)>",
      "description": "Category conforming to protocol(s)"
    },
    {
      "interface": "Category",
      "implementationKeyword": "()",
      "pattern": "@implementation\\s+(\\w+)\\s*\\((\\w*)\\)",
      "description": "Category implementation"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "@interface",
      "@protocol",
      "@required",
      "@optional"
    ],
    "implementation": [
      "@implementation",
      "@synthesize",
      "@dynamic"
    ]
  }
}
