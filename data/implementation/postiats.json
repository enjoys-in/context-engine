{
  "language": "postiats",
  "implementationPatterns": [
    {
      "interface": "FunDef",
      "implementationKeyword": "implement",
      "pattern": "implement\\s+(\\w+)",
      "description": "Function implementation"
    },
    {
      "interface": "FunDecl",
      "implementationKeyword": "fun",
      "pattern": "(?:fun|fn)\\s+(\\w+)\\s*(?:<[^>]+>)?\\s*\\(",
      "description": "Function declaration"
    },
    {
      "interface": "AbsType",
      "implementationKeyword": "abstype",
      "pattern": "abstype\\s+(\\w+)",
      "description": "Abstract type declaration"
    },
    {
      "interface": "Assume",
      "implementationKeyword": "assume",
      "pattern": "assume\\s+(\\w+)\\s*=",
      "description": "Abstract type implementation (assume)"
    },
    {
      "interface": "DataSort",
      "implementationKeyword": "datasort",
      "pattern": "datasort\\s+(\\w+)\\s*=",
      "description": "Datasort definition"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "abstype",
      "fun (signature)",
      "extern fun"
    ],
    "implementation": [
      "implement",
      "assume",
      "fn",
      "fun"
    ]
  }
}
