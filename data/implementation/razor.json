{
  "language": "razor",
  "implementationPatterns": [
    {
      "interface": "Component",
      "implementationKeyword": "@inherits",
      "pattern": "@inherits\\s+([\\w.]+)",
      "description": "Component inheriting base class"
    },
    {
      "interface": "Implements",
      "implementationKeyword": "@implements",
      "pattern": "@implements\\s+([\\w.]+)",
      "description": "Component implementing interface"
    },
    {
      "interface": "CodeBlock",
      "implementationKeyword": "@code",
      "pattern": "@code\\s*\\{",
      "description": "Component code block"
    },
    {
      "interface": "Section",
      "implementationKeyword": "@section",
      "pattern": "@section\\s+(\\w+)\\s*\\{",
      "description": "Layout section implementation"
    },
    {
      "interface": "TypeParam",
      "implementationKeyword": "@typeparam",
      "pattern": "@typeparam\\s+(\\w+)",
      "description": "Generic type parameter"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "@inherits",
      "@implements",
      "@typeparam"
    ],
    "implementation": [
      "@code {}",
      "@section",
      "@inherits",
      "@implements"
    ]
  }
}
