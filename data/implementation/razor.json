{
  "language": "razor",
  "implementationPatterns": [
    {
      "interface": "Component",
      "implementationKeyword": "@inherits",
      "pattern": "@inherits\\s+([\\w.]+)",
      "description": "Component inheriting base class"
    },
    {
      "interface": "Implements",
      "implementationKeyword": "@implements",
      "pattern": "@implements\\s+([\\w.]+)",
      "description": "Component implementing interface"
    },
    {
      "interface": "CodeBlock",
      "implementationKeyword": "@code",
      "pattern": "@code\\s*\\{",
      "description": "Component code block"
    },
    {
      "interface": "Section",
      "implementationKeyword": "@section",
      "pattern": "@section\\s+(\\w+)\\s*\\{",
      "description": "Layout section implementation"
    },
    {
      "interface": "TypeParam",
      "implementationKeyword": "@typeparam",
      "pattern": "@typeparam\\s+(\\w+)",
      "description": "Generic type parameter"
    }
  ],
  "keywords": {
    "interface": [
      "@inherits",
      "@implements",
      "@typeparam"
    ],
    "implementation": [
      "@code {}",
      "@section",
      "@inherits",
      "@implements"
    ]
  }
}
