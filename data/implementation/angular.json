{
  "language": "angular",
  "implementationPatterns": [
    {
      "interface": "ClassDeclaration",
      "implementationKeyword": "class",
      "pattern": "class\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class declaration",
      "kind": "class"
    },
    {
      "interface": "ClassExtends",
      "implementationKeyword": "extends",
      "pattern": "class\\s+(\\w+)\\s+extends\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class extending another class",
      "kind": "class"
    },
    {
      "interface": "PrototypeAssignment",
      "pattern": "(\\w+)\\.prototype\\.(\\w+)\\s*=\\s*function",
      "captureGroup": 2,
      "description": "Prototype method assignment",
      "kind": "method"
    },
    {
      "interface": "PrototypeChain",
      "pattern": "(\\w+)\\.prototype\\s*=\\s*Object\\.create\\((\\w+)\\.prototype\\)",
      "captureGroup": 1,
      "description": "Prototype chain inheritance",
      "kind": "class"
    },
    {
      "interface": "ObjectCreate",
      "pattern": "Object\\.create\\((\\w+)(?:\\.prototype)?\\)",
      "captureGroup": 1,
      "description": "Object.create inheritance",
      "kind": "class"
    },
    {
      "interface": "MixinPattern",
      "pattern": "Object\\.assign\\((\\w+)\\.prototype,\\s*(\\w+)\\)",
      "captureGroup": 1,
      "description": "Mixin via Object.assign",
      "kind": "mixin"
    },
    {
      "interface": "FactoryFunction",
      "pattern": "function\\s+(create|make|build)\\w*\\s*\\(",
      "description": "Factory function pattern",
      "kind": "factory"
    },
    {
      "interface": "GetterSetter",
      "pattern": "(get|set)\\s+(\\w+)\\s*\\(",
      "captureGroup": 2,
      "description": "Getter/setter implementation",
      "kind": "accessor"
    },
    {
      "interface": "SymbolIterator",
      "pattern": "\\[Symbol\\.(iterator|asyncIterator)\\]\\s*\\(",
      "description": "Symbol.iterator implementation",
      "kind": "protocol"
    },
    {
      "interface": "SymbolToPrimitive",
      "pattern": "\\[Symbol\\.toPrimitive\\]\\s*\\(",
      "description": "Symbol.toPrimitive implementation",
      "kind": "protocol"
    },
    {
      "interface": "ProxyHandler",
      "pattern": "new\\s+Proxy\\s*\\([^,]+,\\s*\\{",
      "description": "Proxy handler implementation",
      "kind": "handler"
    },
    {
      "interface": "EventHandler",
      "pattern": "(?:addEventListener|on\\w+)\\s*[=(].*(?:function|=>)",
      "description": "Event handler implementation",
      "kind": "handler"
    },
    {
      "interface": "PromiseExecutor",
      "pattern": "new\\s+Promise\\s*\\(\\s*(?:function|\\()",
      "description": "Promise executor implementation",
      "kind": "callback"
    },
    {
      "interface": "CallbackImpl",
      "pattern": "\\w+\\s*\\(\\s*(?:function|\\([^)]*\\)\\s*=>)",
      "description": "Callback implementation",
      "kind": "callback"
    },
    {
      "interface": "ModuleExport",
      "implementationKeyword": "export",
      "pattern": "export\\s+(default\\s+)?(?:class|function|const|let|var)\\s+(\\w+)",
      "captureGroup": 2,
      "description": "Module export",
      "kind": "module"
    },
    {
      "interface": "StaticMethod",
      "pattern": "static\\s+(\\w+)\\s*\\(",
      "captureGroup": 1,
      "description": "Static method implementation",
      "kind": "method"
    },
    {
      "interface": "AsyncGenerator",
      "pattern": "async\\s*\\*\\s*(\\w+)\\s*\\(",
      "captureGroup": 1,
      "description": "Async generator implementation",
      "kind": "generator"
    },
    {
      "interface": "ComputedProperty",
      "pattern": "\\[(\\w+)\\]\\s*\\(",
      "captureGroup": 1,
      "description": "Computed property method",
      "kind": "method"
    },
    {
      "interface": "InterfaceImpl",
      "implementationKeyword": "implements",
      "pattern": "class\\s+(\\w+)(?:\\s+extends\\s+\\w+)?\\s+implements\\s+([\\w,\\s<>]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "interface": "InterfaceDecl",
      "implementationKeyword": "interface",
      "pattern": "interface\\s+(\\w+)(?:\\s+extends\\s+[\\w,\\s<>]+)?",
      "captureGroup": 1,
      "description": "Interface declaration",
      "kind": "interface"
    },
    {
      "interface": "AbstractClass",
      "implementationKeyword": "abstract",
      "pattern": "abstract\\s+class\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract class declaration",
      "kind": "abstract"
    },
    {
      "interface": "AbstractMethod",
      "pattern": "abstract\\s+(?:get\\s+|set\\s+)?(\\w+)\\s*[(<]",
      "captureGroup": 1,
      "description": "Abstract method declaration",
      "kind": "abstract"
    },
    {
      "interface": "OverrideMethod",
      "implementationKeyword": "override",
      "pattern": "override\\s+(?:get\\s+|set\\s+)?(\\w+)\\s*[(<]",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "override"
    },
    {
      "interface": "TypeAlias",
      "implementationKeyword": "type",
      "pattern": "type\\s+(\\w+)(?:<[^>]+>)?\\s*=",
      "captureGroup": 1,
      "description": "Type alias definition",
      "kind": "type"
    },
    {
      "interface": "EnumDecl",
      "implementationKeyword": "enum",
      "pattern": "(?:const\\s+)?enum\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Enum implementation",
      "kind": "enum"
    },
    {
      "interface": "DecoratorUsage",
      "pattern": "@(\\w+)(?:\\([^)]*\\))?\\s*(?:class|method|property)",
      "captureGroup": 1,
      "description": "Decorator application",
      "kind": "decorator"
    },
    {
      "interface": "GenericConstraint",
      "pattern": "<(\\w+)\\s+extends\\s+([\\w<>]+)>",
      "captureGroup": 1,
      "description": "Generic type constraint implementation",
      "kind": "generic"
    },
    {
      "interface": "ConditionalType",
      "pattern": "type\\s+(\\w+).*=.*extends.*\\?",
      "captureGroup": 1,
      "description": "Conditional type implementation",
      "kind": "type"
    },
    {
      "interface": "MappedType",
      "pattern": "type\\s+(\\w+).*=.*\\[\\w+\\s+in\\s+",
      "captureGroup": 1,
      "description": "Mapped type implementation",
      "kind": "type"
    },
    {
      "interface": "NamespaceDecl",
      "implementationKeyword": "namespace",
      "pattern": "namespace\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Namespace implementation",
      "kind": "namespace"
    },
    {
      "interface": "SatisfiesExpr",
      "pattern": "(\\w+)\\s+satisfies\\s+(\\w+)",
      "description": "Type satisfaction expression",
      "kind": "type"
    },
    {
      "interface": "ComponentDecl",
      "pattern": "@Component\\(\\{[^}]*\\}\\)\\s*class\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Angular component",
      "kind": "component"
    },
    {
      "interface": "ServiceDecl",
      "pattern": "@Injectable\\([^)]*\\)\\s*class\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Angular service",
      "kind": "service"
    },
    {
      "interface": "DirectiveDecl",
      "pattern": "@Directive\\([^)]*\\)\\s*class\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Angular directive",
      "kind": "directive"
    },
    {
      "interface": "PipeDecl",
      "pattern": "@Pipe\\([^)]*\\)\\s*class\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Angular pipe",
      "kind": "pipe"
    },
    {
      "interface": "ModuleDecl",
      "pattern": "@NgModule\\([^)]*\\)\\s*class\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Angular module",
      "kind": "module"
    },
    {
      "interface": "LifecycleHook",
      "pattern": "ng(OnInit|OnDestroy|AfterViewInit|OnChanges|DoCheck|AfterContentInit)\\s*\\(",
      "captureGroup": 1,
      "description": "Angular lifecycle hook",
      "kind": "lifecycle"
    }
  ],
  "keywords": {
    "interface": [
      "interface",
      "abstract",
      "implements",
      "extends",
      "type",
      "override",
      "satisfies"
    ],
    "implementation": [
      "class",
      "implements",
      "extends",
      "override",
      "type",
      "enum",
      "namespace",
      "export",
      "abstract"
    ]
  }
}
