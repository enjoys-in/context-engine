{
  "language": "angular",
  "implementationPatterns": [
    {
      "name": "OnInit",
      "pattern": "class\\s+(\\w+)[^{]*implements\\s+[^{]*\\bOnInit\\b",
      "captureGroup": 1,
      "description": "Class implementing OnInit lifecycle interface"
    },
    {
      "name": "OnDestroy",
      "pattern": "class\\s+(\\w+)[^{]*implements\\s+[^{]*\\bOnDestroy\\b",
      "captureGroup": 1,
      "description": "Class implementing OnDestroy lifecycle interface"
    },
    {
      "name": "OnChanges",
      "pattern": "class\\s+(\\w+)[^{]*implements\\s+[^{]*\\bOnChanges\\b",
      "captureGroup": 1,
      "description": "Class implementing OnChanges lifecycle interface"
    },
    {
      "name": "AfterViewInit",
      "pattern": "class\\s+(\\w+)[^{]*implements\\s+[^{]*\\bAfterViewInit\\b",
      "captureGroup": 1,
      "description": "Class implementing AfterViewInit lifecycle interface"
    },
    {
      "name": "AfterContentInit",
      "pattern": "class\\s+(\\w+)[^{]*implements\\s+[^{]*\\bAfterContentInit\\b",
      "captureGroup": 1,
      "description": "Class implementing AfterContentInit lifecycle interface"
    },
    {
      "name": "DoCheck",
      "pattern": "class\\s+(\\w+)[^{]*implements\\s+[^{]*\\bDoCheck\\b",
      "captureGroup": 1,
      "description": "Class implementing DoCheck lifecycle interface"
    },
    {
      "name": "AfterViewChecked",
      "pattern": "class\\s+(\\w+)[^{]*implements\\s+[^{]*\\bAfterViewChecked\\b",
      "captureGroup": 1,
      "description": "Class implementing AfterViewChecked lifecycle interface"
    },
    {
      "name": "AfterContentChecked",
      "pattern": "class\\s+(\\w+)[^{]*implements\\s+[^{]*\\bAfterContentChecked\\b",
      "captureGroup": 1,
      "description": "Class implementing AfterContentChecked lifecycle interface"
    },
    {
      "name": "CanActivate",
      "pattern": "class\\s+(\\w+)[^{]*implements\\s+[^{]*\\bCanActivate\\b",
      "captureGroup": 1,
      "description": "Class implementing CanActivate route guard interface"
    },
    {
      "name": "CanDeactivate",
      "pattern": "class\\s+(\\w+)[^{]*implements\\s+[^{]*\\bCanDeactivate\\b",
      "captureGroup": 1,
      "description": "Class implementing CanDeactivate route guard interface"
    },
    {
      "name": "Resolve",
      "pattern": "class\\s+(\\w+)[^{]*implements\\s+[^{]*\\bResolve\\b",
      "captureGroup": 1,
      "description": "Class implementing Resolve route resolver interface"
    },
    {
      "name": "HttpInterceptor",
      "pattern": "class\\s+(\\w+)[^{]*implements\\s+[^{]*\\bHttpInterceptor\\b",
      "captureGroup": 1,
      "description": "Class implementing HttpInterceptor interface"
    },
    {
      "name": "PipeTransform",
      "pattern": "class\\s+(\\w+)[^{]*implements\\s+[^{]*\\bPipeTransform\\b",
      "captureGroup": 1,
      "description": "Class implementing PipeTransform interface"
    },
    {
      "name": "ControlValueAccessor",
      "pattern": "class\\s+(\\w+)[^{]*implements\\s+[^{]*\\bControlValueAccessor\\b",
      "captureGroup": 1,
      "description": "Class implementing ControlValueAccessor for custom form controls"
    },
    {
      "name": "Validator",
      "pattern": "class\\s+(\\w+)[^{]*implements\\s+[^{]*\\bValidator\\b",
      "captureGroup": 1,
      "description": "Class implementing Validator interface for custom validation"
    },
    {
      "name": "NgModule",
      "pattern": "@NgModule\\s*\\([^)]*\\)\\s*(?:export\\s+)?class\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Angular module class decorated with @NgModule"
    },
    {
      "name": "ErrorHandler",
      "pattern": "class\\s+(\\w+)[^{]*(?:implements\\s+[^{]*\\bErrorHandler\\b|extends\\s+ErrorHandler)",
      "captureGroup": 1,
      "description": "Class implementing or extending ErrorHandler"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": [
    "implements",
    "extends",
    "override",
    "abstract",
    "virtual",
    "interface",
    "protocol",
    "trait",
    "mixin",
    "delegate"
  ]
}
