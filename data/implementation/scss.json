{
  "language": "scss",
  "implementationPatterns": [
    {
      "interface": "CustomProperty",
      "pattern": "--([\\w-]+)\\s*:",
      "captureGroup": 1,
      "description": "CSS custom property (variable)",
      "kind": "variable"
    },
    {
      "interface": "Keyframes",
      "pattern": "@keyframes\\s+([\\w-]+)",
      "captureGroup": 1,
      "description": "Animation keyframes",
      "kind": "animation"
    },
    {
      "interface": "FontFace",
      "pattern": "@font-face\\s*\\{(?:[^}]*font-family:\\s*['\"]?([\\w\\s-]+))?",
      "captureGroup": 1,
      "description": "Font face definition",
      "kind": "font"
    },
    {
      "interface": "Layer",
      "pattern": "@layer\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Cascade layer",
      "kind": "layer"
    },
    {
      "interface": "PropertyDef",
      "pattern": "@property\\s+--([\\w-]+)",
      "captureGroup": 1,
      "description": "CSS property definition",
      "kind": "property"
    },
    {
      "interface": "MixinDef",
      "implementationKeyword": "@mixin",
      "pattern": "@mixin\\s+([\\w-]+)",
      "captureGroup": 1,
      "description": "Mixin definition",
      "kind": "mixin"
    },
    {
      "interface": "FunctionDef",
      "implementationKeyword": "@function",
      "pattern": "@function\\s+([\\w-]+)",
      "captureGroup": 1,
      "description": "SCSS function",
      "kind": "function"
    },
    {
      "interface": "PlaceholderSelector",
      "pattern": "%([\\w-]+)\\s*\\{",
      "captureGroup": 1,
      "description": "Placeholder selector",
      "kind": "placeholder"
    }
  ],
  "keywords": {
    "interface": [
      "@property",
      "@layer",
      "@keyframes",
      "--"
    ],
    "implementation": [
      "@keyframes",
      "@font-face",
      "@layer",
      "--",
      "@property"
    ]
  }
}
