{
  "language": "scss",
  "implementationPatterns": [
    {
      "interface": "Mixin",
      "implementationKeyword": "@mixin",
      "pattern": "@mixin\\s+([\\w-]+)",
      "description": "Mixin definition"
    },
    {
      "interface": "MixinInclude",
      "implementationKeyword": "@include",
      "pattern": "@include\\s+([\\w-]+)",
      "description": "Mixin inclusion (usage)"
    },
    {
      "interface": "Extend",
      "implementationKeyword": "@extend",
      "pattern": "@extend\\s+([.%][\\w-]+)",
      "description": "Extending another selector/placeholder"
    },
    {
      "interface": "Function",
      "implementationKeyword": "@function",
      "pattern": "@function\\s+([\\w-]+)",
      "description": "Function definition"
    },
    {
      "interface": "Placeholder",
      "implementationKeyword": "%",
      "pattern": "%(\\w[\\w-]*)\\s*\\{",
      "description": "Placeholder selector (abstract)"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "@mixin",
      "%placeholder",
      "@function"
    ],
    "implementation": [
      "@include",
      "@extend",
      "@function...@return"
    ]
  }
}
