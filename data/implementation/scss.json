{
  "language": "scss",
  "implementationPatterns": [
    {
      "interface": "Mixin",
      "implementationKeyword": "@mixin",
      "pattern": "@mixin\\s+([\\w-]+)",
      "description": "Mixin definition"
    },
    {
      "interface": "MixinInclude",
      "implementationKeyword": "@include",
      "pattern": "@include\\s+([\\w-]+)",
      "description": "Mixin inclusion (usage)"
    },
    {
      "interface": "Extend",
      "implementationKeyword": "@extend",
      "pattern": "@extend\\s+([.%][\\w-]+)",
      "description": "Extending another selector/placeholder"
    },
    {
      "interface": "Function",
      "implementationKeyword": "@function",
      "pattern": "@function\\s+([\\w-]+)",
      "description": "Function definition"
    },
    {
      "interface": "Placeholder",
      "implementationKeyword": "%",
      "pattern": "%(\\w[\\w-]*)\\s*\\{",
      "description": "Placeholder selector (abstract)"
    }
  ],
  "keywords": {
    "interface": [
      "@mixin",
      "%placeholder",
      "@function"
    ],
    "implementation": [
      "@include",
      "@extend",
      "@function...@return"
    ]
  }
}
