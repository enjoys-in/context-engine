{
  "language": "dotenv",
  "implementationPatterns": [
    {
      "pattern": "^([A-Z_][A-Z0-9_]*)=",
      "captureGroup": 1,
      "type": "variable",
      "description": "Environment variable definition"
    },
    {
      "pattern": "\\$\\{([A-Z_][A-Z0-9_]*)\\}",
      "captureGroup": 1,
      "type": "reference",
      "description": "Variable reference implementation"
    },
    {
      "pattern": "^([A-Z_][A-Z0-9_]*)=\\$\\{([^}]+):-([^}]*)\\}",
      "captureGroup": 1,
      "type": "variable",
      "description": "Variable with default value"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "note": "dotenv files are key-value configuration files with no interface/implementation constructs."
  }
}
