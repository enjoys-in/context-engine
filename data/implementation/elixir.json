{
  "language": "elixir",
  "implementationPatterns": [
    {
      "interface": "Behaviour",
      "implementationKeyword": "@behaviour",
      "pattern": "@behaviour\\s+(\\w[\\w.]*)",
      "description": "Behaviour callback implementation"
    },
    {
      "interface": "Protocol",
      "implementationKeyword": "defprotocol",
      "pattern": "defprotocol\\s+(\\w[\\w.]*)",
      "description": "Protocol declaration"
    },
    {
      "interface": "ProtocolImpl",
      "implementationKeyword": "defimpl",
      "pattern": "defimpl\\s+(\\w[\\w.]*)\\s*,\\s*for:\\s*(\\w[\\w.]*)",
      "description": "Protocol implementation for a type"
    },
    {
      "interface": "UseModule",
      "implementationKeyword": "use",
      "pattern": "use\\s+(\\w[\\w.]*)",
      "description": "Using a module (macro-based behaviour)"
    },
    {
      "interface": "Callback",
      "implementationKeyword": "@callback",
      "pattern": "@callback\\s+(\\w+)",
      "description": "Behaviour callback declaration"
    },
    {
      "interface": "Impl",
      "implementationKeyword": "@impl",
      "pattern": "@impl\\s+true",
      "description": "Callback implementation marker"
    }
  ],
  "keywords": {
    "interface": [
      "defprotocol",
      "@behaviour",
      "@callback"
    ],
    "implementation": [
      "defimpl",
      "@impl true",
      "use",
      "defmodule"
    ]
  }
}
