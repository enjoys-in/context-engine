{
  "language": "elixir",
  "implementationPatterns": [
    {
      "interface": "Behaviour",
      "implementationKeyword": "@behaviour",
      "pattern": "@behaviour\\s+(\\w[\\w.]*)",
      "description": "Behaviour callback implementation"
    },
    {
      "interface": "Protocol",
      "implementationKeyword": "defprotocol",
      "pattern": "defprotocol\\s+(\\w[\\w.]*)",
      "description": "Protocol declaration"
    },
    {
      "interface": "ProtocolImpl",
      "implementationKeyword": "defimpl",
      "pattern": "defimpl\\s+(\\w[\\w.]*)\\s*,\\s*for:\\s*(\\w[\\w.]*)",
      "description": "Protocol implementation for a type"
    },
    {
      "interface": "UseModule",
      "implementationKeyword": "use",
      "pattern": "use\\s+(\\w[\\w.]*)",
      "description": "Using a module (macro-based behaviour)"
    },
    {
      "interface": "Callback",
      "implementationKeyword": "@callback",
      "pattern": "@callback\\s+(\\w+)",
      "description": "Behaviour callback declaration"
    },
    {
      "interface": "Impl",
      "implementationKeyword": "@impl",
      "pattern": "@impl\\s+true",
      "description": "Callback implementation marker"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:defimpl|impl|instance)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Protocol/typeclass implementation",
      "kind": "protocol"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "defprotocol",
      "@behaviour",
      "@callback"
    ],
    "implementation": [
      "defimpl",
      "@impl true",
      "use",
      "defmodule"
    ]
  }
}
