{
  "language": "elixir",
  "implementationPatterns": [
    {
      "interface": "BehaviourCallback",
      "pattern": "@callback\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Behaviour callback",
      "kind": "callback"
    },
    {
      "interface": "BehaviourImpl",
      "pattern": "@behaviour\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Behaviour usage",
      "kind": "behaviour"
    },
    {
      "interface": "ImplDecl",
      "pattern": "@impl\\s+true",
      "description": "Implementation marker",
      "kind": "impl"
    },
    {
      "interface": "ProtocolDef",
      "pattern": "defprotocol\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Protocol definition",
      "kind": "protocol"
    },
    {
      "interface": "ProtocolImpl",
      "pattern": "defimpl\\s+(\\w+),\\s*for:\\s*(\\w+)",
      "captureGroup": 1,
      "description": "Protocol implementation",
      "kind": "impl"
    },
    {
      "interface": "GenServerImpl",
      "pattern": "use\\s+GenServer",
      "description": "GenServer behaviour",
      "kind": "behaviour"
    },
    {
      "interface": "SupervisorImpl",
      "pattern": "use\\s+Supervisor",
      "description": "Supervisor behaviour",
      "kind": "behaviour"
    },
    {
      "interface": "PlugImpl",
      "pattern": "use\\s+Plug",
      "description": "Plug behaviour",
      "kind": "behaviour"
    }
  ],
  "keywords": {
    "interface": [
      "@callback",
      "defprotocol",
      "@behaviour",
      "GenServer",
      "Supervisor"
    ],
    "implementation": [
      "defimpl",
      "@impl",
      "@behaviour",
      "use",
      "def",
      "defp"
    ]
  }
}
