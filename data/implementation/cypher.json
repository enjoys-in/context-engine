{
  "language": "cypher",
  "implementationPatterns": [
    {
      "interface": "NodeLabel",
      "implementationKeyword": "CREATE",
      "pattern": "CREATE\\s*\\(\\w*:(\\w+)",
      "description": "Node creation implementing a label"
    },
    {
      "interface": "Relationship",
      "implementationKeyword": "CREATE",
      "pattern": "CREATE\\s*\\([^)]*\\)-\\[\\w*:(\\w+)\\]->",
      "description": "Relationship creation"
    },
    {
      "interface": "Constraint",
      "implementationKeyword": "CREATE CONSTRAINT",
      "pattern": "CREATE\\s+CONSTRAINT\\s+(\\w+)",
      "description": "Constraint implementation"
    },
    {
      "interface": "Index",
      "implementationKeyword": "CREATE INDEX",
      "pattern": "CREATE\\s+INDEX\\s+(\\w+)",
      "description": "Index implementation"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "label",
      "relationship type",
      "constraint"
    ],
    "implementation": [
      "CREATE",
      "MERGE",
      "CREATE CONSTRAINT",
      "CREATE INDEX"
    ]
  }
}
