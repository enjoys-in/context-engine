{
  "language": "r",
  "implementationPatterns": [
    {
      "interface": "S3Method",
      "implementationKeyword": "function",
      "pattern": "(\\w+)\\.(\\w+)\\s*<-\\s*function",
      "description": "S3 method dispatch implementation (generic.class)"
    },
    {
      "interface": "S4Class",
      "implementationKeyword": "setClass",
      "pattern": "setClass\\s*\\(\\s*[\"'](\\w+)[\"']",
      "description": "S4 class definition"
    },
    {
      "interface": "S4Method",
      "implementationKeyword": "setMethod",
      "pattern": "setMethod\\s*\\(\\s*[\"'](\\w+)[\"']",
      "description": "S4 method implementation"
    },
    {
      "interface": "R5Class",
      "implementationKeyword": "setRefClass",
      "pattern": "setRefClass\\s*\\(\\s*[\"'](\\w+)[\"']",
      "description": "R5 reference class definition"
    },
    {
      "interface": "R6Class",
      "implementationKeyword": "R6Class",
      "pattern": "R6Class\\$new\\s*\\(|R6::R6Class\\s*\\$\\s*new",
      "description": "R6 class definition"
    },
    {
      "interface": "S4Generic",
      "implementationKeyword": "setGeneric",
      "pattern": "setGeneric\\s*\\(\\s*[\"'](\\w+)[\"']",
      "description": "S4 generic function declaration (interface)"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:defimpl|impl|instance)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Protocol/typeclass implementation",
      "kind": "protocol"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "setGeneric",
      "setClass",
      "UseMethod"
    ],
    "implementation": [
      "setMethod",
      "setRefClass",
      "R6Class$new",
      "generic.class <- function"
    ]
  }
}
