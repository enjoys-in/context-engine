{
  "language": "go",
  "implementationPatterns": [
    {
      "interface": "Interface",
      "implementationKeyword": "func",
      "pattern": "func\\s+\\(\\w+\\s+\\*?(\\w+)\\)\\s+\\w+\\s*\\(",
      "description": "Method on struct (implicit interface satisfaction)"
    },
    {
      "interface": "InterfaceDecl",
      "implementationKeyword": "interface",
      "pattern": "type\\s+(\\w+)\\s+interface\\s*\\{",
      "description": "Interface type declaration"
    },
    {
      "interface": "StructDecl",
      "implementationKeyword": "struct",
      "pattern": "type\\s+(\\w+)\\s+struct\\s*\\{",
      "description": "Struct type declaration (implements interfaces implicitly)"
    },
    {
      "interface": "Embedding",
      "implementationKeyword": "embed",
      "pattern": "type\\s+(\\w+)\\s+struct\\s*\\{[^}]*\\n\\s+\\w+\\b",
      "description": "Struct embedding (composition / interface delegation)"
    },
    {
      "interface": "TypeAssertion",
      "implementationKeyword": ".(type)",
      "pattern": "\\w+\\.\\((\\w+)\\)",
      "description": "Type assertion checking interface satisfaction"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "interface",
      "type"
    ],
    "implementation": [
      "struct",
      "func (receiver)",
      "type assertion"
    ]
  }
}
