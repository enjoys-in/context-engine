{
  "language": "go",
  "implementationPatterns": [
    {
      "interface": "Interface",
      "implementationKeyword": "func",
      "pattern": "func\\s+\\(\\w+\\s+\\*?(\\w+)\\)\\s+\\w+\\s*\\(",
      "description": "Method on struct (implicit interface satisfaction)"
    },
    {
      "interface": "InterfaceDecl",
      "implementationKeyword": "interface",
      "pattern": "type\\s+(\\w+)\\s+interface\\s*\\{",
      "description": "Interface type declaration"
    },
    {
      "interface": "StructDecl",
      "implementationKeyword": "struct",
      "pattern": "type\\s+(\\w+)\\s+struct\\s*\\{",
      "description": "Struct type declaration (implements interfaces implicitly)"
    },
    {
      "interface": "Embedding",
      "implementationKeyword": "embed",
      "pattern": "type\\s+(\\w+)\\s+struct\\s*\\{[^}]*\\n\\s+\\w+\\b",
      "description": "Struct embedding (composition / interface delegation)"
    },
    {
      "interface": "TypeAssertion",
      "implementationKeyword": ".(type)",
      "pattern": "\\w+\\.\\((\\w+)\\)",
      "description": "Type assertion checking interface satisfaction"
    }
  ],
  "keywords": {
    "interface": [
      "interface",
      "type"
    ],
    "implementation": [
      "struct",
      "func (receiver)",
      "type assertion"
    ]
  }
}
