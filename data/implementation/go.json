{
  "language": "go",
  "implementationPatterns": [
    {
      "interface": "InterfaceDecl",
      "implementationKeyword": "interface",
      "pattern": "type\\s+(\\w+)\\s+interface\\s*\\{",
      "captureGroup": 1,
      "description": "Interface declaration",
      "kind": "interface"
    },
    {
      "interface": "StructDecl",
      "implementationKeyword": "struct",
      "pattern": "type\\s+(\\w+)\\s+struct\\s*\\{",
      "captureGroup": 1,
      "description": "Struct declaration",
      "kind": "struct"
    },
    {
      "interface": "MethodReceiver",
      "pattern": "func\\s+\\((\\w+)\\s+\\*?(\\w+)\\)\\s+(\\w+)\\s*\\(",
      "captureGroup": 3,
      "description": "Method with receiver (implicit interface impl)",
      "kind": "method"
    },
    {
      "interface": "EmbeddedStruct",
      "pattern": "type\\s+\\w+\\s+struct\\s*\\{[^}]*\\n\\s+(\\w+)\\s*$",
      "captureGroup": 1,
      "description": "Embedded struct (composition)",
      "kind": "embedding"
    },
    {
      "interface": "EmbeddedInterface",
      "pattern": "type\\s+\\w+\\s+interface\\s*\\{[^}]*\\n\\s+(\\w+)\\s*$",
      "captureGroup": 1,
      "description": "Embedded interface",
      "kind": "embedding"
    },
    {
      "interface": "TypeAlias",
      "pattern": "type\\s+(\\w+)\\s*=\\s*(\\w+)",
      "captureGroup": 1,
      "description": "Type alias",
      "kind": "type"
    },
    {
      "interface": "TypeConstraint",
      "pattern": "type\\s+(\\w+)\\s+interface\\s*\\{[^}]*~?\\w+",
      "captureGroup": 1,
      "description": "Type constraint (generics)",
      "kind": "constraint"
    },
    {
      "interface": "GenericType",
      "pattern": "type\\s+(\\w+)\\[([^\\]]+)\\]",
      "captureGroup": 1,
      "description": "Generic type definition",
      "kind": "generic"
    },
    {
      "interface": "GenericFunc",
      "pattern": "func\\s+(\\w+)\\[([^\\]]+)\\]\\s*\\(",
      "captureGroup": 1,
      "description": "Generic function",
      "kind": "generic"
    },
    {
      "interface": "ErrorInterface",
      "pattern": "func\\s+\\(\\w+\\s+\\*?\\w+\\)\\s+Error\\s*\\(\\)\\s+string",
      "description": "error interface implementation",
      "kind": "interface"
    },
    {
      "interface": "StringerInterface",
      "pattern": "func\\s+\\(\\w+\\s+\\*?\\w+\\)\\s+String\\s*\\(\\)\\s+string",
      "description": "Stringer interface implementation",
      "kind": "interface"
    },
    {
      "interface": "SortInterface",
      "pattern": "func\\s+\\(\\w+\\s+\\*?\\w+\\)\\s+(Len|Less|Swap)\\s*\\(",
      "captureGroup": 1,
      "description": "sort.Interface implementation",
      "kind": "interface"
    },
    {
      "interface": "HandlerFunc",
      "pattern": "func\\s+(\\w+)\\s*\\(\\s*\\w+\\s+http\\.ResponseWriter\\s*,\\s*\\w+\\s*\\*http\\.Request\\)",
      "captureGroup": 1,
      "description": "HTTP handler function",
      "kind": "handler"
    },
    {
      "interface": "ConstructorFunc",
      "pattern": "func\\s+New(\\w+)\\s*\\(",
      "captureGroup": 1,
      "description": "Constructor function pattern",
      "kind": "factory"
    }
  ],
  "keywords": {
    "interface": [
      "interface",
      "struct",
      "type",
      "error",
      "Stringer",
      "io.Reader",
      "io.Writer",
      "http.Handler"
    ],
    "implementation": [
      "func",
      "type",
      "struct",
      "interface",
      "New"
    ]
  }
}
