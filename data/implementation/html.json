{
  "language": "html",
  "implementationPatterns": [
    {
      "pattern": "<(\\w[\\w-]*)(?:\\s|>|/)",
      "captureGroup": 1,
      "type": "element",
      "description": "HTML element implementation"
    },
    {
      "pattern": "id=[\"'](\\w[\\w-]*)[\"']",
      "captureGroup": 1,
      "type": "id",
      "description": "Element ID implementation"
    },
    {
      "pattern": "class=[\"']([^\"']+)[\"']",
      "captureGroup": 1,
      "type": "class",
      "description": "CSS class implementation"
    },
    {
      "pattern": "<script[^>]*>",
      "captureGroup": 0,
      "type": "script",
      "description": "Script block implementation"
    },
    {
      "pattern": "<style[^>]*>",
      "captureGroup": 0,
      "type": "style",
      "description": "Style block implementation"
    }
  ],
  "keywords": {
    "note": "HTML is a markup language with no interface/implementation constructs."
  }
}