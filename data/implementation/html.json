{
  "language": "html",
  "implementationPatterns": [
    {
      "pattern": "<(\\w[\\w-]*)(?:\\s|>|/)",
      "captureGroup": 1,
      "type": "element",
      "description": "HTML element implementation"
    },
    {
      "pattern": "id=[\"'](\\w[\\w-]*)[\"']",
      "captureGroup": 1,
      "type": "id",
      "description": "Element ID implementation"
    },
    {
      "pattern": "class=[\"']([^\"']+)[\"']",
      "captureGroup": 1,
      "type": "class",
      "description": "CSS class implementation"
    },
    {
      "pattern": "<script[^>]*>",
      "captureGroup": 0,
      "type": "script",
      "description": "Script block implementation"
    },
    {
      "pattern": "<style[^>]*>",
      "captureGroup": 0,
      "type": "style",
      "description": "Style block implementation"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "note": "HTML is a markup language with no interface/implementation constructs."
  }
}
