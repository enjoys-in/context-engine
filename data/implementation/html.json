{
  "language": "html",
  "implementationPatterns": [
    {
      "interface": "CustomElement",
      "pattern": "customElements\\.define\\s*\\(\\s*['\"]([\\w-]+)['\"]",
      "captureGroup": 1,
      "description": "Custom element definition",
      "kind": "component"
    },
    {
      "interface": "EventHandler",
      "pattern": "on(\\w+)\\s*=\\s*['\"]",
      "captureGroup": 1,
      "description": "Inline event handler",
      "kind": "handler"
    },
    {
      "interface": "Template",
      "pattern": "<template\\s+id=['\"]([\\w-]+)['\"]",
      "captureGroup": 1,
      "description": "Template element",
      "kind": "template"
    }
  ],
  "keywords": {
    "interface": [
      "customElements",
      "template",
      "slot"
    ],
    "implementation": [
      "define",
      "attachShadow",
      "connectedCallback"
    ]
  }
}
