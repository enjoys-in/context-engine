{
  "language": "clojure",
  "implementationPatterns": [
    {
      "interface": "Protocol",
      "implementationKeyword": "defprotocol",
      "pattern": "\\(defprotocol\\s+(\\w+)",
      "description": "Protocol declaration (interface)"
    },
    {
      "interface": "ExtendType",
      "implementationKeyword": "extend-type",
      "pattern": "\\(extend-type\\s+(\\w+)\\s+\\n?\\s*(\\w+)",
      "description": "Extending a type to implement a protocol"
    },
    {
      "interface": "Defrecord",
      "implementationKeyword": "defrecord",
      "pattern": "\\(defrecord\\s+(\\w+)\\s+\\[[^\\]]*\\]\\s+\\n?\\s*(\\w+)",
      "description": "Record implementing protocol(s)"
    },
    {
      "interface": "Deftype",
      "implementationKeyword": "deftype",
      "pattern": "\\(deftype\\s+(\\w+)\\s+\\[[^\\]]*\\]\\s+\\n?\\s*(\\w+)",
      "description": "Type implementing protocol(s)"
    },
    {
      "interface": "Reify",
      "implementationKeyword": "reify",
      "pattern": "\\(reify\\s+(\\w+)",
      "description": "Anonymous protocol implementation"
    },
    {
      "interface": "Multimethod",
      "implementationKeyword": "defmethod",
      "pattern": "\\(defmethod\\s+(\\w+)",
      "description": "Multimethod dispatch implementation"
    }
  ],
  "keywords": {
    "interface": [
      "defprotocol",
      "defmulti",
      "definterface"
    ],
    "implementation": [
      "extend-type",
      "extend-protocol",
      "defrecord",
      "deftype",
      "reify",
      "defmethod"
    ]
  }
}
