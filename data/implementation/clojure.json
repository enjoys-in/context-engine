{
  "language": "clojure",
  "implementationPatterns": [
    {
      "interface": "ProtocolDef",
      "pattern": "\\(defprotocol\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Protocol definition",
      "kind": "protocol"
    },
    {
      "interface": "RecordImpl",
      "pattern": "\\(defrecord\\s+(\\w+)\\s+\\[",
      "captureGroup": 1,
      "description": "Record definition",
      "kind": "record"
    },
    {
      "interface": "TypeImpl",
      "pattern": "\\(deftype\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Type definition",
      "kind": "type"
    },
    {
      "interface": "ExtendType",
      "pattern": "\\(extend-type\\s+(\\w+)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Extend type with protocol",
      "kind": "extension"
    },
    {
      "interface": "MultimethodDef",
      "pattern": "\\(defmulti\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Multimethod definition",
      "kind": "multimethod"
    },
    {
      "interface": "MultimethodImpl",
      "pattern": "\\(defmethod\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Multimethod implementation",
      "kind": "multimethod"
    },
    {
      "interface": "Reify",
      "pattern": "\\(reify\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Reify expression",
      "kind": "anonymous"
    }
  ],
  "keywords": {
    "interface": [
      "defprotocol",
      "defmulti",
      "reify"
    ],
    "implementation": [
      "defrecord",
      "deftype",
      "extend-type",
      "defmethod",
      "reify"
    ]
  }
}
