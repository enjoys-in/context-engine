{
  "language": "clojure",
  "implementationPatterns": [
    {
      "interface": "Protocol",
      "implementationKeyword": "defprotocol",
      "pattern": "\\(defprotocol\\s+(\\w+)",
      "description": "Protocol declaration (interface)"
    },
    {
      "interface": "ExtendType",
      "implementationKeyword": "extend-type",
      "pattern": "\\(extend-type\\s+(\\w+)\\s+\\n?\\s*(\\w+)",
      "description": "Extending a type to implement a protocol"
    },
    {
      "interface": "Defrecord",
      "implementationKeyword": "defrecord",
      "pattern": "\\(defrecord\\s+(\\w+)\\s+\\[[^\\]]*\\]\\s+\\n?\\s*(\\w+)",
      "description": "Record implementing protocol(s)"
    },
    {
      "interface": "Deftype",
      "implementationKeyword": "deftype",
      "pattern": "\\(deftype\\s+(\\w+)\\s+\\[[^\\]]*\\]\\s+\\n?\\s*(\\w+)",
      "description": "Type implementing protocol(s)"
    },
    {
      "interface": "Reify",
      "implementationKeyword": "reify",
      "pattern": "\\(reify\\s+(\\w+)",
      "description": "Anonymous protocol implementation"
    },
    {
      "interface": "Multimethod",
      "implementationKeyword": "defmethod",
      "pattern": "\\(defmethod\\s+(\\w+)",
      "description": "Multimethod dispatch implementation"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:defimpl|impl|instance)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Protocol/typeclass implementation",
      "kind": "protocol"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "defprotocol",
      "defmulti",
      "definterface"
    ],
    "implementation": [
      "extend-type",
      "extend-protocol",
      "defrecord",
      "deftype",
      "reify",
      "defmethod"
    ]
  }
}
