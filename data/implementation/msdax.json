{
  "language": "msdax",
  "implementationPatterns": [
    {
      "interface": "Measure",
      "implementationKeyword": "MEASURE",
      "pattern": "(?:MEASURE|DEFINE\\s+MEASURE)\\s+(?:[\\w\\[\\]]+\\[)?(\\w+)\\]?\\s*=",
      "description": "Measure definition"
    },
    {
      "interface": "CalculatedColumn",
      "implementationKeyword": "COLUMN",
      "pattern": "DEFINE\\s+COLUMN\\s+(?:[\\w\\[\\]]+\\[)?(\\w+)\\]?\\s*=",
      "description": "Calculated column definition"
    },
    {
      "interface": "Table",
      "implementationKeyword": "TABLE",
      "pattern": "DEFINE\\s+TABLE\\s+(\\w+)\\s*=",
      "description": "Calculated table definition"
    }
  ],
  "keywords": {
    "interface": [
      "MEASURE name",
      "TABLE name"
    ],
    "implementation": [
      "DEFINE MEASURE",
      "DEFINE COLUMN",
      "DEFINE TABLE",
      "EVALUATE"
    ]
  }
}
