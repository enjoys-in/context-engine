{
  "language": "msdax",
  "implementationPatterns": [
    {
      "interface": "Measure",
      "implementationKeyword": "MEASURE",
      "pattern": "(?:MEASURE|DEFINE\\s+MEASURE)\\s+(?:[\\w\\[\\]]+\\[)?(\\w+)\\]?\\s*=",
      "description": "Measure definition"
    },
    {
      "interface": "CalculatedColumn",
      "implementationKeyword": "COLUMN",
      "pattern": "DEFINE\\s+COLUMN\\s+(?:[\\w\\[\\]]+\\[)?(\\w+)\\]?\\s*=",
      "description": "Calculated column definition"
    },
    {
      "interface": "Table",
      "implementationKeyword": "TABLE",
      "pattern": "DEFINE\\s+TABLE\\s+(\\w+)\\s*=",
      "description": "Calculated table definition"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "MEASURE name",
      "TABLE name"
    ],
    "implementation": [
      "DEFINE MEASURE",
      "DEFINE COLUMN",
      "DEFINE TABLE",
      "EVALUATE"
    ]
  }
}
