{
  "language": "graphql",
  "implementationPatterns": [
    {
      "interface": "TypeImpl",
      "implementationKeyword": "type",
      "pattern": "type\\s+(\\w+)(?:\\s+implements\\s+[\\w&\\s]+)?",
      "captureGroup": 1,
      "description": "Type implementation",
      "kind": "type"
    },
    {
      "interface": "InterfaceDecl",
      "pattern": "interface\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Interface declaration",
      "kind": "interface"
    },
    {
      "interface": "UnionDecl",
      "pattern": "union\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "description": "Union type",
      "kind": "union"
    },
    {
      "interface": "InputDecl",
      "pattern": "input\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Input type",
      "kind": "input"
    },
    {
      "interface": "SchemaDecl",
      "pattern": "schema\\s*\\{",
      "description": "Schema definition",
      "kind": "schema"
    },
    {
      "interface": "DirectiveDecl",
      "pattern": "directive\\s+@(\\w+)",
      "captureGroup": 1,
      "description": "Custom directive",
      "kind": "directive"
    },
    {
      "interface": "ResolverField",
      "pattern": "\\w+\\s*\\([^)]*\\)\\s*:",
      "description": "Resolver field with args",
      "kind": "resolver"
    }
  ],
  "keywords": {
    "interface": [
      "interface",
      "type",
      "implements",
      "directive"
    ],
    "implementation": [
      "type",
      "implements",
      "union",
      "input",
      "schema",
      "directive"
    ]
  }
}
