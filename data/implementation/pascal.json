{
  "language": "pascal",
  "implementationPatterns": [
    {
      "interface": "ClassInherit",
      "implementationKeyword": "class",
      "pattern": "(\\w+)\\s*=\\s*class\\s*\\((\\w+)\\)",
      "description": "Class inheriting from base class"
    },
    {
      "interface": "InterfaceImpl",
      "implementationKeyword": "class",
      "pattern": "(\\w+)\\s*=\\s*class\\s*\\(.*,\\s*(I\\w+)",
      "description": "Class implementing interface(s)"
    },
    {
      "interface": "InterfaceDecl",
      "implementationKeyword": "interface",
      "pattern": "(\\w+)\\s*=\\s*interface",
      "description": "Interface declaration"
    },
    {
      "interface": "ImplSection",
      "implementationKeyword": "implementation",
      "pattern": "^implementation$",
      "description": "Implementation section of unit"
    },
    {
      "interface": "MethodImpl",
      "implementationKeyword": "procedure/function",
      "pattern": "(?:procedure|function)\\s+(\\w+)\\.(\\w+)",
      "description": "Method implementation (ClassName.MethodName)"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "interface",
      "class (abstract)",
      "= interface"
    ],
    "implementation": [
      "implementation",
      "class(TBase)",
      "procedure T.Method"
    ]
  }
}
