{
  "language": "ini",
  "implementationPatterns": [
    {
      "pattern": "^\\[([^\\]]+)\\]",
      "captureGroup": 1,
      "type": "section",
      "description": "INI section implementation"
    },
    {
      "pattern": "^(\\w[\\w.-]*)\\s*=",
      "captureGroup": 1,
      "type": "property",
      "description": "INI property implementation"
    },
    {
      "pattern": "^(\\w[\\w.-]*)\\s*=\\s*(.+)",
      "captureGroup": 1,
      "type": "assignment",
      "description": "INI key-value implementation"
    }
  ],
  "keywords": {
    "note": "INI is a configuration file format with no interface/implementation constructs."
  }
}