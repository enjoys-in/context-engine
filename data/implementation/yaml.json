{
  "language": "yaml",
  "implementationPatterns": [
    {
      "pattern": "^\\s*(\\w[\\w-]*):",
      "captureGroup": 1,
      "type": "key",
      "description": "YAML key implementation"
    },
    {
      "pattern": "&(\\w[\\w-]*)",
      "captureGroup": 1,
      "type": "anchor",
      "description": "YAML anchor implementation"
    },
    {
      "pattern": "\\*(\\w[\\w-]*)",
      "captureGroup": 1,
      "type": "alias",
      "description": "YAML alias implementation"
    },
    {
      "pattern": "^---",
      "captureGroup": 0,
      "type": "document",
      "description": "YAML document separator"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "note": "YAML is a data serialization format with no interface/implementation constructs."
  }
}
