{
  "language": "sparql",
  "implementationPatterns": [
    {
      "interface": "PrefixDecl",
      "implementationKeyword": "PREFIX",
      "pattern": "PREFIX\\s+(\\w*):\\s*<([^>]+)>",
      "description": "Prefix namespace binding"
    },
    {
      "interface": "Construct",
      "implementationKeyword": "CONSTRUCT",
      "pattern": "CONSTRUCT\\s*\\{",
      "description": "CONSTRUCT query (graph building)"
    },
    {
      "interface": "SelectQuery",
      "implementationKeyword": "SELECT",
      "pattern": "SELECT\\s+(?:DISTINCT\\s+)?(.+?)\\s+WHERE",
      "description": "SELECT query implementation"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "note": "SPARQL is an RDF query language. PREFIX declarations and query forms (SELECT, CONSTRUCT, ASK, DESCRIBE) are the main structural elements."
  }
}
