{
  "language": "qsharp",
  "implementationPatterns": [
    {
      "interface": "Operation",
      "implementationKeyword": "operation",
      "pattern": "operation\\s+(\\w+)\\s*\\(",
      "description": "Quantum operation implementation"
    },
    {
      "interface": "Function",
      "implementationKeyword": "function",
      "pattern": "function\\s+(\\w+)\\s*\\(",
      "description": "Classical function implementation"
    },
    {
      "interface": "Newtype",
      "implementationKeyword": "newtype",
      "pattern": "newtype\\s+(\\w+)\\s*=",
      "description": "User-defined type"
    },
    {
      "interface": "Adjoint",
      "implementationKeyword": "adjoint",
      "pattern": "adjoint\\s+(auto|self|controlled|\\.\\.\\.)\\s*;",
      "description": "Adjoint specialization implementation"
    },
    {
      "interface": "Controlled",
      "implementationKeyword": "controlled",
      "pattern": "controlled\\s+(auto|\\.\\.\\.)\\s*;",
      "description": "Controlled specialization implementation"
    }
  ],
  "keywords": {
    "interface": [
      "operation (signature)",
      "function (signature)",
      "newtype"
    ],
    "implementation": [
      "operation...{}",
      "function...{}",
      "body",
      "adjoint",
      "controlled"
    ]
  }
}
