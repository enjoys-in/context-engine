{
  "language": "qsharp",
  "implementationPatterns": [
    {
      "interface": "Operation",
      "implementationKeyword": "operation",
      "pattern": "operation\\s+(\\w+)\\s*\\(",
      "description": "Quantum operation implementation"
    },
    {
      "interface": "Function",
      "implementationKeyword": "function",
      "pattern": "function\\s+(\\w+)\\s*\\(",
      "description": "Classical function implementation"
    },
    {
      "interface": "Newtype",
      "implementationKeyword": "newtype",
      "pattern": "newtype\\s+(\\w+)\\s*=",
      "description": "User-defined type"
    },
    {
      "interface": "Adjoint",
      "implementationKeyword": "adjoint",
      "pattern": "adjoint\\s+(auto|self|controlled|\\.\\.\\.)\\s*;",
      "description": "Adjoint specialization implementation"
    },
    {
      "interface": "Controlled",
      "implementationKeyword": "controlled",
      "pattern": "controlled\\s+(auto|\\.\\.\\.)\\s*;",
      "description": "Controlled specialization implementation"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "operation (signature)",
      "function (signature)",
      "newtype"
    ],
    "implementation": [
      "operation...{}",
      "function...{}",
      "body",
      "adjoint",
      "controlled"
    ]
  }
}
