{
  "language": "liquid",
  "implementationPatterns": [
    {
      "interface": "Block",
      "implementationKeyword": "{% block",
      "pattern": "\\{%[-\\s]*block\\s+(\\w+)",
      "description": "Block definition (for template inheritance)"
    },
    {
      "interface": "Render",
      "implementationKeyword": "{% render",
      "pattern": "\\{%[-\\s]*render\\s+['\"]([^'\"]+)['\"]",
      "description": "Rendering a partial/snippet"
    },
    {
      "interface": "Capture",
      "implementationKeyword": "{% capture",
      "pattern": "\\{%[-\\s]*capture\\s+(\\w+)",
      "description": "Capture block output to variable"
    },
    {
      "interface": "Section",
      "implementationKeyword": "{% section",
      "pattern": "\\{%[-\\s]*section\\s+['\"]([^'\"]+)['\"]",
      "description": "Section inclusion"
    }
  ],
  "keywords": {
    "interface": [
      "{% block %}",
      "snippet/partial"
    ],
    "implementation": [
      "{% render %}",
      "{% capture %}",
      "{% section %}"
    ]
  }
}
