{
  "language": "liquid",
  "implementationPatterns": [
    {
      "interface": "Block",
      "implementationKeyword": "{% block",
      "pattern": "\\{%[-\\s]*block\\s+(\\w+)",
      "description": "Block definition (for template inheritance)"
    },
    {
      "interface": "Render",
      "implementationKeyword": "{% render",
      "pattern": "\\{%[-\\s]*render\\s+['\"]([^'\"]+)['\"]",
      "description": "Rendering a partial/snippet"
    },
    {
      "interface": "Capture",
      "implementationKeyword": "{% capture",
      "pattern": "\\{%[-\\s]*capture\\s+(\\w+)",
      "description": "Capture block output to variable"
    },
    {
      "interface": "Section",
      "implementationKeyword": "{% section",
      "pattern": "\\{%[-\\s]*section\\s+['\"]([^'\"]+)['\"]",
      "description": "Section inclusion"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "{% block %}",
      "snippet/partial"
    ],
    "implementation": [
      "{% render %}",
      "{% capture %}",
      "{% section %}"
    ]
  }
}
