{
  "language": "hcl",
  "implementationPatterns": [
    {
      "interface": "ResourceBlock",
      "implementationKeyword": "resource",
      "pattern": "resource\\s+\"(\\w+)\"\\s+\"(\\w+)\"",
      "captureGroup": 2,
      "description": "Resource declaration",
      "kind": "resource"
    },
    {
      "interface": "ModuleBlock",
      "implementationKeyword": "module",
      "pattern": "module\\s+\"(\\w+)\"",
      "captureGroup": 1,
      "description": "Module declaration",
      "kind": "module"
    },
    {
      "interface": "ProviderBlock",
      "pattern": "provider\\s+\"(\\w+)\"",
      "captureGroup": 1,
      "description": "Provider configuration",
      "kind": "provider"
    },
    {
      "interface": "VariableBlock",
      "pattern": "variable\\s+\"(\\w+)\"",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "interface": "OutputBlock",
      "pattern": "output\\s+\"(\\w+)\"",
      "captureGroup": 1,
      "description": "Output declaration",
      "kind": "output"
    }
  ],
  "keywords": {
    "interface": [
      "resource",
      "module",
      "provider"
    ],
    "implementation": [
      "resource",
      "module",
      "data",
      "variable",
      "output",
      "locals"
    ]
  }
}
