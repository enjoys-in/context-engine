{
  "language": "hcl",
  "implementationPatterns": [
    {
      "interface": "Resource",
      "implementationKeyword": "resource",
      "pattern": "resource\\s+\"(\\w+)\"\\s+\"(\\w+)\"\\s*\\{",
      "description": "Resource block implementation"
    },
    {
      "interface": "Module",
      "implementationKeyword": "module",
      "pattern": "module\\s+\"(\\w+)\"\\s*\\{",
      "description": "Module block instantiation"
    },
    {
      "interface": "Variable",
      "implementationKeyword": "variable",
      "pattern": "variable\\s+\"(\\w+)\"\\s*\\{",
      "description": "Variable definition"
    },
    {
      "interface": "Output",
      "implementationKeyword": "output",
      "pattern": "output\\s+\"(\\w+)\"\\s*\\{",
      "description": "Output definition"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "variable",
      "output"
    ],
    "implementation": [
      "resource",
      "module",
      "data",
      "provider",
      "locals"
    ]
  }
}
