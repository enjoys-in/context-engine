{
  "language": "makefile",
  "implementationPatterns": [
    {
      "interface": "Target",
      "implementationKeyword": ":",
      "pattern": "^([\\w.-]+)\\s*:(?!=)",
      "description": "Make target implementation"
    },
    {
      "interface": "PatternRule",
      "implementationKeyword": "%",
      "pattern": "^%\\.(\\w+)\\s*:\\s*%\\.(\\w+)",
      "description": "Pattern rule implementation"
    },
    {
      "interface": "PhonyTarget",
      "implementationKeyword": ".PHONY",
      "pattern": "\\.PHONY\\s*:\\s*([\\w\\s.-]+)",
      "description": "Phony target declaration"
    },
    {
      "interface": "Function",
      "implementationKeyword": "define",
      "pattern": "define\\s+(\\w+)",
      "description": "Multi-line variable/function definition"
    }
  ],
  "keywords": {
    "interface": [
      ".PHONY",
      "target name"
    ],
    "implementation": [
      "target: dependencies",
      "define",
      "%.o: %.c"
    ]
  }
}
