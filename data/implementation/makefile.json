{
  "language": "makefile",
  "implementationPatterns": [
    {
      "interface": "Target",
      "implementationKeyword": ":",
      "pattern": "^([\\w.-]+)\\s*:(?!=)",
      "description": "Make target implementation"
    },
    {
      "interface": "PatternRule",
      "implementationKeyword": "%",
      "pattern": "^%\\.(\\w+)\\s*:\\s*%\\.(\\w+)",
      "description": "Pattern rule implementation"
    },
    {
      "interface": "PhonyTarget",
      "implementationKeyword": ".PHONY",
      "pattern": "\\.PHONY\\s*:\\s*([\\w\\s.-]+)",
      "description": "Phony target declaration"
    },
    {
      "interface": "Function",
      "implementationKeyword": "define",
      "pattern": "define\\s+(\\w+)",
      "description": "Multi-line variable/function definition"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      ".PHONY",
      "target name"
    ],
    "implementation": [
      "target: dependencies",
      "define",
      "%.o: %.c"
    ]
  }
}
