{
  "language": "ecl",
  "implementationPatterns": [
    {
      "interface": "Module",
      "implementationKeyword": "MODULE",
      "pattern": "(?:EXPORT\\s+)?(\\w+)\\s*:=\\s*MODULE",
      "description": "Module definition"
    },
    {
      "interface": "Interface",
      "implementationKeyword": "INTERFACE",
      "pattern": "(?:EXPORT\\s+)?(\\w+)\\s*:=\\s*INTERFACE",
      "description": "Interface declaration"
    },
    {
      "interface": "Record",
      "implementationKeyword": "RECORD",
      "pattern": "(\\w+)\\s*:=\\s*RECORD",
      "description": "Record structure definition"
    },
    {
      "interface": "Function",
      "implementationKeyword": "FUNCTION",
      "pattern": "(?:EXPORT\\s+)?(\\w+)\\s*:=\\s*FUNCTION",
      "description": "Function implementation"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "INTERFACE",
      "MODULE",
      "VIRTUAL"
    ],
    "implementation": [
      "MODULE",
      "FUNCTION",
      "RECORD",
      ":= MODULE"
    ]
  }
}
