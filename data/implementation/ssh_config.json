{
  "language": "ssh_config",
  "implementationPatterns": [
    {
      "pattern": "^Host\\s+(\\S+)",
      "captureGroup": 1,
      "type": "host",
      "description": "SSH host configuration"
    },
    {
      "pattern": "^\\s*(HostName|User|Port|IdentityFile|ProxyCommand|ProxyJump|ForwardAgent|StrictHostKeyChecking|UserKnownHostsFile|ServerAliveInterval|ServerAliveCountMax|Compression|AddKeysToAgent|IdentitiesOnly)\\s+(\\S+)",
      "captureGroup": 1,
      "type": "directive",
      "description": "SSH directive implementation"
    },
    {
      "pattern": "^\\s*Include\\s+(\\S+)",
      "captureGroup": 1,
      "type": "include",
      "description": "SSH config include implementation"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "note": "SSH config is a configuration format with no interface/implementation constructs."
  }
}
