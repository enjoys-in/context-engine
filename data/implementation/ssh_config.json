{
  "language": "ssh_config",
  "implementationPatterns": [
    {
      "pattern": "^Host\\s+(\\S+)",
      "captureGroup": 1,
      "type": "host",
      "description": "SSH host configuration"
    },
    {
      "pattern": "^\\s*(HostName|User|Port|IdentityFile|ProxyCommand|ProxyJump|ForwardAgent|StrictHostKeyChecking|UserKnownHostsFile|ServerAliveInterval|ServerAliveCountMax|Compression|AddKeysToAgent|IdentitiesOnly)\\s+(\\S+)",
      "captureGroup": 1,
      "type": "directive",
      "description": "SSH directive implementation"
    },
    {
      "pattern": "^\\s*Include\\s+(\\S+)",
      "captureGroup": 1,
      "type": "include",
      "description": "SSH config include implementation"
    }
  ],
  "keywords": {
    "note": "SSH config is a configuration format with no interface/implementation constructs."
  }
}