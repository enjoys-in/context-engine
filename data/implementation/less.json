{
  "language": "less",
  "implementationPatterns": [
    {
      "interface": "Mixin",
      "implementationKeyword": ".",
      "pattern": "\\.(\\w[\\w-]*)\\s*\\([^)]*\\)\\s*\\{",
      "description": "Mixin definition (parametric)"
    },
    {
      "interface": "MixinCall",
      "implementationKeyword": ".",
      "pattern": "\\.(\\w[\\w-]*)\\s*\\(",
      "description": "Mixin inclusion (call)"
    },
    {
      "interface": "Extend",
      "implementationKeyword": ":extend",
      "pattern": "&:extend\\(\\.(\\w[\\w-]*)\\)",
      "description": "Extending another ruleset"
    },
    {
      "interface": "Variable",
      "implementationKeyword": "@",
      "pattern": "@(\\w[\\w-]*)\\s*:",
      "description": "Variable definition"
    }
  ],
  "keywords": {
    "interface": [
      "mixin definition",
      "@variable"
    ],
    "implementation": [
      ".mixin()",
      "&:extend()",
      "when (guard)"
    ]
  }
}
