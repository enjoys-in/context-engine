{
  "language": "less",
  "implementationPatterns": [
    {
      "interface": "Mixin",
      "implementationKeyword": ".",
      "pattern": "\\.(\\w[\\w-]*)\\s*\\([^)]*\\)\\s*\\{",
      "description": "Mixin definition (parametric)"
    },
    {
      "interface": "MixinCall",
      "implementationKeyword": ".",
      "pattern": "\\.(\\w[\\w-]*)\\s*\\(",
      "description": "Mixin inclusion (call)"
    },
    {
      "interface": "Extend",
      "implementationKeyword": ":extend",
      "pattern": "&:extend\\(\\.(\\w[\\w-]*)\\)",
      "description": "Extending another ruleset"
    },
    {
      "interface": "Variable",
      "implementationKeyword": "@",
      "pattern": "@(\\w[\\w-]*)\\s*:",
      "description": "Variable definition"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "mixin definition",
      "@variable"
    ],
    "implementation": [
      ".mixin()",
      "&:extend()",
      "when (guard)"
    ]
  }
}
