{
  "language": "nginx",
  "implementationPatterns": [
    {
      "interface": "ServerBlock",
      "implementationKeyword": "server",
      "pattern": "server\\s*\\{",
      "description": "Server block definition"
    },
    {
      "interface": "LocationBlock",
      "implementationKeyword": "location",
      "pattern": "location\\s+([^{]+)\\{",
      "description": "Location block implementation"
    },
    {
      "interface": "UpstreamBlock",
      "implementationKeyword": "upstream",
      "pattern": "upstream\\s+(\\w+)\\s*\\{",
      "description": "Upstream block definition"
    },
    {
      "interface": "MapBlock",
      "implementationKeyword": "map",
      "pattern": "map\\s+\\$\\w+\\s+\\$(\\w+)\\s*\\{",
      "description": "Map directive implementation"
    }
  ],
  "keywords": {
    "interface": [
      "server_name",
      "listen",
      "upstream name"
    ],
    "implementation": [
      "server",
      "location",
      "upstream",
      "map",
      "proxy_pass"
    ]
  }
}
