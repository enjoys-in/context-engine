{
  "language": "nginx",
  "implementationPatterns": [
    {
      "interface": "ServerBlock",
      "implementationKeyword": "server",
      "pattern": "server\\s*\\{",
      "description": "Server block definition"
    },
    {
      "interface": "LocationBlock",
      "implementationKeyword": "location",
      "pattern": "location\\s+([^{]+)\\{",
      "description": "Location block implementation"
    },
    {
      "interface": "UpstreamBlock",
      "implementationKeyword": "upstream",
      "pattern": "upstream\\s+(\\w+)\\s*\\{",
      "description": "Upstream block definition"
    },
    {
      "interface": "MapBlock",
      "implementationKeyword": "map",
      "pattern": "map\\s+\\$\\w+\\s+\\$(\\w+)\\s*\\{",
      "description": "Map directive implementation"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "server_name",
      "listen",
      "upstream name"
    ],
    "implementation": [
      "server",
      "location",
      "upstream",
      "map",
      "proxy_pass"
    ]
  }
}
