{
  "language": "caddy",
  "implementationPatterns": [
    {
      "interface": "SiteBlock",
      "implementationKeyword": "site",
      "pattern": "^[\\w.:]+\\s*\\{",
      "description": "Site block definition"
    },
    {
      "interface": "Directive",
      "implementationKeyword": "directive",
      "pattern": "^\\s+(reverse_proxy|file_server|respond|rewrite|redir|handle|route|tls|encode|log|header|basicauth)\\b",
      "description": "Directive implementation within site block"
    },
    {
      "interface": "HandleBlock",
      "implementationKeyword": "handle",
      "pattern": "handle(?:_path)?\\s+[^{]*\\{",
      "description": "Handle block implementation"
    },
    {
      "interface": "Matcher",
      "implementationKeyword": "@",
      "pattern": "@(\\w+)\\s+",
      "description": "Named matcher definition"
    }
  ],
  "keywords": {
    "interface": [
      "site address",
      "named matcher"
    ],
    "implementation": [
      "handle",
      "route",
      "reverse_proxy",
      "file_server",
      "respond"
    ]
  }
}
