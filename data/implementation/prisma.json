{
  "language": "prisma",
  "implementationPatterns": [
    {
      "interface": "Model",
      "implementationKeyword": "model",
      "pattern": "model\\s+(\\w+)\\s*\\{",
      "captureGroup": 1,
      "description": "Model declaration implementing a data structure",
      "kind": "class"
    },
    {
      "interface": "Enum",
      "implementationKeyword": "enum",
      "pattern": "enum\\s+(\\w+)\\s*\\{",
      "captureGroup": 1,
      "description": "Enum type declaration",
      "kind": "enum"
    },
    {
      "interface": "CompositeType",
      "implementationKeyword": "type",
      "pattern": "type\\s+(\\w+)\\s*\\{",
      "captureGroup": 1,
      "description": "Composite type declaration (MongoDB)",
      "kind": "class"
    },
    {
      "interface": "View",
      "implementationKeyword": "view",
      "pattern": "view\\s+(\\w+)\\s*\\{",
      "captureGroup": 1,
      "description": "Database view declaration",
      "kind": "class"
    }
  ],
  "keywords": {
    "interface": ["model", "enum", "type", "view"],
    "implementation": ["model", "enum", "type", "view"]
  }
}