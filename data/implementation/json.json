{
  "language": "json",
  "implementationPatterns": [
    {
      "pattern": "\"(\\w+)\"\\s*:",
      "captureGroup": 1,
      "type": "property",
      "description": "JSON property implementation"
    },
    {
      "pattern": "\"\\$ref\"\\s*:\\s*\"([^\"]+)\"",
      "captureGroup": 1,
      "type": "reference",
      "description": "JSON Schema reference implementation"
    },
    {
      "pattern": "\"type\"\\s*:\\s*\"(\\w+)\"",
      "captureGroup": 1,
      "type": "type",
      "description": "JSON Schema type implementation"
    }
  ],
  "keywords": {
    "note": "JSON is a data serialization format with no interface/implementation constructs."
  }
}