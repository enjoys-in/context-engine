{
  "language": "json",
  "implementationPatterns": [
    {
      "pattern": "\"(\\w+)\"\\s*:",
      "captureGroup": 1,
      "type": "property",
      "description": "JSON property implementation"
    },
    {
      "pattern": "\"\\$ref\"\\s*:\\s*\"([^\"]+)\"",
      "captureGroup": 1,
      "type": "reference",
      "description": "JSON Schema reference implementation"
    },
    {
      "pattern": "\"type\"\\s*:\\s*\"(\\w+)\"",
      "captureGroup": 1,
      "type": "type",
      "description": "JSON Schema type implementation"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "note": "JSON is a data serialization format with no interface/implementation constructs."
  }
}
