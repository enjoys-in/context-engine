{
  "language": "toml",
  "implementationPatterns": [
    {
      "pattern": "^\\[([^\\]]+)\\]",
      "captureGroup": 1,
      "type": "table",
      "description": "TOML table implementation"
    },
    {
      "pattern": "^\\[\\[([^\\]]+)\\]\\]",
      "captureGroup": 1,
      "type": "array_table",
      "description": "TOML array of tables implementation"
    },
    {
      "pattern": "^(\\w[\\w.-]*)\\s*=",
      "captureGroup": 1,
      "type": "property",
      "description": "TOML key-value implementation"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "note": "TOML is a configuration file format with no interface/implementation constructs."
  }
}
