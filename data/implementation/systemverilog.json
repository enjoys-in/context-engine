{
  "language": "systemverilog",
  "implementationPatterns": [
    {
      "interface": "InterfaceDecl",
      "pattern": "interface\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Interface declaration",
      "kind": "interface"
    },
    {
      "interface": "ClassExtends",
      "pattern": "class\\s+(\\w+)\\s+extends\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class inheritance",
      "kind": "class"
    },
    {
      "interface": "ClassImpl",
      "pattern": "class\\s+(\\w+)\\s+implements\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "interface": "VirtualMethod",
      "pattern": "virtual\\s+(?:function|task)\\s+\\w+\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Virtual method",
      "kind": "virtual"
    },
    {
      "interface": "ModuleInst",
      "pattern": "(\\w+)\\s+(\\w+)\\s*\\(",
      "captureGroup": 2,
      "description": "Module instantiation",
      "kind": "instance"
    }
  ],
  "keywords": {
    "interface": [
      "interface",
      "virtual",
      "extends",
      "implements"
    ],
    "implementation": [
      "class",
      "module",
      "extends",
      "implements",
      "virtual"
    ]
  }
}
