{
  "language": "systemverilog",
  "implementationPatterns": [
    {
      "interface": "ClassExtends",
      "implementationKeyword": "extends",
      "pattern": "class\\s+(\\w+)\\s+extends\\s+(\\w+)",
      "description": "Class extending base class"
    },
    {
      "interface": "InterfaceDecl",
      "implementationKeyword": "interface",
      "pattern": "interface\\s+(\\w+)",
      "description": "Interface declaration"
    },
    {
      "interface": "ClassImplements",
      "implementationKeyword": "implements",
      "pattern": "class\\s+(\\w+)\\s+implements\\s+([\\w,\\s]+)",
      "description": "Class implementing interface(s)"
    },
    {
      "interface": "VirtualMethod",
      "implementationKeyword": "virtual",
      "pattern": "virtual\\s+(?:function|task)\\s+(?:\\w+\\s+)?(\\w+)",
      "description": "Virtual method (overridable)"
    },
    {
      "interface": "ModuleDef",
      "implementationKeyword": "module",
      "pattern": "module\\s+(\\w+)",
      "description": "Module implementation"
    }
  ],
  "keywords": {
    "interface": [
      "interface",
      "virtual class",
      "pure virtual"
    ],
    "implementation": [
      "class...extends",
      "class...implements",
      "module",
      "override"
    ]
  }
}
