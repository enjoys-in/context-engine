{
  "language": "redshift",
  "implementationPatterns": [
    {
      "interface": "View",
      "implementationKeyword": "CREATE VIEW",
      "pattern": "CREATE\\s+(?:OR\\s+REPLACE\\s+)?(?:MATERIALIZED\\s+)?VIEW\\s+(\\w+)",
      "description": "View definition"
    },
    {
      "interface": "Procedure",
      "implementationKeyword": "CREATE PROCEDURE",
      "pattern": "CREATE\\s+(?:OR\\s+REPLACE\\s+)?PROCEDURE\\s+(\\w+)",
      "description": "Stored procedure"
    },
    {
      "interface": "Function",
      "implementationKeyword": "CREATE FUNCTION",
      "pattern": "CREATE\\s+(?:OR\\s+REPLACE\\s+)?FUNCTION\\s+(\\w+)",
      "description": "User-defined function"
    },
    {
      "interface": "Table",
      "implementationKeyword": "CREATE TABLE",
      "pattern": "CREATE\\s+(?:EXTERNAL\\s+)?TABLE\\s+(?:IF\\s+NOT\\s+EXISTS\\s+)?(\\w+)",
      "description": "Table definition"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "TABLE schema",
      "VIEW",
      "FUNCTION signature"
    ],
    "implementation": [
      "CREATE VIEW",
      "CREATE PROCEDURE",
      "CREATE FUNCTION",
      "CREATE TABLE"
    ]
  }
}
