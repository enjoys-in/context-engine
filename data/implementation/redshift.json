{
  "language": "redshift",
  "implementationPatterns": [
    {
      "interface": "View",
      "implementationKeyword": "CREATE VIEW",
      "pattern": "CREATE\\s+(?:OR\\s+REPLACE\\s+)?(?:MATERIALIZED\\s+)?VIEW\\s+(\\w+)",
      "description": "View definition"
    },
    {
      "interface": "Procedure",
      "implementationKeyword": "CREATE PROCEDURE",
      "pattern": "CREATE\\s+(?:OR\\s+REPLACE\\s+)?PROCEDURE\\s+(\\w+)",
      "description": "Stored procedure"
    },
    {
      "interface": "Function",
      "implementationKeyword": "CREATE FUNCTION",
      "pattern": "CREATE\\s+(?:OR\\s+REPLACE\\s+)?FUNCTION\\s+(\\w+)",
      "description": "User-defined function"
    },
    {
      "interface": "Table",
      "implementationKeyword": "CREATE TABLE",
      "pattern": "CREATE\\s+(?:EXTERNAL\\s+)?TABLE\\s+(?:IF\\s+NOT\\s+EXISTS\\s+)?(\\w+)",
      "description": "Table definition"
    }
  ],
  "keywords": {
    "interface": [
      "TABLE schema",
      "VIEW",
      "FUNCTION signature"
    ],
    "implementation": [
      "CREATE VIEW",
      "CREATE PROCEDURE",
      "CREATE FUNCTION",
      "CREATE TABLE"
    ]
  }
}
