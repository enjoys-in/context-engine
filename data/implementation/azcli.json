{
  "language": "azcli",
  "implementationPatterns": [
    {
      "pattern": "az\\s+(\\w[\\w-]*)",
      "captureGroup": 1,
      "type": "command",
      "description": "Azure CLI command group implementation"
    },
    {
      "pattern": "--([\\w-]+)",
      "captureGroup": 1,
      "type": "parameter",
      "description": "CLI parameter implementation"
    },
    {
      "pattern": "az\\s+\\w[\\w-]*\\s+(\\w[\\w-]*)",
      "captureGroup": 1,
      "type": "subcommand",
      "description": "Azure CLI subcommand implementation"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "note": "Azure CLI is a command-line tool language with no interface/implementation constructs."
  }
}
