{
  "language": "react",
  "implementationPatterns": [
    {
      "interface": "ClassDeclaration",
      "implementationKeyword": "class",
      "pattern": "class\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class declaration",
      "kind": "class"
    },
    {
      "interface": "ClassExtends",
      "implementationKeyword": "extends",
      "pattern": "class\\s+(\\w+)\\s+extends\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class extending another class",
      "kind": "class"
    },
    {
      "interface": "PrototypeAssignment",
      "pattern": "(\\w+)\\.prototype\\.(\\w+)\\s*=\\s*function",
      "captureGroup": 2,
      "description": "Prototype method assignment",
      "kind": "method"
    },
    {
      "interface": "PrototypeChain",
      "pattern": "(\\w+)\\.prototype\\s*=\\s*Object\\.create\\((\\w+)\\.prototype\\)",
      "captureGroup": 1,
      "description": "Prototype chain inheritance",
      "kind": "class"
    },
    {
      "interface": "ObjectCreate",
      "pattern": "Object\\.create\\((\\w+)(?:\\.prototype)?\\)",
      "captureGroup": 1,
      "description": "Object.create inheritance",
      "kind": "class"
    },
    {
      "interface": "MixinPattern",
      "pattern": "Object\\.assign\\((\\w+)\\.prototype,\\s*(\\w+)\\)",
      "captureGroup": 1,
      "description": "Mixin via Object.assign",
      "kind": "mixin"
    },
    {
      "interface": "FactoryFunction",
      "pattern": "function\\s+(create|make|build)\\w*\\s*\\(",
      "description": "Factory function pattern",
      "kind": "factory"
    },
    {
      "interface": "GetterSetter",
      "pattern": "(get|set)\\s+(\\w+)\\s*\\(",
      "captureGroup": 2,
      "description": "Getter/setter implementation",
      "kind": "accessor"
    },
    {
      "interface": "SymbolIterator",
      "pattern": "\\[Symbol\\.(iterator|asyncIterator)\\]\\s*\\(",
      "description": "Symbol.iterator implementation",
      "kind": "protocol"
    },
    {
      "interface": "SymbolToPrimitive",
      "pattern": "\\[Symbol\\.toPrimitive\\]\\s*\\(",
      "description": "Symbol.toPrimitive implementation",
      "kind": "protocol"
    },
    {
      "interface": "ProxyHandler",
      "pattern": "new\\s+Proxy\\s*\\([^,]+,\\s*\\{",
      "description": "Proxy handler implementation",
      "kind": "handler"
    },
    {
      "interface": "EventHandler",
      "pattern": "(?:addEventListener|on\\w+)\\s*[=(].*(?:function|=>)",
      "description": "Event handler implementation",
      "kind": "handler"
    },
    {
      "interface": "PromiseExecutor",
      "pattern": "new\\s+Promise\\s*\\(\\s*(?:function|\\()",
      "description": "Promise executor implementation",
      "kind": "callback"
    },
    {
      "interface": "CallbackImpl",
      "pattern": "\\w+\\s*\\(\\s*(?:function|\\([^)]*\\)\\s*=>)",
      "description": "Callback implementation",
      "kind": "callback"
    },
    {
      "interface": "ModuleExport",
      "implementationKeyword": "export",
      "pattern": "export\\s+(default\\s+)?(?:class|function|const|let|var)\\s+(\\w+)",
      "captureGroup": 2,
      "description": "Module export",
      "kind": "module"
    },
    {
      "interface": "StaticMethod",
      "pattern": "static\\s+(\\w+)\\s*\\(",
      "captureGroup": 1,
      "description": "Static method implementation",
      "kind": "method"
    },
    {
      "interface": "AsyncGenerator",
      "pattern": "async\\s*\\*\\s*(\\w+)\\s*\\(",
      "captureGroup": 1,
      "description": "Async generator implementation",
      "kind": "generator"
    },
    {
      "interface": "ComputedProperty",
      "pattern": "\\[(\\w+)\\]\\s*\\(",
      "captureGroup": 1,
      "description": "Computed property method",
      "kind": "method"
    },
    {
      "interface": "FunctionComponent",
      "pattern": "(?:const|function)\\s+(\\w+)\\s*[:=]\\s*(?:React\\.FC|FC|\\([^)]*\\)\\s*(?:=>|:))",
      "captureGroup": 1,
      "description": "React function component",
      "kind": "component"
    },
    {
      "interface": "CustomHook",
      "pattern": "(?:function|const)\\s+(use\\w+)\\s*[=(]",
      "captureGroup": 1,
      "description": "Custom React hook",
      "kind": "hook"
    },
    {
      "interface": "ForwardRef",
      "pattern": "React\\.forwardRef\\s*(?:<[^>]+>)?\\s*\\(",
      "description": "ForwardRef component",
      "kind": "component"
    },
    {
      "interface": "ContextProvider",
      "pattern": "(?:const|let)\\s+(\\w+Context)\\s*=\\s*(?:React\\.)?createContext",
      "captureGroup": 1,
      "description": "React context",
      "kind": "context"
    },
    {
      "interface": "HOC",
      "pattern": "(?:function|const)\\s+(with\\w+)\\s*[=(]",
      "captureGroup": 1,
      "description": "Higher-order component",
      "kind": "hoc"
    },
    {
      "interface": "MemoComponent",
      "pattern": "React\\.memo\\s*\\(\\s*(\\w+)",
      "captureGroup": 1,
      "description": "Memoized component",
      "kind": "component"
    }
  ],
  "keywords": {
    "interface": [
      "class",
      "extends",
      "prototype",
      "Symbol.iterator",
      "Symbol.asyncIterator",
      "Symbol.toPrimitive",
      "Proxy"
    ],
    "implementation": [
      "class",
      "extends",
      "Object.create",
      "Object.assign",
      "prototype",
      "new",
      "export"
    ]
  }
}
