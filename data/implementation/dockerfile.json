{
  "language": "dockerfile",
  "implementationPatterns": [
    {
      "interface": "Stage",
      "implementationKeyword": "FROM",
      "pattern": "FROM\\s+\\S+\\s+(?:AS|as)\\s+(\\w+)",
      "description": "Named build stage (multi-stage build)"
    },
    {
      "interface": "BaseImage",
      "implementationKeyword": "FROM",
      "pattern": "FROM\\s+(\\S+)",
      "description": "Base image selection"
    },
    {
      "interface": "Entrypoint",
      "implementationKeyword": "ENTRYPOINT",
      "pattern": "ENTRYPOINT\\s+(?:\\[|\")",
      "description": "Container entrypoint implementation"
    },
    {
      "interface": "Command",
      "implementationKeyword": "CMD",
      "pattern": "CMD\\s+(?:\\[|\")",
      "description": "Default command implementation"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "FROM (base image)",
      "ARG"
    ],
    "implementation": [
      "FROM...AS",
      "ENTRYPOINT",
      "CMD",
      "RUN",
      "COPY"
    ]
  }
}
