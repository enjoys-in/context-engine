{
  "language": "ruby",
  "implementationPatterns": [
    {
      "interface": "ClassInherit",
      "implementationKeyword": "<",
      "pattern": "class\\s+(\\w+)\\s*<\\s*(\\w+)",
      "captureGroup": 1,
      "description": "Class inheritance",
      "kind": "class"
    },
    {
      "interface": "ModuleInclude",
      "implementationKeyword": "include",
      "pattern": "include\\s+(\\w+(?:::\\w+)*)",
      "captureGroup": 1,
      "description": "Module inclusion (mixin)",
      "kind": "mixin"
    },
    {
      "interface": "ModulePrepend",
      "implementationKeyword": "prepend",
      "pattern": "prepend\\s+(\\w+(?:::\\w+)*)",
      "captureGroup": 1,
      "description": "Module prepend",
      "kind": "mixin"
    },
    {
      "interface": "ModuleExtend",
      "implementationKeyword": "extend",
      "pattern": "extend\\s+(\\w+(?:::\\w+)*)",
      "captureGroup": 1,
      "description": "Module extend (class-level mixin)",
      "kind": "mixin"
    },
    {
      "interface": "ModuleDef",
      "implementationKeyword": "module",
      "pattern": "module\\s+(\\w+(?:::\\w+)*)",
      "captureGroup": 1,
      "description": "Module definition",
      "kind": "module"
    },
    {
      "interface": "MethodMissing",
      "pattern": "def\\s+method_missing\\s*\\(",
      "description": "Dynamic method handling",
      "kind": "metaprogramming"
    },
    {
      "interface": "RespondTo",
      "pattern": "def\\s+respond_to_missing\\?\\s*\\(",
      "description": "Dynamic respond_to? support",
      "kind": "metaprogramming"
    },
    {
      "interface": "Comparable",
      "pattern": "def\\s+<=>\\s*\\(",
      "description": "Comparable#<=> implementation",
      "kind": "interface"
    },
    {
      "interface": "Enumerable",
      "pattern": "include\\s+Enumerable",
      "description": "Enumerable inclusion",
      "kind": "mixin"
    },
    {
      "interface": "Each",
      "pattern": "def\\s+each\\s*(?:\\(&?\\w+\\))?\\s*$",
      "description": "each method for Enumerable",
      "kind": "method"
    },
    {
      "interface": "Concern",
      "pattern": "extend\\s+ActiveSupport::Concern",
      "description": "Rails Concern pattern",
      "kind": "concern"
    },
    {
      "interface": "InstanceMethod",
      "pattern": "def\\s+(\\w+[?!=]?)\\s*(?:\\([^)]*\\))?\\s*$",
      "captureGroup": 1,
      "description": "Instance method definition",
      "kind": "method"
    },
    {
      "interface": "ClassMethod",
      "pattern": "def\\s+self\\.(\\w+[?!=]?)",
      "captureGroup": 1,
      "description": "Class method definition",
      "kind": "class_method"
    },
    {
      "interface": "DSL",
      "pattern": "class_eval|module_eval|define_method",
      "description": "Metaprogramming DSL patterns",
      "kind": "metaprogramming"
    },
    {
      "interface": "AttrAccessor",
      "pattern": "attr_(reader|writer|accessor)\\s+:(\\w+)",
      "captureGroup": 2,
      "description": "Attribute accessor",
      "kind": "accessor"
    }
  ],
  "keywords": {
    "interface": [
      "include",
      "extend",
      "prepend",
      "module",
      "class",
      "<"
    ],
    "implementation": [
      "class",
      "module",
      "include",
      "extend",
      "prepend",
      "def",
      "attr_reader",
      "attr_writer",
      "attr_accessor"
    ]
  }
}
