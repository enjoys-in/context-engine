{
  "language": "bicep",
  "implementationPatterns": [
    {
      "interface": "Resource",
      "implementationKeyword": "resource",
      "pattern": "resource\\s+(\\w+)\\s+'([\\w./@]+)'",
      "description": "Azure resource implementation"
    },
    {
      "interface": "Module",
      "implementationKeyword": "module",
      "pattern": "module\\s+(\\w+)\\s+'([^']+)'",
      "description": "Module instantiation"
    },
    {
      "interface": "Param",
      "implementationKeyword": "param",
      "pattern": "param\\s+(\\w+)\\s+\\w+",
      "description": "Parameter declaration"
    },
    {
      "interface": "Output",
      "implementationKeyword": "output",
      "pattern": "output\\s+(\\w+)\\s+\\w+",
      "description": "Output declaration"
    },
    {
      "interface": "TypeDecl",
      "implementationKeyword": "type",
      "pattern": "type\\s+(\\w+)\\s*=",
      "description": "Custom type definition"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "param",
      "output",
      "type"
    ],
    "implementation": [
      "resource",
      "module",
      "var",
      "existing"
    ]
  }
}
