{
  "language": "docker-compose",
  "implementationPatterns": [
    {
      "interface": "Service",
      "implementationKeyword": "services",
      "pattern": "services:\\s*\\n\\s+(\\w[\\w-]*):",
      "description": "Service definition block"
    },
    {
      "interface": "Volume",
      "implementationKeyword": "volumes",
      "pattern": "^volumes:\\s*\\n\\s+(\\w[\\w-]*):",
      "description": "Named volume definition"
    },
    {
      "interface": "Network",
      "implementationKeyword": "networks",
      "pattern": "^networks:\\s*\\n\\s+(\\w[\\w-]*):",
      "description": "Network definition"
    }
  ],
  "keywords": {
    "interface": [
      "services",
      "volumes",
      "networks"
    ],
    "implementation": [
      "image",
      "build",
      "depends_on",
      "ports",
      "environment"
    ]
  }
}
