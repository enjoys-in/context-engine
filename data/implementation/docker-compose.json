{
  "language": "docker-compose",
  "implementationPatterns": [
    {
      "interface": "Service",
      "implementationKeyword": "services",
      "pattern": "services:\\s*\\n\\s+(\\w[\\w-]*):",
      "description": "Service definition block"
    },
    {
      "interface": "Volume",
      "implementationKeyword": "volumes",
      "pattern": "^volumes:\\s*\\n\\s+(\\w[\\w-]*):",
      "description": "Named volume definition"
    },
    {
      "interface": "Network",
      "implementationKeyword": "networks",
      "pattern": "^networks:\\s*\\n\\s+(\\w[\\w-]*):",
      "description": "Network definition"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "services",
      "volumes",
      "networks"
    ],
    "implementation": [
      "image",
      "build",
      "depends_on",
      "ports",
      "environment"
    ]
  }
}
