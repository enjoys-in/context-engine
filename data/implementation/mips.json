{
  "language": "mips",
  "implementationPatterns": [
    {
      "interface": "Label",
      "implementationKeyword": ":",
      "pattern": "^(\\w+)\\s*:",
      "description": "Label definition (jump target / function entry)"
    },
    {
      "interface": "TextSection",
      "implementationKeyword": ".text",
      "pattern": "\\.text",
      "description": "Code section declaration"
    },
    {
      "interface": "GlobalDef",
      "implementationKeyword": ".globl",
      "pattern": "\\.globl\\s+(\\w+)",
      "description": "Global symbol export"
    }
  ],
  "keywords": {
    "interface": [
      ".globl",
      ".extern"
    ],
    "implementation": [
      "label:",
      ".text",
      "jal (call)"
    ]
  }
}
