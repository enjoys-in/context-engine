{
  "language": "c",
  "implementationPatterns": [
    {
      "interface": "FunctionDecl",
      "implementationKeyword": "definition",
      "pattern": "^\\w[\\w\\s\\*]+\\s+(\\w+)\\s*\\([^)]*\\)\\s*\\{",
      "description": "Function definition implementing a declared prototype"
    },
    {
      "interface": "FunctionPointerTable",
      "implementationKeyword": "struct",
      "pattern": "struct\\s+(\\w+)\\s*\\{[^}]*\\(\\s*\\*\\s*\\w+\\s*\\)",
      "description": "Struct containing function pointers (vtable pattern)"
    },
    {
      "interface": "Callback",
      "implementationKeyword": "typedef",
      "pattern": "typedef\\s+\\w+\\s*\\(\\s*\\*\\s*(\\w+)\\s*\\)",
      "description": "Callback typedef (interface-like)"
    },
    {
      "interface": "ExternDecl",
      "implementationKeyword": "extern",
      "pattern": "extern\\s+\\w+\\s+(\\w+)\\s*\\(",
      "description": "Extern function declarations (header interface)"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "typedef",
      "extern",
      "struct (with function pointers)"
    ],
    "implementation": [
      "function definition",
      "struct",
      "static"
    ]
  }
}
