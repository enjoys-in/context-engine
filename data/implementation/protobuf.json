{
  "language": "protobuf",
  "implementationPatterns": [
    {
      "interface": "Service",
      "implementationKeyword": "service",
      "pattern": "service\\s+(\\w+)\\s*\\{",
      "description": "gRPC service definition"
    },
    {
      "interface": "RPC",
      "implementationKeyword": "rpc",
      "pattern": "rpc\\s+(\\w+)\\s*\\(",
      "description": "RPC method definition within service"
    },
    {
      "interface": "Message",
      "implementationKeyword": "message",
      "pattern": "message\\s+(\\w+)\\s*\\{",
      "description": "Message type definition"
    },
    {
      "interface": "Enum",
      "implementationKeyword": "enum",
      "pattern": "enum\\s+(\\w+)\\s*\\{",
      "description": "Enum type definition"
    },
    {
      "interface": "Oneof",
      "implementationKeyword": "oneof",
      "pattern": "oneof\\s+(\\w+)\\s*\\{",
      "description": "Oneof field group"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "service",
      "message",
      "enum"
    ],
    "implementation": [
      "rpc",
      "message",
      "oneof",
      "extend"
    ]
  }
}
