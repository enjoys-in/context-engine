{
  "language": "protobuf",
  "implementationPatterns": [
    {
      "interface": "ServiceDef",
      "pattern": "service\\s+(\\w+)\\s*\\{",
      "captureGroup": 1,
      "description": "Service definition",
      "kind": "service"
    },
    {
      "interface": "MessageDef",
      "pattern": "message\\s+(\\w+)\\s*\\{",
      "captureGroup": 1,
      "description": "Message definition",
      "kind": "message"
    },
    {
      "interface": "RPCMethod",
      "pattern": "rpc\\s+(\\w+)\\s*\\(",
      "captureGroup": 1,
      "description": "RPC method",
      "kind": "rpc"
    },
    {
      "interface": "EnumDef",
      "pattern": "enum\\s+(\\w+)\\s*\\{",
      "captureGroup": 1,
      "description": "Enum definition",
      "kind": "enum"
    }
  ],
  "keywords": {
    "interface": [
      "service",
      "message",
      "rpc"
    ],
    "implementation": [
      "service",
      "message",
      "rpc",
      "enum"
    ]
  }
}
