{
  "language": "doctest",
  "implementationPatterns": [
    {
      "pattern": ">>>\\s+def\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function",
      "description": "Doctest function implementation"
    },
    {
      "pattern": ">>>\\s+class\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class",
      "description": "Doctest class implementation"
    },
    {
      "pattern": ">>>\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "variable",
      "description": "Doctest variable assignment"
    }
  ],
  "keywords": {
    "note": "Doctest is a testing format embedded in Python docstrings. It has no interface/implementation constructs."
  }
}