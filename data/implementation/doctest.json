{
  "language": "doctest",
  "implementationPatterns": [
    {
      "pattern": ">>>\\s+def\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function",
      "description": "Doctest function implementation"
    },
    {
      "pattern": ">>>\\s+class\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class",
      "description": "Doctest class implementation"
    },
    {
      "pattern": ">>>\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "variable",
      "description": "Doctest variable assignment"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "note": "Doctest is a testing format embedded in Python docstrings. It has no interface/implementation constructs."
  }
}
