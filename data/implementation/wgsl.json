{
  "language": "wgsl",
  "implementationPatterns": [
    {
      "interface": "StructDef",
      "pattern": "struct\\s+(\\w+)\\s*\\{",
      "captureGroup": 1,
      "description": "Struct definition",
      "kind": "struct"
    },
    {
      "interface": "EntryPoint",
      "pattern": "@(vertex|fragment|compute)\\s*fn\\s+(\\w+)",
      "captureGroup": 2,
      "description": "Shader entry point",
      "kind": "entrypoint"
    },
    {
      "interface": "FunctionDef",
      "pattern": "fn\\s+(\\w+)\\s*\\(",
      "captureGroup": 1,
      "description": "Function definition",
      "kind": "function"
    }
  ],
  "keywords": {
    "interface": [
      "struct",
      "@vertex",
      "@fragment",
      "@compute"
    ],
    "implementation": [
      "fn",
      "struct",
      "alias"
    ]
  }
}
