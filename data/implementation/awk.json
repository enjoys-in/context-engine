{
  "language": "awk",
  "implementationPatterns": [
    {
      "interface": "Function",
      "implementationKeyword": "function",
      "pattern": "function\\s+(\\w+)\\s*\\(",
      "description": "Function definitions"
    },
    {
      "interface": "Rule",
      "implementationKeyword": "pattern",
      "pattern": "^/[^/]+/\\s*\\{",
      "description": "Pattern-action rule blocks"
    },
    {
      "interface": "BEGIN",
      "implementationKeyword": "BEGIN",
      "pattern": "BEGIN\\s*\\{",
      "description": "BEGIN block implementation"
    },
    {
      "interface": "END",
      "implementationKeyword": "END",
      "pattern": "END\\s*\\{",
      "description": "END block implementation"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "function"
    ],
    "implementation": [
      "function",
      "BEGIN",
      "END"
    ]
  }
}
