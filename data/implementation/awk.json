{
  "language": "awk",
  "implementationPatterns": [
    {
      "interface": "Function",
      "implementationKeyword": "function",
      "pattern": "function\\s+(\\w+)\\s*\\(",
      "description": "Function definitions"
    },
    {
      "interface": "Rule",
      "implementationKeyword": "pattern",
      "pattern": "^/[^/]+/\\s*\\{",
      "description": "Pattern-action rule blocks"
    },
    {
      "interface": "BEGIN",
      "implementationKeyword": "BEGIN",
      "pattern": "BEGIN\\s*\\{",
      "description": "BEGIN block implementation"
    },
    {
      "interface": "END",
      "implementationKeyword": "END",
      "pattern": "END\\s*\\{",
      "description": "END block implementation"
    }
  ],
  "keywords": {
    "interface": [
      "function"
    ],
    "implementation": [
      "function",
      "BEGIN",
      "END"
    ]
  }
}
