{
  "language": "powerquery",
  "implementationPatterns": [
    {
      "interface": "LetBinding",
      "implementationKeyword": "let",
      "pattern": "let\\s+([\\w.]+)\\s*=",
      "description": "Let binding (step definition)"
    },
    {
      "interface": "SharedFunction",
      "implementationKeyword": "shared",
      "pattern": "shared\\s+(\\w+)\\s*=",
      "description": "Shared/exported function"
    },
    {
      "interface": "Section",
      "implementationKeyword": "section",
      "pattern": "section\\s+(\\w+)\\s*;",
      "description": "Section (module) declaration"
    },
    {
      "interface": "TypeDecl",
      "implementationKeyword": "type",
      "pattern": "type\\s+(\\w+)\\s*=\\s*type",
      "description": "Custom type definition"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "section",
      "type",
      "shared"
    ],
    "implementation": [
      "let...in",
      "shared",
      "each",
      "(x) => x"
    ]
  }
}
