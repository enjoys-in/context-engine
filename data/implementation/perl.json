{
  "language": "perl",
  "implementationPatterns": [
    {
      "interface": "Package",
      "implementationKeyword": "package",
      "pattern": "package\\s+([\\w:]+)",
      "description": "Package/class declaration"
    },
    {
      "interface": "ISA",
      "implementationKeyword": "@ISA",
      "pattern": "@ISA\\s*=\\s*(?:qw)?[\\s(]*([\\w:]+)",
      "description": "Inheritance via @ISA"
    },
    {
      "interface": "UseBase",
      "implementationKeyword": "use base",
      "pattern": "use\\s+(?:base|parent)\\s+(?:qw)?[\\s('\"]*([\\w:]+)",
      "description": "Inheritance via use base/parent"
    },
    {
      "interface": "MooseRole",
      "implementationKeyword": "with",
      "pattern": "with\\s+['\"]([\\w:]+)['\"]",
      "description": "Moose/Moo role consumption"
    },
    {
      "interface": "SubDef",
      "implementationKeyword": "sub",
      "pattern": "sub\\s+(\\w+)\\s*\\{",
      "description": "Subroutine/method implementation"
    },
    {
      "interface": "MooseHas",
      "implementationKeyword": "has",
      "pattern": "has\\s+['\"]?(\\w+)['\"]?\\s*=>",
      "description": "Moose attribute declaration"
    }
  ],
  "keywords": {
    "interface": [
      "package",
      "use base",
      "use parent",
      "with (role)",
      "@ISA"
    ],
    "implementation": [
      "sub",
      "has",
      "extends",
      "with",
      "use Moose",
      "use Moo"
    ]
  }
}
