{
  "language": "perl",
  "implementationPatterns": [
    {
      "interface": "PackageDecl",
      "pattern": "package\\s+([\\w:]+)",
      "captureGroup": 1,
      "description": "Package declaration",
      "kind": "class"
    },
    {
      "interface": "UseMoose",
      "pattern": "use\\s+(Moose|Moo|Mouse)(?:::\\w+)?",
      "captureGroup": 1,
      "description": "OOP framework usage",
      "kind": "framework"
    },
    {
      "interface": "ExtendsDecl",
      "pattern": "extends\\s+['\"]([\\w:]+)['\"]",
      "captureGroup": 1,
      "description": "Class extension (Moose)",
      "kind": "extends"
    },
    {
      "interface": "WithRole",
      "pattern": "with\\s+['\"]([\\w:]+)['\"]",
      "captureGroup": 1,
      "description": "Role composition (Moose)",
      "kind": "role"
    },
    {
      "interface": "BlessNew",
      "pattern": "sub\\s+new\\s*\\{.*bless",
      "description": "Constructor (bless)",
      "kind": "constructor"
    },
    {
      "interface": "ISA",
      "pattern": "@ISA\\s*=.*\\b(\\w+)\\b",
      "captureGroup": 1,
      "description": "@ISA inheritance",
      "kind": "class"
    }
  ],
  "keywords": {
    "interface": [
      "extends",
      "with",
      "@ISA",
      "bless"
    ],
    "implementation": [
      "package",
      "extends",
      "with",
      "bless",
      "sub new",
      "use base"
    ]
  }
}
