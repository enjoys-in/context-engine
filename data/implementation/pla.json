{
  "language": "pla",
  "implementationPatterns": [
    {
      "pattern": "(?:class|struct|type|interface|module)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Type/class declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:extends|implements|inherits|derives|:)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Inheritance/implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:override|virtual|abstract)\\s+(?:func|fun|def|fn|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "override"
    },
    {
      "pattern": "(?:def|fn|func|fun|function|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function/method definition",
      "kind": "function"
    }
  ],
  "keywords": {
    "interface": [
      "class",
      "interface",
      "abstract",
      "virtual",
      "extends",
      "implements"
    ],
    "implementation": [
      "class",
      "struct",
      "override",
      "implements",
      "extends",
      "def"
    ]
  }
}
