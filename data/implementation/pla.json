{
  "language": "pla",
  "implementationPatterns": [
    {
      "interface": "Input",
      "implementationKeyword": ".i",
      "pattern": "\\.i\\s+(\\d+)",
      "description": "Input declaration"
    },
    {
      "interface": "Output",
      "implementationKeyword": ".o",
      "pattern": "\\.o\\s+(\\d+)",
      "description": "Output declaration"
    },
    {
      "interface": "ProductTerm",
      "implementationKeyword": "term",
      "pattern": "^([01-]+)\\s+([01-]+)",
      "description": "Product term implementation"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      ".i (inputs)",
      ".o (outputs)",
      ".ilb",
      ".ob"
    ],
    "implementation": [
      "product terms",
      ".p",
      ".e"
    ]
  }
}
