{
  "language": "crontab",
  "implementationPatterns": [
    {
      "pattern": "^[\\d*,/-]+\\s+[\\d*,/-]+\\s+[\\d*,/-]+\\s+[\\d*,/-]+\\s+[\\d*,/-]+\\s+(\\S+)",
      "captureGroup": 1,
      "type": "command",
      "description": "Scheduled command implementation"
    },
    {
      "pattern": "^@(reboot|yearly|annually|monthly|weekly|daily|midnight|hourly)\\s+(\\S+)",
      "captureGroup": 2,
      "type": "command",
      "description": "Special schedule command implementation"
    },
    {
      "pattern": "^(MAILTO|PATH|SHELL|HOME|LOGNAME)=",
      "captureGroup": 1,
      "type": "variable",
      "description": "Crontab environment variable"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "note": "Crontab is a scheduling format with no interface/implementation constructs. Entries define time schedules and commands."
  }
}
