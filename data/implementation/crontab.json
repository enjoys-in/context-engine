{
  "language": "crontab",
  "implementationPatterns": [
    {
      "pattern": "^[\\d*,/-]+\\s+[\\d*,/-]+\\s+[\\d*,/-]+\\s+[\\d*,/-]+\\s+[\\d*,/-]+\\s+(\\S+)",
      "captureGroup": 1,
      "type": "command",
      "description": "Scheduled command implementation"
    },
    {
      "pattern": "^@(reboot|yearly|annually|monthly|weekly|daily|midnight|hourly)\\s+(\\S+)",
      "captureGroup": 2,
      "type": "command",
      "description": "Special schedule command implementation"
    },
    {
      "pattern": "^(MAILTO|PATH|SHELL|HOME|LOGNAME)=",
      "captureGroup": 1,
      "type": "variable",
      "description": "Crontab environment variable"
    }
  ],
  "keywords": {
    "note": "Crontab is a scheduling format with no interface/implementation constructs. Entries define time schedules and commands."
  }
}