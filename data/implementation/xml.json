{
  "language": "xml",
  "implementationPatterns": [
    {
      "pattern": "<(\\w[\\w:-]*)(?:\\s|>|/)",
      "captureGroup": 1,
      "type": "element",
      "description": "XML element implementation"
    },
    {
      "pattern": "(\\w[\\w:-]*)=[\"']",
      "captureGroup": 1,
      "type": "attribute",
      "description": "XML attribute implementation"
    },
    {
      "pattern": "xmlns(?::(\\w+))?=[\"']([^\"']+)[\"']",
      "captureGroup": 2,
      "type": "namespace",
      "description": "XML namespace implementation"
    },
    {
      "pattern": "<!DOCTYPE\\s+(\\w+)",
      "captureGroup": 1,
      "type": "doctype",
      "description": "XML DOCTYPE implementation"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "note": "XML is a markup/data format with no interface/implementation constructs."
  }
}
