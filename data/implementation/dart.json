{
  "language": "dart",
  "implementationPatterns": [
    {
      "interface": "Interface",
      "implementationKeyword": "implements",
      "pattern": "class\\s+(\\w+)\\s*(?:<[^>]*>)?\\s*(?:extends\\s+\\w+\\s*)?implements\\s+\\w+",
      "description": "Classes implementing interfaces"
    },
    {
      "interface": "AbstractClass",
      "implementationKeyword": "extends",
      "pattern": "class\\s+(\\w+)\\s*(?:<[^>]*>)?\\s*extends\\s+\\w+",
      "description": "Classes extending abstract classes"
    },
    {
      "interface": "Mixin",
      "implementationKeyword": "with",
      "pattern": "class\\s+(\\w+)\\s*(?:<[^>]*>)?\\s*(?:extends\\s+\\w+\\s*)?with\\s+\\w+",
      "description": "Classes applying mixins with 'with' keyword"
    },
    {
      "interface": "SealedClass",
      "implementationKeyword": "extends",
      "pattern": "(?:class|sealed\\s+class)\\s+(\\w+)\\s*(?:<[^>]*>)?\\s*extends\\s+\\w+",
      "description": "Sealed class subtypes"
    },
    {
      "interface": "MixinOn",
      "implementationKeyword": "on",
      "pattern": "mixin\\s+(\\w+)\\s+on\\s+\\w+",
      "description": "Mixin with superclass constraint"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "abstract class",
      "sealed class",
      "interface class",
      "mixin",
      "mixin class"
    ],
    "implementation": [
      "class",
      "enum",
      "extension type",
      "mixin class"
    ]
  }
}
