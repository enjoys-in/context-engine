{
  "language": "dart",
  "implementationPatterns": [
    {
      "interface": "ClassImpl",
      "implementationKeyword": "implements",
      "pattern": "class\\s+(\\w+)(?:<[^>]+>)?(?:\\s+extends\\s+\\w+)?\\s+implements\\s+([\\w,\\s<>]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "interface": "ClassExtends",
      "implementationKeyword": "extends",
      "pattern": "class\\s+(\\w+)(?:<[^>]+>)?\\s+extends\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class extension",
      "kind": "class"
    },
    {
      "interface": "MixinWith",
      "implementationKeyword": "with",
      "pattern": "class\\s+(\\w+).*with\\s+([\\w,\\s<>]+)",
      "captureGroup": 1,
      "description": "Mixin usage",
      "kind": "mixin"
    },
    {
      "interface": "MixinDecl",
      "implementationKeyword": "mixin",
      "pattern": "mixin\\s+(\\w+)(?:\\s+on\\s+\\w+)?",
      "captureGroup": 1,
      "description": "Mixin declaration",
      "kind": "mixin"
    },
    {
      "interface": "AbstractClass",
      "implementationKeyword": "abstract",
      "pattern": "abstract\\s+class\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract class",
      "kind": "abstract"
    },
    {
      "interface": "OverrideMethod",
      "implementationKeyword": "@override",
      "pattern": "@override\\s*\\n\\s*\\w+\\s+(\\w+)\\s*\\(",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "override"
    },
    {
      "interface": "ExtensionDecl",
      "implementationKeyword": "extension",
      "pattern": "extension\\s+(\\w+)\\s+on\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Extension declaration",
      "kind": "extension"
    },
    {
      "interface": "FactoryConstructor",
      "implementationKeyword": "factory",
      "pattern": "factory\\s+(\\w+)(?:\\.(\\w+))?\\s*\\(",
      "captureGroup": 1,
      "description": "Factory constructor",
      "kind": "factory"
    },
    {
      "interface": "StateWidget",
      "pattern": "class\\s+(\\w+)\\s+extends\\s+State<(\\w+)>",
      "captureGroup": 1,
      "description": "Stateful Widget State",
      "kind": "widget"
    },
    {
      "interface": "StatelessWidget",
      "pattern": "class\\s+(\\w+)\\s+extends\\s+StatelessWidget",
      "captureGroup": 1,
      "description": "Stateless Widget",
      "kind": "widget"
    },
    {
      "interface": "StatefulWidget",
      "pattern": "class\\s+(\\w+)\\s+extends\\s+StatefulWidget",
      "captureGroup": 1,
      "description": "Stateful Widget",
      "kind": "widget"
    }
  ],
  "keywords": {
    "interface": [
      "abstract",
      "implements",
      "extends",
      "with",
      "mixin",
      "@override",
      "extension",
      "factory"
    ],
    "implementation": [
      "class",
      "mixin",
      "extends",
      "implements",
      "with",
      "override",
      "extension",
      "factory"
    ]
  }
}
