{
  "language": "tcl",
  "implementationPatterns": [
    {
      "interface": "Proc",
      "implementationKeyword": "proc",
      "pattern": "proc\\s+(\\w+)\\s+\\{",
      "description": "Procedure definition"
    },
    {
      "interface": "OOClass",
      "implementationKeyword": "oo::class",
      "pattern": "oo::class\\s+create\\s+(\\w+)",
      "description": "TclOO class definition"
    },
    {
      "interface": "Method",
      "implementationKeyword": "method",
      "pattern": "method\\s+(\\w+)\\s+\\{",
      "description": "Class method implementation"
    },
    {
      "interface": "Superclass",
      "implementationKeyword": "superclass",
      "pattern": "superclass\\s+(\\w+)",
      "description": "Superclass specification (inheritance)"
    },
    {
      "interface": "Mixin",
      "implementationKeyword": "mixin",
      "pattern": "mixin\\s+(\\w+)",
      "description": "Mixin class application"
    },
    {
      "interface": "IncrTcl",
      "implementationKeyword": "itcl::class",
      "pattern": "itcl::class\\s+(\\w+)",
      "description": "[incr Tcl] class definition"
    },
    {
      "pattern": "(?:implements|extends|:)\\s+([\\w.]+)",
      "captureGroup": 1,
      "description": "Interface implementation",
      "kind": "interface"
    },
    {
      "pattern": "(?:@Override|@override|override)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Method override",
      "kind": "method"
    },
    {
      "pattern": "(?:abstract|virtual|deferred)\\s+(?:fun|func|def|method|function)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Abstract method implementation",
      "kind": "abstract"
    },
    {
      "pattern": "(?:use|include|with|mixin|trait)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Trait/mixin usage",
      "kind": "trait"
    },
    {
      "pattern": "(?:on|handle|listener|callback|subscribe)\\w*\\s*[=(]",
      "description": "Event handler implementation",
      "kind": "handler"
    }
  ],
  "keywords": {
    "interface": [
      "oo::class",
      "itcl::class",
      "superclass",
      "interface"
    ],
    "implementation": [
      "proc",
      "method",
      "oo::class create",
      "mixin",
      "superclass"
    ]
  }
}
