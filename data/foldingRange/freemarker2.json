{
  "language": "freemarker2",
  "offSide": false,
  "markers": {
    "start": "^\\s*<#--\\s*#region\\b",
    "end": "^\\s*<#--\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "<#if\\b",
      "endPattern": "</#if>",
      "description": "FreeMarker if/endif directive blocks"
    },
    {
      "kind": "region",
      "startPattern": "<#list\\b",
      "endPattern": "</#list>",
      "description": "FreeMarker list/endlist directive blocks"
    },
    {
      "kind": "region",
      "startPattern": "<#macro\\b",
      "endPattern": "</#macro>",
      "description": "FreeMarker macro/endmacro directive blocks"
    },
    {
      "kind": "region",
      "startPattern": "<#function\\b",
      "endPattern": "</#function>",
      "description": "FreeMarker function/endfunction directive blocks"
    }
  ]
}