{
  "language": "freemarker2",
  "offSide": false,
  "markers": {
    "start": "^\\s*<#--\\s*#region\\b",
    "end": "^\\s*<#--\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "<#if\\b",
      "endPattern": "</#if>",
      "description": "FreeMarker if/endif directive blocks"
    },
    {
      "kind": "region",
      "startPattern": "<#list\\b",
      "endPattern": "</#list>",
      "description": "FreeMarker list/endlist directive blocks"
    },
    {
      "kind": "region",
      "startPattern": "<#macro\\b",
      "endPattern": "</#macro>",
      "description": "FreeMarker macro/endmacro directive blocks"
    },
    {
      "kind": "region",
      "startPattern": "<#function\\b",
      "endPattern": "</#function>",
      "description": "FreeMarker function/endfunction directive blocks"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "region",
      "description": "Tag-based folding",
      "startPattern": "<[^/][^>]*[^/]>",
      "endPattern": "</[^>]+>"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
