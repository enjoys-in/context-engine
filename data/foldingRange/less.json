{
  "language": "less",
  "offSide": false,
  "markers": {
    "start": "^\\s*//\\s*#region\\b",
    "end": "^\\s*//\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Curly brace blocks (selectors, rules)"
    },
    {
      "kind": "comment",
      "startPattern": "/\\*",
      "endPattern": "\\*/",
      "description": "Multi-line comments"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*\\.\\w[\\w-]*\\s*\\(",
      "endPattern": "^\\s*\\}",
      "description": "Mixin definitions"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*[.#&@\\w][^{]*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Selector blocks"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
