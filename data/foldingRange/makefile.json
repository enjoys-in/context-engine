{
  "language": "makefile",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*#region\\b",
    "end": "^\\s*#\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "^define\\b",
      "endPattern": "^endef\\b",
      "description": "Multi-line define/endef variable blocks"
    },
    {
      "kind": "region",
      "startPattern": "^[a-zA-Z_.%$][^:=]*:\\s*",
      "endPattern": "(?=^\\S|\\z)",
      "description": "Target recipe blocks (tab-indented lines)"
    },
    {
      "kind": "region",
      "startPattern": "^if(n?def|n?eq)\\b",
      "endPattern": "^endif\\b",
      "description": "Conditional ifdef/ifndef/ifeq/ifneq blocks"
    }
  ]
}