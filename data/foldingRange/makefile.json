{
  "language": "makefile",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*#region\\b",
    "end": "^\\s*#\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "^define\\b",
      "endPattern": "^endef\\b",
      "description": "Multi-line define/endef variable blocks"
    },
    {
      "kind": "region",
      "startPattern": "^[a-zA-Z_.%$][^:=]*:\\s*",
      "endPattern": "(?=^\\S|\\z)",
      "description": "Target recipe blocks (tab-indented lines)"
    },
    {
      "kind": "region",
      "startPattern": "^if(n?def|n?eq)\\b",
      "endPattern": "^endif\\b",
      "description": "Conditional ifdef/ifndef/ifeq/ifneq blocks"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "region",
      "description": "Indentation-based folding",
      "indentBased": true
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
