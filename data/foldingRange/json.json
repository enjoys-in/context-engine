{
  "language": "json",
  "offSide": false,
  "markers": {
    "start": "^\\s*#region\\b",
    "end": "^\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Object blocks delimited by curly braces"
    },
    {
      "kind": "region",
      "startPattern": "\\[\\s*$",
      "endPattern": "^\\s*\\]",
      "description": "Array blocks delimited by square brackets"
    }
  ]
}