{
  "language": "twig",
  "offSide": false,
  "markers": {
    "start": "^\\s*\\{#\\s*#region\\b",
    "end": "^\\s*\\{#\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{%[-~]?\\s*block\\b",
      "endPattern": "\\{%[-~]?\\s*endblock\\b",
      "description": "Block/endblock blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\{%[-~]?\\s*if\\b",
      "endPattern": "\\{%[-~]?\\s*endif\\b",
      "description": "If/endif blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\{%[-~]?\\s*for\\b",
      "endPattern": "\\{%[-~]?\\s*endfor\\b",
      "description": "For/endfor loops"
    },
    {
      "kind": "region",
      "startPattern": "\\{%[-~]?\\s*macro\\b",
      "endPattern": "\\{%[-~]?\\s*endmacro\\b",
      "description": "Macro/endmacro blocks"
    }
  ]
}
