{
  "language": "dockerfile",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*region\\b",
    "end": "^\\s*#\\s*endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "^\\s*FROM\\b",
      "endPattern": "^(?=\\s*FROM\\b)|$",
      "description": "Multi-stage build FROM block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*RUN\\b.*\\\\\\s*$",
      "endPattern": "^[^\\\\]*$",
      "description": "Multi-line RUN command with line continuations"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*ENV\\b.*\\\\\\s*$",
      "endPattern": "^[^\\\\]*$",
      "description": "Multi-line ENV declaration"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*LABEL\\b.*\\\\\\s*$",
      "endPattern": "^[^\\\\]*$",
      "description": "Multi-line LABEL declaration"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*COPY\\b.*\\\\\\s*$",
      "endPattern": "^[^\\\\]*$",
      "description": "Multi-line COPY instruction"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*#(?!\\s*region\\b|\\s*endregion\\b)",
      "endPattern": "^(?!\\s*#)",
      "description": "Consecutive comment lines"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*HEALTHCHECK\\b",
      "endPattern": "^(?=\\s*[A-Z])",
      "description": "HEALTHCHECK instruction block"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
