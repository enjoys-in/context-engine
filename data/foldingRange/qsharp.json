{
  "language": "qsharp",
  "offSide": false,
  "markers": {
    "start": "^\\s*//\\s*#region\\b",
    "end": "^\\s*//\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Brace blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\boperation\\b.*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Operation blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bfunction\\b.*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Function blocks"
    }
  ]
}
