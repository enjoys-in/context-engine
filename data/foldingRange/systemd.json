{
  "language": "systemd",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*#region\\b",
    "end": "^\\s*#\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "^\\s*\\[Unit\\]",
      "endPattern": "^(?=\\s*\\[)",
      "description": "[Unit] section"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*\\[Service\\]",
      "endPattern": "^(?=\\s*\\[)",
      "description": "[Service] section"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*\\[Install\\]",
      "endPattern": "^(?=\\s*\\[)",
      "description": "[Install] section"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*\\[Timer\\]",
      "endPattern": "^(?=\\s*\\[)",
      "description": "[Timer] section"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*\\[Socket\\]",
      "endPattern": "^(?=\\s*\\[)",
      "description": "[Socket] section"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*\\[Mount\\]",
      "endPattern": "^(?=\\s*\\[)",
      "description": "[Mount] section"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
