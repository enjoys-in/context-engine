{
  "language": "yaml",
  "offSide": true,
  "markers": {
    "start": "^\\s*#\\s*#region\\b",
    "end": "^\\s*#\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "^\\s*\\S+:\\s*$",
      "endPattern": "^(?!\\s+\\S)",
      "description": "Mapping blocks (indent-based)"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*-\\s+\\S+:\\s*$",
      "endPattern": "^(?!\\s+-|\\s+\\S)",
      "description": "Sequence blocks (indent-based)"
    }
  ]
}
