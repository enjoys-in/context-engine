{
  "language": "yaml",
  "offSide": true,
  "markers": {
    "start": "^\\s*#\\s*#region\\b",
    "end": "^\\s*#\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "^\\s*\\S+:\\s*$",
      "endPattern": "^(?!\\s+\\S)",
      "description": "Mapping blocks (indent-based)"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*-\\s+\\S+:\\s*$",
      "endPattern": "^(?!\\s+-|\\s+\\S)",
      "description": "Sequence blocks (indent-based)"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "region",
      "description": "Indentation-based folding",
      "indentBased": true
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
