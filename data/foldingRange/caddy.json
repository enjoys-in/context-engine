{
  "language": "caddy",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*region\\b",
    "end": "^\\s*#\\s*endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Brace-delimited block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*\\S+\\s*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Server/site block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*(handle|handle_path|route|reverse_proxy|respond|redir|rewrite|php_fastcgi|file_server|encode|header|log|tls|basicauth|import)\\b.*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Directive block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*@\\w+\\s*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Named matcher block"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*#",
      "endPattern": "^(?!\\s*#)",
      "description": "Consecutive comment lines"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
