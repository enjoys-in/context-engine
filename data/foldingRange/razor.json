{
  "language": "razor",
  "offSide": false,
  "markers": {
    "start": "^\\s*@\\*\\s*#region\\b",
    "end": "^\\s*@\\*\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "@\\{",
      "endPattern": "^\\s*\\}",
      "description": "@{ } Razor code blocks"
    },
    {
      "kind": "region",
      "startPattern": "@if\\b.*\\{",
      "endPattern": "^\\s*\\}",
      "description": "@if blocks"
    },
    {
      "kind": "region",
      "startPattern": "@foreach\\b.*\\{",
      "endPattern": "^\\s*\\}",
      "description": "@foreach blocks"
    },
    {
      "kind": "region",
      "startPattern": "@section\\b.*\\{",
      "endPattern": "^\\s*\\}",
      "description": "@section blocks"
    },
    {
      "kind": "comment",
      "startPattern": "<!--",
      "endPattern": "-->",
      "description": "HTML comment blocks"
    }
  ]
}
