{
  "language": "protobuf",
  "offSide": false,
  "markers": {
    "start": "^\\s*//\\s*#region\\b",
    "end": "^\\s*//\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Brace blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bmessage\\b.*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Message blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bservice\\b.*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Service blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\benum\\b.*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Enum blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\boneof\\b.*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Oneof blocks"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
