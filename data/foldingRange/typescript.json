{
  "language": "typescript",
  "offSide": false,
  "markers": {
    "start": "^\\s*\\/\\/\\s*#region\\b",
    "end": "^\\s*\\/\\/\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Curly brace blocks"
    },
    {
      "kind": "comment",
      "startPattern": "\\/\\*",
      "endPattern": "\\*\\/",
      "description": "Block comments"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*\\/\\/\\s*#region\\b",
      "endPattern": "^\\s*\\/\\/\\s*#endregion\\b",
      "description": "Region markers"
    },
    {
      "kind": "region",
      "startPattern": "\\bclass\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Class definitions"
    },
    {
      "kind": "region",
      "startPattern": "\\bfunction\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Function definitions"
    },
    {
      "kind": "region",
      "startPattern": "\\bnamespace\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Namespace blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\binterface\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Interface definitions"
    },
    {
      "kind": "region",
      "startPattern": "\\benum\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Enum definitions"
    },
    {
      "kind": "imports",
      "startPattern": "^\\s*import\\b",
      "endPattern": "^(?!\\s*import\\b)",
      "description": "Import blocks"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
