{
  "language": "mdx",
  "offSide": false,
  "markers": {
    "start": "^\\s*\\{/\\*\\s*#region\\b",
    "end": "^\\s*\\{/\\*\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "^#{1,6}\\s+",
      "endPattern": "(?=^#{1,6}\\s|\\z)",
      "description": "Heading sections"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*```",
      "endPattern": "^\\s*```\\s*$",
      "description": "Fenced code blocks"
    },
    {
      "kind": "region",
      "startPattern": "<[A-Z]\\w*[^/>]*>",
      "endPattern": "</[A-Z]\\w*>",
      "description": "JSX component blocks"
    },
    {
      "kind": "imports",
      "startPattern": "^import\\s+",
      "endPattern": "(?=^\\s*$|^[^i])",
      "description": "Consecutive import statements"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "region",
      "description": "Tag-based folding",
      "startPattern": "<[^/][^>]*[^/]>",
      "endPattern": "</[^>]+>"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
