{
  "language": "wgsl",
  "offSide": false,
  "markers": {
    "start": "^\\s*\\/\\/\\s*#region\\b",
    "end": "^\\s*\\/\\/\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Curly brace blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bfn\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Function definitions"
    },
    {
      "kind": "region",
      "startPattern": "\\bstruct\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Struct definitions"
    },
    {
      "kind": "region",
      "startPattern": "@vertex\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "@vertex blocks"
    },
    {
      "kind": "region",
      "startPattern": "@fragment\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "@fragment blocks"
    },
    {
      "kind": "region",
      "startPattern": "@compute\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "@compute blocks"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
