{
  "language": "redis",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*region\\b",
    "end": "^\\s*#\\s*endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "^\\s*#\\s*region\\b",
      "endPattern": "^\\s*#\\s*endregion\\b",
      "description": "Comment-based region markers"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*#(?!\\s*(?:region|endregion)\\b).*$",
      "endPattern": "^\\s*[^#\\s]",
      "description": "Consecutive comment groups"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
