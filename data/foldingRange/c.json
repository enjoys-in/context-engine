{
  "language": "c",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*pragma\\s+region\\b|^\\s*//\\s*#region\\b",
    "end": "^\\s*#\\s*pragma\\s+endregion\\b|^\\s*//\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Brace-delimited block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*#\\s*if(n?def)?\\b",
      "endPattern": "^\\s*#\\s*endif\\b",
      "description": "Preprocessor conditional block (#if/#ifdef/#ifndef to #endif)"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*/\\*",
      "endPattern": "\\*/\\s*$",
      "description": "Multi-line comment block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*struct\\s+\\w+\\s*\\{",
      "endPattern": "^\\s*\\}\\s*;",
      "description": "Struct definition block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*enum\\s+\\w*\\s*\\{",
      "endPattern": "^\\s*\\}\\s*;",
      "description": "Enum definition block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*union\\s+\\w+\\s*\\{",
      "endPattern": "^\\s*\\}\\s*;",
      "description": "Union definition block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*switch\\s*\\(",
      "endPattern": "^\\s*\\}",
      "description": "Switch statement block"
    },
    {
      "kind": "imports",
      "startPattern": "^\\s*#\\s*include\\b",
      "endPattern": "^(?!\\s*#\\s*include\\b)",
      "description": "Consecutive #include directives"
    }
  ]
}
