{
  "language": "scala",
  "offSide": false,
  "markers": {
    "start": "^\\s*\\/\\/\\s*#region\\b",
    "end": "^\\s*\\/\\/\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Curly brace blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bclass\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Class definitions"
    },
    {
      "kind": "region",
      "startPattern": "\\bobject\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Object definitions"
    },
    {
      "kind": "region",
      "startPattern": "\\btrait\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Trait definitions"
    },
    {
      "kind": "region",
      "startPattern": "\\bdef\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Method definitions"
    },
    {
      "kind": "comment",
      "startPattern": "\\/\\*",
      "endPattern": "\\*\\/",
      "description": "Block comments"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*\\/\\/\\s*#region\\b",
      "endPattern": "^\\s*\\/\\/\\s*#endregion\\b",
      "description": "Region markers"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
