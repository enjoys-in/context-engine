{
  "language": "xml",
  "offSide": false,
  "markers": {
    "start": "^\\s*<!--\\s*#region\\b",
    "end": "^\\s*<!--\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "<([a-zA-Z][\\w.-]*)\\b[^/]*>",
      "endPattern": "</\\1>",
      "description": "XML tag pairs"
    },
    {
      "kind": "comment",
      "startPattern": "<!--",
      "endPattern": "-->",
      "description": "XML comments"
    },
    {
      "kind": "region",
      "startPattern": "<!\\[CDATA\\[",
      "endPattern": "\\]\\]>",
      "description": "CDATA sections"
    }
  ]
}
