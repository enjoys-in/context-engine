{
  "language": "xml",
  "offSide": false,
  "markers": {
    "start": "^\\s*<!--\\s*#region\\b",
    "end": "^\\s*<!--\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "<([a-zA-Z][\\w.-]*)\\b[^/]*>",
      "endPattern": "</\\1>",
      "description": "XML tag pairs"
    },
    {
      "kind": "comment",
      "startPattern": "<!--",
      "endPattern": "-->",
      "description": "XML comments"
    },
    {
      "kind": "region",
      "startPattern": "<!\\[CDATA\\[",
      "endPattern": "\\]\\]>",
      "description": "CDATA sections"
    },
    {
      "kind": "region",
      "description": "Tag-based folding",
      "startPattern": "<[^/][^>]*[^/]>",
      "endPattern": "</[^>]+>"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
