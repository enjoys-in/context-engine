{
  "language": "st",
  "offSide": false,
  "markers": {
    "start": "^\\s*\\(\\*\\s*#region\\b",
    "end": "^\\s*\\(\\*\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\bFUNCTION_BLOCK\\b",
      "endPattern": "\\bEND_FUNCTION_BLOCK\\b",
      "description": "FUNCTION_BLOCK/END_FUNCTION_BLOCK blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bPROGRAM\\b",
      "endPattern": "\\bEND_PROGRAM\\b",
      "description": "PROGRAM/END_PROGRAM blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bIF\\b",
      "endPattern": "\\bEND_IF\\b",
      "description": "IF/END_IF blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bCASE\\b",
      "endPattern": "\\bEND_CASE\\b",
      "description": "CASE/END_CASE blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bFOR\\b",
      "endPattern": "\\bEND_FOR\\b",
      "description": "FOR/END_FOR blocks"
    }
  ]
}
