{
  "language": "angular",
  "offSide": false,
  "markers": {
    "start": "// #region",
    "end": "// #endregion"
  },
  "foldingRules": [
    {
      "startPattern": "^import\\s",
      "endPattern": "^(?!import\\s|\\s*$)",
      "kind": "imports",
      "description": "Fold contiguous import statement blocks"
    },
    {
      "startPattern": "@Component\\s*\\(\\s*\\{",
      "endPattern": "^\\s*\\}\\s*\\)",
      "kind": "region",
      "description": "Fold @Component decorator metadata object"
    },
    {
      "startPattern": "@NgModule\\s*\\(\\s*\\{",
      "endPattern": "^\\s*\\}\\s*\\)",
      "kind": "region",
      "description": "Fold @NgModule decorator metadata object"
    },
    {
      "startPattern": "\\bclass\\s+\\w+[^{]*\\{",
      "endPattern": "^\\}",
      "kind": "region",
      "description": "Fold class body from opening to closing brace"
    },
    {
      "startPattern": "\\bconstructor\\s*\\([^)]*\\)\\s*\\{",
      "endPattern": "^\\s*\\}",
      "kind": "region",
      "description": "Fold constructor body"
    },
    {
      "startPattern": "\\b(ngOnInit|ngOnDestroy|ngOnChanges|ngAfterViewInit|ngAfterContentInit|ngDoCheck|ngAfterViewChecked|ngAfterContentChecked)\\s*\\(",
      "endPattern": "^\\s*\\}",
      "kind": "region",
      "description": "Fold Angular lifecycle hook method bodies"
    },
    {
      "startPattern": "\\b\\w+\\s*\\([^)]*\\)\\s*(:\\s*\\w[^{]*)?\\{",
      "endPattern": "^\\s*\\}",
      "kind": "region",
      "description": "Fold method body from opening to closing brace"
    },
    {
      "startPattern": "template\\s*:\\s*`",
      "endPattern": "`",
      "kind": "region",
      "description": "Fold inline template literal strings in component metadata"
    },
    {
      "startPattern": "styles\\s*:\\s*\\[",
      "endPattern": "\\]",
      "kind": "region",
      "description": "Fold styles array in component metadata"
    },
    {
      "startPattern": "\\b(Routes|Route)\\b[^=]*=\\s*\\[",
      "endPattern": "\\];",
      "kind": "region",
      "description": "Fold route configuration arrays"
    },
    {
      "startPattern": "\\bdescribe\\s*\\(.*\\{",
      "endPattern": "^\\s*\\}\\s*\\);",
      "kind": "region",
      "description": "Fold describe test suite blocks"
    },
    {
      "startPattern": "\\b(it|test)\\s*\\(.*\\{",
      "endPattern": "^\\s*\\}\\s*\\);",
      "kind": "region",
      "description": "Fold it/test blocks in unit tests"
    },
    {
      "startPattern": "\\binterface\\s+\\w+[^{]*\\{",
      "endPattern": "^\\s*\\}",
      "kind": "region",
      "description": "Fold interface body"
    },
    {
      "startPattern": "\\benum\\s+\\w+\\s*\\{",
      "endPattern": "^\\s*\\}",
      "kind": "region",
      "description": "Fold enum body"
    },
    {
      "startPattern": "\\bswitch\\s*\\([^)]*\\)\\s*\\{",
      "endPattern": "^\\s*\\}",
      "kind": "region",
      "description": "Fold switch statement block"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
