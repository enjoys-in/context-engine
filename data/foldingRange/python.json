{
  "language": "python",
  "offSide": true,
  "markers": {
    "start": "^\\s*#\\s*region\\b",
    "end": "^\\s*#\\s*endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "^\\s*class\\b.*:\\s*$",
      "endPattern": "",
      "description": "Class definitions (indent-based)"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*def\\b.*:\\s*$",
      "endPattern": "",
      "description": "Function/method definitions (indent-based)"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*if\\b.*:\\s*$|^\\s*elif\\b.*:\\s*$|^\\s*else\\s*:\\s*$",
      "endPattern": "",
      "description": "if/elif/else blocks (indent-based)"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*for\\b.*:\\s*$",
      "endPattern": "",
      "description": "for loops (indent-based)"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*while\\b.*:\\s*$",
      "endPattern": "",
      "description": "while loops (indent-based)"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*with\\b.*:\\s*$",
      "endPattern": "",
      "description": "with statements (indent-based)"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*try\\s*:\\s*$|^\\s*except\\b.*:\\s*$|^\\s*finally\\s*:\\s*$",
      "endPattern": "",
      "description": "try/except/finally blocks (indent-based)"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*#\\s*region\\b",
      "endPattern": "^\\s*#\\s*endregion\\b",
      "description": "#region/#endregion markers"
    },
    {
      "kind": "comment",
      "startPattern": "\"{3}|'{3}",
      "endPattern": "\"{3}|'{3}",
      "description": "Triple-quoted strings and docstrings"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "region",
      "description": "Indentation-based folding",
      "indentBased": true
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
