{
  "language": "bicep",
  "offSide": false,
  "markers": {
    "start": "^\\s*//\\s*#region\\b",
    "end": "^\\s*//\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Brace-delimited block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*resource\\b",
      "endPattern": "^\\s*\\}",
      "description": "Resource declaration block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*module\\b",
      "endPattern": "^\\s*\\}",
      "description": "Module declaration block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*param\\b.*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Parameter with decorator block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*var\\b.*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Variable object block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*output\\b.*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Output block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*if\\s*\\(",
      "endPattern": "^\\s*\\}",
      "description": "Conditional deployment block"
    },
    {
      "kind": "region",
      "startPattern": "\\[\\s*for\\b",
      "endPattern": "\\]",
      "description": "For loop expression block"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*/\\*",
      "endPattern": "\\*/\\s*$",
      "description": "Multi-line comment block"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*//",
      "endPattern": "^(?!\\s*//)",
      "description": "Consecutive single-line comments"
    }
  ]
}
