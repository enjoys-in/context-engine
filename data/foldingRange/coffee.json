{
  "language": "coffee",
  "offSide": true,
  "markers": {
    "start": "^\\s*#\\s*region\\b",
    "end": "^\\s*#\\s*endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "^\\s*class\\b",
      "endPattern": "^(?=\\S)",
      "description": "Class definition block (indent-based)"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*\\w+\\s*[:=]\\s*\\(.*\\)\\s*->",
      "endPattern": "^(?=\\S)",
      "description": "Function definition block (indent-based)"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*if\\b",
      "endPattern": "^(?=\\S|\\s*else\\b)",
      "description": "If conditional block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*else\\b",
      "endPattern": "^(?=\\S)",
      "description": "Else block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*for\\b",
      "endPattern": "^(?=\\S)",
      "description": "For loop block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*while\\b",
      "endPattern": "^(?=\\S)",
      "description": "While loop block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*switch\\b",
      "endPattern": "^(?=\\S)",
      "description": "Switch statement block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*try\\b",
      "endPattern": "^(?=\\S)",
      "description": "Try block"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*###",
      "endPattern": "^\\s*###",
      "description": "Block comment (### ... ###)"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*#(?!##)",
      "endPattern": "^(?!\\s*#)",
      "description": "Consecutive single-line comments"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*\\w+\\s*[:=]\\s*->",
      "endPattern": "^(?=\\S)",
      "description": "Arrow function block"
    },
    {
      "kind": "region",
      "description": "Indentation-based folding",
      "indentBased": true
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
