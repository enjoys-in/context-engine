{
  "language": "powershell",
  "offSide": false,
  "markers": {
    "start": "^\\s*#region\\b",
    "end": "^\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Brace blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bfunction\\b.*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Function blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*#region\\b",
      "endPattern": "^\\s*#endregion\\b",
      "description": "#region/#endregion markers"
    },
    {
      "kind": "comment",
      "startPattern": "<#",
      "endPattern": "#>",
      "description": "Block comments (<# #>)"
    },
    {
      "kind": "region",
      "startPattern": "\\bif\\b.*\\{|\\belseif\\b.*\\{|\\belse\\s*\\{",
      "endPattern": "^\\s*\\}",
      "description": "if/elseif/else blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bforeach\\b.*\\{",
      "endPattern": "^\\s*\\}",
      "description": "foreach blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bswitch\\b.*\\{",
      "endPattern": "^\\s*\\}",
      "description": "switch blocks"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
