{
  "language": "doctest",
  "offSide": false,
  "markers": {
    "start": "^\\s*//\\s*#region\\b",
    "end": "^\\s*//\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Brace-delimited block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*TEST_CASE\\s*\\(",
      "endPattern": "^\\s*\\}",
      "description": "TEST_CASE block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*SUBCASE\\s*\\(",
      "endPattern": "^\\s*\\}",
      "description": "SUBCASE block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*SECTION\\s*\\(",
      "endPattern": "^\\s*\\}",
      "description": "SECTION block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*TEST_SUITE\\s*\\(",
      "endPattern": "^\\s*\\}",
      "description": "TEST_SUITE block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*SCENARIO\\s*\\(",
      "endPattern": "^\\s*\\}",
      "description": "SCENARIO block"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*/\\*",
      "endPattern": "\\*/\\s*$",
      "description": "Multi-line comment block"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*//",
      "endPattern": "^(?!\\s*//)",
      "description": "Consecutive single-line comments"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
