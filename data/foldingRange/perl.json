{
  "language": "perl",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*region\\b",
    "end": "^\\s*#\\s*endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Brace blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bsub\\b.*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Subroutine blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bif\\b.*\\{|\\belsif\\b.*\\{|\\belse\\s*\\{",
      "endPattern": "^\\s*\\}",
      "description": "if/elsif/else blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bfor\\b.*\\{|\\bforeach\\b.*\\{",
      "endPattern": "^\\s*\\}",
      "description": "for/foreach blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bwhile\\b.*\\{",
      "endPattern": "^\\s*\\}",
      "description": "while blocks"
    },
    {
      "kind": "comment",
      "startPattern": "^=pod\\b",
      "endPattern": "^=cut\\b",
      "description": "POD documentation blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*#\\s*region\\b",
      "endPattern": "^\\s*#\\s*endregion\\b",
      "description": "#region/#endregion markers"
    }
  ]
}
