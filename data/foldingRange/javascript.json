{
  "language": "javascript",
  "offSide": false,
  "markers": {
    "start": "^\\s*//\\s*#region\\b",
    "end": "^\\s*//\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Curly brace blocks"
    },
    {
      "kind": "comment",
      "startPattern": "/\\*",
      "endPattern": "\\*/",
      "description": "Multi-line comments and JSDoc"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*//\\s*#region\\b",
      "endPattern": "^\\s*//\\s*#endregion\\b",
      "description": "Manual region markers"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*(export\\s+)?(default\\s+)?class\\s+",
      "endPattern": "^\\}",
      "description": "Class declarations"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*(export\\s+)?(default\\s+)?(async\\s+)?function\\b",
      "endPattern": "^\\}",
      "description": "Function declarations"
    },
    {
      "kind": "imports",
      "startPattern": "^import\\s+",
      "endPattern": "(?=^\\s*$|^[^i])",
      "description": "Consecutive import statements"
    }
  ]
}
