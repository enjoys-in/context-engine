{
  "language": "restructuredtext",
  "offSide": true,
  "markers": {
    "start": "^\\s*\\.\\.\\s*#region\\b",
    "end": "^\\s*\\.\\.\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "^\\.\\.\\s+\\w[\\w-]*::.*$",
      "endPattern": "",
      "description": "Directive blocks (indent-based)"
    },
    {
      "kind": "region",
      "startPattern": "^\\S.*$\\n^[=\\-~`'\"^_*+#]{2,}$",
      "endPattern": "",
      "description": "Section headers (indent-based)"
    }
  ]
}
