{
  "language": "restructuredtext",
  "offSide": true,
  "markers": {
    "start": "^\\s*\\.\\.\\s*#region\\b",
    "end": "^\\s*\\.\\.\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "^\\.\\.\\s+\\w[\\w-]*::.*$",
      "endPattern": "",
      "description": "Directive blocks (indent-based)"
    },
    {
      "kind": "region",
      "startPattern": "^\\S.*$\\n^[=\\-~`'\"^_*+#]{2,}$",
      "endPattern": "",
      "description": "Section headers (indent-based)"
    },
    {
      "kind": "region",
      "description": "Indentation-based folding",
      "indentBased": true
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
