{
  "language": "pgsql",
  "offSide": false,
  "markers": {
    "start": "^\\s*--\\s*#region\\b",
    "end": "^\\s*--\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\bBEGIN\\b",
      "endPattern": "\\bEND\\b",
      "description": "BEGIN/END blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\$\\$",
      "endPattern": "\\$\\$",
      "description": "Dollar-quoted string blocks ($$...$$)"
    },
    {
      "kind": "region",
      "startPattern": "\\bCREATE\\s+(OR\\s+REPLACE\\s+)?FUNCTION\\b",
      "endPattern": "\\$\\$\\s*;|\\bEND\\b",
      "description": "CREATE FUNCTION blocks"
    },
    {
      "kind": "comment",
      "startPattern": "/\\*",
      "endPattern": "\\*/",
      "description": "Multi-line comments"
    },
    {
      "kind": "region",
      "startPattern": "\\bDO\\s+\\$\\$",
      "endPattern": "\\$\\$\\s*;",
      "description": "DO anonymous code blocks"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
