{
  "language": "r",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*region\\b",
    "end": "^\\s*#\\s*endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Brace blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bfunction\\s*\\(.*\\)\\s*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Function blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bif\\s*\\(.*\\)\\s*\\{",
      "endPattern": "^\\s*\\}",
      "description": "if blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bfor\\s*\\(.*\\)\\s*\\{",
      "endPattern": "^\\s*\\}",
      "description": "for blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bwhile\\s*\\(.*\\)\\s*\\{",
      "endPattern": "^\\s*\\}",
      "description": "while blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*#\\s*region\\b",
      "endPattern": "^\\s*#\\s*endregion\\b",
      "description": "#region/#endregion markers"
    }
  ]
}
