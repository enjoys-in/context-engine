{
  "language": "clojure",
  "offSide": false,
  "markers": {
    "start": "^\\s*;+\\s*region\\b",
    "end": "^\\s*;+\\s*endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\(\\s*$|\\((?!.*\\)\\s*$)",
      "endPattern": "\\)\\s*$",
      "description": "Parenthesized expression block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*\\(\\s*defn\\b",
      "endPattern": "\\)\\s*$",
      "description": "Function definition (defn) block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*\\(\\s*def\\b",
      "endPattern": "\\)\\s*$",
      "description": "Var definition (def) block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*\\(\\s*let\\b",
      "endPattern": "\\)\\s*$",
      "description": "Let binding block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*\\(\\s*do\\b",
      "endPattern": "\\)\\s*$",
      "description": "Do block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*\\(\\s*cond\\b",
      "endPattern": "\\)\\s*$",
      "description": "Cond expression block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*\\(\\s*ns\\b",
      "endPattern": "\\)\\s*$",
      "description": "Namespace declaration block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*\\(\\s*defmacro\\b",
      "endPattern": "\\)\\s*$",
      "description": "Macro definition block"
    },
    {
      "kind": "region",
      "startPattern": "\\[",
      "endPattern": "\\]",
      "description": "Vector/binding block"
    },
    {
      "kind": "region",
      "startPattern": "\\{",
      "endPattern": "\\}",
      "description": "Map literal block"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*;",
      "endPattern": "^(?!\\s*;)",
      "description": "Consecutive comment lines"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
