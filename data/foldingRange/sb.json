{
  "language": "sb",
  "offSide": false,
  "markers": {
    "start": "^\\s*\\/\\/\\s*#region\\b",
    "end": "^\\s*\\/\\/\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\bSub\\b",
      "endPattern": "\\bEndSub\\b",
      "description": "Sub/EndSub blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bWhile\\b",
      "endPattern": "\\bEndWhile\\b",
      "description": "While/EndWhile loops"
    },
    {
      "kind": "region",
      "startPattern": "\\bFor\\b",
      "endPattern": "\\bEndFor\\b",
      "description": "For/EndFor loops"
    },
    {
      "kind": "region",
      "startPattern": "\\bIf\\b",
      "endPattern": "\\bEndIf\\b",
      "description": "If/EndIf conditionals"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "region",
      "description": "Begin/End block folding",
      "startPattern": "\\b(begin|do|then|loop)\\b",
      "endPattern": "\\b(end|done|fi|loop)\\b"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
