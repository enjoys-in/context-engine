{
  "language": "pascaligo",
  "offSide": false,
  "markers": {
    "start": "^\\s*//\\s*#region\\b",
    "end": "^\\s*//\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\bblock_with\\b",
      "endPattern": "\\bend\\b",
      "description": "block_with/end blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bbegin\\b",
      "endPattern": "\\bend\\b",
      "description": "begin/end blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bcase\\b",
      "endPattern": "\\bend\\b",
      "description": "case/end blocks"
    }
  ]
}
