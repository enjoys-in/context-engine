{
  "language": "markdown",
  "offSide": false,
  "markers": {
    "start": "^\\s*<!--\\s*#region\\b",
    "end": "^\\s*<!--\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "^#{1,6}\\s+",
      "endPattern": "(?=^#{1,6}\\s|\\z)",
      "description": "Heading sections (folds content under headings)"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*```",
      "endPattern": "^\\s*```\\s*$",
      "description": "Fenced code blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*>\\s+",
      "endPattern": "(?=^\\s*$|^[^>])",
      "description": "Blockquote sections"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*[-*+]\\s+|^\\s*\\d+\\.\\s+",
      "endPattern": "(?=^\\s*$(?!\\s*[-*+]|\\s*\\d+\\.))",
      "description": "List item groups"
    }
  ]
}