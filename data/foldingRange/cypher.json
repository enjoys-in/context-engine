{
  "language": "cypher",
  "offSide": false,
  "markers": {
    "start": "^\\s*//\\s*region\\b",
    "end": "^\\s*//\\s*endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Brace-delimited map/object block"
    },
    {
      "kind": "region",
      "startPattern": "\\bCASE\\b",
      "endPattern": "\\bEND\\b",
      "description": "CASE/END expression block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*(MATCH|OPTIONAL MATCH|CREATE|MERGE|WITH|RETURN|UNWIND|CALL)\\b",
      "endPattern": "^\\s*;|^\\s*$",
      "description": "Multi-line query clause block"
    },
    {
      "kind": "region",
      "startPattern": "\\[\\s*$",
      "endPattern": "^\\s*\\]",
      "description": "List literal block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*FOREACH\\s*\\(",
      "endPattern": "\\)\\s*$",
      "description": "FOREACH block"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*//",
      "endPattern": "^(?!\\s*//)",
      "description": "Consecutive single-line comments"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*/\\*",
      "endPattern": "\\*/\\s*$",
      "description": "Multi-line comment block"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
