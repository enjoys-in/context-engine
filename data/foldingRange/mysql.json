{
  "language": "mysql",
  "offSide": false,
  "markers": {
    "start": "^\\s*--\\s*#region\\b",
    "end": "^\\s*--\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\bBEGIN\\b",
      "endPattern": "\\bEND\\b",
      "description": "BEGIN/END blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bDELIMITER\\s+\\S+",
      "endPattern": "\\bDELIMITER\\s+;",
      "description": "DELIMITER blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bCREATE\\s+(DEFINER\\s*=\\s*\\S+\\s+)?PROCEDURE\\b",
      "endPattern": "\\bEND\\b",
      "description": "CREATE PROCEDURE blocks"
    },
    {
      "kind": "comment",
      "startPattern": "/\\*",
      "endPattern": "\\*/",
      "description": "Multi-line comments"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
