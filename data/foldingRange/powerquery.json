{
  "language": "powerquery",
  "offSide": false,
  "markers": {
    "start": "^\\s*//\\s*#region\\b",
    "end": "^\\s*//\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\blet\\b",
      "endPattern": "\\bin\\b",
      "description": "let/in blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\beach\\b",
      "endPattern": "(?=\\)|,|\\])",
      "description": "each expression blocks"
    },
    {
      "kind": "region",
      "startPattern": "#section\\b",
      "endPattern": "(?=#section|$)",
      "description": "#section blocks"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
