{
  "language": "go",
  "offSide": false,
  "markers": {
    "start": "^\\s*//\\s*#region\\b",
    "end": "^\\s*//\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Curly brace blocks"
    },
    {
      "kind": "comment",
      "startPattern": "/\\*",
      "endPattern": "\\*/",
      "description": "Multi-line comments"
    },
    {
      "kind": "imports",
      "startPattern": "^import\\s*\\(",
      "endPattern": "^\\)",
      "description": "Grouped import declarations"
    },
    {
      "kind": "region",
      "startPattern": "^func\\b",
      "endPattern": "^\\}",
      "description": "Function declarations"
    },
    {
      "kind": "region",
      "startPattern": "^type\\s+\\w+\\s+struct\\s*\\{",
      "endPattern": "^\\}",
      "description": "Struct type declarations"
    },
    {
      "kind": "region",
      "startPattern": "^type\\s+\\w+\\s+interface\\s*\\{",
      "endPattern": "^\\}",
      "description": "Interface type declarations"
    }
  ]
}