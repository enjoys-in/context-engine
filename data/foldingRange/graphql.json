{
  "language": "graphql",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*#region\\b",
    "end": "^\\s*#\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Curly brace blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*type\\s+\\w+",
      "endPattern": "^\\}",
      "description": "Type definitions"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*query\\s+\\w+",
      "endPattern": "^\\}",
      "description": "Query operations"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*mutation\\s+\\w+",
      "endPattern": "^\\}",
      "description": "Mutation operations"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*fragment\\s+\\w+",
      "endPattern": "^\\}",
      "description": "Fragment definitions"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
