{
  "language": "postiats",
  "offSide": false,
  "markers": {
    "start": "^\\s*//\\s*#region\\b",
    "end": "^\\s*//\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\bimplement\\b",
      "endPattern": "\\bend\\b",
      "description": "implement/end blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\blocal\\b",
      "endPattern": "\\bend\\b",
      "description": "local/in/end blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\blet\\b",
      "endPattern": "\\bend\\b",
      "description": "let/in/end blocks"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "region",
      "description": "Begin/End block folding",
      "startPattern": "\\b(begin|do|then|loop)\\b",
      "endPattern": "\\b(end|done|fi|loop)\\b"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
