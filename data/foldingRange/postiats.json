{
  "language": "postiats",
  "offSide": false,
  "markers": {
    "start": "^\\s*//\\s*#region\\b",
    "end": "^\\s*//\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\bimplement\\b",
      "endPattern": "\\bend\\b",
      "description": "implement/end blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\blocal\\b",
      "endPattern": "\\bend\\b",
      "description": "local/in/end blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\blet\\b",
      "endPattern": "\\bend\\b",
      "description": "let/in/end blocks"
    }
  ]
}
