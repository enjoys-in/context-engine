{
  "language": "liquid",
  "offSide": false,
  "markers": {
    "start": "^\\s*\\{%\\s*comment\\s*%\\}\\s*#region\\b",
    "end": "^\\s*\\{%\\s*comment\\s*%\\}\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{%[-\\s]*if\\b",
      "endPattern": "\\{%[-\\s]*endif\\s*[-]?%\\}",
      "description": "Liquid if/endif blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\{%[-\\s]*for\\b",
      "endPattern": "\\{%[-\\s]*endfor\\s*[-]?%\\}",
      "description": "Liquid for/endfor loops"
    },
    {
      "kind": "region",
      "startPattern": "\\{%[-\\s]*block\\b",
      "endPattern": "\\{%[-\\s]*endblock\\s*[-]?%\\}",
      "description": "Liquid block/endblock sections"
    },
    {
      "kind": "comment",
      "startPattern": "\\{%[-\\s]*comment\\s*[-]?%\\}",
      "endPattern": "\\{%[-\\s]*endcomment\\s*[-]?%\\}",
      "description": "Liquid comment/endcomment blocks"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "region",
      "description": "Tag-based folding",
      "startPattern": "<[^/][^>]*[^/]>",
      "endPattern": "</[^>]+>"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
