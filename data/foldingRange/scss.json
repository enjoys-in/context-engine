{
  "language": "scss",
  "offSide": false,
  "markers": {
    "start": "^\\s*\\/\\/\\s*#region\\b",
    "end": "^\\s*\\/\\/\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Curly brace blocks"
    },
    {
      "kind": "comment",
      "startPattern": "\\/\\*",
      "endPattern": "\\*\\/",
      "description": "Block comments"
    },
    {
      "kind": "region",
      "startPattern": "@mixin\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Mixin blocks"
    },
    {
      "kind": "region",
      "startPattern": "@media\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Media query blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*[.#&\\w][^{]*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Selector blocks"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
