{
  "language": "shell",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*#region\\b",
    "end": "^\\s*#\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Curly brace blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bfunction\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Function definitions"
    },
    {
      "kind": "region",
      "startPattern": "\\bif\\b",
      "endPattern": "\\bfi\\b",
      "description": "If/fi conditionals"
    },
    {
      "kind": "region",
      "startPattern": "\\bcase\\b",
      "endPattern": "\\besac\\b",
      "description": "Case/esac blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bfor\\b",
      "endPattern": "\\bdone\\b",
      "description": "For/done loops"
    },
    {
      "kind": "region",
      "startPattern": "\\bwhile\\b",
      "endPattern": "\\bdone\\b",
      "description": "While/done loops"
    }
  ]
}
