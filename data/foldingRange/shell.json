{
  "language": "shell",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*#region\\b",
    "end": "^\\s*#\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Curly brace blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bfunction\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Function definitions"
    },
    {
      "kind": "region",
      "startPattern": "\\bif\\b",
      "endPattern": "\\bfi\\b",
      "description": "If/fi conditionals"
    },
    {
      "kind": "region",
      "startPattern": "\\bcase\\b",
      "endPattern": "\\besac\\b",
      "description": "Case/esac blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bfor\\b",
      "endPattern": "\\bdone\\b",
      "description": "For/done loops"
    },
    {
      "kind": "region",
      "startPattern": "\\bwhile\\b",
      "endPattern": "\\bdone\\b",
      "description": "While/done loops"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*(function\\s+\\w+|\\w+\\s*\\(\\s*\\))\\s*\\{?",
      "endPattern": "^\\s*\\}",
      "description": "Function definition block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*if\\b",
      "endPattern": "^\\s*fi\\b",
      "description": "If/fi conditional block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*case\\b",
      "endPattern": "^\\s*esac\\b",
      "description": "Case/esac switch block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*for\\b",
      "endPattern": "^\\s*done\\b",
      "description": "For/done loop block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*while\\b",
      "endPattern": "^\\s*done\\b",
      "description": "While/done loop block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*until\\b",
      "endPattern": "^\\s*done\\b",
      "description": "Until/done loop block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*do\\b",
      "endPattern": "^\\s*done\\b",
      "description": "Do/done block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*select\\b",
      "endPattern": "^\\s*done\\b",
      "description": "Select/done block"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*#(?!\\s*region\\b|\\s*endregion\\b)",
      "endPattern": "^(?!\\s*#)",
      "description": "Consecutive comment lines"
    },
    {
      "kind": "region",
      "startPattern": "<<-?\\s*['\"]?(\\w+)['\"]?",
      "endPattern": "^\\s*\\1\\s*$",
      "description": "Here-document block"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
