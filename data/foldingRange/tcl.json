{
  "language": "tcl",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*#region\\b",
    "end": "^\\s*#\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Curly brace blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bproc\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Proc definitions"
    },
    {
      "kind": "region",
      "startPattern": "\\bif\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "If blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bforeach\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Foreach loops"
    },
    {
      "kind": "region",
      "startPattern": "\\bwhile\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "While loops"
    },
    {
      "kind": "region",
      "startPattern": "\\bswitch\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Switch blocks"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
