{
  "language": "ini",
  "offSide": false,
  "markers": {
    "start": "^\\s*[;#]\\s*#region\\b",
    "end": "^\\s*[;#]\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "^\\s*\\[.+\\]",
      "endPattern": "(?=^\\s*\\[.+\\]|\\z)",
      "description": "INI section blocks delimited by [section] headers"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*[;#]",
      "endPattern": "(?=^\\s*[^;#\\s]|\\z)",
      "description": "Consecutive comment line blocks"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
