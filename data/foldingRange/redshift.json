{
  "language": "redshift",
  "offSide": false,
  "markers": {
    "start": "^\\s*--\\s*#region\\b",
    "end": "^\\s*--\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\bBEGIN\\b",
      "endPattern": "\\bEND\\b",
      "description": "BEGIN/END blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bCREATE\\s+(OR\\s+REPLACE\\s+)?PROCEDURE\\b",
      "endPattern": "\\bEND\\b",
      "description": "CREATE PROCEDURE blocks"
    },
    {
      "kind": "comment",
      "startPattern": "/\\*",
      "endPattern": "\\*/",
      "description": "Multi-line comments"
    }
  ]
}
