{
  "language": "cpp",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*pragma\\s+region\\b|^\\s*//\\s*#region\\b",
    "end": "^\\s*#\\s*pragma\\s+endregion\\b|^\\s*//\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Brace-delimited block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*#\\s*if(n?def)?\\b",
      "endPattern": "^\\s*#\\s*endif\\b",
      "description": "Preprocessor conditional block (#if/#ifdef/#ifndef to #endif)"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*/\\*",
      "endPattern": "\\*/\\s*$",
      "description": "Multi-line comment block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*namespace\\b.*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Namespace block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*(class|struct)\\s+\\w+[^;]*\\{",
      "endPattern": "^\\s*\\}\\s*;",
      "description": "Class/struct definition block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*enum\\s+(class\\s+)?\\w*\\s*\\{",
      "endPattern": "^\\s*\\}\\s*;",
      "description": "Enum definition block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*template\\s*<",
      "endPattern": "^\\s*\\}",
      "description": "Template declaration block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*switch\\s*\\(",
      "endPattern": "^\\s*\\}",
      "description": "Switch statement block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*try\\s*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Try block"
    },
    {
      "kind": "imports",
      "startPattern": "^\\s*#\\s*include\\b",
      "endPattern": "^(?!\\s*#\\s*include\\b)",
      "description": "Consecutive #include directives"
    },
    {
      "kind": "imports",
      "startPattern": "^\\s*using\\b",
      "endPattern": "^(?!\\s*using\\b)",
      "description": "Consecutive using declarations"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
