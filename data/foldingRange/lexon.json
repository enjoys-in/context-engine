{
  "language": "lexon",
  "offSide": false,
  "markers": {
    "start": "^\\s*#region\\b",
    "end": "^\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "^\\s*TERMS\\b",
      "endPattern": "(?=^\\s*TERMS\\b|\\z)",
      "description": "TERMS section blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*CLAUSE\\b",
      "endPattern": "(?=^\\s*CLAUSE\\b|^\\s*TERMS\\b|\\z)",
      "description": "CLAUSE definition blocks"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
