{
  "language": "csharp",
  "offSide": false,
  "markers": {
    "start": "^\\s*#region\\b",
    "end": "^\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Brace-delimited block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*namespace\\b",
      "endPattern": "^\\s*\\}",
      "description": "Namespace block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*(public|private|protected|internal|static|abstract|sealed|partial)?\\s*(class|struct|interface|record)\\b",
      "endPattern": "^\\s*\\}",
      "description": "Class/struct/interface/record definition block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*(public|private|protected|internal|static|virtual|override|abstract|async)?\\s+\\w+\\s+\\w+\\s*\\(",
      "endPattern": "^\\s*\\}",
      "description": "Method declaration block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*(public|private|protected|internal)\\s+\\w+\\s+\\w+\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Property with accessor block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*enum\\b",
      "endPattern": "^\\s*\\}",
      "description": "Enum definition block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*switch\\s*\\(",
      "endPattern": "^\\s*\\}",
      "description": "Switch statement block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*try\\s*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Try block"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*/\\*",
      "endPattern": "\\*/\\s*$",
      "description": "Multi-line comment block"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*///",
      "endPattern": "^(?!\\s*///)",
      "description": "XML documentation comment block"
    },
    {
      "kind": "imports",
      "startPattern": "^\\s*using\\b",
      "endPattern": "^(?!\\s*using\\b)",
      "description": "Consecutive using directives"
    }
  ]
}
