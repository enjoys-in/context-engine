{
  "language": "vb",
  "offSide": false,
  "markers": {
    "start": "^\\s*'\\s*#Region\\b",
    "end": "^\\s*'\\s*#End Region\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "^\\s*Sub\\b",
      "endPattern": "^\\s*End\\s+Sub\\b",
      "description": "Sub/End Sub blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*Function\\b",
      "endPattern": "^\\s*End\\s+Function\\b",
      "description": "Function/End Function blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*Class\\b",
      "endPattern": "^\\s*End\\s+Class\\b",
      "description": "Class/End Class blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*If\\b",
      "endPattern": "^\\s*End\\s+If\\b",
      "description": "If/End If blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*For\\b",
      "endPattern": "^\\s*Next\\b",
      "description": "For/Next loops"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*While\\b",
      "endPattern": "^\\s*End\\s+While\\b",
      "description": "While/End While loops"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*#Region\\b",
      "endPattern": "^\\s*#End\\s+Region\\b",
      "description": "#Region/#End Region markers"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
