{
  "language": "pla",
  "offSide": false,
  "markers": {
    "start": "^\\s*//\\s*#region\\b",
    "end": "^\\s*//\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\bPROC\\b",
      "endPattern": "\\bEND\\b",
      "description": "PROC...END blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bBEGIN\\b",
      "endPattern": "\\bEND\\b",
      "description": "BEGIN...END blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bDO\\b",
      "endPattern": "\\bEND\\b",
      "description": "DO...END blocks"
    }
  ]
}
