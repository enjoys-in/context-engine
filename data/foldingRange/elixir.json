{
  "language": "elixir",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*region\\b",
    "end": "^\\s*#\\s*endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\bdo\\s*$",
      "endPattern": "^\\s*end\\b",
      "description": "do/end block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*defmodule\\b",
      "endPattern": "^\\s*end\\b",
      "description": "Module definition (defmodule/end) block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*def\\b",
      "endPattern": "^\\s*end\\b",
      "description": "Function definition (def/end) block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*defp\\b",
      "endPattern": "^\\s*end\\b",
      "description": "Private function definition (defp/end) block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*defmacro\\b",
      "endPattern": "^\\s*end\\b",
      "description": "Macro definition (defmacro/end) block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*defimpl\\b",
      "endPattern": "^\\s*end\\b",
      "description": "Protocol implementation (defimpl/end) block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*defprotocol\\b",
      "endPattern": "^\\s*end\\b",
      "description": "Protocol definition (defprotocol/end) block"
    },
    {
      "kind": "region",
      "startPattern": "\\bfn\\b.*->",
      "endPattern": "^\\s*end\\b",
      "description": "Anonymous function (fn/end) block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*case\\b",
      "endPattern": "^\\s*end\\b",
      "description": "Case expression (case/end) block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*cond\\b",
      "endPattern": "^\\s*end\\b",
      "description": "Cond expression (cond/end) block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*if\\b",
      "endPattern": "^\\s*end\\b",
      "description": "If conditional (if/end) block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*unless\\b",
      "endPattern": "^\\s*end\\b",
      "description": "Unless conditional (unless/end) block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*try\\b",
      "endPattern": "^\\s*end\\b",
      "description": "Try (try/end) block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*with\\b",
      "endPattern": "^\\s*end\\b",
      "description": "With expression (with/end) block"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*#",
      "endPattern": "^(?!\\s*#)",
      "description": "Consecutive comment lines"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*@moduledoc\\s+\"\"\"",
      "endPattern": "^\\s*\"\"\"",
      "description": "Module documentation block"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*@doc\\s+\"\"\"",
      "endPattern": "^\\s*\"\"\"",
      "description": "Function documentation block"
    },
    {
      "kind": "imports",
      "startPattern": "^\\s*(import|alias|require|use)\\b",
      "endPattern": "^(?!\\s*(import|alias|require|use)\\b)",
      "description": "Consecutive import/alias/require/use statements"
    }
  ]
}
