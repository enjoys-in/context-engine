{
  "language": "cameligo",
  "offSide": false,
  "markers": {
    "start": "^\\s*\\(\\*\\s*#region\\b",
    "end": "^\\s*\\(\\*\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\blet\\b.*\\bin\\b\\s*$",
      "endPattern": "^(?=\\blet\\b|$)",
      "description": "Let...in binding block"
    },
    {
      "kind": "region",
      "startPattern": "\\bmatch\\b.*\\bwith\\b",
      "endPattern": "^(?=\\blet\\b|\\btype\\b|$)",
      "description": "Match...with pattern matching block"
    },
    {
      "kind": "region",
      "startPattern": "\\bbegin\\b",
      "endPattern": "\\bend\\b",
      "description": "Begin...end block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*type\\b",
      "endPattern": "^(?=\\blet\\b|\\btype\\b|$)",
      "description": "Type definition block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*let\\s+(rec\\s+)?\\w+",
      "endPattern": "^(?=\\blet\\b|\\btype\\b|$)",
      "description": "Top-level let binding block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*module\\b",
      "endPattern": "^(?=\\bmodule\\b|\\blet\\b|$)",
      "description": "Module declaration block"
    },
    {
      "kind": "comment",
      "startPattern": "\\(\\*",
      "endPattern": "\\*\\)",
      "description": "Multi-line comment block"
    },
    {
      "kind": "region",
      "startPattern": "\\bif\\b",
      "endPattern": "(?=\\belse\\b|\\blet\\b|$)",
      "description": "If-then-else expression block"
    }
  ]
}
