{
  "language": "ruby",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*region\\b",
    "end": "^\\s*#\\s*endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\bdef\\b",
      "endPattern": "\\bend\\b",
      "description": "def/end method blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bclass\\b",
      "endPattern": "\\bend\\b",
      "description": "class/end blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bmodule\\b",
      "endPattern": "\\bend\\b",
      "description": "module/end blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bdo\\b",
      "endPattern": "\\bend\\b",
      "description": "do/end blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bif\\b",
      "endPattern": "\\bend\\b",
      "description": "if/end blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bbegin\\b",
      "endPattern": "\\bend\\b",
      "description": "begin/end blocks"
    },
    {
      "kind": "comment",
      "startPattern": "^=begin\\b",
      "endPattern": "^=end\\b",
      "description": "=begin/=end multi-line comments"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "region",
      "description": "Indentation-based folding",
      "indentBased": true
    },
    {
      "kind": "region",
      "description": "Begin/End block folding",
      "startPattern": "\\b(begin|do|then|loop)\\b",
      "endPattern": "\\b(end|done|fi|loop)\\b"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
