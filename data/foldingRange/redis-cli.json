{
  "language": "redis-cli",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*region\\b",
    "end": "^\\s*#\\s*endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "^\\s*#\\s*region\\b",
      "endPattern": "^\\s*#\\s*endregion\\b",
      "description": "Comment-based region markers"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*#\\s*---",
      "endPattern": "^\\s*#\\s*---",
      "description": "Command group separators"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
