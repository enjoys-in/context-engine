{
  "language": "nginx",
  "offSide": false,
  "markers": {
    "start": "^\\s*#region\\b",
    "end": "^\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Brace blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bserver\\s*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Server blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\blocation\\b.*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Location blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bupstream\\b.*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Upstream blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bhttp\\s*\\{",
      "endPattern": "^\\s*\\}",
      "description": "HTTP blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bevents\\s*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Events blocks"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
