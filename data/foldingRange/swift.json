{
  "language": "swift",
  "offSide": false,
  "markers": {
    "start": "^\\s*\\/\\/\\s*#region\\b",
    "end": "^\\s*\\/\\/\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Curly brace blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bclass\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Class definitions"
    },
    {
      "kind": "region",
      "startPattern": "\\bstruct\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Struct definitions"
    },
    {
      "kind": "region",
      "startPattern": "\\benum\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Enum definitions"
    },
    {
      "kind": "region",
      "startPattern": "\\bfunc\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Function definitions"
    },
    {
      "kind": "comment",
      "startPattern": "\\/\\*",
      "endPattern": "\\*\\/",
      "description": "Block comments"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*\\/\\/\\s*#region\\b",
      "endPattern": "^\\s*\\/\\/\\s*#endregion\\b",
      "description": "Region markers"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*#if\\b",
      "endPattern": "^\\s*#endif\\b",
      "description": "Preprocessor #if/#endif blocks"
    }
  ]
}
