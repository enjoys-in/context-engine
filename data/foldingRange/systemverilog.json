{
  "language": "systemverilog",
  "offSide": false,
  "markers": {
    "start": "^\\s*\\/\\/\\s*#region\\b",
    "end": "^\\s*\\/\\/\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\bmodule\\b",
      "endPattern": "\\bendmodule\\b",
      "description": "Module/endmodule blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bbegin\\b",
      "endPattern": "\\bend\\b",
      "description": "Begin/end blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bfunction\\b",
      "endPattern": "\\bendfunction\\b",
      "description": "Function/endfunction blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\btask\\b",
      "endPattern": "\\bendtask\\b",
      "description": "Task/endtask blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bclass\\b",
      "endPattern": "\\bendclass\\b",
      "description": "Class/endclass blocks"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
