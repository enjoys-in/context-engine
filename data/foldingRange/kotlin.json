{
  "language": "kotlin",
  "offSide": false,
  "markers": {
    "start": "^\\s*//\\s*#region\\b",
    "end": "^\\s*//\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Curly brace blocks"
    },
    {
      "kind": "comment",
      "startPattern": "/\\*",
      "endPattern": "\\*/",
      "description": "Multi-line comments and KDoc"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*//\\s*#region\\b",
      "endPattern": "^\\s*//\\s*#endregion\\b",
      "description": "Manual region markers"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*(open|abstract|sealed|data|inner|private|public|internal|protected)?\\s*class\\s+",
      "endPattern": "^\\}",
      "description": "Class declarations"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*(private|public|internal|protected|override|suspend)?\\s*fun\\s+",
      "endPattern": "^\\}",
      "description": "Function declarations"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*object\\s+",
      "endPattern": "^\\}",
      "description": "Object declarations"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*companion\\s+object\\b",
      "endPattern": "^\\s*\\}",
      "description": "Companion object blocks"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
