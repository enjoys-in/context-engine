{
  "language": "java",
  "offSide": false,
  "markers": {
    "start": "^\\s*//\\s*#region\\b",
    "end": "^\\s*//\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Curly brace blocks"
    },
    {
      "kind": "comment",
      "startPattern": "/\\*",
      "endPattern": "\\*/",
      "description": "Multi-line comments and Javadoc"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*//\\s*#region\\b",
      "endPattern": "^\\s*//\\s*#endregion\\b",
      "description": "Manual region markers"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*(public|private|protected|static|abstract|final|synchronized)?\\s*class\\s+",
      "endPattern": "^\\}",
      "description": "Class declarations"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*(public|private|protected)?\\s*interface\\s+",
      "endPattern": "^\\}",
      "description": "Interface declarations"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*(public|private|protected)?\\s*enum\\s+",
      "endPattern": "^\\}",
      "description": "Enum declarations"
    },
    {
      "kind": "imports",
      "startPattern": "^import\\s+",
      "endPattern": "(?=^\\s*$|^[^i])",
      "description": "Consecutive import statements"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
