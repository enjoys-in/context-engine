{
  "language": "julia",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*#region\\b",
    "end": "^\\s*#\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "^\\s*function\\b",
      "endPattern": "^\\s*end\\b",
      "description": "Function blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*module\\b",
      "endPattern": "^\\s*end\\b",
      "description": "Module blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*begin\\b",
      "endPattern": "^\\s*end\\b",
      "description": "Begin/end blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*if\\b",
      "endPattern": "^\\s*end\\b",
      "description": "If/end conditional blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*for\\b",
      "endPattern": "^\\s*end\\b",
      "description": "For loop blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*while\\b",
      "endPattern": "^\\s*end\\b",
      "description": "While loop blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*#\\s*#region\\b",
      "endPattern": "^\\s*#\\s*#endregion\\b",
      "description": "Manual region markers"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
