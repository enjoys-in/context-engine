{
  "language": "objective-c",
  "offSide": false,
  "markers": {
    "start": "^\\s*#pragma\\s+mark\\s+-\\s*$|^\\s*//\\s*#region\\b",
    "end": "^\\s*#pragma\\s+mark\\b|^\\s*//\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Brace blocks"
    },
    {
      "kind": "region",
      "startPattern": "@interface\\b",
      "endPattern": "@end\\b",
      "description": "@interface/@end blocks"
    },
    {
      "kind": "region",
      "startPattern": "@implementation\\b",
      "endPattern": "@end\\b",
      "description": "@implementation/@end blocks"
    },
    {
      "kind": "region",
      "startPattern": "#pragma\\s+mark\\b",
      "endPattern": "#pragma\\s+mark\\b",
      "description": "#pragma mark regions"
    },
    {
      "kind": "region",
      "startPattern": "#if\\b",
      "endPattern": "#endif\\b",
      "description": "#if/#endif preprocessor blocks"
    },
    {
      "kind": "comment",
      "startPattern": "/\\*",
      "endPattern": "\\*/",
      "description": "Multi-line comments"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
