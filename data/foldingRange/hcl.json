{
  "language": "hcl",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*#region\\b",
    "end": "^\\s*#\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Curly brace blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*resource\\s+\"",
      "endPattern": "^\\}",
      "description": "Resource blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*variable\\s+\"",
      "endPattern": "^\\}",
      "description": "Variable blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*output\\s+\"",
      "endPattern": "^\\}",
      "description": "Output blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*data\\s+\"",
      "endPattern": "^\\}",
      "description": "Data source blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*module\\s+\"",
      "endPattern": "^\\}",
      "description": "Module blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*locals\\s*\\{",
      "endPattern": "^\\}",
      "description": "Locals blocks"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
