{
  "language": "docker-compose",
  "offSide": true,
  "markers": {
    "start": "^\\s*#\\s*region\\b",
    "end": "^\\s*#\\s*endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "^services:\\s*$",
      "endPattern": "^\\w",
      "description": "Services top-level block"
    },
    {
      "kind": "region",
      "startPattern": "^volumes:\\s*$",
      "endPattern": "^\\w",
      "description": "Volumes top-level block"
    },
    {
      "kind": "region",
      "startPattern": "^networks:\\s*$",
      "endPattern": "^\\w",
      "description": "Networks top-level block"
    },
    {
      "kind": "region",
      "startPattern": "^secrets:\\s*$",
      "endPattern": "^\\w",
      "description": "Secrets top-level block"
    },
    {
      "kind": "region",
      "startPattern": "^configs:\\s*$",
      "endPattern": "^\\w",
      "description": "Configs top-level block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s{2}\\w[\\w-]*:\\s*$",
      "endPattern": "^(?=\\s{0,2}\\w)",
      "description": "Individual service/volume/network definition block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s+(environment|ports|volumes|depends_on|labels|deploy|logging|healthcheck|build|networks):\\s*$",
      "endPattern": "^(?=\\s{2,4}\\w[\\w-]*:|^\\w)",
      "description": "Service sub-property block"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*#",
      "endPattern": "^(?!\\s*#)",
      "description": "Consecutive comment lines"
    }
  ]
}
