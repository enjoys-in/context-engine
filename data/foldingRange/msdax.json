{
  "language": "msdax",
  "offSide": false,
  "markers": {
    "start": "^\\s*//\\s*#region\\b",
    "end": "^\\s*//\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\bEVALUATE\\b",
      "endPattern": "(?=^\\s*EVALUATE\\b|\\z)",
      "description": "EVALUATE expression blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bVAR\\b",
      "endPattern": "\\bRETURN\\b",
      "description": "VAR/RETURN variable definition blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bCALCULATE\\s*\\(",
      "endPattern": "\\)",
      "description": "Nested CALCULATE function blocks"
    }
  ]
}