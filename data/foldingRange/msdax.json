{
  "language": "msdax",
  "offSide": false,
  "markers": {
    "start": "^\\s*//\\s*#region\\b",
    "end": "^\\s*//\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\bEVALUATE\\b",
      "endPattern": "(?=^\\s*EVALUATE\\b|\\z)",
      "description": "EVALUATE expression blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bVAR\\b",
      "endPattern": "\\bRETURN\\b",
      "description": "VAR/RETURN variable definition blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bCALCULATE\\s*\\(",
      "endPattern": "\\)",
      "description": "Nested CALCULATE function blocks"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
