{
  "language": "html",
  "offSide": false,
  "markers": {
    "start": "^\\s*<!--\\s*#region\\b",
    "end": "^\\s*<!--\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "<(?!(?:area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)\\b)(\\w[\\w-]*)(?:\\s[^>]*)?>",
      "endPattern": "</\\1>",
      "description": "Matching HTML open/close tag pairs"
    },
    {
      "kind": "comment",
      "startPattern": "<!--",
      "endPattern": "-->",
      "description": "HTML comment blocks"
    },
    {
      "kind": "region",
      "startPattern": "<script\\b[^>]*>",
      "endPattern": "</script>",
      "description": "Script element blocks"
    },
    {
      "kind": "region",
      "startPattern": "<style\\b[^>]*>",
      "endPattern": "</style>",
      "description": "Style element blocks"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "region",
      "description": "Tag-based folding",
      "startPattern": "<[^/][^>]*[^/]>",
      "endPattern": "</[^>]+>"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
