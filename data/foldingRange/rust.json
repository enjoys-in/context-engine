{
  "language": "rust",
  "offSide": false,
  "markers": {
    "start": "^\\s*\\/\\/\\s*#region\\b",
    "end": "^\\s*\\/\\/\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Curly brace blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bfn\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Function definitions"
    },
    {
      "kind": "region",
      "startPattern": "\\bstruct\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Struct definitions"
    },
    {
      "kind": "region",
      "startPattern": "\\benum\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Enum definitions"
    },
    {
      "kind": "region",
      "startPattern": "\\bimpl\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Impl blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bmod\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Module blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\btrait\\b.*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Trait definitions"
    },
    {
      "kind": "comment",
      "startPattern": "\\/\\*",
      "endPattern": "\\*\\/",
      "description": "Block comments"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*\\/\\/\\s*#region\\b",
      "endPattern": "^\\s*\\/\\/\\s*#endregion\\b",
      "description": "Region markers"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
