{
  "language": "pascal",
  "offSide": false,
  "markers": {
    "start": "^\\s*\\{\\s*#region\\b|^\\s*//\\s*#region\\b",
    "end": "^\\s*\\{\\s*#endregion\\b|^\\s*//\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\bbegin\\b",
      "endPattern": "\\bend\\b",
      "description": "begin/end blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bprocedure\\b",
      "endPattern": "\\bend\\b",
      "description": "Procedure blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bfunction\\b",
      "endPattern": "\\bend\\b",
      "description": "Function blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\brecord\\b",
      "endPattern": "\\bend\\b",
      "description": "Record blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bcase\\b",
      "endPattern": "\\bend\\b",
      "description": "Case blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\brepeat\\b",
      "endPattern": "\\buntil\\b",
      "description": "Repeat/until blocks"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "region",
      "description": "Begin/End block folding",
      "startPattern": "\\b(begin|do|then|loop)\\b",
      "endPattern": "\\b(end|done|fi|loop)\\b"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
