{
  "language": "php",
  "offSide": false,
  "markers": {
    "start": "^\\s*//\\s*#region\\b|^\\s*#region\\b",
    "end": "^\\s*//\\s*#endregion\\b|^\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Brace blocks"
    },
    {
      "kind": "comment",
      "startPattern": "/\\*",
      "endPattern": "\\*/",
      "description": "Multi-line comments"
    },
    {
      "kind": "region",
      "startPattern": "\\bclass\\b.*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Class blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bfunction\\b.*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Function blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*//\\s*#region\\b",
      "endPattern": "^\\s*//\\s*#endregion\\b",
      "description": "//#region markers"
    },
    {
      "kind": "region",
      "startPattern": "\\bnamespace\\b.*[{;]",
      "endPattern": "^\\s*\\}",
      "description": "Namespace blocks"
    }
  ]
}
