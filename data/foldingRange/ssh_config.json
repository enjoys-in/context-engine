{
  "language": "ssh_config",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*#region\\b",
    "end": "^\\s*#\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "^\\s*Host\\b",
      "endPattern": "^(?=\\s*Host\\b|\\s*Match\\b|\\s*$)",
      "description": "Host blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*Match\\b",
      "endPattern": "^(?=\\s*Host\\b|\\s*Match\\b|\\s*$)",
      "description": "Match blocks"
    }
  ]
}
