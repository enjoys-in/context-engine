{
  "language": "m3",
  "offSide": false,
  "markers": {
    "start": "^\\s*\\(\\*\\s*#region\\b",
    "end": "^\\s*\\(\\*\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\bPROCEDURE\\b",
      "endPattern": "\\bEND\\s+\\w+\\s*;",
      "description": "Procedure blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bMODULE\\b",
      "endPattern": "\\bEND\\s+\\w+\\s*\\.",
      "description": "Module blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bBEGIN\\b",
      "endPattern": "\\bEND\\b",
      "description": "Begin/End blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bIF\\b",
      "endPattern": "\\bEND\\b",
      "description": "If/End conditional blocks"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
