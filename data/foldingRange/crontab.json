{
  "language": "crontab",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*region\\b",
    "end": "^\\s*#\\s*endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "comment",
      "startPattern": "^\\s*#",
      "endPattern": "^(?!\\s*#)",
      "description": "Consecutive comment lines"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*#\\s*[-=]{3,}",
      "endPattern": "^\\s*$|^\\s*#\\s*[-=]{3,}",
      "description": "Comment-delimited section block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*#.*:$",
      "endPattern": "^\\s*$|^\\s*#.*:$",
      "description": "Labeled comment section"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
