{
  "language": "azcli",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*region\\b",
    "end": "^\\s*#\\s*endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "^\\s*az\\s+\\w+",
      "endPattern": "^(?!\\s+--)",
      "description": "Multi-line az CLI command with continuation parameters"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*#",
      "endPattern": "^(?!\\s*#)",
      "description": "Consecutive comment lines"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*#\\s*[-=]{3,}",
      "endPattern": "^\\s*#\\s*[-=]{3,}",
      "description": "Comment-delimited section block"
    },
    {
      "kind": "region",
      "startPattern": "\\\\\\s*$",
      "endPattern": "^[^\\\\]*$",
      "description": "Line continuation block"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
