{
  "language": "nextjs",
  "offSide": false,
  "markers": {
    "start": "^\\s*(?:\\/\\/\\s*#?region\\b|\\{\\s*\\/\\*\\s*region\\b)",
    "end": "^\\s*(?:\\/\\/\\s*#?endregion\\b|\\{?\\s*\\/\\*\\s*endregion\\b)"
  },
  "foldingRules": [
    {
      "description": "Import block",
      "startPattern": "^import\\s+",
      "endPattern": "^(?!import\\s|\\s*$)",
      "kind": "imports"
    },
    {
      "description": "JSX element block",
      "startPattern": "<([A-Z][a-zA-Z0-9.]*)[^>]*>\\s*$",
      "endPattern": "<\\/\\1>",
      "kind": "region"
    },
    {
      "description": "Function/component body",
      "startPattern": "(?:export\\s+(?:default\\s+)?)?(?:async\\s+)?function\\s+\\w+[^{]*\\{\\s*$",
      "endPattern": "^\\}",
      "kind": "region"
    },
    {
      "description": "Arrow function body",
      "startPattern": "(?:const|let)\\s+\\w+\\s*=.*=>\\s*\\{\\s*$",
      "endPattern": "^\\s*\\};?\\s*$",
      "kind": "region"
    },
    {
      "description": "Object/config literal",
      "startPattern": "(?:const|export\\s+const)\\s+\\w+.*=\\s*\\{\\s*$",
      "endPattern": "^\\s*\\};?\\s*$",
      "kind": "region"
    },
    {
      "description": "JSDoc comment block",
      "startPattern": "^\\s*\\/\\*\\*",
      "endPattern": "\\*\\/\\s*$",
      "kind": "comment"
    },
    {
      "description": "Multi-line comment",
      "startPattern": "^\\s*\\/\\*(?!\\*)",
      "endPattern": "\\*\\/\\s*$",
      "kind": "comment"
    },
    {
      "description": "Return statement with JSX",
      "startPattern": "return\\s*\\(\\s*$",
      "endPattern": "^\\s*\\);?\\s*$",
      "kind": "region"
    },
    {
      "description": "Try-catch block",
      "startPattern": "\\btry\\s*\\{\\s*$",
      "endPattern": "^\\s*\\}\\s*(?:catch|finally)",
      "kind": "region"
    },
    {
      "description": "Switch statement",
      "startPattern": "\\bswitch\\s*\\([^)]*\\)\\s*\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "kind": "region"
    },
    {
      "description": "Template literal",
      "startPattern": "`[^`]*$",
      "endPattern": "[^`]*`",
      "kind": "region"
    },
    {
      "description": "Array literal",
      "startPattern": "\\[\\s*$",
      "endPattern": "^\\s*\\];?\\s*$",
      "kind": "region"
    },
    {
      "description": "Metadata export",
      "startPattern": "export\\s+(?:const|async\\s+function)\\s+(?:metadata|generateMetadata)",
      "endPattern": "^\\s*\\}\\s*;?\\s*$",
      "kind": "region"
    },
    {
      "description": "Middleware function",
      "startPattern": "export\\s+(?:async\\s+)?function\\s+middleware",
      "endPattern": "^\\}",
      "kind": "region"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
