{
  "language": "scheme",
  "offSide": false,
  "markers": {
    "start": "^\\s*\\/\\/\\s*#region\\b",
    "end": "^\\s*\\/\\/\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\(",
      "endPattern": "\\)",
      "description": "Parenthesized expressions"
    },
    {
      "kind": "region",
      "startPattern": "\\(\\s*define\\b",
      "endPattern": "\\)",
      "description": "Define expressions"
    },
    {
      "kind": "region",
      "startPattern": "\\(\\s*let\\b",
      "endPattern": "\\)",
      "description": "Let expressions"
    },
    {
      "kind": "region",
      "startPattern": "\\(\\s*lambda\\b",
      "endPattern": "\\)",
      "description": "Lambda expressions"
    },
    {
      "kind": "region",
      "startPattern": "\\(\\s*cond\\b",
      "endPattern": "\\)",
      "description": "Cond expressions"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
