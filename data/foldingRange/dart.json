{
  "language": "dart",
  "offSide": false,
  "markers": {
    "start": "^\\s*//\\s*#region\\b",
    "end": "^\\s*//\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Brace-delimited block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*(abstract\\s+)?class\\b",
      "endPattern": "^\\s*\\}",
      "description": "Class definition block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*(mixin|extension)\\b",
      "endPattern": "^\\s*\\}",
      "description": "Mixin/extension definition block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*enum\\b",
      "endPattern": "^\\s*\\}",
      "description": "Enum definition block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*(static\\s+)?(Future|Stream|void|int|double|String|bool|dynamic|var|\\w+)\\s+\\w+\\s*\\(",
      "endPattern": "^\\s*\\}",
      "description": "Function/method declaration block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*if\\s*\\(",
      "endPattern": "^\\s*\\}",
      "description": "If statement block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*for\\s*\\(",
      "endPattern": "^\\s*\\}",
      "description": "For loop block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*switch\\s*\\(",
      "endPattern": "^\\s*\\}",
      "description": "Switch statement block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*try\\s*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Try block"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*/\\*",
      "endPattern": "\\*/\\s*$",
      "description": "Multi-line comment block"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*///",
      "endPattern": "^(?!\\s*///)",
      "description": "Documentation comment block"
    },
    {
      "kind": "imports",
      "startPattern": "^\\s*import\\b",
      "endPattern": "^(?!\\s*import\\b)",
      "description": "Consecutive import statements"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
