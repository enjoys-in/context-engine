{
  "language": "awk",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*region\\b",
    "end": "^\\s*#\\s*endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Brace-delimited block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*function\\s+\\w+\\s*\\(",
      "endPattern": "^\\s*\\}",
      "description": "Function definition block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*BEGIN\\s*\\{",
      "endPattern": "^\\s*\\}",
      "description": "BEGIN block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*END\\s*\\{",
      "endPattern": "^\\s*\\}",
      "description": "END block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*/.*\\/\\s*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Pattern-action block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*if\\s*\\(",
      "endPattern": "^\\s*\\}",
      "description": "If statement block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*for\\s*\\(",
      "endPattern": "^\\s*\\}",
      "description": "For loop block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*while\\s*\\(",
      "endPattern": "^\\s*\\}",
      "description": "While loop block"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*#",
      "endPattern": "^(?!\\s*#)",
      "description": "Consecutive comment lines"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
