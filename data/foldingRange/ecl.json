{
  "language": "ecl",
  "offSide": false,
  "markers": {
    "start": "^\\s*//\\s*#region\\b",
    "end": "^\\s*//\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "^\\s*RECORD\\b",
      "endPattern": "^\\s*END\\s*;",
      "description": "RECORD/END record definition block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*TRANSFORM\\b",
      "endPattern": "^\\s*END\\s*;",
      "description": "TRANSFORM/END transform block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*MODULE\\b",
      "endPattern": "^\\s*END\\s*;",
      "description": "MODULE/END module block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*FUNCTION\\b",
      "endPattern": "^\\s*END\\s*;",
      "description": "FUNCTION/END function block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*MACRO\\b",
      "endPattern": "^\\s*ENDMACRO\\s*;",
      "description": "MACRO/ENDMACRO macro block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*INTERFACE\\b",
      "endPattern": "^\\s*END\\s*;",
      "description": "INTERFACE/END interface block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*IF\\b",
      "endPattern": "^\\s*END\\s*;",
      "description": "IF/END conditional block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*LOOP\\b",
      "endPattern": "^\\s*END\\s*;",
      "description": "LOOP/END loop block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*BEGINC\\+\\+\\b",
      "endPattern": "^\\s*ENDC\\+\\+\\s*;",
      "description": "Embedded C++ block"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*/\\*",
      "endPattern": "\\*/\\s*$",
      "description": "Multi-line comment block"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*//",
      "endPattern": "^(?!\\s*//)",
      "description": "Consecutive single-line comments"
    },
    {
      "kind": "imports",
      "startPattern": "^\\s*IMPORT\\b",
      "endPattern": "^(?!\\s*IMPORT\\b)",
      "description": "Consecutive IMPORT statements"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "region",
      "description": "Begin/End block folding",
      "startPattern": "\\b(begin|do|then|loop)\\b",
      "endPattern": "\\b(end|done|fi|loop)\\b"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
