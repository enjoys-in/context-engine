{
  "language": "abap",
  "offSide": false,
  "markers": {
    "start": "^\\s*\\*\\s*region\\b",
    "end": "^\\s*\\*\\s*endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "^\\s*FORM\\b",
      "endPattern": "^\\s*ENDFORM\\b",
      "description": "FORM/ENDFORM subroutine block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*CLASS\\b",
      "endPattern": "^\\s*ENDCLASS\\b",
      "description": "CLASS/ENDCLASS definition block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*METHOD\\b",
      "endPattern": "^\\s*ENDMETHOD\\b",
      "description": "METHOD/ENDMETHOD implementation block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*IF\\b",
      "endPattern": "^\\s*ENDIF\\b",
      "description": "IF/ENDIF conditional block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*LOOP\\b",
      "endPattern": "^\\s*ENDLOOP\\b",
      "description": "LOOP/ENDLOOP iteration block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*DO\\b",
      "endPattern": "^\\s*ENDDO\\b",
      "description": "DO/ENDDO loop block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*WHILE\\b",
      "endPattern": "^\\s*ENDWHILE\\b",
      "description": "WHILE/ENDWHILE loop block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*CASE\\b",
      "endPattern": "^\\s*ENDCASE\\b",
      "description": "CASE/ENDCASE switch block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*TRY\\b",
      "endPattern": "^\\s*ENDTRY\\b",
      "description": "TRY/ENDTRY exception handling block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*SELECT\\b",
      "endPattern": "^\\s*ENDSELECT\\b",
      "description": "SELECT/ENDSELECT database query block"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*\\*",
      "endPattern": "^(?!\\s*\\*)",
      "description": "Consecutive comment lines"
    }
  ]
}
