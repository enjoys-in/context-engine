{
  "language": "sql",
  "offSide": false,
  "markers": {
    "start": "^\\s*--\\s*#region\\b",
    "end": "^\\s*--\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\bBEGIN\\b",
      "endPattern": "\\bEND\\b",
      "description": "BEGIN/END blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bCREATE\\s+PROCEDURE\\b",
      "endPattern": "\\bEND\\b",
      "description": "CREATE PROCEDURE blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bCASE\\b",
      "endPattern": "\\bEND\\b",
      "description": "CASE/END blocks"
    },
    {
      "kind": "comment",
      "startPattern": "\\/\\*",
      "endPattern": "\\*\\/",
      "description": "Block comments"
    },
    {
      "kind": "region",
      "description": "Brace block folding",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "region",
      "description": "Region marker folding",
      "startPattern": "#region|// region|//#region|<!-- #region",
      "endPattern": "#endregion|// endregion|//#endregion|<!-- #endregion"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
