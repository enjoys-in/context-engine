{
  "language": "sparql",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*#region\\b",
    "end": "^\\s*#\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Curly brace blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bSELECT\\b.*\\bWHERE\\b\\s*\\{",
      "endPattern": "^\\s*\\}",
      "description": "SELECT...WHERE blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bCONSTRUCT\\b\\s*\\{",
      "endPattern": "^\\s*\\}",
      "description": "CONSTRUCT blocks"
    },
    {
      "kind": "region",
      "startPattern": "\\bOPTIONAL\\b\\s*\\{",
      "endPattern": "^\\s*\\}",
      "description": "OPTIONAL blocks"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
