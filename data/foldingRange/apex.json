{
  "language": "apex",
  "offSide": false,
  "markers": {
    "start": "^\\s*//\\s*#?region\\b",
    "end": "^\\s*//\\s*#?endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\{\\s*$",
      "endPattern": "^\\s*\\}",
      "description": "Brace-delimited block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*(public|private|protected|global)\\s+class\\b",
      "endPattern": "^\\s*\\}",
      "description": "Class declaration block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*(public|private|protected|global)\\s+(static\\s+)?\\w+\\s+\\w+\\s*\\(",
      "endPattern": "^\\s*\\}",
      "description": "Method declaration block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*if\\s*\\(",
      "endPattern": "^\\s*\\}",
      "description": "If statement block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*for\\s*\\(",
      "endPattern": "^\\s*\\}",
      "description": "For loop block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*while\\s*\\(",
      "endPattern": "^\\s*\\}",
      "description": "While loop block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*try\\s*\\{",
      "endPattern": "^\\s*\\}",
      "description": "Try-catch block"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*trigger\\b",
      "endPattern": "^\\s*\\}",
      "description": "Trigger definition block"
    },
    {
      "kind": "comment",
      "startPattern": "^\\s*/\\*",
      "endPattern": "\\*/\\s*$",
      "description": "Multi-line comment block"
    },
    {
      "kind": "imports",
      "startPattern": "^\\s*import\\b",
      "endPattern": "^(?!\\s*import\\b)",
      "description": "Consecutive import statements"
    }
  ]
}
