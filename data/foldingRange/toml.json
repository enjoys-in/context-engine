{
  "language": "toml",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*#region\\b",
    "end": "^\\s*#\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "^\\s*\\[[^\\[\\]]\\+\\]",
      "endPattern": "^(?=\\s*\\[)",
      "description": "[table] blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*\\[\\[.+\\]\\]",
      "endPattern": "^(?=\\s*\\[\\[|\\s*\\[(?!\\[))",
      "description": "[[array-of-tables]] blocks"
    }
  ]
}
