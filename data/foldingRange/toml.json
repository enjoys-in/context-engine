{
  "language": "toml",
  "offSide": false,
  "markers": {
    "start": "^\\s*#\\s*#region\\b",
    "end": "^\\s*#\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "^\\s*\\[[^\\[\\]]\\+\\]",
      "endPattern": "^(?=\\s*\\[)",
      "description": "[table] blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*\\[\\[.+\\]\\]",
      "endPattern": "^(?=\\s*\\[\\[|\\s*\\[(?!\\[))",
      "description": "[[array-of-tables]] blocks"
    },
    {
      "kind": "comment",
      "description": "Comment block folding",
      "startPattern": "/\\*|<!--|\"\"\"|\\'\\'\\'|=begin",
      "endPattern": "\\*/|-->|\"\"\"|'\\'\\'|=end"
    },
    {
      "kind": "imports",
      "description": "Import group folding",
      "startPattern": "^\\s*(import|require|use|include|from)\\b",
      "groupConsecutive": true
    }
  ]
}
