{
  "language": "lua",
  "offSide": false,
  "markers": {
    "start": "^\\s*--\\s*#region\\b",
    "end": "^\\s*--\\s*#endregion\\b"
  },
  "foldingRules": [
    {
      "kind": "region",
      "startPattern": "\\bfunction\\b",
      "endPattern": "^\\s*end\\b",
      "description": "Function blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*if\\b",
      "endPattern": "^\\s*end\\b",
      "description": "If/end conditional blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*for\\b",
      "endPattern": "^\\s*end\\b",
      "description": "For loop blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*while\\b",
      "endPattern": "^\\s*end\\b",
      "description": "While loop blocks"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*do\\b",
      "endPattern": "^\\s*end\\b",
      "description": "Do/end blocks"
    },
    {
      "kind": "comment",
      "startPattern": "--\\[\\[",
      "endPattern": "\\]\\]",
      "description": "Multi-line block comments"
    },
    {
      "kind": "region",
      "startPattern": "^\\s*--\\s*#region\\b",
      "endPattern": "^\\s*--\\s*#endregion\\b",
      "description": "Manual region markers"
    }
  ]
}