{
  "language": "mdx",
  "autoFormatTriggerCharacters": [
    "\n",
    ";",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "\n",
      "description": "Auto-continuation and formatting in MDX",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*[-*+]\\s+",
          "description": "Continue unordered list item indentation"
        },
        {
          "action": "indent",
          "pattern": "^\\s*\\d+\\.\\s+",
          "description": "Continue ordered list item indentation"
        },
        {
          "action": "indent",
          "pattern": "<[A-Z][a-zA-Z]*[^/]*>\\s*$",
          "description": "Indent after opening JSX component tag"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*</[A-Z]",
          "description": "Outdent closing JSX component tag"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*[-*+]\\s+|^\\s*\\d+\\.\\s+|<[A-Z][a-zA-Z]*[^/]*>\\s*$",
    "decreasePattern": "^\\s*$|^\\s*</[A-Z]"
  }
}
