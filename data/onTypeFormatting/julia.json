{
  "language": "julia",
  "autoFormatTriggerCharacters": ["\n"],
  "formatRules": [
    {
      "trigger": "\n",
      "description": "Auto-indent new line and align block end keywords",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(function|macro|if|elseif|else|for|while|do|try|catch|finally|begin|let|struct|mutable struct|module|baremodule|quote|abstract type|primitive type)\\b.*$",
          "description": "Indent after block-opening keyword"
        },
        {
          "action": "indent",
          "pattern": "\\bdo\\s*$",
          "description": "Indent after do keyword"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*(end|else|elseif|catch|finally)\\b",
          "description": "Outdent end and mid-block keywords"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*(function|macro|if|for|while|do|try|begin|let|struct|mutable struct|module|quote)\\b.*$|\\bdo\\s*$",
    "decreasePattern": "^\\s*(end|else|elseif|catch|finally)\\b"
  }
}