{
  "language": "pla",
  "autoFormatTriggerCharacters": [";", "\n"],
  "formatRules": [
    {
      "trigger": ";",
      "description": "Format statement on semicolon",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s+;",
          "description": "Remove trailing whitespace before semicolon"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on PLA context",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(BEGIN|IF|DO|PROCEDURE)\\b",
          "description": "Indent after block-opening keyword"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*(END|ELSE)\\b",
          "description": "Outdent end keyword"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*(BEGIN|IF|DO|PROCEDURE)\\b",
    "decreasePattern": "^\\s*(END|ELSE)\\b"
  }
}