{
  "language": "sql",
  "autoFormatTriggerCharacters": ["\n"],
  "formatRules": [
    {
      "trigger": "\n",
      "description": "Auto-indent and align SQL keywords",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(SELECT|FROM|WHERE|GROUP BY|ORDER BY|HAVING|JOIN|LEFT JOIN|RIGHT JOIN|INNER JOIN|OUTER JOIN|CROSS JOIN|UNION|INTERSECT|EXCEPT|WITH|INSERT INTO|UPDATE|DELETE FROM|CREATE|ALTER|BEGIN|CASE)\\b",
          "description": "Align major SQL keywords"
        },
        {
          "action": "indent",
          "pattern": "\\(\\s*$",
          "description": "Indent after opening parenthesis in subquery"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*\\)",
          "description": "Outdent closing parenthesis"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(WHEN|THEN|ELSE)\\b",
          "description": "Indent CASE expression clauses"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*END\\b",
          "description": "Outdent END keyword to match CASE or BEGIN"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*(BEGIN|CASE|\\()\\s*$",
    "decreasePattern": "^\\s*(END|\\))\\b"
  }
}