{
  "language": "prisma",
  "displayName": "Prisma",
  "capabilities": {
    "onTypeFormatting": true
  },
  "triggerCharacters": [
    "\n",
    "}",
    ")"
  ],
  "rules": [
    {
      "trigger": "\n",
      "action": "indentNextLine",
      "description": "Auto-indent on new line in prisma"
    },
    {
      "trigger": "}",
      "action": "outdent",
      "description": "Outdent closing brace in prisma"
    }
  ]
}
