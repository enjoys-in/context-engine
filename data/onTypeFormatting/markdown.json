{
  "language": "markdown",
  "autoFormatTriggerCharacters": ["\n"],
  "formatRules": [
    {
      "trigger": "\n",
      "description": "Auto-continuation and formatting in Markdown",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*[-*+]\\s+",
          "description": "Continue unordered list item indentation"
        },
        {
          "action": "indent",
          "pattern": "^\\s*\\d+\\.\\s+",
          "description": "Continue ordered list item indentation"
        },
        {
          "action": "indent",
          "pattern": "^\\s*>\\s*",
          "description": "Continue blockquote prefix"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace except intentional line breaks"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*[-*+]\\s+|^\\s*\\d+\\.\\s+",
    "decreasePattern": "^\\s*$"
  }
}