{
  "language": "ssh_config",
  "autoFormatTriggerCharacters": ["\n", "="],
  "formatRules": [
    {
      "trigger": "=",
      "description": "Format around equals sign in config directives",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s{2,}=|=\\s{2,}",
          "description": "Normalize spacing around equals"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on Host/Match block context",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(Host|Match)\\b",
          "description": "Indent directives after Host or Match block header"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*(Host|Match)\\b",
    "decreasePattern": "^\\s*(Host|Match)\\b"
  }
}