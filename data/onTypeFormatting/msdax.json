{
  "language": "msdax",
  "autoFormatTriggerCharacters": [
    "\n",
    ";",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "\n",
      "description": "Auto-indent and align DAX expressions",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(EVALUATE|DEFINE|MEASURE|VAR|RETURN|SUMMARIZE|FILTER|CALCULATE|ADDCOLUMNS|SELECTCOLUMNS)\\b",
          "description": "Align major DAX keywords"
        },
        {
          "action": "indent",
          "pattern": "\\(\\s*$",
          "description": "Indent after opening parenthesis"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*\\)",
          "description": "Outdent closing parenthesis"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "\\(\\s*$|^\\s*(DEFINE|EVALUATE)\\b",
    "decreasePattern": "^\\s*\\)|^\\s*RETURN\\b"
  }
}
