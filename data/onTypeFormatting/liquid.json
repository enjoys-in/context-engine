{
  "language": "liquid",
  "autoFormatTriggerCharacters": [
    ">",
    "\n",
    ";",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": ">",
      "description": "Format after closing angle bracket",
      "rules": [
        {
          "action": "indent",
          "pattern": "<(?!area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)[a-zA-Z][^/]*>$",
          "description": "Indent after opening HTML tag"
        },
        {
          "action": "outdent",
          "pattern": "</[a-zA-Z][^>]*>$",
          "description": "Outdent closing HTML tag"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on Liquid template context",
      "rules": [
        {
          "action": "indent",
          "pattern": "\\{%[-\\s]*(if|unless|for|case|capture|form|paginate|tablerow|block|comment|raw|style|stylesheet|javascript)\\b",
          "description": "Indent after opening Liquid tag"
        },
        {
          "action": "indent",
          "pattern": "<(?!area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)[a-zA-Z][^/]*>\\s*$",
          "description": "Indent after opening HTML tag"
        },
        {
          "action": "outdent",
          "pattern": "\\{%[-\\s]*(endif|endunless|endfor|endcase|endcapture|endform|endpaginate|endtablerow|endblock|endcomment|endraw|endstyle|endstylesheet|endjavascript|else|elsif|when)\\b",
          "description": "Outdent closing Liquid tag"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*</",
          "description": "Outdent closing HTML tag"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "\\{%[-\\s]*(if|unless|for|case|capture|form|paginate|tablerow|block|comment|raw)\\b|<(?!area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)([a-zA-Z][^/]*)(?!/)>",
    "decreasePattern": "\\{%[-\\s]*(endif|endunless|endfor|endcase|endcapture|endform|endpaginate|endtablerow|endblock|endcomment|endraw|else|elsif|when)\\b|^\\s*</"
  }
}
