{
  "language": "lua",
  "autoFormatTriggerCharacters": [
    "\n",
    ";",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "\n",
      "description": "Auto-indent new line and align block end keywords",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(if|elseif|else|for|while|repeat|function|do|then)\\b.*$",
          "description": "Indent after block-opening keyword"
        },
        {
          "action": "indent",
          "pattern": "\\bthen\\s*$",
          "description": "Indent after then keyword"
        },
        {
          "action": "indent",
          "pattern": "\\bdo\\s*$",
          "description": "Indent after do keyword"
        },
        {
          "action": "indent",
          "pattern": "\\bfunction\\s*\\(.*\\)\\s*$",
          "description": "Indent after anonymous function"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*(end|else|elseif|until)\\b",
          "description": "Outdent end and mid-block keywords"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*(if|for|while|repeat|function)\\b.*$|\\b(then|do)\\s*$",
    "decreasePattern": "^\\s*(end|else|elseif|until)\\b"
  }
}
