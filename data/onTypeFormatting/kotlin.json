{
  "language": "kotlin",
  "autoFormatTriggerCharacters": [
    "}",
    ";",
    "\n",
    ":",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "}",
      "description": "Auto-indent closing brace to match opening brace",
      "rules": [
        {
          "action": "outdent",
          "pattern": "^\\s*\\}",
          "description": "Outdent closing brace to align with opening statement"
        },
        {
          "action": "alignBrackets",
          "pattern": "\\{[^}]*\\}",
          "description": "Align closing brace with its matching opening brace"
        }
      ]
    },
    {
      "trigger": ";",
      "description": "Format statement on semicolon",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s+;",
          "description": "Remove trailing whitespace before semicolon"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent new line based on context",
      "rules": [
        {
          "action": "indent",
          "pattern": "\\{\\s*$",
          "description": "Indent after opening brace"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(if|else|for|while|do|when|try|catch|finally)\\b.*$",
          "description": "Indent after control flow statement"
        },
        {
          "action": "indent",
          "pattern": "->\\s*$",
          "description": "Indent after when branch arrow"
        }
      ]
    },
    {
      "trigger": ":",
      "description": "Format after colon in class inheritance and type annotations",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(class|interface|object)\\s+\\w+\\s*:",
          "description": "Indent after class inheritance declaration"
        },
        {
          "action": "trimWhitespace",
          "pattern": ":\\s{2,}",
          "description": "Normalize spacing after type annotation colon"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "^.*\\{[^}]*$|^\\s*(if|else|for|while|do|when|try|catch|finally)\\b(?!.*\\{).*$",
    "decreasePattern": "^\\s*\\}"
  }
}
