{
  "language": "graphql",
  "autoFormatTriggerCharacters": ["}", "\n"],
  "formatRules": [
    {
      "trigger": "}",
      "description": "Auto-indent closing brace",
      "rules": [
        {
          "action": "outdent",
          "pattern": "^\\s*\\}",
          "description": "Outdent closing brace to match opening"
        },
        {
          "action": "alignBrackets",
          "pattern": "\\{[^}]*\\}",
          "description": "Align closing brace with opening"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent new line in GraphQL schema/query",
      "rules": [
        {
          "action": "indent",
          "pattern": "\\{\\s*$",
          "description": "Indent after opening brace"
        },
        {
          "action": "indent",
          "pattern": "\\(\\s*$",
          "description": "Indent after opening parenthesis for arguments"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*[})]",
          "description": "Outdent closing brace or parenthesis"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "[{(]\\s*$",
    "decreasePattern": "^\\s*[})]"
  }
}