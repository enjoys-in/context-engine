{
  "language": "perl",
  "autoFormatTriggerCharacters": ["}", ";", "\n"],
  "formatRules": [
    {
      "trigger": "}",
      "description": "Outdent closing brace",
      "rules": [
        {
          "action": "outdent",
          "pattern": "^\\s*\\}",
          "description": "Outdent closing brace to match opening"
        }
      ]
    },
    {
      "trigger": ";",
      "description": "Format statement on semicolon",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s+;",
          "description": "Remove trailing whitespace before semicolon"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on Perl context",
      "rules": [
        {
          "action": "indent",
          "pattern": "\\{\\s*$",
          "description": "Indent after opening brace"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(if|elsif|else|unless|while|until|for|foreach|do|eval|sub)\\b.*$",
          "description": "Indent after control flow or subroutine"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*\\}",
          "description": "Outdent closing brace"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "\\{\\s*$|^\\s*(if|elsif|else|unless|while|until|for|foreach|do|sub)\\b(?!.*\\{).*$",
    "decreasePattern": "^\\s*\\}"
  }
}