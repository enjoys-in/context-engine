{
  "language": "ruby",
  "autoFormatTriggerCharacters": [
    "\n",
    ";",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "\n",
      "description": "Auto-indent new line and align block end keywords",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(if|unless|while|until|for|do|def|class|module|begin|case|elsif|else|when|ensure|rescue)\\b.*$",
          "description": "Indent after block-opening keyword"
        },
        {
          "action": "indent",
          "pattern": "\\bdo\\s*(\\|.*\\|)?\\s*$",
          "description": "Indent after do block"
        },
        {
          "action": "indent",
          "pattern": "\\{\\s*(\\|.*\\|)?\\s*$",
          "description": "Indent after opening brace block"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*(end|else|elsif|when|rescue|ensure)\\b",
          "description": "Outdent end and mid-block keywords to align with opening"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*(if|unless|while|until|for|do|def|class|module|begin|case)\\b.*$|\\bdo\\s*(\\|.*\\|)?\\s*$|\\{\\s*(\\|.*\\|)?\\s*$",
    "decreasePattern": "^\\s*(end|else|elsif|when|rescue|ensure|\\})\\b"
  }
}
