{
  "language": "r",
  "autoFormatTriggerCharacters": ["}", ")", "\n"],
  "formatRules": [
    {
      "trigger": "}",
      "description": "Outdent closing brace",
      "rules": [
        {
          "action": "outdent",
          "pattern": "^\\s*\\}",
          "description": "Outdent closing brace to match opening"
        }
      ]
    },
    {
      "trigger": ")",
      "description": "Align closing parenthesis",
      "rules": [
        {
          "action": "alignBrackets",
          "pattern": "\\([^)]*\\)",
          "description": "Align closing paren with opening"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on R context",
      "rules": [
        {
          "action": "indent",
          "pattern": "\\{\\s*$",
          "description": "Indent after opening brace"
        },
        {
          "action": "indent",
          "pattern": "\\(\\s*$",
          "description": "Indent after opening parenthesis"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(if|else|for|while|repeat|function|tryCatch|withCallingHandlers)\\b.*$",
          "description": "Indent after control flow or function"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*[})]",
          "description": "Outdent closing brace or paren"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "[{(]\\s*$|^\\s*(if|else|for|while|repeat|function)\\b(?!.*\\{).*$",
    "decreasePattern": "^\\s*[})]"
  }
}