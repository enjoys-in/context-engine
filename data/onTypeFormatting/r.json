{
  "language": "r",
  "autoFormatTriggerCharacters": [
    "}",
    ")",
    "\n",
    ";"
  ],
  "formatRules": [
    {
      "trigger": "}",
      "description": "Outdent closing brace",
      "rules": [
        {
          "action": "outdent",
          "pattern": "^\\s*\\}",
          "description": "Outdent closing brace to match opening"
        }
      ]
    },
    {
      "trigger": ")",
      "description": "Align closing parenthesis",
      "rules": [
        {
          "action": "alignBrackets",
          "pattern": "\\([^)]*\\)",
          "description": "Align closing paren with opening"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on R context",
      "rules": [
        {
          "action": "indent",
          "pattern": "\\{\\s*$",
          "description": "Indent after opening brace"
        },
        {
          "action": "indent",
          "pattern": "\\(\\s*$",
          "description": "Indent after opening parenthesis"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(if|else|for|while|repeat|function|tryCatch|withCallingHandlers)\\b.*$",
          "description": "Indent after control flow or function"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*[})]",
          "description": "Outdent closing brace or paren"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "[{(]\\s*$|^\\s*(if|else|for|while|repeat|function)\\b(?!.*\\{).*$",
    "decreasePattern": "^\\s*[})]"
  }
}
