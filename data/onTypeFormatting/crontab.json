{
  "language": "crontab",
  "autoFormatTriggerCharacters": ["\n"],
  "formatRules": [
    {
      "trigger": "\n",
      "description": "Minimal formatting for crontab entries",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "$^",
    "decreasePattern": "$^"
  }
}