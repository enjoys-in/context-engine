{
  "language": "tailwindcss",
  "triggerCharacters": [
    ";",
    "}",
    "\n"
  ],
  "formatRules": [
    {
      "trigger": "{",
      "pattern": "@layer\\s+\\w+\\s*\\{$",
      "action": "indent",
      "options": {
        "indentSize": 2,
        "insertNewline": true
      }
    },
    {
      "trigger": "{",
      "pattern": "\\.[\\w-]+\\s*\\{$",
      "action": "indent",
      "options": {
        "indentSize": 2,
        "insertNewline": true
      }
    },
    {
      "trigger": ";",
      "pattern": "@apply\\s+[\\w\\s:-]+;$",
      "action": "formatLine",
      "options": {
        "trimTrailingWhitespace": true
      }
    },
    {
      "trigger": ";",
      "pattern": "@tailwind\\s+\\w+;$",
      "action": "formatLine",
      "options": {
        "trimTrailingWhitespace": true,
        "insertNewlineAfter": true
      }
    },
    {
      "trigger": "}",
      "pattern": "^\\s*\\}$",
      "action": "outdent",
      "options": {
        "insertNewlineAfter": true
      }
    },
    {
      "trigger": "\n",
      "pattern": "@layer\\s+\\w+\\s*\\{\\s*$",
      "action": "indent",
      "options": {
        "indentSize": 2
      }
    },
    {
      "trigger": "\n",
      "pattern": "@apply\\s+[\\w\\s:-]+;\\s*$",
      "action": "maintainIndent",
      "options": {}
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "autoFormatTriggerCharacters": [
    "\n",
    ";",
    "}",
    ")"
  ],
  "indentation": {
    "tabSize": 2,
    "insertSpaces": true
  }
}
