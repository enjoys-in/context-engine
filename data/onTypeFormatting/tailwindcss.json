{
  "language": "tailwindcss",
  "triggerCharacters": [";", "}", "\n"],
  "formatRules": [
    {
      "trigger": "{",
      "pattern": "@layer\\s+\\w+\\s*\\{$",
      "action": "indent",
      "options": {
        "indentSize": 2,
        "insertNewline": true
      }
    },
    {
      "trigger": "{",
      "pattern": "\\.[\\w-]+\\s*\\{$",
      "action": "indent",
      "options": {
        "indentSize": 2,
        "insertNewline": true
      }
    },
    {
      "trigger": ";",
      "pattern": "@apply\\s+[\\w\\s:-]+;$",
      "action": "formatLine",
      "options": {
        "trimTrailingWhitespace": true
      }
    },
    {
      "trigger": ";",
      "pattern": "@tailwind\\s+\\w+;$",
      "action": "formatLine",
      "options": {
        "trimTrailingWhitespace": true,
        "insertNewlineAfter": true
      }
    },
    {
      "trigger": "}",
      "pattern": "^\\s*\\}$",
      "action": "outdent",
      "options": {
        "insertNewlineAfter": true
      }
    },
    {
      "trigger": "\n",
      "pattern": "@layer\\s+\\w+\\s*\\{\\s*$",
      "action": "indent",
      "options": {
        "indentSize": 2
      }
    },
    {
      "trigger": "\n",
      "pattern": "@apply\\s+[\\w\\s:-]+;\\s*$",
      "action": "maintainIndent",
      "options": {}
    }
  ]
}