{
  "language": "sparql",
  "autoFormatTriggerCharacters": ["\n"],
  "formatRules": [
    {
      "trigger": "\n",
      "description": "Auto-indent and align SPARQL query keywords",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(SELECT|CONSTRUCT|ASK|DESCRIBE|WHERE|FILTER|OPTIONAL|UNION|MINUS|BIND|VALUES|SERVICE|PREFIX|BASE|ORDER BY|GROUP BY|HAVING|LIMIT|OFFSET)\\b",
          "description": "Align major SPARQL keywords"
        },
        {
          "action": "indent",
          "pattern": "\\{\\s*$",
          "description": "Indent after opening brace in graph pattern"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*\\}",
          "description": "Outdent closing brace"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "\\{\\s*$",
    "decreasePattern": "^\\s*\\}"
  }
}