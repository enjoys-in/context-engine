{
  "language": "abap",
  "autoFormatTriggerCharacters": ["\n", "."],
  "formatRules": [
    {
      "trigger": ".",
      "description": "Format statement on period (ABAP statement terminator)",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s+\\.",
          "description": "Remove trailing whitespace before period"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent new line based on ABAP block context",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(IF|ELSE|ELSEIF|DO|WHILE|LOOP|CASE|WHEN|TRY|CATCH|FORM|METHOD|FUNCTION|MODULE|CLASS|SELECT|PROVIDE)\\b",
          "description": "Indent after block-opening keyword"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*(ENDIF|ENDDO|ENDWHILE|ENDLOOP|ENDCASE|ENDTRY|ENDFORM|ENDMETHOD|ENDFUNCTION|ENDMODULE|ENDCLASS|ENDSELECT|ENDPROVIDE|ELSE|ELSEIF|WHEN|CATCH)\\b",
          "description": "Outdent block-closing or mid-block keyword"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*(IF|ELSE|ELSEIF|DO|WHILE|LOOP|CASE|WHEN|TRY|CATCH|FORM|METHOD|FUNCTION|MODULE|CLASS|SELECT)\\b",
    "decreasePattern": "^\\s*(ENDIF|ENDDO|ENDWHILE|ENDLOOP|ENDCASE|ENDTRY|ENDFORM|ENDMETHOD|ENDFUNCTION|ENDMODULE|ENDCLASS|ENDSELECT|ELSE|ELSEIF|WHEN|CATCH)\\b"
  }
}