{
  "language": "makefile",
  "autoFormatTriggerCharacters": [
    "\n",
    ";",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "\n",
      "description": "Auto-indent based on Makefile context",
      "rules": [
        {
          "action": "indent",
          "pattern": "^[^\\t#].*:\\s*$",
          "description": "Indent recipe lines after target rule"
        },
        {
          "action": "indent",
          "pattern": "\\\\\\s*$",
          "description": "Indent continuation line after backslash"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(define|ifdef|ifndef|ifeq|ifneq)\\b",
          "description": "Indent after conditional or define directive"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*(endef|endif|else)\\b",
          "description": "Outdent closing directive"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "^[^\\t#].*:\\s*$|^\\s*(define|ifdef|ifndef|ifeq|ifneq)\\b",
    "decreasePattern": "^\\s*(endef|endif|else)\\b"
  }
}
