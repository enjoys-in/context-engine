{
  "language": "makefile",
  "autoFormatTriggerCharacters": ["\n"],
  "formatRules": [
    {
      "trigger": "\n",
      "description": "Auto-indent based on Makefile context",
      "rules": [
        {
          "action": "indent",
          "pattern": "^[^\\t#].*:\\s*$",
          "description": "Indent recipe lines after target rule"
        },
        {
          "action": "indent",
          "pattern": "\\\\\\s*$",
          "description": "Indent continuation line after backslash"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(define|ifdef|ifndef|ifeq|ifneq)\\b",
          "description": "Indent after conditional or define directive"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*(endef|endif|else)\\b",
          "description": "Outdent closing directive"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "^[^\\t#].*:\\s*$|^\\s*(define|ifdef|ifndef|ifeq|ifneq)\\b",
    "decreasePattern": "^\\s*(endef|endif|else)\\b"
  }
}