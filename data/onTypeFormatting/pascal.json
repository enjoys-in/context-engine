{
  "language": "pascal",
  "autoFormatTriggerCharacters": [
    ";",
    "\n",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": ";",
      "description": "Format statement on semicolon",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s+;",
          "description": "Remove trailing whitespace before semicolon"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on Pascal block context",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(begin|if|else|for|while|repeat|case|try|with|record|class|interface|object)\\b",
          "description": "Indent after block-opening keyword"
        },
        {
          "action": "indent",
          "pattern": "\\bthen\\s*$",
          "description": "Indent after then"
        },
        {
          "action": "indent",
          "pattern": "\\bdo\\s*$",
          "description": "Indent after do"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*(end|else|until|except|finally)\\b",
          "description": "Outdent end and mid-block keywords"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*(begin|if|for|while|repeat|case|try|with|record|class)\\b|\\b(then|do)\\s*$",
    "decreasePattern": "^\\s*(end|else|until|except|finally)\\b"
  }
}
