{
  "language": "restructuredtext",
  "autoFormatTriggerCharacters": [
    "\n",
    ";",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "\n",
      "description": "Auto-indent and continuation in reStructuredText",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*\\.\\. \\w+::",
          "description": "Indent after directive"
        },
        {
          "action": "indent",
          "pattern": "^\\s*[-*+]\\s+",
          "description": "Continue list item indentation"
        },
        {
          "action": "indent",
          "pattern": "^\\s*\\d+\\.\\s+",
          "description": "Continue numbered list indentation"
        },
        {
          "action": "indent",
          "pattern": "::$",
          "description": "Indent after literal block marker"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*\\.\\. \\w+::|::$",
    "decreasePattern": "^\\s*$"
  }
}
