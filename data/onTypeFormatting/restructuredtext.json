{
  "language": "restructuredtext",
  "autoFormatTriggerCharacters": ["\n"],
  "formatRules": [
    {
      "trigger": "\n",
      "description": "Auto-indent and continuation in reStructuredText",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*\\.\\. \\w+::",
          "description": "Indent after directive"
        },
        {
          "action": "indent",
          "pattern": "^\\s*[-*+]\\s+",
          "description": "Continue list item indentation"
        },
        {
          "action": "indent",
          "pattern": "^\\s*\\d+\\.\\s+",
          "description": "Continue numbered list indentation"
        },
        {
          "action": "indent",
          "pattern": "::$",
          "description": "Indent after literal block marker"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*\\.\\. \\w+::|::$",
    "decreasePattern": "^\\s*$"
  }
}