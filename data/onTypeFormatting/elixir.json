{
  "language": "elixir",
  "autoFormatTriggerCharacters": [
    "\n",
    ";",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "\n",
      "description": "Auto-indent new line and align block end keywords",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(if|unless|cond|case|fn|def|defp|defmodule|defmacro|defmacrop|defprotocol|defimpl|do|else|with|for|try|catch|rescue|after)\\b.*$",
          "description": "Indent after block-opening keyword"
        },
        {
          "action": "indent",
          "pattern": "\\bdo\\s*$",
          "description": "Indent after do keyword"
        },
        {
          "action": "indent",
          "pattern": "->\\s*$",
          "description": "Indent after arrow in case/cond/fn clause"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*(end|else|catch|rescue|after)\\b",
          "description": "Outdent end and mid-block keywords"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*(if|unless|cond|case|fn|def|defp|defmodule|defmacro|do|with|for|try)\\b.*$|\\bdo\\s*$|->\\s*$",
    "decreasePattern": "^\\s*(end|else|catch|rescue|after)\\b"
  }
}
