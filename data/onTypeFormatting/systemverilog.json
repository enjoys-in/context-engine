{
  "language": "systemverilog",
  "autoFormatTriggerCharacters": [
    ";",
    "\n",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": ";",
      "description": "Format statement on semicolon",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s+;",
          "description": "Remove trailing whitespace before semicolon"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on SystemVerilog block context",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(module|function|task|class|interface|package|program|generate|always|always_ff|always_comb|always_latch|initial|begin|fork|case|casex|casez|if|else|for|foreach|while|do|repeat|forever|covergroup|property|sequence|constraint)\\b",
          "description": "Indent after block-opening keyword"
        },
        {
          "action": "indent",
          "pattern": "\\bbegin\\b\\s*$",
          "description": "Indent after begin keyword"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*(end|endmodule|endfunction|endtask|endclass|endinterface|endpackage|endprogram|endgenerate|endcase|endgroup|endproperty|endsequence|join|join_any|join_none|else)\\b",
          "description": "Outdent block-closing keyword"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*(module|function|task|class|interface|package|program|generate|always|initial|begin|fork|case|if|for|foreach|while|do|repeat|forever|covergroup)\\b",
    "decreasePattern": "^\\s*(end|endmodule|endfunction|endtask|endclass|endinterface|endpackage|endprogram|endgenerate|endcase|endgroup|join|join_any|join_none|else)\\b"
  }
}
