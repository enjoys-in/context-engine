{
  "language": "dotenv",
  "autoFormatTriggerCharacters": [
    "\n",
    "=",
    ";",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "=",
      "description": "Format around equals sign in environment variable definitions",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s+=",
          "description": "Remove whitespace before equals sign"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Minimal formatting on newline",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "$^",
    "decreasePattern": "$^"
  }
}
