{
  "language": "html",
  "autoFormatTriggerCharacters": [">", "\n"],
  "formatRules": [
    {
      "trigger": ">",
      "description": "Format after closing angle bracket of a tag",
      "rules": [
        {
          "action": "indent",
          "pattern": "<(?!area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)[a-zA-Z][^/]*>$",
          "description": "Indent after opening tag that is not self-closing or void"
        },
        {
          "action": "outdent",
          "pattern": "</[a-zA-Z][^>]*>$",
          "description": "Outdent closing tag to match opening tag"
        },
        {
          "action": "insertNewline",
          "pattern": "><",
          "description": "Insert newline between consecutive tags"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent new line based on tag context",
      "rules": [
        {
          "action": "indent",
          "pattern": "<(?!area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)[a-zA-Z][^/]*>\\s*$",
          "description": "Indent after opening tag"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*</",
          "description": "Outdent for closing tag"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "<(?!area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)([a-zA-Z][^/]*)(?!/)>",
    "decreasePattern": "^\\s*</"
  }
}