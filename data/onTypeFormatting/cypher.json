{
  "language": "cypher",
  "autoFormatTriggerCharacters": [
    "\n",
    ";",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "\n",
      "description": "Auto-indent and align Cypher query keywords",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(MATCH|OPTIONAL MATCH|WHERE|WITH|RETURN|ORDER BY|SKIP|LIMIT|CREATE|MERGE|DELETE|DETACH DELETE|SET|REMOVE|FOREACH|UNWIND|CALL|YIELD|UNION)\\b",
          "description": "Align major Cypher keywords"
        },
        {
          "action": "indent",
          "pattern": "\\{\\s*$",
          "description": "Indent after opening brace in map literal"
        },
        {
          "action": "indent",
          "pattern": "\\[\\s*$",
          "description": "Indent after opening bracket in list"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*[}\\]]",
          "description": "Outdent closing brace or bracket"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "[{\\[]\\s*$",
    "decreasePattern": "^\\s*[}\\]]"
  }
}
