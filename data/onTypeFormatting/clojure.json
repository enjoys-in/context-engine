{
  "language": "clojure",
  "autoFormatTriggerCharacters": [")", "\n"],
  "formatRules": [
    {
      "trigger": ")",
      "description": "Align closing parenthesis with its matching open",
      "rules": [
        {
          "action": "alignBrackets",
          "pattern": "\\([^)]*\\)",
          "description": "Align closing paren with opening paren"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*[)\\]]+",
          "description": "Outdent line of closing delimiters"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent new line based on S-expression context",
      "rules": [
        {
          "action": "indent",
          "pattern": "\\(\\s*(defn|defn-|def|fn|let|loop|if|when|cond|case|do|doseq|dotimes|for|ns|defmacro|defmethod|defmulti|defprotocol|defrecord|deftype|reify|proxy)\\b",
          "description": "Indent after special form opening"
        },
        {
          "action": "indent",
          "pattern": "[\\(\\[\\{]\\s*$",
          "description": "Indent after opening delimiter"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "[\\(\\[\\{][^)\\]\\}]*$",
    "decreasePattern": "^\\s*[)\\]\\}]"
  }
}