{
  "language": "twig",
  "autoFormatTriggerCharacters": [
    ">",
    "\n",
    ";",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": ">",
      "description": "Format after closing angle bracket",
      "rules": [
        {
          "action": "indent",
          "pattern": "<(?!area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)[a-zA-Z][^/]*>$",
          "description": "Indent after opening HTML tag"
        },
        {
          "action": "outdent",
          "pattern": "</[a-zA-Z][^>]*>$",
          "description": "Outdent closing HTML tag"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on Twig template context",
      "rules": [
        {
          "action": "indent",
          "pattern": "\\{%[-\\s]*(block|if|elseif|else|for|macro|filter|embed|autoescape|apply|set.*%}.*\\{%[-\\s]*set|spaceless|verbatim|with)\\b",
          "description": "Indent after opening Twig tag"
        },
        {
          "action": "indent",
          "pattern": "<(?!area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)[a-zA-Z][^/]*>\\s*$",
          "description": "Indent after opening HTML tag"
        },
        {
          "action": "outdent",
          "pattern": "\\{%[-\\s]*(endblock|endif|endfor|endmacro|endfilter|endembed|endautoescape|endapply|endspaceless|endverbatim|endwith|else|elseif)\\b",
          "description": "Outdent closing Twig tag"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*</",
          "description": "Outdent closing HTML tag"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "\\{%[-\\s]*(block|if|for|macro|filter|embed|autoescape|apply|spaceless|verbatim|with)\\b|<(?!area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)([a-zA-Z][^/]*)(?!/)>",
    "decreasePattern": "\\{%[-\\s]*(endblock|endif|endfor|endmacro|endfilter|endembed|endautoescape|endapply|endspaceless|endverbatim|endwith|else|elseif)\\b|^\\s*</"
  }
}
