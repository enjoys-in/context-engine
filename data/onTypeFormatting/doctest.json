{
  "language": "doctest",
  "autoFormatTriggerCharacters": ["\n"],
  "formatRules": [
    {
      "trigger": "\n",
      "description": "Auto-indent continuation in doctest blocks",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*>>>\\s+.*:\\s*$",
          "description": "Indent after doctest prompt with block statement"
        },
        {
          "action": "indent",
          "pattern": "^\\s*\\.\\.\\.\\s+",
          "description": "Maintain continuation indent"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*>>>\\s+.*:\\s*$",
    "decreasePattern": "^\\s*$"
  }
}