{
  "language": "wgsl",
  "autoFormatTriggerCharacters": ["}", ";", "\n", ":"],
  "formatRules": [
    {
      "trigger": "}",
      "description": "Auto-indent closing brace",
      "rules": [
        {
          "action": "outdent",
          "pattern": "^\\s*\\}",
          "description": "Outdent closing brace to match opening"
        },
        {
          "action": "alignBrackets",
          "pattern": "\\{[^}]*\\}",
          "description": "Align closing brace with opening"
        }
      ]
    },
    {
      "trigger": ";",
      "description": "Format statement on semicolon",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s+;",
          "description": "Remove trailing whitespace before semicolon"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on WGSL context",
      "rules": [
        {
          "action": "indent",
          "pattern": "\\{\\s*$",
          "description": "Indent after opening brace"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(fn|if|else|for|while|loop|switch|struct|var|let|const|override)\\b.*$",
          "description": "Indent after control flow or declaration"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*\\}",
          "description": "Outdent closing brace"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": ":",
      "description": "Format after colon in type annotations",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": ":\\s{2,}",
          "description": "Normalize spacing after type annotation colon"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "\\{\\s*$|^\\s*(fn|if|else|for|while|loop|switch|struct)\\b(?!.*\\{).*$",
    "decreasePattern": "^\\s*\\}"
  }
}