{
  "language": "cpp",
  "autoFormatTriggerCharacters": [
    "}",
    ";",
    "\n",
    ":",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "}",
      "description": "Auto-indent closing brace to match opening brace",
      "rules": [
        {
          "action": "outdent",
          "pattern": "^\\s*\\}",
          "description": "Outdent closing brace to align with opening statement"
        },
        {
          "action": "alignBrackets",
          "pattern": "\\{[^}]*\\}",
          "description": "Align closing brace with its matching opening brace"
        }
      ]
    },
    {
      "trigger": ";",
      "description": "Format statement on semicolon",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s+;",
          "description": "Remove trailing whitespace before semicolon"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(for|while|if)\\s*\\(",
          "description": "Maintain indentation for control flow statements"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent new line based on context",
      "rules": [
        {
          "action": "indent",
          "pattern": "\\{\\s*$",
          "description": "Indent after opening brace"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(if|else|for|while|do|switch|class|struct|namespace|template)\\b.*$",
          "description": "Indent after control flow or declaration statement"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(public|private|protected)\\s*:",
          "description": "Indent after access specifier"
        }
      ]
    },
    {
      "trigger": ":",
      "description": "Format after colon in switch cases, access specifiers, and initializer lists",
      "rules": [
        {
          "action": "outdent",
          "pattern": "^\\s*(case\\s+.+|default)\\s*:",
          "description": "Align case labels with switch statement"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*(public|private|protected)\\s*:",
          "description": "Outdent access specifiers"
        },
        {
          "action": "indent",
          "pattern": "^\\s*\\w+\\s*\\(.*\\)\\s*:",
          "description": "Indent initializer list after constructor"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "^.*\\{[^}]*$|^\\s*(if|else|for|while|do|switch|class|struct|namespace)\\b(?!.*\\{).*$",
    "decreasePattern": "^\\s*(\\}|public:|private:|protected:)"
  }
}
