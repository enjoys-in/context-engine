{
  "language": "razor",
  "autoFormatTriggerCharacters": [">", "\n"],
  "formatRules": [
    {
      "trigger": ">",
      "description": "Format after closing angle bracket of a tag",
      "rules": [
        {
          "action": "indent",
          "pattern": "<(?!area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)[a-zA-Z][^/]*>$",
          "description": "Indent after opening tag"
        },
        {
          "action": "outdent",
          "pattern": "</[a-zA-Z][^>]*>$",
          "description": "Outdent closing tag to match opening tag"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent new line based on context",
      "rules": [
        {
          "action": "indent",
          "pattern": "<(?!area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)[a-zA-Z][^/]*>\\s*$",
          "description": "Indent after opening tag"
        },
        {
          "action": "indent",
          "pattern": "@(if|else|for|foreach|while|switch|try|catch|finally|using|lock)\\b.*$",
          "description": "Indent after Razor control flow directive"
        },
        {
          "action": "indent",
          "pattern": "@\\{\\s*$",
          "description": "Indent after Razor code block opening"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*(</|\\})",
          "description": "Outdent for closing tag or brace"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "<(?!area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)([a-zA-Z][^/]*)(?!/)>|@\\{\\s*$|@(if|for|foreach|while|switch)\\b",
    "decreasePattern": "^\\s*(</|\\})"
  }
}