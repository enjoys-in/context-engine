{
  "language": "scss",
  "autoFormatTriggerCharacters": [
    "}",
    ";",
    "\n",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "}",
      "description": "Auto-indent closing brace",
      "rules": [
        {
          "action": "outdent",
          "pattern": "^\\s*\\}",
          "description": "Outdent closing brace to match selector"
        },
        {
          "action": "alignBrackets",
          "pattern": "\\{[^}]*\\}",
          "description": "Align closing brace with opening"
        }
      ]
    },
    {
      "trigger": ";",
      "description": "Format property declaration on semicolon",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s+;",
          "description": "Remove trailing whitespace before semicolon"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on SCSS context",
      "rules": [
        {
          "action": "indent",
          "pattern": "\\{\\s*$",
          "description": "Indent after opening brace in rule or mixin block"
        },
        {
          "action": "indent",
          "pattern": "^\\s*@(mixin|include|if|else|for|each|while|function)\\b.*\\{\\s*$",
          "description": "Indent after SCSS directive block"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*\\}",
          "description": "Outdent closing brace"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "\\{\\s*$",
    "decreasePattern": "^\\s*\\}"
  }
}
