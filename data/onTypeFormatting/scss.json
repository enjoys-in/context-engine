{
  "language": "scss",
  "autoFormatTriggerCharacters": ["}", ";", "\n"],
  "formatRules": [
    {
      "trigger": "}",
      "description": "Auto-indent closing brace",
      "rules": [
        {
          "action": "outdent",
          "pattern": "^\\s*\\}",
          "description": "Outdent closing brace to match selector"
        },
        {
          "action": "alignBrackets",
          "pattern": "\\{[^}]*\\}",
          "description": "Align closing brace with opening"
        }
      ]
    },
    {
      "trigger": ";",
      "description": "Format property declaration on semicolon",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s+;",
          "description": "Remove trailing whitespace before semicolon"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on SCSS context",
      "rules": [
        {
          "action": "indent",
          "pattern": "\\{\\s*$",
          "description": "Indent after opening brace in rule or mixin block"
        },
        {
          "action": "indent",
          "pattern": "^\\s*@(mixin|include|if|else|for|each|while|function)\\b.*\\{\\s*$",
          "description": "Indent after SCSS directive block"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*\\}",
          "description": "Outdent closing brace"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "\\{\\s*$",
    "decreasePattern": "^\\s*\\}"
  }
}