{
  "language": "sb",
  "autoFormatTriggerCharacters": [
    "\n",
    ";",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "\n",
      "description": "Auto-indent based on Small Basic block context",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(If|ElseIf|Else|For|While|Sub)\\b",
          "description": "Indent after block-opening keyword"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*(EndIf|EndFor|EndWhile|EndSub|Else|ElseIf)\\b",
          "description": "Outdent block-closing keyword"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*(If|ElseIf|Else|For|While|Sub)\\b",
    "decreasePattern": "^\\s*(EndIf|EndFor|EndWhile|EndSub|Else|ElseIf)\\b"
  }
}
