{
  "language": "bicep",
  "autoFormatTriggerCharacters": [
    "\n",
    "=",
    ";",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "=",
      "description": "Format around equals sign in property assignments",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s{2,}=|=\\s{2,}",
          "description": "Normalize spacing around equals"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on Bicep block context",
      "rules": [
        {
          "action": "indent",
          "pattern": "\\{\\s*$",
          "description": "Indent after opening brace"
        },
        {
          "action": "indent",
          "pattern": "\\[\\s*$",
          "description": "Indent after opening bracket"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(resource|module|param|var|output|targetScope|type)\\b.*\\{\\s*$",
          "description": "Indent after Bicep resource declaration"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*[}\\]]",
          "description": "Outdent closing brace or bracket"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "[{\\[]\\s*$",
    "decreasePattern": "^\\s*[}\\]]"
  }
}
