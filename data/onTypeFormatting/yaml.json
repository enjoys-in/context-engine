{
  "language": "yaml",
  "autoFormatTriggerCharacters": ["\n"],
  "formatRules": [
    {
      "trigger": "\n",
      "description": "Auto-indent new line based on YAML structure",
      "rules": [
        {
          "action": "indent",
          "pattern": ":\\s*$",
          "description": "Indent after key with no inline value"
        },
        {
          "action": "indent",
          "pattern": "^\\s*-\\s+.*:\\s*$",
          "description": "Indent after list item with nested mapping"
        },
        {
          "action": "indent",
          "pattern": "\\|\\s*$",
          "description": "Indent after literal block scalar indicator"
        },
        {
          "action": "indent",
          "pattern": ">\\s*$",
          "description": "Indent after folded block scalar indicator"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*\\S+.*:\\s*$|^\\s*-\\s+.*:\\s*$|[|>][-+]?\\s*$",
    "decreasePattern": "^\\s*$"
  }
}