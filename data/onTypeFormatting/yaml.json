{
  "language": "yaml",
  "autoFormatTriggerCharacters": [
    "\n",
    ";",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "\n",
      "description": "Auto-indent new line based on YAML structure",
      "rules": [
        {
          "action": "indent",
          "pattern": ":\\s*$",
          "description": "Indent after key with no inline value"
        },
        {
          "action": "indent",
          "pattern": "^\\s*-\\s+.*:\\s*$",
          "description": "Indent after list item with nested mapping"
        },
        {
          "action": "indent",
          "pattern": "\\|\\s*$",
          "description": "Indent after literal block scalar indicator"
        },
        {
          "action": "indent",
          "pattern": ">\\s*$",
          "description": "Indent after folded block scalar indicator"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*\\S+.*:\\s*$|^\\s*-\\s+.*:\\s*$|[|>][-+]?\\s*$",
    "decreasePattern": "^\\s*$"
  }
}
