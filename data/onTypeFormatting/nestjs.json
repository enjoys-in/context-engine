{
  "language": "nestjs",
  "autoFormatTriggerCharacters": [
    "}",
    ";",
    "\n",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "}",
      "description": "Auto-indent closing brace",
      "pattern": "^(\\s*)\\}",
      "action": "matchIndent",
      "referencePattern": "\\{\\s*$"
    },
    {
      "trigger": ";",
      "description": "Trim trailing spaces before semicolon",
      "pattern": "\\s+;$",
      "replacement": ";"
    },
    {
      "trigger": "\n",
      "description": "Continue JSDoc comment",
      "pattern": "^\\s*\\*\\s",
      "action": "continueComment",
      "insertText": " * "
    },
    {
      "trigger": "\n",
      "description": "Auto-indent after opening brace",
      "pattern": "\\{\\s*$",
      "action": "indent"
    },
    {
      "trigger": "\n",
      "description": "Auto-indent after decorator",
      "pattern": "^\\s*@\\w+\\([^)]*\\)\\s*$",
      "action": "keepIndent"
    },
    {
      "trigger": "\n",
      "description": "Auto-indent after arrow function",
      "pattern": "=>\\s*\\{?\\s*$",
      "action": "indent"
    },
    {
      "trigger": "\n",
      "description": "Indent after class declaration",
      "pattern": "class\\s+\\w+[^{]*\\{\\s*$",
      "action": "indent"
    },
    {
      "trigger": "\n",
      "description": "Indent after module metadata",
      "pattern": "@Module\\(\\{\\s*$",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "\\{\\s*$",
    "decreasePattern": "^\\s*\\}"
  }
}
