{
  "language": "protobuf",
  "autoFormatTriggerCharacters": ["}", ";", "\n"],
  "formatRules": [
    {
      "trigger": "}",
      "description": "Auto-indent closing brace",
      "rules": [
        {
          "action": "outdent",
          "pattern": "^\\s*\\}",
          "description": "Outdent closing brace to match opening"
        },
        {
          "action": "alignBrackets",
          "pattern": "\\{[^}]*\\}",
          "description": "Align closing brace with opening"
        }
      ]
    },
    {
      "trigger": ";",
      "description": "Format field declaration on semicolon",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s+;",
          "description": "Remove trailing whitespace before semicolon"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent new line in protobuf definition",
      "rules": [
        {
          "action": "indent",
          "pattern": "\\{\\s*$",
          "description": "Indent after opening brace"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(message|enum|service|oneof|extend|rpc)\\b.*\\{\\s*$",
          "description": "Indent after protobuf block declaration"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*\\}",
          "description": "Outdent closing brace"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "\\{\\s*$",
    "decreasePattern": "^\\s*\\}"
  }
}