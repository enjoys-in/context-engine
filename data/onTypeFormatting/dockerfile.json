{
  "language": "dockerfile",
  "autoFormatTriggerCharacters": [
    "\n",
    "=",
    ";",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "=",
      "description": "Format around equals sign in ENV and ARG directives",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s{2,}=|=\\s{2,}",
          "description": "Normalize spacing around equals"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent new line based on Dockerfile context",
      "rules": [
        {
          "action": "indent",
          "pattern": "\\\\\\s*$",
          "description": "Indent continuation line after backslash"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(RUN|CMD|ENTRYPOINT|COPY|ADD|ENV|ARG|LABEL|EXPOSE|VOLUME|WORKDIR|USER|HEALTHCHECK|SHELL|FROM|MAINTAINER)\\b",
          "description": "Maintain alignment for Dockerfile instructions"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "\\\\\\s*$",
    "decreasePattern": "^\\s*(FROM|RUN|CMD|ENTRYPOINT|COPY|ADD)\\b"
  }
}
