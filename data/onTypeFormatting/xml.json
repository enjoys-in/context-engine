{
  "language": "xml",
  "autoFormatTriggerCharacters": [
    ">",
    "\n",
    ";",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": ">",
      "description": "Format after closing angle bracket of a tag",
      "rules": [
        {
          "action": "indent",
          "pattern": "<[a-zA-Z][^/]*[^/]>$",
          "description": "Indent after opening tag"
        },
        {
          "action": "outdent",
          "pattern": "</[a-zA-Z][^>]*>$",
          "description": "Outdent closing tag to match opening tag"
        },
        {
          "action": "insertNewline",
          "pattern": "><",
          "description": "Insert newline between consecutive tags"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent new line based on tag context",
      "rules": [
        {
          "action": "indent",
          "pattern": "<[a-zA-Z][^/]*[^/]>\\s*$",
          "description": "Indent after opening tag"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*</",
          "description": "Outdent for closing tag"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "<[a-zA-Z][^/]*[^/]>",
    "decreasePattern": "^\\s*</"
  }
}
