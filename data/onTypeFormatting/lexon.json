{
  "language": "lexon",
  "autoFormatTriggerCharacters": ["\n", "."],
  "formatRules": [
    {
      "trigger": ".",
      "description": "Format after period (sentence terminator)",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s+\\.",
          "description": "Remove trailing whitespace before period"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on Lexon clause context",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(LEX|CLAUSE|TERMS|PROVISIONS)\\b",
          "description": "Indent after major section keyword"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*(LEX|CLAUSE|TERMS|PROVISIONS)\\b",
    "decreasePattern": "^\\s*(LEX|CLAUSE)\\b"
  }
}