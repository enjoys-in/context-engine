{
  "language": "tcl",
  "autoFormatTriggerCharacters": [
    "}",
    "\n",
    ";",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "}",
      "description": "Outdent closing brace",
      "rules": [
        {
          "action": "outdent",
          "pattern": "^\\s*\\}",
          "description": "Outdent closing brace to match opening"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on Tcl context",
      "rules": [
        {
          "action": "indent",
          "pattern": "\\{\\s*$",
          "description": "Indent after opening brace"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(proc|if|elseif|else|for|foreach|while|switch|catch|try)\\b.*\\{\\s*$",
          "description": "Indent after control flow with opening brace"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*\\}",
          "description": "Outdent closing brace"
        },
        {
          "action": "indent",
          "pattern": "\\\\\\s*$",
          "description": "Indent continuation line"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "\\{\\s*$",
    "decreasePattern": "^\\s*\\}"
  }
}
