{
  "language": "caddy",
  "autoFormatTriggerCharacters": ["\n", "="],
  "formatRules": [
    {
      "trigger": "=",
      "description": "Format around equals in environment variable placeholders",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s{2,}=",
          "description": "Normalize whitespace"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on Caddyfile block context",
      "rules": [
        {
          "action": "indent",
          "pattern": "\\{\\s*$",
          "description": "Indent after opening brace"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*\\}",
          "description": "Outdent closing brace"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "\\{\\s*$",
    "decreasePattern": "^\\s*\\}"
  }
}