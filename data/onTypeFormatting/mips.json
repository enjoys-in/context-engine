{
  "language": "mips",
  "autoFormatTriggerCharacters": [
    "\n",
    ";",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "\n",
      "description": "Auto-indent based on MIPS assembly context",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*\\.(text|data|globl|align|space|word|byte|half|ascii|asciiz)\\b",
          "description": "Maintain alignment after assembler directive"
        },
        {
          "action": "indent",
          "pattern": "^\\w+:\\s*$",
          "description": "Indent instructions after label"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "^\\w+:\\s*$",
    "decreasePattern": "^\\w+:"
  }
}
