{
  "language": "powerquery",
  "autoFormatTriggerCharacters": [
    "\n",
    ";",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "\n",
      "description": "Auto-indent based on Power Query M context",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(let|in|if|then|else|each|try|otherwise|section)\\b",
          "description": "Indent after keyword"
        },
        {
          "action": "indent",
          "pattern": "\\[\\s*$",
          "description": "Indent after opening bracket"
        },
        {
          "action": "indent",
          "pattern": "\\{\\s*$",
          "description": "Indent after opening brace"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*[}\\]]",
          "description": "Outdent closing delimiter"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*in\\b",
          "description": "Outdent in keyword to match let"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*let\\b|[{\\[]\\s*$",
    "decreasePattern": "^\\s*(in|[}\\]])\\b"
  }
}
