{
  "language": "ecl",
  "autoFormatTriggerCharacters": [
    ";",
    "\n",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": ";",
      "description": "Format statement on semicolon",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s+;",
          "description": "Remove trailing whitespace before semicolon"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent new line based on ECL context",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(IF|ELSEIF|ELSE|FUNCTION|MODULE|RECORD|TRANSFORM|MACRO|BEGINC\\+\\+)\\b",
          "description": "Indent after block-opening keyword"
        },
        {
          "action": "indent",
          "pattern": ":=\\s*$",
          "description": "Indent after assignment operator"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*(END|ENDMACRO|ENDC\\+\\+)\\b",
          "description": "Outdent block-closing keyword"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*(IF|FUNCTION|MODULE|RECORD|TRANSFORM|MACRO|BEGINC\\+\\+)\\b",
    "decreasePattern": "^\\s*(END|ENDMACRO|ENDC\\+\\+)\\b"
  }
}
