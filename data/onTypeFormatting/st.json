{
  "language": "st",
  "autoFormatTriggerCharacters": [";", "\n"],
  "formatRules": [
    {
      "trigger": ";",
      "description": "Format statement on semicolon",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s+;",
          "description": "Remove trailing whitespace before semicolon"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on Structured Text block context",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(IF|ELSIF|ELSE|FOR|WHILE|REPEAT|CASE|FUNCTION|FUNCTION_BLOCK|PROGRAM|VAR|VAR_INPUT|VAR_OUTPUT|VAR_IN_OUT|VAR_GLOBAL|STRUCT|ACTION|METHOD)\\b",
          "description": "Indent after block-opening keyword"
        },
        {
          "action": "indent",
          "pattern": "\\bTHEN\\s*$",
          "description": "Indent after THEN"
        },
        {
          "action": "indent",
          "pattern": "\\bDO\\s*$",
          "description": "Indent after DO"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*(END_IF|END_FOR|END_WHILE|END_REPEAT|END_CASE|END_FUNCTION|END_FUNCTION_BLOCK|END_PROGRAM|END_VAR|END_STRUCT|END_ACTION|END_METHOD|ELSE|ELSIF|UNTIL)\\b",
          "description": "Outdent block-closing keyword"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*(IF|FOR|WHILE|REPEAT|CASE|FUNCTION|FUNCTION_BLOCK|PROGRAM|VAR|STRUCT|ACTION|METHOD)\\b|\\b(THEN|DO)\\s*$",
    "decreasePattern": "^\\s*(END_IF|END_FOR|END_WHILE|END_REPEAT|END_CASE|END_FUNCTION|END_FUNCTION_BLOCK|END_PROGRAM|END_VAR|END_STRUCT|END_ACTION|END_METHOD|ELSE|ELSIF|UNTIL)\\b"
  }
}