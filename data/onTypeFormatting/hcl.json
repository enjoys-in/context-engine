{
  "language": "hcl",
  "autoFormatTriggerCharacters": ["\n", "="],
  "formatRules": [
    {
      "trigger": "=",
      "description": "Format around equals sign in attribute assignments",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s{2,}=|=\\s{2,}",
          "description": "Normalize spacing around equals sign"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on HCL block context",
      "rules": [
        {
          "action": "indent",
          "pattern": "\\{\\s*$",
          "description": "Indent after opening brace"
        },
        {
          "action": "indent",
          "pattern": "\\[\\s*$",
          "description": "Indent after opening bracket"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*[}\\]]",
          "description": "Outdent closing brace or bracket"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "[{\\[]\\s*$",
    "decreasePattern": "^\\s*[}\\]]"
  }
}