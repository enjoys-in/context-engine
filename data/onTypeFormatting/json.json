{
  "language": "json",
  "autoFormatTriggerCharacters": [
    "}",
    "\n",
    ";",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "}",
      "description": "Auto-indent closing brace",
      "rules": [
        {
          "action": "outdent",
          "pattern": "^\\s*[}\\]]",
          "description": "Outdent closing brace or bracket to match opening"
        },
        {
          "action": "alignBrackets",
          "pattern": "[{\\[][^}\\]]*[}\\]]",
          "description": "Align closing delimiter with opening"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent new line in JSON structure",
      "rules": [
        {
          "action": "indent",
          "pattern": "[{\\[]\\s*$",
          "description": "Indent after opening brace or bracket"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*[}\\]]",
          "description": "Outdent for closing brace or bracket"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "[{\\[]\\s*$",
    "decreasePattern": "^\\s*[}\\]]"
  }
}
