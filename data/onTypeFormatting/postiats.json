{
  "language": "postiats",
  "autoFormatTriggerCharacters": [
    ")",
    "\n",
    ";",
    "}"
  ],
  "formatRules": [
    {
      "trigger": ")",
      "description": "Align closing parenthesis",
      "rules": [
        {
          "action": "alignBrackets",
          "pattern": "\\([^)]*\\)",
          "description": "Align closing paren with opening"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on ATS context",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(fun|fn|val|var|let|local|if|then|else|case|begin|implement|extern|staload|dynload|datavtype|datatype|datasort|typedef)\\b",
          "description": "Indent after block-opening keyword"
        },
        {
          "action": "indent",
          "pattern": "=>\\s*$",
          "description": "Indent after arrow in case expression"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*(end|in|\\||\\))\\b",
          "description": "Outdent end and mid-block keywords"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*(fun|fn|val|var|let|local|if|case|begin|implement)\\b|=>\\s*$",
    "decreasePattern": "^\\s*(end|in|\\|)\\b"
  }
}
