{
  "language": "dart",
  "autoFormatTriggerCharacters": ["}", ";", "\n", ":"],
  "formatRules": [
    {
      "trigger": "}",
      "description": "Auto-indent closing brace to match opening brace",
      "rules": [
        {
          "action": "outdent",
          "pattern": "^\\s*\\}",
          "description": "Outdent closing brace to align with opening statement"
        },
        {
          "action": "alignBrackets",
          "pattern": "\\{[^}]*\\}",
          "description": "Align closing brace with its matching opening brace"
        }
      ]
    },
    {
      "trigger": ";",
      "description": "Format statement on semicolon",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s+;",
          "description": "Remove trailing whitespace before semicolon"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(for|while|if)\\s*\\(",
          "description": "Maintain indentation for control flow statements"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent new line based on context",
      "rules": [
        {
          "action": "indent",
          "pattern": "\\{\\s*$",
          "description": "Indent after opening brace"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(if|else|for|while|do|switch|try|catch|finally)\\b.*$",
          "description": "Indent after control flow statement"
        },
        {
          "action": "indent",
          "pattern": "=>\\s*$",
          "description": "Indent after arrow expression"
        }
      ]
    },
    {
      "trigger": ":",
      "description": "Format after colon in switch cases and named parameters",
      "rules": [
        {
          "action": "outdent",
          "pattern": "^\\s*(case\\s+.+|default)\\s*:",
          "description": "Align case labels with switch statement"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(case\\s+.+|default)\\s*:$",
          "description": "Indent next line after case label"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "^.*\\{[^}]*$|^\\s*(if|else|for|while|do|switch|try|catch|finally)\\b(?!.*\\{).*$",
    "decreasePattern": "^\\s*\\}"
  }
}