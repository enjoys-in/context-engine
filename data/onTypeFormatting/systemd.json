{
  "language": "systemd",
  "autoFormatTriggerCharacters": ["\n", "="],
  "formatRules": [
    {
      "trigger": "=",
      "description": "Format around equals sign in unit file directives",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s+=|=\\s+",
          "description": "Remove whitespace around equals sign"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on section context",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*\\[.*\\]\\s*$",
          "description": "Maintain alignment after section header"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*\\[.*\\]\\s*$",
    "decreasePattern": "^\\s*\\[.*\\]\\s*$"
  }
}