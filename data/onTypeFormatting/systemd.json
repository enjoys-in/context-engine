{
  "language": "systemd",
  "autoFormatTriggerCharacters": [
    "\n",
    "=",
    ";",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "=",
      "description": "Format around equals sign in unit file directives",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s+=|=\\s+",
          "description": "Remove whitespace around equals sign"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on section context",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*\\[.*\\]\\s*$",
          "description": "Maintain alignment after section header"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*\\[.*\\]\\s*$",
    "decreasePattern": "^\\s*\\[.*\\]\\s*$"
  }
}
