{
  "language": "m3",
  "autoFormatTriggerCharacters": [";", "\n"],
  "formatRules": [
    {
      "trigger": ";",
      "description": "Format statement on semicolon",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s+;",
          "description": "Remove trailing whitespace before semicolon"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on Modula-3 block context",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(BEGIN|IF|FOR|WHILE|REPEAT|CASE|TRY|LOCK|WITH|PROCEDURE|MODULE|INTERFACE|TYPECASE)\\b",
          "description": "Indent after block-opening keyword"
        },
        {
          "action": "indent",
          "pattern": "\\bTHEN\\s*$",
          "description": "Indent after THEN"
        },
        {
          "action": "indent",
          "pattern": "\\bDO\\s*$",
          "description": "Indent after DO"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*(END|ELSE|ELSIF|EXCEPT|FINALLY|UNTIL)\\b",
          "description": "Outdent end and mid-block keywords"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*(BEGIN|IF|FOR|WHILE|REPEAT|CASE|TRY|LOCK|WITH|PROCEDURE)\\b|\\b(THEN|DO)\\s*$",
    "decreasePattern": "^\\s*(END|ELSE|ELSIF|EXCEPT|FINALLY|UNTIL)\\b"
  }
}