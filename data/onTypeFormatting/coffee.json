{
  "language": "coffee",
  "autoFormatTriggerCharacters": ["\n"],
  "formatRules": [
    {
      "trigger": "\n",
      "description": "Auto-indent new line based on indentation context",
      "rules": [
        {
          "action": "indent",
          "pattern": "->\\s*$",
          "description": "Indent after function arrow"
        },
        {
          "action": "indent",
          "pattern": "=>\\s*$",
          "description": "Indent after fat arrow"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(if|else|unless|for|while|until|switch|when|try|catch|finally|class)\\b.*$",
          "description": "Indent after control flow statement"
        },
        {
          "action": "indent",
          "pattern": ":\\s*$",
          "description": "Indent after colon in object literal"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*(return|break|continue|throw)\\b",
          "description": "Outdent after terminal statement"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*(if|else|unless|for|while|until|switch|when|try|catch|finally|class)\\b.*$|[=-]>\\s*$",
    "decreasePattern": "^\\s*(return|break|continue|throw)\\b"
  }
}