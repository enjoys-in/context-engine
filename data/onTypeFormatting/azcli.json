{
  "language": "azcli",
  "autoFormatTriggerCharacters": ["\n"],
  "formatRules": [
    {
      "trigger": "\n",
      "description": "Auto-indent based on Azure CLI command context",
      "rules": [
        {
          "action": "indent",
          "pattern": "\\\\\\s*$",
          "description": "Indent continuation line after backslash"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "\\\\\\s*$",
    "decreasePattern": "^\\s*az\\b"
  }
}