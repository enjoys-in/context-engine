{
  "language": "ssh-config",
  "autoFormatTriggerCharacters": [
    "\n",
    "=",
    ";",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "=",
      "description": "Format around equals sign in config directives",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s{2,}=|=\\s{2,}",
          "description": "Normalize spacing around equals"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on Host/Match block context",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(Host|Match)\\b",
          "description": "Indent directives after Host or Match block header"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*(Host|Match)\\b",
    "decreasePattern": "^\\s*(Host|Match)\\b"
  }
}
