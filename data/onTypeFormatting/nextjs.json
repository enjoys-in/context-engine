{
  "language": "nextjs",
  "autoFormatTriggerCharacters": [
    "}",
    ";",
    "\n",
    ">",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "}",
      "description": "Auto-indent closing brace",
      "pattern": "^(\\s*)\\}",
      "action": "matchIndent",
      "referencePattern": "\\{\\s*$"
    },
    {
      "trigger": ";",
      "description": "Trim trailing spaces before semicolon",
      "pattern": "\\s+;$",
      "replacement": ";"
    },
    {
      "trigger": "\n",
      "description": "Continue JSDoc comment",
      "pattern": "^\\s*\\*\\s",
      "action": "continueComment",
      "insertText": " * "
    },
    {
      "trigger": "\n",
      "description": "Auto-indent after opening brace",
      "pattern": "\\{\\s*$",
      "action": "indent"
    },
    {
      "trigger": "\n",
      "description": "Auto-indent after arrow function",
      "pattern": "=>\\s*$",
      "action": "indent"
    },
    {
      "trigger": "\n",
      "description": "Auto-indent JSX children",
      "pattern": "<[A-Z][a-zA-Z0-9]*[^/]*>\\s*$",
      "action": "indent"
    },
    {
      "trigger": ">",
      "description": "Auto-close JSX tag",
      "pattern": "<([a-zA-Z][a-zA-Z0-9.]*)(?:\\s[^>]*)?>$",
      "action": "closeTag",
      "insertText": "</$1>"
    },
    {
      "trigger": "\n",
      "description": "Auto-indent after return (",
      "pattern": "return\\s*\\(\\s*$",
      "action": "indent"
    },
    {
      "trigger": "\n",
      "description": "Indent after export default",
      "pattern": "export\\s+default\\s+function\\s+\\w+\\([^)]*\\)\\s*\\{\\s*$",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "\\{\\s*$",
    "decreasePattern": "^\\s*\\}"
  }
}
