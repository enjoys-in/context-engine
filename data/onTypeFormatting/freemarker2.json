{
  "language": "freemarker2",
  "autoFormatTriggerCharacters": [
    ">",
    "\n",
    ";",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": ">",
      "description": "Format after closing angle bracket of FreeMarker tag",
      "rules": [
        {
          "action": "indent",
          "pattern": "<#(if|list|macro|function|switch|attempt|recover)\\b[^>]*>$",
          "description": "Indent after opening FreeMarker directive"
        },
        {
          "action": "outdent",
          "pattern": "</#(if|list|macro|function|switch|attempt|recover)>$",
          "description": "Outdent closing FreeMarker directive"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on FreeMarker template context",
      "rules": [
        {
          "action": "indent",
          "pattern": "<#(if|list|macro|function|switch|attempt)\\b[^>]*>\\s*$",
          "description": "Indent after opening FreeMarker directive"
        },
        {
          "action": "indent",
          "pattern": "<(?!area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)[a-zA-Z][^/]*>\\s*$",
          "description": "Indent after HTML opening tag"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*(</#|</)",
          "description": "Outdent closing directive or tag"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "<#(if|list|macro|function|switch|attempt)\\b|<(?!area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)([a-zA-Z][^/]*)(?!/)>",
    "decreasePattern": "^\\s*(</#|</)"
  }
}
