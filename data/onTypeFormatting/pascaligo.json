{
  "language": "pascaligo",
  "autoFormatTriggerCharacters": [
    ")",
    "\n",
    ";",
    "}"
  ],
  "formatRules": [
    {
      "trigger": ")",
      "description": "Align closing parenthesis",
      "rules": [
        {
          "action": "alignBrackets",
          "pattern": "\\([^)]*\\)",
          "description": "Align closing paren with opening paren"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*\\)",
          "description": "Outdent closing parenthesis"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent new line based on PascaLIGO context",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(function|procedure|if|then|else|case|for|while|with|begin|block|record|type|const|var)\\b.*$",
          "description": "Indent after block-opening keyword"
        },
        {
          "action": "indent",
          "pattern": "\\bis\\s*$",
          "description": "Indent after is keyword"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*(end|\\})\\b",
          "description": "Outdent end keyword"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*(function|procedure|if|case|for|while|begin|block|record)\\b.*$|\\bis\\s*$",
    "decreasePattern": "^\\s*end\\b"
  }
}
