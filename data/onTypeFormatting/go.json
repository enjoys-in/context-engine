{
  "language": "go",
  "autoFormatTriggerCharacters": [
    "}",
    ";",
    "\n",
    ":",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "}",
      "description": "Auto-indent closing brace to match opening brace",
      "rules": [
        {
          "action": "outdent",
          "pattern": "^\\s*\\}",
          "description": "Outdent closing brace to align with opening statement"
        },
        {
          "action": "alignBrackets",
          "pattern": "\\{[^}]*\\}",
          "description": "Align closing brace with its matching opening brace"
        }
      ]
    },
    {
      "trigger": ";",
      "description": "Format statement on implicit semicolon insertion",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Trim trailing whitespace at end of statement"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent new line based on context",
      "rules": [
        {
          "action": "indent",
          "pattern": "\\{\\s*$",
          "description": "Indent after opening brace"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(if|else|for|switch|select|func|go|defer)\\b.*$",
          "description": "Indent after control flow or function statement"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(var|const|type)\\s*\\($",
          "description": "Indent after grouped declaration"
        }
      ]
    },
    {
      "trigger": ":",
      "description": "Format after colon in switch cases and short variable declarations",
      "rules": [
        {
          "action": "outdent",
          "pattern": "^\\s*(case\\s+.+|default)\\s*:",
          "description": "Align case labels with switch statement"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(case\\s+.+|default)\\s*:$",
          "description": "Indent next line after case label"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "^.*\\{[^}]*$|^\\s*(if|else|for|switch|select|func)\\b(?!.*\\{).*$",
    "decreasePattern": "^\\s*\\}"
  }
}
