{
  "language": "cameligo",
  "autoFormatTriggerCharacters": [
    ")",
    "\n",
    ";",
    "}"
  ],
  "formatRules": [
    {
      "trigger": ")",
      "description": "Align closing parenthesis",
      "rules": [
        {
          "action": "alignBrackets",
          "pattern": "\\([^)]*\\)",
          "description": "Align closing paren with opening paren"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*\\)",
          "description": "Outdent closing parenthesis"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent new line based on ML expression context",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(let|type|module|if|then|else|match|fun|function|begin)\\b.*$",
          "description": "Indent after block-opening keyword"
        },
        {
          "action": "indent",
          "pattern": "=\\s*$",
          "description": "Indent after equals in let binding"
        },
        {
          "action": "indent",
          "pattern": "->\\s*$",
          "description": "Indent after arrow in match case"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*(end|\\||in)\\b",
          "description": "Outdent end, pipe, and in keywords"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*(let|type|module|if|match|fun|function|begin)\\b.*$|[=]\\s*$|->\\s*$",
    "decreasePattern": "^\\s*(end|\\||in)\\b"
  }
}
