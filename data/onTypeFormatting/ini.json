{
  "language": "ini",
  "autoFormatTriggerCharacters": ["\n", "="],
  "formatRules": [
    {
      "trigger": "=",
      "description": "Format around equals sign in key-value pairs",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s+=\\s+",
          "description": "Normalize spacing around equals sign"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent new line in INI file",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*\\[.*\\]\\s*$",
          "description": "Maintain indentation after section header"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*\\[.*\\]\\s*$",
    "decreasePattern": "^\\s*\\[.*\\]\\s*$"
  }
}