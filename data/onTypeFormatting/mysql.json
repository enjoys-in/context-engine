{
  "language": "mysql",
  "autoFormatTriggerCharacters": [
    "\n",
    ";",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "\n",
      "description": "Auto-indent and align MySQL keywords",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(SELECT|FROM|WHERE|GROUP BY|ORDER BY|HAVING|JOIN|LEFT JOIN|RIGHT JOIN|INNER JOIN|OUTER JOIN|CROSS JOIN|UNION|INSERT INTO|UPDATE|DELETE FROM|CREATE|ALTER|BEGIN|CASE|DELIMITER)\\b",
          "description": "Align major MySQL keywords"
        },
        {
          "action": "indent",
          "pattern": "\\(\\s*$",
          "description": "Indent after opening parenthesis in subquery"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*\\)",
          "description": "Outdent closing parenthesis"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(WHEN|THEN|ELSE)\\b",
          "description": "Indent CASE expression clauses"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*END\\b",
          "description": "Outdent END keyword"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*(BEGIN|CASE|\\()\\s*$",
    "decreasePattern": "^\\s*(END|\\))\\b"
  }
}
