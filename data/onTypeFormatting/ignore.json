{
  "language": "ignore",
  "displayName": "Ignore Files",
  "capabilities": {
    "onTypeFormatting": true
  },
  "triggerCharacters": [
    "\n"
  ],
  "rules": [
    {
      "trigger": "\n",
      "action": "indentNextLine",
      "description": "Auto-indent on new line in ignore"
    },
    {
      "trigger": "}",
      "action": "outdent",
      "description": "Outdent closing brace in ignore"
    }
  ]
}
