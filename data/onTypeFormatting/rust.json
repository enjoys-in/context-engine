{
  "language": "rust",
  "autoFormatTriggerCharacters": ["}", ";", "\n", ":"],
  "formatRules": [
    {
      "trigger": "}",
      "description": "Auto-indent closing brace to match opening brace",
      "rules": [
        {
          "action": "outdent",
          "pattern": "^\\s*\\}",
          "description": "Outdent closing brace to align with opening statement"
        },
        {
          "action": "alignBrackets",
          "pattern": "\\{[^}]*\\}",
          "description": "Align closing brace with its matching opening brace"
        }
      ]
    },
    {
      "trigger": ";",
      "description": "Format statement on semicolon",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s+;",
          "description": "Remove trailing whitespace before semicolon"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(let|const|static)\\b",
          "description": "Maintain indentation for variable declarations"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent new line based on context",
      "rules": [
        {
          "action": "indent",
          "pattern": "\\{\\s*$",
          "description": "Indent after opening brace"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(if|else|for|while|loop|match|fn|impl|struct|enum|trait|mod)\\b.*$",
          "description": "Indent after control flow or declaration statement"
        },
        {
          "action": "indent",
          "pattern": "=>\\s*\\{?\\s*$",
          "description": "Indent after match arm arrow"
        }
      ]
    },
    {
      "trigger": ":",
      "description": "Format after colon in type annotations and struct fields",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": ":\\s{2,}",
          "description": "Normalize spacing after type annotation colon"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "^.*\\{[^}]*$|^\\s*(if|else|for|while|loop|match)\\b(?!.*\\{).*$",
    "decreasePattern": "^\\s*\\}"
  }
}