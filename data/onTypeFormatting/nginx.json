{
  "language": "nginx",
  "autoFormatTriggerCharacters": [
    "\n",
    "=",
    ";",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "=",
      "description": "Format around equals in location matching",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s{2,}=",
          "description": "Normalize whitespace before equals"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on nginx block context",
      "rules": [
        {
          "action": "indent",
          "pattern": "\\{\\s*$",
          "description": "Indent after opening brace"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(server|location|http|events|upstream|stream|map|geo|types|if)\\b.*\\{\\s*$",
          "description": "Indent after block directive with opening brace"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*\\}",
          "description": "Outdent closing brace"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "\\{\\s*$",
    "decreasePattern": "^\\s*\\}"
  }
}
