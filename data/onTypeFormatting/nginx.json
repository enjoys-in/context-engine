{
  "language": "nginx",
  "autoFormatTriggerCharacters": ["\n", "="],
  "formatRules": [
    {
      "trigger": "=",
      "description": "Format around equals in location matching",
      "rules": [
        {
          "action": "trimWhitespace",
          "pattern": "\\s{2,}=",
          "description": "Normalize whitespace before equals"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent based on nginx block context",
      "rules": [
        {
          "action": "indent",
          "pattern": "\\{\\s*$",
          "description": "Indent after opening brace"
        },
        {
          "action": "indent",
          "pattern": "^\\s*(server|location|http|events|upstream|stream|map|geo|types|if)\\b.*\\{\\s*$",
          "description": "Indent after block directive with opening brace"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*\\}",
          "description": "Outdent closing brace"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "\\{\\s*$",
    "decreasePattern": "^\\s*\\}"
  }
}