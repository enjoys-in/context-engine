{
  "language": "scheme",
  "autoFormatTriggerCharacters": [")", "\n"],
  "formatRules": [
    {
      "trigger": ")",
      "description": "Align closing parenthesis with its matching open",
      "rules": [
        {
          "action": "alignBrackets",
          "pattern": "\\([^)]*\\)",
          "description": "Align closing paren with opening paren"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*\\)+",
          "description": "Outdent line of closing parentheses"
        }
      ]
    },
    {
      "trigger": "\n",
      "description": "Auto-indent new line based on S-expression context",
      "rules": [
        {
          "action": "indent",
          "pattern": "\\(\\s*(define|lambda|let|let\\*|letrec|if|cond|case|when|unless|begin|do)\\b",
          "description": "Indent after special form opening"
        },
        {
          "action": "indent",
          "pattern": "\\(\\s*$",
          "description": "Indent after opening parenthesis"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace"
        }
      ]
    }
  ],
  "indentation": {
    "increasePattern": "\\([^)]*$",
    "decreasePattern": "^\\s*\\)"
  }
}