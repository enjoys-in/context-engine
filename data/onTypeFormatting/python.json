{
  "language": "python",
  "autoFormatTriggerCharacters": [
    "\n",
    ":",
    ";",
    "}",
    ")"
  ],
  "formatRules": [
    {
      "trigger": "\n",
      "description": "Auto-indent new line based on context",
      "rules": [
        {
          "action": "indent",
          "pattern": ":\\s*$",
          "description": "Indent after colon ending a block statement"
        },
        {
          "action": "indent",
          "pattern": "\\\\\\s*$",
          "description": "Indent continuation line after backslash"
        },
        {
          "action": "indent",
          "pattern": "[({\\[]\\s*$",
          "description": "Indent after opening bracket, paren, or brace"
        },
        {
          "action": "outdent",
          "pattern": "^\\s*(return|break|continue|raise|pass)\\b",
          "description": "Outdent after terminal statement"
        },
        {
          "action": "trimWhitespace",
          "pattern": "\\s+$",
          "description": "Remove trailing whitespace on previous line"
        }
      ]
    },
    {
      "trigger": ":",
      "description": "Format after colon in block statements and slices",
      "rules": [
        {
          "action": "indent",
          "pattern": "^\\s*(if|elif|else|for|while|with|try|except|finally|def|class|async\\s+def|async\\s+for|async\\s+with)\\b.*:$",
          "description": "Indent next line after block statement colon"
        }
      ]
    },
    {
      "trigger": "{",
      "description": "Auto-indent after opening brace",
      "action": "indent"
    },
    {
      "trigger": "}",
      "description": "Auto-dedent closing brace",
      "action": "outdent"
    },
    {
      "trigger": ":",
      "description": "Auto-indent after colon",
      "action": "indent",
      "context": "afterCaseOrLabel"
    },
    {
      "trigger": "\n",
      "description": "Trim trailing whitespace on Enter",
      "action": "trimTrailing"
    },
    {
      "trigger": "\n",
      "description": "Continue comment on Enter",
      "action": "continueComment",
      "pattern": "^\\s*(\\*|//|#)"
    },
    {
      "trigger": ")",
      "description": "Close bracket auto-format",
      "action": "matchIndent"
    }
  ],
  "indentation": {
    "increasePattern": "^\\s*(if|elif|else|for|while|with|try|except|finally|def|class|async\\s+def|async\\s+for|async\\s+with)\\b.*:\\s*$",
    "decreasePattern": "^\\s*(return|break|continue|raise|pass)\\b"
  }
}
