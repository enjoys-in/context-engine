{
  "language": "prisma",
  "definitions": {
    "model": {
      "signature": "model ModelName { ... }",
      "description": "Defines a data model that maps to a database table or collection. Contains field definitions, attributes, and relations.",
      "type": "keyword",
      "module": "schema",
      "url": "https://www.prisma.io/docs/orm/prisma-schema/data-model/models"
    },
    "enum": {
      "signature": "enum EnumName { VALUE1 VALUE2 }",
      "description": "Defines an enum type with a fixed set of allowed values.",
      "type": "keyword",
      "module": "schema",
      "url": "https://www.prisma.io/docs/orm/prisma-schema/data-model/models#defining-enums"
    },
    "datasource": {
      "signature": "datasource db { provider = \"...\" url = \"...\" }",
      "description": "Configures the database connection including provider type and connection URL.",
      "type": "keyword",
      "module": "schema",
      "url": "https://www.prisma.io/docs/orm/prisma-schema/overview/datasources"
    },
    "generator": {
      "signature": "generator client { provider = \"...\" }",
      "description": "Configures code generators such as Prisma Client.",
      "type": "keyword",
      "module": "schema",
      "url": "https://www.prisma.io/docs/orm/prisma-schema/overview/generators"
    },
    "type": {
      "signature": "type TypeName { ... }",
      "description": "Defines a composite type for embedded documents (MongoDB only).",
      "type": "keyword",
      "module": "schema",
      "url": "https://www.prisma.io/docs/orm/prisma-schema/data-model/models#defining-composite-types"
    },
    "view": {
      "signature": "view ViewName { ... }",
      "description": "Declares a database view (preview feature).",
      "type": "keyword",
      "module": "schema",
      "url": "https://www.prisma.io/docs/orm/prisma-schema/data-model/views"
    },
    "String": {
      "signature": "String",
      "description": "Variable-length text scalar type. Maps to TEXT, VARCHAR, etc.",
      "type": "class",
      "module": "scalar_types",
      "url": "https://www.prisma.io/docs/orm/prisma-schema/data-model/models#scalar-fields"
    },
    "Int": {
      "signature": "Int",
      "description": "32-bit integer scalar type.",
      "type": "class",
      "module": "scalar_types"
    },
    "BigInt": {
      "signature": "BigInt",
      "description": "64-bit integer scalar type for large numbers.",
      "type": "class",
      "module": "scalar_types"
    },
    "Float": {
      "signature": "Float",
      "description": "Floating-point number scalar type.",
      "type": "class",
      "module": "scalar_types"
    },
    "Decimal": {
      "signature": "Decimal",
      "description": "Exact decimal number scalar type for precision calculations.",
      "type": "class",
      "module": "scalar_types"
    },
    "Boolean": {
      "signature": "Boolean",
      "description": "True/false boolean scalar type.",
      "type": "class",
      "module": "scalar_types"
    },
    "DateTime": {
      "signature": "DateTime",
      "description": "Date and time scalar type. Maps to TIMESTAMP, DATETIME, etc.",
      "type": "class",
      "module": "scalar_types"
    },
    "Json": {
      "signature": "Json",
      "description": "JSON data scalar type.",
      "type": "class",
      "module": "scalar_types"
    },
    "Bytes": {
      "signature": "Bytes",
      "description": "Binary data scalar type. Maps to BYTEA, BLOB, etc.",
      "type": "class",
      "module": "scalar_types"
    },
    "@id": {
      "signature": "@id",
      "description": "Marks a field as the primary key of the model.",
      "type": "function",
      "module": "attributes",
      "url": "https://www.prisma.io/docs/orm/prisma-schema/data-model/models#defining-an-id-field"
    },
    "@unique": {
      "signature": "@unique",
      "description": "Adds a unique constraint to the field.",
      "type": "function",
      "module": "attributes"
    },
    "@default": {
      "signature": "@default(value)",
      "description": "Sets a default value for the field. Accepts static values or functions like autoincrement(), uuid(), cuid(), now(), dbgenerated().",
      "type": "function",
      "module": "attributes",
      "url": "https://www.prisma.io/docs/orm/prisma-schema/data-model/models#defining-a-default-value"
    },
    "@relation": {
      "signature": "@relation(fields: [...], references: [...])",
      "description": "Defines the relation between two models, specifying the foreign key field and the referenced field.",
      "type": "function",
      "module": "attributes",
      "url": "https://www.prisma.io/docs/orm/prisma-schema/data-model/relations"
    },
    "@map": {
      "signature": "@map(\"column_name\")",
      "description": "Maps a Prisma field name to a different database column name.",
      "type": "function",
      "module": "attributes"
    },
    "@updatedAt": {
      "signature": "@updatedAt",
      "description": "Automatically updates the DateTime field to the current timestamp on every update.",
      "type": "function",
      "module": "attributes"
    },
    "@ignore": {
      "signature": "@ignore",
      "description": "Excludes a field from the Prisma Client API.",
      "type": "function",
      "module": "attributes"
    },
    "@@id": {
      "signature": "@@id([field1, field2])",
      "description": "Defines a composite primary key on the model.",
      "type": "function",
      "module": "block_attributes"
    },
    "@@unique": {
      "signature": "@@unique([field1, field2])",
      "description": "Defines a composite unique constraint on the model.",
      "type": "function",
      "module": "block_attributes"
    },
    "@@index": {
      "signature": "@@index([field1, field2])",
      "description": "Defines a database index on one or more fields.",
      "type": "function",
      "module": "block_attributes"
    },
    "@@map": {
      "signature": "@@map(\"table_name\")",
      "description": "Maps the model name to a different database table name.",
      "type": "function",
      "module": "block_attributes"
    },
    "@@ignore": {
      "signature": "@@ignore",
      "description": "Excludes the entire model from the Prisma Client API.",
      "type": "function",
      "module": "block_attributes"
    },
    "@@fulltext": {
      "signature": "@@fulltext([field1, field2])",
      "description": "Defines a full-text search index on the model.",
      "type": "function",
      "module": "block_attributes"
    },
    "@@schema": {
      "signature": "@@schema(\"schema_name\")",
      "description": "Assigns the model to a specific database schema (multi-schema feature).",
      "type": "function",
      "module": "block_attributes"
    },
    "autoincrement": {
      "signature": "autoincrement()",
      "description": "Generates an auto-incrementing integer value for the field.",
      "type": "function",
      "module": "default_functions"
    },
    "uuid": {
      "signature": "uuid()",
      "description": "Generates a UUID v4 value.",
      "type": "function",
      "module": "default_functions"
    },
    "cuid": {
      "signature": "cuid()",
      "description": "Generates a CUID (collision-resistant unique identifier).",
      "type": "function",
      "module": "default_functions"
    },
    "now": {
      "signature": "now()",
      "description": "Sets the default to the current date and time.",
      "type": "function",
      "module": "default_functions"
    },
    "dbgenerated": {
      "signature": "dbgenerated(\"expression\")",
      "description": "Uses a database-level expression for the default value.",
      "type": "function",
      "module": "default_functions"
    },
    "env": {
      "signature": "env(\"ENV_VAR_NAME\")",
      "description": "References an environment variable.",
      "type": "function",
      "module": "functions"
    }
  }
}