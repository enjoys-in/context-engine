      "type": "function",
      "module": "Numeric"
    },
    "POWER": {
      "signature": "POWER(base, exponent)",
      "description": "Raise a number to a power.",
      "type": "function",
      "module": "Numeric"
    },
    "SQRT": {
      "signature": "SQRT(n)",
