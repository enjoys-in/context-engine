{
  "language": "elixir",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ],
      [
        "<<",
        ">>"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'",
      "\"\"\""
    ],
    "blockPatterns": [
      {
        "start": "\\bdefmodule\\b",
        "end": "\\bend\\b",
        "description": "Module definition block"
      },
      {
        "start": "\\bdef\\b|\\bdefp\\b",
        "end": "\\bend\\b",
        "description": "Function definition block"
      },
      {
        "start": "\\bdo\\b",
        "end": "\\bend\\b",
        "description": "Do-end block"
      },
      {
        "start": "\\bcase\\b",
        "end": "\\bend\\b",
        "description": "Case expression block"
      },
      {
        "start": "\\bcond\\b",
        "end": "\\bend\\b",
        "description": "Cond expression block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "clause",
      "block",
      "function",
      "module",
      "file"
    ]
  }
}