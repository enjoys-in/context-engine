{
  "language": "elixir",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ],
      [
        "<<",
        ">>"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'",
      "\"\"\""
    ],
    "blockPatterns": [
      {
        "start": "\\bdefmodule\\b",
        "end": "\\bend\\b",
        "description": "Module definition block"
      },
      {
        "start": "\\bdef\\b|\\bdefp\\b",
        "end": "\\bend\\b",
        "description": "Function definition block"
      },
      {
        "start": "\\bdo\\b",
        "end": "\\bend\\b",
        "description": "Do-end block"
      },
      {
        "start": "\\bcase\\b",
        "end": "\\bend\\b",
        "description": "Case expression block"
      },
      {
        "start": "\\bcond\\b",
        "end": "\\bend\\b",
        "description": "Cond expression block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "clause",
      "block",
      "function",
      "module",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
