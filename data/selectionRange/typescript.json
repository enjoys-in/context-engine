{
  "language": "typescript",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"], ["<", ">"]],
    "stringDelimiters": ["\"", "'", "`"],
    "blockPatterns": [
      {
        "start": "\\bfunction\\b.*\\{|=>\\s*\\{",
        "end": "\\}",
        "description": "Function declaration/expression block"
      },
      {
        "start": "\\bclass\\s+\\w+",
        "end": "\\}",
        "description": "Class declaration block"
      },
      {
        "start": "\\binterface\\s+\\w+",
        "end": "\\}",
        "description": "Interface declaration block"
      },
      {
        "start": "\\bif\\s*\\(",
        "end": "\\}",
        "description": "If conditional block"
      },
      {
        "start": "\\b(for|for\\s+of|for\\s+in|while)\\s*\\(",
        "end": "\\}",
        "description": "Loop block"
      },
      {
        "start": "\\bnamespace\\s+\\w+",
        "end": "\\}",
        "description": "Namespace block"
      },
      {
        "start": "\\benum\\s+\\w+",
        "end": "\\}",
        "description": "Enum declaration block"
      }
    ],
    "expansionHierarchy": ["word", "expression", "statement", "block", "function", "class", "namespace", "module", "file"]
  }
}