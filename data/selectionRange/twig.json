{
  "language": "twig",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\{%\\s*block\\s+\\w+",
        "end": "\\{%\\s*endblock\\s*%\\}",
        "description": "Block definition"
      },
      {
        "start": "\\{%\\s*if\\b",
        "end": "\\{%\\s*endif\\s*%\\}",
        "description": "If conditional block"
      },
      {
        "start": "\\{%\\s*for\\b",
        "end": "\\{%\\s*endfor\\s*%\\}",
        "description": "For loop block"
      },
      {
        "start": "\\{%\\s*macro\\s+\\w+",
        "end": "\\{%\\s*endmacro\\s*%\\}",
        "description": "Macro definition block"
      },
      {
        "start": "\\{\\{",
        "end": "\\}\\}",
        "description": "Output expression"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "filter",
      "tag",
      "block",
      "template",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
