{
  "language": "twig",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\{%\\s*block\\s+\\w+",
        "end": "\\{%\\s*endblock\\s*%\\}",
        "description": "Block definition"
      },
      {
        "start": "\\{%\\s*if\\b",
        "end": "\\{%\\s*endif\\s*%\\}",
        "description": "If conditional block"
      },
      {
        "start": "\\{%\\s*for\\b",
        "end": "\\{%\\s*endfor\\s*%\\}",
        "description": "For loop block"
      },
      {
        "start": "\\{%\\s*macro\\s+\\w+",
        "end": "\\{%\\s*endmacro\\s*%\\}",
        "description": "Macro definition block"
      },
      {
        "start": "\\{\\{",
        "end": "\\}\\}",
        "description": "Output expression"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "filter",
      "tag",
      "block",
      "template",
      "file"
    ]
  }
}