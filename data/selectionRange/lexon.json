{
  "language": "lexon",
  "selectionRanges": {
    "bracketPairs": [["(", ")"]],
    "stringDelimiters": ["\""],
    "blockPatterns": [
      {
        "start": "^LEX\\b",
        "end": "(?=^LEX\\b|\\Z)",
        "description": "Lexon contract block"
      },
      {
        "start": "^CLAUSE\\b",
        "end": "(?=^CLAUSE\\b|^LEX\\b|\\Z)",
        "description": "Clause block"
      },
      {
        "start": "^TERMS?\\b",
        "end": "(?=^CLAUSE\\b|^LEX\\b|\\Z)",
        "description": "Terms block"
      }
    ],
    "expansionHierarchy": ["word", "phrase", "sentence", "clause", "contract", "file"]
  }
}