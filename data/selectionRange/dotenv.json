{
  "language": "dotenv",
  "selectionRanges": {
    "bracketPairs": [],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "^[A-Z_][A-Z0-9_]*=",
        "end": "$",
        "description": "Environment variable assignment"
      },
      {
        "start": "^#\\s*[-=]+",
        "end": "(?=^#\\s*[-=]+|\\Z)",
        "description": "Comment section block"
      },
      {
        "start": "^#",
        "end": "$",
        "description": "Comment line"
      }
    ],
    "expansionHierarchy": [
      "word",
      "value",
      "assignment",
      "section",
      "file"
    ]
  }
}