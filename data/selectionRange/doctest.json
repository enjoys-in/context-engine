{
  "language": "doctest",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "^>>>\\s",
        "end": "(?=^>>>|^$|\\Z)",
        "description": "Doctest input block"
      },
      {
        "start": "^\\.\\.\\.\\s",
        "end": "(?=^>>>|^$|\\Z)",
        "description": "Doctest continuation block"
      },
      {
        "start": "^(?!>>>|\\.\\.\\.)",
        "end": "(?=^>>>|\\Z)",
        "description": "Expected output block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "line",
      "test-case",
      "test-group",
      "file"
    ]
  }
}