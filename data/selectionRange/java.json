{
  "language": "java",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"], ["<", ">"]],
    "stringDelimiters": ["\"", "'", "\"\"\""],
    "blockPatterns": [
      {
        "start": "\\b(public|private|protected)?\\s*(static)?\\s*class\\s+\\w+",
        "end": "\\}",
        "description": "Class declaration block"
      },
      {
        "start": "\\b(public|private|protected)?\\s*(static|synchronized|abstract)?\\s*\\w+\\s+\\w+\\s*\\(",
        "end": "\\}",
        "description": "Method declaration block"
      },
      {
        "start": "\\bif\\s*\\(",
        "end": "\\}",
        "description": "If conditional block"
      },
      {
        "start": "\\b(for|while)\\s*\\(",
        "end": "\\}",
        "description": "Loop block"
      },
      {
        "start": "\\btry\\s*\\{",
        "end": "\\}",
        "description": "Try-catch block"
      },
      {
        "start": "\\binterface\\s+\\w+",
        "end": "\\}",
        "description": "Interface declaration block"
      }
    ],
    "expansionHierarchy": ["word", "expression", "statement", "block", "method", "class", "file"]
  }
}