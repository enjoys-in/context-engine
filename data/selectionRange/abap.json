{
  "language": "abap",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "'",
      "`"
    ],
    "blockPatterns": [
      {
        "start": "\\bFORM\\b",
        "end": "\\bENDFORM\\b",
        "description": "Form routine block"
      },
      {
        "start": "\\bIF\\b",
        "end": "\\bENDIF\\b",
        "description": "If conditional block"
      },
      {
        "start": "\\bLOOP\\b",
        "end": "\\bENDLOOP\\b",
        "description": "Loop block"
      },
      {
        "start": "\\bMETHOD\\b",
        "end": "\\bENDMETHOD\\b",
        "description": "Method definition block"
      },
      {
        "start": "\\bCLASS\\b",
        "end": "\\bENDCLASS\\b",
        "description": "Class definition block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "method",
      "class",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
