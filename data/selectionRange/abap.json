{
  "language": "abap",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "'",
      "`"
    ],
    "blockPatterns": [
      {
        "start": "\\bFORM\\b",
        "end": "\\bENDFORM\\b",
        "description": "Form routine block"
      },
      {
        "start": "\\bIF\\b",
        "end": "\\bENDIF\\b",
        "description": "If conditional block"
      },
      {
        "start": "\\bLOOP\\b",
        "end": "\\bENDLOOP\\b",
        "description": "Loop block"
      },
      {
        "start": "\\bMETHOD\\b",
        "end": "\\bENDMETHOD\\b",
        "description": "Method definition block"
      },
      {
        "start": "\\bCLASS\\b",
        "end": "\\bENDCLASS\\b",
        "description": "Class definition block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "method",
      "class",
      "file"
    ]
  }
}