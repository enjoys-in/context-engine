{
  "language": "graphql",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"]],
    "stringDelimiters": ["\"", "\"\"\""],
    "blockPatterns": [
      {
        "start": "\\btype\\s+\\w+",
        "end": "\\}",
        "description": "Type definition block"
      },
      {
        "start": "\\bquery\\s+\\w*",
        "end": "\\}",
        "description": "Query operation block"
      },
      {
        "start": "\\bmutation\\s+\\w*",
        "end": "\\}",
        "description": "Mutation operation block"
      },
      {
        "start": "\\bsubscription\\s+\\w*",
        "end": "\\}",
        "description": "Subscription operation block"
      },
      {
        "start": "\\binput\\s+\\w+",
        "end": "\\}",
        "description": "Input type definition block"
      }
    ],
    "expansionHierarchy": ["word", "argument", "field", "selection-set", "operation", "definition", "file"]
  }
}