{
  "language": "graphql",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "\"\"\""
    ],
    "blockPatterns": [
      {
        "start": "\\btype\\s+\\w+",
        "end": "\\}",
        "description": "Type definition block"
      },
      {
        "start": "\\bquery\\s+\\w*",
        "end": "\\}",
        "description": "Query operation block"
      },
      {
        "start": "\\bmutation\\s+\\w*",
        "end": "\\}",
        "description": "Mutation operation block"
      },
      {
        "start": "\\bsubscription\\s+\\w*",
        "end": "\\}",
        "description": "Subscription operation block"
      },
      {
        "start": "\\binput\\s+\\w+",
        "end": "\\}",
        "description": "Input type definition block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "argument",
      "field",
      "selection-set",
      "operation",
      "definition",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
