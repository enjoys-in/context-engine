{
  "language": "caddy",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "`"
    ],
    "blockPatterns": [
      {
        "start": "^\\S+\\s*\\{",
        "end": "\\}",
        "description": "Site block"
      },
      {
        "start": "\\b(route|handle|handle_path)\\b.*\\{",
        "end": "\\}",
        "description": "Route/handler block"
      },
      {
        "start": "\\b(reverse_proxy|respond|rewrite|redir)\\b",
        "end": "$|\\}",
        "description": "Directive block"
      },
      {
        "start": "\\btls\\b.*\\{",
        "end": "\\}",
        "description": "TLS configuration block"
      },
      {
        "start": "\\blog\\b.*\\{",
        "end": "\\}",
        "description": "Log configuration block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "argument",
      "directive",
      "block",
      "site",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
