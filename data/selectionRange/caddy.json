{
  "language": "caddy",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"]],
    "stringDelimiters": ["\"", "`"],
    "blockPatterns": [
      {
        "start": "^\\S+\\s*\\{",
        "end": "\\}",
        "description": "Site block"
      },
      {
        "start": "\\b(route|handle|handle_path)\\b.*\\{",
        "end": "\\}",
        "description": "Route/handler block"
      },
      {
        "start": "\\b(reverse_proxy|respond|rewrite|redir)\\b",
        "end": "$|\\}",
        "description": "Directive block"
      },
      {
        "start": "\\btls\\b.*\\{",
        "end": "\\}",
        "description": "TLS configuration block"
      },
      {
        "start": "\\blog\\b.*\\{",
        "end": "\\}",
        "description": "Log configuration block"
      }
    ],
    "expansionHierarchy": ["word", "argument", "directive", "block", "site", "file"]
  }
}