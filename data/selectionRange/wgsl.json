{
  "language": "wgsl",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ],
      [
        "<",
        ">"
      ]
    ],
    "stringDelimiters": [
      "\""
    ],
    "blockPatterns": [
      {
        "start": "\\bfn\\s+\\w+",
        "end": "\\}",
        "description": "Function definition block"
      },
      {
        "start": "\\bstruct\\s+\\w+\\s*\\{",
        "end": "\\}",
        "description": "Struct definition block"
      },
      {
        "start": "\\bif\\s*\\(",
        "end": "\\}",
        "description": "If conditional block"
      },
      {
        "start": "\\bfor\\s*\\(|\\bloop\\s*\\{|\\bwhile\\s*\\(",
        "end": "\\}",
        "description": "Loop block"
      },
      {
        "start": "\\bswitch\\s*\\(",
        "end": "\\}",
        "description": "Switch statement block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "function",
      "struct",
      "file"
    ]
  }
}