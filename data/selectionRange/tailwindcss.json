{
  "language": "tailwindcss",
  "selectionPatterns": [
    {
      "pattern": "[\\w:-]+",
      "expandTo": "utility-class",
      "description": "Select a single Tailwind utility class (e.g. 'flex', 'p-4', 'hover:bg-blue-500')."
    },
    {
      "pattern": "[\\w:-]+(?:\\s+[\\w:-]+)*",
      "expandTo": "class-list",
      "description": "Expand selection to the full list of space-separated utility classes."
    },
    {
      "pattern": "@apply\\s+[\\w\\s:-]+;",
      "expandTo": "apply-rule",
      "description": "Expand selection to the entire @apply rule including directive and semicolon."
    },
    {
      "pattern": "\\.[\\w-]+\\s*\\{[^}]*\\}",
      "expandTo": "rule-block",
      "description": "Expand selection to the entire CSS rule block including selector and braces."
    },
    {
      "pattern": "@layer\\s+\\w+\\s*\\{[\\s\\S]*?\\}",
      "expandTo": "layer-block",
      "description": "Expand selection to the entire @layer block including contents."
    },
    {
      "pattern": "class\\s*=\\s*[\"'][^\"']*[\"']",
      "expandTo": "class-attribute",
      "description": "Expand selection to the full class attribute including quotes."
    },
    {
      "pattern": "\\\\b\\\\w+\\\\b",
      "expandTo": "word",
      "description": "Select word in Tailwind CSS"
    },
    {
      "pattern": "\"[^\"]*\"|'[^']*'",
      "expandTo": "string",
      "description": "Select string literal"
    },
    {
      "pattern": "\\\\([^)]*\\\\)",
      "expandTo": "parentheses",
      "description": "Select parenthesized expression"
    },
    {
      "pattern": "\\\\[[^\\\\]]*\\\\]",
      "expandTo": "brackets",
      "description": "Select bracketed expression"
    },
    {
      "pattern": "\\\\{[^}]*\\\\}",
      "expandTo": "braces",
      "description": "Select braced block"
    },
    {
      "pattern": "[^\\\\n;]+",
      "expandTo": "statement",
      "description": "Select full statement"
    },
    {
      "pattern": "\\\\{[\\\\s\\\\S]*?\\\\}",
      "expandTo": "block",
      "description": "Select Tailwind CSS code block"
    },
    {
      "pattern": "(function|def|fn|func)\\\\s+\\\\w+[^{]*\\\\{[\\\\s\\\\S]*?\\\\}",
      "expandTo": "function-body",
      "description": "Select function body"
    },
    {
      "pattern": "^.*$",
      "expandTo": "line",
      "description": "Select entire line"
    },
    {
      "pattern": "\\/\\\\*[\\\\s\\\\S]*?\\\\*\\/|#.*$|\\/\\/.*$",
      "expandTo": "comment",
      "description": "Select comment block"
    },
    {
      "pattern": "(import|require|use|include|from)\\\\s+.*",
      "expandTo": "imports",
      "description": "Select import block"
    },
    {
      "pattern": "class\\\\s+\\\\w+[^{]*\\\\{[\\\\s\\\\S]*?\\\\}",
      "expandTo": "class-body",
      "description": "Select class/type body"
    }
  ],
  "selectionRanges": {
    "blockPatterns": [
      {
        "open": "(",
        "close": ")",
        "description": "Parenthesized expression"
      },
      {
        "pattern": "\\{[^}]*\\}",
        "description": "Curly brace block"
      },
      {
        "pattern": "\\([^)]*\\)",
        "description": "Parentheses"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      }
    ],
    "expansionHierarchy": [
      "expression",
      "statement",
      "block",
      "file"
    ],
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
