{
  "language": "yaml",
  "selectionRanges": {
    "bracketPairs": [["{", "}"], ["[", "]"]],
    "stringDelimiters": ["\"", "'"],
    "blockPatterns": [
      {
        "start": "^\\w[\\w-]*:\\s*$",
        "end": "(?=^\\w|\\Z)",
        "description": "Top-level mapping block (indent-based)"
      },
      {
        "start": "^\\s+\\w[\\w-]*:\\s*$",
        "end": "(?=^\\s{0,\\1}\\w|^\\w|\\Z)",
        "description": "Nested mapping block (indent-based)"
      },
      {
        "start": "^\\s*-\\s+",
        "end": "(?=^\\s*-|^\\s*\\w|^\\w|\\Z)",
        "description": "Sequence item"
      },
      {
        "start": "\\|\\s*$|>\\s*$",
        "end": "(?=^\\S|^\\s*\\w+:|\\Z)",
        "description": "Multi-line scalar block"
      },
      {
        "start": "^---",
        "end": "(?=^---|^\\.\\.\\.)",
        "description": "Document block"
      }
    ],
    "expansionHierarchy": ["word", "value", "key-value", "indented-block", "mapping", "document", "file"]
  }
}