{
  "language": "yaml",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "^\\w[\\w-]*:\\s*$",
        "end": "(?=^\\w|\\Z)",
        "description": "Top-level mapping block (indent-based)"
      },
      {
        "start": "^\\s+\\w[\\w-]*:\\s*$",
        "end": "(?=^\\s{0,\\1}\\w|^\\w|\\Z)",
        "description": "Nested mapping block (indent-based)"
      },
      {
        "start": "^\\s*-\\s+",
        "end": "(?=^\\s*-|^\\s*\\w|^\\w|\\Z)",
        "description": "Sequence item"
      },
      {
        "start": "\\|\\s*$|>\\s*$",
        "end": "(?=^\\S|^\\s*\\w+:|\\Z)",
        "description": "Multi-line scalar block"
      },
      {
        "start": "^---",
        "end": "(?=^---|^\\.\\.\\.)",
        "description": "Document block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "value",
      "key-value",
      "indented-block",
      "mapping",
      "document",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
