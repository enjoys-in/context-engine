{
  "language": "yaml",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "^\\w[\\w-]*:\\s*$",
        "end": "(?=^\\w|\\Z)",
        "description": "Top-level mapping block (indent-based)"
      },
      {
        "start": "^\\s+\\w[\\w-]*:\\s*$",
        "end": "(?=^\\s{0,\\1}\\w|^\\w|\\Z)",
        "description": "Nested mapping block (indent-based)"
      },
      {
        "start": "^\\s*-\\s+",
        "end": "(?=^\\s*-|^\\s*\\w|^\\w|\\Z)",
        "description": "Sequence item"
      },
      {
        "start": "\\|\\s*$|>\\s*$",
        "end": "(?=^\\S|^\\s*\\w+:|\\Z)",
        "description": "Multi-line scalar block"
      },
      {
        "start": "^---",
        "end": "(?=^---|^\\.\\.\\.)",
        "description": "Document block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "value",
      "key-value",
      "indented-block",
      "mapping",
      "document",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  },
  "selectionPatterns": [
    {
      "pattern": "\\\\b\\\\w+\\\\b",
      "expandTo": "word",
      "description": "Select word in YAML"
    },
    {
      "pattern": "\"[^\"]*\"|'[^']*'",
      "expandTo": "string",
      "description": "Select string literal"
    },
    {
      "pattern": "\\\\([^)]*\\\\)",
      "expandTo": "parentheses",
      "description": "Select parenthesized expression"
    },
    {
      "pattern": "\\\\[[^\\\\]]*\\\\]",
      "expandTo": "brackets",
      "description": "Select bracketed expression"
    },
    {
      "pattern": "\\\\{[^}]*\\\\}",
      "expandTo": "braces",
      "description": "Select braced block"
    },
    {
      "pattern": "[^\\\\n;]+",
      "expandTo": "statement",
      "description": "Select full statement"
    },
    {
      "pattern": "\\\\{[\\\\s\\\\S]*?\\\\}",
      "expandTo": "block",
      "description": "Select YAML code block"
    },
    {
      "pattern": "(function|def|fn|func)\\\\s+\\\\w+[^{]*\\\\{[\\\\s\\\\S]*?\\\\}",
      "expandTo": "function-body",
      "description": "Select function body"
    },
    {
      "pattern": "^.*$",
      "expandTo": "line",
      "description": "Select entire line"
    },
    {
      "pattern": "\\/\\\\*[\\\\s\\\\S]*?\\\\*\\/|#.*$|\\/\\/.*$",
      "expandTo": "comment",
      "description": "Select comment block"
    },
    {
      "pattern": "(import|require|use|include|from)\\\\s+.*",
      "expandTo": "imports",
      "description": "Select import block"
    },
    {
      "pattern": "class\\\\s+\\\\w+[^{]*\\\\{[\\\\s\\\\S]*?\\\\}",
      "expandTo": "class-body",
      "description": "Select class/type body"
    }
  ]
}
