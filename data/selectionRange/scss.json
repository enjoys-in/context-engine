{
  "language": "scss",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"]],
    "stringDelimiters": ["\"", "'"],
    "blockPatterns": [
      {
        "start": "[.#&]?[\\w-]+\\s*\\{",
        "end": "\\}",
        "description": "Selector rule block"
      },
      {
        "start": "@mixin\\s+[\\w-]+",
        "end": "\\}",
        "description": "Mixin definition block"
      },
      {
        "start": "@media\\b",
        "end": "\\}",
        "description": "Media query block"
      },
      {
        "start": "@if\\b",
        "end": "\\}",
        "description": "If conditional block"
      },
      {
        "start": "@each\\b|@for\\b|@while\\b",
        "end": "\\}",
        "description": "Loop directive block"
      }
    ],
    "expansionHierarchy": ["word", "value", "property", "declaration", "rule", "media-query", "file"]
  }
}