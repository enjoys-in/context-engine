{
  "language": "rust",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"], ["<", ">"]],
    "stringDelimiters": ["\"", "'"],
    "blockPatterns": [
      {
        "start": "\\bfn\\s+\\w+",
        "end": "\\}",
        "description": "Function definition block"
      },
      {
        "start": "\\bstruct\\s+\\w+",
        "end": "\\}|;",
        "description": "Struct definition block"
      },
      {
        "start": "\\benum\\s+\\w+",
        "end": "\\}",
        "description": "Enum definition block"
      },
      {
        "start": "\\bimpl\\b",
        "end": "\\}",
        "description": "Implementation block"
      },
      {
        "start": "\\bmatch\\b",
        "end": "\\}",
        "description": "Match expression block"
      },
      {
        "start": "\\bmod\\s+\\w+\\s*\\{",
        "end": "\\}",
        "description": "Module block"
      },
      {
        "start": "\\btrait\\s+\\w+",
        "end": "\\}",
        "description": "Trait definition block"
      }
    ],
    "expansionHierarchy": ["word", "expression", "statement", "block", "function", "impl", "module", "file"]
  }
}