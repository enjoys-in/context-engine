{
  "language": "julia",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"]],
    "stringDelimiters": ["\"", "'", "\"\"\""],
    "blockPatterns": [
      {
        "start": "\\bfunction\\s+\\w+",
        "end": "\\bend\\b",
        "description": "Function definition block"
      },
      {
        "start": "\\bstruct\\s+\\w+|\\bmutable\\s+struct\\s+\\w+",
        "end": "\\bend\\b",
        "description": "Struct definition block"
      },
      {
        "start": "\\bmodule\\s+\\w+",
        "end": "\\bend\\b",
        "description": "Module block"
      },
      {
        "start": "\\bif\\b",
        "end": "\\bend\\b",
        "description": "If conditional block"
      },
      {
        "start": "\\bfor\\b|\\bwhile\\b",
        "end": "\\bend\\b",
        "description": "Loop block"
      },
      {
        "start": "\\bbegin\\b",
        "end": "\\bend\\b",
        "description": "Begin block"
      }
    ],
    "expansionHierarchy": ["word", "expression", "statement", "block", "function", "struct", "module", "file"]
  }
}