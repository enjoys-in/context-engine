{
  "language": "julia",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'",
      "\"\"\""
    ],
    "blockPatterns": [
      {
        "start": "\\bfunction\\s+\\w+",
        "end": "\\bend\\b",
        "description": "Function definition block"
      },
      {
        "start": "\\bstruct\\s+\\w+|\\bmutable\\s+struct\\s+\\w+",
        "end": "\\bend\\b",
        "description": "Struct definition block"
      },
      {
        "start": "\\bmodule\\s+\\w+",
        "end": "\\bend\\b",
        "description": "Module block"
      },
      {
        "start": "\\bif\\b",
        "end": "\\bend\\b",
        "description": "If conditional block"
      },
      {
        "start": "\\bfor\\b|\\bwhile\\b",
        "end": "\\bend\\b",
        "description": "Loop block"
      },
      {
        "start": "\\bbegin\\b",
        "end": "\\bend\\b",
        "description": "Begin block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "function",
      "struct",
      "module",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
