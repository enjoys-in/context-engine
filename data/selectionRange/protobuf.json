{
  "language": "protobuf",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\bmessage\\s+\\w+\\s*\\{",
        "end": "\\}",
        "description": "Message definition block"
      },
      {
        "start": "\\bservice\\s+\\w+\\s*\\{",
        "end": "\\}",
        "description": "Service definition block"
      },
      {
        "start": "\\benum\\s+\\w+\\s*\\{",
        "end": "\\}",
        "description": "Enum definition block"
      },
      {
        "start": "\\boneof\\s+\\w+\\s*\\{",
        "end": "\\}",
        "description": "Oneof field block"
      },
      {
        "start": "\\brpc\\s+\\w+",
        "end": ";|\\}",
        "description": "RPC method definition"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "type",
      "field",
      "block",
      "message",
      "service",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
