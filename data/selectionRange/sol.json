{
  "language": "sol",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"]],
    "stringDelimiters": ["\"", "'"],
    "blockPatterns": [
      {
        "start": "\\bcontract\\s+\\w+",
        "end": "\\}",
        "description": "Contract definition block"
      },
      {
        "start": "\\bfunction\\s+\\w+",
        "end": "\\}",
        "description": "Function definition block"
      },
      {
        "start": "\\bmodifier\\s+\\w+",
        "end": "\\}",
        "description": "Modifier definition block"
      },
      {
        "start": "\\bevent\\s+\\w+",
        "end": ";",
        "description": "Event declaration"
      },
      {
        "start": "\\bif\\s*\\(",
        "end": "\\}",
        "description": "If conditional block"
      },
      {
        "start": "\\bfor\\s*\\(|\\bwhile\\s*\\(",
        "end": "\\}",
        "description": "Loop block"
      }
    ],
    "expansionHierarchy": ["word", "expression", "statement", "block", "function", "contract", "file"]
  }
}