{
  "language": "mips",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "^\\s*\\.text\\b",
        "end": "(?=^\\s*\\.(data|text|globl)|\\Z)",
        "description": "Text segment"
      },
      {
        "start": "^\\s*\\.data\\b",
        "end": "(?=^\\s*\\.(text|data|globl)|\\Z)",
        "description": "Data segment"
      },
      {
        "start": "^\\w+:\\s*$",
        "end": "(?=^\\w+:|^\\s*\\.|\\Z)",
        "description": "Label block"
      },
      {
        "start": "^\\s*#",
        "end": "$",
        "description": "Comment line"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "operand",
      "instruction",
      "label-block",
      "segment",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
