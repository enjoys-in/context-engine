{
  "language": "mips",
  "selectionRanges": {
    "bracketPairs": [["(", ")"]],
    "stringDelimiters": ["\""],
    "blockPatterns": [
      {
        "start": "^\\s*\\.text\\b",
        "end": "(?=^\\s*\\.(data|text|globl)|\\Z)",
        "description": "Text segment"
      },
      {
        "start": "^\\s*\\.data\\b",
        "end": "(?=^\\s*\\.(text|data|globl)|\\Z)",
        "description": "Data segment"
      },
      {
        "start": "^\\w+:\\s*$",
        "end": "(?=^\\w+:|^\\s*\\.|\\Z)",
        "description": "Label block"
      },
      {
        "start": "^\\s*#",
        "end": "$",
        "description": "Comment line"
      }
    ],
    "expansionHierarchy": ["word", "operand", "instruction", "label-block", "segment", "file"]
  }
}