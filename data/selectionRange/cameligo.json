{
  "language": "cameligo",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"]],
    "stringDelimiters": ["\""],
    "blockPatterns": [
      {
        "start": "\\blet\\b",
        "end": "(?=\\blet\\b|$)",
        "description": "Let binding block"
      },
      {
        "start": "\\btype\\b",
        "end": "(?=\\blet\\b|\\btype\\b|$)",
        "description": "Type declaration block"
      },
      {
        "start": "\\bmatch\\b",
        "end": "(?=\\blet\\b|$)",
        "description": "Match expression block"
      },
      {
        "start": "\\bif\\b",
        "end": "(?=\\blet\\b|$)",
        "description": "If conditional expression"
      },
      {
        "start": "\\bmodule\\b",
        "end": "\\bend\\b",
        "description": "Module block"
      }
    ],
    "expansionHierarchy": ["word", "expression", "binding", "block", "module", "file"]
  }
}