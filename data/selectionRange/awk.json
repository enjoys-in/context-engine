{
  "language": "awk",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"]],
    "stringDelimiters": ["\""],
    "blockPatterns": [
      {
        "start": "\\bBEGIN\\s*\\{",
        "end": "\\}",
        "description": "BEGIN block"
      },
      {
        "start": "\\bEND\\s*\\{",
        "end": "\\}",
        "description": "END block"
      },
      {
        "start": "\\/.*\\/\\s*\\{",
        "end": "\\}",
        "description": "Pattern-action block"
      },
      {
        "start": "\\bfunction\\s+\\w+\\s*\\(",
        "end": "\\}",
        "description": "Function definition"
      },
      {
        "start": "\\bif\\s*\\(",
        "end": "\\}",
        "description": "If conditional block"
      }
    ],
    "expansionHierarchy": ["word", "expression", "statement", "block", "rule", "file"]
  }
}