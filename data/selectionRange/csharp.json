{
  "language": "csharp",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ],
      [
        "<",
        ">"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'",
      "@\""
    ],
    "blockPatterns": [
      {
        "start": "\\bnamespace\\s+[\\w.]+",
        "end": "\\}",
        "description": "Namespace block"
      },
      {
        "start": "\\b(public|private|protected|internal)?\\s*(static)?\\s*class\\s+\\w+",
        "end": "\\}",
        "description": "Class declaration block"
      },
      {
        "start": "\\b(public|private|protected|internal)?\\s*(static|async|virtual|override)?\\s*\\w+\\s+\\w+\\s*\\(",
        "end": "\\}",
        "description": "Method declaration block"
      },
      {
        "start": "\\bif\\s*\\(",
        "end": "\\}",
        "description": "If conditional block"
      },
      {
        "start": "\\b(for|foreach|while)\\s*\\(",
        "end": "\\}",
        "description": "Loop block"
      },
      {
        "start": "\\btry\\s*\\{",
        "end": "\\}",
        "description": "Try-catch block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "method",
      "class",
      "namespace",
      "file"
    ]
  }
}