{
  "language": "sql",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ]
    ],
    "stringDelimiters": [
      "'",
      "\""
    ],
    "blockPatterns": [
      {
        "start": "\\bSELECT\\b",
        "end": ";",
        "description": "SELECT statement block"
      },
      {
        "start": "\\bCREATE\\s+(TABLE|VIEW|PROCEDURE|FUNCTION|TRIGGER)\\b",
        "end": ";|\\bEND\\b",
        "description": "CREATE definition block"
      },
      {
        "start": "\\bBEGIN\\b",
        "end": "\\bEND\\b",
        "description": "BEGIN-END block"
      },
      {
        "start": "\\bIF\\b",
        "end": "\\bEND\\s+IF\\b",
        "description": "IF conditional block"
      },
      {
        "start": "\\bCASE\\b",
        "end": "\\bEND\\b",
        "description": "CASE expression"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "clause",
      "statement",
      "block",
      "procedure",
      "file"
    ]
  }
}