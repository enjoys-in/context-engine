{
  "language": "ecl",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "'",
      "\""
    ],
    "blockPatterns": [
      {
        "start": "\\bRECORD\\b",
        "end": "\\bEND\\b",
        "description": "Record definition block"
      },
      {
        "start": "\\bTRANSFORM\\b",
        "end": "\\bEND\\b",
        "description": "Transform block"
      },
      {
        "start": "\\bMODULE\\b",
        "end": "\\bEND\\b",
        "description": "Module block"
      },
      {
        "start": "\\bFUNCTION\\b",
        "end": "\\bEND\\b",
        "description": "Function block"
      },
      {
        "start": "\\bIF\\b",
        "end": "\\bEND\\b",
        "description": "If conditional block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "definition",
      "module",
      "file"
    ]
  }
}