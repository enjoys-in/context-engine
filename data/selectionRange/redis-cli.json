{
  "language": "redis-cli",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\bMULTI\\b",
        "end": "\\bEXEC\\b|\\bDISCARD\\b",
        "description": "Transaction block"
      },
      {
        "start": "^\\s*[A-Z]+\\b",
        "end": "$",
        "description": "CLI command line"
      },
      {
        "start": "^#",
        "end": "$",
        "description": "Comment line"
      }
    ],
    "expansionHierarchy": [
      "word",
      "argument",
      "command",
      "transaction",
      "file"
    ]
  }
}