{
  "language": "systemverilog",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\bmodule\\s+\\w+",
        "end": "\\bendmodule\\b",
        "description": "Module definition block"
      },
      {
        "start": "\\bclass\\s+\\w+",
        "end": "\\bendclass\\b",
        "description": "Class definition block"
      },
      {
        "start": "\\btask\\s+\\w+|\\bfunction\\s+\\w+",
        "end": "\\bendtask\\b|\\bendfunction\\b",
        "description": "Task/function definition block"
      },
      {
        "start": "\\bif\\s*\\(",
        "end": "\\bend\\b",
        "description": "If conditional block"
      },
      {
        "start": "\\balways\\b|\\balways_ff\\b|\\balways_comb\\b",
        "end": "\\bend\\b",
        "description": "Always block"
      },
      {
        "start": "\\bbegin\\b",
        "end": "\\bend\\b",
        "description": "Begin-end block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "task",
      "module",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
