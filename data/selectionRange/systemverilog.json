{
  "language": "systemverilog",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\""
    ],
    "blockPatterns": [
      {
        "start": "\\bmodule\\s+\\w+",
        "end": "\\bendmodule\\b",
        "description": "Module definition block"
      },
      {
        "start": "\\bclass\\s+\\w+",
        "end": "\\bendclass\\b",
        "description": "Class definition block"
      },
      {
        "start": "\\btask\\s+\\w+|\\bfunction\\s+\\w+",
        "end": "\\bendtask\\b|\\bendfunction\\b",
        "description": "Task/function definition block"
      },
      {
        "start": "\\bif\\s*\\(",
        "end": "\\bend\\b",
        "description": "If conditional block"
      },
      {
        "start": "\\balways\\b|\\balways_ff\\b|\\balways_comb\\b",
        "end": "\\bend\\b",
        "description": "Always block"
      },
      {
        "start": "\\bbegin\\b",
        "end": "\\bend\\b",
        "description": "Begin-end block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "task",
      "module",
      "file"
    ]
  }
}