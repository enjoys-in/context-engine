{
  "language": "python",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'",
      "\"\"\"",
      "'''"
    ],
    "blockPatterns": [
      {
        "start": "^\\s*def\\s+\\w+",
        "end": "(?=^\\S|^\\s*def\\b|^\\s*class\\b|\\Z)",
        "description": "Function definition block (indent-based)"
      },
      {
        "start": "^\\s*class\\s+\\w+",
        "end": "(?=^\\S|^\\s*class\\b|\\Z)",
        "description": "Class definition block (indent-based)"
      },
      {
        "start": "^\\s*if\\b",
        "end": "(?=^\\s*(?:elif|else|def|class|\\S)|\\Z)",
        "description": "If conditional block"
      },
      {
        "start": "^\\s*(for|while)\\b",
        "end": "(?=^\\s*(?:def|class|\\S)|\\Z)",
        "description": "Loop block"
      },
      {
        "start": "^\\s*try\\s*:",
        "end": "(?=^\\s*(?:def|class|\\S)|\\Z)",
        "description": "Try-except block"
      },
      {
        "start": "^\\s*with\\b",
        "end": "(?=^\\s*(?:def|class|\\S)|\\Z)",
        "description": "With context manager block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "indented-block",
      "function",
      "class",
      "module",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
