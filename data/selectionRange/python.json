{
  "language": "python",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'",
      "\"\"\"",
      "'''"
    ],
    "blockPatterns": [
      {
        "start": "^\\s*def\\s+\\w+",
        "end": "(?=^\\S|^\\s*def\\b|^\\s*class\\b|\\Z)",
        "description": "Function definition block (indent-based)"
      },
      {
        "start": "^\\s*class\\s+\\w+",
        "end": "(?=^\\S|^\\s*class\\b|\\Z)",
        "description": "Class definition block (indent-based)"
      },
      {
        "start": "^\\s*if\\b",
        "end": "(?=^\\s*(?:elif|else|def|class|\\S)|\\Z)",
        "description": "If conditional block"
      },
      {
        "start": "^\\s*(for|while)\\b",
        "end": "(?=^\\s*(?:def|class|\\S)|\\Z)",
        "description": "Loop block"
      },
      {
        "start": "^\\s*try\\s*:",
        "end": "(?=^\\s*(?:def|class|\\S)|\\Z)",
        "description": "Try-except block"
      },
      {
        "start": "^\\s*with\\b",
        "end": "(?=^\\s*(?:def|class|\\S)|\\Z)",
        "description": "With context manager block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "indented-block",
      "function",
      "class",
      "module",
      "file"
    ]
  }
}