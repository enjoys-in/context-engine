{
  "language": "react",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ],
      [
        "<",
        ">"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'",
      "`"
    ],
    "blockPatterns": [
      {
        "description": "JSX element",
        "startPattern": "<([A-Z][a-zA-Z0-9.]*)",
        "endPattern": "<\\/\\1>"
      },
      {
        "description": "HTML element",
        "startPattern": "<([a-z][a-z0-9]*)",
        "endPattern": "<\\/\\1>"
      },
      {
        "description": "JSX self-closing",
        "startPattern": "<[A-Za-z][a-zA-Z0-9.]*\\s",
        "endPattern": "\\/>"
      },
      {
        "description": "JSX expression",
        "startPattern": "\\{",
        "endPattern": "\\}"
      },
      {
        "description": "Arrow function body",
        "startPattern": "=>\\s*\\{",
        "endPattern": "\\}"
      },
      {
        "description": "Function body",
        "startPattern": "\\)\\s*\\{",
        "endPattern": "\\}"
      },
      {
        "description": "Return statement with parens",
        "startPattern": "return\\s*\\(",
        "endPattern": "\\)"
      },
      {
        "description": "Conditional block",
        "startPattern": "if\\s*\\(",
        "endPattern": "\\}"
      },
      {
        "description": "Ternary expression",
        "startPattern": "\\?\\s",
        "endPattern": ":\\s"
      },
      {
        "description": "Template literal",
        "startPattern": "`",
        "endPattern": "`"
      },
      {
        "description": "Hook call",
        "startPattern": "use[A-Z][a-zA-Z0-9]*\\(",
        "endPattern": "\\)"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "string_content",
      "string",
      "jsx_attribute_value",
      "jsx_attribute",
      "jsx_opening_element",
      "jsx_expression",
      "jsx_element",
      "hook_call",
      "statement",
      "block",
      "function_body",
      "function_declaration",
      "component",
      "export_statement",
      "program"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  },
  "selectionPatterns": [
    {
      "pattern": "\\\\b\\\\w+\\\\b",
      "expandTo": "word",
      "description": "Select word in React"
    },
    {
      "pattern": "\"[^\"]*\"|'[^']*'",
      "expandTo": "string",
      "description": "Select string literal"
    },
    {
      "pattern": "\\\\([^)]*\\\\)",
      "expandTo": "parentheses",
      "description": "Select parenthesized expression"
    },
    {
      "pattern": "\\\\[[^\\\\]]*\\\\]",
      "expandTo": "brackets",
      "description": "Select bracketed expression"
    },
    {
      "pattern": "\\\\{[^}]*\\\\}",
      "expandTo": "braces",
      "description": "Select braced block"
    },
    {
      "pattern": "[^\\\\n;]+",
      "expandTo": "statement",
      "description": "Select full statement"
    },
    {
      "pattern": "\\\\{[\\\\s\\\\S]*?\\\\}",
      "expandTo": "block",
      "description": "Select React code block"
    },
    {
      "pattern": "(function|def|fn|func)\\\\s+\\\\w+[^{]*\\\\{[\\\\s\\\\S]*?\\\\}",
      "expandTo": "function-body",
      "description": "Select function body"
    },
    {
      "pattern": "^.*$",
      "expandTo": "line",
      "description": "Select entire line"
    },
    {
      "pattern": "\\/\\\\*[\\\\s\\\\S]*?\\\\*\\/|#.*$|\\/\\/.*$",
      "expandTo": "comment",
      "description": "Select comment block"
    },
    {
      "pattern": "(import|require|use|include|from)\\\\s+.*",
      "expandTo": "imports",
      "description": "Select import block"
    },
    {
      "pattern": "class\\\\s+\\\\w+[^{]*\\\\{[\\\\s\\\\S]*?\\\\}",
      "expandTo": "class-body",
      "description": "Select class/type body"
    }
  ]
}
