{
  "language": "systemd",
  "selectionRanges": {
    "bracketPairs": [["[", "]"]],
    "stringDelimiters": ["\""],
    "blockPatterns": [
      {
        "start": "^\\[Unit\\]",
        "end": "(?=^\\[|\\Z)",
        "description": "Unit section"
      },
      {
        "start": "^\\[Service\\]",
        "end": "(?=^\\[|\\Z)",
        "description": "Service section"
      },
      {
        "start": "^\\[Install\\]",
        "end": "(?=^\\[|\\Z)",
        "description": "Install section"
      },
      {
        "start": "^\\[Timer\\]",
        "end": "(?=^\\[|\\Z)",
        "description": "Timer section"
      },
      {
        "start": "^\\w+=",
        "end": "$",
        "description": "Key-value directive"
      }
    ],
    "expansionHierarchy": ["word", "value", "directive", "section", "file"]
  }
}