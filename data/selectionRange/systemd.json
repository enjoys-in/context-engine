{
  "language": "systemd",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "^\\[Unit\\]",
        "end": "(?=^\\[|\\Z)",
        "description": "Unit section"
      },
      {
        "start": "^\\[Service\\]",
        "end": "(?=^\\[|\\Z)",
        "description": "Service section"
      },
      {
        "start": "^\\[Install\\]",
        "end": "(?=^\\[|\\Z)",
        "description": "Install section"
      },
      {
        "start": "^\\[Timer\\]",
        "end": "(?=^\\[|\\Z)",
        "description": "Timer section"
      },
      {
        "start": "^\\w+=",
        "end": "$",
        "description": "Key-value directive"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "value",
      "directive",
      "section",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
