{
  "language": "html",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ],
      [
        "<",
        ">"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "<(div|section|article|main|header|footer|nav|aside)\\b[^>]*>",
        "end": "</(div|section|article|main|header|footer|nav|aside)>",
        "description": "Semantic/structural element block"
      },
      {
        "start": "<(ul|ol|table|form|select)\\b[^>]*>",
        "end": "</(ul|ol|table|form|select)>",
        "description": "Container element block"
      },
      {
        "start": "<(head|body|html)\\b[^>]*>",
        "end": "</(head|body|html)>",
        "description": "Document structure element"
      },
      {
        "start": "<script\\b[^>]*>",
        "end": "</script>",
        "description": "Script element block"
      },
      {
        "start": "<style\\b[^>]*>",
        "end": "</style>",
        "description": "Style element block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "attribute-value",
      "attribute",
      "tag",
      "element",
      "parent-element",
      "document",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
