{
  "language": "javascript",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'",
      "`"
    ],
    "blockPatterns": [
      {
        "start": "\\bfunction\\b.*\\{|=>\\s*\\{",
        "end": "\\}",
        "description": "Function declaration/expression block"
      },
      {
        "start": "\\bclass\\s+\\w+",
        "end": "\\}",
        "description": "Class declaration block"
      },
      {
        "start": "\\bif\\s*\\(",
        "end": "\\}",
        "description": "If conditional block"
      },
      {
        "start": "\\b(for|for\\s+of|for\\s+in|while)\\s*\\(",
        "end": "\\}",
        "description": "Loop block"
      },
      {
        "start": "\\btry\\s*\\{",
        "end": "\\}",
        "description": "Try-catch block"
      },
      {
        "start": "\\bswitch\\s*\\(",
        "end": "\\}",
        "description": "Switch statement block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "function",
      "class",
      "module",
      "file"
    ]
  }
}