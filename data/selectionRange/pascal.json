{
  "language": "pascal",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\bprocedure\\s+\\w+|\\bfunction\\s+\\w+",
        "end": "\\bend;",
        "description": "Procedure/function block"
      },
      {
        "start": "\\bbegin\\b",
        "end": "\\bend[.;]",
        "description": "Begin-end block"
      },
      {
        "start": "\\bif\\b",
        "end": ";",
        "description": "If conditional block"
      },
      {
        "start": "\\bfor\\b|\\bwhile\\b|\\brepeat\\b",
        "end": ";|\\buntil\\b",
        "description": "Loop block"
      },
      {
        "start": "\\brecord\\b",
        "end": "\\bend;",
        "description": "Record type block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "procedure",
      "unit",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
