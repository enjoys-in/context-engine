{
  "language": "pascal",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["[", "]"]],
    "stringDelimiters": ["'"],
    "blockPatterns": [
      {
        "start": "\\bprocedure\\s+\\w+|\\bfunction\\s+\\w+",
        "end": "\\bend;",
        "description": "Procedure/function block"
      },
      {
        "start": "\\bbegin\\b",
        "end": "\\bend[.;]",
        "description": "Begin-end block"
      },
      {
        "start": "\\bif\\b",
        "end": ";",
        "description": "If conditional block"
      },
      {
        "start": "\\bfor\\b|\\bwhile\\b|\\brepeat\\b",
        "end": ";|\\buntil\\b",
        "description": "Loop block"
      },
      {
        "start": "\\brecord\\b",
        "end": "\\bend;",
        "description": "Record type block"
      }
    ],
    "expansionHierarchy": ["word", "expression", "statement", "block", "procedure", "unit", "file"]
  }
}