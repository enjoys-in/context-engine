{
  "language": "redis",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\bMULTI\\b",
        "end": "\\bEXEC\\b|\\bDISCARD\\b",
        "description": "Transaction block"
      },
      {
        "start": "^[A-Z]+\\b",
        "end": "$",
        "description": "Redis command"
      },
      {
        "start": "\\bEVAL\\b",
        "end": "$",
        "description": "Lua script evaluation command"
      }
    ],
    "expansionHierarchy": [
      "word",
      "argument",
      "command",
      "transaction",
      "file"
    ]
  }
}