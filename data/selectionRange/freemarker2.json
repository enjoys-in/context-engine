{
  "language": "freemarker2",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["[", "]"], ["<", ">"]],
    "stringDelimiters": ["\"", "'"],
    "blockPatterns": [
      {
        "start": "<#if\\b",
        "end": "</#if>",
        "description": "If directive block"
      },
      {
        "start": "<#list\\b",
        "end": "</#list>",
        "description": "List directive block"
      },
      {
        "start": "<#macro\\b",
        "end": "</#macro>",
        "description": "Macro definition block"
      },
      {
        "start": "<#function\\b",
        "end": "</#function>",
        "description": "Function definition block"
      },
      {
        "start": "<#assign\\b",
        "end": ">|</#assign>",
        "description": "Assign directive"
      }
    ],
    "expansionHierarchy": ["word", "expression", "interpolation", "directive", "block", "template", "file"]
  }
}