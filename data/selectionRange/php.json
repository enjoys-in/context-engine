{
  "language": "php",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'",
      "<<<"
    ],
    "blockPatterns": [
      {
        "start": "\\bfunction\\s+\\w+|\\bfunction\\s*\\(",
        "end": "\\}",
        "description": "Function declaration block"
      },
      {
        "start": "\\bclass\\s+\\w+",
        "end": "\\}",
        "description": "Class declaration block"
      },
      {
        "start": "\\bif\\s*\\(",
        "end": "\\}",
        "description": "If conditional block"
      },
      {
        "start": "\\b(for|foreach|while)\\s*\\(",
        "end": "\\}",
        "description": "Loop block"
      },
      {
        "start": "\\bnamespace\\s+[\\w\\\\]+",
        "end": "\\}|(?=\\bnamespace\\b)",
        "description": "Namespace block"
      },
      {
        "start": "\\btry\\s*\\{",
        "end": "\\}",
        "description": "Try-catch block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "function",
      "class",
      "namespace",
      "file"
    ]
  }
}