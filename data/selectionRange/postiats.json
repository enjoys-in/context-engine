{
  "language": "postiats",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ],
      [
        "<",
        ">"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\bfun\\b|\\bfn\\b",
        "end": "(?=\\bfun\\b|\\bfn\\b|\\bval\\b|\\bend\\b|$)",
        "description": "Function definition"
      },
      {
        "start": "\\bimplement\\b",
        "end": "(?=\\bimplement\\b|\\bend\\b|$)",
        "description": "Implementation block"
      },
      {
        "start": "\\blet\\b",
        "end": "\\bend\\b",
        "description": "Let binding block"
      },
      {
        "start": "\\bif\\b",
        "end": "(?=\\belse\\b|\\bend\\b|$)",
        "description": "If conditional"
      },
      {
        "start": "\\bcase\\b",
        "end": "(?=\\bfun\\b|\\bval\\b|\\bend\\b|$)",
        "description": "Case expression"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "clause",
      "block",
      "function",
      "module",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
