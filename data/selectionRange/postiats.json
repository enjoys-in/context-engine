{
  "language": "postiats",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"], ["<", ">"]],
    "stringDelimiters": ["\""],
    "blockPatterns": [
      {
        "start": "\\bfun\\b|\\bfn\\b",
        "end": "(?=\\bfun\\b|\\bfn\\b|\\bval\\b|\\bend\\b|$)",
        "description": "Function definition"
      },
      {
        "start": "\\bimplement\\b",
        "end": "(?=\\bimplement\\b|\\bend\\b|$)",
        "description": "Implementation block"
      },
      {
        "start": "\\blet\\b",
        "end": "\\bend\\b",
        "description": "Let binding block"
      },
      {
        "start": "\\bif\\b",
        "end": "(?=\\belse\\b|\\bend\\b|$)",
        "description": "If conditional"
      },
      {
        "start": "\\bcase\\b",
        "end": "(?=\\bfun\\b|\\bval\\b|\\bend\\b|$)",
        "description": "Case expression"
      }
    ],
    "expansionHierarchy": ["word", "expression", "clause", "block", "function", "module", "file"]
  }
}