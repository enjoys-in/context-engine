{
  "language": "scheme",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\(define\\s",
        "end": "\\)",
        "description": "Definition form"
      },
      {
        "start": "\\(lambda\\s",
        "end": "\\)",
        "description": "Lambda expression"
      },
      {
        "start": "\\(let\\*?\\s",
        "end": "\\)",
        "description": "Let binding form"
      },
      {
        "start": "\\(cond\\s",
        "end": "\\)",
        "description": "Cond expression"
      },
      {
        "start": "\\(begin\\s",
        "end": "\\)",
        "description": "Begin block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "symbol",
      "s-expression",
      "list",
      "top-level-form",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
