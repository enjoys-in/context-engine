{
  "language": "scheme",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["[", "]"]],
    "stringDelimiters": ["\""],
    "blockPatterns": [
      {
        "start": "\\(define\\s",
        "end": "\\)",
        "description": "Definition form"
      },
      {
        "start": "\\(lambda\\s",
        "end": "\\)",
        "description": "Lambda expression"
      },
      {
        "start": "\\(let\\*?\\s",
        "end": "\\)",
        "description": "Let binding form"
      },
      {
        "start": "\\(cond\\s",
        "end": "\\)",
        "description": "Cond expression"
      },
      {
        "start": "\\(begin\\s",
        "end": "\\)",
        "description": "Begin block"
      }
    ],
    "expansionHierarchy": ["word", "symbol", "s-expression", "list", "top-level-form", "file"]
  }
}