{
  "language": "scheme",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\(define\\s",
        "end": "\\)",
        "description": "Definition form"
      },
      {
        "start": "\\(lambda\\s",
        "end": "\\)",
        "description": "Lambda expression"
      },
      {
        "start": "\\(let\\*?\\s",
        "end": "\\)",
        "description": "Let binding form"
      },
      {
        "start": "\\(cond\\s",
        "end": "\\)",
        "description": "Cond expression"
      },
      {
        "start": "\\(begin\\s",
        "end": "\\)",
        "description": "Begin block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "symbol",
      "s-expression",
      "list",
      "top-level-form",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  },
  "selectionPatterns": [
    {
      "pattern": "\\\\b\\\\w+\\\\b",
      "expandTo": "word",
      "description": "Select word in Scheme"
    },
    {
      "pattern": "\"[^\"]*\"|'[^']*'",
      "expandTo": "string",
      "description": "Select string literal"
    },
    {
      "pattern": "\\\\([^)]*\\\\)",
      "expandTo": "parentheses",
      "description": "Select parenthesized expression"
    },
    {
      "pattern": "\\\\[[^\\\\]]*\\\\]",
      "expandTo": "brackets",
      "description": "Select bracketed expression"
    },
    {
      "pattern": "\\\\{[^}]*\\\\}",
      "expandTo": "braces",
      "description": "Select braced block"
    },
    {
      "pattern": "[^\\\\n;]+",
      "expandTo": "statement",
      "description": "Select full statement"
    },
    {
      "pattern": "\\\\{[\\\\s\\\\S]*?\\\\}",
      "expandTo": "block",
      "description": "Select Scheme code block"
    },
    {
      "pattern": "(function|def|fn|func)\\\\s+\\\\w+[^{]*\\\\{[\\\\s\\\\S]*?\\\\}",
      "expandTo": "function-body",
      "description": "Select function body"
    },
    {
      "pattern": "^.*$",
      "expandTo": "line",
      "description": "Select entire line"
    },
    {
      "pattern": "\\/\\\\*[\\\\s\\\\S]*?\\\\*\\/|#.*$|\\/\\/.*$",
      "expandTo": "comment",
      "description": "Select comment block"
    },
    {
      "pattern": "(import|require|use|include|from)\\\\s+.*",
      "expandTo": "imports",
      "description": "Select import block"
    },
    {
      "pattern": "class\\\\s+\\\\w+[^{]*\\\\{[\\\\s\\\\S]*?\\\\}",
      "expandTo": "class-body",
      "description": "Select class/type body"
    }
  ]
}
