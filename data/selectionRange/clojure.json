{
  "language": "clojure",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"]],
    "stringDelimiters": ["\""],
    "blockPatterns": [
      {
        "start": "\\(defn\\s",
        "end": "\\)",
        "description": "Function definition"
      },
      {
        "start": "\\(def\\s",
        "end": "\\)",
        "description": "Var definition"
      },
      {
        "start": "\\(let\\s",
        "end": "\\)",
        "description": "Let binding block"
      },
      {
        "start": "\\(ns\\s",
        "end": "\\)",
        "description": "Namespace declaration"
      },
      {
        "start": "\\(do\\s",
        "end": "\\)",
        "description": "Do block"
      }
    ],
    "expansionHierarchy": ["word", "symbol", "s-expression", "list", "top-level-form", "namespace", "file"]
  }
}