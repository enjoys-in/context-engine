{
  "language": "clojure",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\(defn\\s",
        "end": "\\)",
        "description": "Function definition"
      },
      {
        "start": "\\(def\\s",
        "end": "\\)",
        "description": "Var definition"
      },
      {
        "start": "\\(let\\s",
        "end": "\\)",
        "description": "Let binding block"
      },
      {
        "start": "\\(ns\\s",
        "end": "\\)",
        "description": "Namespace declaration"
      },
      {
        "start": "\\(do\\s",
        "end": "\\)",
        "description": "Do block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "symbol",
      "s-expression",
      "list",
      "top-level-form",
      "namespace",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
