{
  "language": "powerquery",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"]],
    "stringDelimiters": ["\""],
    "blockPatterns": [
      {
        "start": "\\blet\\b",
        "end": "\\bin\\b",
        "description": "Let-in expression block"
      },
      {
        "start": "\\bif\\b",
        "end": "(?=\\belse\\b.*\\bthen\\b|$)",
        "description": "If-then-else expression"
      },
      {
        "start": "\\beach\\b",
        "end": "(?=,|\\)|\\bin\\b|$)",
        "description": "Each expression"
      },
      {
        "start": "\\btry\\b",
        "end": "(?=,|\\)|$)",
        "description": "Try expression"
      },
      {
        "start": "\\(\\s*\\w+\\s+as\\b",
        "end": "\\)",
        "description": "Function expression"
      }
    ],
    "expansionHierarchy": ["word", "expression", "step", "let-binding", "section", "file"]
  }
}