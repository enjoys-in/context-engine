{
  "language": "powerquery",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\blet\\b",
        "end": "\\bin\\b",
        "description": "Let-in expression block"
      },
      {
        "start": "\\bif\\b",
        "end": "(?=\\belse\\b.*\\bthen\\b|$)",
        "description": "If-then-else expression"
      },
      {
        "start": "\\beach\\b",
        "end": "(?=,|\\)|\\bin\\b|$)",
        "description": "Each expression"
      },
      {
        "start": "\\btry\\b",
        "end": "(?=,|\\)|$)",
        "description": "Try expression"
      },
      {
        "start": "\\(\\s*\\w+\\s+as\\b",
        "end": "\\)",
        "description": "Function expression"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "step",
      "let-binding",
      "section",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  },
  "selectionPatterns": [
    {
      "pattern": "\\\\b\\\\w+\\\\b",
      "expandTo": "word",
      "description": "Select word in Power Query M"
    },
    {
      "pattern": "\"[^\"]*\"|'[^']*'",
      "expandTo": "string",
      "description": "Select string literal"
    },
    {
      "pattern": "\\\\([^)]*\\\\)",
      "expandTo": "parentheses",
      "description": "Select parenthesized expression"
    },
    {
      "pattern": "\\\\[[^\\\\]]*\\\\]",
      "expandTo": "brackets",
      "description": "Select bracketed expression"
    },
    {
      "pattern": "\\\\{[^}]*\\\\}",
      "expandTo": "braces",
      "description": "Select braced block"
    },
    {
      "pattern": "[^\\\\n;]+",
      "expandTo": "statement",
      "description": "Select full statement"
    },
    {
      "pattern": "\\\\{[\\\\s\\\\S]*?\\\\}",
      "expandTo": "block",
      "description": "Select Power Query M code block"
    },
    {
      "pattern": "(function|def|fn|func)\\\\s+\\\\w+[^{]*\\\\{[\\\\s\\\\S]*?\\\\}",
      "expandTo": "function-body",
      "description": "Select function body"
    },
    {
      "pattern": "^.*$",
      "expandTo": "line",
      "description": "Select entire line"
    },
    {
      "pattern": "\\/\\\\*[\\\\s\\\\S]*?\\\\*\\/|#.*$|\\/\\/.*$",
      "expandTo": "comment",
      "description": "Select comment block"
    },
    {
      "pattern": "(import|require|use|include|from)\\\\s+.*",
      "expandTo": "imports",
      "description": "Select import block"
    },
    {
      "pattern": "class\\\\s+\\\\w+[^{]*\\\\{[\\\\s\\\\S]*?\\\\}",
      "expandTo": "class-body",
      "description": "Select class/type body"
    }
  ]
}
