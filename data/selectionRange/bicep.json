{
  "language": "bicep",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\bresource\\s+\\w+",
        "end": "\\}",
        "description": "Resource declaration block"
      },
      {
        "start": "\\bmodule\\s+\\w+",
        "end": "\\}",
        "description": "Module declaration block"
      },
      {
        "start": "\\bparam\\s+\\w+",
        "end": "$",
        "description": "Parameter declaration"
      },
      {
        "start": "\\bvar\\s+\\w+",
        "end": "$",
        "description": "Variable declaration"
      },
      {
        "start": "\\boutput\\s+\\w+",
        "end": "$",
        "description": "Output declaration"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "property",
      "block",
      "resource",
      "file"
    ]
  }
}