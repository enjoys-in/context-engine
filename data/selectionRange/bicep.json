{
  "language": "bicep",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\bresource\\s+\\w+",
        "end": "\\}",
        "description": "Resource declaration block"
      },
      {
        "start": "\\bmodule\\s+\\w+",
        "end": "\\}",
        "description": "Module declaration block"
      },
      {
        "start": "\\bparam\\s+\\w+",
        "end": "$",
        "description": "Parameter declaration"
      },
      {
        "start": "\\bvar\\s+\\w+",
        "end": "$",
        "description": "Variable declaration"
      },
      {
        "start": "\\boutput\\s+\\w+",
        "end": "$",
        "description": "Output declaration"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "property",
      "block",
      "resource",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
