{
  "language": "liquid",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"]],
    "stringDelimiters": ["\"", "'"],
    "blockPatterns": [
      {
        "start": "\\{%\\s*if\\b",
        "end": "\\{%\\s*endif\\s*%\\}",
        "description": "If conditional block"
      },
      {
        "start": "\\{%\\s*for\\b",
        "end": "\\{%\\s*endfor\\s*%\\}",
        "description": "For loop block"
      },
      {
        "start": "\\{%\\s*block\\b",
        "end": "\\{%\\s*endblock\\s*%\\}",
        "description": "Block definition"
      },
      {
        "start": "\\{%\\s*capture\\b",
        "end": "\\{%\\s*endcapture\\s*%\\}",
        "description": "Capture block"
      },
      {
        "start": "\\{\\{",
        "end": "\\}\\}",
        "description": "Output expression"
      }
    ],
    "expansionHierarchy": ["word", "expression", "filter", "tag", "block", "template", "file"]
  }
}