{
  "language": "crontab",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "^[0-9*,/\\-]+\\s+",
        "end": "$",
        "description": "Cron schedule entry"
      },
      {
        "start": "^@(yearly|annually|monthly|weekly|daily|hourly|reboot)",
        "end": "$",
        "description": "Special time string entry"
      },
      {
        "start": "^#",
        "end": "$",
        "description": "Comment line"
      },
      {
        "start": "^[A-Z_]+=",
        "end": "$",
        "description": "Environment variable assignment"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "field",
      "schedule",
      "command",
      "entry",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
