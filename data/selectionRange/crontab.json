{
  "language": "crontab",
  "selectionRanges": {
    "bracketPairs": [],
    "stringDelimiters": ["\"", "'"],
    "blockPatterns": [
      {
        "start": "^[0-9*,/\\-]+\\s+",
        "end": "$",
        "description": "Cron schedule entry"
      },
      {
        "start": "^@(yearly|annually|monthly|weekly|daily|hourly|reboot)",
        "end": "$",
        "description": "Special time string entry"
      },
      {
        "start": "^#",
        "end": "$",
        "description": "Comment line"
      },
      {
        "start": "^[A-Z_]+=",
        "end": "$",
        "description": "Environment variable assignment"
      }
    ],
    "expansionHierarchy": ["word", "field", "schedule", "command", "entry", "file"]
  }
}