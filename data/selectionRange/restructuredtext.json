{
  "language": "restructuredtext",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"]],
    "stringDelimiters": ["\"", "'", "``"],
    "blockPatterns": [
      {
        "start": "^[=\\-~^]+$",
        "end": "(?=^[=\\-~^]+$|\\Z)",
        "description": "Section heading block"
      },
      {
        "start": "^\\.\\.\\s+\\w+::",
        "end": "(?=^\\S|\\Z)",
        "description": "Directive block"
      },
      {
        "start": "^\\.\\.\\s+code-block::",
        "end": "(?=^\\S|\\Z)",
        "description": "Code block directive"
      },
      {
        "start": "^\\|",
        "end": "(?=^[^|]|\\Z)",
        "description": "Table block"
      },
      {
        "start": "^\\.\\.\\s+\\[",
        "end": "(?=^\\S|\\Z)",
        "description": "Footnote/citation block"
      }
    ],
    "expansionHierarchy": ["word", "inline", "paragraph", "block", "section", "file"]
  }
}