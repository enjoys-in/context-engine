{
  "language": "restructuredtext",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'",
      "``"
    ],
    "blockPatterns": [
      {
        "start": "^[=\\-~^]+$",
        "end": "(?=^[=\\-~^]+$|\\Z)",
        "description": "Section heading block"
      },
      {
        "start": "^\\.\\.\\s+\\w+::",
        "end": "(?=^\\S|\\Z)",
        "description": "Directive block"
      },
      {
        "start": "^\\.\\.\\s+code-block::",
        "end": "(?=^\\S|\\Z)",
        "description": "Code block directive"
      },
      {
        "start": "^\\|",
        "end": "(?=^[^|]|\\Z)",
        "description": "Table block"
      },
      {
        "start": "^\\.\\.\\s+\\[",
        "end": "(?=^\\S|\\Z)",
        "description": "Footnote/citation block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "inline",
      "paragraph",
      "block",
      "section",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
