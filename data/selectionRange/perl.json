{
  "language": "perl",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'",
      "`"
    ],
    "blockPatterns": [
      {
        "start": "\\bsub\\s+\\w+",
        "end": "\\}",
        "description": "Subroutine definition block"
      },
      {
        "start": "\\bif\\s*\\(|\\bunless\\s*\\(",
        "end": "\\}",
        "description": "If/unless conditional block"
      },
      {
        "start": "\\b(for|foreach|while|until)\\b",
        "end": "\\}",
        "description": "Loop block"
      },
      {
        "start": "\\bpackage\\s+[\\w:]+",
        "end": "(?=\\bpackage\\b|\\Z)",
        "description": "Package block"
      },
      {
        "start": "<<['\"]?(\\w+)['\"]?",
        "end": "^\\1$",
        "description": "Here-document block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "subroutine",
      "package",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
