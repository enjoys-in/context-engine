{
  "language": "perl",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"]],
    "stringDelimiters": ["\"", "'", "`"],
    "blockPatterns": [
      {
        "start": "\\bsub\\s+\\w+",
        "end": "\\}",
        "description": "Subroutine definition block"
      },
      {
        "start": "\\bif\\s*\\(|\\bunless\\s*\\(",
        "end": "\\}",
        "description": "If/unless conditional block"
      },
      {
        "start": "\\b(for|foreach|while|until)\\b",
        "end": "\\}",
        "description": "Loop block"
      },
      {
        "start": "\\bpackage\\s+[\\w:]+",
        "end": "(?=\\bpackage\\b|\\Z)",
        "description": "Package block"
      },
      {
        "start": "<<['\"]?(\\w+)['\"]?",
        "end": "^\\1$",
        "description": "Here-document block"
      }
    ],
    "expansionHierarchy": ["word", "expression", "statement", "block", "subroutine", "package", "file"]
  }
}