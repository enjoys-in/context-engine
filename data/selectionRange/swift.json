{
  "language": "swift",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ],
      [
        "<",
        ">"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "\"\"\""
    ],
    "blockPatterns": [
      {
        "start": "\\bfunc\\s+\\w+",
        "end": "\\}",
        "description": "Function declaration block"
      },
      {
        "start": "\\b(class|struct|enum|protocol)\\s+\\w+",
        "end": "\\}",
        "description": "Type declaration block"
      },
      {
        "start": "\\bif\\b.*\\{",
        "end": "\\}",
        "description": "If conditional block"
      },
      {
        "start": "\\b(for|while)\\b.*\\{",
        "end": "\\}",
        "description": "Loop block"
      },
      {
        "start": "\\bswitch\\b.*\\{",
        "end": "\\}",
        "description": "Switch statement block"
      },
      {
        "start": "\\bguard\\b",
        "end": "\\}",
        "description": "Guard statement block"
      },
      {
        "start": "\\bextension\\s+\\w+",
        "end": "\\}",
        "description": "Extension block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "function",
      "type",
      "extension",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
