{
  "language": "ruby",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'",
      "`"
    ],
    "blockPatterns": [
      {
        "start": "\\bdef\\s+\\w+",
        "end": "\\bend\\b",
        "description": "Method definition block"
      },
      {
        "start": "\\bclass\\s+\\w+",
        "end": "\\bend\\b",
        "description": "Class definition block"
      },
      {
        "start": "\\bmodule\\s+\\w+",
        "end": "\\bend\\b",
        "description": "Module definition block"
      },
      {
        "start": "\\bif\\b|\\bunless\\b",
        "end": "\\bend\\b",
        "description": "If/unless conditional block"
      },
      {
        "start": "\\b(do|\\{)\\s*\\|",
        "end": "\\bend\\b|\\}",
        "description": "Block/iterator block"
      },
      {
        "start": "\\bbegin\\b",
        "end": "\\bend\\b",
        "description": "Begin-rescue block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "method",
      "class",
      "module",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
