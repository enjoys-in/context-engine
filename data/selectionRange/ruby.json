{
  "language": "ruby",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'",
      "`"
    ],
    "blockPatterns": [
      {
        "start": "\\bdef\\s+\\w+",
        "end": "\\bend\\b",
        "description": "Method definition block"
      },
      {
        "start": "\\bclass\\s+\\w+",
        "end": "\\bend\\b",
        "description": "Class definition block"
      },
      {
        "start": "\\bmodule\\s+\\w+",
        "end": "\\bend\\b",
        "description": "Module definition block"
      },
      {
        "start": "\\bif\\b|\\bunless\\b",
        "end": "\\bend\\b",
        "description": "If/unless conditional block"
      },
      {
        "start": "\\b(do|\\{)\\s*\\|",
        "end": "\\bend\\b|\\}",
        "description": "Block/iterator block"
      },
      {
        "start": "\\bbegin\\b",
        "end": "\\bend\\b",
        "description": "Begin-rescue block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "method",
      "class",
      "module",
      "file"
    ]
  }
}