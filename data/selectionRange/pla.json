{
  "language": "pla",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"]],
    "stringDelimiters": ["\""],
    "blockPatterns": [
      {
        "start": "\\bFUNCTION\\b|\\bPROCEDURE\\b",
        "end": "\\bEND\\b",
        "description": "Function/procedure block"
      },
      {
        "start": "\\bIF\\b",
        "end": "\\bEND\\s+IF\\b",
        "description": "If conditional block"
      },
      {
        "start": "\\bLOOP\\b|\\bFOR\\b|\\bWHILE\\b",
        "end": "\\bEND\\s+LOOP\\b",
        "description": "Loop block"
      },
      {
        "start": "\\bBEGIN\\b",
        "end": "\\bEND\\b",
        "description": "Begin-end block"
      }
    ],
    "expansionHierarchy": ["word", "expression", "statement", "block", "procedure", "package", "file"]
  }
}