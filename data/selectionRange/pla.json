{
  "language": "pla",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\bFUNCTION\\b|\\bPROCEDURE\\b",
        "end": "\\bEND\\b",
        "description": "Function/procedure block"
      },
      {
        "start": "\\bIF\\b",
        "end": "\\bEND\\s+IF\\b",
        "description": "If conditional block"
      },
      {
        "start": "\\bLOOP\\b|\\bFOR\\b|\\bWHILE\\b",
        "end": "\\bEND\\s+LOOP\\b",
        "description": "Loop block"
      },
      {
        "start": "\\bBEGIN\\b",
        "end": "\\bEND\\b",
        "description": "Begin-end block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "procedure",
      "package",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
