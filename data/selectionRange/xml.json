{
  "language": "xml",
  "selectionRanges": {
    "bracketPairs": [["<", ">"]],
    "stringDelimiters": ["\"", "'"],
    "blockPatterns": [
      {
        "start": "<\\w+[^/>]*>",
        "end": "</\\w+>",
        "description": "Element block"
      },
      {
        "start": "<!--",
        "end": "-->",
        "description": "Comment block"
      },
      {
        "start": "<!\\[CDATA\\[",
        "end": "\\]\\]>",
        "description": "CDATA section"
      },
      {
        "start": "<\\?xml\\b",
        "end": "\\?>",
        "description": "XML declaration"
      },
      {
        "start": "<!DOCTYPE\\b",
        "end": ">",
        "description": "DOCTYPE declaration"
      }
    ],
    "expansionHierarchy": ["word", "attribute-value", "attribute", "tag", "element", "parent-element", "document", "file"]
  }
}