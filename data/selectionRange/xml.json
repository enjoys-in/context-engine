{
  "language": "xml",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "<\\w+[^/>]*>",
        "end": "</\\w+>",
        "description": "Element block"
      },
      {
        "start": "<!--",
        "end": "-->",
        "description": "Comment block"
      },
      {
        "start": "<!\\[CDATA\\[",
        "end": "\\]\\]>",
        "description": "CDATA section"
      },
      {
        "start": "<\\?xml\\b",
        "end": "\\?>",
        "description": "XML declaration"
      },
      {
        "start": "<!DOCTYPE\\b",
        "end": ">",
        "description": "DOCTYPE declaration"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "attribute-value",
      "attribute",
      "tag",
      "element",
      "parent-element",
      "document",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
