{
  "language": "vb",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\b(Sub|Function)\\s+\\w+",
        "end": "\\bEnd\\s+(Sub|Function)\\b",
        "description": "Sub/Function declaration block"
      },
      {
        "start": "\\bClass\\s+\\w+",
        "end": "\\bEnd\\s+Class\\b",
        "description": "Class declaration block"
      },
      {
        "start": "\\bIf\\b",
        "end": "\\bEnd\\s+If\\b",
        "description": "If conditional block"
      },
      {
        "start": "\\bFor\\b|\\bWhile\\b|\\bDo\\b",
        "end": "\\bNext\\b|\\bEnd\\s+While\\b|\\bLoop\\b",
        "description": "Loop block"
      },
      {
        "start": "\\bSelect\\s+Case\\b",
        "end": "\\bEnd\\s+Select\\b",
        "description": "Select Case block"
      },
      {
        "start": "\\bNamespace\\s+[\\w.]+",
        "end": "\\bEnd\\s+Namespace\\b",
        "description": "Namespace block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "method",
      "class",
      "namespace",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
