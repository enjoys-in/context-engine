{
  "language": "json",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Object block"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Array block"
      },
      {
        "start": "\"[^\"]+\"\\s*:",
        "end": ",|(?=\\}|\\])",
        "description": "Key-value pair"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "string",
      "value",
      "key-value",
      "object",
      "root",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
