{
  "language": "json",
  "selectionRanges": {
    "bracketPairs": [["{", "}"], ["[", "]"]],
    "stringDelimiters": ["\""],
    "blockPatterns": [
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Object block"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Array block"
      },
      {
        "start": "\"[^\"]+\"\\s*:",
        "end": ",|(?=\\}|\\])",
        "description": "Key-value pair"
      }
    ],
    "expansionHierarchy": ["word", "string", "value", "key-value", "object", "root", "file"]
  }
}