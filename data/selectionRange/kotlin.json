{
  "language": "kotlin",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"], ["<", ">"]],
    "stringDelimiters": ["\"", "'", "\"\"\""],
    "blockPatterns": [
      {
        "start": "\\bclass\\s+\\w+|\\bobject\\s+\\w+",
        "end": "\\}",
        "description": "Class/object declaration block"
      },
      {
        "start": "\\bfun\\s+\\w+",
        "end": "\\}",
        "description": "Function declaration block"
      },
      {
        "start": "\\bif\\s*\\(",
        "end": "\\}",
        "description": "If conditional block"
      },
      {
        "start": "\\bwhen\\s*[({]",
        "end": "\\}",
        "description": "When expression block"
      },
      {
        "start": "\\bfor\\s*\\(|\\bwhile\\s*\\(",
        "end": "\\}",
        "description": "Loop block"
      },
      {
        "start": "\\btry\\s*\\{",
        "end": "\\}",
        "description": "Try-catch block"
      }
    ],
    "expansionHierarchy": ["word", "expression", "statement", "block", "function", "class", "file"]
  }
}