{
  "language": "go",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "`"
    ],
    "blockPatterns": [
      {
        "start": "\\bfunc\\b.*\\{",
        "end": "\\}",
        "description": "Function declaration block"
      },
      {
        "start": "\\btype\\s+\\w+\\s+struct\\s*\\{",
        "end": "\\}",
        "description": "Struct type declaration block"
      },
      {
        "start": "\\btype\\s+\\w+\\s+interface\\s*\\{",
        "end": "\\}",
        "description": "Interface type declaration block"
      },
      {
        "start": "\\bif\\b.*\\{",
        "end": "\\}",
        "description": "If conditional block"
      },
      {
        "start": "\\bfor\\b.*\\{",
        "end": "\\}",
        "description": "For loop block"
      },
      {
        "start": "\\bswitch\\b.*\\{|\\bselect\\b.*\\{",
        "end": "\\}",
        "description": "Switch/select block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "function",
      "type",
      "package",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  },
  "selectionPatterns": [
    {
      "pattern": "\\\\b\\\\w+\\\\b",
      "expandTo": "word",
      "description": "Select word in Go"
    },
    {
      "pattern": "\"[^\"]*\"|'[^']*'",
      "expandTo": "string",
      "description": "Select string literal"
    },
    {
      "pattern": "\\\\([^)]*\\\\)",
      "expandTo": "parentheses",
      "description": "Select parenthesized expression"
    },
    {
      "pattern": "\\\\[[^\\\\]]*\\\\]",
      "expandTo": "brackets",
      "description": "Select bracketed expression"
    },
    {
      "pattern": "\\\\{[^}]*\\\\}",
      "expandTo": "braces",
      "description": "Select braced block"
    },
    {
      "pattern": "[^\\\\n;]+",
      "expandTo": "statement",
      "description": "Select full statement"
    },
    {
      "pattern": "\\\\{[\\\\s\\\\S]*?\\\\}",
      "expandTo": "block",
      "description": "Select Go code block"
    },
    {
      "pattern": "(function|def|fn|func)\\\\s+\\\\w+[^{]*\\\\{[\\\\s\\\\S]*?\\\\}",
      "expandTo": "function-body",
      "description": "Select function body"
    },
    {
      "pattern": "^.*$",
      "expandTo": "line",
      "description": "Select entire line"
    },
    {
      "pattern": "\\/\\\\*[\\\\s\\\\S]*?\\\\*\\/|#.*$|\\/\\/.*$",
      "expandTo": "comment",
      "description": "Select comment block"
    },
    {
      "pattern": "(import|require|use|include|from)\\\\s+.*",
      "expandTo": "imports",
      "description": "Select import block"
    },
    {
      "pattern": "class\\\\s+\\\\w+[^{]*\\\\{[\\\\s\\\\S]*?\\\\}",
      "expandTo": "class-body",
      "description": "Select class/type body"
    }
  ]
}
