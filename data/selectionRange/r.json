{
  "language": "r",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\w+\\s*<-\\s*function\\s*\\(",
        "end": "\\}",
        "description": "Function definition block"
      },
      {
        "start": "\\bif\\s*\\(",
        "end": "\\}",
        "description": "If conditional block"
      },
      {
        "start": "\\bfor\\s*\\(|\\bwhile\\s*\\(",
        "end": "\\}",
        "description": "Loop block"
      },
      {
        "start": "\\btryCatch\\s*\\(",
        "end": "\\)",
        "description": "Try-catch block"
      },
      {
        "start": "\\brepeat\\s*\\{",
        "end": "\\}",
        "description": "Repeat block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "function",
      "file"
    ]
  }
}