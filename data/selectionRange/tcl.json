{
  "language": "tcl",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\bproc\\s+\\w+",
        "end": "\\}",
        "description": "Procedure definition block"
      },
      {
        "start": "\\bif\\s*\\{",
        "end": "\\}",
        "description": "If conditional block"
      },
      {
        "start": "\\b(for|foreach|while)\\b",
        "end": "\\}",
        "description": "Loop block"
      },
      {
        "start": "\\bswitch\\b",
        "end": "\\}",
        "description": "Switch block"
      },
      {
        "start": "\\bnamespace\\s+eval\\b",
        "end": "\\}",
        "description": "Namespace evaluation block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "command",
      "block",
      "procedure",
      "namespace",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
