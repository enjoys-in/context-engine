{
  "language": "shell",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ],
      [
        "[[",
        "]]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'",
      "`"
    ],
    "blockPatterns": [
      {
        "start": "\\bfunction\\s+\\w+|\\w+\\s*\\(\\)\\s*\\{",
        "end": "\\}",
        "description": "Function definition"
      },
      {
        "start": "\\bif\\b",
        "end": "\\bfi\\b",
        "description": "If conditional block"
      },
      {
        "start": "\\bfor\\b|\\bwhile\\b|\\buntil\\b",
        "end": "\\bdone\\b",
        "description": "Loop block"
      },
      {
        "start": "\\bcase\\b",
        "end": "\\besac\\b",
        "description": "Case statement block"
      },
      {
        "start": "<<-?\\s*['\"]?(\\w+)['\"]?",
        "end": "^\\1$",
        "description": "Here-document block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "command",
      "pipeline",
      "statement",
      "block",
      "function",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
