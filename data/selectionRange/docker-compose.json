{
  "language": "docker-compose",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "^services:\\s*$",
        "end": "(?=^\\w+:|\\Z)",
        "description": "Services section"
      },
      {
        "start": "^\\s{2}\\w+:\\s*$",
        "end": "(?=^\\s{2}\\w+:|^\\w+:|\\Z)",
        "description": "Service definition block"
      },
      {
        "start": "^volumes:\\s*$",
        "end": "(?=^\\w+:|\\Z)",
        "description": "Volumes section"
      },
      {
        "start": "^networks:\\s*$",
        "end": "(?=^\\w+:|\\Z)",
        "description": "Networks section"
      },
      {
        "start": "^\\s+environment:",
        "end": "(?=^\\s{4}\\w+:|^\\s{2}\\w+:|^\\w+:)",
        "description": "Environment variables block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "value",
      "key-value",
      "property-group",
      "service",
      "section",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
