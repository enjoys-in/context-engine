{
  "language": "docker-compose",
  "selectionRanges": {
    "bracketPairs": [
      [
        "[",
        "]"
      ],
      [
        "{",
        "}"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "^services:\\s*$",
        "end": "(?=^\\w+:|\\Z)",
        "description": "Services section"
      },
      {
        "start": "^\\s{2}\\w+:\\s*$",
        "end": "(?=^\\s{2}\\w+:|^\\w+:|\\Z)",
        "description": "Service definition block"
      },
      {
        "start": "^volumes:\\s*$",
        "end": "(?=^\\w+:|\\Z)",
        "description": "Volumes section"
      },
      {
        "start": "^networks:\\s*$",
        "end": "(?=^\\w+:|\\Z)",
        "description": "Networks section"
      },
      {
        "start": "^\\s+environment:",
        "end": "(?=^\\s{4}\\w+:|^\\s{2}\\w+:|^\\w+:)",
        "description": "Environment variables block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "value",
      "key-value",
      "property-group",
      "service",
      "section",
      "file"
    ]
  }
}