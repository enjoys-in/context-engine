{
  "language": "sparql",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\bSELECT\\b",
        "end": "\\}",
        "description": "SELECT query block"
      },
      {
        "start": "\\bCONSTRUCT\\b",
        "end": "\\}",
        "description": "CONSTRUCT query block"
      },
      {
        "start": "\\bWHERE\\s*\\{",
        "end": "\\}",
        "description": "WHERE clause block"
      },
      {
        "start": "\\bOPTIONAL\\s*\\{",
        "end": "\\}",
        "description": "OPTIONAL block"
      },
      {
        "start": "\\bFILTER\\s*\\(",
        "end": "\\)",
        "description": "FILTER expression"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "triple-pattern",
      "graph-pattern",
      "clause",
      "query",
      "file"
    ]
  }
}