{
  "language": "sparql",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\bSELECT\\b",
        "end": "\\}",
        "description": "SELECT query block"
      },
      {
        "start": "\\bCONSTRUCT\\b",
        "end": "\\}",
        "description": "CONSTRUCT query block"
      },
      {
        "start": "\\bWHERE\\s*\\{",
        "end": "\\}",
        "description": "WHERE clause block"
      },
      {
        "start": "\\bOPTIONAL\\s*\\{",
        "end": "\\}",
        "description": "OPTIONAL block"
      },
      {
        "start": "\\bFILTER\\s*\\(",
        "end": "\\)",
        "description": "FILTER expression"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "triple-pattern",
      "graph-pattern",
      "clause",
      "query",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
