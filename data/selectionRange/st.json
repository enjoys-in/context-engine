{
  "language": "st",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\w+\\s*>>\\s*\\[",
        "end": "\\]",
        "description": "Method definition block"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Block closure"
      },
      {
        "start": "\\bifTrue:\\b|\\bifFalse:\\b",
        "end": "\\]",
        "description": "Conditional block"
      },
      {
        "start": "\\btimesRepeat:\\b|\\bdo:\\b|\\bcollect:\\b",
        "end": "\\]",
        "description": "Iterator block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "message-send",
      "statement",
      "block",
      "method",
      "class",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
