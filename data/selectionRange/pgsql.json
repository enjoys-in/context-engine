{
  "language": "pgsql",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "'",
      "$$"
    ],
    "blockPatterns": [
      {
        "start": "\\bSELECT\\b",
        "end": ";",
        "description": "SELECT statement block"
      },
      {
        "start": "\\bCREATE\\s+(OR\\s+REPLACE\\s+)?(TABLE|VIEW|FUNCTION|PROCEDURE)\\b",
        "end": ";|\\$\\$",
        "description": "CREATE definition block"
      },
      {
        "start": "\\bBEGIN\\b",
        "end": "\\bEND\\b",
        "description": "BEGIN-END transaction/block"
      },
      {
        "start": "\\bIF\\b",
        "end": "\\bEND\\s+IF\\b",
        "description": "IF conditional block"
      },
      {
        "start": "\\bLOOP\\b|\\bFOR\\b|\\bWHILE\\b",
        "end": "\\bEND\\s+LOOP\\b",
        "description": "Loop block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "clause",
      "statement",
      "block",
      "function",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
