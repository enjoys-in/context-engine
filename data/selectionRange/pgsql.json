{
  "language": "pgsql",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ]
    ],
    "stringDelimiters": [
      "'",
      "$$"
    ],
    "blockPatterns": [
      {
        "start": "\\bSELECT\\b",
        "end": ";",
        "description": "SELECT statement block"
      },
      {
        "start": "\\bCREATE\\s+(OR\\s+REPLACE\\s+)?(TABLE|VIEW|FUNCTION|PROCEDURE)\\b",
        "end": ";|\\$\\$",
        "description": "CREATE definition block"
      },
      {
        "start": "\\bBEGIN\\b",
        "end": "\\bEND\\b",
        "description": "BEGIN-END transaction/block"
      },
      {
        "start": "\\bIF\\b",
        "end": "\\bEND\\s+IF\\b",
        "description": "IF conditional block"
      },
      {
        "start": "\\bLOOP\\b|\\bFOR\\b|\\bWHILE\\b",
        "end": "\\bEND\\s+LOOP\\b",
        "description": "Loop block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "clause",
      "statement",
      "block",
      "function",
      "file"
    ]
  }
}