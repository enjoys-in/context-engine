{
  "language": "ssh_config",
  "selectionRanges": {
    "bracketPairs": [],
    "stringDelimiters": [
      "\""
    ],
    "blockPatterns": [
      {
        "start": "^Host\\s+",
        "end": "(?=^Host\\s|^Match\\s|\\Z)",
        "description": "Host block"
      },
      {
        "start": "^Match\\s+",
        "end": "(?=^Host\\s|^Match\\s|\\Z)",
        "description": "Match block"
      },
      {
        "start": "^\\s+\\w+\\s+",
        "end": "$",
        "description": "Configuration directive"
      },
      {
        "start": "^#",
        "end": "$",
        "description": "Comment line"
      }
    ],
    "expansionHierarchy": [
      "word",
      "value",
      "directive",
      "host-block",
      "file"
    ]
  }
}