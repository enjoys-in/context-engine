{
  "language": "ssh_config",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "^Host\\s+",
        "end": "(?=^Host\\s|^Match\\s|\\Z)",
        "description": "Host block"
      },
      {
        "start": "^Match\\s+",
        "end": "(?=^Host\\s|^Match\\s|\\Z)",
        "description": "Match block"
      },
      {
        "start": "^\\s+\\w+\\s+",
        "end": "$",
        "description": "Configuration directive"
      },
      {
        "start": "^#",
        "end": "$",
        "description": "Comment line"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "value",
      "directive",
      "host-block",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
