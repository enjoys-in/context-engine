{
  "language": "msdax",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\""
    ],
    "blockPatterns": [
      {
        "start": "\\bDEFINE\\b",
        "end": "\\bEVALUATE\\b",
        "description": "DEFINE block"
      },
      {
        "start": "\\bEVALUATE\\b",
        "end": "(?=\\bDEFINE\\b|$)",
        "description": "EVALUATE block"
      },
      {
        "start": "\\bCALCULATE\\s*\\(",
        "end": "\\)",
        "description": "CALCULATE function block"
      },
      {
        "start": "\\bSUMMARIZE\\s*\\(",
        "end": "\\)",
        "description": "SUMMARIZE function block"
      },
      {
        "start": "\\bFILTER\\s*\\(",
        "end": "\\)",
        "description": "FILTER function block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "function-call",
      "measure",
      "query",
      "file"
    ]
  }
}