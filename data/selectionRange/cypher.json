{
  "language": "cypher",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\bMATCH\\b",
        "end": "\\bRETURN\\b|\\bWITH\\b|;|$",
        "description": "MATCH clause block"
      },
      {
        "start": "\\bCREATE\\b",
        "end": "\\bRETURN\\b|;|$",
        "description": "CREATE clause block"
      },
      {
        "start": "\\bWHERE\\b",
        "end": "\\bRETURN\\b|\\bWITH\\b|\\bSET\\b|$",
        "description": "WHERE filter clause"
      },
      {
        "start": "\\bWITH\\b",
        "end": "\\bMATCH\\b|\\bRETURN\\b|$",
        "description": "WITH projection clause"
      },
      {
        "start": "\\bCALL\\b",
        "end": "\\bYIELD\\b|$",
        "description": "Procedure call block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "pattern",
      "clause",
      "query",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
