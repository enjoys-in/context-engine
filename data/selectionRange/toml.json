{
  "language": "toml",
  "selectionRanges": {
    "bracketPairs": [["[", "]"], ["{", "}"]],
    "stringDelimiters": ["\"", "'", "\"\"\"", "'''"],
    "blockPatterns": [
      {
        "start": "^\\[\\w[\\w.]*\\]",
        "end": "(?=^\\[|\\Z)",
        "description": "Table section"
      },
      {
        "start": "^\\[\\[\\w[\\w.]*\\]\\]",
        "end": "(?=^\\[|\\Z)",
        "description": "Array of tables section"
      },
      {
        "start": "^\\w[\\w-]*\\s*=",
        "end": "$",
        "description": "Key-value pair"
      },
      {
        "start": "^#",
        "end": "$",
        "description": "Comment line"
      }
    ],
    "expansionHierarchy": ["word", "value", "key-value", "table", "file"]
  }
}