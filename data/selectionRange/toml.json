{
  "language": "toml",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'",
      "\"\"\"",
      "'''"
    ],
    "blockPatterns": [
      {
        "start": "^\\[\\w[\\w.]*\\]",
        "end": "(?=^\\[|\\Z)",
        "description": "Table section"
      },
      {
        "start": "^\\[\\[\\w[\\w.]*\\]\\]",
        "end": "(?=^\\[|\\Z)",
        "description": "Array of tables section"
      },
      {
        "start": "^\\w[\\w-]*\\s*=",
        "end": "$",
        "description": "Key-value pair"
      },
      {
        "start": "^#",
        "end": "$",
        "description": "Comment line"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "value",
      "key-value",
      "table",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
