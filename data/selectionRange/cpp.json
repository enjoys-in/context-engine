{
  "language": "cpp",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ],
      [
        "<",
        ">"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\b\\w+\\s+\\w+\\s*\\([^)]*\\)\\s*(const)?\\s*\\{",
        "end": "\\}",
        "description": "Function/method definition block"
      },
      {
        "start": "\\b(class|struct)\\s+\\w+[^;]*\\{",
        "end": "\\};",
        "description": "Class/struct definition block"
      },
      {
        "start": "\\bnamespace\\s+\\w+\\s*\\{",
        "end": "\\}",
        "description": "Namespace block"
      },
      {
        "start": "\\bif\\s*\\(",
        "end": "\\}",
        "description": "If conditional block"
      },
      {
        "start": "\\bfor\\s*\\(|\\bwhile\\s*\\(",
        "end": "\\}",
        "description": "Loop block"
      },
      {
        "start": "\\btemplate\\s*<",
        "end": "\\}|;",
        "description": "Template declaration block"
      },
      {
        "start": "#ifdef|#ifndef|#if",
        "end": "#endif",
        "description": "Preprocessor conditional block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "function",
      "class",
      "namespace",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
