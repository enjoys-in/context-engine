{
  "language": "cpp",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"], ["<", ">"]],
    "stringDelimiters": ["\"", "'"],
    "blockPatterns": [
      {
        "start": "\\b\\w+\\s+\\w+\\s*\\([^)]*\\)\\s*(const)?\\s*\\{",
        "end": "\\}",
        "description": "Function/method definition block"
      },
      {
        "start": "\\b(class|struct)\\s+\\w+[^;]*\\{",
        "end": "\\};",
        "description": "Class/struct definition block"
      },
      {
        "start": "\\bnamespace\\s+\\w+\\s*\\{",
        "end": "\\}",
        "description": "Namespace block"
      },
      {
        "start": "\\bif\\s*\\(",
        "end": "\\}",
        "description": "If conditional block"
      },
      {
        "start": "\\bfor\\s*\\(|\\bwhile\\s*\\(",
        "end": "\\}",
        "description": "Loop block"
      },
      {
        "start": "\\btemplate\\s*<",
        "end": "\\}|;",
        "description": "Template declaration block"
      },
      {
        "start": "#ifdef|#ifndef|#if",
        "end": "#endif",
        "description": "Preprocessor conditional block"
      }
    ],
    "expansionHierarchy": ["word", "expression", "statement", "block", "function", "class", "namespace", "file"]
  }
}