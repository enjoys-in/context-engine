{
  "language": "c",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"]],
    "stringDelimiters": ["\"", "'"],
    "blockPatterns": [
      {
        "start": "\\b\\w+\\s+\\w+\\s*\\([^)]*\\)\\s*\\{",
        "end": "\\}",
        "description": "Function definition block"
      },
      {
        "start": "\\bstruct\\s+\\w*\\s*\\{",
        "end": "\\};",
        "description": "Struct definition block"
      },
      {
        "start": "\\bif\\s*\\(",
        "end": "\\}",
        "description": "If conditional block"
      },
      {
        "start": "\\bfor\\s*\\(|\\bwhile\\s*\\(",
        "end": "\\}",
        "description": "Loop block"
      },
      {
        "start": "\\bswitch\\s*\\(",
        "end": "\\}",
        "description": "Switch statement block"
      },
      {
        "start": "#ifdef|#ifndef|#if",
        "end": "#endif",
        "description": "Preprocessor conditional block"
      }
    ],
    "expansionHierarchy": ["word", "expression", "statement", "block", "function", "file"]
  }
}