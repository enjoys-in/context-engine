{
  "language": "makefile",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "^[\\w.%-]+\\s*:(?!=)",
        "end": "(?=^[\\w.%-]+\\s*:|^$|\\Z)",
        "description": "Target rule block"
      },
      {
        "start": "^define\\s+\\w+",
        "end": "^endef",
        "description": "Multi-line variable definition"
      },
      {
        "start": "^ifeq\\b|^ifneq\\b|^ifdef\\b|^ifndef\\b",
        "end": "^endif",
        "description": "Conditional directive block"
      },
      {
        "start": "^\\w+\\s*[:?+]?=",
        "end": "$",
        "description": "Variable assignment"
      },
      {
        "start": "^include\\b",
        "end": "$",
        "description": "Include directive"
      }
    ],
    "expansionHierarchy": [
      "word",
      "variable",
      "command",
      "recipe",
      "target",
      "file"
    ]
  }
}