{
  "language": "makefile",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "^[\\w.%-]+\\s*:(?!=)",
        "end": "(?=^[\\w.%-]+\\s*:|^$|\\Z)",
        "description": "Target rule block"
      },
      {
        "start": "^define\\s+\\w+",
        "end": "^endef",
        "description": "Multi-line variable definition"
      },
      {
        "start": "^ifeq\\b|^ifneq\\b|^ifdef\\b|^ifndef\\b",
        "end": "^endif",
        "description": "Conditional directive block"
      },
      {
        "start": "^\\w+\\s*[:?+]?=",
        "end": "$",
        "description": "Variable assignment"
      },
      {
        "start": "^include\\b",
        "end": "$",
        "description": "Include directive"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "variable",
      "command",
      "recipe",
      "target",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
