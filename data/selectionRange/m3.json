{
  "language": "m3",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\""
    ],
    "blockPatterns": [
      {
        "start": "\\bMODULE\\b",
        "end": "\\bEND\\b",
        "description": "Module block"
      },
      {
        "start": "\\bPROCEDURE\\b",
        "end": "\\bEND\\b",
        "description": "Procedure block"
      },
      {
        "start": "\\bIF\\b",
        "end": "\\bEND\\b",
        "description": "If conditional block"
      },
      {
        "start": "\\bFOR\\b|\\bWHILE\\b|\\bLOOP\\b",
        "end": "\\bEND\\b",
        "description": "Loop block"
      },
      {
        "start": "\\bTYPE\\b",
        "end": ";",
        "description": "Type declaration"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "procedure",
      "module",
      "file"
    ]
  }
}