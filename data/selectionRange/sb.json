{
  "language": "sb",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\bSub\\s+\\w+",
        "end": "\\bEndSub\\b",
        "description": "Subroutine block"
      },
      {
        "start": "\\bIf\\b",
        "end": "\\bEndIf\\b",
        "description": "If conditional block"
      },
      {
        "start": "\\bFor\\b",
        "end": "\\bEndFor\\b",
        "description": "For loop block"
      },
      {
        "start": "\\bWhile\\b",
        "end": "\\bEndWhile\\b",
        "description": "While loop block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "subroutine",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
