{
  "language": "sb",
  "selectionRanges": {
    "bracketPairs": [["(", ")"]],
    "stringDelimiters": ["\""],
    "blockPatterns": [
      {
        "start": "\\bSub\\s+\\w+",
        "end": "\\bEndSub\\b",
        "description": "Subroutine block"
      },
      {
        "start": "\\bIf\\b",
        "end": "\\bEndIf\\b",
        "description": "If conditional block"
      },
      {
        "start": "\\bFor\\b",
        "end": "\\bEndFor\\b",
        "description": "For loop block"
      },
      {
        "start": "\\bWhile\\b",
        "end": "\\bEndWhile\\b",
        "description": "While loop block"
      }
    ],
    "expansionHierarchy": ["word", "expression", "statement", "block", "subroutine", "file"]
  }
}