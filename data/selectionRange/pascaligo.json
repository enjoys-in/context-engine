{
  "language": "pascaligo",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\bfunction\\s+\\w+",
        "end": "\\bend|\\bis\\b.*(?=\\bfunction\\b|$)",
        "description": "Function definition block"
      },
      {
        "start": "\\btype\\b",
        "end": "(?=\\btype\\b|\\bfunction\\b|\\bconst\\b|$)",
        "description": "Type declaration block"
      },
      {
        "start": "\\bbegin\\b",
        "end": "\\bend\\b",
        "description": "Begin-end block"
      },
      {
        "start": "\\bif\\b",
        "end": "(?=\\belse\\b|;|$)",
        "description": "If conditional block"
      },
      {
        "start": "\\bcase\\b",
        "end": "\\bend\\b",
        "description": "Case expression block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "function",
      "module",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
