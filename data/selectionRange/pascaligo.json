{
  "language": "pascaligo",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\""
    ],
    "blockPatterns": [
      {
        "start": "\\bfunction\\s+\\w+",
        "end": "\\bend|\\bis\\b.*(?=\\bfunction\\b|$)",
        "description": "Function definition block"
      },
      {
        "start": "\\btype\\b",
        "end": "(?=\\btype\\b|\\bfunction\\b|\\bconst\\b|$)",
        "description": "Type declaration block"
      },
      {
        "start": "\\bbegin\\b",
        "end": "\\bend\\b",
        "description": "Begin-end block"
      },
      {
        "start": "\\bif\\b",
        "end": "(?=\\belse\\b|;|$)",
        "description": "If conditional block"
      },
      {
        "start": "\\bcase\\b",
        "end": "\\bend\\b",
        "description": "Case expression block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "function",
      "module",
      "file"
    ]
  }
}