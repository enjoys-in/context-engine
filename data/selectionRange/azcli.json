{
  "language": "azcli",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["[", "]"]],
    "stringDelimiters": ["\"", "'"],
    "blockPatterns": [
      {
        "start": "^az\\s+",
        "end": "$",
        "description": "Azure CLI command"
      },
      {
        "start": "--[a-z-]+",
        "end": "\\s",
        "description": "Command parameter"
      },
      {
        "start": "\\\\\\n",
        "end": "[^\\\\]$",
        "description": "Multi-line continuation"
      }
    ],
    "expansionHierarchy": ["word", "parameter", "argument", "command", "pipeline", "file"]
  }
}