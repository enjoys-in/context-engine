{
  "language": "azcli",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "^az\\s+",
        "end": "$",
        "description": "Azure CLI command"
      },
      {
        "start": "--[a-z-]+",
        "end": "\\s",
        "description": "Command parameter"
      },
      {
        "start": "\\\\\\n",
        "end": "[^\\\\]$",
        "description": "Multi-line continuation"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "parameter",
      "argument",
      "command",
      "pipeline",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
