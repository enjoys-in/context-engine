{
  "language": "flow9",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\bimport\\b",
        "end": ";",
        "description": "Import statement"
      },
      {
        "start": "\\b\\w+\\s*\\(.*\\)\\s*->\\s*\\{",
        "end": "\\}",
        "description": "Function definition block"
      },
      {
        "start": "\\bif\\s*\\(",
        "end": "\\}|;",
        "description": "If conditional block"
      },
      {
        "start": "\\bswitch\\s*\\(",
        "end": "\\}",
        "description": "Switch expression block"
      },
      {
        "start": "\\bexport\\b",
        "end": "\\}|;",
        "description": "Export block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "function",
      "module",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
