{
  "language": "flow9",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"]],
    "stringDelimiters": ["\""],
    "blockPatterns": [
      {
        "start": "\\bimport\\b",
        "end": ";",
        "description": "Import statement"
      },
      {
        "start": "\\b\\w+\\s*\\(.*\\)\\s*->\\s*\\{",
        "end": "\\}",
        "description": "Function definition block"
      },
      {
        "start": "\\bif\\s*\\(",
        "end": "\\}|;",
        "description": "If conditional block"
      },
      {
        "start": "\\bswitch\\s*\\(",
        "end": "\\}",
        "description": "Switch expression block"
      },
      {
        "start": "\\bexport\\b",
        "end": "\\}|;",
        "description": "Export block"
      }
    ],
    "expansionHierarchy": ["word", "expression", "statement", "block", "function", "module", "file"]
  }
}