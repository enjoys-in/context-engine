{
  "language": "qsharp",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\boperation\\s+\\w+",
        "end": "\\}",
        "description": "Operation definition block"
      },
      {
        "start": "\\bfunction\\s+\\w+",
        "end": "\\}",
        "description": "Function definition block"
      },
      {
        "start": "\\bnamespace\\s+[\\w.]+",
        "end": "\\}",
        "description": "Namespace block"
      },
      {
        "start": "\\bif\\s*\\(",
        "end": "\\}",
        "description": "If conditional block"
      },
      {
        "start": "\\bfor\\s*\\(|\\bwhile\\s*\\(",
        "end": "\\}",
        "description": "Loop block"
      },
      {
        "start": "\\busing\\s*\\(",
        "end": "\\}",
        "description": "Qubit allocation block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "operation",
      "namespace",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
