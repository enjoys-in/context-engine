{
  "language": "qsharp",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"]],
    "stringDelimiters": ["\""],
    "blockPatterns": [
      {
        "start": "\\boperation\\s+\\w+",
        "end": "\\}",
        "description": "Operation definition block"
      },
      {
        "start": "\\bfunction\\s+\\w+",
        "end": "\\}",
        "description": "Function definition block"
      },
      {
        "start": "\\bnamespace\\s+[\\w.]+",
        "end": "\\}",
        "description": "Namespace block"
      },
      {
        "start": "\\bif\\s*\\(",
        "end": "\\}",
        "description": "If conditional block"
      },
      {
        "start": "\\bfor\\s*\\(|\\bwhile\\s*\\(",
        "end": "\\}",
        "description": "Loop block"
      },
      {
        "start": "\\busing\\s*\\(",
        "end": "\\}",
        "description": "Qubit allocation block"
      }
    ],
    "expansionHierarchy": ["word", "expression", "statement", "block", "operation", "namespace", "file"]
  }
}