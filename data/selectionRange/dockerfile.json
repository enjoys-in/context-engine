{
  "language": "dockerfile",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "^FROM\\b",
        "end": "(?=^FROM\\b|\\Z)",
        "description": "Build stage block"
      },
      {
        "start": "^RUN\\b",
        "end": "(?=^[A-Z]+\\b|\\Z)",
        "description": "RUN instruction block"
      },
      {
        "start": "^COPY\\b|^ADD\\b",
        "end": "$",
        "description": "Copy/add instruction"
      },
      {
        "start": "^ENV\\b",
        "end": "$",
        "description": "Environment variable instruction"
      },
      {
        "start": "^ENTRYPOINT\\b|^CMD\\b",
        "end": "$",
        "description": "Entrypoint/command instruction"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "argument",
      "instruction",
      "stage",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
