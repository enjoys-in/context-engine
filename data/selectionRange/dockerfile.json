{
  "language": "dockerfile",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"]],
    "stringDelimiters": ["\"", "'"],
    "blockPatterns": [
      {
        "start": "^FROM\\b",
        "end": "(?=^FROM\\b|\\Z)",
        "description": "Build stage block"
      },
      {
        "start": "^RUN\\b",
        "end": "(?=^[A-Z]+\\b|\\Z)",
        "description": "RUN instruction block"
      },
      {
        "start": "^COPY\\b|^ADD\\b",
        "end": "$",
        "description": "Copy/add instruction"
      },
      {
        "start": "^ENV\\b",
        "end": "$",
        "description": "Environment variable instruction"
      },
      {
        "start": "^ENTRYPOINT\\b|^CMD\\b",
        "end": "$",
        "description": "Entrypoint/command instruction"
      }
    ],
    "expansionHierarchy": ["word", "argument", "instruction", "stage", "file"]
  }
}