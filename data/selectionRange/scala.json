{
  "language": "scala",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'",
      "\"\"\""
    ],
    "blockPatterns": [
      {
        "start": "\\bdef\\s+\\w+",
        "end": "\\}|(?=\\bdef\\b|\\bval\\b|\\bvar\\b|$)",
        "description": "Method definition block"
      },
      {
        "start": "\\b(class|object|trait)\\s+\\w+",
        "end": "\\}",
        "description": "Class/object/trait declaration block"
      },
      {
        "start": "\\bif\\s*\\(",
        "end": "\\}",
        "description": "If conditional block"
      },
      {
        "start": "\\bfor\\s*[({]",
        "end": "\\}|\\)",
        "description": "For comprehension block"
      },
      {
        "start": "\\bmatch\\s*\\{",
        "end": "\\}",
        "description": "Match expression block"
      },
      {
        "start": "\\bpackage\\s+[\\w.]+",
        "end": "\\}|(?=\\bpackage\\b)",
        "description": "Package block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "method",
      "class",
      "package",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
