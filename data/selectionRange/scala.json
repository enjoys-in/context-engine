{
  "language": "scala",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"]],
    "stringDelimiters": ["\"", "'", "\"\"\""],
    "blockPatterns": [
      {
        "start": "\\bdef\\s+\\w+",
        "end": "\\}|(?=\\bdef\\b|\\bval\\b|\\bvar\\b|$)",
        "description": "Method definition block"
      },
      {
        "start": "\\b(class|object|trait)\\s+\\w+",
        "end": "\\}",
        "description": "Class/object/trait declaration block"
      },
      {
        "start": "\\bif\\s*\\(",
        "end": "\\}",
        "description": "If conditional block"
      },
      {
        "start": "\\bfor\\s*[({]",
        "end": "\\}|\\)",
        "description": "For comprehension block"
      },
      {
        "start": "\\bmatch\\s*\\{",
        "end": "\\}",
        "description": "Match expression block"
      },
      {
        "start": "\\bpackage\\s+[\\w.]+",
        "end": "\\}|(?=\\bpackage\\b)",
        "description": "Package block"
      }
    ],
    "expansionHierarchy": ["word", "expression", "statement", "block", "method", "class", "package", "file"]
  }
}