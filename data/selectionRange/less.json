{
  "language": "less",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"]],
    "stringDelimiters": ["\"", "'"],
    "blockPatterns": [
      {
        "start": "[.#]?[\\w-]+\\s*\\{",
        "end": "\\}",
        "description": "Selector rule block"
      },
      {
        "start": "@media\\b",
        "end": "\\}",
        "description": "Media query block"
      },
      {
        "start": "\\.[\\w-]+\\s*\\(",
        "end": "\\}",
        "description": "Mixin definition block"
      },
      {
        "start": "@[\\w-]+\\s*:",
        "end": ";",
        "description": "Variable declaration"
      },
      {
        "start": "&:",
        "end": "\\}|;",
        "description": "Parent reference selector"
      }
    ],
    "expansionHierarchy": ["word", "value", "property", "declaration", "rule", "media-query", "file"]
  }
}