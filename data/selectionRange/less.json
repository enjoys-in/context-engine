{
  "language": "less",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "[.#]?[\\w-]+\\s*\\{",
        "end": "\\}",
        "description": "Selector rule block"
      },
      {
        "start": "@media\\b",
        "end": "\\}",
        "description": "Media query block"
      },
      {
        "start": "\\.[\\w-]+\\s*\\(",
        "end": "\\}",
        "description": "Mixin definition block"
      },
      {
        "start": "@[\\w-]+\\s*:",
        "end": ";",
        "description": "Variable declaration"
      },
      {
        "start": "&:",
        "end": "\\}|;",
        "description": "Parent reference selector"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "value",
      "property",
      "declaration",
      "rule",
      "media-query",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
