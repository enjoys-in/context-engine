{
  "language": "coffee",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"]],
    "stringDelimiters": ["\"", "'", "`"],
    "blockPatterns": [
      {
        "start": "^\\s*\\w+\\s*[=:]\\s*\\(.*\\)\\s*->|=>",
        "end": "(?=^\\S|\\Z)",
        "description": "Function definition (indent-based)"
      },
      {
        "start": "\\bclass\\s+\\w+",
        "end": "(?=^\\S|\\Z)",
        "description": "Class definition block"
      },
      {
        "start": "\\bif\\b",
        "end": "(?=^\\S|\\belse\\b|\\Z)",
        "description": "If conditional block"
      },
      {
        "start": "\\bfor\\b.*\\bin\\b",
        "end": "(?=^\\S|\\Z)",
        "description": "For loop block"
      },
      {
        "start": "\\bswitch\\b",
        "end": "(?=^\\S|\\Z)",
        "description": "Switch statement block"
      }
    ],
    "expansionHierarchy": ["word", "expression", "statement", "indented-block", "function", "class", "file"]
  }
}