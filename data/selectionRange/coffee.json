{
  "language": "coffee",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'",
      "`"
    ],
    "blockPatterns": [
      {
        "start": "^\\s*\\w+\\s*[=:]\\s*\\(.*\\)\\s*->|=>",
        "end": "(?=^\\S|\\Z)",
        "description": "Function definition (indent-based)"
      },
      {
        "start": "\\bclass\\s+\\w+",
        "end": "(?=^\\S|\\Z)",
        "description": "Class definition block"
      },
      {
        "start": "\\bif\\b",
        "end": "(?=^\\S|\\belse\\b|\\Z)",
        "description": "If conditional block"
      },
      {
        "start": "\\bfor\\b.*\\bin\\b",
        "end": "(?=^\\S|\\Z)",
        "description": "For loop block"
      },
      {
        "start": "\\bswitch\\b",
        "end": "(?=^\\S|\\Z)",
        "description": "Switch statement block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "indented-block",
      "function",
      "class",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
