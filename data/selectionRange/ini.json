{
  "language": "ini",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "^\\[.+\\]",
        "end": "(?=^\\[|\\Z)",
        "description": "Section block"
      },
      {
        "start": "^[a-zA-Z_][a-zA-Z0-9_]*\\s*=",
        "end": "$",
        "description": "Key-value assignment"
      },
      {
        "start": "^[;#]",
        "end": "$",
        "description": "Comment line"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "value",
      "key-value",
      "section",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
