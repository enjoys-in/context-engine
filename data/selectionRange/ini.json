{
  "language": "ini",
  "selectionRanges": {
    "bracketPairs": [["[", "]"]],
    "stringDelimiters": ["\"", "'"],
    "blockPatterns": [
      {
        "start": "^\\[.+\\]",
        "end": "(?=^\\[|\\Z)",
        "description": "Section block"
      },
      {
        "start": "^[a-zA-Z_][a-zA-Z0-9_]*\\s*=",
        "end": "$",
        "description": "Key-value assignment"
      },
      {
        "start": "^[;#]",
        "end": "$",
        "description": "Comment line"
      }
    ],
    "expansionHierarchy": ["word", "value", "key-value", "section", "file"]
  }
}