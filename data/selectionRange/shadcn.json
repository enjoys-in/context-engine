{
  "language": "shadcn",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'",
      "`"
    ],
    "blockPatterns": [
      {
        "name": "stringLiteral",
        "pattern": "([\"'])(?:(?!\\1)[^\\\\]|\\\\.)*\\1",
        "captureGroup": 0,
        "description": "Select a single or double quoted string literal"
      },
      {
        "name": "templateLiteral",
        "pattern": "`(?:[^`\\\\]|\\\\.)*`",
        "captureGroup": 0,
        "description": "Select a template literal string including backticks"
      },
      {
        "name": "jsxElement",
        "pattern": "<([A-Z][a-zA-Z0-9.]*)[^>]*>(?:[\\s\\S]*?)</\\1>|<([A-Z][a-zA-Z0-9.]*)[^>]*/>",
        "captureGroup": 0,
        "description": "Select an entire JSX element including opening and closing tags"
      },
      {
        "name": "jsxAttributeValue",
        "pattern": "(?<==)(?:\\{[^}]*\\}|\"[^\"]*\"|'[^']*')",
        "captureGroup": 0,
        "description": "Select a JSX attribute value (string or expression)"
      },
      {
        "name": "functionParameters",
        "pattern": "\\(([^()]*)\\)",
        "captureGroup": 1,
        "description": "Select the parameters inside a function's parentheses"
      },
      {
        "name": "classNameString",
        "pattern": "className\\s*=\\s*(?:\"([^\"]*)\"|'([^']*)'|\\{([^}]*)\\})",
        "captureGroup": 0,
        "description": "Select the full className attribute value"
      },
      {
        "name": "cnArguments",
        "pattern": "cn\\(([^)]*)\\)",
        "captureGroup": 1,
        "description": "Select the arguments inside a cn() utility call"
      },
      {
        "name": "cvaVariantValues",
        "pattern": "variants\\s*:\\s*\\{([\\s\\S]*?)\\}(?=\\s*[,}])",
        "captureGroup": 1,
        "description": "Select the variant values object inside a cva() config"
      },
      {
        "name": "objectProperty",
        "pattern": "([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*:\\s*([^,}]+)",
        "captureGroup": 0,
        "description": "Select a single object property (key: value pair)"
      },
      {
        "name": "arrayElement",
        "pattern": "(?<=\\[|,)\\s*([^,\\]]+)",
        "captureGroup": 1,
        "description": "Select a single element within an array literal"
      },
      {
        "name": "typeAnnotation",
        "pattern": ":\\s*([A-Z][a-zA-Z0-9<>,\\s|&\\[\\]]*)",
        "captureGroup": 1,
        "description": "Select a TypeScript type annotation after a colon"
      },
      {
        "name": "genericType",
        "pattern": "<([A-Z][a-zA-Z0-9,\\s<>]*)>",
        "captureGroup": 1,
        "description": "Select the type parameters inside angle brackets"
      },
      {
        "name": "importSpecifiers",
        "pattern": "\\{\\s*([^}]+)\\s*\\}\\s*from",
        "captureGroup": 1,
        "description": "Select the named import specifiers within an import statement"
      },
      {
        "name": "formFieldBlock",
        "pattern": "<FormField[\\s\\S]*?</FormField>|<FormField[^>]*/>",
        "captureGroup": 0,
        "description": "Select an entire FormField component block including children"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "function",
      "class",
      "module",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  },
  "selectionPatterns": [
    {
      "pattern": "\\\\b\\\\w+\\\\b",
      "expandTo": "word",
      "description": "Select word in shadcn/ui"
    },
    {
      "pattern": "\"[^\"]*\"|'[^']*'",
      "expandTo": "string",
      "description": "Select string literal"
    },
    {
      "pattern": "\\\\([^)]*\\\\)",
      "expandTo": "parentheses",
      "description": "Select parenthesized expression"
    },
    {
      "pattern": "\\\\[[^\\\\]]*\\\\]",
      "expandTo": "brackets",
      "description": "Select bracketed expression"
    },
    {
      "pattern": "\\\\{[^}]*\\\\}",
      "expandTo": "braces",
      "description": "Select braced block"
    },
    {
      "pattern": "[^\\\\n;]+",
      "expandTo": "statement",
      "description": "Select full statement"
    },
    {
      "pattern": "\\\\{[\\\\s\\\\S]*?\\\\}",
      "expandTo": "block",
      "description": "Select shadcn/ui code block"
    },
    {
      "pattern": "(function|def|fn|func)\\\\s+\\\\w+[^{]*\\\\{[\\\\s\\\\S]*?\\\\}",
      "expandTo": "function-body",
      "description": "Select function body"
    },
    {
      "pattern": "^.*$",
      "expandTo": "line",
      "description": "Select entire line"
    },
    {
      "pattern": "\\/\\\\*[\\\\s\\\\S]*?\\\\*\\/|#.*$|\\/\\/.*$",
      "expandTo": "comment",
      "description": "Select comment block"
    },
    {
      "pattern": "(import|require|use|include|from)\\\\s+.*",
      "expandTo": "imports",
      "description": "Select import block"
    },
    {
      "pattern": "class\\\\s+\\\\w+[^{]*\\\\{[\\\\s\\\\S]*?\\\\}",
      "expandTo": "class-body",
      "description": "Select class/type body"
    }
  ]
}
