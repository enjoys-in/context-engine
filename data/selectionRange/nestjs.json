{
  "language": "nestjs",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'",
      "`"
    ],
    "blockPatterns": [
      {
        "pattern": "\\{[^}]*\\}",
        "description": "Curly brace block"
      },
      {
        "pattern": "\\([^)]*\\)",
        "description": "Parentheses"
      },
      {
        "pattern": "\\[[^\\]]*\\]",
        "description": "Square brackets"
      },
      {
        "pattern": "@\\w+\\([^)]*\\)",
        "description": "Decorator"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "function",
      "class",
      "module",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
