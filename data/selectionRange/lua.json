{
  "language": "lua",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'",
      "\\[\\["
    ],
    "blockPatterns": [
      {
        "start": "\\bfunction\\b",
        "end": "\\bend\\b",
        "description": "Function definition block"
      },
      {
        "start": "\\bif\\b",
        "end": "\\bend\\b",
        "description": "If conditional block"
      },
      {
        "start": "\\bfor\\b|\\bwhile\\b|\\brepeat\\b",
        "end": "\\bend\\b|\\buntil\\b",
        "description": "Loop block"
      },
      {
        "start": "\\bdo\\b",
        "end": "\\bend\\b",
        "description": "Do block"
      },
      {
        "start": "\\blocal\\s+function\\b",
        "end": "\\bend\\b",
        "description": "Local function definition"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "function",
      "chunk",
      "file"
    ]
  }
}