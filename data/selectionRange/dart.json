{
  "language": "dart",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ],
      [
        "<",
        ">"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'",
      "\"\"\"",
      "'''"
    ],
    "blockPatterns": [
      {
        "start": "\\bclass\\s+\\w+",
        "end": "\\}",
        "description": "Class declaration block"
      },
      {
        "start": "\\b(void|Future|Stream|\\w+)\\s+\\w+\\s*\\(",
        "end": "\\}",
        "description": "Function/method declaration block"
      },
      {
        "start": "\\bif\\s*\\(",
        "end": "\\}",
        "description": "If conditional block"
      },
      {
        "start": "\\bfor\\s*\\(|\\bwhile\\s*\\(",
        "end": "\\}",
        "description": "Loop block"
      },
      {
        "start": "\\bswitch\\s*\\(",
        "end": "\\}",
        "description": "Switch statement block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "function",
      "class",
      "library",
      "file"
    ]
  }
}