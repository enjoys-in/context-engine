{
  "language": "markdown",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"]],
    "stringDelimiters": ["`", "\""],
    "blockPatterns": [
      {
        "start": "^#{1,6}\\s",
        "end": "(?=^#{1,6}\\s|\\Z)",
        "description": "Heading section block"
      },
      {
        "start": "^```",
        "end": "^```",
        "description": "Fenced code block"
      },
      {
        "start": "^>\\s",
        "end": "(?=^[^>]|\\Z)",
        "description": "Blockquote block"
      },
      {
        "start": "^[-*+]\\s|^\\d+\\.\\s",
        "end": "(?=^[^-*+\\d\\s]|^$|\\Z)",
        "description": "List block"
      },
      {
        "start": "^\\|",
        "end": "(?=^[^|]|\\Z)",
        "description": "Table block"
      }
    ],
    "expansionHierarchy": ["word", "inline", "paragraph", "block", "section", "file"]
  }
}