{
  "language": "mdx",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ],
      [
        "<",
        ">"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'",
      "`"
    ],
    "blockPatterns": [
      {
        "start": "^#{1,6}\\s",
        "end": "(?=^#{1,6}\\s|\\Z)",
        "description": "Heading section block"
      },
      {
        "start": "^```",
        "end": "^```",
        "description": "Fenced code block"
      },
      {
        "start": "<\\w+[^>]*>",
        "end": "</\\w+>",
        "description": "JSX component block"
      },
      {
        "start": "^export\\b",
        "end": "(?=^export\\b|^#{1,6}\\s|\\Z)",
        "description": "Export statement"
      },
      {
        "start": "^import\\b",
        "end": "$",
        "description": "Import statement"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "inline",
      "expression",
      "paragraph",
      "component",
      "section",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
