{
  "language": "mdx",
  "selectionRanges": {
    "bracketPairs": [["(", ")"], ["{", "}"], ["[", "]"], ["<", ">"]],
    "stringDelimiters": ["\"", "'", "`"],
    "blockPatterns": [
      {
        "start": "^#{1,6}\\s",
        "end": "(?=^#{1,6}\\s|\\Z)",
        "description": "Heading section block"
      },
      {
        "start": "^```",
        "end": "^```",
        "description": "Fenced code block"
      },
      {
        "start": "<\\w+[^>]*>",
        "end": "</\\w+>",
        "description": "JSX component block"
      },
      {
        "start": "^export\\b",
        "end": "(?=^export\\b|^#{1,6}\\s|\\Z)",
        "description": "Export statement"
      },
      {
        "start": "^import\\b",
        "end": "$",
        "description": "Import statement"
      }
    ],
    "expansionHierarchy": ["word", "inline", "expression", "paragraph", "component", "section", "file"]
  }
}