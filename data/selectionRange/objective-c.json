{
  "language": "objective-c",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'",
      "@\""
    ],
    "blockPatterns": [
      {
        "start": "@interface\\s+\\w+",
        "end": "@end",
        "description": "Interface declaration block"
      },
      {
        "start": "@implementation\\s+\\w+",
        "end": "@end",
        "description": "Implementation block"
      },
      {
        "start": "^[-+]\\s*\\(",
        "end": "\\}",
        "description": "Method definition block"
      },
      {
        "start": "\\bif\\s*\\(",
        "end": "\\}",
        "description": "If conditional block"
      },
      {
        "start": "\\bfor\\s*\\(|\\bwhile\\s*\\(",
        "end": "\\}",
        "description": "Loop block"
      },
      {
        "start": "@protocol\\s+\\w+",
        "end": "@end",
        "description": "Protocol declaration block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "method",
      "class",
      "file"
    ]
  }
}