{
  "language": "nginx",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "\\bserver\\s*\\{",
        "end": "\\}",
        "description": "Server block"
      },
      {
        "start": "\\blocation\\b.*\\{",
        "end": "\\}",
        "description": "Location block"
      },
      {
        "start": "\\bhttp\\s*\\{",
        "end": "\\}",
        "description": "HTTP block"
      },
      {
        "start": "\\bupstream\\s+\\w+\\s*\\{",
        "end": "\\}",
        "description": "Upstream block"
      },
      {
        "start": "\\bif\\s*\\(",
        "end": "\\}",
        "description": "If conditional block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "argument",
      "directive",
      "block",
      "context",
      "file"
    ]
  }
}