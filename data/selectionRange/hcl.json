{
  "language": "hcl",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ]
    ],
    "stringDelimiters": [
      "\""
    ],
    "blockPatterns": [
      {
        "start": "\\bresource\\s+\"[^\"]+\"\\s+\"[^\"]+\"\\s*\\{",
        "end": "\\}",
        "description": "Resource block"
      },
      {
        "start": "\\bvariable\\s+\"[^\"]+\"\\s*\\{",
        "end": "\\}",
        "description": "Variable block"
      },
      {
        "start": "\\boutput\\s+\"[^\"]+\"\\s*\\{",
        "end": "\\}",
        "description": "Output block"
      },
      {
        "start": "\\bmodule\\s+\"[^\"]+\"\\s*\\{",
        "end": "\\}",
        "description": "Module block"
      },
      {
        "start": "\\bdata\\s+\"[^\"]+\"\\s+\"[^\"]+\"\\s*\\{",
        "end": "\\}",
        "description": "Data source block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "attribute",
      "block",
      "resource",
      "file"
    ]
  }
}