{
  "language": "razor",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ],
      [
        "<",
        ">"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "@\\{",
        "end": "\\}",
        "description": "Razor code block"
      },
      {
        "start": "@if\\s*\\(",
        "end": "\\}",
        "description": "Razor if conditional block"
      },
      {
        "start": "@(foreach|for|while)\\s*\\(",
        "end": "\\}",
        "description": "Razor loop block"
      },
      {
        "start": "<\\w+[^>]*>",
        "end": "</\\w+>",
        "description": "HTML element block"
      },
      {
        "start": "@section\\s+\\w+\\s*\\{",
        "end": "\\}",
        "description": "Razor section block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "element",
      "section",
      "page",
      "file"
    ]
  }
}