{
  "language": "razor",
  "selectionRanges": {
    "bracketPairs": [
      [
        "(",
        ")"
      ],
      [
        "{",
        "}"
      ],
      [
        "[",
        "]"
      ],
      [
        "<",
        ">"
      ]
    ],
    "stringDelimiters": [
      "\"",
      "'"
    ],
    "blockPatterns": [
      {
        "start": "@\\{",
        "end": "\\}",
        "description": "Razor code block"
      },
      {
        "start": "@if\\s*\\(",
        "end": "\\}",
        "description": "Razor if conditional block"
      },
      {
        "start": "@(foreach|for|while)\\s*\\(",
        "end": "\\}",
        "description": "Razor loop block"
      },
      {
        "start": "<\\w+[^>]*>",
        "end": "</\\w+>",
        "description": "HTML element block"
      },
      {
        "start": "@section\\s+\\w+\\s*\\{",
        "end": "\\}",
        "description": "Razor section block"
      },
      {
        "start": "\\{",
        "end": "\\}",
        "description": "Brace-delimited block"
      },
      {
        "start": "\\(",
        "end": "\\)",
        "description": "Parenthesized expression"
      },
      {
        "start": "\\[",
        "end": "\\]",
        "description": "Bracket-delimited block"
      },
      {
        "start": "/\\*",
        "end": "\\*/",
        "description": "Block comment"
      },
      {
        "start": "^\\s*if\\b",
        "end": "^\\s*(?:else|end|\\})",
        "description": "If block"
      },
      {
        "start": "^\\s*for\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "For loop block"
      },
      {
        "start": "^\\s*while\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "While loop block"
      },
      {
        "start": "^\\s*(?:class|struct)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Class/struct block"
      },
      {
        "start": "^\\s*(?:function|def|fn)\\b",
        "end": "^\\s*(?:end|\\})",
        "description": "Function block"
      },
      {
        "start": "^\\s*try\\b",
        "end": "^\\s*(?:catch|finally|end|\\})",
        "description": "Try block"
      }
    ],
    "expansionHierarchy": [
      "word",
      "expression",
      "statement",
      "block",
      "element",
      "section",
      "page",
      "file"
    ],
    "wordPattern": "[a-zA-Z_]\\w*"
  }
}
