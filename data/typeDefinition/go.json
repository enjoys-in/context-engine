{
  "language": "go",
  "typeDefinitions": {
    "int": {
      "type": "type",
      "signature": "int",
      "description": "Platform-dependent signed integer type, either 32 or 64 bits",
      "module": "builtin"
    },
    "int8": {
      "type": "type",
      "signature": "int8",
      "description": "8-bit signed integer, range -128 to 127",
      "module": "builtin"
    },
    "int16": {
      "type": "type",
      "signature": "int16",
      "description": "16-bit signed integer, range -32768 to 32767",
      "module": "builtin"
    },
    "int32": {
      "type": "type",
      "signature": "int32",
      "description": "32-bit signed integer, alias rune for Unicode code points",
      "module": "builtin"
    },
    "int64": {
      "type": "type",
      "signature": "int64",
      "description": "64-bit signed integer for large whole numbers",
      "module": "builtin"
    },
    "uint": {
      "type": "type",
      "signature": "uint",
      "description": "Platform-dependent unsigned integer type",
      "module": "builtin"
    },
    "float32": {
      "type": "type",
      "signature": "float32",
      "description": "32-bit IEEE 754 single-precision floating-point number",
      "module": "builtin"
    },
    "float64": {
      "type": "type",
      "signature": "float64",
      "description": "64-bit IEEE 754 double-precision floating-point number",
      "module": "builtin"
    },
    "string": {
      "type": "type",
      "signature": "string",
      "description": "Immutable sequence of bytes, conventionally holding UTF-8 encoded text",
      "module": "builtin"
    },
    "bool": {
      "type": "type",
      "signature": "bool",
      "description": "Boolean type with predeclared constants true and false",
      "module": "builtin"
    },
    "byte": {
      "type": "type",
      "signature": "byte (alias for uint8)",
      "description": "Alias for uint8, used for raw data and ASCII characters",
      "module": "builtin"
    },
    "rune": {
      "type": "type",
      "signature": "rune (alias for int32)",
      "description": "Alias for int32, represents a Unicode code point",
      "module": "builtin"
    },
    "error": {
      "type": "interface",
      "signature": "interface error { Error() string }",
      "description": "Built-in interface for error values, the idiomatic way to represent errors",
      "module": "builtin"
    },
    "any": {
      "type": "type",
      "signature": "any (alias for interface{})",
      "description": "Alias for the empty interface, can hold any value",
      "module": "builtin"
    },
    "complex128": {
      "type": "type",
      "signature": "complex128",
      "description": "Complex number type with float64 real and imaginary parts",
      "module": "builtin"
    },
    "uintptr": {
      "type": "type",
      "signature": "uintptr",
      "description": "Integer type large enough to hold a pointer value, used for unsafe operations",
      "module": "builtin"
    }
  }
}
