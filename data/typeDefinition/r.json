{
  "language": "r",
  "typeDefinitions": {
    "integer": {
      "type": "primitive",
      "signature": "integer",
      "description": "Signed integer type (32-bit). Created with the L suffix: 42L",
      "module": "base"
    },
    "double": {
      "type": "primitive",
      "signature": "double",
      "description": "Double-precision floating point number (64-bit IEEE 754). The default numeric type in R",
      "module": "base"
    },
    "numeric": {
      "type": "primitive",
      "signature": "numeric",
      "description": "Numeric type — encompasses both integer and double",
      "module": "base"
    },
    "character": {
      "type": "primitive",
      "signature": "character",
      "description": "Character (string) type. R has no separate single-character type",
      "module": "base"
    },
    "logical": {
      "type": "primitive",
      "signature": "logical",
      "description": "Logical (boolean) type: TRUE, FALSE, or NA",
      "module": "base"
    },
    "complex": {
      "type": "primitive",
      "signature": "complex",
      "description": "Complex number type. Created with the i suffix: 1+2i",
      "module": "base"
    },
    "raw": {
      "type": "primitive",
      "signature": "raw",
      "description": "Raw byte type. Values 0x00 to 0xff",
      "module": "base"
    },
    "list": {
      "type": "composite",
      "signature": "list",
      "description": "Generic container holding elements of any type",
      "module": "base"
    },
    "data.frame": {
      "type": "composite",
      "signature": "data.frame",
      "description": "Tabular data structure — list of equal-length vectors",
      "module": "base"
    },
    "matrix": {
      "type": "composite",
      "signature": "matrix",
      "description": "2D array with elements of the same type",
      "module": "base"
    },
    "array": {
      "type": "composite",
      "signature": "array",
      "description": "Multi-dimensional array with elements of the same type",
      "module": "base"
    },
    "factor": {
      "type": "composite",
      "signature": "factor",
      "description": "Categorical variable with fixed levels",
      "module": "base"
    },
    "environment": {
      "type": "composite",
      "signature": "environment",
      "description": "Frame for variable bindings forming a tree structure",
      "module": "base"
    },
    "function": {
      "type": "callable",
      "signature": "function",
      "description": "Function object (closure, primitive, or special)",
      "module": "base"
    },
    "formula": {
      "type": "composite",
      "signature": "formula",
      "description": "Symbolic model specification using ~ operator",
      "module": "base"
    },
    "expression": {
      "type": "composite",
      "signature": "expression",
      "description": "Vector of unevaluated R expressions",
      "module": "base"
    },
    "call": {
      "type": "composite",
      "signature": "call",
      "description": "Unevaluated function call object",
      "module": "base"
    },
    "symbol": {
      "type": "primitive",
      "signature": "name",
      "description": "Variable name (also called 'name' type)",
      "module": "base"
    },
    "NULL": {
      "type": "special",
      "signature": "NULL",
      "description": "The null object. Length 0, no type",
      "module": "base"
    },
    "NA": {
      "type": "special",
      "signature": "NA",
      "description": "Logical missing value. NA_integer_, NA_real_, NA_complex_, NA_character_ for typed variants",
      "module": "base"
    }
  }
}