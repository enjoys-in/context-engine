{
  "language": "apex",
  "typeDefinitions": {
    "String": { "type": "String", "description": "Text value" },
    "Integer": { "type": "Integer", "description": "32-bit integer" },
    "Long": { "type": "Long", "description": "64-bit integer" },
    "Double": { "type": "Double", "description": "64-bit floating point" },
    "Decimal": { "type": "Decimal", "description": "Arbitrary precision number" },
    "Boolean": { "type": "Boolean", "description": "True/false value" },
    "Id": { "type": "Id", "description": "18-character Salesforce record identifier" },
    "Date": { "type": "Date", "description": "Date without time" },
    "Datetime": { "type": "Datetime", "description": "Date with time" },
    "Time": { "type": "Time", "description": "Time without date" },
    "Blob": { "type": "Blob", "description": "Binary data" },
    "SObject": { "type": "SObject", "description": "Base type for all Salesforce objects" },
    "List": { "type": "List<T>", "description": "Ordered collection" },
    "Set": { "type": "Set<T>", "description": "Unordered unique collection" },
