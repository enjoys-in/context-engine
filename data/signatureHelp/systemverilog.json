  "signatures": [
    {
      "label": "$display(format: string, args: ...)",
      "documentation": {
        "value": "Displays formatted text to the simulator console with an automatic newline."
      },
      "parameters": [
        {
          "label": "format",
          "documentation": {
            "value": "A format string with specifiers: `%d` decimal, `%h` hex, `%b` binary, `%s` string, `%t` time, `%m` module"
          }
        },
        {
          "label": "args",
          "documentation": {
            "value": "Values to substitute into the format string"
          }
        }
      ]
    },
    {
      "label": "$write(format: string, args: ...)",
      "documentation": {
        "value": "Displays formatted text to the simulator console without a trailing newline."
      },
      "parameters": [
        {
          "label": "format",
          "documentation": {
            "value": "A format string with specifiers"
          }
        },
        {
          "label": "args",
          "documentation": {
            "value": "Values to substitute into the format string"
          }
        }
      ]
    },
    {
      "label": "$monitor(format: string, args: ...)",
      "documentation": {
        "value": "Monitors and displays signal values whenever any of the listed signals change."
      },
      "parameters": [
        {
          "label": "format",
          "documentation": {
            "value": "A format string for display"
          }
        },
        {
          "label": "args",
          "documentation": {
            "value": "Signals and values to monitor and display"
          }
        }
      ]
    },
    {
      "label": "$finish(n: integer)",
      "documentation": {
        "value": "Terminates the simulation. The argument controls the diagnostic message level."
      },
      "parameters": [
        {
          "label": "n",
          "documentation": {
            "value": "Exit verbosity: `0` no message, `1` simulation time and location, `2` time, location, and statistics"
          }
        }
      ]
    },
    {
      "label": "$time(): time",
      "documentation": {
        "value": "Returns the current simulation time as a 64-bit integer."
      },
      "parameters": []
    },
    {
      "label": "$random(seed: integer): integer",
      "documentation": {
        "value": "Returns a 32-bit signed random integer. An optional seed controls the random sequence."
      },
      "parameters": [
        {
          "label": "seed",
          "documentation": {
            "value": "Optional seed variable for the random number generator"
          }
        }
      ]
    },
    {
      "label": "$readmemh(filename: string, memory: reg, start: integer, finish: integer)",
      "documentation": {
        "value": "Reads hexadecimal values from a file and loads them into a memory array."
      },
      "parameters": [
        {
          "label": "filename",
          "documentation": {
            "value": "The path to the file containing hex data"
          }
        },
        {
          "label": "memory",
          "documentation": {
            "value": "The memory array to load data into"
          }
        },
        {
          "label": "start",
          "documentation": {
            "value": "Optional starting address"
          }
        },
        {
          "label": "finish",
          "documentation": {
            "value": "Optional ending address"
          }
        }
      ]
    },
    {
      "label": "$readmemb(filename: string, memory: reg, start: integer, finish: integer)",
      "documentation": {
        "value": "Reads binary values from a file and loads them into a memory array."
      },
      "parameters": [
        {
          "label": "filename",
          "documentation": {
            "value": "The path to the file containing binary data"
          }
        },
        {
          "label": "memory",
          "documentation": {
            "value": "The memory array to load data into"
          }
        },
        {
          "label": "start",
          "documentation": {
            "value": "Optional starting address"
          }
        },
        {
          "label": "finish",
          "documentation": {
            "value": "Optional ending address"
          }
        }
      ]
    },
    {
      "label": "assert (expression) [else action_block]",
      "documentation": {
        "value": "Checks that the given expression is true. If false, an assertion failure is reported."
      },
      "parameters": [
        {
          "label": "expression",
          "documentation": {
            "value": "A boolean expression that must be true"
          }
        },
        {
          "label": "action_block",
          "documentation": {
            "value": "Optional action to execute on failure (e.g. `$error`, `$fatal`)"
          }
        }
      ]
    },
    {
      "label": "initial begin ... end",
      "documentation": {
        "value": "Defines a block of statements that execute once at the beginning of simulation."
      },
      "parameters": []
    },
    {
      "label": "always @(sensitivity_list) begin ... end",
      "documentation": {
        "value": "Defines a block that re-executes whenever a signal in the sensitivity list changes."
      },
      "parameters": [
        {
          "label": "sensitivity_list",
          "documentation": {
            "value": "Signals to trigger on: `posedge clk`, `negedge rst`, `*` for all, or combinational signals"
          }
        }
      ]
    },
    {
      "label": "module name #(parameters) (ports); ... endmodule",
      "documentation": {
        "value": "Declares a hardware module with optional parameters and port declarations."
      },
      "parameters": [
        {
          "label": "name",
          "documentation": {
            "value": "The module identifier"
          }
        },
        {
          "label": "parameters",
          "documentation": {
            "value": "Optional parameter declarations for parameterized modules"
          }
        },
        {
          "label": "ports",
          "documentation": {
            "value": "The module's input, output, and inout port declarations"
          }
        }
      ]
    },
    {
      "label": "function [automatic] return_type name(args); ... endfunction",
      "documentation": {
        "value": "Declares a function that computes and returns a value in zero simulation time."
      },
      "parameters": [
        {
          "label": "return_type",
          "documentation": {
            "value": "The data type of the return value"
          }
        },
        {
          "label": "name",
          "documentation": {
            "value": "The function identifier"
          }
        },
        {
          "label": "args",
          "documentation": {
            "value": "Input arguments with their types"
          }
        }
      ]
    },
    {
      "label": "task [automatic] name(args); ... endtask",
      "documentation": {
        "value": "Declares a task that can contain timing controls and does not return a value."
