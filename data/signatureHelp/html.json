    {
      "label": "document.createElement(tagName: string): HTMLElement",
      "documentation": {
        "value": "Creates the HTML element specified by tagName."
      },
      "parameters": [
        {
          "label": "tagName",
          "documentation": {
            "value": "A string specifying the type of element to create (e.g., 'div', 'span', 'p')."
          }
        }
      ]
    },
    {
      "label": "document.getElementById(id: string): HTMLElement | null",
      "documentation": {
        "value": "Returns the element that has the specified ID attribute, or null if no such element exists."
      },
      "parameters": [
        {
          "label": "id",
          "documentation": {
            "value": "The ID of the element to locate."
          }
        }
      ]
    },
    {
      "label": "document.querySelector(selectors: string): Element | null",
      "documentation": {
        "value": "Returns the first element within the document that matches the specified CSS selector(s)."
      },
      "parameters": [
        {
          "label": "selectors",
          "documentation": {
            "value": "A CSS selector string (e.g., '.class', '#id', 'div > p')."
          }
        }
      ]
    },
    {
      "label": "document.querySelectorAll(selectors: string): NodeList",
      "documentation": {
        "value": "Returns a static NodeList of all elements matching the specified CSS selector(s)."
      },
      "parameters": [
        {
          "label": "selectors",
          "documentation": {
            "value": "A CSS selector string."
          }
        }
      ]
    },
    {
      "label": "element.setAttribute(name: string, value: string): void",
      "documentation": {
        "value": "Sets the value of an attribute on the specified element. If the attribute already exists, the value is updated."
      },
      "parameters": [
        {
          "label": "name",
          "documentation": {
            "value": "The name of the attribute (e.g., 'class', 'id', 'src')."
          }
        },
        {
          "label": "value",
          "documentation": {
            "value": "The value to assign to the attribute."
          }
        }
      ]
    },
    {
      "label": "element.getAttribute(name: string): string | null",
      "documentation": {
        "value": "Returns the value of a specified attribute on the element, or null if the attribute does not exist."
      },
      "parameters": [
        {
          "label": "name",
          "documentation": {
            "value": "The name of the attribute to retrieve."
          }
        }
      ]
    },
    {
      "label": "element.addEventListener(type: string, listener: EventListener, options?: AddEventListenerOptions): void",
      "documentation": {
        "value": "Registers an event handler on the element for the specified event type."
      },
      "parameters": [
        {
          "label": "type",
          "documentation": {
            "value": "The event type to listen for (e.g., 'click', 'input', 'submit')."
          }
        },
        {
          "label": "listener",
          "documentation": {
            "value": "The callback function invoked when the event fires."
          }
        },
        {
          "label": "options?",
          "documentation": {
            "value": "Optional object with capture, once, passive, and signal properties."
          }
        }
      ]
    },
    {
      "label": "element.removeEventListener(type: string, listener: EventListener, options?: EventListenerOptions): void",
      "documentation": {
        "value": "Removes a previously registered event listener from the element."
      },
      "parameters": [
        {
          "label": "type",
          "documentation": {
            "value": "The event type of the listener to remove."
          }
        },
        {
          "label": "listener",
          "documentation": {
            "value": "The callback function to remove."
          }
        },
        {
          "label": "options?",
          "documentation": {
            "value": "Optional object specifying characteristics of the listener."
          }
        }
      ]
    },
    {
      "label": "element.classList.add(tokens: ...string): void",
      "documentation": {
        "value": "Adds one or more CSS class names to the element's class list."
      },
      "parameters": [
        {
          "label": "tokens",
          "documentation": {
            "value": "One or more class names to add."
          }
        }
      ]
    },
    {
      "label": "element.classList.remove(tokens: ...string): void",
      "documentation": {
        "value": "Removes one or more CSS class names from the element's class list."
      },
      "parameters": [
        {
          "label": "tokens",
          "documentation": {
            "value": "One or more class names to remove."
          }
        }
      ]
    },
    {
      "label": "element.classList.toggle(token: string, force?: boolean): boolean",
      "documentation": {
        "value": "Toggles the specified class name on the element. If force is provided, adds the class when true and removes when false."
      },
      "parameters": [
        {
          "label": "token",
          "documentation": {
            "value": "The class name to toggle."
          }
        },
        {
          "label": "force?",
          "documentation": {
            "value": "If true, add the class; if false, remove it."
          }
        }
      ]
    },
    {
      "label": "element.insertAdjacentHTML(position: InsertPosition, text: string): void",
      "documentation": {
        "value": "Parses the text as HTML and inserts the resulting nodes at the specified position relative to the element."
      },
      "parameters": [
        {
          "label": "position",
          "documentation": {
            "value": "One of 'beforebegin', 'afterbegin', 'beforeend', 'afterend'."
          }
        },
        {
          "label": "text",
          "documentation": {
            "value": "The HTML string to parse and insert."
          }
        }
      ]
    },
