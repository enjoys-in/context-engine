  "signatures": [
    {
      "label": "@Html.Raw(value: string): IHtmlContent",
      "documentation": {
        "value": "Returns markup that is not HTML-encoded. Use with caution to avoid XSS vulnerabilities."
      },
      "parameters": [
        {
          "label": "value",
          "documentation": {
            "value": "The HTML string to render without encoding."
          }
        }
      ]
    },
    {
      "label": "@Html.ActionLink(linkText: string, actionName: string, controllerName: string, routeValues: object, htmlAttributes: object): IHtmlContent",
      "documentation": {
        "value": "Generates an HTML anchor element (<a>) for the specified controller action."
      },
      "parameters": [
        {
          "label": "linkText",
          "documentation": {
            "value": "The text to display for the link."
          }
        },
        {
          "label": "actionName",
          "documentation": {
            "value": "The name of the action method."
          }
        },
        {
          "label": "controllerName",
          "documentation": {
            "value": "The name of the controller."
          }
        },
        {
          "label": "routeValues",
          "documentation": {
            "value": "An anonymous object containing route values (e.g., new { id = 5 })."
          }
        },
        {
          "label": "htmlAttributes",
          "documentation": {
            "value": "An anonymous object containing HTML attributes (e.g., new { @class = \"btn\" })."
          }
        }
      ]
    },
    {
      "label": "@Html.Partial(partialViewName: string, model: object): IHtmlContent",
      "documentation": {
        "value": "Renders a partial view as an HTML string. Prefer @await Html.PartialAsync() for async rendering."
      },
      "parameters": [
        {
          "label": "partialViewName",
          "documentation": {
            "value": "The name of the partial view to render (e.g., \"_LoginPartial\")."
          }
        },
        {
          "label": "model",
          "documentation": {
            "value": "Optional model object to pass to the partial view."
          }
        }
      ]
    },
    {
      "label": "@Html.TextBoxFor(expression: Expression<Func<TModel, TProperty>>, htmlAttributes: object): IHtmlContent",
      "documentation": {
        "value": "Generates an HTML text input element for the specified model property with model binding."
      },
      "parameters": [
        {
          "label": "expression",
          "documentation": {
            "value": "A lambda expression identifying the model property (e.g., m => m.Name)."
          }
        },
        {
          "label": "htmlAttributes",
          "documentation": {
            "value": "An anonymous object containing HTML attributes."
          }
        }
      ]
    },
    {
      "label": "@Model.PropertyName",
      "documentation": {
        "value": "Accesses a property on the view's model. The model type is defined by the @model directive at the top of the view."
      },
      "parameters": [
        {
          "label": "PropertyName",
          "documentation": {
            "value": "The name of the property to access on the model."
          }
        }
      ]
    },
    {
      "label": "@ViewBag.PropertyName",
      "documentation": {
        "value": "Accesses dynamic data passed from the controller to the view via the ViewBag dictionary."
      },
      "parameters": [
        {
          "label": "PropertyName",
          "documentation": {
            "value": "The dynamic property name set in the controller."
          }
        }
      ]
    },
    {
      "label": "@section SectionName { content }",
      "documentation": {
        "value": "Defines a named section in a view that can be rendered in the layout using @RenderSection."
      },
      "parameters": [
        {
          "label": "SectionName",
          "documentation": {
            "value": "The name of the section (e.g., Scripts, Styles)."
          }
        },
        {
          "label": "content",
          "documentation": {
            "value": "The HTML and Razor content for this section."
          }
        }
      ]
    },
    {
      "label": "@functions { code }",
      "documentation": {
        "value": "Defines C# methods and properties within a Razor view. In Razor Pages, use @functions for page-level logic."
      },
      "parameters": [
        {
          "label": "code",
          "documentation": {
            "value": "C# methods, properties, and fields available within the view."
          }
        }
      ]
    },
    {
      "label": "@using Namespace",
      "documentation": {
        "value": "Imports a C# namespace into the Razor view, making its types available without full qualification."
      },
      "parameters": [
        {
          "label": "Namespace",
          "documentation": {
            "value": "The fully qualified namespace to import (e.g., System.Linq, MyApp.Models)."
          }
        }
      ]
    },
    {
      "label": "@inject ServiceType ServiceName",
      "documentation": {
        "value": "Injects a service from the dependency injection container into the Razor view."
      },
      "parameters": [
        {
          "label": "ServiceType",
          "documentation": {
            "value": "The type of the service to inject (e.g., IConfiguration, ILogger<IndexModel>)."
          }
        },
        {
          "label": "ServiceName",
          "documentation": {
            "value": "The property name to access the service within the view."
          }
        }
      ]
    },
