    {
      "label": "print(object): void",
      "documentation": {
        "value": "Prints an object to the console with a trailing newline.\n```dart\nprint('Hello World');\nprint(42);\nprint([1, 2, 3]);\n```"
      },
      "parameters": [
        {
          "label": "object",
          "documentation": {
            "value": "The object to print. Calls `.toString()` on the object."
          }
        }
      ]
    },
    {
      "label": "int.parse(source, {int? radix}): int",
      "documentation": {
        "value": "Parses a string as an integer. Throws `FormatException` if the string is not a valid integer.\n```dart\nint n = int.parse('42');\nint hex = int.parse('FF', radix: 16); // 255\n```"
      },
      "parameters": [
        {
          "label": "source",
          "documentation": {
            "value": "The string to parse."
          }
        },
        {
          "label": "radix",
          "documentation": {
            "value": "Optional base for parsing (2-36). Defaults to 10."
          }
        }
      ]
    },
    {
      "label": "double.parse(source): double",
      "documentation": {
        "value": "Parses a string as a double. Throws `FormatException` if invalid.\n```dart\ndouble d = double.parse('3.14');\ndouble d2 = double.parse('1e10');\n```"
      },
      "parameters": [
        {
          "label": "source",
          "documentation": {
            "value": "The string to parse as a double-precision floating-point number."
          }
        }
      ]
    },
    {
      "label": "List.add(value): void",
      "documentation": {
        "value": "Adds `value` to the end of this list, extending the length by one.\n```dart\nvar list = <int>[1, 2];\nlist.add(3); // [1, 2, 3]\n```"
      },
      "parameters": [
        {
          "label": "value",
          "documentation": {
            "value": "The element to add."
          }
        }
      ]
    },
    {
      "label": "Map.containsKey(key): bool",
      "documentation": {
        "value": "Returns `true` if the map contains the given key.\n```dart\nvar map = {'a': 1, 'b': 2};\nmap.containsKey('a'); // true\nmap.containsKey('c'); // false\n```"
      },
      "parameters": [
        {
          "label": "key",
          "documentation": {
            "value": "The key to look for."
          }
        }
      ]
    },
    {
      "label": "Future.delayed(duration, [computation]): Future<T>",
      "documentation": {
        "value": "Creates a future that completes after the given duration.\n```dart\nawait Future.delayed(Duration(seconds: 2));\nvar result = await Future.delayed(Duration(seconds: 1), () => 42);\n```"
      },
      "parameters": [
        {
          "label": "duration",
          "documentation": {
            "value": "A `Duration` object specifying the delay."
          }
        },
        {
          "label": "computation",
          "documentation": {
            "value": "Optional function to compute the future's value after the delay."
          }
        }
      ]
    },
    {
      "label": "Stream.fromIterable(elements): Stream<T>",
      "documentation": {
        "value": "Creates a stream from an iterable of elements.\n```dart\nvar stream = Stream.fromIterable([1, 2, 3]);\nawait for (var value in stream) {\n  print(value);\n}\n```"
      },
      "parameters": [
        {
          "label": "elements",
          "documentation": {
            "value": "An `Iterable<T>` of elements to emit."
          }
        }
      ]
    },
    {
      "label": "RegExp(source, {bool multiLine, bool caseSensitive, bool unicode, bool dotAll}): RegExp",
      "documentation": {
        "value": "Creates a regular expression from a pattern string.\n```dart\nvar re = RegExp(r'\\d+');\nvar match = re.firstMatch('abc123');\nvar allMatches = re.allMatches('a1 b2 c3');\n```"
      },
      "parameters": [
        {
          "label": "source",
          "documentation": {
            "value": "The regular expression pattern string."
          }
        },
        {
          "label": "multiLine",
          "documentation": {
            "value": "Whether `^` and `$` match line boundaries. Defaults to `false`."
          }
        },
        {
          "label": "caseSensitive",
          "documentation": {
            "value": "Whether the match is case-sensitive. Defaults to `true`."
          }
        },
        {
          "label": "unicode",
          "documentation": {
            "value": "Whether the pattern uses Unicode mode. Defaults to `false`."
          }
        },
        {
          "label": "dotAll",
          "documentation": {
            "value": "Whether `.` matches newlines. Defaults to `false`."
          }
        }
      ]
    },
    {
      "label": "DateTime.now(): DateTime",
      "documentation": {
        "value": "Returns the current date and time in the local time zone.\n```dart\nvar now = DateTime.now();\nprint(now.year);\nprint(now.toIso8601String());\n```"
      },
      "parameters": []
    },
    {
      "label": "Duration({int days, int hours, int minutes, int seconds, int milliseconds, int microseconds}): Duration",
      "documentation": {
        "value": "Creates a duration from named components.\n```dart\nvar d = Duration(hours: 1, minutes: 30);\nvar d2 = Duration(days: 7);\nprint(d.inMinutes); // 90\n```"
      },
      "parameters": [
        {
          "label": "days",
          "documentation": {
            "value": "Number of days."
          }
        },
        {
          "label": "hours",
          "documentation": {
