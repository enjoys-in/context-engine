    },
    {
      "label": "jsonDecode(source): dynamic",
      "documentation": {
        "value": "Parses a JSON string and returns the decoded object.\n```dart\nimport 'dart:convert';\nvar data = jsonDecode('{\"name\": \"Alice\", \"age\": 30}');\nprint(data['name']); // Alice\n```"
      },
      "parameters": [
        {
          "label": "source",
          "documentation": {
            "value": "A valid JSON string to decode."
          }
        }
      ]
    },
    {
      "label": "jsonEncode(object): String",
      "documentation": {
        "value": "Converts an object to a JSON string.\n```dart\nimport 'dart:convert';\nvar json = jsonEncode({'name': 'Alice', 'age': 30});\nprint(json); // {\"name\":\"Alice\",\"age\":30}\n```"
      },
      "parameters": [
        {
          "label": "object",
          "documentation": {
            "value": "An object to encode (must be a JSON-encodable type: `Map`, `List`, `String`, `num`, `bool`, or `null`)."
          }
        }
      ]
    },
