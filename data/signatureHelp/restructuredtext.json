  "signatures": [
    {
      "label": ".. code-block:: language\n   :linenos:\n   :emphasize-lines: lines",
      "documentation": {
        "value": "Displays a block of code with syntax highlighting. Requires Pygments for highlighting support."
      },
      "parameters": [
        {
          "label": "language",
          "documentation": {
            "value": "The programming language for syntax highlighting (e.g., python, javascript, bash, json)."
          }
        },
        {
          "label": ":linenos:",
          "documentation": {
            "value": "Optional. Adds line numbers to the code block."
          }
        },
        {
          "label": ":emphasize-lines:",
          "documentation": {
            "value": "Optional. Comma-separated list of line numbers to highlight (e.g., 1,3,5-7)."
          }
        }
      ]
    },
    {
      "label": ".. image:: path/to/image\n   :alt: text\n   :width: value\n   :height: value\n   :scale: percentage",
      "documentation": {
        "value": "Inserts an image into the document."
      },
      "parameters": [
        {
          "label": "path/to/image",
          "documentation": {
            "value": "The path or URL to the image file."
          }
        },
        {
          "label": ":alt:",
          "documentation": {
            "value": "Alternative text for accessibility."
          }
        },
        {
          "label": ":width:",
          "documentation": {
            "value": "The width of the image (e.g., 200px, 50%)."
          }
        },
        {
          "label": ":scale:",
          "documentation": {
            "value": "Scale the image as a percentage (e.g., 50 for 50%)."
          }
        }
      ]
    },
    {
      "label": ".. toctree::\n   :maxdepth: depth\n   :caption: text\n   :numbered:\n\n   document1\n   document2",
      "documentation": {
        "value": "Creates a table of contents linking to other documents. Central to Sphinx document organization."
      },
      "parameters": [
        {
          "label": ":maxdepth:",
          "documentation": {
            "value": "The maximum depth of the tree. Use 1 for top-level only."
          }
        },
        {
          "label": ":caption:",
          "documentation": {
            "value": "Optional caption displayed above the TOC tree."
          }
        },
        {
          "label": ":numbered:",
          "documentation": {
            "value": "Optional. Automatically numbers the entries."
          }
        },
        {
          "label": "documents",
          "documentation": {
            "value": "List of document names (without .rst extension), one per line."
          }
        }
      ]
    },
    {
      "label": ".. note::\n\n   Note text here.",
      "documentation": {
        "value": "Creates a note admonition block to highlight important information."
      },
      "parameters": [
        {
          "label": "text",
          "documentation": {
            "value": "The note content. Must be indented and separated from the directive by a blank line."
          }
        }
      ]
    },
    {
      "label": ".. warning::\n\n   Warning text here.",
      "documentation": {
        "value": "Creates a warning admonition block to alert readers about potential issues."
      },
      "parameters": [
        {
          "label": "text",
          "documentation": {
            "value": "The warning content. Must be indented and separated from the directive by a blank line."
          }
        }
      ]
    },
    {
      "label": ":ref:`label-name`",
