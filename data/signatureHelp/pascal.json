      },
      "parameters": [
        {
          "label": "s",
          "documentation": {
            "value": "The string or dynamic array whose length is returned."
          }
        }
      ]
    },
    {
      "label": "Copy(s: string, index: Integer, count: Integer): string",
      "documentation": {
        "value": "Returns a substring of a string, starting at the given index for the given number of characters."
      },
      "parameters": [
        {
          "label": "s",
          "documentation": {
            "value": "The source string."
          }
        },
        {
          "label": "index",
          "documentation": {
            "value": "The 1-based starting position."
          }
        },
        {
          "label": "count",
          "documentation": {
            "value": "The number of characters to copy."
          }
        }
      ]
    },
    {
      "label": "Pos(substr: string, s: string): Integer",
      "documentation": {
        "value": "Returns the position of the first occurrence of a substring in a string. Returns 0 if not found."
      },
      "parameters": [
        {
          "label": "substr",
          "documentation": {
            "value": "The substring to search for."
          }
        },
        {
          "label": "s",
          "documentation": {
            "value": "The string to search in."
          }
        }
      ]
    },
    {
      "label": "Delete(var s: string, index: Integer, count: Integer): void",
      "documentation": {
        "value": "Removes count characters from string s starting at position index."
      },
      "parameters": [
        {
          "label": "s",
          "documentation": {
            "value": "The string to modify (passed by reference)."
          }
        },
        {
          "label": "index",
          "documentation": {
            "value": "The 1-based starting position to delete from."
          }
        },
        {
          "label": "count",
          "documentation": {
            "value": "The number of characters to delete."
          }
        }
      ]
    },
    {
