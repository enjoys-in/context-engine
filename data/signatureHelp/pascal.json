      "documentation": {
        "value": "Inserts a substring into a string at the specified position."
      },
      "parameters": [
        {
          "label": "source",
          "documentation": {
            "value": "The substring to insert."
          }
        },
        {
          "label": "s",
          "documentation": {
            "value": "The target string to insert into (passed by reference)."
          }
        },
        {
          "label": "index",
          "documentation": {
            "value": "The 1-based position where the source string will be inserted."
          }
        }
      ]
    },
