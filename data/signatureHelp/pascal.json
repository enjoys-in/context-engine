    {
      "label": "WriteLn(args: ...): void",
      "documentation": {
        "value": "Writes one or more values to standard output followed by a newline character."
      },
      "parameters": [
        {
          "label": "args",
          "documentation": {
            "value": "One or more expressions to write. Supports strings, integers, reals, booleans, and chars."
          }
        }
      ]
    },
    {
      "label": "ReadLn(var s: string): void",
      "documentation": {
        "value": "Reads a line of text from standard input into a variable."
      },
      "parameters": [
        {
          "label": "s",
          "documentation": {
            "value": "The variable to store the input. Reads until end of line."
          }
        }
      ]
    },
    {
