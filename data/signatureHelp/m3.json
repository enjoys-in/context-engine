      "documentation": { "value": "Returns the square root of x." },
      "parameters": [
        { "label": "x", "documentation": { "value": "A non-negative real number." } }
      ]
    },
    {
      "label": "Thread.Signal(cv: Condition): void",
      "documentation": { "value": "Wakes one thread waiting on the condition variable cv." },
      "parameters": [
        { "label": "cv", "documentation": { "value": "The condition variable to signal." } }
      ]
    },
    {
      "label": "Thread.Broadcast(cv: Condition): void",
      "documentation": { "value": "Wakes all threads waiting on the condition variable cv." },
      "parameters": [
        { "label": "cv", "documentation": { "value": "The condition variable to broadcast on." } }
      ]
    }
