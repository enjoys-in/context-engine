    {
      "label": "IO.Put(wr: Wr.T, txt: TEXT): void",
      "documentation": {
        "value": "Writes a text string to the specified writer. If wr is omitted, writes to standard output."
      },
      "parameters": [
        {
          "label": "wr",
          "documentation": {
            "value": "The writer to output to. Use Stdio.stdout for standard output."
          }
        },
        {
          "label": "txt",
          "documentation": {
            "value": "The TEXT string to write."
          }
        }
      ]
    },
    {
      "label": "IO.PutInt(wr: Wr.T, n: INTEGER): void",
      "documentation": {
        "value": "Writes an integer to the specified writer as its decimal text representation."
      },
      "parameters": [
        {
          "label": "wr",
          "documentation": {
            "value": "The writer to output to."
          }
        },
        {
          "label": "n",
          "documentation": {
            "value": "The integer value to write."
          }
        }
      ]
    },
