    {
      "label": "IO.Put(wr: Wr.T, txt: TEXT): void",
      "documentation": { "value": "Writes a text string to the specified writer. If wr is omitted, writes to standard output." },
      "parameters": [
        { "label": "wr", "documentation": { "value": "The writer to output to. Use Stdio.stdout for standard output." } },
        { "label": "txt", "documentation": { "value": "The TEXT string to write." } }
      ]
    },
    {
      "label": "IO.PutInt(wr: Wr.T, n: INTEGER): void",
      "documentation": { "value": "Writes an integer to the specified writer as its decimal text representation." },
      "parameters": [
        { "label": "wr", "documentation": { "value": "The writer to output to." } },
        { "label": "n", "documentation": { "value": "The integer value to write." } }
      ]
    },
    {
      "label": "Text.Length(t: TEXT): CARDINAL",
      "documentation": { "value": "Returns the number of characters in the text." },
      "parameters": [
        { "label": "t", "documentation": { "value": "The TEXT value to measure." } }
      ]
    },
    {
      "label": "Text.Sub(t: TEXT, start: CARDINAL, length: CARDINAL): TEXT",
      "documentation": { "value": "Returns a substring of t starting at position start with the given length." },
      "parameters": [
        { "label": "t", "documentation": { "value": "The source TEXT string." } },
        { "label": "start", "documentation": { "value": "The zero-based starting index." } },
        { "label": "length", "documentation": { "value": "The number of characters to extract." } }
      ]
    },
    {
      "label": "Text.Cat(t: TEXT, u: TEXT): TEXT",
      "documentation": { "value": "Concatenates two text values and returns the result." },
      "parameters": [
        { "label": "t", "documentation": { "value": "The first text string." } },
        { "label": "u", "documentation": { "value": "The second text string." } }
      ]
    },
    {
      "label": "Text.Equal(t: TEXT, u: TEXT): BOOLEAN",
      "documentation": { "value": "Returns TRUE if the two text values contain the same characters." },
      "parameters": [
        { "label": "t", "documentation": { "value": "The first text to compare." } },
        { "label": "u", "documentation": { "value": "The second text to compare." } }
      ]
    },
    {
      "label": "Text.GetChar(t: TEXT, i: CARDINAL): CHAR",
      "documentation": { "value": "Returns the character at position i in the text. Raises an exception if i is out of range." },
      "parameters": [
        { "label": "t", "documentation": { "value": "The TEXT value." } },
        { "label": "i", "documentation": { "value": "The zero-based character index." } }
      ]
    },
