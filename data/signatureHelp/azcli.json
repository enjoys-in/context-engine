  "signatures": [
    {
      "label": "az group create --name <name> --location <location> [--tags]",
      "documentation": {
        "value": "Creates a new resource group.\n```bash\naz group create --name myRG --location eastus\naz group create --name myRG --location westus2 --tags env=dev\n```"
      },
      "parameters": [
        {
          "label": "--name",
          "documentation": {
            "value": "Name of the new resource group."
          }
        },
        {
          "label": "--location",
          "documentation": {
            "value": "Azure region (e.g. `eastus`, `westus2`, `northeurope`)."
          }
        },
        {
          "label": "--tags",
          "documentation": {
            "value": "Optional space-separated tags in `key=value` format."
          }
        }
      ]
    },
    {
      "label": "az vm create --resource-group <rg> --name <name> --image <image> [--size] [--admin-username] [--generate-ssh-keys]",
      "documentation": {
        "value": "Creates a new virtual machine.\n```bash\naz vm create --resource-group myRG --name myVM --image Ubuntu2204 --size Standard_B1s --admin-username azureuser --generate-ssh-keys\n```"
      },
      "parameters": [
        {
          "label": "--resource-group",
          "documentation": {
            "value": "Name of the resource group."
          }
        },
        {
          "label": "--name",
          "documentation": {
            "value": "Name of the virtual machine."
          }
        },
        {
          "label": "--image",
          "documentation": {
            "value": "OS image URN or alias (e.g. `Ubuntu2204`, `Win2019Datacenter`)."
          }
        },
        {
          "label": "--size",
          "documentation": {
            "value": "Optional VM size (e.g. `Standard_B1s`, `Standard_D2s_v3`)."
          }
        },
        {
          "label": "--admin-username",
          "documentation": {
            "value": "Administrator username for the VM."
          }
        },
        {
          "label": "--generate-ssh-keys",
          "documentation": {
            "value": "Generate SSH public and private key files if they don't exist."
          }
        }
      ]
    },
    {
      "label": "az storage account create --name <name> --resource-group <rg> --location <location> --sku <sku>",
      "documentation": {
        "value": "Creates a new storage account.\n```bash\naz storage account create --name mystorageacct --resource-group myRG --location eastus --sku Standard_LRS\n```"
      },
      "parameters": [
        {
          "label": "--name",
          "documentation": {
            "value": "Globally unique storage account name (3-24 lowercase letters/digits)."
          }
        },
        {
          "label": "--resource-group",
          "documentation": {
            "value": "Name of the resource group."
          }
        },
        {
          "label": "--location",
          "documentation": {
            "value": "Azure region."
          }
        },
        {
          "label": "--sku",
          "documentation": {
            "value": "Storage SKU: `Standard_LRS`, `Standard_GRS`, `Standard_ZRS`, `Premium_LRS`."
          }
        }
      ]
    },
    {
      "label": "az webapp create --resource-group <rg> --plan <plan> --name <name> [--runtime]",
      "documentation": {
        "value": "Creates a new web app.\n```bash\naz webapp create --resource-group myRG --plan myPlan --name myApp --runtime \"NODE:18-lts\"\n```"
      },
      "parameters": [
        {
          "label": "--resource-group",
          "documentation": {
            "value": "Name of the resource group."
          }
        },
        {
          "label": "--plan",
          "documentation": {
            "value": "Name of the App Service plan."
          }
        },
        {
          "label": "--name",
          "documentation": {
            "value": "Globally unique name for the web app."
          }
        },
        {
          "label": "--runtime",
          "documentation": {
            "value": "Optional runtime stack (e.g. `\"NODE:18-lts\"`, `\"PYTHON:3.11\"`)."
          }
        }
      ]
    },
    {
      "label": "az keyvault create --name <name> --resource-group <rg> --location <location> [--sku]",
      "documentation": {
        "value": "Creates a new Azure Key Vault.\n```bash\naz keyvault create --name myVault --resource-group myRG --location eastus\n```"
      },
      "parameters": [
        {
          "label": "--name",
          "documentation": {
            "value": "Globally unique name for the key vault."
          }
        },
        {
          "label": "--resource-group",
          "documentation": {
            "value": "Name of the resource group."
          }
        },
        {
          "label": "--location",
          "documentation": {
            "value": "Azure region."
          }
        },
        {
          "label": "--sku",
          "documentation": {
            "value": "Optional SKU: `standard` (default) or `premium`."
          }
        }
      ]
    },
    {
      "label": "az account set --subscription <subscription>",
      "documentation": {
        "value": "Sets the current active subscription.\n```bash\naz account set --subscription \"My Subscription\"\naz account set --subscription 12345678-abcd-efgh-ijkl-123456789012\n```"
      },
      "parameters": [
        {
          "label": "--subscription",
          "documentation": {
            "value": "Subscription name or ID to set as active."
          }
        }
      ]
    },
    {
      "label": "az login [--use-device-code] [--tenant]",
      "documentation": {
        "value": "Logs in to Azure.\n```bash\naz login\naz login --use-device-code\naz login --tenant myorg.onmicrosoft.com\n```"
      },
      "parameters": [
        {
          "label": "--use-device-code",
          "documentation": {
            "value": "Use device code flow for environments without a browser."
          }
        },
        {
          "label": "--tenant",
          "documentation": {
            "value": "Optional Azure AD tenant domain or ID."
          }
        }
      ]
    },
    {
      "label": "az logout [--username]",
      "documentation": {
        "value": "Logs out and removes access to Azure subscriptions.\n```bash\naz logout\naz logout --username user@example.com\n```"
      },
      "parameters": [
        {
          "label": "--username",
          "documentation": {
            "value": "Optional specific account to log out."
          }
        }
      ]
    },
    {
      "label": "az configure [--defaults] [--scope]",
      "documentation": {
        "value": "Manages Azure CLI configuration including default values.\n```bash\naz configure --defaults group=myRG location=eastus\naz configure --defaults web=myApp\n```"
      },
      "parameters": [
        {
          "label": "--defaults",
          "documentation": {
            "value": "Space-separated defaults in `key=value` format (e.g. `group=myRG`)."
          }
        },
        {
          "label": "--scope",
          "documentation": {
            "value": "Scope of defaults: `global` (default) or `local`."
          }
        }
      ]
    },
