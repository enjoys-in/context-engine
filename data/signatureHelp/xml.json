  "signatures": [
    {
      "label": "<element attribute=\"value\">content</element>",
      "documentation": {
        "value": "An XML element with an opening tag, optional attributes, content, and a closing tag."
      },
      "parameters": [
        {
          "label": "element",
          "documentation": {
            "value": "The tag name (must start with a letter or underscore, no spaces)"
          }
        },
        {
          "label": "attribute=\"value\"",
          "documentation": {
            "value": "Optional name-value pairs providing metadata about the element"
          }
        },
        {
          "label": "content",
          "documentation": {
            "value": "The element content: text, child elements, or mixed content"
          }
        }
      ]
    },
    {
      "label": "attribute=\"value\"",
      "documentation": {
        "value": "An attribute provides additional information about an element. Values must be quoted with single or double quotes."
      },
      "parameters": [
        {
          "label": "attribute",
          "documentation": {
            "value": "The attribute name"
          }
        },
        {
          "label": "value",
          "documentation": {
            "value": "The attribute value (must be enclosed in quotes)"
          }
        }
      ]
    },
    {
      "label": "<![CDATA[content]]>",
      "documentation": {
        "value": "A CDATA section allows inclusion of text that would otherwise be recognized as markup. Content is not parsed."
      },
      "parameters": [
        {
          "label": "content",
          "documentation": {
            "value": "Unparsed character data — can contain `<`, `>`, `&` without escaping"
          }
        }
      ]
    },
    {
      "label": "<?target instruction?>",
      "documentation": {
        "value": "A processing instruction provides instructions to an application processing the XML document."
      },
      "parameters": [
        {
          "label": "target",
          "documentation": {
            "value": "The target application name (e.g. `xml`, `xml-stylesheet`)"
          }
        },
        {
          "label": "instruction",
          "documentation": {
            "value": "Additional data for the target application"
          }
        }
      ]
    },
    {
      "label": "xmlns:prefix=\"namespaceURI\"",
      "documentation": {
        "value": "Declares an XML namespace, associating a prefix with a URI to avoid name collisions between elements from different vocabularies."
      },
      "parameters": [
        {
          "label": "prefix",
          "documentation": {
            "value": "The namespace prefix to use (omit for default namespace: `xmlns=\"...\"`) "
          }
        },
        {
          "label": "namespaceURI",
          "documentation": {
            "value": "The URI that uniquely identifies the namespace"
          }
        }
      ]
    },
    {
      "label": "<!-- comment -->",
      "documentation": {
        "value": "An XML comment. Comments cannot contain `--` and cannot be nested."
      },
      "parameters": [
        {
          "label": "comment",
          "documentation": {
            "value": "The comment text (must not contain double hyphens `--`)"
          }
        }
      ]
    },
    {
      "label": "&entity;",
      "documentation": {
        "value": "A character or entity reference. Predefined entities: `&lt;` (<), `&gt;` (>), `&amp;` (&), `&apos;` ('), `&quot;` (\")."
      },
      "parameters": [
        {
          "label": "entity",
          "documentation": {
            "value": "An entity name (`lt`, `gt`, `amp`, `apos`, `quot`) or numeric reference (`#60`, `#x3C`)"
          }
        }
      ]
    },
    {
      "label": "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes|no\"?>",
      "documentation": {
        "value": "The XML declaration specifies the XML version, character encoding, and whether the document is standalone."
      },
      "parameters": [
        {
          "label": "version",
          "documentation": {
            "value": "The XML version number (`1.0` or `1.1`)"
          }
        },
        {
          "label": "encoding",
          "documentation": {
            "value": "The character encoding (e.g. `UTF-8`, `UTF-16`, `ISO-8859-1`)"
          }
        },
        {
          "label": "standalone",
          "documentation": {
            "value": "`yes` if the document has no external markup declarations, `no` otherwise"
          }
        }
      ]
    },
