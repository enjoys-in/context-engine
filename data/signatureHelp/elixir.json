  "signatures": [
    {
      "label": "IO.puts(item): :ok",
      "documentation": {
        "value": "Writes `item` to standard output followed by a newline.\n```elixir\nIO.puts(\"Hello World\")\nIO.puts(42)\nIO.puts(inspect(%{a: 1}))\n```"
      },
      "parameters": [
        {
          "label": "item",
          "documentation": {
            "value": "The item to write. Converted to a string via `to_string/1`."
          }
        }
      ]
    },
    {
      "label": "Enum.map(enumerable, fun): list",
      "documentation": {
        "value": "Returns a list where each element is the result of invoking `fun` on each element of `enumerable`.\n```elixir\nEnum.map([1, 2, 3], fn x -> x * 2 end)  # [2, 4, 6]\nEnum.map([1, 2, 3], &(&1 * 2))          # [2, 4, 6]\n```"
      },
      "parameters": [
        {
          "label": "enumerable",
          "documentation": {
            "value": "The enumerable to map over (list, map, range, etc.)."
          }
        },
        {
          "label": "fun",
          "documentation": {
            "value": "A function `(element -> new_element)` applied to each element."
          }
        }
      ]
    },
    {
      "label": "Enum.filter(enumerable, fun): list",
      "documentation": {
        "value": "Filters the enumerable, keeping only elements for which `fun` returns a truthy value.\n```elixir\nEnum.filter([1, 2, 3, 4], fn x -> rem(x, 2) == 0 end)  # [2, 4]\nEnum.filter([1, nil, 3, false], & &1)                    # [1, 3]\n```"
      },
      "parameters": [
        {
          "label": "enumerable",
          "documentation": {
            "value": "The enumerable to filter."
          }
        },
        {
          "label": "fun",
          "documentation": {
            "value": "A predicate function `(element -> boolean)`."
          }
        }
      ]
    },
    {
      "label": "Enum.reduce(enumerable, acc, fun): value",
      "documentation": {
        "value": "Reduces the enumerable to a single value using `fun`.\n```elixir\nEnum.reduce([1, 2, 3], 0, fn x, acc -> acc + x end)  # 6\nEnum.reduce([\"a\", \"b\", \"c\"], \"\", &(&2 <> &1))        # \"abc\"\n```"
      },
      "parameters": [
        {
          "label": "enumerable",
          "documentation": {
            "value": "The enumerable to reduce."
          }
        },
        {
          "label": "acc",
          "documentation": {
            "value": "The initial accumulator value."
          }
        },
        {
          "label": "fun",
          "documentation": {
            "value": "A function `(element, acc -> new_acc)` applied at each step."
          }
        }
      ]
    },
    {
      "label": "String.split(string, pattern, opts \\\\ []): list",
      "documentation": {
        "value": "Splits a string on occurrences of `pattern`.\n```elixir\nString.split(\"hello world\", \" \")       # [\"hello\", \"world\"]\nString.split(\"a,b,,c\", \",\", trim: true) # [\"a\", \"b\", \"c\"]\nString.split(\"abc\", \"\")                 # [\"a\", \"b\", \"c\"]\n```"
      },
      "parameters": [
        {
          "label": "string",
          "documentation": {
            "value": "The string to split."
          }
        },
        {
          "label": "pattern",
          "documentation": {
            "value": "A string, regex, or list of strings to split on."
          }
        },
        {
          "label": "opts",
          "documentation": {
            "value": "Options: `trim: true` to remove empty strings, `parts: n` to limit splits."
          }
        }
      ]
    },
    {
      "label": "String.replace(subject, pattern, replacement, opts \\\\ []): String.t()",
      "documentation": {
        "value": "Replaces occurrences of `pattern` in `subject` with `replacement`.\n```elixir\nString.replace(\"hello world\", \"world\", \"elixir\")  # \"hello elixir\"\nString.replace(\"aaa\", \"a\", \"b\", global: false)     # \"baa\"\n```"
      },
      "parameters": [
        {
          "label": "subject",
          "documentation": {
            "value": "The original string."
          }
        },
        {
          "label": "pattern",
          "documentation": {
            "value": "A string or regex to match."
          }
        },
        {
          "label": "replacement",
          "documentation": {
            "value": "The replacement string or function."
          }
        },
        {
          "label": "opts",
          "documentation": {
            "value": "Options: `global: false` to replace only the first occurrence."
          }
        }
      ]
    },
    {
      "label": "Map.get(map, key, default \\\\ nil): value",
      "documentation": {
        "value": "Gets the value for a specific key in the map.\n```elixir\nMap.get(%{a: 1, b: 2}, :a)        # 1\nMap.get(%{a: 1}, :c, :default)    # :default\nMap.get(%{a: 1}, :c)              # nil\n```"
      },
      "parameters": [
        {
          "label": "map",
          "documentation": {
            "value": "The map to look up."
          }
        },
        {
          "label": "key",
          "documentation": {
            "value": "The key to fetch."
          }
        },
        {
          "label": "default",
          "documentation": {
            "value": "Value returned if key is not found (default: `nil`)."
          }
        }
      ]
    },
    {
      "label": "Map.put(map, key, value): map",
      "documentation": {
        "value": "Puts the given `value` under `key` in `map`.\n```elixir\nMap.put(%{a: 1}, :b, 2)   # %{a: 1, b: 2}\nMap.put(%{a: 1}, :a, 99)  # %{a: 99}\n```"
      },
      "parameters": [
        {
          "label": "map",
          "documentation": {
            "value": "The map to update."
          }
        },
        {
          "label": "key",
          "documentation": {
            "value": "The key to set."
          }
        },
        {
          "label": "value",
          "documentation": {
            "value": "The value to associate with the key."
          }
        }
      ]
    },
    {
      "label": "List.first(list, default \\\\ nil): value",
      "documentation": {
        "value": "Returns the first element of `list`, or `default` if empty.\n```elixir\nList.first([1, 2, 3])     # 1\nList.first([], :none)     # :none\n```"
      },
      "parameters": [
        {
          "label": "list",
          "documentation": {
            "value": "The list."
          }
        },
        {
          "label": "default",
          "documentation": {
            "value": "Value returned if the list is empty (default: `nil`)."
          }
        }
      ]
    },
    {
      "label": "Kernel.is_nil(term): boolean",
      "documentation": {
        "value": "Returns `true` if `term` is `nil`, `false` otherwise. Allowed in guard clauses.\n```elixir\nis_nil(nil)    # true\nis_nil(42)     # false\n```"
      },
      "parameters": [
        {
          "label": "term",
          "documentation": {
            "value": "The term to check."
          }
        }
      ]
    },
    {
      "label": "GenServer.call(server, request, timeout \\\\ 5000): response",
      "documentation": {
        "value": "Makes a synchronous call to a GenServer and waits for a reply.\n```elixir\nGenServer.call(pid, :get_state)\nGenServer.call(MyServer, {:update, value}, 10_000)\n```"
      },
      "parameters": [
        {
          "label": "server",
          "documentation": {
            "value": "The GenServer pid, name, or `{name, node}` tuple."
          }
        },
        {
          "label": "request",
          "documentation": {
            "value": "The request term sent to `handle_call/3`."
          }
        },
        {
          "label": "timeout",
          "documentation": {
            "value": "Timeout in milliseconds (default: 5000). Use `:infinity` for no timeout."
          }
        }
      ]
    },
    {
      "label": "GenServer.cast(server, request): :ok",
      "documentation": {
        "value": "Sends an asynchronous request to a GenServer (fire-and-forget).\n```elixir\nGenServer.cast(pid, {:increment, 1})\nGenServer.cast(MyServer, :reset)\n```"
      },
      "parameters": [
        {
          "label": "server",
          "documentation": {
            "value": "The GenServer pid, name, or `{name, node}` tuple."
          }
        },
        {
          "label": "request",
          "documentation": {
            "value": "The request term sent to `handle_cast/2`."
          }
        }
      ]
    },
    {
      "label": "Task.async(fun): Task.t()",
      "documentation": {
        "value": "Starts a task that must be awaited on. The result is collected with `Task.await/2`.\n```elixir\ntask = Task.async(fn -> expensive_computation() end)\nresult = Task.await(task)\n```"
      },
      "parameters": [
        {
          "label": "fun",
          "documentation": {
            "value": "A zero-arity function to execute asynchronously."
          }
        }
      ]
    },
    {
      "label": "Agent.start_link(fun, opts \\\\ []): {:ok, pid}",
      "documentation": {
        "value": "Starts an agent linked to the current process with the given initial state.\n```elixir\n{:ok, agent} = Agent.start_link(fn -> %{} end)\n{:ok, agent} = Agent.start_link(fn -> 0 end, name: :counter)\n```"
      },
      "parameters": [
        {
          "label": "fun",
          "documentation": {
            "value": "A zero-arity function returning the initial state."
          }
        },
        {
          "label": "opts",
          "documentation": {
            "value": "Options: `name:` to register the agent, `timeout:`, etc."
          }
        }
      ]
    },
