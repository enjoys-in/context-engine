  "signatures": [
    {
      "label": "System.debug(logLevel, msg): void",
      "documentation": {
        "value": "Writes a message to the debug log.\n```apex\nSystem.debug('Hello');\nSystem.debug(LoggingLevel.ERROR, 'Error occurred');\n```"
      },
      "parameters": [
        {
          "label": "logLevel",
          "documentation": {
            "value": "Optional `LoggingLevel` enum value (ERROR, WARN, INFO, DEBUG, FINE, FINER, FINEST)."
          }
        },
        {
          "label": "msg",
          "documentation": {
            "value": "The object or string to write to the debug log."
          }
        }
      ]
    },
    {
      "label": "String.valueOf(obj): String",
      "documentation": {
        "value": "Returns the string representation of the specified object.\n```apex\nString s = String.valueOf(42);\nString s2 = String.valueOf(Date.today());\n```"
      },
      "parameters": [
        {
          "label": "obj",
          "documentation": {
            "value": "The object to convert to a String."
          }
        }
      ]
    },
    {
      "label": "Date.newInstance(year, month, day): Date",
      "documentation": {
        "value": "Constructs a Date from integer year, month, and day values.\n```apex\nDate d = Date.newInstance(2024, 1, 15);\n```"
      },
      "parameters": [
        {
          "label": "year",
          "documentation": {
            "value": "The year component (Integer)."
          }
        },
        {
          "label": "month",
          "documentation": {
            "value": "The month component, 1-12 (Integer)."
          }
        },
        {
          "label": "day",
          "documentation": {
            "value": "The day component (Integer)."
          }
        }
      ]
    },
    {
      "label": "Math.max(a, b): Decimal",
      "documentation": {
        "value": "Returns the larger of two values.\n```apex\nDecimal result = Math.max(10, 20); // 20\n```"
      },
      "parameters": [
        {
          "label": "a",
          "documentation": {
            "value": "First numeric value (Decimal, Double, Integer, or Long)."
          }
        },
        {
          "label": "b",
          "documentation": {
            "value": "Second numeric value."
          }
        }
      ]
    },
    {
      "label": "List.add(element): Boolean",
      "documentation": {
        "value": "Adds an element to the end of the list.\n```apex\nList<String> names = new List<String>();\nnames.add('Alice');\n```"
      },
      "parameters": [
        {
          "label": "element",
          "documentation": {
            "value": "The element to add to the list."
          }
        }
      ]
    },
    {
      "label": "Map.put(key, value): Object",
      "documentation": {
        "value": "Associates the specified value with the specified key in the map.\n```apex\nMap<String, Integer> m = new Map<String, Integer>();\nm.put('count', 5);\n```"
      },
      "parameters": [
        {
          "label": "key",
          "documentation": {
            "value": "The key with which the value is to be associated."
          }
        },
        {
          "label": "value",
          "documentation": {
            "value": "The value to be associated with the key."
          }
        }
      ]
    },
    {
      "label": "Database.query(queryString): List<sObject>",
      "documentation": {
        "value": "Executes a dynamic SOQL query and returns a list of sObjects.\n```apex\nList<Account> accts = Database.query('SELECT Id, Name FROM Account LIMIT 10');\n```"
      },
      "parameters": [
        {
          "label": "queryString",
          "documentation": {
            "value": "A valid SOQL query string."
          }
        }
      ]
    },
    {
      "label": "String.format(template, args): String",
      "documentation": {
        "value": "Returns a string with the arguments substituted into the template.\n```apex\nString msg = String.format('Hello {0}, you have {1} items', new List<String>{'Alice', '5'});\n```"
      },
      "parameters": [
        {
          "label": "template",
          "documentation": {
            "value": "A template string with `{0}`, `{1}`, etc. placeholders."
          }
        },
        {
          "label": "args",
          "documentation": {
            "value": "A `List<String>` of substitution values."
          }
        }
      ]
    },
    {
      "label": "JSON.serialize(obj): String",
      "documentation": {
        "value": "Serializes an Apex object into a JSON string.\n```apex\nAccount a = new Account(Name='Acme');\nString jsonStr = JSON.serialize(a);\n```"
      },
      "parameters": [
        {
          "label": "obj",
          "documentation": {
            "value": "The Apex object to serialize."
          }
        }
      ]
    },
    {
      "label": "JSON.deserialize(jsonString, apexType): Object",
      "documentation": {
        "value": "Deserializes a JSON string into an Apex object of the specified type.\n```apex\nAccount a = (Account) JSON.deserialize(jsonStr, Account.class);\n```"
      },
      "parameters": [
        {
          "label": "jsonString",
          "documentation": {
            "value": "The JSON string to deserialize."
          }
        },
        {
          "label": "apexType",
          "documentation": {
            "value": "The Apex type to deserialize into (e.g. `Account.class`)."
          }
        }
      ]
    },
