  "signatures": [
    {
      "label": "DECLARE variable type",
      "documentation": {
        "value": "Declares a variable with a specified type in PL/A."
      },
      "parameters": [
        {
          "label": "variable",
          "documentation": {
            "value": "The name of the variable to declare."
          }
        },
        {
          "label": "type",
          "documentation": {
            "value": "The data type (e.g., FIXED, FLOAT, CHAR, BIT)."
          }
        }
      ]
    },
    {
      "label": "PUT LIST(expression, ...): void",
      "documentation": {
        "value": "Outputs one or more expressions to the standard output stream in list-directed format."
      },
      "parameters": [
        {
          "label": "expression",
          "documentation": {
            "value": "The expression(s) to output."
          }
        }
      ]
    },
    {
      "label": "GET LIST(variable, ...): void",
      "documentation": {
        "value": "Reads one or more values from the standard input stream in list-directed format."
      },
      "parameters": [
        {
          "label": "variable",
          "documentation": {
            "value": "The variable(s) to store input values."
          }
        }
      ]
    },
    {
      "label": "SUBSTR(string, position, length): CHAR",
      "documentation": {
        "value": "Extracts a substring from a string starting at the given position."
      },
      "parameters": [
        {
          "label": "string",
          "documentation": {
            "value": "The source string."
          }
        },
        {
          "label": "position",
          "documentation": {
            "value": "The 1-based start position."
          }
        },
        {
          "label": "length",
          "documentation": {
            "value": "The number of characters to extract."
          }
        }
      ]
    },
    {
      "label": "LENGTH(string): FIXED",
      "documentation": {
        "value": "Returns the current length of a varying-length character string."
      },
      "parameters": [
        {
          "label": "string",
          "documentation": {
            "value": "The string to measure."
          }
        }
      ]
    },
    {
      "label": "INDEX(string, substring): FIXED",
      "documentation": {
        "value": "Returns the position of the first occurrence of a substring within a string. Returns 0 if not found."
      },
      "parameters": [
        {
          "label": "string",
          "documentation": {
            "value": "The string to search in."
          }
        },
        {
          "label": "substring",
          "documentation": {
            "value": "The substring to search for."
          }
        }
      ]
    },
    {
      "label": "ABS(expression): number",
      "documentation": {
        "value": "Returns the absolute value of a numeric expression."
      },
      "parameters": [
        {
          "label": "expression",
          "documentation": {
            "value": "A numeric expression."
          }
        }
      ]
    },
    {
      "label": "MOD(dividend, divisor): FIXED",
      "documentation": {
        "value": "Returns the remainder of integer division."
      },
      "parameters": [
        {
          "label": "dividend",
          "documentation": {
            "value": "The number to divide."
          }
        },
        {
          "label": "divisor",
          "documentation": {
            "value": "The number to divide by."
          }
        }
      ]
    },
