  "signatures": [
    {
      "label": ".mixin(@param1, @param2, ...)",
      "documentation": {
        "value": "Calls a mixin with the specified arguments. Mixins allow reusing groups of CSS properties."
      },
      "parameters": [
        {
          "label": "@param1",
          "documentation": {
            "value": "The first parameter passed to the mixin."
          }
        },
        {
          "label": "@param2",
          "documentation": {
            "value": "The second parameter passed to the mixin."
          }
        }
      ]
    },
    {
      "label": "color(@string): color",
      "documentation": {
        "value": "Parses a color string and returns a color value. Accepts hex, rgb, rgba, hsl, and named colors."
      },
      "parameters": [
        {
          "label": "@string",
          "documentation": {
            "value": "A string representing a color (e.g., '#ff0000', 'red')."
          }
        }
      ]
    },
    {
      "label": "darken(@color, @amount): color",
      "documentation": {
        "value": "Decreases the lightness of a color by the specified percentage."
      },
      "parameters": [
        {
          "label": "@color",
          "documentation": {
            "value": "The base color to darken."
          }
        },
        {
          "label": "@amount",
          "documentation": {
            "value": "The percentage to decrease lightness (0-100%)."
          }
        }
      ]
    },
    {
      "label": "lighten(@color, @amount): color",
      "documentation": {
        "value": "Increases the lightness of a color by the specified percentage."
      },
      "parameters": [
        {
          "label": "@color",
          "documentation": {
            "value": "The base color to lighten."
          }
        },
        {
          "label": "@amount",
          "documentation": {
            "value": "The percentage to increase lightness (0-100%)."
          }
        }
      ]
    },
    {
      "label": "percentage(@number): percentage",
      "documentation": {
        "value": "Converts a unitless number into a percentage. For example, percentage(0.5) returns 50%."
      },
      "parameters": [
        {
          "label": "@number",
          "documentation": {
            "value": "A unitless number to convert (e.g., 0.5 becomes 50%)."
          }
        }
      ]
    },
    {
      "label": "unit(@dimension, @unit?): number",
      "documentation": {
        "value": "Removes or changes the unit of a dimension. If @unit is specified, changes to that unit."
      },
      "parameters": [
        {
          "label": "@dimension",
          "documentation": {
            "value": "A number with a unit (e.g., 5px)."
          }
        },
        {
          "label": "@unit?",
          "documentation": {
            "value": "Optional target unit string (e.g., 'rem', 'em')."
          }
        }
      ]
    },
    {
      "label": "length(@list): number",
      "documentation": {
        "value": "Returns the number of elements in a comma or space separated list."
      },
      "parameters": [
        {
          "label": "@list",
          "documentation": {
            "value": "A Less list value."
          }
        }
      ]
    },
    {
      "label": "extract(@list, @index): value",
      "documentation": {
        "value": "Returns the value at the specified position in a list. Index is 1-based."
      },
      "parameters": [
        {
          "label": "@list",
          "documentation": {
            "value": "A Less list value."
          }
        },
        {
          "label": "@index",
          "documentation": {
            "value": "The 1-based index of the element to extract."
          }
        }
      ]
    },
    {
      "label": "if(@condition, @trueValue, @falseValue): value",
      "documentation": {
        "value": "Returns @trueValue if @condition evaluates to true, otherwise returns @falseValue."
      },
      "parameters": [
        {
          "label": "@condition",
          "documentation": {
            "value": "A boolean expression to evaluate."
          }
        },
        {
          "label": "@trueValue",
          "documentation": {
            "value": "Value returned when the condition is true."
          }
        },
        {
          "label": "@falseValue",
          "documentation": {
            "value": "Value returned when the condition is false."
          }
        }
      ]
    },
    {
      "label": "each(@list, @ruleset): void",
      "documentation": {
        "value": "Iterates over a list, applying the ruleset for each element. Binds @value, @key, and @index."
      },
      "parameters": [
        {
          "label": "@list",
          "documentation": {
            "value": "A Less list or map to iterate over."
          }
        },
        {
          "label": "@ruleset",
          "documentation": {
            "value": "A detached ruleset to apply for each element."
          }
        }
      ]
    },
