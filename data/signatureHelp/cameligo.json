  "signatures": [
    {
      "label": "Map.find_opt(key, map): option<value>",
      "documentation": {
        "value": "Returns `Some(value)` if the key exists in the map, or `None` otherwise.\n```cameligo\nlet result : int option = Map.find_opt \"alice\" my_map\n```"
      },
      "parameters": [
        {
          "label": "key",
          "documentation": {
            "value": "The key to look up in the map."
          }
        },
        {
          "label": "map",
          "documentation": {
            "value": "The map to search in (`(key, value) map`)."
          }
        }
      ]
    },
    {
      "label": "Map.update(key, value_opt, map): map",
      "documentation": {
        "value": "Updates or removes a binding. If `value_opt` is `Some(v)`, sets key to v. If `None`, removes the key.\n```cameligo\nlet updated = Map.update \"alice\" (Some 42) my_map\nlet removed = Map.update \"bob\" (None : int option) my_map\n```"
      },
      "parameters": [
        {
          "label": "key",
          "documentation": {
            "value": "The key to update."
          }
        },
        {
          "label": "value_opt",
          "documentation": {
            "value": "`Some(value)` to set or `None` to remove."
          }
        },
        {
          "label": "map",
          "documentation": {
            "value": "The map to update."
          }
        }
      ]
    },
    {
      "label": "Map.mem(key, map): bool",
      "documentation": {
        "value": "Tests whether a key exists in the map.\n```cameligo\nlet exists : bool = Map.mem \"alice\" my_map\n```"
      },
      "parameters": [
        {
          "label": "key",
          "documentation": {
            "value": "The key to check."
          }
        },
        {
          "label": "map",
          "documentation": {
            "value": "The map to search."
          }
        }
      ]
    },
    {
      "label": "List.map(f, list): list",
      "documentation": {
        "value": "Applies function `f` to each element and returns a new list.\n```cameligo\nlet doubled = List.map (fun (x : int) -> x * 2) [1; 2; 3]\n```"
      },
      "parameters": [
        {
          "label": "f",
          "documentation": {
            "value": "A function `('a -> 'b)` to apply to each element."
          }
        },
        {
          "label": "list",
          "documentation": {
            "value": "The input list."
          }
        }
      ]
    },
    {
      "label": "List.fold(f, list, acc): acc",
      "documentation": {
        "value": "Folds a function over a list from left to right.\n```cameligo\nlet total = List.fold (fun (acc, x : int * int) -> acc + x) [1; 2; 3] 0\n```"
      },
      "parameters": [
        {
          "label": "f",
          "documentation": {
            "value": "A function `('acc * 'a -> 'acc)` applied at each step."
          }
        },
        {
          "label": "list",
          "documentation": {
            "value": "The input list to fold over."
          }
        },
        {
          "label": "acc",
          "documentation": {
            "value": "The initial accumulator value."
          }
        }
      ]
    },
    {
      "label": "Tezos.transaction(param, amount, contract): operation",
      "documentation": {
        "value": "Creates a transaction operation to send to a contract.\n```cameligo\nlet op = Tezos.transaction param 0mutez contract\n```"
      },
      "parameters": [
        {
          "label": "param",
          "documentation": {
            "value": "The parameter to pass to the target contract's entrypoint."
          }
        },
        {
          "label": "amount",
          "documentation": {
            "value": "The amount of tez to transfer (e.g. `0mutez`, `1tez`)."
          }
        },
        {
          "label": "contract",
          "documentation": {
            "value": "The target contract of the appropriate type."
          }
        }
      ]
    },
    {
      "label": "Tezos.get_sender(): address",
      "documentation": {
        "value": "Returns the address that initiated the current internal transaction.\n```cameligo\nlet sender : address = Tezos.get_sender ()\n```"
      },
      "parameters": []
    },
    {
      "label": "Tezos.get_balance(): tez",
      "documentation": {
        "value": "Returns the current balance of the executing contract.\n```cameligo\nlet bal : tez = Tezos.get_balance ()\n```"
      },
      "parameters": []
    },
    {
      "label": "abs(value): nat",
      "documentation": {
        "value": "Returns the absolute value of an integer as a natural number.\n```cameligo\nlet n : nat = abs (-5)  (* 5n *)\n```"
      },
      "parameters": [
        {
          "label": "value",
          "documentation": {
            "value": "An integer value."
          }
        }
      ]
    },
    {
      "label": "int(value): int",
      "documentation": {
        "value": "Converts a natural number to an integer.\n```cameligo\nlet i : int = int 5n  (* 5 *)\n```"
      },
      "parameters": [
        {
          "label": "value",
          "documentation": {
            "value": "A natural number (`nat`)."
          }
        }
      ]
