{
  "language": "doctest",
  "triggerCharacters": [
    "(",
    ","
  ],
  "retriggerCharacters": [
    ","
  ],
  "signatures": [
    {
      "label": "TEST_CASE(name, [tags])",
      "documentation": {
        "value": "Defines a test case with an optional set of tags.\n```cpp\nTEST_CASE(\"vectors can be sized and resized\") {\n    std::vector<int> v(5);\n    REQUIRE(v.size() == 5);\n}\n\nTEST_CASE(\"math operations\" * doctest::test_suite(\"math\")) {\n    CHECK(1 + 1 == 2);\n}\n```"
      },
      "parameters": [
        {
          "label": "name",
          "documentation": {
            "value": "A string literal naming the test case. Must be unique."
          }
        },
        {
          "label": "tags",
          "documentation": {
            "value": "Optional decorators: `doctest::test_suite(\"name\")`, `doctest::skip()`, `doctest::timeout(seconds)`, etc."
          }
        }
      ]
    },
    {
      "label": "SUBCASE(name)",
      "documentation": {
        "value": "Defines a sub-section within a test case. Subcases share setup code and each runs independently.\n```cpp\nTEST_CASE(\"subcases\") {\n    int x = 0;\n    SUBCASE(\"increment\") { x++; CHECK(x == 1); }\n    SUBCASE(\"decrement\") { x--; CHECK(x == -1); }\n}\n```"
      },
      "parameters": [
        {
          "label": "name",
          "documentation": {
            "value": "A string literal naming the subcase."
          }
        }
      ]
    },
    {
      "label": "CHECK(expression)",
      "documentation": {
        "value": "Evaluates `expression` and reports failure if false, but continues execution.\n```cpp\nCHECK(x == 42);\nCHECK(result.has_value());\nCHECK(str == \"expected\");\n```"
      },
      "parameters": [
        {
          "label": "expression",
          "documentation": {
            "value": "A boolean expression to check. Decomposed for detailed failure messages."
          }
        }
      ]
    },
    {
      "label": "REQUIRE(expression)",
      "documentation": {
        "value": "Evaluates `expression` and aborts the test case if false.\n```cpp\nREQUIRE(ptr != nullptr);\nREQUIRE(vec.size() > 0);\n```"
      },
      "parameters": [
        {
          "label": "expression",
          "documentation": {
            "value": "A boolean expression. Test case stops immediately on failure."
          }
        }
      ]
    },
    {
      "label": "WARN(expression)",
      "documentation": {
        "value": "Evaluates `expression` and issues a warning if false, but does not fail the test.\n```cpp\nWARN(performance_ms < 100);\nWARN(deprecated_count == 0);\n```"
      },
      "parameters": [
        {
          "label": "expression",
          "documentation": {
            "value": "A boolean expression. Reports a warning on failure without failing the test."
          }
        }
      ]
    },
    {
      "label": "CHECK_EQ(lhs, rhs)",
      "documentation": {
        "value": "Checks that `lhs` equals `rhs`. Continues on failure.\n```cpp\nCHECK_EQ(result, 42);\nCHECK_EQ(str, \"hello\");\n```"
      },
      "parameters": [
        {
          "label": "lhs",
          "documentation": {
            "value": "Left-hand side value."
          }
        },
        {
          "label": "rhs",
          "documentation": {
            "value": "Right-hand side value to compare against."
          }
        }
      ]
    },
    {
      "label": "CHECK_NE(lhs, rhs)",
      "documentation": {
        "value": "Checks that `lhs` is not equal to `rhs`.\n```cpp\nCHECK_NE(ptr, nullptr);\nCHECK_NE(result, -1);\n```"
      },
      "parameters": [
        {
          "label": "lhs",
          "documentation": {
            "value": "Left-hand side value."
          }
        },
        {
          "label": "rhs",
          "documentation": {
            "value": "Right-hand side value that `lhs` should not equal."
          }
        }
      ]
    },
    {
      "label": "CHECK_LT(lhs, rhs)",
      "documentation": {
        "value": "Checks that `lhs` is less than `rhs`.\n```cpp\nCHECK_LT(elapsed_ms, 1000);\nCHECK_LT(error_count, max_errors);\n```"
      },
      "parameters": [
        {
          "label": "lhs",
          "documentation": {
            "value": "Left-hand side value (expected to be less)."
          }
        },
        {
          "label": "rhs",
          "documentation": {
            "value": "Right-hand side value (upper bound)."
          }
        }
      ]
    },
    {
      "label": "CHECK_THROWS(expression)",
      "documentation": {
        "value": "Checks that evaluating `expression` throws an exception.\n```cpp\nCHECK_THROWS(throw_func());\nCHECK_THROWS(parse(\"\"));\n```"
      },
      "parameters": [
        {
          "label": "expression",
          "documentation": {
            "value": "An expression expected to throw an exception."
          }
        }
      ]
    },
    {
      "label": "CHECK_THROWS_AS(expression, exception_type)",
      "documentation": {
        "value": "Checks that `expression` throws a specific exception type.\n```cpp\nCHECK_THROWS_AS(parse(\"bad\"), std::runtime_error);\nCHECK_THROWS_AS(divide(1, 0), DivisionByZero);\n```"
      },
      "parameters": [
        {
          "label": "expression",
          "documentation": {
            "value": "An expression expected to throw."
          }
        },
        {
          "label": "exception_type",
          "documentation": {
            "value": "The expected exception type (e.g. `std::runtime_error`, `std::out_of_range`)."
          }
        }
      ]
    },
