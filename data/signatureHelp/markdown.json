{
  "language": "markdown",
  "triggerCharacters": [
    "(",
    "["
  ],
  "retriggerCharacters": [],
  "signatures": [
    {
      "label": "[text](url \"title\")",
      "documentation": {
        "value": "Creates an inline hyperlink. The title attribute is optional and shown as a tooltip on hover."
      },
      "parameters": [
        {
          "label": "text",
          "documentation": {
            "value": "The visible link text."
          }
        },
        {
          "label": "url",
          "documentation": {
            "value": "The URL the link points to."
          }
        },
        {
          "label": "title",
          "documentation": {
            "value": "Optional tooltip text shown on hover."
          }
        }
      ]
    },
    {
      "label": "![alt](url \"title\")",
      "documentation": {
        "value": "Embeds an image. The alt text is displayed if the image cannot be loaded."
      },
      "parameters": [
        {
          "label": "alt",
          "documentation": {
            "value": "Alternative text describing the image."
          }
        },
        {
          "label": "url",
          "documentation": {
            "value": "The URL or path of the image."
          }
        },
        {
          "label": "title",
          "documentation": {
            "value": "Optional tooltip text shown on hover."
          }
        }
      ]
    },
    {
      "label": "[text][reference_id]",
      "documentation": {
        "value": "Creates a reference-style link. The reference_id is defined elsewhere as [reference_id]: url."
      },
      "parameters": [
        {
          "label": "text",
          "documentation": {
            "value": "The visible link text."
          }
        },
        {
          "label": "reference_id",
          "documentation": {
            "value": "The identifier linking to a URL defined elsewhere in the document."
          }
        }
      ]
    },
    {
      "label": "```language\\ncode\\n```",
      "documentation": {
        "value": "Creates a fenced code block with optional syntax highlighting for the specified language."
      },
      "parameters": [
        {
          "label": "language",
          "documentation": {
            "value": "Optional language identifier for syntax highlighting (e.g., javascript, python, bash)."
          }
        }
      ]
    },
    {
      "label": "# Heading (level 1-6)",
      "documentation": {
        "value": "Creates a heading. The number of # characters (1-6) determines the heading level."
      },
      "parameters": [
        {
          "label": "#",
          "documentation": {
            "value": "One to six hash characters for heading levels 1-6."
          }
        }
      ]
    },
    {
      "label": "| Header | Header |\\n|--------|--------|\\n| Cell   | Cell   |",
      "documentation": {
        "value": "Creates a table using pipes and hyphens. Columns are separated by | and the header row is separated from data by a line of dashes."
      },
      "parameters": [
        {
          "label": "Header",
          "documentation": {
            "value": "Column header text."
          }
        },
        {
          "label": "Cell",
          "documentation": {
            "value": "Table cell content."
          }
        }
      ]
    },
    {
      "label": "> blockquote text",
      "documentation": {
        "value": "Creates a blockquote. Nest with additional > characters."
      },
      "parameters": [
        {
          "label": "text",
          "documentation": {
            "value": "The quoted text content."
          }
        }
      ]
    },
    {
      "label": "- [ ] task item / - [x] completed item",
      "documentation": {
        "value": "Creates a task list item. Use [ ] for incomplete and [x] for completed tasks."
      },
      "parameters": [
        {
          "label": "task item",
          "documentation": {
            "value": "The task description text."
          }
