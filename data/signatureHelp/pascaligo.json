    {
      "label": "Map.find_opt(key: 'key, map: map('key, 'value)): option('value)",
      "documentation": {
        "value": "Returns the value associated with a key in the map as Some(value), or None if the key is not present."
      },
      "parameters": [
        {
          "label": "key",
          "documentation": {
            "value": "The key to look up in the map."
          }
        },
        {
          "label": "map",
          "documentation": {
            "value": "The map to search in."
          }
        }
      ]
    },
    {
      "label": "Map.update(key: 'key, value: option('value), map: map('key, 'value)): map('key, 'value)",
      "documentation": {
        "value": "Updates the value associated with a key. If value is Some(v), the binding is updated; if None, the key is removed."
      },
      "parameters": [
        {
          "label": "key",
          "documentation": {
            "value": "The key to update."
          }
        },
        {
          "label": "value",
          "documentation": {
            "value": "Some(new_value) to set, or None to remove the binding."
          }
        },
        {
          "label": "map",
          "documentation": {
            "value": "The map to update."
          }
        }
      ]
    },
    {
      "label": "Map.mem(key: 'key, map: map('key, 'value)): bool",
      "documentation": {
        "value": "Tests whether a key exists in the map. Returns true if the key is present."
      },
      "parameters": [
        {
          "label": "key",
          "documentation": {
            "value": "The key to test for membership."
          }
        },
        {
          "label": "map",
          "documentation": {
            "value": "The map to test."
          }
        }
      ]
    },
    {
