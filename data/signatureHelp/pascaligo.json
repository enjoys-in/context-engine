      },
      "parameters": [
        {
          "label": "f",
          "documentation": {
            "value": "The function to apply to each element."
          }
        },
        {
          "label": "list",
          "documentation": {
            "value": "The input list."
          }
        }
      ]
    },
    {
      "label": "List.fold(f: (('acc, 'a) -> 'acc), list: list('a), init: 'acc): 'acc",
      "documentation": {
        "value": "Reduces a list to a single value by applying a function to each element and an accumulator."
      },
      "parameters": [
        {
          "label": "f",
          "documentation": {
            "value": "The folding function that takes an accumulator and an element."
          }
        },
        {
          "label": "list",
          "documentation": {
            "value": "The list to fold over."
          }
        },
        {
          "label": "init",
          "documentation": {
            "value": "The initial accumulator value."
          }
        }
      ]
    },
    {
      "label": "Tezos.transaction(parameter: 'param, amount: tez, contract: contract('param)): operation",
