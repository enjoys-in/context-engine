  "signatures": [
    {
      "label": "require(condition: bool, message: string)",
      "documentation": {
        "value": "Reverts the transaction if the condition is false. Optionally provides an error message."
      },
      "parameters": [
        {
          "label": "condition",
          "documentation": {
            "value": "The boolean condition that must be true"
          }
        },
        {
          "label": "message",
          "documentation": {
            "value": "Optional revert reason string"
          }
        }
      ]
    },
    {
      "label": "assert(condition: bool)",
      "documentation": {
        "value": "Checks for internal errors and invariants. Should only fail due to bugs. Consumes all remaining gas on failure."
      },
      "parameters": [
        {
          "label": "condition",
          "documentation": {
            "value": "The invariant condition that should always be true"
          }
        }
      ]
    },
    {
      "label": "revert(reason: string)",
      "documentation": {
        "value": "Aborts execution and reverts state changes, providing an optional explanation string."
      },
      "parameters": [
        {
          "label": "reason",
          "documentation": {
            "value": "The revert reason string"
          }
        }
      ]
    },
    {
      "label": "keccak256(data: bytes): bytes32",
      "documentation": {
        "value": "Computes the Keccak-256 hash of the input data."
      },
      "parameters": [
        {
          "label": "data",
          "documentation": {
            "value": "The bytes input to hash (use `abi.encodePacked(...)` for multiple values)"
          }
        }
      ]
    },
    {
      "label": "abi.encode(values: ...): bytes",
      "documentation": {
        "value": "ABI-encodes the given arguments with padding to 32 bytes per value."
      },
      "parameters": [
        {
          "label": "values",
          "documentation": {
            "value": "The values to ABI-encode"
          }
        }
      ]
    },
    {
      "label": "abi.encodePacked(values: ...): bytes",
      "documentation": {
        "value": "Performs non-standard packed encoding of the given values. Does not pad to 32 bytes."
      },
      "parameters": [
        {
          "label": "values",
          "documentation": {
            "value": "The values to encode in packed format"
          }
        }
      ]
    },
    {
      "label": "abi.decode(data: bytes, types: (...)): (...)",
      "documentation": {
        "value": "ABI-decodes the given data according to the specified types."
      },
      "parameters": [
        {
          "label": "data",
          "documentation": {
            "value": "The ABI-encoded bytes to decode"
          }
        },
        {
          "label": "types",
          "documentation": {
            "value": "The tuple of types to decode into, e.g. `(uint256, address)`"
          }
        }
      ]
    },
    {
      "label": "address.transfer(amount: uint256)",
      "documentation": {
        "value": "Sends the given amount of Wei to the address. Reverts on failure. Forwards 2300 gas."
      },
      "parameters": [
        {
          "label": "amount",
          "documentation": {
            "value": "The amount of Wei to transfer"
          }
        }
      ]
    },
    {
      "label": "address.send(amount: uint256): bool",
      "documentation": {
        "value": "Sends the given amount of Wei to the address. Returns false on failure. Forwards 2300 gas."
      },
      "parameters": [
        {
          "label": "amount",
          "documentation": {
            "value": "The amount of Wei to send"
          }
        }
      ]
    },
    {
      "label": "address.call{value: uint256, gas: uint256}(data: bytes): (bool, bytes)",
      "documentation": {
        "value": "Low-level call to an address. Returns success boolean and return data."
      },
      "parameters": [
        {
          "label": "data",
          "documentation": {
            "value": "The calldata to send"
          }
        }
      ]
    },
    {
      "label": "mapping(keyType => valueType)",
      "documentation": {
        "value": "Declares a mapping type that maps keys of `keyType` to values of `valueType`."
      },
      "parameters": [
        {
          "label": "keyType",
          "documentation": {
            "value": "The key type (must be a value type, bytes, string, or contract)"
          }
        },
        {
          "label": "valueType",
          "documentation": {
            "value": "The value type (can be any type including another mapping)"
          }
        }
      ]
    },
