{
  "language": "dotenv",
  "triggerCharacters": [
    "="
  ],
  "retriggerCharacters": [],
  "signatures": [
    {
      "label": "KEY=value",
      "documentation": {
        "value": "Defines an environment variable.\n```dotenv\nDATABASE_URL=postgres://user:pass@localhost:5432/mydb\nAPI_KEY=sk-abc123\nDEBUG=true\n```"
      },
      "parameters": [
        {
          "label": "KEY",
          "documentation": {
            "value": "Variable name. Convention: UPPER_SNAKE_CASE. Must not contain spaces or `=`."
          }
        },
        {
          "label": "value",
          "documentation": {
            "value": "The value. Can be unquoted, single-quoted (literal), or double-quoted (allows `\\n` escapes and variable expansion)."
          }
        }
      ]
    },
    {
      "label": "KEY=\"value with spaces\"",
      "documentation": {
        "value": "Double-quoted values support escape sequences and variable interpolation.\n```dotenv\nGREETING=\"Hello World\"\nMULTILINE=\"line1\\nline2\"\nFULL_URL=\"https://${HOST}:${PORT}/api\"\n```"
      },
      "parameters": [
        {
          "label": "KEY",
          "documentation": {
            "value": "Variable name."
          }
        },
        {
          "label": "value",
          "documentation": {
            "value": "Value in double quotes. Supports `\\n`, `\\r`, `\\t` escapes and `${VAR}` interpolation."
          }
        }
      ]
    },
    {
      "label": "KEY='literal value'",
      "documentation": {
        "value": "Single-quoted values are treated as literals with no interpolation or escape processing.\n```dotenv\nREGEX='\\d+\\.\\d+'\nPATH_PATTERN='/home/*/data'\n```"
      },
      "parameters": [
        {
          "label": "KEY",
          "documentation": {
            "value": "Variable name."
          }
        },
        {
          "label": "value",
          "documentation": {
            "value": "Literal value. No escape sequences or variable expansion."
          }
        }
      ]
    },
    {
      "label": "export KEY=value",
      "documentation": {
        "value": "Exports the variable to the shell environment (for compatibility with `source .env`).\n```dotenv\nexport NODE_ENV=production\nexport PATH=\"/usr/local/bin:$PATH\"\n```"
      },
      "parameters": [
        {
          "label": "KEY",
          "documentation": {
            "value": "Variable name to export."
          }
        },
        {
          "label": "value",
          "documentation": {
            "value": "The value to assign."
          }
        }
      ]
    },
    {
      "label": "KEY=${VARIABLE:-default}",
      "documentation": {
        "value": "Uses variable interpolation with a default fallback.\n```dotenv\nPORT=${PORT:-3000}\nHOST=${HOST:-localhost}\nDB_NAME=${DB_NAME:-myapp}\n```"
      },
      "parameters": [
        {
          "label": "KEY",
          "documentation": {
            "value": "Variable name."
          }
        },
        {
          "label": "VARIABLE",
          "documentation": {
            "value": "The variable to reference."
          }
        },
        {
          "label": "default",
          "documentation": {
            "value": "Default value if VARIABLE is unset or empty."
          }
        }
      ]
    },
    {
      "label": "# comment",
      "documentation": {
        "value": "Lines starting with `#` are comments and are ignored.\n```dotenv\n# Database configuration\nDB_HOST=localhost\nDB_PORT=5432  # inline comments are also supported in some implementations\n```"
      },
      "parameters": [
        {
          "label": "comment",
          "documentation": {
            "value": "Comment text. Used for documentation and section headers."
          }
        }
      ]
    },
    {
      "label": "KEY=value1\\nvalue2 (multiline)",
      "documentation": {
        "value": "Multi-line values using double quotes and `\\n` or heredoc-style.\n```dotenv\nPRIVATE_KEY=\"-----BEGIN RSA PRIVATE KEY-----\\nMIIE...\\n-----END RSA PRIVATE KEY-----\"\n\n# Or with actual newlines in double quotes (some parsers):\nCERT=\"-----BEGIN CERTIFICATE-----\nMIID...\n-----END CERTIFICATE-----\"\n```"
      },
      "parameters": [
        {
          "label": "KEY",
          "documentation": {
            "value": "Variable name."
          }
        },
        {
          "label": "value",
          "documentation": {
            "value": "Multi-line content using `\\n` escapes within double quotes."
          }
        }
      ]
    },
    {
      "label": "KEY= (empty value)",
      "documentation": {
        "value": "Sets a variable to an empty string.\n```dotenv\nOPTIONAL_FLAG=\nFALLBACK_URL=\n```"
      },
      "parameters": [
        {
          "label": "KEY",
          "documentation": {
            "value": "Variable name set to an empty string."
          }
        }
      ]
    },
