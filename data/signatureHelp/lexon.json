{
  "language": "lexon",
  "triggerCharacters": ["(", ","],
  "retriggerCharacters": [","],
  "signatures": [
    {
      "label": "LEX contract_name.",
      "documentation": { "value": "Declares the beginning of a Lexon legal contract with the given name." },
      "parameters": [
        { "label": "contract_name", "documentation": { "value": "The name of the contract." } }
      ]
    },
    {
      "label": "CLAUSE clause_name.",
      "documentation": { "value": "Defines a named clause within the contract." },
      "parameters": [
        { "label": "clause_name", "documentation": { "value": "The name of the clause." } }
      ]
    },
    {
      "label": "LEXON version_number",
      "documentation": { "value": "Specifies the Lexon language version for the contract." },
      "parameters": [
        { "label": "version_number", "documentation": { "value": "The Lexon version (e.g., 0.2.1)." } }
      ]
    },
    {
      "label": "party IS A person.",
      "documentation": { "value": "Declares a party (participant) in the contract as a person entity." },
      "parameters": [
        { "label": "party", "documentation": { "value": "The role name for this party in the contract." } }
      ]
    },
    {
      "label": "amount IS AN amount.",
      "documentation": { "value": "Declares a value variable as an amount (monetary or numeric quantity)." },
      "parameters": [
        { "label": "amount", "documentation": { "value": "The name of the amount variable." } }
      ]
    },
    {
      "label": "party MAY action.",
      "documentation": { "value": "Grants permission to a party to perform an action." },
      "parameters": [
        { "label": "party", "documentation": { "value": "The party being granted permission." } },
        { "label": "action", "documentation": { "value": "The action the party is permitted to perform." } }
      ]
    },
    {
      "label": "party SHALL action.",
      "documentation": { "value": "Obliges a party to perform an action." },
      "parameters": [
        { "label": "party", "documentation": { "value": "The party being obligated." } },
        { "label": "action", "documentation": { "value": "The action the party must perform." } }
      ]
    },
    {
      "label": "PAY amount TO party.",
      "documentation": { "value": "Transfers the specified amount to the designated party." },
      "parameters": [
        { "label": "amount", "documentation": { "value": "The amount to transfer." } },
        { "label": "party", "documentation": { "value": "The recipient of the payment." } }
      ]
    }
  ]
}
