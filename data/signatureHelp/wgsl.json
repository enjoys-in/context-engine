    {
      "label": "@vertex fn name(input: VertexInput) -> VertexOutput",
      "documentation": {
        "value": "Marks a function as a vertex shader entry point. Processes each vertex and outputs clip-space position."
      },
      "parameters": [
        {
          "label": "input",
          "documentation": {
            "value": "The vertex input struct, typically with `@location` attributes for vertex attributes"
          }
        }
      ]
    },
    {
      "label": "@fragment fn name(input: FragmentInput) -> @location(0) vec4<f32>",
      "documentation": {
        "value": "Marks a function as a fragment shader entry point. Computes the color for each pixel."
      },
      "parameters": [
        {
          "label": "input",
          "documentation": {
            "value": "The fragment input struct with interpolated values from the vertex shader"
          }
        }
      ]
    },
    {
      "label": "@compute @workgroup_size(x, y, z) fn name(@builtin(global_invocation_id) id: vec3<u32>)",
      "documentation": {
        "value": "Marks a function as a compute shader entry point with the specified workgroup dimensions."
      },
      "parameters": [
        {
          "label": "x",
          "documentation": {
            "value": "The workgroup size in the x dimension"
          }
        },
        {
          "label": "y",
          "documentation": {
            "value": "The workgroup size in the y dimension (default: 1)"
          }
        },
        {
          "label": "z",
          "documentation": {
            "value": "The workgroup size in the z dimension (default: 1)"
          }
        }
      ]
    },
