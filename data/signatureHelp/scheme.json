{
  "language": "scheme",
  "triggerCharacters": [
    "(",
    " "
  ],
  "retriggerCharacters": [
    " "
  ],
  "signatures": [
    {
      "label": "(display obj [port])",
      "documentation": {
        "value": "Writes a representation of `obj` to the given port. If port is omitted, the current output port is used."
      },
      "parameters": [
        {
          "label": "obj",
          "documentation": {
            "value": "The object to display"
          }
        },
        {
          "label": "port",
          "documentation": {
            "value": "Optional output port (defaults to current output port)"
          }
        }
      ]
    },
    {
      "label": "(newline [port])",
      "documentation": {
        "value": "Writes a newline character to the given port."
      },
      "parameters": [
        {
          "label": "port",
          "documentation": {
            "value": "Optional output port (defaults to current output port)"
          }
        }
      ]
    },
    {
      "label": "(car pair): obj",
      "documentation": {
        "value": "Returns the first element (the car) of a pair."
      },
      "parameters": [
        {
          "label": "pair",
          "documentation": {
            "value": "A pair (cons cell)"
          }
        }
      ]
    },
    {
      "label": "(cdr pair): obj",
      "documentation": {
        "value": "Returns the second element (the cdr) of a pair."
      },
      "parameters": [
        {
          "label": "pair",
          "documentation": {
            "value": "A pair (cons cell)"
          }
        }
      ]
    },
    {
      "label": "(cons obj1 obj2): pair",
      "documentation": {
        "value": "Returns a newly allocated pair whose car is `obj1` and whose cdr is `obj2`."
      },
      "parameters": [
        {
          "label": "obj1",
          "documentation": {
            "value": "The car of the new pair"
          }
        },
        {
          "label": "obj2",
          "documentation": {
            "value": "The cdr of the new pair"
          }
        }
      ]
    },
    {
      "label": "(list obj ...): list",
      "documentation": {
        "value": "Returns a newly allocated list of its arguments."
      },
      "parameters": [
        {
          "label": "obj",
          "documentation": {
            "value": "Zero or more objects to include in the list"
          }
        }
      ]
    },
    {
      "label": "(append list ...): list",
      "documentation": {
        "value": "Returns a list consisting of the elements of the first list followed by the elements of the other lists."
      },
      "parameters": [
        {
          "label": "list",
          "documentation": {
            "value": "One or more lists to concatenate"
          }
        }
      ]
    },
    {
      "label": "(map proc list1 list2 ...): list",
      "documentation": {
        "value": "Applies `proc` element-wise to the elements of the lists and returns a list of the results."
      },
      "parameters": [
        {
          "label": "proc",
          "documentation": {
            "value": "A procedure to apply to each element"
          }
        },
        {
          "label": "list1",
          "documentation": {
            "value": "The first list"
          }
        },
        {
          "label": "list2",
          "documentation": {
            "value": "Additional lists (optional, for multi-argument proc)"
          }
        }
      ]
    },
    {
      "label": "(filter pred list): list",
      "documentation": {
        "value": "Returns a list of the elements of `list` that satisfy predicate `pred`."
      },
      "parameters": [
        {
          "label": "pred",
          "documentation": {
            "value": "A predicate procedure"
          }
        },
        {
          "label": "list",
          "documentation": {
            "value": "The list to filter"
          }
        }
      ]
    },
    {
      "label": "(fold-left f init list): obj",
      "documentation": {
        "value": "Applies `f` to `init` and the first element of `list`, then to that result and the next element, and so on."
      },
      "parameters": [
        {
          "label": "f",
          "documentation": {
            "value": "A binary procedure `(f accumulator element)`"
          }
        },
        {
          "label": "init",
          "documentation": {
            "value": "The initial accumulator value"
          }
        },
        {
          "label": "list",
          "documentation": {
            "value": "The list to fold over"
          }
        }
      ]
    },
    {
      "label": "(lambda (formals) body)",
      "documentation": {
        "value": "Creates an anonymous procedure with the given formal parameters and body expressions."
      },
      "parameters": [
        {
          "label": "formals",
          "documentation": {
            "value": "The parameter list"
          }
        },
        {
          "label": "body",
          "documentation": {
            "value": "One or more expressions forming the body"
          }
        }
      ]
    },
    {
      "label": "(define name expr)",
      "documentation": {
        "value": "Binds `name` to the value of `expr` in the current environment."
      },
      "parameters": [
        {
          "label": "name",
          "documentation": {
            "value": "The variable name to bind"
          }
        },
        {
          "label": "expr",
          "documentation": {
            "value": "The expression whose value will be bound"
          }
        }
      ]
    },
    {
      "label": "(let ((var expr) ...) body)",
      "documentation": {
        "value": "Binds each `var` to the corresponding `expr`, then evaluates `body` in the extended environment."
      },
      "parameters": [
        {
          "label": "(var expr)",
          "documentation": {
            "value": "A list of variable-expression bindings"
          }
        },
        {
          "label": "body",
          "documentation": {
            "value": "One or more expressions to evaluate"
          }
        }
      ]
    },
    {
      "label": "(cond (test expr ...) ... (else expr ...))",
      "documentation": {
        "value": "Evaluates test expressions in order. When one evaluates to true, evaluates the corresponding expressions."
      },
      "parameters": [
        {
          "label": "(test expr ...)",
          "documentation": {
            "value": "A clause with a test and expressions to evaluate if the test is true"
          }
        },
        {
          "label": "(else expr ...)",
          "documentation": {
            "value": "Optional else clause evaluated if no test is true"
          }
        }
      ]
    },
    {
      "label": "(if test consequent alternate)",
      "documentation": {
        "value": "Evaluates `test`. If it yields a true value, `consequent` is evaluated; otherwise `alternate` is evaluated."
      },
      "parameters": [
        {
          "label": "test",
          "documentation": {
            "value": "The condition to evaluate"
          }
        },
        {
          "label": "consequent",
          "documentation": {
            "value": "Expression evaluated when test is true"
          }
        },
        {
          "label": "alternate",
          "documentation": {
            "value": "Expression evaluated when test is false (optional)"
          }
        }
      ]
    }
  ]
}
