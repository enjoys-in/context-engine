  "signatures": [
    {
      "label": "message MessageName { field_type field_name = field_number; }",
      "documentation": {
        "value": "Defines a message type, the fundamental unit of data in Protocol Buffers. Messages contain typed fields with unique numeric tags."
      },
      "parameters": [
        {
          "label": "MessageName",
          "documentation": {
            "value": "The name of the message type, in CamelCase by convention."
          }
        },
        {
          "label": "field_type field_name = field_number",
          "documentation": {
            "value": "Field definitions with type, name, and unique tag number (1-536870911, excluding 19000-19999)."
          }
        }
      ]
    },
    {
      "label": "service ServiceName { rpc MethodName (RequestType) returns (ResponseType); }",
      "documentation": {
        "value": "Defines an RPC service with method signatures. Used by gRPC and other RPC frameworks."
      },
      "parameters": [
        {
          "label": "ServiceName",
          "documentation": {
            "value": "The name of the service."
          }
        },
        {
          "label": "rpc MethodName",
          "documentation": {
            "value": "The RPC method declarations within the service."
          }
        }
      ]
    },
    {
      "label": "rpc MethodName (RequestType) returns (ResponseType)",
      "documentation": {
        "value": "Defines an RPC method within a service. Supports unary and streaming (stream keyword) calls."
      },
      "parameters": [
        {
          "label": "MethodName",
          "documentation": {
            "value": "The name of the RPC method."
          }
        },
        {
          "label": "RequestType",
          "documentation": {
            "value": "The request message type. Prefix with 'stream' for client streaming."
          }
        },
        {
          "label": "ResponseType",
          "documentation": {
            "value": "The response message type. Prefix with 'stream' for server streaming."
          }
        }
      ]
    },
    {
      "label": "enum EnumName { ENUM_VALUE = 0; ENUM_VALUE2 = 1; }",
      "documentation": {
        "value": "Defines an enumeration type. The first value must be zero and serves as the default."
      },
      "parameters": [
        {
          "label": "EnumName",
          "documentation": {
            "value": "The name of the enum type, in CamelCase."
          }
        },
        {
          "label": "ENUM_VALUE = number",
          "documentation": {
            "value": "Enum values with unique numeric assignments. First value must be 0."
          }
        }
      ]
    },
    {
      "label": "oneof oneof_name { type1 field1 = tag1; type2 field2 = tag2; }",
      "documentation": {
        "value": "Specifies that at most one of the fields in the group will be set at a time. Setting one field clears the others."
      },
      "parameters": [
        {
          "label": "oneof_name",
          "documentation": {
            "value": "The name of the oneof group."
          }
        },
        {
          "label": "fields",
          "documentation": {
            "value": "The mutually exclusive field definitions. Cannot contain map or repeated fields."
          }
        }
      ]
    },
    {
      "label": "map<key_type, value_type> field_name = field_number",
      "documentation": {
        "value": "Defines a map field. Key types can be any integral or string type. Value types can be any type except another map."
      },
      "parameters": [
        {
          "label": "key_type",
          "documentation": {
            "value": "The key type: int32, int64, uint32, uint64, sint32, sint64, fixed32, fixed64, sfixed32, sfixed64, bool, string."
          }
        },
        {
          "label": "value_type",
          "documentation": {
            "value": "The value type: any scalar, enum, or message type."
          }
        },
        {
          "label": "field_name",
          "documentation": {
            "value": "The name of the map field."
          }
        },
        {
          "label": "field_number",
          "documentation": {
            "value": "The unique field tag number."
          }
        }
      ]
    },
    {
      "label": "repeated type field_name = field_number",
      "documentation": {
        "value": "Defines a repeated field (array/list). Can contain zero or more values of the specified type."
      },
      "parameters": [
        {
          "label": "type",
          "documentation": {
            "value": "The element type (any scalar, enum, or message type)."
          }
        },
        {
          "label": "field_name",
          "documentation": {
            "value": "The name of the repeated field."
          }
        },
        {
          "label": "field_number",
          "documentation": {
            "value": "The unique field tag number."
          }
        }
      ]
    },
    {
      "label": "optional type field_name = field_number",
      "documentation": {
        "value": "Defines an optional field (proto3). Enables explicit presence tracking so you can distinguish between default and unset."
      },
      "parameters": [
        {
          "label": "type",
          "documentation": {
            "value": "The field type."
          }
        },
        {
          "label": "field_name",
          "documentation": {
            "value": "The name of the field."
          }
        },
        {
          "label": "field_number",
          "documentation": {
            "value": "The unique field tag number."
          }
        }
      ]
    },
    {
      "label": "package package.name",
      "documentation": {
        "value": "Specifies the package namespace for the .proto file. Prevents naming conflicts between message types."
      },
      "parameters": [
        {
          "label": "package.name",
          "documentation": {
            "value": "The package name, typically using dot-separated notation (e.g., com.example.project)."
          }
        }
      ]
    },
    {
      "label": "import \"path/to/file.proto\"",
      "documentation": {
        "value": "Imports definitions from another .proto file. Use 'import public' to transitively expose imports."
      },
      "parameters": [
        {
          "label": "path/to/file.proto",
          "documentation": {
            "value": "The path to the .proto file to import, relative to the proto path."
          }
        }
      ]
    },
    {
      "label": "syntax = \"proto3\"",
      "documentation": {
        "value": "Specifies the Protocol Buffers syntax version. Must be the first non-comment line. Options: 'proto2' or 'proto3'."
      },
      "parameters": [
        {
          "label": "version",
          "documentation": {
            "value": "The syntax version: 'proto2' or 'proto3'."
          }
        }
      ]
    },
    {
      "label": "option option_name = value",
      "documentation": {
        "value": "Sets a file-level, message-level, or field-level option. Common options include java_package, go_package, optimize_for."
      },
      "parameters": [
        {
          "label": "option_name",
          "documentation": {
            "value": "The option name (e.g., java_package, go_package, optimize_for, deprecated)."
          }
        },
        {
          "label": "value",
          "documentation": {
            "value": "The option value (string, integer, or identifier)."
          }
        }
      ]
    },
