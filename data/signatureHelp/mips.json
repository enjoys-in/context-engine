{
  "language": "mips",
  "triggerCharacters": [" ", ","],
  "retriggerCharacters": [","],
  "signatures": [
    {
      "label": "syscall",
      "documentation": { "value": "Invokes an operating system service. The service number must be loaded into $v0 before the call. Arguments are passed in $a0-$a3." },
      "parameters": []
    },
    {
      "label": "add $rd, $rs, $rt",
      "documentation": { "value": "Adds two registers and stores the result. Causes an overflow exception on signed overflow." },
      "parameters": [
        { "label": "$rd", "documentation": { "value": "Destination register for the sum." } },
        { "label": "$rs", "documentation": { "value": "First source register." } },
        { "label": "$rt", "documentation": { "value": "Second source register." } }
      ]
    },
    {
      "label": "sub $rd, $rs, $rt",
      "documentation": { "value": "Subtracts $rt from $rs and stores the result in $rd. Causes an overflow exception on signed overflow." },
      "parameters": [
        { "label": "$rd", "documentation": { "value": "Destination register for the difference." } },
        { "label": "$rs", "documentation": { "value": "Source register (minuend)." } },
        { "label": "$rt", "documentation": { "value": "Source register (subtrahend)." } }
      ]
    },
    {
      "label": "mul $rd, $rs, $rt",
      "documentation": { "value": "Multiplies two registers and stores the low 32 bits of the result in $rd." },
      "parameters": [
        { "label": "$rd", "documentation": { "value": "Destination register for the product." } },
        { "label": "$rs", "documentation": { "value": "First source register." } },
        { "label": "$rt", "documentation": { "value": "Second source register." } }
      ]
    },
    {
      "label": "div $rs, $rt",
      "documentation": { "value": "Divides $rs by $rt. The quotient is stored in $lo and the remainder in $hi." },
      "parameters": [
        { "label": "$rs", "documentation": { "value": "Source register (dividend)." } },
        { "label": "$rt", "documentation": { "value": "Source register (divisor)." } }
      ]
    },
    {
      "label": "lw $rt, offset($rs)",
      "documentation": { "value": "Loads a 32-bit word from memory at address ($rs + offset) into register $rt." },
      "parameters": [
        { "label": "$rt", "documentation": { "value": "Destination register to load the word into." } },
        { "label": "offset", "documentation": { "value": "Signed 16-bit offset added to the base address." } },
        { "label": "$rs", "documentation": { "value": "Base address register." } }
      ]
    },
    {
      "label": "sw $rt, offset($rs)",
      "documentation": { "value": "Stores the 32-bit word from register $rt to memory at address ($rs + offset)." },
      "parameters": [
        { "label": "$rt", "documentation": { "value": "Source register containing the word to store." } },
        { "label": "offset", "documentation": { "value": "Signed 16-bit offset added to the base address." } },
        { "label": "$rs", "documentation": { "value": "Base address register." } }
      ]
    },
    {
      "label": "la $rd, label",
      "documentation": { "value": "Loads the address of a label into register $rd. This is a pseudo-instruction." },
      "parameters": [
        { "label": "$rd", "documentation": { "value": "Destination register." } },
        { "label": "label", "documentation": { "value": "The label whose address to load." } }
      ]
    },
    {
      "label": "li $rd, immediate",
      "documentation": { "value": "Loads a 32-bit immediate value into register $rd. This is a pseudo-instruction." },
      "parameters": [
        { "label": "$rd", "documentation": { "value": "Destination register." } },
        { "label": "immediate", "documentation": { "value": "The 32-bit integer constant to load." } }
      ]
    },
    {
      "label": "beq $rs, $rt, label",
      "documentation": { "value": "Branches to the target label if $rs equals $rt." },
      "parameters": [
        { "label": "$rs", "documentation": { "value": "First register to compare." } },
        { "label": "$rt", "documentation": { "value": "Second register to compare." } },
        { "label": "label", "documentation": { "value": "Branch target label." } }
      ]
    },
    {
      "label": "bne $rs, $rt, label",
      "documentation": { "value": "Branches to the target label if $rs does not equal $rt." },
      "parameters": [
        { "label": "$rs", "documentation": { "value": "First register to compare." } },
        { "label": "$rt", "documentation": { "value": "Second register to compare." } },
        { "label": "label", "documentation": { "value": "Branch target label." } }
      ]
    },
    {
      "label": "j label",
      "documentation": { "value": "Unconditionally jumps to the target label." },
      "parameters": [
        { "label": "label", "documentation": { "value": "The target label to jump to." } }
      ]
    },
    {
      "label": "jal label",
      "documentation": { "value": "Jumps to the target label and stores the return address (PC+4) in $ra. Used for function calls." },
      "parameters": [
        { "label": "label", "documentation": { "value": "The target subroutine label." } }
      ]
    },
    {
      "label": "jr $rs",
      "documentation": { "value": "Jumps to the address contained in register $rs. Commonly used with $ra for function returns." },
      "parameters": [
        { "label": "$rs", "documentation": { "value": "Register containing the target address (typically $ra)." } }
      ]
    }
  ]
}
