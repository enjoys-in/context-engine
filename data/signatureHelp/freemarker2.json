  "signatures": [
    {
      "label": "?string: string",
      "documentation": {
        "value": "Converts a value to its string representation. For numbers, uses the default number format. For booleans, converts to \"true\" or \"false\"."
      },
      "parameters": []
    },
    {
      "label": "?number: number",
      "documentation": {
        "value": "Converts a string to a number. The string must be in a valid number format."
      },
      "parameters": []
    },
    {
      "label": "?date: date",
      "documentation": {
        "value": "Converts a string to a date value using the configured date format."
      },
      "parameters": []
    },
    {
      "label": "?size: number",
      "documentation": {
        "value": "Returns the number of elements in a sequence or the number of characters in a string."
      },
      "parameters": []
    },
    {
      "label": "?has_content: boolean",
      "documentation": {
        "value": "Returns true if the variable exists and is not empty. For strings, checks that it's not blank; for sequences, checks length > 0."
      },
      "parameters": []
    },
    {
      "label": "?replace(target: string, replacement: string): string",
      "documentation": {
        "value": "Replaces all occurrences of a substring within the string."
      },
      "parameters": [
        {
          "label": "target",
          "documentation": {
            "value": "The substring to search for."
          }
        },
        {
          "label": "replacement",
          "documentation": {
            "value": "The string to replace matches with."
          }
        }
      ]
    },
    {
      "label": "?split(separator: string): sequence",
      "documentation": {
        "value": "Splits a string into a sequence of substrings around the given separator."
      },
      "parameters": [
        {
          "label": "separator",
          "documentation": {
            "value": "The delimiter string to split on."
          }
        }
      ]
    },
    {
      "label": "?join(separator: string): string",
      "documentation": {
        "value": "Joins the elements of a sequence into a single string, separated by the given delimiter."
      },
      "parameters": [
        {
          "label": "separator",
          "documentation": {
            "value": "The delimiter to place between elements."
          }
        }
      ]
    },
    {
      "label": "?upper_case: string",
      "documentation": {
        "value": "Converts all characters in the string to upper case."
      },
      "parameters": []
    },
    {
      "label": "?lower_case: string",
      "documentation": {
        "value": "Converts all characters in the string to lower case."
      },
      "parameters": []
    },
