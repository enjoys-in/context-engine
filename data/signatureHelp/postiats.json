      "parameters": [
        {
          "label": "name",
          "documentation": {
            "value": "The name of the function to implement."
          }
        },
        {
          "label": "args",
          "documentation": {
            "value": "The function arguments."
          }
        },
        {
          "label": "body",
          "documentation": {
            "value": "The implementation body."
          }
        }
      ]
    },
    {
