    {
      "label": "print(x: a): void",
      "documentation": {
        "value": "Prints a value to standard output without a trailing newline."
      },
      "parameters": [
        {
          "label": "x",
          "documentation": {
            "value": "The value to print. Supports various types through overloading."
          }
        }
      ]
    },
    {
      "label": "println(x: a): void",
      "documentation": {
        "value": "Prints a value to standard output followed by a newline character."
      },
      "parameters": [
        {
          "label": "x",
          "documentation": {
            "value": "The value to print followed by a newline."
          }
        }
      ]
    },
    {
      "label": "val name = expression",
      "documentation": {
        "value": "Declares an immutable value binding. The pattern on the left is matched against the expression on the right."
      },
      "parameters": [
        {
          "label": "name",
          "documentation": {
            "value": "The name (or pattern) to bind."
          }
        },
        {
          "label": "expression",
          "documentation": {
            "value": "The expression whose value is bound to the name."
          }
        }
      ]
    },
    {
      "label": "fun name(args): returnType = body",
      "documentation": {
        "value": "Defines a function. Supports pattern matching, mutual recursion (with 'and'), and type annotations."
      },
      "parameters": [
        {
          "label": "name",
          "documentation": {
            "value": "The function name."
          }
        },
        {
          "label": "args",
          "documentation": {
            "value": "The function parameters with optional type annotations."
          }
        },
        {
          "label": "returnType",
          "documentation": {
            "value": "The return type of the function."
          }
        },
        {
          "label": "body",
          "documentation": {
            "value": "The function body expression."
          }
        }
      ]
    },
    {
      "label": "implement name(args) = body",
