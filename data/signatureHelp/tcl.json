{
  "language": "tcl",
  "triggerCharacters": [
    " ",
    "("
  ],
  "retriggerCharacters": [
    " "
  ],
  "signatures": [
    {
      "label": "puts ?-nonewline? ?channelId? string",
      "documentation": {
        "value": "Writes string to channelId followed by a newline. Defaults to stdout."
      },
      "parameters": [
        {
          "label": "-nonewline",
          "documentation": {
            "value": "Optional flag to suppress the trailing newline"
          }
        },
        {
          "label": "channelId",
          "documentation": {
            "value": "Optional output channel (default: stdout)"
          }
        },
        {
          "label": "string",
          "documentation": {
            "value": "The string to write"
          }
        }
      ]
    },
    {
      "label": "set varName ?value?",
      "documentation": {
        "value": "Assigns a value to a variable, or reads the variable's value if no value is given."
      },
      "parameters": [
        {
          "label": "varName",
          "documentation": {
            "value": "The name of the variable"
          }
        },
        {
          "label": "value",
          "documentation": {
            "value": "Optional value to assign to the variable"
          }
        }
      ]
    },
    {
      "label": "expr expression",
      "documentation": {
        "value": "Evaluates a mathematical or logical expression and returns the result."
      },
      "parameters": [
        {
          "label": "expression",
          "documentation": {
            "value": "A mathematical or logical expression using operators, functions, and variables"
          }
        }
      ]
    },
    {
      "label": "proc name args body",
      "documentation": {
        "value": "Defines a new Tcl procedure (command) with the given name, argument list, and body."
      },
      "parameters": [
        {
          "label": "name",
          "documentation": {
            "value": "The name of the procedure"
          }
        },
        {
          "label": "args",
          "documentation": {
            "value": "A list of argument specifications; use `{arg default}` for defaults, `args` for varargs"
          }
        },
        {
          "label": "body",
          "documentation": {
            "value": "The Tcl script body of the procedure"
          }
        }
      ]
    },
    {
      "label": "if expr1 ?then? body1 ?elseif expr2 ?then? body2 ...? ?else? ?bodyN?",
      "documentation": {
        "value": "Conditional execution. Evaluates the expression and executes the corresponding body."
      },
      "parameters": [
        {
          "label": "expr1",
          "documentation": {
            "value": "A boolean expression to test"
          }
        },
        {
          "label": "body1",
          "documentation": {
            "value": "Script to execute when expr1 is true"
          }
        }
      ]
    },
    {
      "label": "foreach varname list body",
      "documentation": {
        "value": "Iterates over each element of a list, assigning each to the variable and executing the body."
      },
      "parameters": [
        {
          "label": "varname",
          "documentation": {
            "value": "Variable to receive each element (or a list of variable names)"
          }
        },
        {
          "label": "list",
          "documentation": {
            "value": "The list to iterate over"
          }
        },
        {
          "label": "body",
          "documentation": {
            "value": "Script to execute for each element"
          }
        }
      ]
    },
    {
      "label": "while test body",
      "documentation": {
        "value": "Repeatedly evaluates the test expression and executes the body while the test is true."
      },
      "parameters": [
        {
          "label": "test",
          "documentation": {
            "value": "A boolean expression evaluated before each iteration"
          }
        },
        {
          "label": "body",
          "documentation": {
            "value": "Script to execute in each iteration"
          }
        }
      ]
    },
    {
      "label": "for start test next body",
      "documentation": {
        "value": "A C-style for loop with initialization, test, increment, and body."
      },
      "parameters": [
        {
          "label": "start",
          "documentation": {
            "value": "Initialization script (executed once)"
          }
        },
        {
          "label": "test",
          "documentation": {
            "value": "Boolean expression evaluated before each iteration"
          }
        },
        {
          "label": "next",
          "documentation": {
            "value": "Script executed after each iteration (increment)"
          }
        },
        {
          "label": "body",
          "documentation": {
            "value": "Script to execute in each iteration"
          }
        }
      ]
    },
    {
      "label": "switch ?options? string pattern body ?pattern body ...?",
      "documentation": {
        "value": "Matches string against patterns and executes the body of the first match."
      },
      "parameters": [
        {
          "label": "string",
          "documentation": {
            "value": "The string to match against patterns"
          }
        },
        {
          "label": "pattern",
          "documentation": {
            "value": "A pattern to match (use `-exact`, `-glob`, or `-regexp` options)"
          }
        },
        {
          "label": "body",
          "documentation": {
            "value": "Script to execute when the pattern matches"
          }
        }
      ]
    },
    {
      "label": "catch script ?resultVarName? ?optionsVarName?",
      "documentation": {
        "value": "Evaluates the script and catches any errors. Returns the return code."
      },
      "parameters": [
        {
          "label": "script",
          "documentation": {
            "value": "The Tcl script to evaluate"
          }
        },
        {
          "label": "resultVarName",
          "documentation": {
            "value": "Optional variable to store the result or error message"
          }
        },
        {
          "label": "optionsVarName",
          "documentation": {
            "value": "Optional variable to store additional return options"
          }
        }
      ]
    },
    {
      "label": "string length string",
      "documentation": {
        "value": "Returns the number of characters in the string."
      },
      "parameters": [
        {
          "label": "string",
          "documentation": {
            "value": "The string to measure"
          }
        }
      ]
    },
    {
      "label": "string match ?-nocase? pattern string",
      "documentation": {
        "value": "Tests whether the string matches the glob-style pattern."
      },
      "parameters": [
        {
          "label": "pattern",
          "documentation": {
            "value": "A glob pattern with `*`, `?`, and `[chars]` wildcards"
          }
        },
        {
          "label": "string",
          "documentation": {
            "value": "The string to test against the pattern"
          }
        }
      ]
    },
    {
      "label": "lindex list ?index ...?",
      "documentation": {
        "value": "Returns the element at the specified index from the list."
      },
      "parameters": [
        {
          "label": "list",
          "documentation": {
            "value": "The list to index into"
          }
        },
        {
          "label": "index",
          "documentation": {
            "value": "The 0-based index (or nested indices for sublists)"
          }
        }
      ]
    },
    {
      "label": "llength list",
      "documentation": {
        "value": "Returns the number of elements in the list."
      },
      "parameters": [
        {
          "label": "list",
          "documentation": {
            "value": "The list to count elements of"
          }
        }
      ]
    },
    {
      "label": "lappend varName ?value value ...?",
      "documentation": {
        "value": "Appends values to the end of the list stored in the variable."
      },
      "parameters": [
        {
          "label": "varName",
          "documentation": {
            "value": "The variable containing the list"
          }
        },
        {
          "label": "value",
          "documentation": {
            "value": "One or more values to append"
          }
        }
      ]
    },
    {
      "label": "lsort ?options? list",
      "documentation": {
        "value": "Sorts the elements of a list and returns the sorted list."
      },
      "parameters": [
        {
          "label": "options",
          "documentation": {
            "value": "Sort options: `-ascii`, `-dictionary`, `-integer`, `-real`, `-increasing`, `-decreasing`, `-unique`"
          }
        },
        {
          "label": "list",
          "documentation": {
            "value": "The list to sort"
          }
        }
      ]
    }
  ]
}
