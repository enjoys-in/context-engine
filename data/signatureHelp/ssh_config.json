{
  "language": "ssh_config",
  "triggerCharacters": [
    " "
  ],
  "retriggerCharacters": [
    " "
  ],
  "signatures": [
    {
      "label": "Host pattern [pattern ...]",
      "documentation": {
        "value": "Restricts the following declarations to hosts matching the given patterns. Use `*` for wildcard matching."
      },
      "parameters": [
        {
          "label": "pattern",
          "documentation": {
            "value": "A hostname pattern. `*` matches any string, `?` matches any single character, `!` negates the pattern."
          }
        }
      ]
    },
    {
      "label": "HostName hostname",
      "documentation": {
        "value": "Specifies the real hostname to log into. Numeric IP addresses are also permitted. This allows aliases in the Host directive."
      },
      "parameters": [
        {
          "label": "hostname",
          "documentation": {
            "value": "The actual hostname or IP address to connect to"
          }
        }
      ]
    },
    {
      "label": "User username",
      "documentation": {
        "value": "Specifies the user to log in as on the remote machine."
      },
      "parameters": [
        {
          "label": "username",
          "documentation": {
            "value": "The remote username for SSH login"
          }
        }
      ]
    },
    {
      "label": "Port number",
      "documentation": {
        "value": "Specifies the port number to connect to on the remote host."
      },
      "parameters": [
        {
          "label": "number",
          "documentation": {
            "value": "The port number (default is 22)"
          }
        }
      ]
    },
    {
      "label": "IdentityFile path",
      "documentation": {
        "value": "Specifies a file from which the user's identity key is read for public key authentication."
      },
      "parameters": [
        {
          "label": "path",
          "documentation": {
            "value": "Path to the private key file, e.g. `~/.ssh/id_ed25519`"
          }
        }
      ]
    },
    {
      "label": "ProxyJump destination [, destination ...]",
      "documentation": {
        "value": "Specifies one or more jump proxies to connect through before reaching the target host."
      },
      "parameters": [
        {
          "label": "destination",
          "documentation": {
            "value": "A jump host in the format `[user@]host[:port]`, or comma-separated list for chained jumps"
          }
        }
      ]
    },
    {
      "label": "ForwardAgent yes|no",
      "documentation": {
        "value": "Specifies whether the authentication agent connection will be forwarded to the remote machine."
      },
      "parameters": [
        {
          "label": "yes|no",
          "documentation": {
            "value": "`yes` to forward the agent, `no` to disable forwarding (default: no)"
          }
        }
      ]
    },
    {
      "label": "LocalForward [bind_address:]port host:hostport",
      "documentation": {
        "value": "Specifies that a TCP port on the local machine be forwarded over the secure channel to a specified host and port from the remote machine."
      },
      "parameters": [
        {
          "label": "[bind_address:]port",
          "documentation": {
            "value": "Local address and port to listen on"
          }
        },
        {
          "label": "host:hostport",
          "documentation": {
            "value": "Remote host and port to forward to"
          }
        }
      ]
    },
    {
      "label": "RemoteForward [bind_address:]port host:hostport",
      "documentation": {
        "value": "Specifies that a TCP port on the remote machine be forwarded over the secure channel to a specified host and port from the local machine."
      },
      "parameters": [
        {
          "label": "[bind_address:]port",
          "documentation": {
            "value": "Remote address and port to listen on"
          }
        },
        {
          "label": "host:hostport",
          "documentation": {
            "value": "Local host and port to forward to"
          }
        }
      ]
    },
    {
      "label": "StrictHostKeyChecking yes|no|ask|accept-new",
      "documentation": {
        "value": "Controls whether SSH automatically adds host keys to the known_hosts file and whether it refuses connections to hosts with changed keys."
      },
      "parameters": [
        {
          "label": "yes|no|ask|accept-new",
          "documentation": {
            "value": "`yes` never auto-add, `no` auto-add, `ask` prompt user, `accept-new` auto-add new but reject changed"
          }
        }
      ]
    },
