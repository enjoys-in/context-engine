    {
      "label": "NSLog(format, ...): void",
      "documentation": {
        "value": "Logs an error message to the Apple System Log facility. Uses printf-style format specifiers with %@ for objects."
      },
      "parameters": [
        {
          "label": "format",
          "documentation": {
            "value": "An NSString format string (e.g., @\"Value: %@, Count: %d\")."
          }
        },
        {
          "label": "...",
          "documentation": {
            "value": "Variable arguments matching the format specifiers."
          }
        }
      ]
    },
    {
      "label": "[NSString stringWithFormat:(NSString *)format, ...]: NSString *",
      "documentation": {
        "value": "Returns a string created by using a given format string as a template into which the remaining argument values are substituted."
      },
      "parameters": [
        {
          "label": "format",
          "documentation": {
            "value": "A format string. Uses %@ for objects, %d for integers, %f for floats, etc."
          }
        },
        {
          "label": "...",
          "documentation": {
            "value": "A comma-separated list of arguments to substitute into the format string."
          }
        }
      ]
    },
    {
      "label": "[NSArray arrayWithObjects:(id)firstObj, ..., nil]: NSArray *",
      "documentation": {
        "value": "Creates and returns an array containing the objects in the argument list. The list must be nil-terminated."
      },
      "parameters": [
        {
          "label": "firstObj",
          "documentation": {
            "value": "The first object to include in the array."
          }
        },
        {
          "label": "...",
          "documentation": {
            "value": "Additional objects, followed by nil to terminate the list."
          }
        }
      ]
    },
    {
      "label": "[NSDictionary dictionaryWithObjectsAndKeys:(id)firstObject, (id)firstKey, ..., nil]: NSDictionary *",
      "documentation": {
        "value": "Creates a dictionary with object-key pairs from the argument list. Must be nil-terminated."
      },
      "parameters": [
        {
          "label": "firstObject",
          "documentation": {
            "value": "The value for the first key."
          }
        },
        {
          "label": "firstKey",
          "documentation": {
            "value": "The key for the first object."
          }
        },
        {
          "label": "...",
          "documentation": {
            "value": "Additional value-key pairs, terminated with nil."
          }
        }
      ]
    },
    {
      "label": "[[ClassName alloc] init]: instancetype",
      "documentation": {
        "value": "Allocates memory for a new object and initializes it. The standard two-step Objective-C object creation pattern."
      },
      "parameters": [
        {
          "label": "ClassName",
          "documentation": {
            "value": "The class to instantiate."
          }
        }
      ]
    },
    {
      "label": "[UIView initWithFrame:(CGRect)frame]: instancetype",
      "documentation": {
        "value": "Initializes and returns a newly allocated UIView object with the specified frame rectangle."
      },
      "parameters": [
        {
          "label": "frame",
          "documentation": {
            "value": "The frame rectangle (CGRect) for the view, specifying origin and size in the superview's coordinate system."
          }
        }
      ]
    },
    {
      "label": "[UIView addSubview:(UIView *)view]: void",
      "documentation": {
        "value": "Adds a view to the end of the receiver's list of subviews."
      },
      "parameters": [
        {
          "label": "view",
          "documentation": {
            "value": "The view to add as a subview. It is retained by the receiver."
          }
        }
      ]
    },
    {
      "label": "[NSObject performSelector:(SEL)aSelector withObject:(id)anArgument afterDelay:(NSTimeInterval)delay]: void",
      "documentation": {
        "value": "Invokes a method of the receiver on the current thread after a specified delay."
      },
      "parameters": [
        {
          "label": "aSelector",
          "documentation": {
            "value": "A selector identifying the method to invoke. The method should take one or no arguments."
          }
        },
        {
          "label": "anArgument",
          "documentation": {
            "value": "The argument to pass to the method. Pass nil if the method takes no arguments."
          }
        },
        {
          "label": "delay",
          "documentation": {
            "value": "The minimum time before the message is sent, in seconds."
          }
        }
      ]
    },
    {
      "label": "dispatch_async(queue, block): void",
      "documentation": {
        "value": "Submits a block for asynchronous execution on a dispatch queue and returns immediately."
      },
      "parameters": [
        {
          "label": "queue",
          "documentation": {
            "value": "The dispatch queue to submit the block to (e.g., dispatch_get_main_queue(), dispatch_get_global_queue())."
          }
        },
        {
          "label": "block",
          "documentation": {
            "value": "The block to execute asynchronously. It takes no arguments and has no return value."
          }
        }
      ]
    },
