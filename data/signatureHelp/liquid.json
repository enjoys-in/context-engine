{
  "language": "liquid",
  "triggerCharacters": [
    "{",
    "%",
    "|",
    ","
  ],
  "retriggerCharacters": [
    ","
  ],
  "signatures": [
    {
      "label": "{% assign variable = value %}",
      "documentation": {
        "value": "Creates a new named variable and assigns it a value."
      },
      "parameters": [
        {
          "label": "variable",
          "documentation": {
            "value": "The name of the variable to create or overwrite."
          }
        },
        {
          "label": "value",
          "documentation": {
            "value": "The value to assign (string, number, boolean, or another variable)."
          }
        }
      ]
    },
    {
      "label": "{% capture variable %}...{% endcapture %}",
      "documentation": {
        "value": "Captures the rendered content between the tags and assigns it to a variable as a string."
      },
      "parameters": [
        {
          "label": "variable",
          "documentation": {
            "value": "The variable name to store the captured content."
          }
        }
      ]
    },
    {
      "label": "{% for item in collection %}...{% endfor %}",
      "documentation": {
        "value": "Iterates over an array or range, rendering the enclosed block for each item."
      },
      "parameters": [
        {
          "label": "item",
          "documentation": {
            "value": "The loop variable name for each element."
          }
        },
        {
          "label": "collection",
          "documentation": {
            "value": "The array, hash, or range to iterate over."
          }
        }
      ]
    },
    {
      "label": "{% if condition %}...{% endif %}",
      "documentation": {
        "value": "Conditionally renders the enclosed block if the condition is truthy."
      },
      "parameters": [
        {
          "label": "condition",
          "documentation": {
            "value": "An expression that evaluates to truthy or falsy."
          }
        }
      ]
    },
    {
      "label": "{% unless condition %}...{% endunless %}",
      "documentation": {
        "value": "Renders the enclosed block unless the condition is truthy (opposite of if)."
      },
      "parameters": [
        {
          "label": "condition",
          "documentation": {
            "value": "An expression; the block renders when this is falsy."
          }
        }
      ]
    },
    {
      "label": "{% case variable %}{% when value %}...{% endcase %}",
      "documentation": {
        "value": "Creates a switch statement. Renders the block matching the variable's value."
      },
      "parameters": [
        {
          "label": "variable",
          "documentation": {
            "value": "The variable to compare against."
          }
        },
        {
          "label": "value",
          "documentation": {
            "value": "The value to match in each when clause."
          }
        }
      ]
    },
    {
      "label": "{% include 'template_name' %}",
      "documentation": {
        "value": "Inserts the rendered content of another template file. Deprecated in favor of render."
      },
      "parameters": [
        {
          "label": "template_name",
          "documentation": {
            "value": "The filename of the template to include (without extension)."
          }
        }
      ]
    },
    {
      "label": "{% render 'template_name', var: value %}",
      "documentation": {
        "value": "Renders another template with its own isolated scope. Variables can be passed explicitly."
      },
      "parameters": [
        {
          "label": "template_name",
          "documentation": {
            "value": "The filename of the template to render (without extension)."
          }
        },
        {
          "label": "var: value",
          "documentation": {
            "value": "Optional variables to pass into the rendered template."
          }
        }
      ]
    },
    {
      "label": "{% raw %}...{% endraw %}",
      "documentation": {
        "value": "Outputs the enclosed content without parsing any Liquid tags. Useful for displaying Liquid code examples."
      },
      "parameters": []
    },
    {
      "label": "{% comment %}...{% endcomment %}",
      "documentation": {
        "value": "Prevents the enclosed content from being rendered or output. Used for inline comments."
      },
      "parameters": []
    },
    {
      "label": "{% cycle 'val1', 'val2', ... %}",
      "documentation": {
        "value": "Cycles through a group of strings and outputs them in order on each successive call. Commonly used in loops."
      },
      "parameters": [
        {
          "label": "val1",
          "documentation": {
            "value": "The first value in the cycle."
          }
        },
        {
          "label": "val2",
          "documentation": {
            "value": "The second value in the cycle."
          }
        }
      ]
    },
    {
      "label": "{% tablerow item in collection cols:n %}...{% endtablerow %}",
      "documentation": {
        "value": "Generates an HTML table by iterating over a collection. Automatically wraps output in <tr> and <td> tags."
      },
      "parameters": [
        {
          "label": "item",
          "documentation": {
            "value": "The loop variable for each element."
          }
        },
        {
          "label": "collection",
          "documentation": {
            "value": "The array to iterate over."
          }
        },
        {
          "label": "cols:n",
          "documentation": {
            "value": "Optional number of columns per table row."
          }
        }
      ]
    },
