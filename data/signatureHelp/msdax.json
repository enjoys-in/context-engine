    ","
  ],
  "retriggerCharacters": [
    ","
  ],
  "signatures": [
    {
      "label": "CALCULATE(expression, filter1, filter2, ...): value",
      "documentation": {
        "value": "Evaluates an expression in a modified filter context. Each filter argument modifies the context in which the expression is evaluated."
      },
      "parameters": [
        {
          "label": "expression",
          "documentation": {
            "value": "The expression to evaluate (typically an aggregation like SUM, COUNT, etc.)."
          }
        },
        {
          "label": "filter1",
          "documentation": {
            "value": "A boolean expression or table expression that defines a filter."
          }
        },
        {
          "label": "filter2",
          "documentation": {
            "value": "Additional filter expressions."
          }
        }
      ]
    },
    {
      "label": "FILTER(table, filter_expression): table",
      "documentation": {
        "value": "Returns a table that contains only the rows that satisfy the filter expression."
      },
      "parameters": [
        {
          "label": "table",
          "documentation": {
            "value": "The table to filter."
          }
        },
        {
          "label": "filter_expression",
          "documentation": {
            "value": "A boolean expression evaluated for each row of the table."
          }
        }
      ]
    },
    {
      "label": "SUMX(table, expression): number",
      "documentation": {
        "value": "Iterates over a table, evaluates the expression for each row, and returns the sum of all values."
      },
      "parameters": [
        {
          "label": "table",
          "documentation": {
            "value": "The table to iterate over."
          }
        },
        {
          "label": "expression",
          "documentation": {
            "value": "An expression evaluated for each row to produce a number."
          }
        }
      ]
    },
    {
      "label": "COUNTROWS(table): integer",
      "documentation": {
        "value": "Counts the number of rows in a table or table expression."
      },
      "parameters": [
        {
          "label": "table",
          "documentation": {
            "value": "The table whose rows to count."
          }
        }
      ]
    },
    {
      "label": "RELATED(column): value",
      "documentation": {
        "value": "Returns a related value from another table using an existing relationship. Must be used in a row context."
      },
      "parameters": [
        {
          "label": "column",
          "documentation": {
            "value": "A column from a related table (many-to-one or one-to-one side)."
          }
        }
      ]
    },
    {
      "label": "ALL(table_or_column, ...): table",
      "documentation": {
        "value": "Returns all rows in a table or all values in a column, ignoring any filters that have been applied."
      },
      "parameters": [
        {
          "label": "table_or_column",
          "documentation": {
            "value": "A table or column reference to remove filters from."
          }
        }
      ]
    },
    {
      "label": "VALUES(column): table",
      "documentation": {
        "value": "Returns a one-column table of distinct values from the specified column, respecting the current filter context."
      },
      "parameters": [
        {
          "label": "column",
          "documentation": {
            "value": "The column from which to return distinct values."
          }
        }
      ]
    },
    {
      "label": "AVERAGEX(table, expression): number",
      "documentation": {
        "value": "Iterates over a table, evaluates the expression for each row, and returns the arithmetic mean of all values."
      },
      "parameters": [
        {
          "label": "table",
          "documentation": {
            "value": "The table to iterate over."
          }
        },
        {
          "label": "expression",
          "documentation": {
            "value": "An expression evaluated for each row to produce a number."
          }
        }
      ]
    },
    {
      "label": "MAXX(table, expression): value",
      "documentation": {
        "value": "Iterates over a table, evaluates the expression for each row, and returns the largest value."
      },
      "parameters": [
        {
          "label": "table",
          "documentation": {
            "value": "The table to iterate over."
          }
        },
        {
          "label": "expression",
          "documentation": {
            "value": "An expression evaluated for each row."
          }
        }
      ]
    },
    {
      "label": "MINX(table, expression): value",
      "documentation": {
        "value": "Iterates over a table, evaluates the expression for each row, and returns the smallest value."
      },
      "parameters": [
        {
          "label": "table",
          "documentation": {
            "value": "The table to iterate over."
          }
        },
        {
          "label": "expression",
          "documentation": {
            "value": "An expression evaluated for each row."
          }
        }
      ]
    },
    {
      "label": "SWITCH(expression, value1, result1, value2, result2, ..., else_result): value",
      "documentation": {
        "value": "Evaluates an expression against a list of values and returns the corresponding result. Returns else_result if no match is found."
      },
      "parameters": [
        {
          "label": "expression",
          "documentation": {
            "value": "The expression to evaluate and compare against each value."
          }
        },
        {
          "label": "value1",
          "documentation": {
            "value": "First value to match against."
          }
        },
        {
          "label": "result1",
          "documentation": {
            "value": "Result returned when expression matches value1."
          }
        },
        {
          "label": "else_result",
          "documentation": {
            "value": "Optional default result if no value matches."
          }
        }
      ]
    },
    {
      "label": "IF(logical_test, value_if_true, value_if_false): value",
      "documentation": {
        "value": "Returns one value if a condition is TRUE and another value if it is FALSE."
      },
      "parameters": [
        {
          "label": "logical_test",
          "documentation": {
            "value": "A boolean expression to evaluate."
          }
        },
        {
          "label": "value_if_true",
          "documentation": {
            "value": "The value returned when the condition is TRUE."
          }
        },
        {
          "label": "value_if_false",
          "documentation": {
            "value": "The value returned when the condition is FALSE."
          }
        }
      ]
    },
    {
      "label": "DIVIDE(numerator, denominator, alternate_result?): number",
      "documentation": {
        "value": "Performs safe division and returns an alternate result (default BLANK) when the denominator is zero."
      },
      "parameters": [
        {
          "label": "numerator",
          "documentation": {
            "value": "The dividend."
          }
        },
        {
          "label": "denominator",
          "documentation": {
            "value": "The divisor."
          }
        },
        {
          "label": "alternate_result?",
          "documentation": {
            "value": "Optional value returned when denominator is 0. Defaults to BLANK."
          }
        }
      ]
    },
