    {
      "label": "import ComponentName from 'module'",
      "documentation": {
        "value": "Imports a React component or module for use within the MDX document."
      },
      "parameters": [
        {
          "label": "ComponentName",
          "documentation": {
            "value": "The name to bind the imported module to."
          }
        },
        {
          "label": "module",
          "documentation": {
            "value": "The module path or package name to import from."
          }
        }
      ]
    },
    {
      "label": "import { named } from 'module'",
      "documentation": {
        "value": "Imports a named export from a module for use in the MDX document."
      },
      "parameters": [
        {
          "label": "named",
          "documentation": {
            "value": "The named export to import."
          }
        },
        {
          "label": "module",
          "documentation": {
            "value": "The module path or package name."
          }
        }
      ]
    },
    {
      "label": "export default (props) => <Layout>{props.children}</Layout>",
      "documentation": {
        "value": "Exports a default layout component that wraps the MDX content."
      },
      "parameters": [
        {
          "label": "props",
          "documentation": {
            "value": "Props passed to the layout, including children (the MDX content)."
          }
        }
      ]
    },
    {
      "label": "export const metadata = { title, description }",
      "documentation": {
        "value": "Exports metadata or constants that can be consumed by the framework or other components."
      },
      "parameters": [
        {
          "label": "metadata",
          "documentation": {
            "value": "An object containing exported values (e.g., title, description, date)."
          }
        }
      ]
    },
    {
      "label": "<Component prop={value} />",
      "documentation": {
        "value": "Renders a JSX component inline within MDX content. Props can be static strings or dynamic expressions."
      },
      "parameters": [
        {
          "label": "Component",
          "documentation": {
            "value": "The React component name (must be capitalized)."
          }
        },
        {
          "label": "prop",
          "documentation": {
            "value": "A prop name passed to the component."
          }
        },
        {
          "label": "value",
          "documentation": {
            "value": "The prop value, either a string or a JSX expression in curly braces."
          }
        }
      ]
    },
    {
      "label": "<Component>children</Component>",
      "documentation": {
        "value": "Renders a JSX component with children content, which can be markdown or other JSX."
      },
      "parameters": [
        {
          "label": "Component",
          "documentation": {
            "value": "The React component name."
          }
        },
        {
          "label": "children",
          "documentation": {
            "value": "Content between the opening and closing tags (markdown, text, or JSX)."
          }
        }
      ]
    },
    {
      "label": "{expression}",
      "documentation": {
        "value": "Embeds a JavaScript expression inline. The result is rendered into the document."
      },
      "parameters": [
        {
          "label": "expression",
          "documentation": {
            "value": "Any valid JavaScript expression that returns a renderable value."
          }
        }
      ]
    },
    {
      "label": "export function ComponentName(props): JSX.Element",
      "documentation": {
        "value": "Defines and exports a React component within the MDX file for reuse."
      },
      "parameters": [
        {
          "label": "ComponentName",
          "documentation": {
            "value": "The name of the component to export."
          }
        },
        {
          "label": "props",
          "documentation": {
            "value": "The props the component accepts."
          }
        }
      ]
    },
