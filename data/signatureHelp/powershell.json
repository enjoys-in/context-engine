  "signatures": [
    {
      "label": "Write-Host [-Object] <Object> [-NoNewline] [-Separator <Object>] [-ForegroundColor <ConsoleColor>] [-BackgroundColor <ConsoleColor>]",
      "documentation": {
        "value": "Writes customized output to the host (console). Supports colored text output. Note: output is not sent to the pipeline."
      },
      "parameters": [
        {
          "label": "-Object",
          "documentation": {
            "value": "The object to display. Can be a string, number, or any object."
          }
        },
        {
          "label": "-NoNewline",
          "documentation": {
            "value": "Suppresses the newline at the end of the output."
          }
        },
        {
          "label": "-ForegroundColor",
          "documentation": {
            "value": "Text color: Black, DarkBlue, DarkGreen, DarkCyan, DarkRed, DarkMagenta, DarkYellow, Gray, DarkGray, Blue, Green, Cyan, Red, Magenta, Yellow, White."
          }
        },
        {
          "label": "-BackgroundColor",
          "documentation": {
            "value": "Background color. Same color options as ForegroundColor."
          }
        }
      ]
    },
    {
      "label": "Write-Output [-InputObject] <PSObject[]> [-NoEnumerate]",
      "documentation": {
        "value": "Sends the specified objects to the next command in the pipeline. If it is the last command, the objects are displayed in the console."
      },
      "parameters": [
        {
          "label": "-InputObject",
          "documentation": {
            "value": "The objects to send through the pipeline."
          }
        },
        {
          "label": "-NoEnumerate",
          "documentation": {
            "value": "By default, collections are enumerated. This switch suppresses that behavior."
          }
        }
      ]
    },
    {
      "label": "Get-ChildItem [[-Path] <String[]>] [[-Filter] <String>] [-Recurse] [-Include <String[]>] [-Exclude <String[]>] [-Force] [-Name]",
      "documentation": {
        "value": "Gets the items and child items in one or more specified locations (files, folders, registry keys, etc.)."
      },
      "parameters": [
        {
          "label": "-Path",
          "documentation": {
            "value": "The path(s) to get child items from. Wildcards are permitted."
          }
        },
        {
          "label": "-Filter",
          "documentation": {
            "value": "A filter in the provider's format (e.g., '*.txt'). More efficient than -Include."
          }
        },
        {
          "label": "-Recurse",
          "documentation": {
            "value": "Gets items in all child containers (subdirectories)."
          }
        },
        {
          "label": "-Include",
          "documentation": {
            "value": "String array of patterns to include (e.g., '*.log', '*.txt')."
          }
        },
        {
          "label": "-Exclude",
          "documentation": {
            "value": "String array of patterns to exclude."
          }
        }
      ]
    },
    {
      "label": "Set-Location [[-Path] <String>] [-PassThru]",
      "documentation": {
        "value": "Sets the current working location to a specified location (directory, registry key, etc.)."
      },
      "parameters": [
        {
          "label": "-Path",
          "documentation": {
            "value": "The path to the new location."
          }
        },
        {
          "label": "-PassThru",
          "documentation": {
            "value": "Returns the PathInfo object representing the location."
          }
        }
      ]
    },
    {
      "label": "New-Object [-TypeName] <String> [[-ArgumentList] <Object[]>] [-Property <IDictionary>]",
      "documentation": {
        "value": "Creates an instance of a .NET or COM object."
      },
      "parameters": [
        {
          "label": "-TypeName",
          "documentation": {
            "value": "The fully qualified name of the .NET class (e.g., 'System.Collections.ArrayList')."
          }
        },
        {
          "label": "-ArgumentList",
          "documentation": {
            "value": "Arguments to pass to the constructor."
          }
        },
        {
          "label": "-Property",
          "documentation": {
            "value": "A hashtable of property names and values to set on the new object."
          }
        }
      ]
    },
    {
      "label": "Invoke-WebRequest [-Uri] <Uri> [-Method <WebRequestMethod>] [-Body <Object>] [-Headers <IDictionary>] [-ContentType <String>] [-OutFile <String>]",
      "documentation": {
        "value": "Sends an HTTP or HTTPS request to a web page or web service and parses the response."
      },
      "parameters": [
        {
          "label": "-Uri",
          "documentation": {
            "value": "The URI of the web resource to send the request to."
          }
        },
        {
          "label": "-Method",
          "documentation": {
            "value": "The HTTP method: Default, Get, Head, Post, Put, Delete, Trace, Options, Merge, Patch."
          }
        },
        {
          "label": "-Body",
          "documentation": {
            "value": "The body of the request. Can be a string, hashtable, or byte array."
          }
        },
        {
          "label": "-Headers",
          "documentation": {
            "value": "A dictionary of additional HTTP headers."
          }
        },
        {
          "label": "-ContentType",
          "documentation": {
            "value": "The content type of the request (e.g., 'application/json')."
          }
        },
        {
          "label": "-OutFile",
          "documentation": {
            "value": "Saves the response body to the specified file."
          }
        }
      ]
    },
    {
      "label": "ConvertTo-Json [-InputObject] <Object> [-Depth <Int32>] [-Compress] [-EnumsAsStrings]",
      "documentation": {
        "value": "Converts an object to a JSON-formatted string."
      },
      "parameters": [
        {
          "label": "-InputObject",
          "documentation": {
            "value": "The object to convert to JSON."
          }
        },
        {
          "label": "-Depth",
          "documentation": {
            "value": "The maximum depth of nested objects to include. Default is 2."
          }
        },
        {
          "label": "-Compress",
          "documentation": {
            "value": "Omits whitespace and indentation for a compact representation."
          }
        }
      ]
    },
    {
      "label": "ConvertFrom-Json [-InputObject] <String> [-AsHashtable] [-Depth <Int32>]",
      "documentation": {
        "value": "Converts a JSON-formatted string to a PowerShell object (PSCustomObject or Hashtable)."
      },
      "parameters": [
        {
          "label": "-InputObject",
          "documentation": {
            "value": "The JSON string to convert."
          }
        },
        {
          "label": "-AsHashtable",
          "documentation": {
            "value": "Converts JSON to a Hashtable instead of PSCustomObject."
          }
        },
        {
          "label": "-Depth",
          "documentation": {
            "value": "Maximum depth the JSON input is allowed to have. Default is 1024."
          }
        }
      ]
    },
    {
      "label": "ForEach-Object [-Process] <ScriptBlock[]> [-InputObject <PSObject>] [-Begin <ScriptBlock>] [-End <ScriptBlock>]",
      "documentation": {
        "value": "Performs an operation against each item in a collection of input objects."
      },
      "parameters": [
        {
          "label": "-Process",
          "documentation": {
            "value": "The script block to run for each input object. Use $_ or $PSItem for the current object."
          }
        },
        {
          "label": "-InputObject",
          "documentation": {
            "value": "The input objects. Usually received from the pipeline."
          }
        },
        {
          "label": "-Begin",
          "documentation": {
            "value": "Script block to run before processing any input objects."
          }
        },
        {
          "label": "-End",
          "documentation": {
            "value": "Script block to run after processing all input objects."
          }
        }
      ]
    },
    {
      "label": "Where-Object [-FilterScript] <ScriptBlock> [-InputObject <PSObject>]",
      "documentation": {
        "value": "Selects objects from a collection based on their property values."
      },
      "parameters": [
        {
          "label": "-FilterScript",
          "documentation": {
            "value": "The script block used to filter objects. Returns $true to include the object (e.g., { $_.Length -gt 100 })."
          }
        },
        {
          "label": "-InputObject",
          "documentation": {
            "value": "The objects to filter. Usually received from the pipeline."
          }
        }
      ]
    },
    {
      "label": "Select-Object [[-Property] <Object[]>] [-First <Int32>] [-Last <Int32>] [-Skip <Int32>] [-Unique] [-ExpandProperty <String>]",
      "documentation": {
        "value": "Selects specified properties of objects or a specified number of objects."
      },
      "parameters": [
        {
          "label": "-Property",
          "documentation": {
            "value": "The property names to select (e.g., Name, Length, @{Name='Size';Expression={$_.Length}})."
          }
        },
        {
          "label": "-First",
          "documentation": {
            "value": "Number of objects to select from the beginning."
          }
        },
        {
          "label": "-Last",
          "documentation": {
            "value": "Number of objects to select from the end."
          }
        },
        {
          "label": "-ExpandProperty",
          "documentation": {
            "value": "A property to expand (select all items in the property's collection)."
          }
        }
      ]
    },
    {
      "label": "Sort-Object [[-Property] <Object[]>] [-Descending] [-Unique] [-CaseSensitive]",
      "documentation": {
        "value": "Sorts objects by property values."
      },
      "parameters": [
        {
          "label": "-Property",
          "documentation": {
            "value": "The property or properties to sort by."
          }
        },
        {
          "label": "-Descending",
          "documentation": {
            "value": "Sorts in descending order."
          }
        },
        {
          "label": "-Unique",
          "documentation": {
            "value": "Eliminates duplicates and returns only unique members."
          }
        }
      ]
    },
    {
      "label": "Test-Path [-Path] <String[]> [-PathType <TestPathType>] [-IsValid]",
      "documentation": {
        "value": "Determines whether all elements of a path exist. Returns $true or $false."
      },
      "parameters": [
        {
          "label": "-Path",
          "documentation": {
            "value": "The path to test. Wildcards are permitted."
          }
        },
        {
          "label": "-PathType",
          "documentation": {
            "value": "The type of element to test: Any, Container (directory), Leaf (file)."
          }
        },
        {
          "label": "-IsValid",
          "documentation": {
            "value": "Tests whether the path syntax is valid, regardless of whether the path exists."
          }
        }
      ]
    },
    {
      "label": "Get-Content [-Path] <String[]> [-TotalCount <Int64>] [-Tail <Int32>] [-Encoding <Encoding>] [-Raw]",
      "documentation": {
        "value": "Gets the content of a file as an array of strings (one per line) or as a single string with -Raw."
      },
      "parameters": [
        {
          "label": "-Path",
          "documentation": {
            "value": "The path to the file(s) to read."
          }
        },
        {
          "label": "-TotalCount",
          "documentation": {
            "value": "Read only the first N lines."
          }
        },
        {
          "label": "-Tail",
          "documentation": {
            "value": "Read only the last N lines."
          }
        },
        {
          "label": "-Encoding",
          "documentation": {
            "value": "The encoding: ASCII, UTF8, UTF7, UTF32, Unicode, BigEndianUnicode, Default, OEM."
          }
        },
        {
          "label": "-Raw",
          "documentation": {
            "value": "Returns the entire file as a single string instead of an array of lines."
          }
        }
      ]
    },
