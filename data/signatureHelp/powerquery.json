  "signatures": [
    {
      "label": "Table.SelectRows(table as table, condition as function) as table",
      "documentation": {
        "value": "Returns a table containing only the rows that match the specified condition function."
      },
      "parameters": [
        {
          "label": "table",
          "documentation": {
            "value": "The input table to filter."
          }
        },
        {
          "label": "condition",
          "documentation": {
            "value": "A function applied to each row. Returns true to include the row (e.g., each [Column] > 10)."
          }
        }
      ]
    },
    {
      "label": "Table.AddColumn(table as table, newColumnName as text, columnGenerator as function, optional columnType as type) as table",
      "documentation": {
        "value": "Adds a new column to the table with values computed by the given function."
      },
      "parameters": [
        {
          "label": "table",
          "documentation": {
            "value": "The input table."
          }
        },
        {
          "label": "newColumnName",
          "documentation": {
            "value": "The name of the new column."
          }
        },
        {
          "label": "columnGenerator",
          "documentation": {
            "value": "A function applied to each row to compute the new column value (e.g., each [A] + [B])."
          }
        },
        {
          "label": "columnType",
          "documentation": {
            "value": "Optional. The type of the new column (e.g., type number, type text)."
          }
        }
      ]
    },
    {
      "label": "Table.TransformColumns(table as table, transformOperations as list, optional defaultTransformation as function, optional missingField as MissingField.Type) as table",
      "documentation": {
        "value": "Transforms the values of one or more columns using the specified transformation functions."
      },
      "parameters": [
        {
          "label": "table",
          "documentation": {
            "value": "The input table."
          }
        },
        {
          "label": "transformOperations",
          "documentation": {
            "value": "A list of {column name, transformation function} pairs."
          }
        },
        {
          "label": "defaultTransformation",
          "documentation": {
            "value": "Optional. A function to apply to columns not listed in transformOperations."
          }
        },
        {
          "label": "missingField",
          "documentation": {
            "value": "Optional. Behavior when a column is missing: MissingField.Error, MissingField.Ignore, MissingField.UseNull."
          }
        }
      ]
    },
    {
      "label": "List.Select(list as list, selection as function) as list",
      "documentation": {
        "value": "Returns a list of values from the input list that match the selection criteria."
      },
      "parameters": [
        {
          "label": "list",
          "documentation": {
            "value": "The input list to filter."
          }
        },
        {
          "label": "selection",
          "documentation": {
            "value": "The condition function applied to each element (e.g., each _ > 5)."
          }
        }
      ]
    },
    {
      "label": "Text.Contains(text as nullable text, substring as text, optional comparer as Comparer.Type) as nullable logical",
      "documentation": {
        "value": "Returns true if the text contains the specified substring."
      },
      "parameters": [
        {
          "label": "text",
          "documentation": {
            "value": "The text to search in."
          }
        },
        {
          "label": "substring",
          "documentation": {
            "value": "The substring to search for."
          }
        },
        {
          "label": "comparer",
          "documentation": {
            "value": "Optional. A comparer function (e.g., Comparer.OrdinalIgnoreCase for case-insensitive)."
          }
        }
      ]
    },
    {
      "label": "Number.Round(number as nullable number, optional digits as nullable number, optional roundingMode as nullable RoundingMode.Type) as nullable number",
      "documentation": {
        "value": "Returns the result of rounding a number to the specified number of digits."
      },
      "parameters": [
        {
          "label": "number",
          "documentation": {
            "value": "The number to round."
          }
        },
        {
          "label": "digits",
          "documentation": {
            "value": "Optional. The number of decimal places. Default is 0."
          }
        },
        {
          "label": "roundingMode",
          "documentation": {
            "value": "Optional. RoundingMode.Up, RoundingMode.Down, RoundingMode.AwayFromZero, RoundingMode.ToEven."
          }
        }
      ]
    },
    {
      "label": "Date.From(value as any, optional culture as nullable text) as nullable date",
      "documentation": {
        "value": "Converts a value to a date. Supports conversion from text, datetime, datetimezone, and number."
      },
      "parameters": [
        {
          "label": "value",
          "documentation": {
            "value": "The value to convert to a date."
          }
        },
        {
          "label": "culture",
          "documentation": {
            "value": "Optional. A text value for culture-specific parsing (e.g., \"en-US\")."
          }
        }
      ]
    },
    {
      "label": "Record.Field(record as record, field as text) as any",
      "documentation": {
        "value": "Returns the value of the specified field in a record. Equivalent to record[field]."
      },
      "parameters": [
        {
          "label": "record",
          "documentation": {
            "value": "The record to access."
          }
        },
        {
          "label": "field",
          "documentation": {
            "value": "The name of the field to retrieve."
          }
        }
      ]
    },
    {
      "label": "Table.Group(table as table, key as any, aggregatedColumns as list, optional groupKind as GroupKind.Type, optional comparer as function) as table",
      "documentation": {
        "value": "Groups table rows by key columns and applies aggregate functions to create summary columns."
      },
      "parameters": [
        {
          "label": "table",
          "documentation": {
            "value": "The input table to group."
          }
        },
        {
          "label": "key",
          "documentation": {
            "value": "The column name or list of column names to group by."
          }
        },
        {
          "label": "aggregatedColumns",
          "documentation": {
            "value": "A list of {new column name, aggregation function, optional type} lists."
          }
        },
        {
          "label": "groupKind",
          "documentation": {
            "value": "Optional. GroupKind.Global or GroupKind.Local."
          }
        },
        {
          "label": "comparer",
          "documentation": {
            "value": "Optional. A comparer function for comparing key values."
          }
        }
      ]
    },
    {
      "label": "Table.Join(table1 as table, key1 as any, table2 as table, key2 as any, optional joinKind as JoinKind.Type, optional joinAlgorithm as JoinAlgorithm.Type, optional keyEqualityComparers as list) as table",
      "documentation": {
        "value": "Joins two tables based on matching key columns."
      },
      "parameters": [
        {
          "label": "table1",
          "documentation": {
            "value": "The left table."
          }
        },
        {
          "label": "key1",
          "documentation": {
            "value": "The join key column name(s) from table1."
          }
        },
        {
          "label": "table2",
          "documentation": {
            "value": "The right table."
          }
        },
        {
          "label": "key2",
          "documentation": {
            "value": "The join key column name(s) from table2."
          }
        },
        {
          "label": "joinKind",
          "documentation": {
            "value": "Optional. JoinKind.Inner, JoinKind.LeftOuter, JoinKind.RightOuter, JoinKind.FullOuter, JoinKind.LeftAnti, JoinKind.RightAnti."
          }
        }
      ]
    },
