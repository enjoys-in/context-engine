  "signatures": [
    {
      "label": "minute hour day_of_month month day_of_week command",
      "documentation": {
        "value": "Defines a cron job schedule. Each field specifies when the command runs.\n```crontab\n# Every day at 2:30 AM\n30 2 * * * /usr/bin/backup.sh\n\n# Every 5 minutes\n*/5 * * * * /usr/bin/check_health.sh\n\n# Weekdays at 9 AM\n0 9 * * 1-5 /usr/bin/report.sh\n```"
      },
      "parameters": [
        {
          "label": "minute",
          "documentation": {
            "value": "Minute (0-59). Supports `*`, ranges (`1-5`), lists (`1,15,30`), and steps (`*/5`)."
          }
        },
        {
          "label": "hour",
          "documentation": {
            "value": "Hour (0-23). Supports `*`, ranges, lists, and steps."
          }
        },
        {
          "label": "day_of_month",
          "documentation": {
            "value": "Day of month (1-31). Supports `*`, ranges, lists, and steps."
          }
        },
        {
          "label": "month",
          "documentation": {
            "value": "Month (1-12 or JAN-DEC). Supports `*`, ranges, lists, and steps."
          }
        },
        {
          "label": "day_of_week",
          "documentation": {
            "value": "Day of week (0-7, where 0 and 7 are Sunday, or SUN-SAT). Supports `*`, ranges, lists, and steps."
          }
        },
        {
          "label": "command",
          "documentation": {
            "value": "The shell command to execute."
          }
        }
      ]
    },
    {
      "label": "@reboot command",
      "documentation": {
        "value": "Runs a command once at system startup.\n```crontab\n@reboot /usr/bin/start_server.sh\n```"
      },
      "parameters": [
        {
          "label": "command",
          "documentation": {
            "value": "The shell command to execute at boot."
          }
        }
      ]
    },
    {
      "label": "@hourly command",
      "documentation": {
        "value": "Runs a command once every hour (equivalent to `0 * * * *`).\n```crontab\n@hourly /usr/bin/sync.sh\n```"
      },
      "parameters": [
        {
          "label": "command",
          "documentation": {
            "value": "The shell command to execute every hour."
          }
        }
      ]
    },
    {
      "label": "@daily command",
      "documentation": {
        "value": "Runs a command once every day at midnight (equivalent to `0 0 * * *`).\n```crontab\n@daily /usr/bin/cleanup.sh\n```"
      },
      "parameters": [
        {
          "label": "command",
          "documentation": {
            "value": "The shell command to execute daily."
          }
        }
      ]
    },
    {
      "label": "@weekly command",
      "documentation": {
        "value": "Runs a command once a week on Sunday at midnight (equivalent to `0 0 * * 0`).\n```crontab\n@weekly /usr/bin/weekly_report.sh\n```"
      },
      "parameters": [
        {
          "label": "command",
          "documentation": {
            "value": "The shell command to execute weekly."
          }
        }
      ]
    },
    {
      "label": "@monthly command",
      "documentation": {
        "value": "Runs a command once a month on the 1st at midnight (equivalent to `0 0 1 * *`).\n```crontab\n@monthly /usr/bin/monthly_backup.sh\n```"
      },
      "parameters": [
        {
          "label": "command",
          "documentation": {
            "value": "The shell command to execute monthly."
          }
        }
      ]
    },
    {
      "label": "@annually command",
      "documentation": {
        "value": "Runs a command once a year on January 1st at midnight (equivalent to `0 0 1 1 *`).\n```crontab\n@annually /usr/bin/yearly_archive.sh\n```"
      },
      "parameters": [
        {
          "label": "command",
          "documentation": {
            "value": "The shell command to execute annually."
          }
        }
      ]
    },
    {
      "label": "VARIABLE=value",
      "documentation": {
        "value": "Sets an environment variable for all subsequent cron jobs in the crontab.\n```crontab\nSHELL=/bin/bash\nPATH=/usr/local/bin:/usr/bin:/bin\nMAILTO=admin@example.com\n```"
      },
      "parameters": [
        {
          "label": "VARIABLE",
          "documentation": {
            "value": "Environment variable name (e.g. `SHELL`, `PATH`, `MAILTO`, `HOME`)."
          }
        },
        {
          "label": "value",
          "documentation": {
            "value": "Value to assign to the variable."
          }
        }
      ]
    },
