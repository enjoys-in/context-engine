{
  "language": "hcl",
  "triggerCharacters": [
    "(",
    ","
  ],
  "retriggerCharacters": [
    ","
  ],
  "signatures": [
    {
      "label": "resource \"type\" \"name\" { ...config }",
      "documentation": {
        "value": "Declares an infrastructure resource of the given type with configuration arguments."
      },
      "parameters": [
        {
          "label": "type",
          "documentation": {
            "value": "The resource type (e.g., \"aws_instance\", \"azurerm_resource_group\")."
          }
        },
        {
          "label": "name",
          "documentation": {
            "value": "A local name used to refer to this resource elsewhere in the configuration."
          }
        }
      ]
    },
    {
      "label": "variable \"name\" { type, default, description }",
      "documentation": {
        "value": "Declares an input variable that can be set when applying the configuration."
      },
      "parameters": [
        {
          "label": "name",
          "documentation": {
            "value": "The name of the variable, used as var.<name> in expressions."
          }
        }
      ]
    },
    {
      "label": "output \"name\" { value, description }",
      "documentation": {
        "value": "Declares an output value that is displayed after apply and accessible by other configurations."
      },
      "parameters": [
        {
          "label": "name",
          "documentation": {
            "value": "The name of the output value."
          }
        }
      ]
    },
    {
      "label": "data \"type\" \"name\" { ...query }",
      "documentation": {
        "value": "Declares a data source to fetch information from an external source or another configuration."
      },
      "parameters": [
        {
          "label": "type",
          "documentation": {
            "value": "The data source type (e.g., \"aws_ami\", \"azurerm_subscription\")."
          }
        },
        {
          "label": "name",
          "documentation": {
            "value": "A local name for this data source."
          }
        }
      ]
    },
    {
      "label": "module \"name\" { source, ...inputs }",
      "documentation": {
        "value": "Calls a child module with the given source and input variables."
      },
      "parameters": [
        {
          "label": "name",
          "documentation": {
            "value": "A local name for this module instance."
          }
        }
      ]
    },
    {
      "label": "locals { key = value, ... }",
      "documentation": {
        "value": "Declares local values that can simplify expressions and avoid repetition within a module."
      },
      "parameters": []
    },
    {
      "label": "terraform { required_version, required_providers, backend }",
      "documentation": {
        "value": "Configures Terraform behavior including version constraints, required providers, and backend state storage."
      },
      "parameters": []
    },
    {
      "label": "provider \"name\" { ...config }",
      "documentation": {
        "value": "Configures a provider plugin with settings such as region, credentials, and other provider-specific options."
      },
      "parameters": [
        {
          "label": "name",
          "documentation": {
            "value": "The provider name (e.g., \"aws\", \"azurerm\", \"google\")."
          }
        }
      ]
    },
    {
      "label": "lookup(map, key, default): value",
      "documentation": {
        "value": "Retrieves a value from a map by its key, returning a default value if the key is not found."
      },
      "parameters": [
        {
          "label": "map",
          "documentation": {
            "value": "The map to look up the value in."
          }
        },
        {
          "label": "key",
          "documentation": {
            "value": "The key to look up."
          }
        },
        {
          "label": "default",
          "documentation": {
            "value": "The default value to return if the key is not found."
          }
        }
      ]
    },
    {
      "label": "element(list, index): value",
      "documentation": {
        "value": "Retrieves a single element from a list by its index. The index is zero-based and wraps around using modulo."
      },
      "parameters": [
        {
          "label": "list",
          "documentation": {
            "value": "The list to retrieve from."
          }
        },
        {
          "label": "index",
          "documentation": {
            "value": "The zero-based index of the element."
          }
        }
      ]
    },
    {
      "label": "merge(maps...): map",
      "documentation": {
        "value": "Takes an arbitrary number of maps or objects and returns a single map containing a merged set of elements from all arguments."
      },
      "parameters": [
        {
          "label": "maps...",
          "documentation": {
            "value": "One or more maps to merge. Later values override earlier ones for duplicate keys."
          }
        }
      ]
    },
    {
      "label": "concat(lists...): list",
      "documentation": {
        "value": "Combines two or more lists into a single list."
      },
      "parameters": [
        {
          "label": "lists...",
          "documentation": {
            "value": "Two or more lists to concatenate in order."
          }
        }
      ]
    },
    {
      "label": "file(path): string",
      "documentation": {
        "value": "Reads the contents of a file at the given path and returns it as a string."
      },
      "parameters": [
        {
          "label": "path",
          "documentation": {
            "value": "The path to the file to read, relative to the root module directory."
          }
        }
      ]
    },
    {
      "label": "templatefile(path, vars): string",
      "documentation": {
        "value": "Reads a file at the given path and renders its content as a template using the supplied variables."
      },
      "parameters": [
        {
          "label": "path",
          "documentation": {
            "value": "The path to the template file."
          }
        },
        {
          "label": "vars",
          "documentation": {
            "value": "A map of template variables to use during rendering."
          }
        }
      ]
    },
