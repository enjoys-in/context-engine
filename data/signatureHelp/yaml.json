{
  "language": "yaml",
  "triggerCharacters": [
    ":",
    " ",
    "-"
  ],
  "retriggerCharacters": [
    " "
  ],
  "signatures": [
    {
      "label": "key: value - Mapping entry",
      "documentation": {
        "value": "A mapping (dictionary/hash) associates keys with values using a colon followed by a space."
      },
      "parameters": [
        {
          "label": "key",
          "documentation": {
            "value": "A scalar key (string, number, or boolean). Complex keys use `? key`"
          }
        },
        {
          "label": "value",
          "documentation": {
            "value": "Any YAML value: scalar, sequence, or nested mapping"
          }
        }
      ]
    },
    {
      "label": "- item - Sequence entry",
      "documentation": {
        "value": "A sequence (list/array) is indicated by a dash followed by a space for each entry."
      },
      "parameters": [
        {
          "label": "item",
          "documentation": {
            "value": "Any YAML value: scalar, mapping, or nested sequence"
          }
        }
      ]
    },
    {
      "label": "scalar: string | number | boolean | null",
      "documentation": {
        "value": "Scalar values are plain text, quoted strings, numbers, booleans (`true`/`false`), or null. YAML auto-detects types."
      },
      "parameters": [
        {
          "label": "string",
          "documentation": {
            "value": "Plain: `hello`, single-quoted: `'hello'`, double-quoted: `\"hello\\n\"`"
          }
        },
        {
          "label": "number",
          "documentation": {
            "value": "Integer: `42`, float: `3.14`, hex: `0xFF`, octal: `0o77`"
          }
        },
        {
          "label": "boolean",
          "documentation": {
            "value": "`true`, `false`, `yes`, `no`, `on`, `off` (unquoted)"
          }
        },
        {
          "label": "null",
          "documentation": {
            "value": "`null`, `~`, or empty value"
          }
        }
      ]
    },
    {
      "label": "&anchor / *alias - Anchor and alias",
      "documentation": {
        "value": "An anchor (`&name`) marks a node for later reuse. An alias (`*name`) references the anchored node."
      },
      "parameters": [
        {
          "label": "&anchor",
          "documentation": {
            "value": "Defines an anchor on a node, e.g. `&defaults` on a mapping"
          }
        },
        {
          "label": "*alias",
          "documentation": {
            "value": "References a previously defined anchor, e.g. `*defaults`"
          }
        }
      ]
    },
    {
      "label": "!tag value - Tag",
      "documentation": {
        "value": "Tags specify the data type of a node. Custom tags use `!` prefix, standard tags use `!!`."
      },
      "parameters": [
        {
          "label": "tag",
          "documentation": {
            "value": "A type tag: `!!str`, `!!int`, `!!float`, `!!bool`, `!!null`, `!!seq`, `!!map`, or custom `!MyType`"
          }
        },
        {
          "label": "value",
          "documentation": {
            "value": "The value to interpret according to the tag"
          }
        }
      ]
    },
    {
      "label": "<<: *alias - Merge key",
      "documentation": {
        "value": "Merges the referenced mapping into the current mapping. Keys in the current mapping take precedence."
      },
      "parameters": [
        {
          "label": "*alias",
          "documentation": {
            "value": "An alias referencing an anchored mapping to merge, or a sequence of aliases"
          }
        }
      ]
    },
    {
      "label": "| or > - Multiline scalar",
      "documentation": {
        "value": "Block scalars preserve (`|`, literal) or fold (`>`, folded) newlines in multiline text."
      },
      "parameters": [
        {
          "label": "|",
          "documentation": {
            "value": "Literal block: preserves newlines as-is. Use `|-` to strip trailing newline, `|+` to keep all trailing newlines."
          }
        },
        {
          "label": ">",
          "documentation": {
            "value": "Folded block: folds newlines into spaces. Use `>-` to strip trailing newline, `>+` to keep all trailing newlines."
          }
        }
      ]
    },
    {
      "label": "--- / ... - Document markers",
      "documentation": {
        "value": "`---` starts a new YAML document. `...` ends a document. Multiple documents can exist in one file."
      },
      "parameters": [
        {
          "label": "---",
          "documentation": {
            "value": "Marks the beginning of a YAML document"
          }
        },
        {
          "label": "...",
          "documentation": {
            "value": "Marks the end of a YAML document (optional)"
          }
        }
      ]
    },
