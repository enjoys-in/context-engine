  "signatures": [
    {
      "label": "get key",
      "documentation": {
        "value": "Retrieves the string value stored at the specified key."
      },
      "parameters": [
        {
          "label": "key",
          "documentation": {
            "value": "The key name to retrieve."
          }
        }
      ]
    },
    {
      "label": "set key value [EX seconds] [PX milliseconds] [NX|XX]",
      "documentation": {
        "value": "Sets a key to hold a string value, with optional expiration and conditional flags."
      },
      "parameters": [
        {
          "label": "key",
          "documentation": {
            "value": "The key name."
          }
        },
        {
          "label": "value",
          "documentation": {
            "value": "The string value to store."
          }
        },
        {
          "label": "EX seconds",
          "documentation": {
            "value": "Optional. Set key expiration in seconds."
          }
        },
        {
          "label": "NX|XX",
          "documentation": {
            "value": "NX: set only if key doesn't exist. XX: set only if key exists."
          }
        }
      ]
    },
    {
      "label": "del key [key ...]",
      "documentation": {
        "value": "Deletes one or more keys. Returns the number of keys removed."
      },
      "parameters": [
        {
          "label": "key",
          "documentation": {
            "value": "One or more key names to delete."
          }
        }
      ]
    },
    {
      "label": "hget key field",
      "documentation": {
        "value": "Returns the value of a field in a hash."
      },
      "parameters": [
        {
          "label": "key",
          "documentation": {
            "value": "The hash key."
          }
        },
        {
          "label": "field",
          "documentation": {
            "value": "The field within the hash."
          }
        }
      ]
    },
    {
      "label": "hset key field value [field value ...]",
      "documentation": {
        "value": "Sets one or more field-value pairs in a hash."
      },
      "parameters": [
        {
          "label": "key",
          "documentation": {
            "value": "The hash key."
          }
        },
        {
          "label": "field",
          "documentation": {
            "value": "The field name."
          }
        },
        {
          "label": "value",
          "documentation": {
            "value": "The value for the field."
          }
        }
      ]
    },
    {
      "label": "lpush key element [element ...]",
      "documentation": {
        "value": "Prepends one or more elements to the head of a list."
      },
      "parameters": [
        {
          "label": "key",
          "documentation": {
            "value": "The list key."
          }
        },
        {
          "label": "element",
          "documentation": {
            "value": "One or more elements to push to the left."
          }
        }
      ]
    },
    {
      "label": "rpush key element [element ...]",
      "documentation": {
        "value": "Appends one or more elements to the tail of a list."
      },
      "parameters": [
        {
          "label": "key",
          "documentation": {
            "value": "The list key."
          }
        },
        {
          "label": "element",
          "documentation": {
            "value": "One or more elements to push to the right."
          }
        }
      ]
    },
    {
      "label": "lrange key start stop",
      "documentation": {
        "value": "Returns a range of elements from a list. Use 0 -1 for full list."
      },
      "parameters": [
        {
          "label": "key",
          "documentation": {
            "value": "The list key."
          }
        },
        {
          "label": "start",
          "documentation": {
            "value": "The start index (0-based)."
          }
        },
        {
          "label": "stop",
          "documentation": {
            "value": "The stop index (inclusive, -1 for last)."
          }
        }
      ]
    },
    {
      "label": "keys pattern",
      "documentation": {
        "value": "Returns all keys matching the glob-style pattern. Avoid in production; use SCAN instead."
      },
      "parameters": [
        {
          "label": "pattern",
          "documentation": {
            "value": "The pattern to match (e.g., *, user:*, session:????)."
          }
        }
      ]
    },
    {
      "label": "monitor",
      "documentation": {
        "value": "Streams back every command processed by the Redis server in real time. Useful for debugging. Press Ctrl+C to stop."
      },
      "parameters": []
    },
    {
      "label": "subscribe channel [channel ...]",
      "documentation": {
        "value": "Subscribes the client to one or more channels for Pub/Sub messaging."
      },
      "parameters": [
        {
          "label": "channel",
          "documentation": {
            "value": "One or more channel names to subscribe to."
          }
        }
      ]
    },
    {
      "label": "publish channel message",
      "documentation": {
        "value": "Posts a message to a Pub/Sub channel. Returns the number of clients that received the message."
