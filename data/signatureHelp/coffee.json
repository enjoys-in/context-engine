  "signatures": [
    {
      "label": "console.log(data, ...args): void",
      "documentation": {
        "value": "Prints data to the console with a newline.\n```coffeescript\nconsole.log 'Hello World'\nconsole.log 'Count:', 42\nconsole.log {name: 'Alice', age: 30}\n```"
      },
      "parameters": [
        {
          "label": "data",
          "documentation": {
            "value": "Primary value to log."
          }
        },
        {
          "label": "...args",
          "documentation": {
            "value": "Additional values to log, space-separated."
          }
        }
      ]
    },
    {
      "label": "alert(message): void",
      "documentation": {
        "value": "Displays a browser alert dialog with the specified message.\n```coffeescript\nalert 'Warning!'\nalert \"You have #{count} items\"\n```"
      },
      "parameters": [
        {
          "label": "message",
          "documentation": {
            "value": "The message string to display in the alert dialog."
          }
        }
      ]
    },
    {
      "label": "setTimeout(callback, delay, ...args): timeoutId",
      "documentation": {
        "value": "Calls a function after a specified delay in milliseconds.\n```coffeescript\nsetTimeout (->\n  console.log 'Delayed'\n), 1000\n\ntid = setTimeout doWork, 500\n```"
      },
      "parameters": [
        {
          "label": "callback",
          "documentation": {
            "value": "The function to execute after the delay."
          }
        },
        {
          "label": "delay",
          "documentation": {
            "value": "Time in milliseconds before execution."
          }
        },
        {
          "label": "...args",
          "documentation": {
            "value": "Optional arguments passed to the callback."
          }
        }
      ]
    },
    {
      "label": "setInterval(callback, delay, ...args): intervalId",
      "documentation": {
        "value": "Repeatedly calls a function at a fixed time interval.\n```coffeescript\nsetInterval (->\n  console.log 'tick'\n), 1000\n```"
      },
      "parameters": [
        {
          "label": "callback",
          "documentation": {
            "value": "The function to execute at each interval."
          }
        },
        {
          "label": "delay",
          "documentation": {
            "value": "Time in milliseconds between each execution."
          }
        },
        {
          "label": "...args",
          "documentation": {
            "value": "Optional arguments passed to the callback."
          }
        }
      ]
    },
    {
      "label": "JSON.stringify(value, replacer?, space?): string",
      "documentation": {
        "value": "Converts a JavaScript value to a JSON string.\n```coffeescript\nstr = JSON.stringify {name: 'Alice', age: 30}\nformatted = JSON.stringify obj, null, 2\n```"
      },
      "parameters": [
        {
          "label": "value",
          "documentation": {
            "value": "The value to convert to JSON."
          }
        },
        {
          "label": "replacer?",
          "documentation": {
            "value": "Optional function or array to filter/transform values."
          }
        },
        {
          "label": "space?",
          "documentation": {
            "value": "Optional indentation (number of spaces or string)."
          }
        }
      ]
    },
    {
      "label": "JSON.parse(text, reviver?): any",
      "documentation": {
        "value": "Parses a JSON string and returns the resulting value.\n```coffeescript\nobj = JSON.parse '{\"name\":\"Alice\"}'\ndata = JSON.parse text, (key, val) -> val\n```"
      },
      "parameters": [
        {
          "label": "text",
          "documentation": {
            "value": "The JSON string to parse."
          }
        },
        {
          "label": "reviver?",
          "documentation": {
            "value": "Optional function to transform parsed values."
          }
        }
      ]
    },
    {
      "label": "Math.max(...values): number",
      "documentation": {
        "value": "Returns the largest of zero or more numbers.\n```coffeescript\nMath.max 1, 5, 3       # 5\nMath.max ...myArray\n```"
      },
      "parameters": [
        {
          "label": "...values",
          "documentation": {
            "value": "Numbers to compare. Returns `-Infinity` if no arguments."
          }
        }
      ]
    },
    {
      "label": "Math.min(...values): number",
      "documentation": {
        "value": "Returns the smallest of zero or more numbers.\n```coffeescript\nMath.min 1, 5, 3       # 1\nMath.min ...myArray\n```"
      },
      "parameters": [
        {
          "label": "...values",
          "documentation": {
            "value": "Numbers to compare. Returns `Infinity` if no arguments."
          }
        }
      ]
    },
    {
      "label": "Math.round(x): number",
      "documentation": {
        "value": "Returns the value of `x` rounded to the nearest integer.\n```coffeescript\nMath.round 4.7   # 5\nMath.round 4.4   # 4\nMath.round -4.5  # -4\n```"
      },
      "parameters": [
        {
          "label": "x",
          "documentation": {
            "value": "A number to round."
          }
        }
      ]
    },
    {
      "label": "Array.isArray(value): boolean",
      "documentation": {
        "value": "Determines whether the passed value is an Array.\n```coffeescript\nArray.isArray [1, 2, 3]   # true\nArray.isArray 'hello'     # false\nArray.isArray arguments   # false\n```"
      },
      "parameters": [
        {
          "label": "value",
          "documentation": {
            "value": "The value to check."
          }
        }
      ]
    },
