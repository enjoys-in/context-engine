{
  "language": "ini",
  "triggerCharacters": [
    "[",
    "="
  ],
  "retriggerCharacters": [],
  "signatures": [
    {
      "label": "[section]",
      "documentation": {
        "value": "Declares a section header. All key-value pairs following this header belong to this section until the next section header."
      },
      "parameters": [
        {
          "label": "section",
          "documentation": {
            "value": "The name of the section."
          }
        }
      ]
    },
    {
      "label": "key = value",
      "documentation": {
        "value": "Assigns a value to a key within the current section. The value extends to the end of the line."
      },
      "parameters": [
        {
          "label": "key",
          "documentation": {
            "value": "The property name."
          }
        },
        {
          "label": "value",
          "documentation": {
            "value": "The property value (string, number, or boolean)."
          }
        }
      ]
    },
    {
      "label": "; comment",
      "documentation": {
        "value": "A line comment. Everything after the semicolon is ignored by the parser."
      },
      "parameters": []
    },
    {
      "label": "# comment",
      "documentation": {
        "value": "An alternative line comment syntax. Everything after the hash is ignored by the parser."
      },
      "parameters": []
    },
    {
      "label": "key = ${other_key}",
      "documentation": {
        "value": "Variable interpolation (supported by some INI parsers). References the value of another key."
      },
      "parameters": [
        {
          "label": "other_key",
          "documentation": {
            "value": "The key whose value to substitute."
          }
        }
      ]
    },
    {
      "label": "[section:parent]",
      "documentation": {
        "value": "Section inheritance (supported by some INI parsers). The section inherits all key-value pairs from the parent section."
      },
      "parameters": [
        {
          "label": "section",
          "documentation": {
            "value": "The child section name."
          }
        },
        {
          "label": "parent",
          "documentation": {
            "value": "The parent section to inherit from."
          }
        }
      ]
    },
    {
      "label": "key[] = value",
      "documentation": {
        "value": "Array-style value assignment (supported by some INI parsers). Multiple values can be assigned to the same key as a list."
      },
      "parameters": [
        {
          "label": "key",
          "documentation": {
            "value": "The property name for the array."
          }
        },
        {
          "label": "value",
          "documentation": {
            "value": "A value to append to the array."
          }
        }
      ]
    },
    {
      "label": "key = \"quoted value\"",
      "documentation": {
        "value": "A quoted string value. Use quotes to preserve leading/trailing whitespace or include special characters."
      },
      "parameters": [
        {
          "label": "key",
          "documentation": {
            "value": "The property name."
          }
        },
        {
          "label": "quoted value",
          "documentation": {
            "value": "The value enclosed in double quotes."
          }
        }
      ]
    },
