{
  "language": "st",
  "triggerCharacters": [
    "(",
    ",",
    " "
  ],
  "retriggerCharacters": [
    ",",
    " "
  ],
  "signatures": [
    {
      "label": "IF condition THEN statements [ELSIF condition THEN statements] [ELSE statements] END_IF",
      "documentation": {
        "value": "Conditional branching statement. Executes statements if the condition evaluates to TRUE."
      },
      "parameters": [
        {
          "label": "condition",
          "documentation": {
            "value": "A BOOL expression to evaluate"
          }
        },
        {
          "label": "statements",
          "documentation": {
            "value": "One or more statements to execute when the condition is TRUE"
          }
        }
      ]
    },
    {
      "label": "CASE expression OF value1: statements; [value2: statements;] [ELSE statements;] END_CASE",
      "documentation": {
        "value": "Selects one of several groups of statements depending on the value of an expression."
      },
      "parameters": [
        {
          "label": "expression",
          "documentation": {
            "value": "An integer or enumeration expression to evaluate"
          }
        },
        {
          "label": "value1: statements",
          "documentation": {
            "value": "A case label followed by statements to execute"
          }
        }
      ]
    },
    {
      "label": "FOR variable := start TO end [BY step] DO statements END_FOR",
      "documentation": {
        "value": "Repeats statements for a counter variable from a start value to an end value."
      },
      "parameters": [
        {
          "label": "variable",
          "documentation": {
            "value": "The loop counter variable (must be an integer type)"
          }
        },
        {
          "label": "start",
          "documentation": {
            "value": "The initial value of the counter"
          }
        },
        {
          "label": "end",
          "documentation": {
            "value": "The final value of the counter (inclusive)"
          }
        },
        {
          "label": "step",
          "documentation": {
            "value": "Optional increment value (default is 1)"
          }
        }
      ]
    },
    {
      "label": "WHILE condition DO statements END_WHILE",
      "documentation": {
        "value": "Repeats statements as long as the condition evaluates to TRUE."
      },
      "parameters": [
        {
          "label": "condition",
          "documentation": {
            "value": "A BOOL expression evaluated before each iteration"
          }
        },
        {
          "label": "statements",
          "documentation": {
            "value": "Statements to execute in each iteration"
          }
        }
      ]
    },
    {
      "label": "REPEAT statements UNTIL condition END_REPEAT",
      "documentation": {
        "value": "Repeats statements until the condition evaluates to TRUE. Body is executed at least once."
      },
      "parameters": [
        {
          "label": "statements",
          "documentation": {
            "value": "Statements to execute in each iteration"
          }
        },
        {
          "label": "condition",
          "documentation": {
            "value": "A BOOL expression evaluated after each iteration"
          }
        }
      ]
    },
    {
      "label": "FUNCTION_BLOCK name VAR ... END_VAR ... END_FUNCTION_BLOCK",
      "documentation": {
        "value": "Declares a function block - a POU with persistent state between calls. Can have input, output, and internal variables."
      },
      "parameters": [
        {
          "label": "name",
          "documentation": {
            "value": "The name of the function block"
          }
        }
      ]
    },
    {
      "label": "VAR [CONSTANT|RETAIN] variable : type [:= initial_value]; END_VAR",
      "documentation": {
        "value": "Declares local variables within a POU. Optional qualifiers: CONSTANT for read-only, RETAIN for persistent values."
      },
      "parameters": [
        {
          "label": "variable",
          "documentation": {
            "value": "The variable identifier"
          }
        },
        {
          "label": "type",
          "documentation": {
            "value": "The data type (BOOL, INT, REAL, STRING, etc.)"
          }
        },
        {
          "label": "initial_value",
          "documentation": {
            "value": "Optional initial value for the variable"
          }
        }
      ]
    },
    {
      "label": "ABS(value: ANY_NUM): ANY_NUM",
      "documentation": {
        "value": "Returns the absolute value of a numeric input."
      },
      "parameters": [
        {
          "label": "value",
          "documentation": {
            "value": "A numeric value (INT, REAL, DINT, LREAL, etc.)"
          }
        }
      ]
    },
    {
      "label": "SQRT(value: ANY_REAL): ANY_REAL",
      "documentation": {
        "value": "Returns the square root of a real number."
      },
      "parameters": [
        {
          "label": "value",
          "documentation": {
            "value": "A non-negative REAL or LREAL value"
          }
        }
      ]
    },
    {
      "label": "MAX(value1: ANY_NUM, value2: ANY_NUM): ANY_NUM",
      "documentation": {
        "value": "Returns the larger of two numeric values."
      },
      "parameters": [
        {
          "label": "value1",
          "documentation": {
            "value": "The first numeric value"
          }
        },
        {
          "label": "value2",
          "documentation": {
            "value": "The second numeric value"
          }
        }
      ]
    },
    {
      "label": "MIN(value1: ANY_NUM, value2: ANY_NUM): ANY_NUM",
      "documentation": {
        "value": "Returns the smaller of two numeric values."
      },
      "parameters": [
        {
          "label": "value1",
          "documentation": {
            "value": "The first numeric value"
          }
        },
        {
          "label": "value2",
          "documentation": {
            "value": "The second numeric value"
          }
        }
      ]
    },
    {
      "label": "LEN(str: STRING): INT",
      "documentation": {
        "value": "Returns the length of a string in characters."
      },
      "parameters": [
        {
          "label": "str",
          "documentation": {
            "value": "The input string"
          }
        }
      ]
    },
    {
      "label": "MID(str: STRING, length: INT, position: INT): STRING",
      "documentation": {
        "value": "Returns a substring of the given length starting at the specified position."
      },
      "parameters": [
        {
          "label": "str",
          "documentation": {
            "value": "The input string"
          }
        },
        {
          "label": "length",
          "documentation": {
            "value": "The number of characters to extract"
          }
        },
        {
          "label": "position",
          "documentation": {
            "value": "The 1-based starting position"
          }
        }
      ]
    },
