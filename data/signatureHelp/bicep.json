  "signatures": [
    {
      "label": "concat(arg1, arg2, ...): array | string",
      "documentation": {
        "value": "Combines multiple arrays or strings into one.\n```bicep\nvar combined = concat('Hello', ' ', 'World') // 'Hello World'\nvar arr = concat([1, 2], [3, 4]) // [1, 2, 3, 4]\n```"
      },
      "parameters": [
        {
          "label": "arg1",
          "documentation": {
            "value": "First array or string."
          }
        },
        {
          "label": "arg2",
          "documentation": {
            "value": "Second array or string."
          }
        },
        {
          "label": "...",
          "documentation": {
            "value": "Additional arrays or strings to concatenate."
          }
        }
      ]
    },
    {
      "label": "length(value): int",
      "documentation": {
        "value": "Returns the number of elements in an array, characters in a string, or properties in an object.\n```bicep\nvar len = length('hello') // 5\nvar arrLen = length([1, 2, 3]) // 3\n```"
      },
      "parameters": [
        {
          "label": "value",
          "documentation": {
            "value": "An array, string, or object to measure."
          }
        }
      ]
    },
    {
      "label": "contains(container, itemToFind): bool",
      "documentation": {
        "value": "Checks whether an array, object, or string contains a value.\n```bicep\nvar result = contains('Hello World', 'World') // true\nvar has = contains([1, 2, 3], 2) // true\n```"
      },
      "parameters": [
        {
          "label": "container",
          "documentation": {
            "value": "An array, object, or string to search in."
          }
        },
        {
          "label": "itemToFind",
          "documentation": {
            "value": "The value, key, or substring to find."
          }
        }
      ]
    },
    {
      "label": "empty(itemToTest): bool",
      "documentation": {
        "value": "Determines if an array, object, or string is empty.\n```bicep\nvar isEmpty = empty('') // true\nvar isArrEmpty = empty([]) // true\n```"
      },
      "parameters": [
        {
          "label": "itemToTest",
          "documentation": {
            "value": "An array, object, or string to check."
          }
        }
      ]
    },
    {
      "label": "first(value): element",
      "documentation": {
        "value": "Returns the first element of an array or first character of a string.\n```bicep\nvar f = first([1, 2, 3]) // 1\nvar c = first('hello') // 'h'\n```"
      },
      "parameters": [
        {
          "label": "value",
          "documentation": {
            "value": "An array or string."
          }
        }
      ]
    },
    {
      "label": "last(value): element",
      "documentation": {
        "value": "Returns the last element of an array or last character of a string.\n```bicep\nvar l = last([1, 2, 3]) // 3\nvar c = last('hello') // 'o'\n```"
      },
      "parameters": [
        {
          "label": "value",
          "documentation": {
            "value": "An array or string."
          }
        }
      ]
    },
    {
      "label": "union(arg1, arg2, ...): array | object",
      "documentation": {
        "value": "Returns the union of multiple arrays or objects (combined with duplicates removed for arrays).\n```bicep\nvar u = union([1, 2], [2, 3]) // [1, 2, 3]\nvar o = union({a: 1}, {b: 2}) // {a: 1, b: 2}\n```"
      },
      "parameters": [
        {
          "label": "arg1",
          "documentation": {
            "value": "First array or object."
          }
        },
        {
          "label": "arg2",
          "documentation": {
            "value": "Second array or object."
          }
        },
        {
          "label": "...",
          "documentation": {
            "value": "Additional arrays or objects."
          }
        }
      ]
    },
    {
      "label": "intersection(arg1, arg2, ...): array | object",
      "documentation": {
        "value": "Returns common elements from arrays or common properties from objects.\n```bicep\nvar common = intersection([1, 2, 3], [2, 3, 4]) // [2, 3]\n```"
      },
      "parameters": [
        {
          "label": "arg1",
          "documentation": {
            "value": "First array or object."
          }
        },
        {
          "label": "arg2",
          "documentation": {
            "value": "Second array or object."
          }
        },
        {
          "label": "...",
          "documentation": {
            "value": "Additional arrays or objects."
          }
        }
      ]
    },
    {
      "label": "resourceId(resourceType, resourceName1, resourceName2, ...): string",
      "documentation": {
        "value": "Returns the unique resource identifier of a resource.\n```bicep\nvar id = resourceId('Microsoft.Storage/storageAccounts', 'myStorage')\n```"
      },
      "parameters": [
        {
          "label": "resourceType",
          "documentation": {
            "value": "The resource type including namespace (e.g. `'Microsoft.Storage/storageAccounts'`)."
          }
        },
        {
          "label": "resourceName1",
          "documentation": {
            "value": "The name of the resource."
          }
        },
        {
          "label": "resourceName2",
          "documentation": {
            "value": "Optional child resource name segments."
          }
        }
      ]
    },
    {
      "label": "uniqueString(baseString, ...): string",
      "documentation": {
        "value": "Creates a deterministic hash string (13 chars) based on input values. Useful for creating unique resource names.\n```bicep\nvar unique = uniqueString(resourceGroup().id) // e.g. 'a1b2c3d4e5f6g'\nvar name = 'storage${uniqueString(resourceGroup().id)}'\n```"
      },
      "parameters": [
        {
          "label": "baseString",
          "documentation": {
            "value": "The base value used to create a unique string."
          }
        },
        {
          "label": "...",
          "documentation": {
            "value": "Additional strings to combine for uniqueness."
          }
        }
      ]
    },
    {
      "label": "subscription(): object",
      "documentation": {
        "value": "Returns details of the current subscription.\n```bicep\nvar subId = subscription().subscriptionId\nvar tenantId = subscription().tenantId\n```"
      },
      "parameters": []
    },
    {
      "label": "resourceGroup(): object",
      "documentation": {
        "value": "Returns details of the current resource group.\n```bicep\nvar rgName = resourceGroup().name\nvar rgLocation = resourceGroup().location\n```"
      },
      "parameters": []
    },
