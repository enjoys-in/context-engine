{
  "language": "toml",
  "triggerCharacters": [
    "=",
    "[",
    " "
  ],
  "retriggerCharacters": [
    "="
  ],
  "signatures": [
    {
      "label": "[table] - Standard table",
      "documentation": {
        "value": "Defines a table (also called a hash table or dictionary). All key/value pairs that follow belong to this table until the next table header."
      },
      "parameters": [
        {
          "label": "table",
          "documentation": {
            "value": "The table name, e.g. `[package]`, `[dependencies]`. Use dotted keys for nested tables: `[servers.alpha]`"
          }
        }
      ]
    },
    {
      "label": "[[array_of_tables]] - Array of tables",
      "documentation": {
        "value": "Defines an array of tables. Each use of the same header creates a new element in the array."
      },
      "parameters": [
        {
          "label": "array_of_tables",
          "documentation": {
            "value": "The table name, e.g. `[[bin]]`, `[[test]]`. Each occurrence appends a new table to the array."
          }
        }
      ]
    },
    {
      "label": "key = value",
      "documentation": {
        "value": "Assigns a value to a key. Keys are on the left of the equals sign and values are on the right."
      },
      "parameters": [
        {
          "label": "key",
          "documentation": {
            "value": "A bare key, quoted key, or dotted key, e.g. `name`, `\"quoted.key\"`, `server.host`"
          }
        },
        {
          "label": "value",
          "documentation": {
            "value": "A string, integer, float, boolean, datetime, array, or inline table"
          }
        }
      ]
    },
    {
      "label": "inline_table = { key1 = val1, key2 = val2 }",
      "documentation": {
        "value": "An inline table provides a compact syntax for expressing tables on a single line."
      },
      "parameters": [
        {
          "label": "key1 = val1",
          "documentation": {
            "value": "Comma-separated key/value pairs. Inline tables must appear on a single line."
          }
        }
      ]
    },
    {
      "label": "datetime = 1979-05-27T07:32:00Z",
      "documentation": {
        "value": "TOML supports RFC 3339 datetimes: offset datetime, local datetime, local date, and local time."
      },
      "parameters": [
        {
          "label": "datetime",
          "documentation": {
            "value": "Formats: `1979-05-27T07:32:00Z` (offset), `1979-05-27T07:32:00` (local datetime), `1979-05-27` (local date), `07:32:00` (local time)"
          }
        }
      ]
    },
    {
      "label": "array = [val1, val2, val3]",
      "documentation": {
        "value": "Arrays are square brackets with values inside. Whitespace is ignored. Values are separated by commas. Arrays can span multiple lines."
      },
      "parameters": [
        {
          "label": "val1, val2, val3",
          "documentation": {
            "value": "Array values. Can be mixed types in TOML v1.0+. A trailing comma is permitted."
          }
        }
      ]
    },
    {
      "label": "string = \"basic string\" | 'literal string'",
      "documentation": {
        "value": "Basic strings use double quotes and support escape sequences. Literal strings use single quotes with no escaping. Multi-line variants use triple quotes."
      },
      "parameters": [
        {
          "label": "string",
          "documentation": {
            "value": "Basic: `\"hello\\nworld\"`, literal: `'C:\\path'`, multi-line basic: `\"\"\"...\"\"\"`, multi-line literal: `'''...'''`"
          }
        }
      ]
    },
    {
      "label": "boolean = true | false",
      "documentation": {
        "value": "Booleans are lowercase `true` and `false`."
      },
      "parameters": [
        {
          "label": "true | false",
          "documentation": {
            "value": "Must be lowercase: `true` or `false`"
          }
        }
      ]
    },
