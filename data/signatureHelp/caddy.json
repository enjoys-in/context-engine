  "signatures": [
    {
      "label": "reverse_proxy [matcher] upstream1 [upstream2 ...] { ... }",
      "documentation": {
        "value": "Proxies requests to one or more backend servers.\n```caddy\nreverse_proxy localhost:8080\nreverse_proxy /api/* localhost:3000 localhost:3001 {\n  lb_policy round_robin\n  health_uri /health\n}\n```"
      },
      "parameters": [
        {
          "label": "matcher",
          "documentation": {
            "value": "Optional request matcher (e.g. `/api/*`, `@name`)."
          }
        },
        {
          "label": "upstream1",
          "documentation": {
            "value": "Address of the upstream backend (e.g. `localhost:8080`, `http://backend:3000`)."
          }
        },
        {
          "label": "upstream2 ...",
          "documentation": {
            "value": "Additional upstream addresses for load balancing."
          }
        }
      ]
    },
    {
      "label": "file_server [matcher] { root <path>, browse }",
      "documentation": {
        "value": "Serves static files from the given root directory.\n```caddy\nfile_server\nfile_server /static/* {\n  root /var/www\n  browse\n}\n```"
      },
      "parameters": [
        {
          "label": "matcher",
          "documentation": {
            "value": "Optional request matcher to limit which requests are served."
          }
        },
        {
          "label": "root",
          "documentation": {
            "value": "Root directory for file serving (default: current directory)."
          }
        },
        {
          "label": "browse",
          "documentation": {
            "value": "Enable directory browsing."
          }
        }
      ]
    },
    {
      "label": "tls [cert_file] [key_file] { ... }",
      "documentation": {
        "value": "Configures TLS settings for the site.\n```caddy\ntls internal\ntls /path/to/cert.pem /path/to/key.pem\ntls {\n  protocols tls1.2 tls1.3\n}\n```"
      },
      "parameters": [
        {
          "label": "cert_file",
          "documentation": {
            "value": "Path to the TLS certificate file, or `internal` for self-signed."
          }
        },
        {
          "label": "key_file",
          "documentation": {
            "value": "Path to the TLS private key file."
          }
        }
      ]
    },
    {
      "label": "encode [matcher] gzip [zstd] { ... }",
      "documentation": {
        "value": "Encodes responses using the specified algorithm(s).\n```caddy\nencode gzip zstd\nencode gzip {\n  minimum_length 256\n}\n```"
      },
      "parameters": [
        {
          "label": "matcher",
          "documentation": {
            "value": "Optional request matcher."
          }
        },
        {
          "label": "gzip",
          "documentation": {
            "value": "Enable gzip compression."
          }
        },
        {
          "label": "zstd",
          "documentation": {
            "value": "Enable Zstandard compression."
          }
        }
      ]
    },
    {
      "label": "header [matcher] [field] [value] { ... }",
      "documentation": {
        "value": "Manipulates HTTP response headers.\n```caddy\nheader X-Frame-Options DENY\nheader -Server\nheader /api/* Cache-Control \"no-store\"\n```"
      },
      "parameters": [
        {
          "label": "matcher",
          "documentation": {
            "value": "Optional request matcher."
          }
        },
        {
          "label": "field",
          "documentation": {
            "value": "Header field name. Prefix with `-` to delete, `+` to add, `?` to set only if missing."
          }
        },
        {
          "label": "value",
          "documentation": {
            "value": "Header value to set."
          }
        }
      ]
    },
    {
      "label": "rewrite [matcher] <to>",
      "documentation": {
        "value": "Rewrites the URI internally (no redirect).\n```caddy\nrewrite /old /new\nrewrite /app/* /index.html\n```"
      },
      "parameters": [
        {
          "label": "matcher",
          "documentation": {
            "value": "Optional request matcher."
          }
        },
        {
          "label": "to",
          "documentation": {
            "value": "The new URI to rewrite to. Supports placeholders like `{uri}`, `{path}`."
          }
        }
      ]
    },
    {
      "label": "respond [matcher] <status|body> [status_code] { ... }",
      "documentation": {
        "value": "Returns a static response to the client.\n```caddy\nrespond \"Hello, World!\" 200\nrespond /health 200\nrespond 404\n```"
      },
      "parameters": [
        {
          "label": "matcher",
          "documentation": {
            "value": "Optional request matcher."
          }
        },
        {
          "label": "body",
          "documentation": {
            "value": "Response body string."
          }
        },
        {
          "label": "status_code",
          "documentation": {
            "value": "HTTP status code (e.g. `200`, `404`, `503`)."
          }
        }
      ]
    },
    {
      "label": "redir [matcher] <to> [code]",
      "documentation": {
        "value": "Issues an HTTP redirect.\n```caddy\nredir /old /new 301\nredir /blog https://blog.example.com permanent\n```"
      },
      "parameters": [
        {
          "label": "matcher",
          "documentation": {
            "value": "Optional request matcher."
          }
        },
        {
          "label": "to",
          "documentation": {
            "value": "The URL to redirect to."
          }
        },
        {
          "label": "code",
          "documentation": {
            "value": "HTTP redirect code: `301`, `302` (default), `307`, `308`, or `permanent`, `temporary`."
          }
        }
      ]
    },
    {
      "label": "basicauth [matcher] <realm> { <username> <hashed_password> }",
      "documentation": {
        "value": "Enables HTTP Basic Authentication.\n```caddy\nbasicauth /admin/* {\n  admin JDJhJDEwJC5...\n}\n```"
      },
      "parameters": [
        {
          "label": "matcher",
          "documentation": {
            "value": "Optional request matcher."
          }
        },
        {
          "label": "realm",
          "documentation": {
            "value": "Optional authentication realm name."
          }
        },
        {
          "label": "username",
          "documentation": {
            "value": "The username."
          }
        },
        {
          "label": "hashed_password",
          "documentation": {
            "value": "The bcrypt-hashed password."
          }
        }
      ]
    },
    {
      "label": "log { output <destination>, format <format>, level <level> }",
      "documentation": {
        "value": "Enables and configures HTTP access logging.\n```caddy\nlog {\n  output file /var/log/caddy/access.log\n  format json\n  level INFO\n}\n```"
      },
      "parameters": [
        {
          "label": "output",
          "documentation": {
            "value": "Log destination: `stdout`, `stderr`, `discard`, or `file /path/to/log`."
          }
        },
        {
          "label": "format",
          "documentation": {
            "value": "Log format: `console`, `json`, or `filter`."
          }
        },
        {
          "label": "level",
          "documentation": {
            "value": "Minimum log level: `DEBUG`, `INFO`, `WARN`, `ERROR`."
          }
        }
      ]
    },
