{
  "language": "systemd",
  "triggerCharacters": [
    "=",
    " "
  ],
  "retriggerCharacters": [
    "="
  ],
  "signatures": [
    {
      "label": "[Unit] - Unit section header",
      "documentation": {
        "value": "Defines generic information about the unit that is not dependent on the type of unit. Contains metadata and dependency configuration."
      },
      "parameters": []
    },
    {
      "label": "[Service] - Service section header",
      "documentation": {
        "value": "Contains information about the service and the process it supervises. Only applicable for service unit files."
      },
      "parameters": []
    },
    {
      "label": "[Install] - Install section header",
      "documentation": {
        "value": "Contains installation information for the unit. Used by `systemctl enable` and `systemctl disable`."
      },
      "parameters": []
    },
    {
      "label": "ExecStart=command [arguments]",
      "documentation": {
        "value": "Commands with arguments that are executed when this service is started. Must be an absolute path."
      },
      "parameters": [
        {
          "label": "command",
          "documentation": {
            "value": "The absolute path to the executable to run"
          }
        },
        {
          "label": "arguments",
          "documentation": {
            "value": "Optional command-line arguments"
          }
        }
      ]
    },
    {
      "label": "ExecStop=command [arguments]",
      "documentation": {
        "value": "Commands to execute to stop the service started via ExecStart=."
      },
      "parameters": [
        {
          "label": "command",
          "documentation": {
            "value": "The absolute path to the executable for stopping the service"
          }
        },
        {
          "label": "arguments",
          "documentation": {
            "value": "Optional command-line arguments"
          }
        }
      ]
    },
    {
      "label": "Type=simple|exec|forking|oneshot|dbus|notify|idle",
      "documentation": {
        "value": "Configures the process start-up type for this service unit."
      },
      "parameters": [
        {
          "label": "simple|exec|forking|oneshot|dbus|notify|idle",
          "documentation": {
            "value": "`simple` (default): process is the main service. `forking`: the process forks and the parent exits. `oneshot`: the process exits after doing its work. `notify`: the service sends a notification when ready."
          }
        }
      ]
    },
    {
      "label": "Restart=no|on-success|on-failure|on-abnormal|on-watchdog|on-abort|always",
      "documentation": {
        "value": "Configures whether the service shall be restarted when the service process exits, is killed, or a timeout is reached."
      },
      "parameters": [
        {
          "label": "no|on-success|on-failure|on-abnormal|on-watchdog|on-abort|always",
          "documentation": {
            "value": "`no` (default): service will not be restarted. `on-failure`: restart on non-zero exit code, signal, or timeout. `always`: always restart regardless of exit reason."
          }
        }
      ]
    },
    {
      "label": "WantedBy=target [target ...]",
      "documentation": {
        "value": "Creates a symbolic link in the `.wants/` directory of the listed targets when `systemctl enable` is used."
      },
      "parameters": [
        {
          "label": "target",
          "documentation": {
            "value": "The target unit(s), e.g. `multi-user.target`, `graphical.target`"
          }
        }
      ]
    },
    {
      "label": "After=unit [unit ...]",
      "documentation": {
        "value": "Configures ordering dependencies. This unit will be started after the listed units have been started."
      },
      "parameters": [
        {
          "label": "unit",
          "documentation": {
            "value": "One or more unit names to order after, e.g. `network.target`, `syslog.service`"
          }
        }
      ]
    },
    {
      "label": "Before=unit [unit ...]",
      "documentation": {
        "value": "The inverse of After=. This unit will be started before the listed units."
      },
      "parameters": [
        {
          "label": "unit",
          "documentation": {
            "value": "One or more unit names to order before"
          }
        }
      ]
    },
    {
      "label": "Environment=KEY=value [KEY=value ...]",
      "documentation": {
        "value": "Sets environment variables for executed processes."
      },
      "parameters": [
        {
          "label": "KEY=value",
          "documentation": {
            "value": "Space-separated list of variable assignments, e.g. `FOO=bar BAZ=qux`"
          }
        }
      ]
    },
