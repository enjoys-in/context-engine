{
  "language": "docker-compose",
  "codeLensPatterns": [
    {
      "pattern": "^\\s*(\\w[\\w-]*):",
      "captureGroup": 1,
      "commandId": "editor.action.referenceSearch.trigger",
      "title": "Find References",
      "description": "Show all references to this service"
    },
    {
      "pattern": "^\\s*image:\\s*(\\S+)",
      "captureGroup": 1,
      "commandId": "editor.action.peekDefinition",
      "title": "Peek Image",
      "description": "Peek at image definition"
    },
    {
      "pattern": "^\\s*depends_on:",
      "captureGroup": 0,
      "commandId": "editor.action.referenceSearch.trigger",
      "title": "Show Dependencies",
      "description": "Show service dependencies"
    }
  ]
}