{
  "language": "restructuredtext",
  "codeLensPatterns": [
    {
      "pattern": "^(.+)\\n[=\\-~^]+$",
      "captureGroup": 1,
      "title": "string",
      "command": "editor.action.referenceSearch"
    },
    {
      "pattern": "^\\.\\. (\\w+)::",
      "captureGroup": 1,
      "title": "function",
      "command": "editor.action.referenceSearch"
    }
  ]
}