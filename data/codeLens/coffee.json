{
  "language": "coffee",
  "codeLensPatterns": [
    {
      "pattern": "^\\s*class\\s+(\\w+)",
      "captureGroup": 1,
      "title": "class",
      "command": "editor.action.referenceSearch"
    },
    {
      "pattern": "^\\s*(\\w+)\\s*[:=]\\s*(?:\\(.*\\))?\\s*[-=]>",
      "captureGroup": 1,
      "title": "function",
      "command": "editor.action.referenceSearch"
    }
  ]
}