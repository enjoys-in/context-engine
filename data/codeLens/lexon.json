{
  "language": "lexon",
  "codeLensPatterns": [
    {
      "pattern": "^LEX\\s+(\\w+)",
      "captureGroup": 1,
      "title": "class",
      "command": "editor.action.referenceSearch"
    },
    {
      "pattern": "^CLAUSE:\\s+(.+)\\.",
      "captureGroup": 1,
      "title": "function",
      "command": "editor.action.referenceSearch"
    }
  ]
}