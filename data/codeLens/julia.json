{
  "language": "julia",
  "codeLensPatterns": [
    {
      "pattern": "^\\s*function\\s+(\\w+)",
      "captureGroup": 1,
      "title": "function",
      "command": "editor.action.referenceSearch"
    },
    {
      "pattern": "^\\s*(?:mutable\\s+)?struct\\s+(\\w+)",
      "captureGroup": 1,
      "title": "struct",
      "command": "editor.action.referenceSearch"
    }
  ]
}