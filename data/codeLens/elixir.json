{
  "language": "elixir",
  "codeLensPatterns": [
    {
      "pattern": "^\\s*defmodule\\s+(\\S+)",
      "captureGroup": 1,
      "title": "module",
      "command": "editor.action.referenceSearch"
    },
    {
      "pattern": "^\\s*def[p]?\\s+(\\w+)",
      "captureGroup": 1,
      "title": "function",
      "command": "editor.action.referenceSearch"
    }
  ]
}