{
  "language": "wgsl",
  "codeLensPatterns": [
    {
      "pattern": "^\\s*(?:@\\w+\\s+)*fn\\s+(\\w+)",
      "captureGroup": 1,
      "title": "function",
      "command": "editor.action.referenceSearch"
    },
    {
      "pattern": "^\\s*struct\\s+(\\w+)",
      "captureGroup": 1,
      "title": "struct",
      "command": "editor.action.referenceSearch"
    }
  ]
}