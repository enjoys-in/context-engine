{
  "language": "pgsql",
  "codeLensPatterns": [
    {
      "pattern": "CREATE\\s+TABLE\\s+(?:IF\\s+NOT\\s+EXISTS\\s+)?(\\w+)",
      "captureGroup": 1,
      "title": "class",
      "command": "editor.action.referenceSearch"
    },
    {
      "pattern": "CREATE\\s+(?:OR\\s+REPLACE\\s+)?FUNCTION\\s+(\\w+)",
      "captureGroup": 1,
      "title": "function",
      "command": "editor.action.referenceSearch"
    }
  ]
}