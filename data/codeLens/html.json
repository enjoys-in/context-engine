{
  "language": "html",
  "codeLensPatterns": [
    {
      "pattern": "class=\"([^\"]+)\"",
      "captureGroup": 1,
      "commandId": "editor.action.goToImplementation",
      "title": "Find Implementations",
      "description": "Show all implementations of this class"
    },
    {
      "pattern": "<(\\w+)[^>]*id=\"([^\"]+)\"",
      "title": "references",
      "description": "Show references to element ID",
      "commandId": "editor.action.showReferences"
    },
    {
      "pattern": "<(\\w+)[^>]*class=\"([^\"]+)\"",
      "title": "references",
      "description": "Show references to CSS class",
      "commandId": "editor.action.showReferences"
    },
    {
      "pattern": "(?:function|def|fn|func|sub|proc)\\s+(\\w+)",
      "captureGroup": 1,
      "commandId": "editor.action.referenceSearch.trigger",
      "title": "Find References",
      "description": "Show all references to this symbol"
    },
    {
      "pattern": "(?:test|spec|it|describe)\\s*[(\\/]",
      "captureGroup": 0,
      "commandId": "testing.runAtCursor",
      "title": "Run Test",
      "description": "Run this test"
    }
  ]
}
