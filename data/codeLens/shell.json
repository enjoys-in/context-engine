{
  "language": "shell",
  "codeLensPatterns": [
    {
      "pattern": "^\\s*(?:function\\s+)?(\\w+)\\s*\\(\\)",
      "captureGroup": 1,
      "title": "function",
      "command": "editor.action.referenceSearch"
    },
    {
      "pattern": "^\\s*(\\w+)=",
      "captureGroup": 1,
      "title": "variable",
      "command": "editor.action.referenceSearch"
    }
  ]
}