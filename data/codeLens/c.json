{
  "language": "c",
  "codeLensPatterns": [
    {
      "pattern": "^\\\\s*(?:\\\\w+\\\\s+)+\\\\*?(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "commandId": "editor.action.referenceSearch.trigger",
      "title": "Find References",
      "description": "Show all references to this function"
    },
    {
      "pattern": "^\\w+\\s+\\*?(\\w+)\\s*\\(",
      "title": "references",
      "description": "Show references to C function",
      "commandId": "editor.action.showReferences"
    },
    {
      "pattern": "^struct\\s+(\\w+)",
      "title": "references",
      "description": "Show references to struct",
      "commandId": "editor.action.showReferences"
    },
    {
      "pattern": "(?:class|struct|interface|trait|type)\\s+(\\w+)",
      "captureGroup": 1,
      "commandId": "editor.action.goToImplementation",
      "title": "Find Implementations",
      "description": "Show all implementations"
    },
    {
      "pattern": "(?:test|spec|it|describe)\\s*[(\\/]",
      "captureGroup": 0,
      "commandId": "testing.runAtCursor",
      "title": "Run Test",
      "description": "Run this test"
    }
  ]
}
