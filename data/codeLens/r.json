{
  "language": "r",
  "codeLensPatterns": [
    {
      "pattern": "^\\\\s*(\\\\w[\\\\w.]*)\\\\s*<-\\\\s*function\\\\s*\\\\(",
      "captureGroup": 1,
      "commandId": "editor.action.referenceSearch.trigger",
      "title": "Find References",
      "description": "Show all references to this function"
    },
    {
      "pattern": "^\\\\s*setClass\\\\s*\\\\(\\\\s*[\"'](\\\\w+)[\"']",
      "captureGroup": 1,
      "commandId": "editor.action.referenceSearch.trigger",
      "title": "Find References",
      "description": "Show all references to this S4 class"
    },
    {
      "pattern": "^\\\\s*(\\\\w+)\\\\s*<-\\\\s*R6Class\\\\s*\\\\(",
      "captureGroup": 1,
      "commandId": "editor.action.referenceSearch.trigger",
      "title": "Find References",
      "description": "Show all references to this R6 class"
    },
    {
      "pattern": "^\\\\s*test_that\\\\s*\\\\(",
      "captureGroup": 0,
      "commandId": "testing.runAtCursor",
      "title": "Run Test",
      "description": "Run this testthat test case"
    },
    {
      "pattern": "(?:class|struct|interface|trait|type)\\s+(\\w+)",
      "captureGroup": 1,
      "commandId": "editor.action.goToImplementation",
      "title": "Find Implementations",
      "description": "Show all implementations"
    }
  ]
}
