{
  "language": "ssh_config",
  "codeLensPatterns": [
    {
      "pattern": "^Host\\s+(\\S+)",
      "captureGroup": 1,
      "commandId": "editor.action.referenceSearch.trigger",
      "title": "Find References",
      "description": "Show all references to this host"
    },
    {
      "pattern": "^\\s*IdentityFile\\s+(\\S+)",
      "captureGroup": 1,
      "commandId": "editor.action.peekDefinition",
      "title": "Peek File",
      "description": "Peek at identity file location"
    },
    {
      "pattern": "^\\s*Include\\s+(\\S+)",
      "captureGroup": 1,
      "commandId": "editor.action.peekDefinition",
      "title": "Peek Include",
      "description": "Peek at included config file"
    },
    {
      "pattern": "(?:class|struct|interface|trait|type)\\s+(\\w+)",
      "captureGroup": 1,
      "commandId": "editor.action.goToImplementation",
      "title": "Find Implementations",
      "description": "Show all implementations"
    },
    {
      "pattern": "(?:test|spec|it|describe)\\s*[(\\/]",
      "captureGroup": 0,
      "commandId": "testing.runAtCursor",
      "title": "Run Test",
      "description": "Run this test"
    }
  ]
}
