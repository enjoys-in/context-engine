{
  "language": "mdx",
  "codeLensPatterns": [
    {
      "pattern": "^import\\s+.*from\\s+'([^']+)'",
      "captureGroup": 1,
      "title": "module",
      "command": "editor.action.referenceSearch"
    },
    {
      "pattern": "^export\\s+(?:default\\s+)?(?:function|const|class)\\s+(\\w+)",
      "captureGroup": 1,
      "title": "variable",
      "command": "editor.action.referenceSearch"
    }
  ]
}