{
  "language": "clojure",
  "codeLensPatterns": [
    {
      "pattern": "^\\s*\\(defn-?\\s+(\\S+)",
      "captureGroup": 1,
      "title": "function",
      "command": "editor.action.referenceSearch"
    },
    {
      "pattern": "^\\s*\\(def\\s+(\\S+)",
      "captureGroup": 1,
      "title": "variable",
      "command": "editor.action.referenceSearch"
    }
  ]
}