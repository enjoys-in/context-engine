{
  "language": "vb",
  "codeLensPatterns": [
    {
      "pattern": "^\\s*(?:Public|Private|Friend)?\\s*(?:Partial\\s+)?Class\\s+(\\w+)",
      "captureGroup": 1,
      "title": "class",
      "command": "editor.action.referenceSearch"
    },
    {
      "pattern": "^\\s*Module\\s+(\\w+)",
      "captureGroup": 1,
      "title": "module",
      "command": "editor.action.referenceSearch"
    }
  ]
}