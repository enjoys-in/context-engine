{
  "language": "csharp",
  "codeLensPatterns": [
    {
      "pattern": "^\\\\s*(?:public|private|protected|internal|static|abstract|sealed|partial)?\\\\s*class\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "commandId": "editor.action.goToImplementation",
      "title": "Find Implementations",
      "description": "Show all implementations of this class"
    },
    {
      "pattern": "^\\\\s*(?:public|private|protected|internal)?\\\\s*interface\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "commandId": "editor.action.goToImplementation",
      "title": "Find Implementations",
      "description": "Show all implementations of this interface"
    },
    {
      "pattern": "^\\\\s*(?:public|private|protected|internal|static|virtual|override|abstract|async)?\\\\s*[\\\\w<>\\\\[\\\\],?]+\\\\s+(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "commandId": "editor.action.referenceSearch.trigger",
      "title": "Find References",
      "description": "Show all references to this method"
    },
    {
      "pattern": "^\\\\s*\\\\[(?:Test|Fact|Theory|TestMethod)\\\\]",
      "captureGroup": 0,
      "commandId": "testing.runAtCursor",
      "title": "Run Test",
      "description": "Run this test case"
    },
    {
      "pattern": "(?:export|public)\\s+(?:class|function|interface|type)\\s+(\\w+)",
      "captureGroup": 1,
      "commandId": "editor.action.peekDefinition",
      "title": "Peek Definition",
      "description": "Preview definition inline"
    }
  ]
}
