{
  "language": "cypher",
  "codeLensPatterns": [
    {
      "pattern": "^\\s*CREATE\\s+\\(\\s*(\\w+)",
      "captureGroup": 1,
      "commandId": "editor.action.referenceSearch.trigger",
      "title": "Find References",
      "description": "Show all references to this node"
    },
    {
      "pattern": "^\\s*MATCH\\s+\\(\\s*(\\w+)",
      "captureGroup": 1,
      "commandId": "editor.action.referenceSearch.trigger",
      "title": "Find References",
      "description": "Show all references to this variable"
    },
    {
      "pattern": "^\\s*//.*TODO",
      "captureGroup": 0,
      "commandId": "editor.action.marker.next",
      "title": "TODO",
      "description": "Navigate to next TODO comment"
    }
  ]
}