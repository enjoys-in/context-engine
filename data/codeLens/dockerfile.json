{
  "language": "dockerfile",
  "codeLensPatterns": [
    {
      "pattern": "^FROM\\s+(\\S+)",
      "captureGroup": 1,
      "commandId": "editor.action.peekDefinition",
      "title": "Peek Base Image",
      "description": "Peek at the base image definition"
    },
    {
      "pattern": "^(RUN|COPY|ADD|CMD|ENTRYPOINT|EXPOSE|ENV|ARG|WORKDIR|VOLUME|USER|LABEL|HEALTHCHECK|SHELL|STOPSIGNAL|ONBUILD)\\b",
      "captureGroup": 1,
      "commandId": "editor.action.referenceSearch.trigger",
      "title": "Find References",
      "description": "Show all references to this instruction"
    },
    {
      "pattern": "^#.*TODO",
      "captureGroup": 0,
      "commandId": "editor.action.marker.next",
      "title": "TODO",
      "description": "Navigate to next TODO comment"
    }
  ]
}