{
  "language": "ruby",
  "codeLensPatterns": [
    {
      "pattern": "^\\\\s*def\\\\s+(\\\\w+[!?=]?)",
      "captureGroup": 1,
      "commandId": "editor.action.referenceSearch.trigger",
      "title": "Find References",
      "description": "Show all references to this method"
    },
    {
      "pattern": "^\\\\s*class\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "commandId": "editor.action.goToImplementation",
      "title": "Find Implementations",
      "description": "Show all implementations of this class"
    },
    {
      "pattern": "^\\\\s*(?:def\\\\s+test_|it\\\\s+['\"]|describe\\\\s+|context\\\\s+)",
      "captureGroup": 0,
      "commandId": "testing.runAtCursor",
      "title": "Run Test",
      "description": "Run this test case"
    }
  ]
}
