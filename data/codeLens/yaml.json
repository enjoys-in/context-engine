{
  "language": "yaml",
  "codeLensPatterns": [
    {
      "pattern": "^\\s*(\\w[\\w-]*):",
      "captureGroup": 1,
      "commandId": "editor.action.referenceSearch.trigger",
      "title": "Find References",
      "description": "Show all references to this key"
    },
    {
      "pattern": "\\*([\\w-]+)",
      "captureGroup": 1,
      "commandId": "editor.action.peekDefinition",
      "title": "Peek Anchor",
      "description": "Peek at YAML anchor definition"
    },
    {
      "pattern": "^#.*TODO",
      "captureGroup": 0,
      "commandId": "editor.action.marker.next",
      "title": "TODO",
      "description": "Navigate to next TODO comment"
    },
    {
      "pattern": "(?:class|struct|interface|trait|type)\\s+(\\w+)",
      "captureGroup": 1,
      "commandId": "editor.action.goToImplementation",
      "title": "Find Implementations",
      "description": "Show all implementations"
    },
    {
      "pattern": "(?:test|spec|it|describe)\\s*[(\\/]",
      "captureGroup": 0,
      "commandId": "testing.runAtCursor",
      "title": "Run Test",
      "description": "Run this test"
    }
  ]
}
