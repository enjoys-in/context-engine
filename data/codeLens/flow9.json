{
  "language": "flow9",
  "codeLensPatterns": [
    {
      "pattern": "^\\s*(\\w+)\\s*\\(.*\\)\\s*->",
      "captureGroup": 1,
      "title": "function",
      "command": "editor.action.referenceSearch"
    },
    {
      "pattern": "^\\s*import\\s+(\\S+)",
      "captureGroup": 1,
      "title": "module",
      "command": "editor.action.referenceSearch"
    }
  ]
}