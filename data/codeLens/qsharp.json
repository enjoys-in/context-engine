{
  "language": "qsharp",
  "codeLensPatterns": [
    {
      "pattern": "^\\s*namespace\\s+(\\S+)",
      "captureGroup": 1,
      "title": "namespace",
      "command": "editor.action.referenceSearch"
    },
    {
      "pattern": "^\\s*operation\\s+(\\w+)",
      "captureGroup": 1,
      "title": "function",
      "command": "editor.action.referenceSearch"
    }
  ]
}