{
  "language": "sb",
  "codeLensPatterns": [
    {
      "pattern": "^\\s*Sub\\s+(\\w+)",
      "captureGroup": 1,
      "title": "function",
      "command": "editor.action.referenceSearch"
    },
    {
      "pattern": "^(\\w+):",
      "captureGroup": 1,
      "title": "constant",
      "command": "editor.action.referenceSearch"
    }
  ]
}