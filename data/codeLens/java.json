{
  "language": "java",
  "codeLensPatterns": [
    {
      "pattern": "^\\\\s*(?:public|private|protected|abstract|final|static|sealed)?\\\\s*class\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "commandId": "editor.action.goToImplementation",
      "title": "Find Implementations",
      "description": "Show all implementations of this class"
    },
    {
      "pattern": "^\\\\s*(?:public|private|protected)?\\\\s*interface\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "commandId": "editor.action.goToImplementation",
      "title": "Find Implementations",
      "description": "Show all implementations of this interface"
    },
    {
      "pattern": "^\\\\s*(?:public|private|protected|static|final|abstract|synchronized|native)?\\\\s*(?:[\\\\w<>\\\\[\\\\],?]+\\\\s+)(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "commandId": "editor.action.referenceSearch.trigger",
      "title": "Find References",
      "description": "Show all references to this method"
    },
    {
      "pattern": "^\\\\s*@(?:Test|ParameterizedTest|RepeatedTest)\\\\b",
      "captureGroup": 0,
      "commandId": "testing.runAtCursor",
      "title": "Run Test",
      "description": "Run this test case"
    }
  ]
}
