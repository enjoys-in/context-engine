{
  "language": "mips",
  "codeLensPatterns": [
    {
      "pattern": "^(\\w+):",
      "captureGroup": 1,
      "title": "constant",
      "command": "editor.action.referenceSearch"
    },
    {
      "pattern": "^\\s*(\\.\\w+)",
      "captureGroup": 1,
      "title": "string",
      "command": "editor.action.referenceSearch"
    }
  ]
}