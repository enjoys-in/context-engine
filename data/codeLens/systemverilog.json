{
  "language": "systemverilog",
  "codeLensPatterns": [
    {
      "pattern": "^\\s*module\\s+(\\w+)",
      "captureGroup": 1,
      "title": "module",
      "command": "editor.action.referenceSearch"
    },
    {
      "pattern": "^\\s*interface\\s+(\\w+)",
      "captureGroup": 1,
      "title": "interface",
      "command": "editor.action.referenceSearch"
    }
  ]
}