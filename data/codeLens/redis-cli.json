{
  "language": "redis-cli",
  "codeLensPatterns": [
    {
      "pattern": "^\\s*(GET|SET|DEL|HGET|HSET|LPUSH|RPUSH|SADD|ZADD|SUBSCRIBE|PUBLISH)\\s+(\\S+)",
      "captureGroup": 2,
      "commandId": "editor.action.referenceSearch.trigger",
      "title": "Find References",
      "description": "Show all references to this key"
    },
    {
      "pattern": "^\\s*#.*TODO",
      "captureGroup": 0,
      "commandId": "editor.action.marker.next",
      "title": "TODO",
      "description": "Navigate to next TODO"
    },
    {
      "pattern": "^\\s*(MULTI|EXEC|DISCARD)",
      "captureGroup": 0,
      "commandId": "editor.action.referenceSearch.trigger",
      "title": "Transaction",
      "description": "Show transaction boundaries"
    }
  ]
}