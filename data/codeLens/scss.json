{
  "language": "scss",
  "codeLensPatterns": [
    {
      "pattern": "^\\s*(\\$[\\w-]+)\\s*:",
      "captureGroup": 1,
      "title": "variable",
      "command": "editor.action.referenceSearch"
    },
    {
      "pattern": "^\\s*@mixin\\s+([\\w-]+)",
      "captureGroup": 1,
      "title": "function",
      "command": "editor.action.referenceSearch"
    }
  ]
}