{
  "language": "scheme",
  "codeLensPatterns": [
    {
      "pattern": "^\\s*\\(define\\s+\\(?(\\S+)",
      "captureGroup": 1,
      "title": "function",
      "command": "editor.action.referenceSearch"
    },
    {
      "pattern": "^\\s*\\(define\\s+(\\S+)\\s+(?!\\()",
      "captureGroup": 1,
      "title": "variable",
      "command": "editor.action.referenceSearch"
    }
  ]
}