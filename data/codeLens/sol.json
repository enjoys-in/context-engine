{
  "language": "sol",
  "codeLensPatterns": [
    {
      "pattern": "^\\s*(?:abstract\\s+)?contract\\s+(\\w+)",
      "captureGroup": 1,
      "title": "class",
      "command": "editor.action.referenceSearch"
    },
    {
      "pattern": "^\\s*interface\\s+(\\w+)",
      "captureGroup": 1,
      "title": "interface",
      "command": "editor.action.referenceSearch"
    }
  ]
}