{
  "language": "tcl",
  "codeLensPatterns": [
    {
      "pattern": "^\\s*proc\\s+(\\S+)",
      "captureGroup": 1,
      "title": "function",
      "command": "editor.action.referenceSearch"
    },
    {
      "pattern": "^\\s*namespace\\s+eval\\s+(\\S+)",
      "captureGroup": 1,
      "title": "namespace",
      "command": "editor.action.referenceSearch"
    }
  ]
}