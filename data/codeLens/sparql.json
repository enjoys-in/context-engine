{
  "language": "sparql",
  "codeLensPatterns": [
    {
      "pattern": "^PREFIX\\s+(\\w+):",
      "captureGroup": 1,
      "title": "module",
      "command": "editor.action.referenceSearch"
    },
    {
      "pattern": "\\?(\\w+)",
      "captureGroup": 1,
      "title": "variable",
      "command": "editor.action.referenceSearch"
    }
  ]
}