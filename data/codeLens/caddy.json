{
  "language": "caddy",
  "codeLensPatterns": [
    {
      "pattern": "^\\\\s*\\\\(([^)]+)\\\\)",
      "captureGroup": 1,
      "commandId": "editor.action.referenceSearch.trigger",
      "title": "Find References",
      "description": "Show all references to this function"
    },
    {
      "pattern": "^(\\w[\\w.]+)\\s*\\{",
      "command": "editor.action.showReferences",
      "title": "references",
      "description": "Show references to site block"
    },
    {
      "pattern": "(?:class|struct|interface|trait|type)\\s+(\\w+)",
      "captureGroup": 1,
      "commandId": "editor.action.goToImplementation",
      "title": "Find Implementations",
      "description": "Show all implementations"
    },
    {
      "pattern": "(?:test|spec|it|describe)\\s*[(\\/]",
      "captureGroup": 0,
      "commandId": "testing.runAtCursor",
      "title": "Run Test",
      "description": "Run this test"
    },
    {
      "pattern": "(?:export|public)\\s+(?:class|function|interface|type)\\s+(\\w+)",
      "captureGroup": 1,
      "commandId": "editor.action.peekDefinition",
      "title": "Peek Definition",
      "description": "Preview definition inline"
    }
  ]
}
