{
  "language": "st",
  "codeLensPatterns": [
    {
      "pattern": "^\\s*PROGRAM\\s+(\\w+)",
      "captureGroup": 1,
      "title": "module",
      "command": "editor.action.referenceSearch"
    },
    {
      "pattern": "^\\s*FUNCTION_BLOCK\\s+(\\w+)",
      "captureGroup": 1,
      "title": "class",
      "command": "editor.action.referenceSearch"
    }
  ]
}