{
  "language": "json",
  "codeLensPatterns": [
    {
      "pattern": "\"(\\w+)\"\\s*:",
      "captureGroup": 1,
      "commandId": "editor.action.referenceSearch.trigger",
      "title": "Find References",
      "description": "Show all references to this key"
    },
    {
      "pattern": "\"\\$ref\"\\s*:\\s*\"([^\"]+)\"",
      "captureGroup": 1,
      "commandId": "editor.action.peekDefinition",
      "title": "Peek Reference",
      "description": "Peek at JSON Schema reference"
    },
    {
      "pattern": "\"\\$schema\"\\s*:\\s*\"([^\"]+)\"",
      "captureGroup": 1,
      "commandId": "editor.action.peekDefinition",
      "title": "Peek Schema",
      "description": "Peek at the JSON Schema"
    }
  ]
}