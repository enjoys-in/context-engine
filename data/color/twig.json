{
  "language": "twig",
  "colorPatterns": [
    {
      "pattern": "#([0-9a-fA-F]{6})\\b",
      "format": "hex6",
      "description": "6-digit hex color (#RRGGBB)"
    },
    {
      "pattern": "#([0-9a-fA-F]{8})\\b",
      "format": "hex8",
      "description": "8-digit hex color with alpha (#RRGGBBAA)"
    },
    {
      "pattern": "#([0-9a-fA-F]{3})\\b",
      "format": "hex3",
      "description": "3-digit shorthand hex color (#RGB)"
    },
    {
      "pattern": "rgb\\((\\d+),\\s*(\\d+),\\s*(\\d+)\\)",
      "format": "rgb",
      "description": "RGB color function"
    },
    {
      "pattern": "rgba\\((\\d+),\\s*(\\d+),\\s*(\\d+),\\s*([\\d.]+)\\)",
      "format": "rgba",
      "description": "RGBA color function with alpha"
    },
    {
      "pattern": "hsl\\((\\d+),\\s*(\\d+)%,\\s*(\\d+)%\\)",
      "format": "hsl",
      "description": "HSL color function"
    },
    {
      "pattern": "hsla\\((\\d+),\\s*(\\d+)%,\\s*(\\d+)%,\\s*([\\d.]+)\\)",
      "format": "hsla",
      "description": "HSLA color function with alpha"
    }
  ],
