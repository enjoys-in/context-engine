{
  "language": "react",
  "colorPatterns": [
    {
      "pattern": "(?:color|backgroundColor|borderColor|outlineColor|textDecorationColor|fill|stroke)\\s*:\\s*['\"]?(#[0-9a-fA-F]{3,8})['\"]?",
      "captureGroup": 1,
      "description": "Hex color in JSX style props"
    },
    {
      "pattern": "(?:color|backgroundColor|borderColor|outlineColor|fill|stroke)\\s*:\\s*['\"]?(rgb\\(\\s*\\d{1,3}\\s*,\\s*\\d{1,3}\\s*,\\s*\\d{1,3}\\s*\\))['\"]?",
      "captureGroup": 1,
      "description": "RGB color in JSX style props"
    },
    {
      "pattern": "(?:color|backgroundColor|borderColor|outlineColor|fill|stroke)\\s*:\\s*['\"]?(rgba\\(\\s*\\d{1,3}\\s*,\\s*\\d{1,3}\\s*,\\s*\\d{1,3}\\s*,\\s*[0-9.]+\\s*\\))['\"]?",
      "captureGroup": 1,
      "description": "RGBA color in JSX style props"
    },
    {
      "pattern": "(?:color|backgroundColor|borderColor|outlineColor|fill|stroke)\\s*:\\s*['\"]?(hsl\\(\\s*\\d{1,3}\\s*,\\s*\\d{1,3}%\\s*,\\s*\\d{1,3}%\\s*\\))['\"]?",
      "captureGroup": 1,
      "description": "HSL color in JSX style props"
    },
    {
      "pattern": "(?:color|backgroundColor|borderColor|outlineColor|fill|stroke)\\s*:\\s*['\"]?(hsla\\(\\s*\\d{1,3}\\s*,\\s*\\d{1,3}%\\s*,\\s*\\d{1,3}%\\s*,\\s*[0-9.]+\\s*\\))['\"]?",
      "captureGroup": 1,
      "description": "HSLA color in JSX style props"
    },
    {
      "pattern": "styled\\.[a-z]+`[^`]*(?:color|background|border-color|fill|stroke)\\s*:\\s*(#[0-9a-fA-F]{3,8})",
      "captureGroup": 1,
      "description": "Hex color in styled-components template literal"
    },
    {
      "pattern": "styled\\.[a-z]+`[^`]*(?:color|background|border-color|fill|stroke)\\s*:\\s*(rgb(?:a)?\\([^)]+\\))",
      "captureGroup": 1,
      "description": "RGB/RGBA color in styled-components"
    },
    {
      "pattern": "css`[^`]*(?:color|background|border-color|fill|stroke)\\s*:\\s*(#[0-9a-fA-F]{3,8})",
      "captureGroup": 1,
      "description": "Hex color in CSS-in-JS css tagged template"
    },
    {
      "pattern": "css`[^`]*(?:color|background|border-color|fill|stroke)\\s*:\\s*(rgb(?:a)?\\([^)]+\\))",
      "captureGroup": 1,
      "description": "RGB/RGBA color in CSS-in-JS css tagged template"
    },
    {
      "pattern": "(?:theme|colors|palette)\\.[a-zA-Z.]+\\s*[=:]\\s*['\"]?(#[0-9a-fA-F]{3,8})['\"]?",
      "captureGroup": 1,
      "description": "Hex color in theme/palette configuration"
    }
  ],
  "colorPresentations": [
    {
      "format": "hex",
      "pattern": "#[0-9a-fA-F]{6}",
      "description": "6-digit hex color"
    },
    {
      "format": "hex_short",
      "pattern": "#[0-9a-fA-F]{3}",
      "description": "3-digit shorthand hex color"
    },
    {
      "format": "hex_alpha",
      "pattern": "#[0-9a-fA-F]{8}",
      "description": "8-digit hex color with alpha"
    },
    {
      "format": "rgb",
      "pattern": "rgb\\(\\d{1,3},\\s*\\d{1,3},\\s*\\d{1,3}\\)",
      "description": "CSS RGB color"
    },
    {
      "format": "rgba",
      "pattern": "rgba\\(\\d{1,3},\\s*\\d{1,3},\\s*\\d{1,3},\\s*[0-9.]+\\)",
      "description": "CSS RGBA color with alpha"
    },
    {
      "format": "hsl",
      "pattern": "hsl\\(\\d{1,3},\\s*\\d{1,3}%,\\s*\\d{1,3}%\\)",
      "description": "CSS HSL color"
    },
    {
      "format": "hsla",
      "pattern": "hsla\\(\\d{1,3},\\s*\\d{1,3}%,\\s*\\d{1,3}%,\\s*[0-9.]+\\)",
      "description": "CSS HSLA color with alpha"
    }
  ],
  "namedColors": {}
}