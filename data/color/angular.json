{
  "language": "angular",
  "colorPatterns": [
    {
      "pattern": "#([0-9a-fA-F]{8})\\b",
      "captureGroup": 1,
      "format": "hex"
    },
    {
      "pattern": "#([0-9a-fA-F]{6})\\b",
      "captureGroup": 1,
      "format": "hex"
    },
    {
      "pattern": "#([0-9a-fA-F]{3})\\b",
      "captureGroup": 1,
      "format": "hex"
    },
    {
      "pattern": "rgba?\\(\\s*(\\d{1,3}\\s*,\\s*\\d{1,3}\\s*,\\s*\\d{1,3}(?:\\s*,\\s*[\\d.]+)?)\\s*\\)",
      "captureGroup": 1,
      "format": "rgb"
    },
    {
      "pattern": "hsla?\\(\\s*(\\d{1,3}\\s*,\\s*\\d{1,3}%\\s*,\\s*\\d{1,3}%(?:\\s*,\\s*[\\d.]+)?)\\s*\\)",
      "captureGroup": 1,
      "format": "hsl"
    },
    {
      "pattern": "oklch\\(\\s*([\\d.]+%?\\s+[\\d.]+\\s+[\\d.]+(?:\\s*/\\s*[\\d.]+%?)?)\\s*\\)",
      "captureGroup": 1,
      "format": "oklch"
    },
    {
      "pattern": "var\\(\\s*(--[\\w-]+)\\s*\\)",
      "captureGroup": 1,
      "format": "hex"
    },
    {
      "pattern": "color\\(\\s*(\\w+\\s+[\\d.]+\\s+[\\d.]+\\s+[\\d.]+(?:\\s*/\\s*[\\d.]+)?)\\s*\\)",
      "captureGroup": 1,
      "format": "rgb"
    }
  ],
  "colorPresentations": [
    {
      "label": "hex",
      "format": "#{r:02x}{g:02x}{b:02x}"
    },
    {
      "label": "rgb",
      "format": "rgb({r}, {g}, {b})"
    },
    {
      "label": "hsl",
      "format": "hsl({h}, {s}%, {l}%)"
    }
  ],
  "namedColors": {
    "red": "#ff0000",
    "blue": "#0000ff",
    "green": "#008000",
    "white": "#ffffff",
    "black": "#000000",
    "gray": "#808080"
  }
}
