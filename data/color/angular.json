{
  "language": "angular",
  "colorPatterns": [
    {
      "pattern": "#([0-9a-fA-F]{8})\\b",
      "captureGroup": 1,
      "format": "hex",
      "description": "hex color format"
    },
    {
      "pattern": "rgba?\\(\\s*(\\d{1,3}\\s*,\\s*\\d{1,3}\\s*,\\s*\\d{1,3}(?:\\s*,\\s*[\\d.]+)?)\\s*\\)",
      "captureGroup": 1,
      "format": "rgb",
      "description": "rgb color format"
    },
    {
      "pattern": "hsla?\\(\\s*(\\d{1,3}\\s*,\\s*\\d{1,3}%\\s*,\\s*\\d{1,3}%(?:\\s*,\\s*[\\d.]+)?)\\s*\\)",
      "captureGroup": 1,
      "format": "hsl",
      "description": "hsl color format"
    },
    {
      "pattern": "oklch\\(\\s*([\\d.]+%?\\s+[\\d.]+\\s+[\\d.]+(?:\\s*/\\s*[\\d.]+%?)?)\\s*\\)",
      "captureGroup": 1,
      "format": "oklch",
      "description": "oklch color format"
    }
  ],
  "colorPresentations": [
    "#{r:02x}{g:02x}{b:02x}",
    "rgb({r}, {g}, {b})",
    "hsl({h}, {s}%, {l}%)"
  ],
  "namedColors": {
    "red": "#ff0000",
    "blue": "#0000ff",
    "green": "#008000",
    "white": "#ffffff",
    "black": "#000000",
    "gray": "#808080"
  }
}
