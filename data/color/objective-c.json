{
  "language": "objective-c",
  "colorPatterns": [
    {
      "pattern": "[\"']#([0-9a-fA-F]{3})[\"']",
      "format": "hex3_string",
      "description": "Short hex in string literal."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{6})[\"']",
      "format": "hex6_string",
      "description": "Hex color in string literal (#rrggbb)."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{8})[\"']",
      "format": "hex8_string",
      "description": "Hex+alpha in string literal."
    },
    {
      "pattern": "0x([0-9a-fA-F]{6})\\b",
      "format": "hex_literal",
      "description": "Hex integer color (0xRRGGBB)."
    },
    {
      "pattern": "0x([0-9a-fA-F]{8})\\b",
      "format": "hex_literal_alpha",
      "description": "Hex integer+alpha (0xAARRGGBB)."
    },
    {
      "pattern": "\\[UIColor\\s+(?:redColor|greenColor|blueColor|whiteColor|blackColor|yellowColor|cyanColor|magentaColor|orangeColor|purpleColor|brownColor|grayColor|darkGrayColor|lightGrayColor|clearColor)\\]",
      "format": "uicolor-class",
      "description": "UIColor class method."
    },
    {
      "pattern": "\\[UIColor\\s+colorWithRed:(\\S+)\\s+green:(\\S+)\\s+blue:(\\S+)\\s+alpha:(\\S+)\\]",
      "format": "uicolor-rgba",
      "description": "UIColor RGBA."
    },
    {
      "pattern": "@\"#([0-9a-fA-F]{6})\"",
      "format": "objc-hex-string",
      "description": "Hex in NSString."
    }
  ],
  "colorPresentations": [
    "hex6",
    "hex8",
    "rgb"
  ],
  "namedColors": {
    "red": "#FF0000",
    "green": "#008000",
    "blue": "#0000FF",
    "white": "#FFFFFF",
    "black": "#000000",
    "yellow": "#FFFF00",
    "cyan": "#00FFFF",
    "magenta": "#FF00FF",
    "orange": "#FFA500",
    "purple": "#800080",
    "gray": "#808080",
    "transparent": "rgba(0,0,0,0)"
  }
}
