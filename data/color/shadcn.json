{
  "language": "shadcn",
  "colorPatterns": [
    {
      "pattern": "hsl\\(var\\(--([\\w-]+)\\)\\)",
      "captureGroup": 1,
      "format": "hsl"
    },
    {
      "pattern": "#([0-9a-fA-F]{8})\\b",
      "captureGroup": 0,
      "format": "hex"
    },
    {
      "pattern": "#([0-9a-fA-F]{6})\\b",
      "captureGroup": 0,
      "format": "hex"
    },
    {
      "pattern": "#([0-9a-fA-F]{3})\\b",
      "captureGroup": 0,
      "format": "hex"
    },
    {
      "pattern": "rgba?\\(([^)]+)\\)",
      "captureGroup": 1,
      "format": "rgb"
    },
    {
      "pattern": "hsla?\\(([^)]+)\\)",
      "captureGroup": 1,
      "format": "hsl"
    },
    {
      "pattern": "oklch\\(([^)]+)\\)",
      "captureGroup": 1,
      "format": "oklch"
    },
    {
      "pattern": "(?:text|bg|border|ring|accent|fill|stroke|outline|shadow|from|to|via)-(primary|secondary|muted|destructive|accent|popover|card|background|foreground|border|input|ring)(?:\\b|/)",
      "captureGroup": 1,
      "format": "hsl"
    }
  ],
  "namedColors": {
    "background": "hsl(var(--background))",
    "foreground": "hsl(var(--foreground))",
    "primary": "hsl(var(--primary))",
    "primary-foreground": "hsl(var(--primary-foreground))",
    "secondary": "hsl(var(--secondary))",
    "secondary-foreground": "hsl(var(--secondary-foreground))",
    "muted": "hsl(var(--muted))",
    "muted-foreground": "hsl(var(--muted-foreground))",
    "accent": "hsl(var(--accent))",
    "accent-foreground": "hsl(var(--accent-foreground))",
    "destructive": "hsl(var(--destructive))",
    "destructive-foreground": "hsl(var(--destructive-foreground))",
    "border": "hsl(var(--border))",
    "input": "hsl(var(--input))",
    "ring": "hsl(var(--ring))",
    "card": "hsl(var(--card))",
    "card-foreground": "hsl(var(--card-foreground))",
    "popover": "hsl(var(--popover))",
    "popover-foreground": "hsl(var(--popover-foreground))"
  }
}
