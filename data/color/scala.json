{
  "language": "scala",
  "colorPatterns": [
    {
      "pattern": "#([0-9a-fA-F]{6})",
      "format": "hex6",
      "description": "6-digit hex color in strings"
    },
    {
      "pattern": "#([0-9a-fA-F]{8})",
      "format": "hex8",
      "description": "8-digit hex color with alpha in strings"
    },
    {
      "pattern": "0x([0-9a-fA-F]{6})",
      "format": "hex6",
      "description": "Hex color as integer literal"
    },
    {
      "pattern": "0x([0-9a-fA-F]{8})",
      "format": "hex8",
      "description": "Hex color with alpha as integer literal"
    },
    {
      "pattern": "Color\\(\\s*(\\d+)\\s*,\\s*(\\d+)\\s*,\\s*(\\d+)\\s*\\)",
      "format": "rgb",
      "description": "Color(r, g, b) constructor"
    },
    {
      "pattern": "Color\\(\\s*(\\d+)\\s*,\\s*(\\d+)\\s*,\\s*(\\d+)\\s*,\\s*(\\d+)\\s*\\)",
      "format": "rgba",
      "description": "Color(r, g, b, a) constructor"
    },
    {
      "kind": "hex",
      "pattern": "#(?:[0-9a-fA-F]{3,4}){1,2}\\b",
      "description": "Hex color (#RGB, #RGBA, #RRGGBB, #RRGGBBAA)"
    }
  ],
  "colorPresentations": [
    "hex"
  ],
  "namedColors": {}
}
