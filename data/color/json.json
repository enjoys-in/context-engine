{
  "language": "json",
  "colorPatterns": [
    {
      "pattern": "[\"']#([0-9a-fA-F]{3})[\"']",
      "format": "hex3_string",
      "description": "Short hex in string literal."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{6})[\"']",
      "format": "hex6_string",
      "description": "Hex color in string literal (#rrggbb)."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{8})[\"']",
      "format": "hex8_string",
      "description": "Hex+alpha in string literal."
    },
    {
      "pattern": "\"(?:color|background|foreground|fill|stroke|border|accent|primary|secondary|theme)\"\\s*:\\s*\"([^\"]+)\"",
      "format": "json-color-key",
      "description": "Color in JSON key."
    },
    {
      "pattern": "\"#([0-9a-fA-F]{3,8})\"",
      "format": "json-hex",
      "description": "Hex in JSON string."
    },
    {
      "pattern": "\"rgb[a]?\\([^\"]+\\)\"",
      "format": "json-rgb",
      "description": "RGB(A) in JSON string."
    }
  ],
  "colorPresentations": [
    "hex6",
    "hex8"
  ],
  "namedColors": {
    "red": "#FF0000",
    "green": "#008000",
    "blue": "#0000FF",
    "white": "#FFFFFF",
    "black": "#000000",
    "yellow": "#FFFF00",
    "cyan": "#00FFFF",
    "magenta": "#FF00FF",
    "orange": "#FFA500",
    "purple": "#800080",
    "gray": "#808080",
    "transparent": "rgba(0,0,0,0)"
  }
}
