{
  "language": "less",
  "colorPatterns": [
    {
      "pattern": "#([0-9a-fA-F]{3,8})\\b",
      "type": "hex"
    },
    {
      "pattern": "rgb\\(\\s*(\\d+)\\s*,\\s*(\\d+)\\s*,\\s*(\\d+)\\s*\\)",
      "type": "rgb"
    },
    {
      "pattern": "rgba\\(\\s*(\\d+)\\s*,\\s*(\\d+)\\s*,\\s*(\\d+)\\s*,\\s*([\\d.]+)\\s*\\)",
      "type": "rgba"
    },
    {
      "kind": "hex",
      "pattern": "#(?:[0-9a-fA-F]{3,4}){1,2}\\b",
      "description": "Hex color (#RGB, #RGBA, #RRGGBB, #RRGGBBAA)"
    },
    {
      "kind": "rgb",
      "pattern": "rgba?\\(\\s*\\d+\\s*,\\s*\\d+\\s*,\\s*\\d+",
      "description": "RGB/RGBA color function"
    },
    {
      "kind": "hsl",
      "pattern": "hsla?\\(\\s*\\d+\\s*,\\s*\\d+%\\s*,\\s*\\d+%",
      "description": "HSL/HSLA color function"
    },
    {
      "kind": "named",
      "pattern": "\\b(?:red|green|blue|white|black|yellow|purple|orange|gray|pink|cyan)\\b",
      "description": "Named CSS colors"
    }
  ],
  "colorPresentations": [],
  "namedColors": {}
}
