{
  "language": "cpp",
  "colorPatterns": [
    {
      "pattern": "0x([0-9a-fA-F]{6})\\b",
      "format": "hex_literal",
      "description": "Hex integer color (0xRRGGBB)."
    },
    {
      "pattern": "0x([0-9a-fA-F]{8})\\b",
      "format": "hex_literal_alpha",
      "description": "Hex integer+alpha (0xAARRGGBB)."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{6})[\"']",
      "format": "hex6_string",
      "description": "Hex color in string literal (#rrggbb)."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{3})[\"']",
      "format": "hex3_string",
      "description": "Short hex in string literal."
    },
    {
      "pattern": "\\{\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})(?:\\s*,\\s*(\\d{1,3}))?\\s*\\}",
      "format": "struct-rgba",
      "description": "Color struct {r, g, b[, a]}."
    },
    {
      "pattern": "Color\\(\\s*(\\d+)\\s*,\\s*(\\d+)\\s*,\\s*(\\d+)(?:\\s*,\\s*(\\d+))?\\s*\\)",
      "format": "color-constructor",
      "description": "Color class RGBA constructor."
    },
    {
      "pattern": "QColor\\(\\s*(\\d+)\\s*,\\s*(\\d+)\\s*,\\s*(\\d+)(?:\\s*,\\s*(\\d+))?\\s*\\)",
      "format": "qt-qcolor",
      "description": "Qt QColor RGBA."
    },
    {
      "pattern": "QColor\\(\\s*[\"']([^\"']+)[\"']\\s*\\)",
      "format": "qt-qcolor-name",
      "description": "Qt QColor from name."
    },
    {
      "pattern": "Qt::(?:red|green|blue|white|black|yellow|cyan|magenta|darkRed|darkGreen|darkBlue|gray|darkGray|lightGray|transparent)\\b",
      "format": "qt-global",
      "description": "Qt global color."
    },
    {
      "pattern": "SDL_Color\\s*\\{\\s*(\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+)\\s*\\}",
      "format": "sdl-color",
      "description": "SDL_Color struct."
    },
    {
      "pattern": "ImVec4\\(\\s*([0-9.]+)f?\\s*,\\s*([0-9.]+)f?\\s*,\\s*([0-9.]+)f?\\s*,\\s*([0-9.]+)f?\\s*\\)",
      "format": "imgui-color",
      "description": "ImGui ImVec4."
    },
    {
      "pattern": "sf::Color\\(\\s*(\\d+)\\s*,\\s*(\\d+)\\s*,\\s*(\\d+)(?:\\s*,\\s*(\\d+))?\\s*\\)",
      "format": "sfml-color",
      "description": "SFML sf::Color."
    },
    {
      "pattern": "sf::Color::(?:Red|Green|Blue|White|Black|Yellow|Cyan|Magenta|Transparent)\\b",
      "format": "sfml-named",
      "description": "SFML named color."
    },
    {
      "pattern": "cv::Scalar\\(\\s*(\\d+)\\s*,\\s*(\\d+)\\s*,\\s*(\\d+)(?:\\s*,\\s*(\\d+))?\\s*\\)",
      "format": "opencv-scalar",
      "description": "OpenCV Scalar BGR(A)."
    }
  ],
  "colorPresentations": [
    "hex6",
    "hex8",
    "rgb"
  ],
  "namedColors": {
    "red": "#FF0000",
    "green": "#008000",
    "blue": "#0000FF",
    "white": "#FFFFFF",
    "black": "#000000",
    "yellow": "#FFFF00",
    "cyan": "#00FFFF",
    "magenta": "#FF00FF",
    "orange": "#FFA500",
    "purple": "#800080",
    "gray": "#808080",
    "transparent": "rgba(0,0,0,0)"
  }
}
