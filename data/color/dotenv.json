{
  "language": "dotenv",
  "colorPatterns": [
    {
      "pattern": "[\"']#([0-9a-fA-F]{6})[\"']",
      "format": "hex6_string",
      "description": "Hex color in string literal (#rrggbb)."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{3})[\"']",
      "format": "hex3_string",
      "description": "Short hex in string literal."
    },
    {
      "pattern": "(?:COLOR|THEME|ACCENT|BACKGROUND|FOREGROUND)[\\w_]*\\s*=\\s*[\"']?([^\"'\\n]+)[\"']?",
      "format": "env-color",
      "description": "Color env variable."
    }
  ],
  "colorPresentations": [
    "hex6"
  ],
  "namedColors": {}
}
