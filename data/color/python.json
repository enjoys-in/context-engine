{
  "language": "python",
  "colorPatterns": [
    {
      "pattern": "[\"']#([0-9a-fA-F]{3})[\"']",
      "format": "hex3_string",
      "description": "Short hex in string literal."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{6})[\"']",
      "format": "hex6_string",
      "description": "Hex color in string literal (#rrggbb)."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{8})[\"']",
      "format": "hex8_string",
      "description": "Hex+alpha in string literal."
    },
    {
      "pattern": "0x([0-9a-fA-F]{6})\\b",
      "format": "hex_literal",
      "description": "Hex integer color (0xRRGGBB)."
    },
    {
      "pattern": "0x([0-9a-fA-F]{8})\\b",
      "format": "hex_literal_alpha",
      "description": "Hex integer+alpha (0xAARRGGBB)."
    },
    {
      "pattern": "rgb\\(\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*\\)",
      "format": "rgb",
      "description": "RGB with comma-separated integers (0-255)."
    },
    {
      "pattern": "rgba\\(\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*([0-9.]+)\\s*\\)",
      "format": "rgba",
      "description": "RGBA with alpha (0-1)."
    },
    {
      "pattern": "\\b(?:red|green|blue|white|black|yellow|purple|orange|gray|cyan|magenta|pink|brown)\\b",
      "format": "named",
      "description": "Common named colors."
    },
    {
      "pattern": "Color\\(\\s*(\\d+)\\s*,\\s*(\\d+)\\s*,\\s*(\\d+)",
      "format": "color-tuple",
      "description": "Color constructor RGB."
    },
    {
      "pattern": "\\(\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*\\)",
      "format": "rgb-tuple",
      "description": "RGB tuple (PIL, pygame, tkinter)."
    },
    {
      "pattern": "\\(\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*\\)",
      "format": "rgba-tuple",
      "description": "RGBA tuple alpha 0-255."
    },
    {
      "pattern": "(?:pygame\\.Color|ImageColor\\.getrgb|ImageColor\\.getcolor)\\([\"']([^\"']+)[\"']\\)",
      "format": "python-color-api",
      "description": "Python color API (pygame, PIL)."
    },
    {
      "pattern": "plt\\.cm\\.\\w+|matplotlib\\.colors\\.\\w+|mcolors\\.\\w+",
      "format": "matplotlib-colormap",
      "description": "Matplotlib colormap."
    },
    {
      "pattern": "(?:tkinter\\.)?(?:fg|bg|foreground|background|activebackground|activeforeground|highlightcolor|selectcolor|insertbackground)\\s*=\\s*[\"']([^\"']+)[\"']",
      "format": "tkinter-color",
      "description": "Tkinter widget color."
    },
    {
      "pattern": "QColor\\(\\s*(\\d+)\\s*,\\s*(\\d+)\\s*,\\s*(\\d+)",
      "format": "qt-color",
      "description": "Qt QColor constructor."
    },
    {
      "pattern": "Qt\\.(?:red|green|blue|white|black|yellow|cyan|magenta|darkRed|darkGreen|darkBlue|gray|darkGray|lightGray|transparent)\\b",
      "format": "qt-global-color",
      "description": "Qt global color enum."
    }
  ],
  "colorPresentations": [
    "hex6",
    "rgb",
    "rgba",
    "hsl"
  ],
  "namedColors": {
    "red": "#FF0000",
    "green": "#008000",
    "blue": "#0000FF",
    "white": "#FFFFFF",
    "black": "#000000",
    "yellow": "#FFFF00",
    "cyan": "#00FFFF",
    "magenta": "#FF00FF",
    "orange": "#FFA500",
    "purple": "#800080",
    "gray": "#808080",
    "transparent": "rgba(0,0,0,0)",
    "navy": "#000080",
    "teal": "#008080",
    "maroon": "#800000",
    "olive": "#808000",
    "lime": "#00FF00",
    "silver": "#C0C0C0"
  }
}
