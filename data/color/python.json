{
  "language": "python",
  "colorPatterns": [
    {
      "pattern": "[\"']#([0-9a-fA-F]{6})[\"']",
      "format": "hex6_string",
      "description": "Hex color in string literal"
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{3})[\"']",
      "format": "hex3_string",
      "description": "Short hex color in string literal"
    },
    {
      "pattern": "0x([0-9a-fA-F]{6})\\b",
      "format": "hex_literal",
      "description": "Hex color literal (0xRRGGBB)"
    },
    {
      "pattern": "rgb\\((\\d+),\\s*(\\d+),\\s*(\\d+)\\)",
      "format": "rgb",
      "description": "RGB color function"
    },
    {
      "pattern": "rgba\\((\\d+),\\s*(\\d+),\\s*(\\d+),\\s*([\\d.]+)\\)",
      "format": "rgba",
      "description": "RGBA color function"
    }
  ],
  "colorPresentations": [
    "hex",
    "rgb",
    "rgba"
  ],
  "namedColors": {
    "red": "#FF0000",
    "green": "#008000",
    "blue": "#0000FF",
    "white": "#FFFFFF",
    "black": "#000000",
    "yellow": "#FFFF00",
    "cyan": "#00FFFF",
    "magenta": "#FF00FF",
    "orange": "#FFA500",
    "purple": "#800080",
    "gray": "#808080",
    "transparent": "#000000"
  }
}
