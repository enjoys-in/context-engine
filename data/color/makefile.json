{
  "language": "makefile",
  "colorPatterns": [
    {
      "pattern": "[\"']#([0-9a-fA-F]{6})[\"']",
      "format": "hex6_string",
      "description": "Hex color in string literal (#rrggbb)."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{3})[\"']",
      "format": "hex3_string",
      "description": "Short hex in string literal."
    },
    {
      "pattern": "\\\\033\\[\\d+(?:;\\d+)*m|\\\\e\\[\\d+(?:;\\d+)*m",
      "format": "ansi-escape",
      "description": "ANSI escape in Makefile."
    }
  ],
  "colorPresentations": [
    "hex6"
  ],
  "namedColors": {}
}
