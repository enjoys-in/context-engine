{
  "language": "powershell",
  "colorPatterns": [
    {
      "pattern": "\\\\033\\[(\\d+;)*\\d+m|\\\\e\\[(\\d+;)*\\d+m|\\\\x1b\\[(\\d+;)*\\d+m",
      "format": "ansi_escape",
      "description": "ANSI escape code color sequence"
    },
    {
      "pattern": "tput\\s+setaf\\s+(\\d+)",
      "format": "tput_setaf",
      "description": "tput foreground color"
    },
    {
      "pattern": "tput\\s+setab\\s+(\\d+)",
      "format": "tput_setab",
      "description": "tput background color"
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{6})[\"']",
      "format": "hex6_string",
      "description": "Hex color in string literal"
    }
  ],
  "colorPresentations": [
    "ansi_escape",
    "tput",
    "hex"
  ],
  "namedColors": {
    "black": "#000000",
    "red": "#CD0000",
    "green": "#00CD00",
    "yellow": "#CDCD00",
    "blue": "#0000CD",
    "magenta": "#CD00CD",
    "cyan": "#00CDCD",
    "white": "#CDCDCD"
  }
}
