{
  "language": "powershell",
  "colorPatterns": [
    {
      "pattern": "[\"']#([0-9a-fA-F]{6})[\"']",
      "format": "hex6_string",
      "description": "Hex color in string literal (#rrggbb)."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{3})[\"']",
      "format": "hex3_string",
      "description": "Short hex in string literal."
    },
    {
      "pattern": "0x([0-9a-fA-F]{6})\\b",
      "format": "hex_literal",
      "description": "Hex integer color (0xRRGGBB)."
    },
    {
      "pattern": "\\[System\\.Drawing\\.Color\\]::\\w+",
      "format": "dotnet-color",
      "description": ".NET System.Drawing.Color."
    },
    {
      "pattern": "\\[System\\.ConsoleColor\\]::(?:DarkBlue|DarkGreen|DarkCyan|DarkRed|DarkMagenta|DarkYellow|Gray|DarkGray|Blue|Green|Cyan|Red|Magenta|Yellow|White|Black)\\b",
      "format": "console-color",
      "description": ".NET ConsoleColor."
    },
    {
      "pattern": "Write-Host.*-(?:ForegroundColor|BackgroundColor)\\s+(\\w+)",
      "format": "write-host-color",
      "description": "Write-Host color param."
    },
    {
      "pattern": "\\\\e\\[\\d+(?:;\\d+)*m|`e\\[\\d+(?:;\\d+)*m",
      "format": "ansi-escape",
      "description": "ANSI/VT escape."
    }
  ],
  "colorPresentations": [
    "hex6",
    "console-color"
  ],
  "namedColors": {
    "red": "#FF0000",
    "green": "#008000",
    "blue": "#0000FF",
    "white": "#FFFFFF",
    "black": "#000000",
    "yellow": "#FFFF00",
    "cyan": "#00FFFF",
    "magenta": "#FF00FF",
    "orange": "#FFA500",
    "purple": "#800080",
    "gray": "#808080",
    "transparent": "rgba(0,0,0,0)"
  }
}
