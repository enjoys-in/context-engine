{
  "language": "perl",
  "colorPatterns": [
    {
      "pattern": "[\"']#([0-9a-fA-F]{6})[\"']",
      "format": "hex6_string",
      "description": "Hex color in string literal (#rrggbb)."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{3})[\"']",
      "format": "hex3_string",
      "description": "Short hex in string literal."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{8})[\"']",
      "format": "hex8_string",
      "description": "Hex+alpha in string literal."
    },
    {
      "pattern": "0x([0-9a-fA-F]{6})\\b",
      "format": "hex_literal",
      "description": "Hex integer color (0xRRGGBB)."
    },
    {
      "pattern": "rgb\\(\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*\\)",
      "format": "rgb",
      "description": "RGB with comma-separated integers (0-255)."
    },
    {
      "pattern": "rgba\\(\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*([0-9.]+)\\s*\\)",
      "format": "rgba",
      "description": "RGBA with alpha (0-1)."
    },
    {
      "pattern": "\\b(?:red|green|blue|white|black|yellow|purple|orange|gray|cyan|magenta|pink|brown)\\b",
      "format": "named",
      "description": "Common named color."
    },
    {
      "pattern": "Term::ANSIColor\\s+\\w+",
      "format": "ansi-module",
      "description": "Term::ANSIColor."
    },
    {
      "pattern": "\\\\e\\[\\d+(?:;\\d+)*m",
      "format": "ansi-escape",
      "description": "ANSI escape."
    }
  ],
  "colorPresentations": [
    "hex6",
    "rgb",
    "named"
  ],
  "namedColors": {
    "red": "#FF0000",
    "green": "#008000",
    "blue": "#0000FF",
    "white": "#FFFFFF",
    "black": "#000000",
    "yellow": "#FFFF00",
    "cyan": "#00FFFF",
    "magenta": "#FF00FF",
    "orange": "#FFA500",
    "purple": "#800080",
    "gray": "#808080",
    "transparent": "rgba(0,0,0,0)"
  }
}
