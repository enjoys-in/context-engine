{
  "language": "typescript",
  "colorPatterns": [
    {
      "pattern": "#([0-9a-fA-F]{6})\\\\b",
      "format": "hex6",
      "description": "6-digit hex color"
    },
    {
      "pattern": "#([0-9a-fA-F]{8})\\\\b",
      "format": "hex8",
      "description": "8-digit hex color with alpha"
    },
    {
      "pattern": "#([0-9a-fA-F]{3})\\\\b",
      "format": "hex3",
      "description": "3-digit hex color"
    },
    {
      "pattern": "rgb\\\\((\\\\d+),\\\\s*(\\\\d+),\\\\s*(\\\\d+)\\\\)",
      "format": "rgb",
      "description": "RGB color"
    },
    {
      "pattern": "rgba\\\\((\\\\d+),\\\\s*(\\\\d+),\\\\s*(\\\\d+),\\\\s*([\\\\d.]+)\\\\)",
      "format": "rgba",
      "description": "RGBA color"
    },
    {
      "pattern": "hsl\\\\((\\\\d+),\\\\s*(\\\\d+)%,\\\\s*(\\\\d+)%\\\\)",
      "format": "hsl",
      "description": "HSL color"
    },
    {
      "pattern": "hsla\\\\((\\\\d+),\\\\s*(\\\\d+)%,\\\\s*(\\\\d+)%,\\\\s*([\\\\d.]+)\\\\)",
      "format": "hsla",
      "description": "HSLA color"
    }
  ],
  "colorPresentations": [
    "hex",
    "rgb",
    "rgba",
    "hsl",
    "hsla"
  ],
  "namedColors": {
    "red": {
      "red": 1,
      "green": 0,
      "blue": 0,
      "alpha": 1
    },
    "green": {
      "red": 0,
      "green": 0.502,
      "blue": 0,
      "alpha": 1
    },
    "blue": {
      "red": 0,
      "green": 0,
      "blue": 1,
      "alpha": 1
    },
    "white": {
      "red": 1,
      "green": 1,
      "blue": 1,
      "alpha": 1
    },
    "black": {
      "red": 0,
      "green": 0,
      "blue": 0,
      "alpha": 1
    },
    "transparent": {
      "red": 0,
      "green": 0,
      "blue": 0,
      "alpha": 0
    }
  }
}
