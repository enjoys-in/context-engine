{
  "language": "r",
  "colorPatterns": [
    {
      "pattern": "[\"']#([0-9a-fA-F]{6})[\"']",
      "format": "hex6_string",
      "description": "Hex color in string literal (#rrggbb)."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{3})[\"']",
      "format": "hex3_string",
      "description": "Short hex in string literal."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{8})[\"']",
      "format": "hex8_string",
      "description": "Hex+alpha in string literal."
    },
    {
      "pattern": "rgb\\(\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*\\)",
      "format": "rgb",
      "description": "RGB with comma-separated integers (0-255)."
    },
    {
      "pattern": "\\b(?:red|green|blue|white|black|yellow|purple|orange|gray|cyan|magenta|pink|brown|navy|coral|gold|salmon|tomato|violet|turquoise|khaki|maroon|olive|teal)\\b",
      "format": "r-named",
      "description": "R built-in color name."
    },
    {
      "pattern": "rgb\\(\\s*([0-9.]+)\\s*,\\s*([0-9.]+)\\s*,\\s*([0-9.]+)(?:\\s*,\\s*(?:alpha\\s*=\\s*)?([0-9.]+))?\\s*(?:,\\s*maxColorValue\\s*=\\s*\\d+)?\\s*\\)",
      "format": "r-rgb",
      "description": "R rgb() function."
    },
    {
      "pattern": "hsv\\(\\s*([0-9.]+)\\s*,\\s*([0-9.]+)\\s*,\\s*([0-9.]+)\\)",
      "format": "r-hsv",
      "description": "R hsv() function."
    },
    {
      "pattern": "col2rgb\\(\\s*[\"']([^\"']+)[\"']\\s*\\)",
      "format": "r-col2rgb",
      "description": "R col2rgb()."
    },
    {
      "pattern": "scale_(?:color|fill|colour)_(?:manual|gradient|brewer|viridis)\\(",
      "format": "ggplot-scale",
      "description": "ggplot2 scale color."
    },
    {
      "pattern": "brewer\\.pal\\(\\s*\\d+\\s*,\\s*[\"']([^\"']+)[\"']\\s*\\)",
      "format": "brewer-palette",
      "description": "RColorBrewer palette."
    },
    {
      "pattern": "#([0-9a-fA-F]{3})\\\\b",
      "format": "hex3",
      "description": "3-digit hex color (#rgb)"
    },
    {
      "pattern": "#([0-9a-fA-F]{6})\\\\b",
      "format": "hex6",
      "description": "6-digit hex color (#rrggbb)"
    },
    {
      "pattern": "#([0-9a-fA-F]{8})\\\\b",
      "format": "hex8",
      "description": "8-digit hex color with alpha (#rrggbbaa)"
    },
    {
      "pattern": "rgba\\\\(\\\\s*\\\\d+\\\\s*,\\\\s*\\\\d+\\\\s*,\\\\s*\\\\d+\\\\s*,\\\\s*[\\\\d.]+\\\\s*\\\\)",
      "format": "rgba",
      "description": "RGBA function notation"
    },
    {
      "pattern": "hsl\\\\(\\\\s*\\\\d+\\\\s*,\\\\s*\\\\d+%?\\\\s*,\\\\s*\\\\d+%?\\\\s*\\\\)",
      "format": "hsl",
      "description": "HSL function notation"
    },
    {
      "pattern": "hsla\\\\(\\\\s*\\\\d+\\\\s*,\\\\s*\\\\d+%?\\\\s*,\\\\s*\\\\d+%?\\\\s*,\\\\s*[\\\\d.]+\\\\s*\\\\)",
      "format": "hsla",
      "description": "HSLA function notation"
    },
    {
      "pattern": "oklch\\\\(\\\\s*[\\\\d.]+%?\\\\s+[\\\\d.]+\\\\s+[\\\\d.]+\\\\s*\\\\)",
      "format": "oklch",
      "description": "OKLCH color function"
    },
    {
      "pattern": "color\\\\(\\\\s*srgb\\\\s+[\\\\d.]+\\\\s+[\\\\d.]+\\\\s+[\\\\d.]+\\\\s*\\\\)",
      "format": "color-srgb",
      "description": "CSS color() with sRGB"
    },
    {
      "pattern": "hwb\\\\(\\\\s*\\\\d+\\\\s+\\\\d+%\\\\s+\\\\d+%\\\\s*\\\\)",
      "format": "hwb",
      "description": "HWB color notation"
    }
  ],
  "colorPresentations": [
    "hex6",
    "hex8",
    "rgb",
    "rgb-modern",
    "hsl",
    "hsl-modern",
    "oklch",
    "named"
  ],
  "namedColors": {
    "red": "#FF0000",
    "green": "#008000",
    "blue": "#0000FF",
    "white": "#FFFFFF",
    "black": "#000000",
    "yellow": "#FFFF00",
    "cyan": "#00FFFF",
    "magenta": "#FF00FF",
    "orange": "#FFA500",
    "purple": "#800080",
    "pink": "#FFC0CB",
    "brown": "#A52A2A",
    "gray": "#808080",
    "grey": "#808080",
    "silver": "#C0C0C0",
    "gold": "#FFD700",
    "navy": "#000080",
    "teal": "#008080",
    "maroon": "#800000",
    "olive": "#808000",
    "lime": "#00FF00",
    "aqua": "#00FFFF",
    "coral": "#FF7F50",
    "salmon": "#FA8072",
    "indigo": "#4B0082",
    "violet": "#EE82EE",
    "turquoise": "#40E0D0",
    "tan": "#D2B48C",
    "transparent": "rgba(0,0,0,0)",
    "currentColor": "currentColor"
  }
}
