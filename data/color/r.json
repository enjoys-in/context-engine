{
  "language": "r",
  "colorPatterns": [
    {
      "pattern": "[\"']#([0-9a-fA-F]{6})[\"']",
      "format": "hex6_string",
      "description": "Hex color in string literal (#rrggbb)."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{3})[\"']",
      "format": "hex3_string",
      "description": "Short hex in string literal."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{8})[\"']",
      "format": "hex8_string",
      "description": "Hex+alpha in string literal."
    },
    {
      "pattern": "rgb\\(\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*\\)",
      "format": "rgb",
      "description": "RGB with comma-separated integers (0-255)."
    },
    {
      "pattern": "\\b(?:red|green|blue|white|black|yellow|purple|orange|gray|cyan|magenta|pink|brown|navy|coral|gold|salmon|tomato|violet|turquoise|khaki|maroon|olive|teal)\\b",
      "format": "r-named",
      "description": "R built-in color name."
    },
    {
      "pattern": "rgb\\(\\s*([0-9.]+)\\s*,\\s*([0-9.]+)\\s*,\\s*([0-9.]+)(?:\\s*,\\s*(?:alpha\\s*=\\s*)?([0-9.]+))?\\s*(?:,\\s*maxColorValue\\s*=\\s*\\d+)?\\s*\\)",
      "format": "r-rgb",
      "description": "R rgb() function."
    },
    {
      "pattern": "hsv\\(\\s*([0-9.]+)\\s*,\\s*([0-9.]+)\\s*,\\s*([0-9.]+)\\)",
      "format": "r-hsv",
      "description": "R hsv() function."
    },
    {
      "pattern": "col2rgb\\(\\s*[\"']([^\"']+)[\"']\\s*\\)",
      "format": "r-col2rgb",
      "description": "R col2rgb()."
    },
    {
      "pattern": "scale_(?:color|fill|colour)_(?:manual|gradient|brewer|viridis)\\(",
      "format": "ggplot-scale",
      "description": "ggplot2 scale color."
    },
    {
      "pattern": "brewer\\.pal\\(\\s*\\d+\\s*,\\s*[\"']([^\"']+)[\"']\\s*\\)",
      "format": "brewer-palette",
      "description": "RColorBrewer palette."
    }
  ],
  "colorPresentations": [
    "hex6",
    "rgb",
    "named"
  ],
  "namedColors": {
    "red": "#FF0000",
    "green": "#008000",
    "blue": "#0000FF",
    "white": "#FFFFFF",
    "black": "#000000",
    "yellow": "#FFFF00",
    "cyan": "#00FFFF",
    "magenta": "#FF00FF",
    "orange": "#FFA500",
    "purple": "#800080",
    "gray": "#808080",
    "transparent": "rgba(0,0,0,0)",
    "coral": "#FF7F50",
    "salmon": "#FA8072",
    "gold": "#FFD700",
    "navy": "#000080"
  }
}
