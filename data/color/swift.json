{
  "language": "swift",
  "colorPatterns": [
    {
      "pattern": "[\"']#([0-9a-fA-F]{3})[\"']",
      "format": "hex3_string",
      "description": "Short hex in string literal."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{6})[\"']",
      "format": "hex6_string",
      "description": "Hex color in string literal (#rrggbb)."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{8})[\"']",
      "format": "hex8_string",
      "description": "Hex+alpha in string literal."
    },
    {
      "pattern": "0x([0-9a-fA-F]{6})\\b",
      "format": "hex_literal",
      "description": "Hex integer color (0xRRGGBB)."
    },
    {
      "pattern": "0x([0-9a-fA-F]{8})\\b",
      "format": "hex_literal_alpha",
      "description": "Hex integer+alpha (0xAARRGGBB)."
    },
    {
      "pattern": "UIColor\\(\\s*red:\\s*([0-9.]+)\\s*,\\s*green:\\s*([0-9.]+)\\s*,\\s*blue:\\s*([0-9.]+)\\s*,\\s*alpha:\\s*([0-9.]+)\\s*\\)",
      "format": "uicolor-rgba",
      "description": "UIColor RGBA (0.0-1.0)."
    },
    {
      "pattern": "UIColor\\.(?:red|green|blue|white|black|yellow|cyan|magenta|orange|purple|brown|gray|darkGray|lightGray|clear|systemRed|systemGreen|systemBlue|systemOrange|systemYellow|systemPink|systemPurple|systemTeal|systemIndigo)\\b",
      "format": "uicolor-named",
      "description": "UIColor system color."
    },
    {
      "pattern": "Color\\(\\s*red:\\s*([0-9.]+)\\s*,\\s*green:\\s*([0-9.]+)\\s*,\\s*blue:\\s*([0-9.]+)(?:\\s*,\\s*opacity:\\s*([0-9.]+))?\\s*\\)",
      "format": "swiftui-color",
      "description": "SwiftUI Color initializer."
    },
    {
      "pattern": "Color\\.(?:red|green|blue|white|black|yellow|orange|pink|purple|gray|clear|primary|secondary|accentColor|mint|teal|cyan|indigo|brown)\\b",
      "format": "swiftui-named",
      "description": "SwiftUI named color."
    },
    {
      "pattern": "Color\\([\"']([^\"']+)[\"']\\)",
      "format": "asset-color",
      "description": "Asset catalog color."
    },
    {
      "pattern": "#colorLiteral\\(\\s*red:\\s*([0-9.]+)\\s*,\\s*green:\\s*([0-9.]+)\\s*,\\s*blue:\\s*([0-9.]+)\\s*,\\s*alpha:\\s*([0-9.]+)\\s*\\)",
      "format": "color-literal",
      "description": "Xcode #colorLiteral."
    }
  ],
  "colorPresentations": [
    "hex6",
    "hex8",
    "rgb",
    "named"
  ],
  "namedColors": {
    "red": "#FF0000",
    "green": "#008000",
    "blue": "#0000FF",
    "white": "#FFFFFF",
    "black": "#000000",
    "yellow": "#FFFF00",
    "cyan": "#00FFFF",
    "magenta": "#FF00FF",
    "orange": "#FFA500",
    "purple": "#800080",
    "gray": "#808080",
    "transparent": "rgba(0,0,0,0)",
    "clear": "rgba(0,0,0,0)",
    "systemRed": "#FF3B30",
    "systemBlue": "#007AFF"
  }
}
