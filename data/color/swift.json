{
  "language": "swift",
  "colorPatterns": [
    {
      "pattern": "UIColor\\(\\s*red:\\s*([\\d.]+)\\s*,\\s*green:\\s*([\\d.]+)\\s*,\\s*blue:\\s*([\\d.]+)\\s*,\\s*alpha:\\s*([\\d.]+)\\s*\\)",
      "format": "rgba_float",
      "description": "UIColor with RGBA float components (0.0-1.0)"
    },
    {
      "pattern": "UIColor\\(\\s*white:\\s*([\\d.]+)\\s*,\\s*alpha:\\s*([\\d.]+)\\s*\\)",
      "format": "grayscale_float",
      "description": "UIColor grayscale with alpha"
    },
    {
      "pattern": "Color\\(\\s*red:\\s*([\\d.]+)\\s*,\\s*green:\\s*([\\d.]+)\\s*,\\s*blue:\\s*([\\d.]+)\\s*\\)",
      "format": "rgb_float",
      "description": "SwiftUI Color with RGB float components"
    },
    {
      "pattern": "#([0-9a-fA-F]{6})",
      "format": "hex6",
      "description": "6-digit hex color in strings"
    },
    {
      "pattern": "#([0-9a-fA-F]{8})",
      "format": "hex8",
      "description": "8-digit hex color with alpha in strings"
    }
  ],
  "colorPresentations": [
    "hex",
    "rgb",
    "rgba"
  ],
  "namedColors": {
    ".red": "#FF0000",
    ".green": "#00FF00",
    ".blue": "#0000FF",
    ".white": "#FFFFFF",
    ".black": "#000000",
    ".gray": "#808080",
    ".orange": "#FF8000",
    ".yellow": "#FFFF00",
    ".pink": "#FF2D55",
    ".purple": "#AF52DE",
    ".cyan": "#00FFFF",
    ".mint": "#00C7BE",
    ".teal": "#30B0C7",
    ".indigo": "#5856D6",
    ".brown": "#A2845E",
    ".clear": "#00000000",
    ".primary": "#000000",
    ".secondary": "#8E8E93",
    ".accentColor": "#007AFF"
  }
}
