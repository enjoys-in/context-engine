{
  "language": "dart",
  "colorPatterns": [
    {
      "pattern": "[\"']#([0-9a-fA-F]{6})[\"']",
      "format": "hex6_string",
      "description": "Hex color in string literal (#rrggbb)."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{3})[\"']",
      "format": "hex3_string",
      "description": "Short hex in string literal."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{8})[\"']",
      "format": "hex8_string",
      "description": "Hex+alpha in string literal."
    },
    {
      "pattern": "0x([0-9a-fA-F]{6})\\b",
      "format": "hex_literal",
      "description": "Hex integer color (0xRRGGBB)."
    },
    {
      "pattern": "0x([0-9a-fA-F]{8})\\b",
      "format": "hex_literal_alpha",
      "description": "Hex integer+alpha (0xAARRGGBB)."
    },
    {
      "pattern": "Color\\(0x[0-9a-fA-F]{8}\\)",
      "format": "flutter-color",
      "description": "Flutter Color(0xAARRGGBB)."
    },
    {
      "pattern": "Color\\.fromARGB\\(\\s*(\\d+)\\s*,\\s*(\\d+)\\s*,\\s*(\\d+)\\s*,\\s*(\\d+)\\s*\\)",
      "format": "flutter-argb",
      "description": "Color.fromARGB(a, r, g, b)."
    },
    {
      "pattern": "Color\\.fromRGBO\\(\\s*(\\d+)\\s*,\\s*(\\d+)\\s*,\\s*(\\d+)\\s*,\\s*([0-9.]+)\\s*\\)",
      "format": "flutter-rgbo",
      "description": "Color.fromRGBO(r, g, b, opacity)."
    },
    {
      "pattern": "Colors\\.(?:red|green|blue|white|black|yellow|cyan|orange|purple|pink|grey|brown|amber|deepOrange|deepPurple|indigo|lightBlue|lightGreen|lime|teal|transparent|blueGrey)(?:\\[\\d+\\])?\\b",
      "format": "material-color",
      "description": "Flutter Material Colors."
    },
    {
      "pattern": "CupertinoColors\\.(?:activeBlue|activeGreen|activeOrange|white|black|systemBlue|systemGreen|systemRed|systemYellow|systemPink|systemPurple)\\b",
      "format": "cupertino-color",
      "description": "Cupertino color."
    },
    {
      "pattern": "Theme\\.of\\(context\\)\\.(?:colorScheme|primaryColor|backgroundColor|cardColor|dividerColor)\\b",
      "format": "theme-color",
      "description": "Flutter Theme color."
    },
    {
      "pattern": "#([0-9a-fA-F]{3})\\\\b",
      "format": "hex3",
      "description": "3-digit hex color (#rgb)"
    },
    {
      "pattern": "#([0-9a-fA-F]{6})\\\\b",
      "format": "hex6",
      "description": "6-digit hex color (#rrggbb)"
    },
    {
      "pattern": "#([0-9a-fA-F]{8})\\\\b",
      "format": "hex8",
      "description": "8-digit hex color with alpha (#rrggbbaa)"
    },
    {
      "pattern": "rgb\\\\(\\\\s*\\\\d+\\\\s*,\\\\s*\\\\d+\\\\s*,\\\\s*\\\\d+\\\\s*\\\\)",
      "format": "rgb",
      "description": "RGB function notation"
    },
    {
      "pattern": "rgba\\\\(\\\\s*\\\\d+\\\\s*,\\\\s*\\\\d+\\\\s*,\\\\s*\\\\d+\\\\s*,\\\\s*[\\\\d.]+\\\\s*\\\\)",
      "format": "rgba",
      "description": "RGBA function notation"
    },
    {
      "pattern": "hsl\\\\(\\\\s*\\\\d+\\\\s*,\\\\s*\\\\d+%?\\\\s*,\\\\s*\\\\d+%?\\\\s*\\\\)",
      "format": "hsl",
      "description": "HSL function notation"
    },
    {
      "pattern": "hsla\\\\(\\\\s*\\\\d+\\\\s*,\\\\s*\\\\d+%?\\\\s*,\\\\s*\\\\d+%?\\\\s*,\\\\s*[\\\\d.]+\\\\s*\\\\)",
      "format": "hsla",
      "description": "HSLA function notation"
    },
    {
      "pattern": "oklch\\\\(\\\\s*[\\\\d.]+%?\\\\s+[\\\\d.]+\\\\s+[\\\\d.]+\\\\s*\\\\)",
      "format": "oklch",
      "description": "OKLCH color function"
    },
    {
      "pattern": "color\\\\(\\\\s*srgb\\\\s+[\\\\d.]+\\\\s+[\\\\d.]+\\\\s+[\\\\d.]+\\\\s*\\\\)",
      "format": "color-srgb",
      "description": "CSS color() with sRGB"
    },
    {
      "pattern": "hwb\\\\(\\\\s*\\\\d+\\\\s+\\\\d+%\\\\s+\\\\d+%\\\\s*\\\\)",
      "format": "hwb",
      "description": "HWB color notation"
    }
  ],
  "colorPresentations": [
    "hex6",
    "hex8",
    "rgb",
    "rgb-modern",
    "hsl",
    "hsl-modern",
    "oklch",
    "named"
  ],
