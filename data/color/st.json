{
  "language": "st",
  "colorPatterns": [
    {
      "pattern": "[\"']#([0-9a-fA-F]{6})[\"']",
      "format": "hex6_string",
      "description": "Hex color in string literal (#rrggbb)."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{3})[\"']",
      "format": "hex3_string",
      "description": "Short hex in string literal."
    },
    {
      "pattern": "0x([0-9a-fA-F]{6})\\b",
      "format": "hex_literal",
      "description": "Hex integer color (0xRRGGBB)."
    },
    {
      "pattern": "Color\\s+(?:red|green|blue|white|black|yellow|cyan|magenta)\\b",
      "format": "st-color",
      "description": "Smalltalk Color class."
    },
    {
      "pattern": "Color\\s+r:\\s*([0-9.]+)\\s+g:\\s*([0-9.]+)\\s+b:\\s*([0-9.]+)",
      "format": "st-rgb",
      "description": "Smalltalk Color r:g:b:."
    }
  ],
  "colorPresentations": [
    "hex6",
    "rgb",
    "named"
  ],
  "namedColors": {
    "red": "#FF0000",
    "green": "#008000",
    "blue": "#0000FF",
    "white": "#FFFFFF",
    "black": "#000000",
    "yellow": "#FFFF00",
    "cyan": "#00FFFF",
    "magenta": "#FF00FF",
    "orange": "#FFA500",
    "purple": "#800080",
    "gray": "#808080",
    "transparent": "rgba(0,0,0,0)"
  }
}
