{
  "language": "xml",
  "colorPatterns": [
    {
      "pattern": "#([0-9a-fA-F]{3})\\b",
      "format": "hex3",
      "description": "Short hex color (#rgb). Each digit doubled."
    },
    {
      "pattern": "#([0-9a-fA-F]{6})\\b",
      "format": "hex6",
      "description": "Standard 6-digit hex (#rrggbb)."
    },
    {
      "pattern": "#([0-9a-fA-F]{8})\\b",
      "format": "hex8",
      "description": "8-digit hex+alpha (#rrggbbaa)."
    },
    {
      "pattern": "rgb\\(\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*\\)",
      "format": "rgb",
      "description": "RGB with comma-separated integers (0-255)."
    },
    {
      "pattern": "rgba\\(\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*([0-9.]+)\\s*\\)",
      "format": "rgba",
      "description": "RGBA with alpha (0-1)."
    },
    {
      "pattern": "(?:color|fill|stroke)\\s*=\\s*\"([^\"]+)\"",
      "format": "xml-attr",
      "description": "Color in XML/SVG attribute."
    },
    {
      "pattern": "#([0-9a-fA-F]{6})(?=[\"'<>\\s])",
      "format": "hex6-attr",
      "description": "Hex in XML attribute value."
    }
  ],
  "colorPresentations": [
    "hex6",
    "hex8",
    "rgb"
  ],
  "namedColors": {
    "red": "#FF0000",
    "green": "#008000",
    "blue": "#0000FF",
    "white": "#FFFFFF",
    "black": "#000000",
    "yellow": "#FFFF00",
    "cyan": "#00FFFF",
    "magenta": "#FF00FF",
    "orange": "#FFA500",
    "purple": "#800080",
    "gray": "#808080",
    "transparent": "rgba(0,0,0,0)"
  }
}
