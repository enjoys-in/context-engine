{
  "language": "pascal",
  "colorPatterns": [
    {
      "pattern": "[\"']#([0-9a-fA-F]{6})[\"']",
      "format": "hex6_string",
      "description": "Hex color in string literal (#rrggbb)."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{3})[\"']",
      "format": "hex3_string",
      "description": "Short hex in string literal."
    },
    {
      "pattern": "0x([0-9a-fA-F]{6})\\b",
      "format": "hex_literal",
      "description": "Hex integer color (0xRRGGBB)."
    },
    {
      "pattern": "\\$([0-9a-fA-F]{6})\\b",
      "format": "pascal-hex",
      "description": "Pascal hex $BBGGRR."
    },
    {
      "pattern": "cl(?:Red|Green|Blue|White|Black|Yellow|Aqua|Fuchsia|Silver|Gray|Maroon|Olive|Navy|Purple|Teal|Lime|None|Default)\\b",
      "format": "delphi-color",
      "description": "Delphi TColor constant."
    },
    {
      "pattern": "RGB\\(\\s*(\\d+)\\s*,\\s*(\\d+)\\s*,\\s*(\\d+)\\s*\\)",
      "format": "rgb-func",
      "description": "RGB() function."
    }
  ],
  "colorPresentations": [
    "hex6",
    "rgb",
    "named"
  ],
  "namedColors": {
    "red": "#FF0000",
    "green": "#008000",
    "blue": "#0000FF",
    "white": "#FFFFFF",
    "black": "#000000",
    "yellow": "#FFFF00",
    "cyan": "#00FFFF",
    "magenta": "#FF00FF",
    "orange": "#FFA500",
    "purple": "#800080",
    "gray": "#808080",
    "transparent": "rgba(0,0,0,0)"
  }
}
