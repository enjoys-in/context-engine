{
  "language": "kotlin",
  "colorPatterns": [
    {
      "pattern": "[\"']#([0-9a-fA-F]{6})[\"']",
      "format": "hex6_string",
      "description": "Hex color in string literal (#rrggbb)."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{3})[\"']",
      "format": "hex3_string",
      "description": "Short hex in string literal."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{8})[\"']",
      "format": "hex8_string",
      "description": "Hex+alpha in string literal."
    },
    {
      "pattern": "0x([0-9a-fA-F]{6})\\b",
      "format": "hex_literal",
      "description": "Hex integer color (0xRRGGBB)."
    },
    {
      "pattern": "0x([0-9a-fA-F]{8})\\b",
      "format": "hex_literal_alpha",
      "description": "Hex integer+alpha (0xAARRGGBB)."
    },
    {
      "pattern": "Color\\(\\s*0x[0-9a-fA-F]+\\s*\\)",
      "format": "compose-color-hex",
      "description": "Compose Color(0xAARRGGBB)."
    },
    {
      "pattern": "Color\\(\\s*(\\d+)\\s*,\\s*(\\d+)\\s*,\\s*(\\d+)(?:\\s*,\\s*(\\d+))?\\s*\\)",
      "format": "color-rgb-int",
      "description": "Color(r, g, b[, a]) int."
    },
    {
      "pattern": "Color\\.(?:Red|Green|Blue|White|Black|Yellow|Cyan|Magenta|Gray|LightGray|DarkGray|Transparent|Unspecified)\\b",
      "format": "compose-named",
      "description": "Compose named color."
    },
    {
      "pattern": "android\\.graphics\\.Color\\.parseColor\\(\\s*[\"']([^\"']+)[\"']\\s*\\)",
      "format": "android-parse",
      "description": "Android Color.parseColor()."
    },
    {
      "pattern": "MaterialTheme\\.colorScheme\\.(?:primary|secondary|tertiary|error|background|surface|onPrimary|onSecondary|onBackground|onSurface)\\b",
      "format": "material-theme",
      "description": "Material3 color scheme."
    }
  ],
  "colorPresentations": [
    "hex8",
    "rgb",
    "named"
  ],
  "namedColors": {
    "red": "#FF0000",
    "green": "#008000",
    "blue": "#0000FF",
    "white": "#FFFFFF",
    "black": "#000000",
    "yellow": "#FFFF00",
    "cyan": "#00FFFF",
    "magenta": "#FF00FF",
    "orange": "#FFA500",
    "purple": "#800080",
    "gray": "#808080",
    "transparent": "rgba(0,0,0,0)",
    "Transparent": "rgba(0,0,0,0)"
  }
}
