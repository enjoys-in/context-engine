{
  "language": "bash",
  "colorPatterns": [
    {
      "pattern": "\\\\033\\[(\\d+;)*\\d+m|\\\\e\\[(\\d+;)*\\d+m|\\\\x1b\\[(\\d+;)*\\d+m",
      "format": "ansi_escape",
      "description": "ANSI escape code color sequence (\\033[...m, \\e[...m, \\x1b[...m)"
    },
    {
      "pattern": "tput\\s+setaf\\s+(\\d+)",
      "format": "tput_setaf",
      "description": "tput foreground color (0-255)"
    },
    {
      "pattern": "tput\\s+setab\\s+(\\d+)",
      "format": "tput_setab",
      "description": "tput background color (0-255)"
    }
  ],
  "colorPresentations": [
    "ansi_escape",
    "tput"
  ],
