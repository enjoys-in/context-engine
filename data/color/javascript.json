{
  "language": "javascript",
  "colorPatterns": [
    {
      "pattern": "[\"']#([0-9a-fA-F]{3})[\"']",
      "format": "hex3_string",
      "description": "Short hex in string literal."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{6})[\"']",
      "format": "hex6_string",
      "description": "Hex color in string literal (#rrggbb)."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{8})[\"']",
      "format": "hex8_string",
      "description": "Hex+alpha in string literal."
    },
    {
      "pattern": "0x([0-9a-fA-F]{6})\\b",
      "format": "hex_literal",
      "description": "Hex integer color (0xRRGGBB)."
    },
    {
      "pattern": "0x([0-9a-fA-F]{8})\\b",
      "format": "hex_literal_alpha",
      "description": "Hex integer+alpha (0xAARRGGBB)."
    },
    {
      "pattern": "rgb\\(\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*\\)",
      "format": "rgb",
      "description": "RGB with comma-separated integers (0-255)."
    },
    {
      "pattern": "rgba\\(\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*([0-9.]+)\\s*\\)",
      "format": "rgba",
      "description": "RGBA with alpha (0-1)."
    },
    {
      "pattern": "hsl\\(\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})%\\s*,\\s*(\\d{1,3})%\\s*\\)",
      "format": "hsl",
      "description": "HSL: hue (0-360), saturation (0-100%), lightness (0-100%)."
    },
    {
      "pattern": "hsla\\(\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})%\\s*,\\s*(\\d{1,3})%\\s*,\\s*([0-9.]+)\\s*\\)",
      "format": "hsla",
      "description": "HSLA with alpha."
    },
    {
      "pattern": "\\b(?:red|green|blue|white|black|yellow|purple|orange|gray|cyan|magenta|pink|brown|transparent)\\b",
      "format": "named",
      "description": "Common named color keywords."
    },
    {
      "pattern": "(?:canvas|ctx)\\.(?:fillStyle|strokeStyle|shadowColor)\\s*=\\s*[\"']([^\"']+)[\"']",
      "format": "canvas-style",
      "description": "Canvas 2D context color."
    },
    {
      "pattern": "new\\s+Color\\(\\s*(\\d+)\\s*,\\s*(\\d+)\\s*,\\s*(\\d+)",
      "format": "color-constructor",
      "description": "Color constructor RGB."
    },
    {
      "pattern": "Color\\.(?:fromRgb|fromHex|fromHsl)\\(",
      "format": "color-factory",
      "description": "Color factory method."
    },
    {
      "pattern": "(?:background(?:Color)?|color|border(?:Color)?|outline(?:Color)?|fill|stroke)\\s*[:=]\\s*[\"'`]([^\"'`]+)[\"'`]",
      "format": "css-property",
      "description": "CSS color property in JS/DOM."
    }
  ],
  "colorPresentations": [
    "hex6",
    "hex8",
    "rgb",
    "rgba",
    "hsl"
  ],
  "namedColors": {
    "red": "#FF0000",
    "green": "#008000",
    "blue": "#0000FF",
    "white": "#FFFFFF",
    "black": "#000000",
    "yellow": "#FFFF00",
    "cyan": "#00FFFF",
    "magenta": "#FF00FF",
    "orange": "#FFA500",
    "purple": "#800080",
    "gray": "#808080",
    "transparent": "rgba(0,0,0,0)"
  }
}
