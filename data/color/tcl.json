{
  "language": "tcl",
  "colorPatterns": [
    {
      "pattern": "[\"']#([0-9a-fA-F]{6})[\"']",
      "format": "hex6_string",
      "description": "Hex color in string literal (#rrggbb)."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{3})[\"']",
      "format": "hex3_string",
      "description": "Short hex in string literal."
    },
    {
      "pattern": "0x([0-9a-fA-F]{6})\\b",
      "format": "hex_literal",
      "description": "Hex integer color (0xRRGGBB)."
    },
    {
      "pattern": "rgb\\(\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*\\)",
      "format": "rgb",
      "description": "RGB with comma-separated integers (0-255)."
    },
    {
      "pattern": "\\b(?:red|green|blue|white|black|yellow|cyan|magenta|orange|purple|pink|gray|brown|navy|teal|maroon|olive|coral|gold|salmon|violet|turquoise|khaki|indigo|ivory|lavender|linen|beige)\\b",
      "format": "tk-named",
      "description": "Tk X11 color name."
    },
    {
      "pattern": "-(?:foreground|background|activebackground|activeforeground|selectbackground|highlightcolor|insertbackground)\\s+([\\w#]+)",
      "format": "tk-option",
      "description": "Tk widget color option."
    }
  ],
  "colorPresentations": [
    "hex6",
    "rgb",
    "named"
  ],
  "namedColors": {
