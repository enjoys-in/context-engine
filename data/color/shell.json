{
  "language": "shell",
  "colorPatterns": [
    {
      "pattern": "[\"']#([0-9a-fA-F]{6})[\"']",
      "format": "hex6_string",
      "description": "Hex color in string literal (#rrggbb)."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{3})[\"']",
      "format": "hex3_string",
      "description": "Short hex in string literal."
    },
    {
      "pattern": "\\\\033\\[\\d+(?:;\\d+)*m|\\\\e\\[\\d+(?:;\\d+)*m|\\\\x1b\\[\\d+(?:;\\d+)*m",
      "format": "ansi-escape",
      "description": "ANSI escape color code."
    },
    {
      "pattern": "\\\\033\\[38;2;(\\d+);(\\d+);(\\d+)m",
      "format": "ansi-truecolor-fg",
      "description": "ANSI 24-bit truecolor fg."
    },
    {
      "pattern": "\\\\033\\[48;2;(\\d+);(\\d+);(\\d+)m",
      "format": "ansi-truecolor-bg",
      "description": "ANSI 24-bit truecolor bg."
    },
    {
      "pattern": "\\\\033\\[38;5;(\\d+)m",
      "format": "ansi-256-fg",
      "description": "ANSI 256-color fg."
    },
    {
      "pattern": "\\\\033\\[48;5;(\\d+)m",
      "format": "ansi-256-bg",
      "description": "ANSI 256-color bg."
    },
    {
      "pattern": "tput\\s+setaf\\s+(\\d+)|tput\\s+setab\\s+(\\d+)",
      "format": "tput-color",
      "description": "tput color command."
    }
  ],
  "colorPresentations": [
    "ansi-escape",
    "hex6"
  ],
  "namedColors": {
    "RED": "\\033[0;31m",
    "GREEN": "\\033[0;32m",
    "BLUE": "\\033[0;34m",
    "YELLOW": "\\033[0;33m",
    "WHITE": "\\033[0;37m",
    "BLACK": "\\033[0;30m",
    "NC": "\\033[0m"
  }
}
