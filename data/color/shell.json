{
  "language": "shell",
  "colorPatterns": [
    {
      "pattern": "[\"']#([0-9a-fA-F]{6})[\"']",
      "format": "hex6_string",
      "description": "Hex color in string literal (#rrggbb)."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{3})[\"']",
      "format": "hex3_string",
      "description": "Short hex in string literal."
    },
    {
      "pattern": "\\\\033\\[\\d+(?:;\\d+)*m|\\\\e\\[\\d+(?:;\\d+)*m|\\\\x1b\\[\\d+(?:;\\d+)*m",
      "format": "ansi-escape",
      "description": "ANSI escape color code."
    },
    {
      "pattern": "\\\\033\\[38;2;(\\d+);(\\d+);(\\d+)m",
      "format": "ansi-truecolor-fg",
      "description": "ANSI 24-bit truecolor fg."
    },
    {
      "pattern": "\\\\033\\[48;2;(\\d+);(\\d+);(\\d+)m",
      "format": "ansi-truecolor-bg",
      "description": "ANSI 24-bit truecolor bg."
    },
    {
      "pattern": "\\\\033\\[38;5;(\\d+)m",
      "format": "ansi-256-fg",
      "description": "ANSI 256-color fg."
    },
    {
      "pattern": "\\\\033\\[48;5;(\\d+)m",
      "format": "ansi-256-bg",
      "description": "ANSI 256-color bg."
    },
    {
      "pattern": "tput\\s+setaf\\s+(\\d+)|tput\\s+setab\\s+(\\d+)",
      "format": "tput-color",
      "description": "tput color command."
    },
    {
      "pattern": "#([0-9a-fA-F]{3})\\\\b",
      "format": "hex3",
      "description": "3-digit hex color (#rgb)"
    },
    {
      "pattern": "#([0-9a-fA-F]{6})\\\\b",
      "format": "hex6",
      "description": "6-digit hex color (#rrggbb)"
    },
    {
      "pattern": "#([0-9a-fA-F]{8})\\\\b",
      "format": "hex8",
      "description": "8-digit hex color with alpha (#rrggbbaa)"
    },
    {
      "pattern": "rgb\\\\(\\\\s*\\\\d+\\\\s*,\\\\s*\\\\d+\\\\s*,\\\\s*\\\\d+\\\\s*\\\\)",
      "format": "rgb",
      "description": "RGB function notation"
    },
    {
      "pattern": "rgba\\\\(\\\\s*\\\\d+\\\\s*,\\\\s*\\\\d+\\\\s*,\\\\s*\\\\d+\\\\s*,\\\\s*[\\\\d.]+\\\\s*\\\\)",
      "format": "rgba",
      "description": "RGBA function notation"
    },
    {
      "pattern": "hsl\\\\(\\\\s*\\\\d+\\\\s*,\\\\s*\\\\d+%?\\\\s*,\\\\s*\\\\d+%?\\\\s*\\\\)",
      "format": "hsl",
      "description": "HSL function notation"
    },
    {
      "pattern": "hsla\\\\(\\\\s*\\\\d+\\\\s*,\\\\s*\\\\d+%?\\\\s*,\\\\s*\\\\d+%?\\\\s*,\\\\s*[\\\\d.]+\\\\s*\\\\)",
      "format": "hsla",
      "description": "HSLA function notation"
    },
    {
      "pattern": "oklch\\\\(\\\\s*[\\\\d.]+%?\\\\s+[\\\\d.]+\\\\s+[\\\\d.]+\\\\s*\\\\)",
      "format": "oklch",
      "description": "OKLCH color function"
    },
    {
      "pattern": "color\\\\(\\\\s*srgb\\\\s+[\\\\d.]+\\\\s+[\\\\d.]+\\\\s+[\\\\d.]+\\\\s*\\\\)",
      "format": "color-srgb",
      "description": "CSS color() with sRGB"
    },
    {
      "pattern": "hwb\\\\(\\\\s*\\\\d+\\\\s+\\\\d+%\\\\s+\\\\d+%\\\\s*\\\\)",
      "format": "hwb",
      "description": "HWB color notation"
    }
  ],
  "colorPresentations": [
    "hex6",
    "hex8",
    "rgb",
    "rgb-modern",
    "hsl",
    "hsl-modern",
    "oklch",
    "named"
  ],
  "namedColors": {
    "red": "#FF0000",
    "green": "#008000",
    "blue": "#0000FF",
    "white": "#FFFFFF",
    "black": "#000000",
    "yellow": "#FFFF00",
    "cyan": "#00FFFF",
    "magenta": "#FF00FF",
    "orange": "#FFA500",
    "purple": "#800080",
    "pink": "#FFC0CB",
    "brown": "#A52A2A",
    "gray": "#808080",
    "grey": "#808080",
    "silver": "#C0C0C0",
    "gold": "#FFD700",
    "navy": "#000080",
    "teal": "#008080",
    "maroon": "#800000",
    "olive": "#808000",
    "lime": "#00FF00",
    "aqua": "#00FFFF",
    "coral": "#FF7F50",
    "salmon": "#FA8072",
    "indigo": "#4B0082",
    "violet": "#EE82EE",
    "turquoise": "#40E0D0",
