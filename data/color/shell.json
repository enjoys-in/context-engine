    "transparent": "rgba(0,0,0,0)",
    "currentColor": "currentColor",
    "RED": "\\033[0;31m",
    "GREEN": "\\033[0;32m",
    "BLUE": "\\033[0;34m",
    "YELLOW": "\\033[0;33m",
    "WHITE": "\\033[0;37m",
    "BLACK": "\\033[0;30m",
    "NC": "\\033[0m"
  }
}
