    "42": "bg green",
    "43": "bg yellow",
    "44": "bg blue",
    "45": "bg magenta",
    "46": "bg cyan",
    "47": "bg white",
    "90": "bright black",
    "91": "bright red",
    "92": "bright green",
    "93": "bright yellow",
    "94": "bright blue",
    "95": "bright magenta",
    "96": "bright cyan",
    "97": "bright white"
  }
}
