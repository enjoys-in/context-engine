{
  "language": "java",
  "colorPatterns": [
    {
      "pattern": "[\"']#([0-9a-fA-F]{3})[\"']",
      "format": "hex3_string",
      "description": "Short hex in string literal."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{6})[\"']",
      "format": "hex6_string",
      "description": "Hex color in string literal (#rrggbb)."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{8})[\"']",
      "format": "hex8_string",
      "description": "Hex+alpha in string literal."
    },
    {
      "pattern": "0x([0-9a-fA-F]{6})\\b",
      "format": "hex_literal",
      "description": "Hex integer color (0xRRGGBB)."
    },
    {
      "pattern": "0x([0-9a-fA-F]{8})\\b",
      "format": "hex_literal_alpha",
      "description": "Hex integer+alpha (0xAARRGGBB)."
    },
    {
      "pattern": "rgb\\(\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*\\)",
      "format": "rgb",
      "description": "RGB with comma-separated integers (0-255)."
    },
    {
      "pattern": "rgba\\(\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*([0-9.]+)\\s*\\)",
      "format": "rgba",
      "description": "RGBA with alpha (0-1)."
    },
    {
      "pattern": "Color\\.(?:RED|GREEN|BLUE|WHITE|BLACK|YELLOW|CYAN|MAGENTA|ORANGE|PINK|GRAY|DARK_GRAY|LIGHT_GRAY)\\b",
      "format": "awt-constant",
      "description": "java.awt.Color constant."
    },
    {
      "pattern": "new\\s+Color\\(\\s*(\\d+)\\s*,\\s*(\\d+)\\s*,\\s*(\\d+)(?:\\s*,\\s*(\\d+))?\\s*\\)",
      "format": "awt-constructor",
      "description": "java.awt.Color RGB(A) constructor."
    },
    {
      "pattern": "new\\s+Color\\(\\s*0x[0-9a-fA-F]+\\s*\\)",
      "format": "awt-hex-constructor",
      "description": "java.awt.Color hex constructor."
    },
    {
      "pattern": "Color\\.decode\\(\\s*[\"']([^\"']+)[\"']\\s*\\)",
      "format": "awt-decode",
      "description": "Color.decode(String)."
    },
    {
      "pattern": "Color\\.getHSBColor\\(\\s*([0-9.]+)f?\\s*,\\s*([0-9.]+)f?\\s*,\\s*([0-9.]+)f?\\s*\\)",
      "format": "awt-hsb",
      "description": "Color.getHSBColor()."
    },
    {
      "pattern": "(?:javafx\\.scene\\.paint\\.)?Color\\.(?:web|valueOf|color|rgb|hsb|gray)\\(",
      "format": "javafx-factory",
      "description": "JavaFX Color factory."
    },
    {
      "pattern": "Color\\.parseColor\\(\\s*[\"']([^\"']+)[\"']\\s*\\)",
      "format": "android-parse",
      "description": "Android Color.parseColor()."
    },
    {
      "pattern": "Color\\.(?:RED|GREEN|BLUE|WHITE|BLACK|YELLOW|CYAN|MAGENTA|TRANSPARENT|GRAY|DKGRAY|LTGRAY)\\b",
      "format": "android-constant",
      "description": "Android Color constant."
    }
  ],
  "colorPresentations": [
    "hex6",
    "hex8",
    "rgb",
    "rgba"
  ],
  "namedColors": {
    "red": "#FF0000",
    "green": "#008000",
    "blue": "#0000FF",
    "white": "#FFFFFF",
    "black": "#000000",
    "yellow": "#FFFF00",
    "cyan": "#00FFFF",
    "magenta": "#FF00FF",
    "orange": "#FFA500",
    "purple": "#800080",
    "gray": "#808080",
    "transparent": "rgba(0,0,0,0)",
    "darkGray": "#404040",
    "lightGray": "#C0C0C0"
  }
}
