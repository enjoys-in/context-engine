{
  "language": "lua",
  "colorPatterns": [
    {
      "pattern": "[\"']#([0-9a-fA-F]{6})[\"']",
      "format": "hex6_string",
      "description": "Hex color in string literal (#rrggbb)."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{3})[\"']",
      "format": "hex3_string",
      "description": "Short hex in string literal."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{8})[\"']",
      "format": "hex8_string",
      "description": "Hex+alpha in string literal."
    },
    {
      "pattern": "0x([0-9a-fA-F]{6})\\b",
      "format": "hex_literal",
      "description": "Hex integer color (0xRRGGBB)."
    },
    {
      "pattern": "\\{\\s*(\\d+(?:\\.\\d+)?)\\s*,\\s*(\\d+(?:\\.\\d+)?)\\s*,\\s*(\\d+(?:\\.\\d+)?)(?:\\s*,\\s*(\\d+(?:\\.\\d+)?))?\\s*\\}",
      "format": "table-rgba",
      "description": "Lua table {r, g, b[, a]}."
    },
    {
      "pattern": "love\\.graphics\\.setColor\\(\\s*([0-9.]+)\\s*,\\s*([0-9.]+)\\s*,\\s*([0-9.]+)(?:\\s*,\\s*([0-9.]+))?\\s*\\)",
      "format": "love-setcolor",
      "description": "LOVE2D setColor (0-1)."
    },
    {
      "pattern": "Color3\\.fromRGB\\(\\s*(\\d+)\\s*,\\s*(\\d+)\\s*,\\s*(\\d+)\\s*\\)",
      "format": "roblox-fromrgb",
      "description": "Roblox Color3.fromRGB()."
    },
    {
      "pattern": "Color3\\.fromHSV\\(\\s*([0-9.]+)\\s*,\\s*([0-9.]+)\\s*,\\s*([0-9.]+)\\s*\\)",
      "format": "roblox-fromhsv",
      "description": "Roblox Color3.fromHSV()."
    },
    {
      "pattern": "Color3\\.new\\(\\s*([0-9.]+)\\s*,\\s*([0-9.]+)\\s*,\\s*([0-9.]+)\\s*\\)",
      "format": "roblox-new",
      "description": "Roblox Color3.new (0-1)."
    },
    {
      "pattern": "BrickColor\\.new\\(\\s*[\"']([^\"']+)[\"']\\s*\\)",
      "format": "roblox-brick",
      "description": "Roblox BrickColor by name."
    },
    {
      "pattern": "#([0-9a-fA-F]{3})\\\\b",
      "format": "hex3",
      "description": "3-digit hex color (#rgb)"
    },
    {
      "pattern": "#([0-9a-fA-F]{6})\\\\b",
      "format": "hex6",
      "description": "6-digit hex color (#rrggbb)"
    },
    {
      "pattern": "#([0-9a-fA-F]{8})\\\\b",
      "format": "hex8",
      "description": "8-digit hex color with alpha (#rrggbbaa)"
    },
    {
      "pattern": "rgb\\\\(\\\\s*\\\\d+\\\\s*,\\\\s*\\\\d+\\\\s*,\\\\s*\\\\d+\\\\s*\\\\)",
      "format": "rgb",
      "description": "RGB function notation"
    },
    {
      "pattern": "rgba\\\\(\\\\s*\\\\d+\\\\s*,\\\\s*\\\\d+\\\\s*,\\\\s*\\\\d+\\\\s*,\\\\s*[\\\\d.]+\\\\s*\\\\)",
      "format": "rgba",
      "description": "RGBA function notation"
    },
    {
      "pattern": "hsl\\\\(\\\\s*\\\\d+\\\\s*,\\\\s*\\\\d+%?\\\\s*,\\\\s*\\\\d+%?\\\\s*\\\\)",
      "format": "hsl",
      "description": "HSL function notation"
    },
    {
      "pattern": "hsla\\\\(\\\\s*\\\\d+\\\\s*,\\\\s*\\\\d+%?\\\\s*,\\\\s*\\\\d+%?\\\\s*,\\\\s*[\\\\d.]+\\\\s*\\\\)",
      "format": "hsla",
      "description": "HSLA function notation"
    },
    {
      "pattern": "oklch\\\\(\\\\s*[\\\\d.]+%?\\\\s+[\\\\d.]+\\\\s+[\\\\d.]+\\\\s*\\\\)",
      "format": "oklch",
      "description": "OKLCH color function"
    },
    {
      "pattern": "color\\\\(\\\\s*srgb\\\\s+[\\\\d.]+\\\\s+[\\\\d.]+\\\\s+[\\\\d.]+\\\\s*\\\\)",
      "format": "color-srgb",
      "description": "CSS color() with sRGB"
    },
    {
      "pattern": "hwb\\\\(\\\\s*\\\\d+\\\\s+\\\\d+%\\\\s+\\\\d+%\\\\s*\\\\)",
      "format": "hwb",
      "description": "HWB color notation"
    }
  ],
  "colorPresentations": [
    "hex6",
    "hex8",
    "rgb",
    "rgb-modern",
    "hsl",
    "hsl-modern",
    "oklch",
    "named"
  ],
  "namedColors": {
    "red": "#FF0000",
    "green": "#008000",
    "blue": "#0000FF",
    "white": "#FFFFFF",
    "black": "#000000",
    "yellow": "#FFFF00",
    "cyan": "#00FFFF",
    "magenta": "#FF00FF",
    "orange": "#FFA500",
    "purple": "#800080",
    "pink": "#FFC0CB",
    "brown": "#A52A2A",
    "gray": "#808080",
    "grey": "#808080",
    "silver": "#C0C0C0",
    "gold": "#FFD700",
    "navy": "#000080",
    "teal": "#008080",
    "maroon": "#800000",
    "olive": "#808000",
    "lime": "#00FF00",
    "aqua": "#00FFFF",
    "coral": "#FF7F50",
    "salmon": "#FA8072",
    "indigo": "#4B0082",
    "violet": "#EE82EE",
    "turquoise": "#40E0D0",
    "tan": "#D2B48C",
    "transparent": "rgba(0,0,0,0)",
    "currentColor": "currentColor"
  }
}
