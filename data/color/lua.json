{
  "language": "lua",
  "colorPatterns": [
    {
      "pattern": "#([0-9a-fA-F]{6})\\b",
      "format": "hex6",
      "description": "6-digit hex color (#RRGGBB)"
    },
    {
      "pattern": "#([0-9a-fA-F]{3})\\b",
      "format": "hex3",
      "description": "3-digit shorthand hex color (#RGB)"
    },
    {
      "pattern": "0x([0-9a-fA-F]{6})\\b",
      "format": "hex_literal",
      "description": "Hex color literal (0xRRGGBB)"
    },
    {
      "pattern": "0x([0-9a-fA-F]{8})\\b",
      "format": "hex_literal_alpha",
      "description": "Hex color literal with alpha (0xAARRGGBB)"
    },
    {
      "kind": "hex",
      "pattern": "#(?:[0-9a-fA-F]{3,4}){1,2}\\b",
      "description": "Hex color (#RGB, #RGBA, #RRGGBB, #RRGGBBAA)"
    },
    {
      "kind": "rgb",
      "pattern": "rgba?\\(\\s*\\d+\\s*,\\s*\\d+\\s*,\\s*\\d+",
      "description": "RGB/RGBA color function"
    }
  ],
  "colorPresentations": [
    "hex",
    "hex_literal"
  ],
  "namedColors": {}
}
