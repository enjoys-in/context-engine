{
  "language": "c",
  "colorPatterns": [
    {
      "pattern": "0x([0-9a-fA-F]{6})\\b",
      "format": "hex_literal",
      "description": "Hex integer color (0xRRGGBB)."
    },
    {
      "pattern": "0x([0-9a-fA-F]{8})\\b",
      "format": "hex_literal_alpha",
      "description": "Hex integer+alpha (0xAARRGGBB)."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{6})[\"']",
      "format": "hex6_string",
      "description": "Hex color in string literal (#rrggbb)."
    },
    {
      "pattern": "[\"']#([0-9a-fA-F]{3})[\"']",
      "format": "hex3_string",
      "description": "Short hex in string literal."
    },
    {
      "pattern": "\\{\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})(?:\\s*,\\s*(\\d{1,3}))?\\s*\\}",
      "format": "struct-rgba",
      "description": "Color struct {r, g, b[, a]}."
    },
    {
      "pattern": "SDL_Color\\s*\\{\\s*(\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+)\\s*\\}",
      "format": "sdl-color",
      "description": "SDL_Color struct."
    },
    {
      "pattern": "(?:COLORREF|RGB|RGBA|COLOR)\\s*\\(\\s*(\\d+)\\s*,\\s*(\\d+)\\s*,\\s*(\\d+)",
      "format": "win32-color",
      "description": "Win32 RGB macro."
    },
    {
      "pattern": "ImVec4\\(\\s*([0-9.]+)f?\\s*,\\s*([0-9.]+)f?\\s*,\\s*([0-9.]+)f?\\s*,\\s*([0-9.]+)f?\\s*\\)",
      "format": "imgui-color",
      "description": "ImGui ImVec4 color."
    },
    {
      "pattern": "GdkRGBA\\s*\\{\\s*([0-9.]+)\\s*,\\s*([0-9.]+)\\s*,\\s*([0-9.]+)\\s*,\\s*([0-9.]+)\\s*\\}",
      "format": "gtk-color",
      "description": "GTK GdkRGBA."
    },
    {
      "pattern": "\\\\033\\[\\d+(?:;\\d+)*m|\\\\e\\[\\d+(?:;\\d+)*m",
      "format": "ansi-escape",
      "description": "ANSI escape color."
    }
  ],
  "colorPresentations": [
    "hex6",
    "hex8",
    "rgb"
  ],
  "namedColors": {
    "red": "#FF0000",
    "green": "#008000",
    "blue": "#0000FF",
    "white": "#FFFFFF",
    "black": "#000000",
    "yellow": "#FFFF00",
    "cyan": "#00FFFF",
    "magenta": "#FF00FF",
    "orange": "#FFA500",
    "purple": "#800080",
    "gray": "#808080",
    "transparent": "rgba(0,0,0,0)"
  }
}
