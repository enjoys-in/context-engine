{
  "language": "elixir",
  "referencePatterns": [
    {
      "symbol": "def_ref",
      "patterns": [
        "\\bdef\\s+\\w+",
        "\\bdefp\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Public and private function definitions"
    },
    {
      "symbol": "defmodule_ref",
      "patterns": [
        "\\bdefmodule\\s+[A-Z]\\w*"
      ],
      "includeDeclaration": true,
      "description": "Module definitions"
    },
    {
      "symbol": "defprotocol_ref",
      "patterns": [
        "\\bdefprotocol\\s+\\w+",
        "\\bdefimpl\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Protocol and implementation definitions"
    },
    {
      "symbol": "defmacro_ref",
      "patterns": [
        "\\bdefmacro\\s+\\w+",
        "\\bdefmacrop\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Macro definitions"
    },
    {
      "symbol": "defstruct_ref",
      "patterns": [
        "\\bdefstruct\\b",
        "\\bdefexception\\b",
        "\\bdefguard\\b"
      ],
      "includeDeclaration": true,
      "description": "Struct, exception, and guard definitions"
    },
    {
      "symbol": "module_call",
      "patterns": [
        "\\b[A-Z]\\w*\\.\\w+",
        "\\bEnum\\.\\w+",
        "\\bMap\\.\\w+",
        "\\bIO\\.\\w+",
        "\\bString\\.\\w+"
      ],
      "includeDeclaration": true,
      "description": "Module function calls (Enum.map, Map.get, IO.puts)"
    },
    {
      "symbol": "pipe_ref",
      "patterns": [
        "\\|>\\s*\\w+",
        "\\|>\\s*&\\w+"
      ],
      "includeDeclaration": true,
      "description": "Pipe operator references"
    },
    {
      "symbol": "use_import",
      "patterns": [
        "\\buse\\s+\\w+",
        "\\bimport\\s+\\w+",
        "\\balias\\s+\\w+",
        "\\brequire\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "use, import, alias, require references"
    },
    {
      "symbol": "atom_ref",
      "patterns": [
        ":\\w+",
        ":\\\"[^\"]+\\\""
      ],
      "includeDeclaration": true,
      "description": "Atom references"
    },
    {
      "symbol": "sigil_ref",
      "patterns": [
        "~[a-zA-Z](?:\\(|\\[|\\{|\\/|\\||<)"
      ],
      "includeDeclaration": true,
      "description": "Sigil references (~r, ~s, ~w, etc.)"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier",
      "includeDeclaration": false,
      "symbol": "identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference",
      "includeDeclaration": false,
      "symbol": "function_call"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference",
      "includeDeclaration": false,
      "symbol": "import"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference",
      "includeDeclaration": false,
      "symbol": "type_reference"
    },
    {
      "symbol": "import_statement",
      "patterns": [
        "(import|require|use|include|load)\\s+"
      ],
      "includeDeclaration": false,
      "description": "Import/include statement reference"
    },
    {
      "symbol": "function_definition",
      "patterns": [
        "(function|func|fn|def|sub|proc|method)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Function/method definition reference"
    },
    {
      "symbol": "class_definition",
      "patterns": [
        "(class|struct|type|interface|trait|record|enum)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Type definition reference"
    },
    {
      "symbol": "variable_declaration",
      "patterns": [
        "(var|let|const|val|my|local|dim|set)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Variable declaration reference"
    },
    {
      "symbol": "function_call",
      "patterns": [
        "\\b(\\w+)\\s*\\("
      ],
      "includeDeclaration": false,
      "description": "Function/method call reference"
    },
    {
      "symbol": "property_access",
      "patterns": [
        "\\.(\\w+)"
      ],
      "includeDeclaration": false,
      "description": "Property/field access reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_?!]*",
  "includeDeclaration": true
}
