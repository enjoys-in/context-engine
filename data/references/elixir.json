{
  "language": "elixir",
  "referencePatterns": [
    {
      "symbol": "def_ref",
      "patterns": [
        "\\bdef\\s+\\w+",
        "\\bdefp\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Public and private function definitions"
    },
    {
      "symbol": "defmodule_ref",
      "patterns": [
        "\\bdefmodule\\s+[A-Z]\\w*"
      ],
      "includeDeclaration": true,
      "description": "Module definitions"
    },
    {
      "symbol": "defprotocol_ref",
      "patterns": [
        "\\bdefprotocol\\s+\\w+",
        "\\bdefimpl\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Protocol and implementation definitions"
    },
    {
      "symbol": "defmacro_ref",
      "patterns": [
        "\\bdefmacro\\s+\\w+",
        "\\bdefmacrop\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Macro definitions"
    },
    {
      "symbol": "defstruct_ref",
      "patterns": [
        "\\bdefstruct\\b",
        "\\bdefexception\\b",
        "\\bdefguard\\b"
      ],
      "includeDeclaration": true,
      "description": "Struct, exception, and guard definitions"
    },
    {
      "symbol": "module_call",
      "patterns": [
        "\\b[A-Z]\\w*\\.\\w+",
        "\\bEnum\\.\\w+",
        "\\bMap\\.\\w+",
        "\\bIO\\.\\w+",
        "\\bString\\.\\w+"
      ],
      "includeDeclaration": true,
      "description": "Module function calls (Enum.map, Map.get, IO.puts)"
    },
    {
      "symbol": "pipe_ref",
      "patterns": [
        "\\|>\\s*\\w+",
        "\\|>\\s*&\\w+"
      ],
      "includeDeclaration": true,
      "description": "Pipe operator references"
    },
    {
      "symbol": "use_import",
      "patterns": [
        "\\buse\\s+\\w+",
        "\\bimport\\s+\\w+",
        "\\balias\\s+\\w+",
        "\\brequire\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "use, import, alias, require references"
    },
    {
      "symbol": "atom_ref",
      "patterns": [
        ":\\w+",
        ":\\\"[^\"]+\\\""
      ],
      "includeDeclaration": true,
      "description": "Atom references"
    },
    {
      "symbol": "sigil_ref",
      "patterns": [
        "~[a-zA-Z](?:\\(|\\[|\\{|\\/|\\||<)"
      ],
      "includeDeclaration": true,
      "description": "Sigil references (~r, ~s, ~w, etc.)"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_?!]*"
}
