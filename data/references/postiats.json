{
  "language": "postiats",
  "referencePatterns": [
    {
      "symbol": "fun_ref",
      "patterns": [
        "\\bfun\\s+\\w+",
        "\\bfn\\s+\\w+",
        "\\bimplement\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Function and implementation references"
    },
    {
      "symbol": "type_ref",
      "patterns": [
        "\\btypedef\\s+\\w+",
        "\\bsortdef\\s+\\w+",
        "\\bdatasort\\s+\\w+",
        "\\bdatatype\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Type, sort, and datatype definitions"
    },
    {
      "symbol": "val_ref",
      "patterns": [
        "\\bval\\s+\\w+",
        "\\bvar\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Value and variable bindings"
    },
    {
      "symbol": "staload_ref",
      "patterns": [
        "\\bstaload\\s+",
        "\\bdynload\\s+"
      ],
      "includeDeclaration": true,
      "description": "Static and dynamic load references"
    },
    {
      "symbol": "proof_ref",
      "patterns": [
        "\\bprfun\\s+\\w+",
        "\\bprval\\s+\\w+",
        "\\bpraxi\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Proof function and value references"
    },
    {
      "symbol": "extern_ref",
      "patterns": [
        "\\bextern\\s+fun\\s+\\w+",
        "\\bmacdef\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "External and macro definitions"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
