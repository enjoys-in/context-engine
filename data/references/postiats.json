{
  "language": "postiats",
  "referencePatterns": [
    {
      "symbol": "fun_ref",
      "patterns": [
        "\\bfun\\s+\\w+",
        "\\bfn\\s+\\w+",
        "\\bimplement\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Function and implementation references"
    },
    {
      "symbol": "type_ref",
      "patterns": [
        "\\btypedef\\s+\\w+",
        "\\bsortdef\\s+\\w+",
        "\\bdatasort\\s+\\w+",
        "\\bdatatype\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Type, sort, and datatype definitions"
    },
    {
      "symbol": "val_ref",
      "patterns": [
        "\\bval\\s+\\w+",
        "\\bvar\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Value and variable bindings"
    },
    {
      "symbol": "staload_ref",
      "patterns": [
        "\\bstaload\\s+",
        "\\bdynload\\s+"
      ],
      "includeDeclaration": true,
      "description": "Static and dynamic load references"
    },
    {
      "symbol": "proof_ref",
      "patterns": [
        "\\bprfun\\s+\\w+",
        "\\bprval\\s+\\w+",
        "\\bpraxi\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Proof function and value references"
    },
    {
      "symbol": "extern_ref",
      "patterns": [
        "\\bextern\\s+fun\\s+\\w+",
        "\\bmacdef\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "External and macro definitions"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    },
    {
      "kind": "comment_reference",
      "pattern": "@(?:see|link|param|returns?)\\s+(\\w+)",
      "description": "Documentation reference"
    },
    {
      "kind": "decorator",
      "pattern": "@(\\w+)",
      "description": "Decorator/annotation reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "includeDeclaration": true
}
