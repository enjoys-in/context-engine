{
  "language": "twig",
  "referencePatterns": [
    {
      "symbol": "tag_ref",
      "patterns": [
        "\\{%[-~]?\\s*\\w+",
        "\\{%[-~]?\\s*end\\w+"
      ],
      "includeDeclaration": true,
      "description": "Twig tag references ({% block %}, {% if %}, {% for %})"
    },
    {
      "symbol": "output_ref",
      "patterns": [
        "\\{\\{\\s*[^}]+\\s*\\}\\}"
      ],
      "includeDeclaration": true,
      "description": "Output references ({{ variable }})"
    },
    {
      "symbol": "filter_ref",
      "patterns": [
        "\\|\\s*\\w+(?:\\([^)]*\\))?"
      ],
      "includeDeclaration": true,
      "description": "Filter references (|escape, |date, |raw)"
    },
    {
      "symbol": "function_ref",
      "patterns": [
        "\\b(range|cycle|constant|random|min|max|date|dump|template_from_string|block|parent|source|attribute)\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Built-in function references"
    },
    {
      "symbol": "block_ref",
      "patterns": [
        "\\{%\\s*block\\s+\\w+",
        "\\bblock\\s*\\(\\s*'\\w+'\\s*\\)"
      ],
      "includeDeclaration": true,
      "description": "Block definitions and block() function calls"
    },
    {
      "symbol": "include_ref",
      "patterns": [
        "\\{%\\s*include\\s+'[^']+'",
        "\\{%\\s*extends\\s+'[^']+'",
        "\\{%\\s*embed\\s+'[^']+'",
        "\\{%\\s*use\\s+'[^']+'"
      ],
      "includeDeclaration": true,
      "description": "Include, extends, embed, and use references"
    },
    {
      "symbol": "macro_ref",
      "patterns": [
        "\\{%\\s*macro\\s+\\w+",
        "\\{%\\s*import\\s+'[^']+'",
        "\\b_self\\.\\w+"
      ],
      "includeDeclaration": true,
      "description": "Macro definitions and imports"
    },
    {
      "symbol": "test_ref",
      "patterns": [
        "\\bis\\s+(defined|divisibleby|empty|even|odd|iterable|null|none|sameas)\\b"
      ],
      "includeDeclaration": true,
      "description": "Twig test references (is defined, is empty)"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "includeDeclaration": true
}
