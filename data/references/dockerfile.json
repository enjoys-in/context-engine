{
  "language": "dockerfile",
  "referencePatterns": [
    {
      "symbol": "from_ref",
      "patterns": [
        "^FROM\\s+\\S+",
        "FROM\\s+\\S+\\s+AS\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "FROM image and build stage references"
    },
    {
      "symbol": "run_ref",
      "patterns": [
        "^RUN\\s+.+"
      ],
      "includeDeclaration": true,
      "description": "RUN command references"
    },
    {
      "symbol": "copy_add",
      "patterns": [
        "^COPY\\s+",
        "^ADD\\s+",
        "--from=\\w+"
      ],
      "includeDeclaration": true,
      "description": "COPY and ADD with multi-stage --from references"
    },
    {
      "symbol": "env_ref",
      "patterns": [
        "^ENV\\s+\\w+",
        "\\$\\{?\\w+\\}?",
        "^ARG\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "ENV/ARG definitions and variable references"
    },
    {
      "symbol": "expose_ref",
      "patterns": [
        "^EXPOSE\\s+\\d+"
      ],
      "includeDeclaration": true,
      "description": "EXPOSE port references"
    },
    {
      "symbol": "cmd_entry",
      "patterns": [
        "^CMD\\s+",
        "^ENTRYPOINT\\s+"
      ],
      "includeDeclaration": true,
      "description": "CMD and ENTRYPOINT references"
    },
    {
      "symbol": "workdir_ref",
      "patterns": [
        "^WORKDIR\\s+\\S+"
      ],
      "includeDeclaration": true,
      "description": "WORKDIR path references"
    },
    {
      "symbol": "label_ref",
      "patterns": [
        "^LABEL\\s+\\S+",
        "^HEALTHCHECK\\s+"
      ],
      "includeDeclaration": true,
      "description": "LABEL and HEALTHCHECK directives"
    },
    {
      "symbol": "stage_ref",
      "patterns": [
        "\\bAS\\s+\\w+",
        "--from=\\w+"
      ],
      "includeDeclaration": true,
      "description": "Multi-stage build name references"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_.-]*",
  "includeDeclaration": true
}
