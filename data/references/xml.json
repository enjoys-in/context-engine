{
  "language": "xml",
  "referencePatterns": [
    {
      "symbol": "element_ref",
      "patterns": [
        "<\\/?[a-zA-Z_][\\w:.-]*",
        "<[a-zA-Z_][\\w:.-]*\\s"
      ],
      "includeDeclaration": true,
      "description": "XML element/tag references"
    },
    {
      "symbol": "attribute_ref",
      "patterns": [
        "\\b[a-zA-Z_][\\w:.-]*\\s*=\\s*[\"']"
      ],
      "includeDeclaration": true,
      "description": "XML attribute references"
    },
    {
      "symbol": "namespace_ref",
      "patterns": [
        "xmlns(?::\\w+)?\\s*=\\s*[\"'][^\"']+[\"']",
        "\\w+:\\w+"
      ],
      "includeDeclaration": true,
      "description": "Namespace declarations and prefixed names"
    },
    {
      "symbol": "entity_ref",
      "patterns": [
        "&\\w+;",
        "&#\\d+;",
        "&#x[0-9a-fA-F]+;"
      ],
      "includeDeclaration": true,
      "description": "Entity references (&amp;, &#123;)"
    },
    {
      "symbol": "processing_instr",
      "patterns": [
        "<\\?\\w+",
        "\\?>"
      ],
      "includeDeclaration": true,
      "description": "Processing instruction references (<?xml, <?xsl)"
    },
    {
      "symbol": "cdata_comment",
      "patterns": [
        "<!\\[CDATA\\[",
        "<!--"
      ],
      "includeDeclaration": true,
      "description": "CDATA and comment references"
    },
    {
      "symbol": "dtd_ref",
      "patterns": [
        "<!DOCTYPE\\s+\\w+",
        "<!ELEMENT\\s+\\w+",
        "<!ATTLIST\\s+\\w+",
        "<!ENTITY\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "DTD declaration references"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    },
    {
      "kind": "comment_reference",
      "pattern": "@(?:see|link|param|returns?)\\s+(\\w+)",
      "description": "Documentation reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_:.-]*",
  "includeDeclaration": true
}
