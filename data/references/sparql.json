{
  "language": "sparql",
  "referencePatterns": [
    {
      "symbol": "query_form",
      "patterns": [
        "\\bSELECT\\b",
        "\\bCONSTRUCT\\b",
        "\\bASK\\b",
        "\\bDESCRIBE\\b"
      ],
      "includeDeclaration": true,
      "description": "Query form references"
    },
    {
      "symbol": "where_clause",
      "patterns": [
        "\\bWHERE\\b",
        "\\bOPTIONAL\\b",
        "\\bFILTER\\b",
        "\\bBIND\\b",
        "\\bVALUES\\b",
        "\\bMINUS\\b"
      ],
      "includeDeclaration": true,
      "description": "WHERE clause and pattern references"
    },
    {
      "symbol": "update_ref",
      "patterns": [
        "\\bINSERT\\b",
        "\\bDELETE\\b",
        "\\bLOAD\\b",
        "\\bCLEAR\\b",
        "\\bDROP\\b",
        "\\bCREATE\\b"
      ],
      "includeDeclaration": true,
      "description": "SPARQL Update references"
    },
    {
      "symbol": "prefix_ref",
      "patterns": [
        "\\bPREFIX\\s+\\w*:",
        "\\bBASE\\s+<"
      ],
      "includeDeclaration": true,
      "description": "PREFIX and BASE declarations"
    },
    {
      "symbol": "variable_ref",
      "patterns": [
        "\\?\\w+",
        "\\$\\w+"
      ],
      "includeDeclaration": true,
      "description": "SPARQL variable references (?var, $var)"
    },
    {
      "symbol": "iri_ref",
      "patterns": [
        "<[^>]+>",
        "\\w+:\\w+"
      ],
      "includeDeclaration": true,
      "description": "IRI and prefixed name references"
    },
    {
      "symbol": "service_ref",
      "patterns": [
        "\\bSERVICE\\b",
        "\\bGRAPH\\b",
        "\\bFROM\\s+NAMED\\b",
        "\\bFROM\\b"
      ],
      "includeDeclaration": true,
      "description": "SERVICE and graph references"
    },
    {
      "symbol": "aggregate_ref",
      "patterns": [
        "\\b(COUNT|SUM|AVG|MIN|MAX|GROUP_CONCAT|SAMPLE)\\s*\\(",
        "\\bGROUP\\s+BY\\b",
        "\\bHAVING\\b",
        "\\bORDER\\s+BY\\b"
      ],
      "includeDeclaration": true,
      "description": "Aggregate function and grouping references"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "includeDeclaration": true
}
