{
  "language": "html",
  "referencePatterns": [
    {
      "symbol": "tag_ref",
      "patterns": [
        "<\\/?[a-zA-Z][a-zA-Z0-9-]*",
        "<[a-zA-Z][a-zA-Z0-9-]*\\s"
      ],
      "includeDeclaration": true,
      "description": "HTML element/tag references"
    },
    {
      "symbol": "attribute_ref",
      "patterns": [
        "\\b[a-z][a-z-]*\\s*=",
        "\\bdata-[a-z-]+=",
        "\\baria-[a-z-]+="
      ],
      "includeDeclaration": true,
      "description": "Attribute references (class=, data-*, aria-*)"
    },
    {
      "symbol": "id_ref",
      "patterns": [
        "\\bid\\s*=\\s*[\"'][^\"']+[\"']",
        "#[a-zA-Z][a-zA-Z0-9_-]*"
      ],
      "includeDeclaration": true,
      "description": "ID attribute references and #id selectors"
    },
    {
      "symbol": "class_ref",
      "patterns": [
        "\\bclass\\s*=\\s*[\"'][^\"']+[\"']",
        "\\.[a-zA-Z][a-zA-Z0-9_-]*"
      ],
      "includeDeclaration": true,
      "description": "Class attribute references"
    },
    {
      "symbol": "href_ref",
      "patterns": [
        "\\bhref\\s*=\\s*[\"'][^\"']*[\"']",
        "\\bsrc\\s*=\\s*[\"'][^\"']*[\"']"
      ],
      "includeDeclaration": true,
      "description": "Href and src link references"
    },
    {
      "symbol": "event_ref",
      "patterns": [
        "\\bon\\w+\\s*="
      ],
      "includeDeclaration": true,
      "description": "Inline event handler references (onclick, onload)"
    },
    {
      "symbol": "entity_ref",
      "patterns": [
        "&\\w+;",
        "&#\\d+;",
        "&#x[0-9a-fA-F]+;"
      ],
      "includeDeclaration": true,
      "description": "HTML entity references (&amp;, &#123;)"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    },
    {
      "kind": "comment_reference",
      "pattern": "@(?:see|link|param|returns?)\\s+(\\w+)",
      "description": "Documentation reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_-]*",
  "includeDeclaration": true
}
