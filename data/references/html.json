{
  "language": "html",
  "referencePatterns": [
    {
      "symbol": "tag_ref",
      "patterns": [
        "<\\/?[a-zA-Z][a-zA-Z0-9-]*",
        "<[a-zA-Z][a-zA-Z0-9-]*\\s"
      ],
      "includeDeclaration": true,
      "description": "HTML element/tag references"
    },
    {
      "symbol": "attribute_ref",
      "patterns": [
        "\\b[a-z][a-z-]*\\s*=",
        "\\bdata-[a-z-]+=",
        "\\baria-[a-z-]+="
      ],
      "includeDeclaration": true,
      "description": "Attribute references (class=, data-*, aria-*)"
    },
    {
      "symbol": "id_ref",
      "patterns": [
        "\\bid\\s*=\\s*[\"'][^\"']+[\"']",
        "#[a-zA-Z][a-zA-Z0-9_-]*"
      ],
      "includeDeclaration": true,
      "description": "ID attribute references and #id selectors"
    },
    {
      "symbol": "class_ref",
      "patterns": [
        "\\bclass\\s*=\\s*[\"'][^\"']+[\"']",
        "\\.[a-zA-Z][a-zA-Z0-9_-]*"
      ],
      "includeDeclaration": true,
      "description": "Class attribute references"
    },
    {
      "symbol": "href_ref",
      "patterns": [
        "\\bhref\\s*=\\s*[\"'][^\"']*[\"']",
        "\\bsrc\\s*=\\s*[\"'][^\"']*[\"']"
      ],
      "includeDeclaration": true,
      "description": "Href and src link references"
    },
    {
      "symbol": "event_ref",
      "patterns": [
        "\\bon\\w+\\s*="
      ],
      "includeDeclaration": true,
      "description": "Inline event handler references (onclick, onload)"
    },
    {
      "symbol": "entity_ref",
      "patterns": [
        "&\\w+;",
        "&#\\d+;",
        "&#x[0-9a-fA-F]+;"
      ],
      "includeDeclaration": true,
      "description": "HTML entity references (&amp;, &#123;)"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_-]*"
}
