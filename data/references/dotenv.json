{
  "language": "dotenv",
  "referencePatterns": [
    {
      "symbol": "key_def",
      "patterns": [
        "^[A-Z_][A-Z0-9_]*="
      ],
      "includeDeclaration": true,
      "description": "Environment variable key definitions"
    },
    {
      "symbol": "variable_ref",
      "patterns": [
        "\\$\\{[A-Z_][A-Z0-9_]*\\}",
        "\\$[A-Z_][A-Z0-9_]*"
      ],
      "includeDeclaration": true,
      "description": "Variable interpolation references"
    },
    {
      "symbol": "comment",
      "patterns": [
        "^#\\s*.*$"
      ],
      "includeDeclaration": true,
      "description": "Comment lines"
    },
    {
      "symbol": "url_value",
      "patterns": [
        "=\\s*https?://\\S+",
        "=\\s*\\w+://\\S+"
      ],
      "includeDeclaration": true,
      "description": "URL value references"
    }
  ],
  "identifierPattern": "[A-Z_][A-Z0-9_]*"
}
