{
  "language": "flow9",
  "referencePatterns": [
    {
      "symbol": "function_ref",
      "patterns": [
        "\\b\\w+\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Function calls"
    },
    {
      "symbol": "type_ref",
      "patterns": [
        ":\\s*\\w+",
        "->\\s*\\w+"
      ],
      "includeDeclaration": true,
      "description": "Type annotations and return types"
    },
    {
      "symbol": "import_ref",
      "patterns": [
        "\\bimport\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Import references"
    },
    {
      "symbol": "struct_ref",
      "patterns": [
        "\\b\\w+\\s*::=",
        "\\b[A-Z]\\w+\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Struct/union type references"
    },
    {
      "symbol": "variable_ref",
      "patterns": [
        "\\b\\w+\\s*=(?!=)",
        "\\b\\w+\\s*:="
      ],
      "includeDeclaration": true,
      "description": "Variable bindings and mutations"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    },
    {
      "kind": "comment_reference",
      "pattern": "@(?:see|link|param|returns?)\\s+(\\w+)",
      "description": "Documentation reference"
    },
    {
      "kind": "decorator",
      "pattern": "@(\\w+)",
      "description": "Decorator/annotation reference"
    },
    {
      "kind": "class_reference",
      "pattern": "\\b([A-Z]\\w+)\\b",
      "description": "Class/type name reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "includeDeclaration": true
}
