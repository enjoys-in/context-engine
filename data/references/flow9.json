{
  "language": "flow9",
  "referencePatterns": [
    {
      "symbol": "function_ref",
      "patterns": [
        "\\b\\w+\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Function calls"
    },
    {
      "symbol": "type_ref",
      "patterns": [
        ":\\s*\\w+",
        "->\\s*\\w+"
      ],
      "includeDeclaration": true,
      "description": "Type annotations and return types"
    },
    {
      "symbol": "import_ref",
      "patterns": [
        "\\bimport\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Import references"
    },
    {
      "symbol": "struct_ref",
      "patterns": [
        "\\b\\w+\\s*::=",
        "\\b[A-Z]\\w+\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Struct/union type references"
    },
    {
      "symbol": "variable_ref",
      "patterns": [
        "\\b\\w+\\s*=(?!=)",
        "\\b\\w+\\s*:="
      ],
      "includeDeclaration": true,
      "description": "Variable bindings and mutations"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
