{
  "language": "angular",
  "referencePatterns": [
    {
      "name": "Component",
      "pattern": "@Component\\s*\\(\\s*\\{[^}]*\\}\\s*\\)\\s*(?:export\\s+)?class\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Angular component class decorated with @Component",
      "includeDeclaration": true,
      "symbol": "Component"
    },
    {
      "name": "Injectable",
      "pattern": "@Injectable\\s*\\(\\s*\\{[^}]*\\}\\s*\\)\\s*(?:export\\s+)?class\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Angular injectable service class",
      "includeDeclaration": true,
      "symbol": "Injectable"
    },
    {
      "name": "NgModule",
      "pattern": "@NgModule\\s*\\(\\s*\\{[^}]*\\}\\s*\\)\\s*(?:export\\s+)?class\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Angular module decorated with @NgModule",
      "includeDeclaration": true,
      "symbol": "NgModule"
    },
    {
      "name": "Directive",
      "pattern": "@Directive\\s*\\(\\s*\\{[^}]*\\}\\s*\\)\\s*(?:export\\s+)?class\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Angular directive class",
      "includeDeclaration": true,
      "symbol": "Directive"
    },
    {
      "name": "Pipe",
      "pattern": "@Pipe\\s*\\(\\s*\\{[^}]*\\}\\s*\\)\\s*(?:export\\s+)?class\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Angular pipe class decorated with @Pipe",
      "includeDeclaration": true,
      "symbol": "Pipe"
    },
    {
      "name": "Input",
      "pattern": "@Input\\s*\\(\\s*[^)]*\\)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Input-bound property on a component or directive",
      "includeDeclaration": true,
      "symbol": "Input"
    },
    {
      "name": "Output",
      "pattern": "@Output\\s*\\(\\s*[^)]*\\)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Output event emitter property",
      "includeDeclaration": true,
      "symbol": "Output"
    },
    {
      "name": "ngOnInit",
      "pattern": "(ngOnInit)\\s*\\(\\s*\\)",
      "captureGroup": 1,
      "description": "OnInit lifecycle hook method",
      "includeDeclaration": true,
      "symbol": "ngOnInit"
    },
    {
      "name": "ngOnDestroy",
      "pattern": "(ngOnDestroy)\\s*\\(\\s*\\)",
      "captureGroup": 1,
      "description": "OnDestroy lifecycle hook method",
      "includeDeclaration": true,
      "symbol": "ngOnDestroy"
    },
    {
      "name": "ngOnChanges",
      "pattern": "(ngOnChanges)\\s*\\(",
      "captureGroup": 1,
      "description": "OnChanges lifecycle hook method",
      "includeDeclaration": true,
      "symbol": "ngOnChanges"
    },
    {
      "name": "ngAfterViewInit",
      "pattern": "(ngAfterViewInit)\\s*\\(\\s*\\)",
      "captureGroup": 1,
      "description": "AfterViewInit lifecycle hook method",
      "includeDeclaration": true,
      "symbol": "ngAfterViewInit"
    },
    {
      "name": "ngAfterContentInit",
      "pattern": "(ngAfterContentInit)\\s*\\(\\s*\\)",
      "captureGroup": 1,
      "description": "AfterContentInit lifecycle hook method",
      "includeDeclaration": true,
      "symbol": "ngAfterContentInit"
    },
    {
      "name": "RouteConfig",
      "pattern": "\\{\\s*path:\\s*['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "description": "Route configuration path definition",
      "includeDeclaration": true,
      "symbol": "RouteConfig"
    },
    {
      "name": "Guard",
      "pattern": "(?:canActivate|canDeactivate|canMatch|resolve):\\s*\\[([^\\]]+)\\]",
      "captureGroup": 1,
      "description": "Route guard references in route config",
      "includeDeclaration": true,
      "symbol": "Guard"
    },
    {
      "name": "Interceptor",
      "pattern": "(?:provide:\\s*HTTP_INTERCEPTORS[^}]*useClass:\\s*|withInterceptors\\s*\\(\\s*\\[\\s*)(\\w+)",
      "captureGroup": 1,
      "description": "HTTP interceptor reference",
      "includeDeclaration": true,
      "symbol": "Interceptor"
    },
    {
      "name": "ServiceInjection",
      "pattern": "(?:private|protected|public|readonly)\\s+(\\w+)\\s*:\\s*\\w+",
      "captureGroup": 1,
      "description": "Constructor-injected service reference",
      "includeDeclaration": true,
      "symbol": "ServiceInjection"
    },
    {
      "name": "FormControl",
      "pattern": "new\\s+(?:FormControl|FormGroup|FormArray)\\s*(?:<[^>]*>)?\\s*\\(([^)]*)",
      "captureGroup": 1,
      "description": "Reactive form control instantiation",
      "includeDeclaration": true,
      "symbol": "FormControl"
    },
    {
      "name": "Signal",
      "pattern": "(?:signal|computed|effect)\\s*(?:<[^>]*>)?\\s*\\(([^)]*)",
      "captureGroup": 1,
      "description": "Angular signal, computed, or effect declaration",
      "includeDeclaration": true,
      "symbol": "Signal"
    },
    {
      "name": "PipeUsage",
      "pattern": "\\|\\s*(\\w+)(?:\\s*:|\\s*\\})",
      "captureGroup": 1,
      "description": "Pipe usage in template expression",
      "includeDeclaration": true,
      "symbol": "PipeUsage"
    },
    {
      "name": "TemplateRef",
      "pattern": "#(\\w+)",
      "captureGroup": 1,
      "description": "Template reference variable",
      "includeDeclaration": true,
      "symbol": "TemplateRef"
    },
    {
      "name": "InjectFunction",
      "pattern": "inject\\s*\\(\\s*(\\w+)",
      "captureGroup": 1,
      "description": "inject() function call referencing a token",
      "includeDeclaration": true,
      "symbol": "InjectFunction"
    },
    {
      "symbol": "Array.isArray",
      "patterns": [
        "\\bArray\\.isArray\\b"
      ],
      "includeDeclaration": true,
      "description": "Array.isArray static method"
    },
    {
      "symbol": "Array.from",
      "patterns": [
        "\\bArray\\.from\\b"
      ],
      "includeDeclaration": true,
      "description": "Array.from static method"
    },
    {
      "symbol": "Object.keys",
      "patterns": [
        "\\bObject\\.keys\\b"
      ],
      "includeDeclaration": true,
      "description": "Object.keys static method"
    },
    {
      "symbol": "Object.values",
      "patterns": [
        "\\bObject\\.values\\b"
      ],
      "includeDeclaration": true,
      "description": "Object.values static method"
    },
    {
      "symbol": "Object.entries",
      "patterns": [
        "\\bObject\\.entries\\b"
      ],
      "includeDeclaration": true,
      "description": "Object.entries static method"
    },
    {
      "symbol": "Object.assign",
      "patterns": [
        "\\bObject\\.assign\\b"
      ],
      "includeDeclaration": true,
      "description": "Object.assign static method"
    },
    {
      "symbol": "Promise.all",
      "patterns": [
        "\\bPromise\\.all\\b"
      ],
      "includeDeclaration": true,
      "description": "Promise.all static method"
    },
    {
      "symbol": "Promise.resolve",
      "patterns": [
        "\\bPromise\\.resolve\\b"
      ],
      "includeDeclaration": true,
      "description": "Promise.resolve static method"
    },
    {
      "symbol": "JSON.stringify",
      "patterns": [
        "\\bJSON\\.stringify\\b"
      ],
      "includeDeclaration": true,
      "description": "JSON.stringify method"
    },
    {
      "symbol": "JSON.parse",
      "patterns": [
        "\\bJSON\\.parse\\b"
      ],
      "includeDeclaration": true,
      "description": "JSON.parse method"
    },
    {
      "symbol": "Math.floor",
      "patterns": [
        "\\bMath\\.floor\\b"
      ],
      "includeDeclaration": true,
      "description": "Math.floor method"
    },
    {
      "symbol": "Math.random",
      "patterns": [
        "\\bMath\\.random\\b"
      ],
      "includeDeclaration": true,
      "description": "Math.random method"
    },
    {
      "symbol": "setTimeout",
      "patterns": [
        "\\bsetTimeout\\b"
      ],
      "includeDeclaration": true,
      "description": "setTimeout global function"
    },
    {
      "symbol": "setInterval",
      "patterns": [
        "\\bsetInterval\\b"
      ],
      "includeDeclaration": true,
      "description": "setInterval global function"
    },
    {
      "symbol": "addEventListener",
      "patterns": [
        "\\baddEventListener\\b"
      ],
      "includeDeclaration": true,
      "description": "addEventListener method"
    },
    {
      "symbol": "querySelector",
      "patterns": [
        "\\bquerySelector\\b"
      ],
      "includeDeclaration": true,
      "description": "querySelector method"
    },
    {
      "symbol": "getElementById",
      "patterns": [
        "\\bgetElementById\\b"
      ],
      "includeDeclaration": true,
      "description": "getElementById method"
    },
    {
      "symbol": "createElement",
      "patterns": [
        "\\bcreateElement\\b"
      ],
      "includeDeclaration": true,
      "description": "createElement method"
    },
    {
      "symbol": "fetch",
      "patterns": [
        "\\bfetch\\b\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "fetch API function"
    },
    {
      "symbol": "require",
      "patterns": [
        "\\brequire\\b\\s*\\("
      ],
      "includeDeclaration": false,
      "description": "CommonJS require"
    }
  ]
}
