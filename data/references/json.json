{
  "language": "json",
  "referencePatterns": [
    {
      "symbol": "key_ref",
      "patterns": [
        "\"[^\"]+\"\\s*:"
      ],
      "includeDeclaration": true,
      "description": "JSON key/property references"
    },
    {
      "symbol": "string_value",
      "patterns": [
        ":\\s*\"[^\"]*\""
      ],
      "includeDeclaration": true,
      "description": "String value references"
    },
    {
      "symbol": "ref_pointer",
      "patterns": [
        "\\$ref\"\\s*:\\s*\"[^\"]+\"",
        "\"\\$id\"\\s*:\\s*\"[^\"]+\""
      ],
      "includeDeclaration": true,
      "description": "JSON Schema $ref and $id references"
    },
    {
      "symbol": "json_path",
      "patterns": [
        "\\$\\.[a-zA-Z0-9_.\\[\\]*]+"
      ],
      "includeDeclaration": true,
      "description": "JSONPath expression references"
    }
  ],
  "identifierPattern": "[a-zA-Z_$][a-zA-Z0-9_$-]*"
}
