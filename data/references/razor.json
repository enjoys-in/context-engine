{
  "language": "razor",
  "referencePatterns": [
    {
      "symbol": "directive_ref",
      "patterns": [
        "@model\\s+\\w+",
        "@page\\b",
        "@inject\\s+\\w+",
        "@using\\s+\\w+",
        "@inherits\\s+\\w+",
        "@implements\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Razor directive references (@model, @page, @inject)"
    },
    {
      "symbol": "code_block",
      "patterns": [
        "@\\{",
        "@(if|for|foreach|while|switch|try|using)\\b"
      ],
      "includeDeclaration": true,
      "description": "Razor code block and control flow references"
    },
    {
      "symbol": "expression_ref",
      "patterns": [
        "@\\w+",
        "@\\(\\w+"
      ],
      "includeDeclaration": true,
      "description": "Razor expression and inline references"
    },
    {
      "symbol": "html_helper",
      "patterns": [
        "@Html\\.\\w+",
        "@Url\\.\\w+",
        "@Model\\.\\w+",
        "@ViewBag\\.\\w+"
      ],
      "includeDeclaration": true,
      "description": "HTML helper and view property references"
    },
    {
      "symbol": "tag_helper",
      "patterns": [
        "asp-\\w+\\s*=",
        "<partial\\s+",
        "<component\\s+",
        "<environment\\s+"
      ],
      "includeDeclaration": true,
      "description": "Tag helper attribute and element references"
    },
    {
      "symbol": "section_ref",
      "patterns": [
        "@section\\s+\\w+",
        "@RenderSection\\s*\\(",
        "@RenderBody\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Section and layout references"
    }
  ],
  "identifierPattern": "[a-zA-Z_@][a-zA-Z0-9_]*"
}
