{
  "language": "razor",
  "referencePatterns": [
    {
      "symbol": "directive_ref",
      "patterns": [
        "@model\\s+\\w+",
        "@page\\b",
        "@inject\\s+\\w+",
        "@using\\s+\\w+",
        "@inherits\\s+\\w+",
        "@implements\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Razor directive references (@model, @page, @inject)"
    },
    {
      "symbol": "code_block",
      "patterns": [
        "@\\{",
        "@(if|for|foreach|while|switch|try|using)\\b"
      ],
      "includeDeclaration": true,
      "description": "Razor code block and control flow references"
    },
    {
      "symbol": "expression_ref",
      "patterns": [
        "@\\w+",
        "@\\(\\w+"
      ],
      "includeDeclaration": true,
      "description": "Razor expression and inline references"
    },
    {
      "symbol": "html_helper",
      "patterns": [
        "@Html\\.\\w+",
        "@Url\\.\\w+",
        "@Model\\.\\w+",
        "@ViewBag\\.\\w+"
      ],
      "includeDeclaration": true,
      "description": "HTML helper and view property references"
    },
    {
      "symbol": "tag_helper",
      "patterns": [
        "asp-\\w+\\s*=",
        "<partial\\s+",
        "<component\\s+",
        "<environment\\s+"
      ],
      "includeDeclaration": true,
      "description": "Tag helper attribute and element references"
    },
    {
      "symbol": "section_ref",
      "patterns": [
        "@section\\s+\\w+",
        "@RenderSection\\s*\\(",
        "@RenderBody\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Section and layout references"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    },
    {
      "kind": "comment_reference",
      "pattern": "@(?:see|link|param|returns?)\\s+(\\w+)",
      "description": "Documentation reference"
    },
    {
      "kind": "decorator",
      "pattern": "@(\\w+)",
      "description": "Decorator/annotation reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_@][a-zA-Z0-9_]*",
  "includeDeclaration": true
}
