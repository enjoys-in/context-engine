{
  "language": "doctest",
  "referencePatterns": [
    {
      "symbol": "prompt_line",
      "patterns": [
        "^>>>\\s+.+",
        "^\\.\\.\\. .+"
      ],
      "includeDeclaration": true,
      "description": "Doctest prompt lines (>>> and ... continuations)"
    },
    {
      "symbol": "function_call",
      "patterns": [
        "\\b\\w+\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Function calls in doctest examples"
    },
    {
      "symbol": "variable_ref",
      "patterns": [
        "\\b\\w+\\s*=",
        "\\b[a-zA-Z_]\\w*\\b"
      ],
      "includeDeclaration": true,
      "description": "Variable assignments and references in doctests"
    },
    {
      "symbol": "expected_output",
      "patterns": [
        "^[^>\\s].*$"
      ],
      "includeDeclaration": true,
      "description": "Expected output lines"
    },
    {
      "symbol": "import_ref",
      "patterns": [
        ">>>\\s+import\\s+\\w+",
        ">>>\\s+from\\s+\\w+\\s+import"
      ],
      "includeDeclaration": true,
      "description": "Import statements in doctests"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    },
    {
      "kind": "comment_reference",
      "pattern": "@(?:see|link|param|returns?)\\s+(\\w+)",
      "description": "Documentation reference"
    },
    {
      "kind": "decorator",
      "pattern": "@(\\w+)",
      "description": "Decorator/annotation reference"
    },
    {
      "kind": "class_reference",
      "pattern": "\\b([A-Z]\\w+)\\b",
      "description": "Class/type name reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "includeDeclaration": true
}
