{
  "language": "cypher",
  "referencePatterns": [
    {
      "symbol": "match_clause",
      "patterns": [
        "\\bMATCH\\b",
        "\\bOPTIONAL\\s+MATCH\\b"
      ],
      "includeDeclaration": true,
      "description": "MATCH and OPTIONAL MATCH clauses"
    },
    {
      "symbol": "where_clause",
      "patterns": [
        "\\bWHERE\\b",
        "\\bAND\\b",
        "\\bOR\\b",
        "\\bNOT\\b"
      ],
      "includeDeclaration": true,
      "description": "WHERE conditions and logical operators"
    },
    {
      "symbol": "return_clause",
      "patterns": [
        "\\bRETURN\\b",
        "\\bWITH\\b",
        "\\bORDER\\s+BY\\b",
        "\\bLIMIT\\b",
        "\\bSKIP\\b"
      ],
      "includeDeclaration": true,
      "description": "RETURN, WITH, and ordering clauses"
    },
    {
      "symbol": "write_clause",
      "patterns": [
        "\\bCREATE\\b",
        "\\bMERGE\\b",
        "\\bSET\\b",
        "\\bDELETE\\b",
        "\\bDETACH\\s+DELETE\\b",
        "\\bREMOVE\\b"
      ],
      "includeDeclaration": true,
      "description": "Write operations (CREATE, MERGE, SET, DELETE)"
    },
    {
      "symbol": "node_pattern",
      "patterns": [
        "\\(\\w*:\\w+",
        "\\(\\w+\\)"
      ],
      "includeDeclaration": true,
      "description": "Node patterns and labels"
    },
    {
      "symbol": "relationship_pattern",
      "patterns": [
        "-\\[\\w*:\\w+",
        "->",
        "<-"
      ],
      "includeDeclaration": true,
      "description": "Relationship patterns and types"
    },
    {
      "symbol": "function_call",
      "patterns": [
        "\\b\\w+\\s*\\(",
        "\\bcollect\\b",
        "\\bcount\\b",
        "\\bsum\\b",
        "\\bavg\\b",
        "\\bmin\\b",
        "\\bmax\\b"
      ],
      "includeDeclaration": true,
      "description": "Function calls and aggregations"
    },
    {
      "symbol": "property_ref",
      "patterns": [
        "\\w+\\.\\w+",
        "\\w+\\['.+?'\\]"
      ],
      "includeDeclaration": true,
      "description": "Property access on nodes and relationships"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier",
      "includeDeclaration": false,
      "symbol": "identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference",
      "includeDeclaration": false,
      "symbol": "function_call"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference",
      "includeDeclaration": false,
      "symbol": "import"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference",
      "includeDeclaration": false,
      "symbol": "type_reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference",
      "includeDeclaration": false,
      "symbol": "property_access"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference",
      "includeDeclaration": false,
      "symbol": "string_literal"
    },
    {
      "symbol": "import_statement",
      "patterns": [
        "(import|require|use|include|load)\\s+"
      ],
      "includeDeclaration": false,
      "description": "Import/include statement reference"
    },
    {
      "symbol": "function_definition",
      "patterns": [
        "(function|func|fn|def|sub|proc|method)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Function/method definition reference"
    },
    {
      "symbol": "class_definition",
      "patterns": [
        "(class|struct|type|interface|trait|record|enum)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Type definition reference"
    },
    {
      "symbol": "variable_declaration",
      "patterns": [
        "(var|let|const|val|my|local|dim|set)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Variable declaration reference"
    },
    {
      "symbol": "property_access",
      "patterns": [
        "\\.(\\w+)"
      ],
      "includeDeclaration": false,
      "description": "Property/field access reference"
    },
    {
      "symbol": "type_annotation",
      "patterns": [
        ":\\s*(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Type annotation reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "includeDeclaration": true
}
