{
  "language": "swift",
  "referencePatterns": [
    {
      "symbol": "function_call",
      "patterns": [
        "\\b\\w+\\s*\\(",
        "\\b\\w+\\s*\\{"
      ],
      "includeDeclaration": true,
      "description": "Function calls and trailing closure invocations"
    },
    {
      "symbol": "type_reference",
      "patterns": [
        ":\\s*\\w+",
        "\\w+\\s*\\(",
        "is\\s+\\w+",
        "as[?!]?\\s+\\w+",
        "->\\s*\\w+"
      ],
      "includeDeclaration": true,
      "description": "Type references in annotations, casts, and return types"
    },
    {
      "symbol": "protocol_conformance",
      "patterns": [
        ":\\s*\\w+(?:,\\s*\\w+)*\\s*\\{",
        "extension\\s+\\w+\\s*:\\s*\\w+"
      ],
      "includeDeclaration": true,
      "description": "Protocol conformance declarations"
    },
    {
      "symbol": "property_access",
      "patterns": [
        "\\.\\w+",
        "\\w+\\."
      ],
      "includeDeclaration": true,
      "description": "Property and member access"
    },
    {
      "symbol": "import_ref",
      "patterns": [
        "import\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Import references"
    },
    {
      "symbol": "generic_type",
      "patterns": [
        "<\\w+>",
        "\\w+<",
        "where\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Generic type parameters and constraints"
    },
    {
      "symbol": "attribute_usage",
      "patterns": [
        "@\\w+"
      ],
      "includeDeclaration": true,
      "description": "Attribute references (@MainActor, @Published, etc.)"
    },
    {
      "symbol": "key_path",
      "patterns": [
        "\\\\\\.\\w+",
        "\\\\\\w+\\.\\w+"
      ],
      "includeDeclaration": true,
      "description": "Key path expressions"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "includeDeclaration": true
}
