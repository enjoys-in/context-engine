{
  "language": "less",
  "referencePatterns": [
    {
      "symbol": "variable_ref",
      "patterns": [
        "@[a-zA-Z_][a-zA-Z0-9_-]*"
      ],
      "includeDeclaration": true,
      "description": "Less variable references (@color, @size)"
    },
    {
      "symbol": "mixin_ref",
      "patterns": [
        "\\.\\w[\\w-]*\\s*\\(",
        "\\.\\w[\\w-]*\\s*;",
        "#\\w[\\w-]*\\s*>\\s*\\.\\w+"
      ],
      "includeDeclaration": true,
      "description": "Mixin calls and namespaced mixin references"
    },
    {
      "symbol": "selector_ref",
      "patterns": [
        "\\.\\w[\\w-]*",
        "#\\w[\\w-]*",
        "&[a-zA-Z_.-]"
      ],
      "includeDeclaration": true,
      "description": "Class, ID, and parent selector references"
    },
    {
      "symbol": "extend_ref",
      "patterns": [
        "&:extend\\([^)]+\\)",
        ":extend\\([^)]+\\)"
      ],
      "includeDeclaration": true,
      "description": "Extend references"
    },
    {
      "symbol": "import_ref",
      "patterns": [
        "@import\\s+[\"'][^\"']+[\"']",
        "@import\\s+\\([^)]+\\)\\s+[\"']"
      ],
      "includeDeclaration": true,
      "description": "Import references with optional keywords"
    },
    {
      "symbol": "function_call",
      "patterns": [
        "\\b\\w+\\s*\\(",
        "\\beach\\s*\\(",
        "\\bwhen\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Built-in and guard function calls"
    },
    {
      "symbol": "property_ref",
      "patterns": [
        "\\$\\w+",
        "\\bproperty\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Property variable references ($prop)"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    },
    {
      "kind": "comment_reference",
      "pattern": "@(?:see|link|param|returns?)\\s+(\\w+)",
      "description": "Documentation reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_@][a-zA-Z0-9_-]*",
  "includeDeclaration": true
}
