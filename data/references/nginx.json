{
  "language": "nginx",
  "referencePatterns": [
    {
      "symbol": "server_block",
      "patterns": [
        "\\bserver\\s*\\{",
        "\\blisten\\s+\\S+",
        "\\bserver_name\\s+\\S+"
      ],
      "includeDeclaration": true,
      "description": "Server block, listen, and server_name directives"
    },
    {
      "symbol": "location_ref",
      "patterns": [
        "\\blocation\\s+[~=^]*\\s*\\S+\\s*\\{",
        "\\blocation\\b"
      ],
      "includeDeclaration": true,
      "description": "Location block references"
    },
    {
      "symbol": "upstream_ref",
      "patterns": [
        "\\bupstream\\s+\\w+\\s*\\{",
        "\\bproxy_pass\\s+\\S+"
      ],
      "includeDeclaration": true,
      "description": "Upstream and proxy_pass references"
    },
    {
      "symbol": "root_alias",
      "patterns": [
        "\\broot\\s+\\S+",
        "\\balias\\s+\\S+",
        "\\btry_files\\s+"
      ],
      "includeDeclaration": true,
      "description": "Root, alias, and try_files directives"
    },
    {
      "symbol": "proxy_directive",
      "patterns": [
        "\\bproxy_set_header\\s+",
        "\\bproxy_redirect\\s+",
        "\\bproxy_read_timeout\\s+",
        "\\bproxy_connect_timeout\\s+"
      ],
      "includeDeclaration": true,
      "description": "Proxy configuration directives"
    },
    {
      "symbol": "include_ref",
      "patterns": [
        "\\binclude\\s+\\S+"
      ],
      "includeDeclaration": true,
      "description": "Include directive references"
    },
    {
      "symbol": "variable_ref",
      "patterns": [
        "\\$[a-zA-Z_][a-zA-Z0-9_]*"
      ],
      "includeDeclaration": true,
      "description": "Nginx variable references ($host, $uri, $request_uri)"
    },
    {
      "symbol": "ssl_ref",
      "patterns": [
        "\\bssl_certificate\\s+",
        "\\bssl_certificate_key\\s+",
        "\\bssl_protocols\\s+"
      ],
      "includeDeclaration": true,
      "description": "SSL/TLS configuration directives"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "includeDeclaration": true
}
