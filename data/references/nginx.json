{
  "language": "nginx",
  "referencePatterns": [
    {
      "symbol": "server_block",
      "patterns": [
        "\\bserver\\s*\\{",
        "\\blisten\\s+\\S+",
        "\\bserver_name\\s+\\S+"
      ],
      "includeDeclaration": true,
      "description": "Server block, listen, and server_name directives"
    },
    {
      "symbol": "location_ref",
      "patterns": [
        "\\blocation\\s+[~=^]*\\s*\\S+\\s*\\{",
        "\\blocation\\b"
      ],
      "includeDeclaration": true,
      "description": "Location block references"
    },
    {
      "symbol": "upstream_ref",
      "patterns": [
        "\\bupstream\\s+\\w+\\s*\\{",
        "\\bproxy_pass\\s+\\S+"
      ],
      "includeDeclaration": true,
      "description": "Upstream and proxy_pass references"
    },
    {
      "symbol": "root_alias",
      "patterns": [
        "\\broot\\s+\\S+",
        "\\balias\\s+\\S+",
        "\\btry_files\\s+"
      ],
      "includeDeclaration": true,
      "description": "Root, alias, and try_files directives"
    },
    {
      "symbol": "proxy_directive",
      "patterns": [
        "\\bproxy_set_header\\s+",
        "\\bproxy_redirect\\s+",
        "\\bproxy_read_timeout\\s+",
        "\\bproxy_connect_timeout\\s+"
      ],
      "includeDeclaration": true,
      "description": "Proxy configuration directives"
    },
    {
      "symbol": "include_ref",
      "patterns": [
        "\\binclude\\s+\\S+"
      ],
      "includeDeclaration": true,
      "description": "Include directive references"
    },
    {
      "symbol": "variable_ref",
      "patterns": [
        "\\$[a-zA-Z_][a-zA-Z0-9_]*"
      ],
      "includeDeclaration": true,
      "description": "Nginx variable references ($host, $uri, $request_uri)"
    },
    {
      "symbol": "ssl_ref",
      "patterns": [
        "\\bssl_certificate\\s+",
        "\\bssl_certificate_key\\s+",
        "\\bssl_protocols\\s+"
      ],
      "includeDeclaration": true,
      "description": "SSL/TLS configuration directives"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
