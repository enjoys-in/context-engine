{
  "language": "coffee",
  "referencePatterns": [
    {
      "symbol": "class_ref",
      "patterns": [
        "\\bclass\\s+\\w+",
        "\\bextends\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Class declarations and extends"
    },
    {
      "symbol": "constructor_ref",
      "patterns": [
        "\\bconstructor\\s*:",
        "\\bnew\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Constructor and instantiation references"
    },
    {
      "symbol": "function_ref",
      "patterns": [
        "\\w+\\s*[=:]\\s*\\(.*\\)\\s*->",
        "\\w+\\s*[=:]\\s*\\(.*\\)\\s*=>"
      ],
      "includeDeclaration": true,
      "description": "Function definitions (-> and =>)"
    },
    {
      "symbol": "require_ref",
      "patterns": [
        "\\brequire\\s*\\(?['\"][^'\"]+['\"]\\)?"
      ],
      "includeDeclaration": true,
      "description": "Require/import references"
    },
    {
      "symbol": "variable_ref",
      "patterns": [
        "\\b\\w+\\s*=(?!=)",
        "@\\w+"
      ],
      "includeDeclaration": true,
      "description": "Variable assignments and instance variables"
    },
    {
      "symbol": "property_access",
      "patterns": [
        "\\.\\w+",
        "\\w+\\.\\w+",
        "\\w+\\??\\.\\w+"
      ],
      "includeDeclaration": true,
      "description": "Property and existential access"
    },
    {
      "symbol": "destructure",
      "patterns": [
        "\\{[^}]+\\}\\s*=",
        "\\[[^\\]]+\\]\\s*="
      ],
      "includeDeclaration": true,
      "description": "Destructuring assignments"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    },
    {
      "kind": "comment_reference",
      "pattern": "@(?:see|link|param|returns?)\\s+(\\w+)",
      "description": "Documentation reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "includeDeclaration": true
}
