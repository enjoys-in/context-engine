{
  "language": "julia",
  "referencePatterns": [
    {
      "symbol": "function_ref",
      "patterns": [
        "\\bfunction\\s+\\w+",
        "\\b\\w+\\s*\\(.*\\)\\s*="
      ],
      "includeDeclaration": true,
      "description": "Function definitions and short-form"
    },
    {
      "symbol": "struct_ref",
      "patterns": [
        "\\bstruct\\s+\\w+",
        "\\bmutable\\s+struct\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Struct and mutable struct definitions"
    },
    {
      "symbol": "abstract_type",
      "patterns": [
        "\\babstract\\s+type\\s+\\w+",
        "\\bprimitive\\s+type\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Abstract and primitive type definitions"
    },
    {
      "symbol": "module_ref",
      "patterns": [
        "\\bmodule\\s+\\w+",
        "\\bbaremodule\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Module definitions"
    },
    {
      "symbol": "using_import",
      "patterns": [
        "\\busing\\s+\\w+",
        "\\bimport\\s+\\w+",
        "\\bexport\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Using, import, and export references"
    },
    {
      "symbol": "macro_ref",
      "patterns": [
        "\\bmacro\\s+\\w+",
        "@\\w+"
      ],
      "includeDeclaration": true,
      "description": "Macro definitions and invocations"
    },
    {
      "symbol": "type_annotation",
      "patterns": [
        "::\\w+",
        "<:\\s*\\w+"
      ],
      "includeDeclaration": true,
      "description": "Type annotations and subtype references"
    },
    {
      "symbol": "function_call",
      "patterns": [
        "\\b\\w+\\s*\\(",
        "\\b\\w+\\.\\w+\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Function and method calls"
    },
    {
      "symbol": "broadcast_ref",
      "patterns": [
        "\\.\\w+\\s*\\(",
        "\\w+\\.\\("
      ],
      "includeDeclaration": true,
      "description": "Broadcasting dot-call references"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier",
      "includeDeclaration": false,
      "symbol": "identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference",
      "includeDeclaration": false,
      "symbol": "function_call"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference",
      "includeDeclaration": false,
      "symbol": "import"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference",
      "includeDeclaration": false,
      "symbol": "type_reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference",
      "includeDeclaration": false,
      "symbol": "property_access"
    },
    {
      "symbol": "import_statement",
      "patterns": [
        "(import|require|use|include|load)\\s+"
      ],
      "includeDeclaration": false,
      "description": "Import/include statement reference"
    },
    {
      "symbol": "function_definition",
      "patterns": [
        "(function|func|fn|def|sub|proc|method)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Function/method definition reference"
    },
    {
      "symbol": "class_definition",
      "patterns": [
        "(class|struct|type|interface|trait|record|enum)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Type definition reference"
    },
    {
      "symbol": "variable_declaration",
      "patterns": [
        "(var|let|const|val|my|local|dim|set)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Variable declaration reference"
    },
    {
      "symbol": "property_access",
      "patterns": [
        "\\.(\\w+)"
      ],
      "includeDeclaration": false,
      "description": "Property/field access reference"
    },
    {
      "symbol": "string_literal",
      "patterns": [
        "[\"'][^\"']+[\"']"
      ],
      "includeDeclaration": false,
      "description": "String literal reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_!]*",
  "includeDeclaration": true
}
