{
  "language": "wgsl",
  "referencePatterns": [
    {
      "symbol": "function_ref",
      "patterns": [
        "\\bfn\\s+\\w+",
        "@vertex\\b",
        "@fragment\\b",
        "@compute\\b"
      ],
      "includeDeclaration": true,
      "description": "Function definitions and entry point attributes"
    },
    {
      "symbol": "variable_ref",
      "patterns": [
        "\\bvar\\s+",
        "\\blet\\s+\\w+",
        "\\bconst\\s+\\w+",
        "\\boverride\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Variable, let, const, and override declarations"
    },
    {
      "symbol": "type_ref",
      "patterns": [
        "\\bf32\\b",
        "\\bi32\\b",
        "\\bu32\\b",
        "\\bbool\\b",
        "\\bvec[234]\\b",
        "\\bmat[234]x[234]\\b",
        "\\barray\\b",
        "\\btexture_\\w+",
        "\\bsampler\\b"
      ],
      "includeDeclaration": true,
      "description": "Built-in type references"
    },
    {
      "symbol": "struct_ref",
      "patterns": [
        "\\bstruct\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Struct definitions"
    },
    {
      "symbol": "attribute_ref",
      "patterns": [
        "@\\w+(?:\\([^)]*\\))?",
        "@group\\(\\d+\\)",
        "@binding\\(\\d+\\)",
        "@location\\(\\d+\\)",
        "@builtin\\(\\w+\\)"
      ],
      "includeDeclaration": true,
      "description": "Attribute references (@group, @binding, @location, @builtin)"
    },
    {
      "symbol": "storage_ref",
      "patterns": [
        "\\b<uniform>\\b",
        "\\b<storage\\b",
        "\\b<read>\\b",
        "\\b<write>\\b",
        "\\b<read_write>\\b"
      ],
      "includeDeclaration": true,
      "description": "Address space and access mode references"
    },
    {
      "symbol": "builtin_fn",
      "patterns": [
        "\\b(dot|cross|normalize|length|clamp|min|max|abs|ceil|floor|round|pow|sqrt|exp|log|sin|cos|tan|atan|smoothstep|mix|step|fract)\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Built-in function references"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    },
    {
      "kind": "comment_reference",
      "pattern": "@(?:see|link|param|returns?)\\s+(\\w+)",
      "description": "Documentation reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "includeDeclaration": true
}
