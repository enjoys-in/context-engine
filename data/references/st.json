{
  "language": "st",
  "referencePatterns": [
    {
      "symbol": "class_ref",
      "patterns": [
        "\\b[A-Z]\\w+\\s+subclass:",
        "\\b[A-Z]\\w+\\s+class\\b"
      ],
      "includeDeclaration": true,
      "description": "Class definitions and class references"
    },
    {
      "symbol": "message_ref",
      "patterns": [
        "\\b\\w+:",
        "\\s\\w+\\s",
        "\\b[+\\-*/~<>=@%|&?!,]+\\b"
      ],
      "includeDeclaration": true,
      "description": "Keyword, unary, and binary message sends"
    },
    {
      "symbol": "method_ref",
      "patterns": [
        ">>\\s*\\w+",
        "\\w+\\s*\\["
      ],
      "includeDeclaration": true,
      "description": "Method definitions and category references"
    },
    {
      "symbol": "variable_ref",
      "patterns": [
        "\\|\\s*[^|]+\\s*\\|",
        ":=\\s*\\w+",
        "\\b[a-z]\\w+\\b"
      ],
      "includeDeclaration": true,
      "description": "Temporary variable declarations and assignments"
    },
    {
      "symbol": "global_ref",
      "patterns": [
        "\\bSmalltalk\\b",
        "\\bTranscript\\b",
        "\\b[A-Z]\\w+\\b"
      ],
      "includeDeclaration": true,
      "description": "Global and class name references"
    },
    {
      "symbol": "block_ref",
      "patterns": [
        "\\[\\s*:",
        "\\[\\s*\\|"
      ],
      "includeDeclaration": true,
      "description": "Block closure references with parameters"
    },
    {
      "symbol": "pragma_ref",
      "patterns": [
        "<\\w+:?[^>]*>"
      ],
      "includeDeclaration": true,
      "description": "Pragma/annotation references"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
