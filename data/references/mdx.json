{
  "language": "mdx",
  "referencePatterns": [
    {
      "symbol": "component_ref",
      "patterns": [
        "<[A-Z]\\w*",
        "</[A-Z]\\w*>",
        "<[A-Z]\\w*\\s*/>"
      ],
      "includeDeclaration": true,
      "description": "JSX component references"
    },
    {
      "symbol": "import_ref",
      "patterns": [
        "\\bimport\\s+\\{?[^}]*\\}?\\s+from",
        "\\bimport\\s+\\w+\\s+from",
        "\\bexport\\s+"
      ],
      "includeDeclaration": true,
      "description": "ESM import and export references"
    },
    {
      "symbol": "heading_ref",
      "patterns": [
        "^#{1,6}\\s+.+"
      ],
      "includeDeclaration": true,
      "description": "Heading references"
    },
    {
      "symbol": "link_ref",
      "patterns": [
        "\\[[^\\]]+\\]\\([^)]+\\)"
      ],
      "includeDeclaration": true,
      "description": "Markdown link references"
    },
    {
      "symbol": "jsx_expression",
      "patterns": [
        "\\{[^}]+\\}"
      ],
      "includeDeclaration": true,
      "description": "JSX expression references"
    },
    {
      "symbol": "prop_ref",
      "patterns": [
        "\\b\\w+\\s*=\\s*\\{",
        "\\b\\w+\\s*=\\s*\""
      ],
      "includeDeclaration": true,
      "description": "Component prop references"
    }
  ],
  "identifierPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*"
}
