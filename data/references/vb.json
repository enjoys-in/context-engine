{
  "language": "vb",
  "referencePatterns": [
    {
      "symbol": "sub_func",
      "patterns": [
        "\\bSub\\s+\\w+",
        "\\bFunction\\s+\\w+",
        "\\bEnd\\s+Sub\\b",
        "\\bEnd\\s+Function\\b"
      ],
      "includeDeclaration": true,
      "description": "Sub and Function definitions"
    },
    {
      "symbol": "class_ref",
      "patterns": [
        "\\bClass\\s+\\w+",
        "\\bModule\\s+\\w+",
        "\\bStructure\\s+\\w+",
        "\\bInterface\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Class, Module, Structure, Interface definitions"
    },
    {
      "symbol": "property_ref",
      "patterns": [
        "\\bProperty\\s+\\w+",
        "\\bGet\\b",
        "\\bSet\\b"
      ],
      "includeDeclaration": true,
      "description": "Property definitions"
    },
    {
      "symbol": "imports_ref",
      "patterns": [
        "\\bImports\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Imports references"
    },
    {
      "symbol": "variable_ref",
      "patterns": [
        "\\bDim\\s+\\w+",
        "\\bConst\\s+\\w+",
        "\\bStatic\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Variable and constant declarations"
    },
    {
      "symbol": "type_ref",
      "patterns": [
        "\\bAs\\s+\\w+",
        "\\bString\\b",
        "\\bInteger\\b",
        "\\bBoolean\\b",
        "\\bDouble\\b",
        "\\bObject\\b",
        "\\bDate\\b"
      ],
      "includeDeclaration": true,
      "description": "Type references"
    },
    {
      "symbol": "inheritance_ref",
      "patterns": [
        "\\bInherits\\s+\\w+",
        "\\bImplements\\s+\\w+",
        "\\bOverrides\\b",
        "\\bOverridable\\b",
        "\\bMustOverride\\b"
      ],
      "includeDeclaration": true,
      "description": "Inheritance and interface references"
    },
    {
      "symbol": "event_ref",
      "patterns": [
        "\\bEvent\\s+\\w+",
        "\\bRaiseEvent\\s+\\w+",
        "\\bHandles\\s+\\w+",
        "\\bAddHandler\\s+",
        "\\bWithEvents\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Event declarations and handler references"
    },
    {
      "symbol": "linq_ref",
      "patterns": [
        "\\bFrom\\s+\\w+\\s+In\\b",
        "\\bSelect\\b",
        "\\bWhere\\b",
        "\\bOrder\\s+By\\b",
        "\\bGroup\\s+By\\b"
      ],
      "includeDeclaration": true,
      "description": "LINQ query references"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "includeDeclaration": true
}
