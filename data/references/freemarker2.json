{
  "language": "freemarker2",
  "referencePatterns": [
    {
      "symbol": "directive_ref",
      "patterns": [
        "<#\\w+",
        "</#\\w+",
        "<@\\w+",
        "</@\\w+"
      ],
      "includeDeclaration": true,
      "description": "FreeMarker directive references (<#if, <#list, <@macro)"
    },
    {
      "symbol": "variable_ref",
      "patterns": [
        "\\$\\{[^}]+\\}",
        "\\$\\{\\w+\\.\\w+\\}"
      ],
      "includeDeclaration": true,
      "description": "Interpolation and variable references"
    },
    {
      "symbol": "macro_ref",
      "patterns": [
        "<#macro\\s+\\w+",
        "<@\\w+"
      ],
      "includeDeclaration": true,
      "description": "Macro definitions and invocations"
    },
    {
      "symbol": "function_ref",
      "patterns": [
        "<#function\\s+\\w+",
        "\\?\\w+"
      ],
      "includeDeclaration": true,
      "description": "Function definitions and built-in calls (?string, ?size)"
    },
    {
      "symbol": "assign_ref",
      "patterns": [
        "<#assign\\s+\\w+",
        "<#local\\s+\\w+",
        "<#global\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Variable assignment directives"
    },
    {
      "symbol": "include_ref",
      "patterns": [
        "<#include\\s+",
        "<#import\\s+"
      ],
      "includeDeclaration": true,
      "description": "Include and import directives"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    },
    {
      "kind": "comment_reference",
      "pattern": "@(?:see|link|param|returns?)\\s+(\\w+)",
      "description": "Documentation reference"
    },
    {
      "kind": "decorator",
      "pattern": "@(\\w+)",
      "description": "Decorator/annotation reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "includeDeclaration": true
}
