{
  "language": "objective-c",
  "referencePatterns": [
    {
      "symbol": "interface_ref",
      "patterns": [
        "@interface\\s+\\w+",
        "@implementation\\s+\\w+",
        "@protocol\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Interface, implementation, and protocol declarations"
    },
    {
      "symbol": "method_ref",
      "patterns": [
        "[-+]\\s*\\([^)]+\\)\\s*\\w+",
        "\\[\\w+\\s+\\w+\\]",
        "\\[\\w+\\s+\\w+:.+\\]"
      ],
      "includeDeclaration": true,
      "description": "Method declarations and message send syntax"
    },
    {
      "symbol": "property_ref",
      "patterns": [
        "@property\\s*\\([^)]*\\)\\s*\\w+\\s+\\*?\\w+",
        "\\.\\w+",
        "self\\.\\w+"
      ],
      "includeDeclaration": true,
      "description": "Property declarations and dot-syntax access"
    },
    {
      "symbol": "import_ref",
      "patterns": [
        "#import\\s+[<\"][^>\"]+[>\"]",
        "@import\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Import and module import references"
    },
    {
      "symbol": "type_ref",
      "patterns": [
        "\\bNS\\w+\\b",
        "\\bUI\\w+\\b",
        "\\bid\\b",
        "\\binstancetype\\b"
      ],
      "includeDeclaration": true,
      "description": "Foundation/UIKit type references"
    },
    {
      "symbol": "selector_ref",
      "patterns": [
        "@selector\\(\\w+:?\\)",
        "SEL\\b",
        "\\bperformSelector\\b"
      ],
      "includeDeclaration": true,
      "description": "Selector references"
    },
    {
      "symbol": "class_ref",
      "patterns": [
        "\\[\\[\\w+\\s+alloc\\]\\s+init",
        "\\[\\w+\\s+new\\]",
        "\\[\\w+\\s+class\\]"
      ],
      "includeDeclaration": true,
      "description": "Class allocation and initialization"
    },
    {
      "symbol": "block_ref",
      "patterns": [
        "\\^\\s*\\([^)]*\\)\\s*\\{",
        "\\btypedef\\s+\\w+\\s*\\(\\^\\w+\\)"
      ],
      "includeDeclaration": true,
      "description": "Block expression and typedef references"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier",
      "includeDeclaration": false,
      "symbol": "identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference",
      "includeDeclaration": false,
      "symbol": "function_call"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference",
      "includeDeclaration": false,
      "symbol": "import"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference",
      "includeDeclaration": false,
      "symbol": "type_reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference",
      "includeDeclaration": false,
      "symbol": "property_access"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference",
      "includeDeclaration": false,
      "symbol": "string_literal"
    },
    {
      "symbol": "import_statement",
      "patterns": [
        "(import|require|use|include|load)\\s+"
      ],
      "includeDeclaration": false,
      "description": "Import/include statement reference"
    },
    {
      "symbol": "function_definition",
      "patterns": [
        "(function|func|fn|def|sub|proc|method)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Function/method definition reference"
    },
    {
      "symbol": "class_definition",
      "patterns": [
        "(class|struct|type|interface|trait|record|enum)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Type definition reference"
    },
    {
      "symbol": "variable_declaration",
      "patterns": [
        "(var|let|const|val|my|local|dim|set)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Variable declaration reference"
    },
    {
      "symbol": "function_call",
      "patterns": [
        "\\b(\\w+)\\s*\\("
      ],
      "includeDeclaration": false,
      "description": "Function/method call reference"
    },
    {
      "symbol": "property_access",
      "patterns": [
        "\\.(\\w+)"
      ],
      "includeDeclaration": false,
      "description": "Property/field access reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "includeDeclaration": true
}
