{
  "language": "objective-c",
  "referencePatterns": [
    {
      "symbol": "interface_ref",
      "patterns": [
        "@interface\\s+\\w+",
        "@implementation\\s+\\w+",
        "@protocol\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Interface, implementation, and protocol declarations"
    },
    {
      "symbol": "method_ref",
      "patterns": [
        "[-+]\\s*\\([^)]+\\)\\s*\\w+",
        "\\[\\w+\\s+\\w+\\]",
        "\\[\\w+\\s+\\w+:.+\\]"
      ],
      "includeDeclaration": true,
      "description": "Method declarations and message send syntax"
    },
    {
      "symbol": "property_ref",
      "patterns": [
        "@property\\s*\\([^)]*\\)\\s*\\w+\\s+\\*?\\w+",
        "\\.\\w+",
        "self\\.\\w+"
      ],
      "includeDeclaration": true,
      "description": "Property declarations and dot-syntax access"
    },
    {
      "symbol": "import_ref",
      "patterns": [
        "#import\\s+[<\"][^>\"]+[>\"]",
        "@import\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Import and module import references"
    },
    {
      "symbol": "type_ref",
      "patterns": [
        "\\bNS\\w+\\b",
        "\\bUI\\w+\\b",
        "\\bid\\b",
        "\\binstancetype\\b"
      ],
      "includeDeclaration": true,
      "description": "Foundation/UIKit type references"
    },
    {
      "symbol": "selector_ref",
      "patterns": [
        "@selector\\(\\w+:?\\)",
        "SEL\\b",
        "\\bperformSelector\\b"
      ],
      "includeDeclaration": true,
      "description": "Selector references"
    },
    {
      "symbol": "class_ref",
      "patterns": [
        "\\[\\[\\w+\\s+alloc\\]\\s+init",
        "\\[\\w+\\s+new\\]",
        "\\[\\w+\\s+class\\]"
      ],
      "includeDeclaration": true,
      "description": "Class allocation and initialization"
    },
    {
      "symbol": "block_ref",
      "patterns": [
        "\\^\\s*\\([^)]*\\)\\s*\\{",
        "\\btypedef\\s+\\w+\\s*\\(\\^\\w+\\)"
      ],
      "includeDeclaration": true,
      "description": "Block expression and typedef references"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
