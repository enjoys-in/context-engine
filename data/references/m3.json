{
  "language": "m3",
  "referencePatterns": [
    {
      "symbol": "module_ref",
      "patterns": [
        "\\bMODULE\\s+\\w+",
        "\\bINTERFACE\\s+\\w+",
        "\\bGENERIC\\s+MODULE\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Module and interface declarations"
    },
    {
      "symbol": "import_ref",
      "patterns": [
        "\\bIMPORT\\s+\\w+",
        "\\bFROM\\s+\\w+\\s+IMPORT"
      ],
      "includeDeclaration": true,
      "description": "Import references"
    },
    {
      "symbol": "type_ref",
      "patterns": [
        "\\bTYPE\\s+\\w+",
        "\\bRECORD\\b",
        "\\bOBJECT\\b",
        "\\bENUM\\b",
        "\\bARRAY\\b",
        "\\bSET\\b"
      ],
      "includeDeclaration": true,
      "description": "Type definitions and built-in type constructors"
    },
    {
      "symbol": "procedure_ref",
      "patterns": [
        "\\bPROCEDURE\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Procedure definitions"
    },
    {
      "symbol": "variable_ref",
      "patterns": [
        "\\bVAR\\s+\\w+",
        "\\bCONST\\s+\\w+",
        "\\bREVEAL\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Variable and constant declarations"
    },
    {
      "symbol": "exception_ref",
      "patterns": [
        "\\bEXCEPTION\\s+\\w+",
        "\\bRAISE\\s+\\w+",
        "\\bTRY\\b",
        "\\bEXCEPT\\b"
      ],
      "includeDeclaration": true,
      "description": "Exception handling references"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    },
    {
      "kind": "comment_reference",
      "pattern": "@(?:see|link|param|returns?)\\s+(\\w+)",
      "description": "Documentation reference"
    },
    {
      "kind": "decorator",
      "pattern": "@(\\w+)",
      "description": "Decorator/annotation reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "includeDeclaration": true
}
