{
  "language": "graphql",
  "referencePatterns": [
    {
      "symbol": "type_def",
      "patterns": [
        "\\btype\\s+\\w+",
        "\\binput\\s+\\w+",
        "\\binterface\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Type, input, and interface definitions"
    },
    {
      "symbol": "enum_def",
      "patterns": [
        "\\benum\\s+\\w+",
        "\\bunion\\s+\\w+",
        "\\bscalar\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Enum, union, and scalar definitions"
    },
    {
      "symbol": "operation_ref",
      "patterns": [
        "\\bquery\\s+\\w*",
        "\\bmutation\\s+\\w*",
        "\\bsubscription\\s+\\w*"
      ],
      "includeDeclaration": true,
      "description": "Query, mutation, and subscription operations"
    },
    {
      "symbol": "field_ref",
      "patterns": [
        "\\b\\w+\\s*:",
        "\\b\\w+\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Field definitions and field calls with arguments"
    },
    {
      "symbol": "fragment_ref",
      "patterns": [
        "\\bfragment\\s+\\w+\\s+on\\s+\\w+",
        "\\.\\.\\.\\w+",
        "\\.\\.\\.\\s+on\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Fragment definitions and spread references"
    },
    {
      "symbol": "directive_ref",
      "patterns": [
        "@\\w+(?:\\([^)]*\\))?",
        "\\bdirective\\s+@\\w+"
      ],
      "includeDeclaration": true,
      "description": "Directive usage and definitions (@deprecated, @skip)"
    },
    {
      "symbol": "implements_ref",
      "patterns": [
        "\\bimplements\\s+[\\w&\\s]+",
        "\\bextends\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Implements and extends references"
    },
    {
      "symbol": "variable_ref",
      "patterns": [
        "\\$\\w+",
        "\\$\\w+\\s*:\\s*\\w+"
      ],
      "includeDeclaration": true,
      "description": "Variable references ($id, $input)"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "includeDeclaration": true
}
