{
  "language": "scala",
  "referencePatterns": [
    {
      "symbol": "function_call",
      "patterns": [
        "\\b\\w+\\s*\\(",
        "\\b\\w+\\s*\\[.*?\\]\\s*\\(",
        "\\.\\w+\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Function and method calls"
    },
    {
      "symbol": "type_reference",
      "patterns": [
        ":\\s*\\w+",
        "\\w+\\s*\\[",
        "extends\\s+\\w+",
        "with\\s+\\w+",
        "new\\s+\\w+",
        "isInstanceOf\\s*\\[\\s*\\w+",
        "asInstanceOf\\s*\\[\\s*\\w+"
      ],
      "includeDeclaration": true,
      "description": "Type references, inheritance, and casts"
    },
    {
      "symbol": "implicit_usage",
      "patterns": [
        "implicit\\s+(?:val|def|class)\\s+\\w+",
        "implicitly\\s*\\[\\s*\\w+",
        "\\(implicit\\s+\\w+",
        "given\\s+\\w+",
        "using\\s+\\w+",
        "summon\\s*\\["
      ],
      "includeDeclaration": true,
      "description": "Implicit/given parameter and conversion usage"
    },
    {
      "symbol": "import_ref",
      "patterns": [
        "import\\s+[\\w.]+",
        "import\\s+[\\w.]+\\.\\{[^}]+\\}",
        "import\\s+[\\w.]+\\._"
      ],
      "includeDeclaration": true,
      "description": "Import references"
    },
    {
      "symbol": "annotation_usage",
      "patterns": [
        "@\\w+(?:\\.\\w+)*(?:\\([^)]*\\))?"
      ],
      "includeDeclaration": true,
      "description": "Annotation references (@main, @deprecated, @tailrec, etc.)"
    },
    {
      "symbol": "pattern_reference",
      "patterns": [
        "case\\s+\\w+\\s*\\(",
        "case\\s+\\w+\\s*=>",
        "case\\s+_\\s*:"
      ],
      "includeDeclaration": true,
      "description": "Pattern matching references"
    },
    {
      "symbol": "property_access",
      "patterns": [
        "\\.\\w+",
        "\\w+\\.\\w+"
      ],
      "includeDeclaration": true,
      "description": "Property and field access"
    },
    {
      "symbol": "type_parameter",
      "patterns": [
        "\\[\\s*\\w+(?:\\s*<:\\s*\\w+)?(?:\\s*>:\\s*\\w+)?\\s*\\]",
        "\\[\\s*\\w+\\s*:\\s*\\w+\\s*\\]"
      ],
      "includeDeclaration": true,
      "description": "Type parameter references and bounds"
    },
    {
      "symbol": "string_interpolation",
      "patterns": [
        "[sf]\"[^\"]*\\$\\{?\\w+",
        "raw\"[^\"]*\\$\\{?\\w+"
      ],
      "includeDeclaration": false,
      "description": "Variable references in string interpolation"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "includeDeclaration": true
}
