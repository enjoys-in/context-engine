{
  "language": "systemd",
  "referencePatterns": [
    {
      "symbol": "section_ref",
      "patterns": [
        "^\\[(Unit|Service|Install|Timer|Socket|Mount|Automount|Swap|Path|Slice|Scope)\\]"
      ],
      "includeDeclaration": true,
      "description": "Section header references ([Unit], [Service], [Install])"
    },
    {
      "symbol": "unit_directive",
      "patterns": [
        "^Description=",
        "^Documentation=",
        "^After=",
        "^Before=",
        "^Requires=",
        "^Wants=",
        "^Conflicts=",
        "^BindsTo="
      ],
      "includeDeclaration": true,
      "description": "[Unit] section directive references"
    },
    {
      "symbol": "service_directive",
      "patterns": [
        "^Type=",
        "^ExecStart=",
        "^ExecStartPre=",
        "^ExecStartPost=",
        "^ExecStop=",
        "^ExecReload=",
        "^Restart=",
        "^RestartSec=",
        "^User=",
        "^Group=",
        "^WorkingDirectory=",
        "^Environment=",
        "^EnvironmentFile="
      ],
      "includeDeclaration": true,
      "description": "[Service] section directive references"
    },
    {
      "symbol": "install_directive",
      "patterns": [
        "^WantedBy=",
        "^RequiredBy=",
        "^Alias=",
        "^Also="
      ],
      "includeDeclaration": true,
      "description": "[Install] section directive references"
    },
    {
      "symbol": "unit_ref",
      "patterns": [
        "\\w+\\.(service|socket|timer|mount|target|path|slice|scope)\\b"
      ],
      "includeDeclaration": true,
      "description": "Unit file name references (foo.service, bar.timer)"
    },
    {
      "symbol": "specifier_ref",
      "patterns": [
        "%[nNpPiIfcrRtTsSCdDhHvVbBGULMju]"
      ],
      "includeDeclaration": true,
      "description": "Unit specifier references (%n, %i, %u)"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    },
    {
      "kind": "comment_reference",
      "pattern": "@(?:see|link|param|returns?)\\s+(\\w+)",
      "description": "Documentation reference"
    },
    {
      "kind": "decorator",
      "pattern": "@(\\w+)",
      "description": "Decorator/annotation reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_-]*",
  "includeDeclaration": true
}
