{
  "language": "systemd",
  "referencePatterns": [
    {
      "symbol": "section_ref",
      "patterns": [
        "^\\[(Unit|Service|Install|Timer|Socket|Mount|Automount|Swap|Path|Slice|Scope)\\]"
      ],
      "includeDeclaration": true,
      "description": "Section header references ([Unit], [Service], [Install])"
    },
    {
      "symbol": "unit_directive",
      "patterns": [
        "^Description=",
        "^Documentation=",
        "^After=",
        "^Before=",
        "^Requires=",
        "^Wants=",
        "^Conflicts=",
        "^BindsTo="
      ],
      "includeDeclaration": true,
      "description": "[Unit] section directive references"
    },
    {
      "symbol": "service_directive",
      "patterns": [
        "^Type=",
        "^ExecStart=",
        "^ExecStartPre=",
        "^ExecStartPost=",
        "^ExecStop=",
        "^ExecReload=",
        "^Restart=",
        "^RestartSec=",
        "^User=",
        "^Group=",
        "^WorkingDirectory=",
        "^Environment=",
        "^EnvironmentFile="
      ],
      "includeDeclaration": true,
      "description": "[Service] section directive references"
    },
    {
      "symbol": "install_directive",
      "patterns": [
        "^WantedBy=",
        "^RequiredBy=",
        "^Alias=",
        "^Also="
      ],
      "includeDeclaration": true,
      "description": "[Install] section directive references"
    },
    {
      "symbol": "unit_ref",
      "patterns": [
        "\\w+\\.(service|socket|timer|mount|target|path|slice|scope)\\b"
      ],
      "includeDeclaration": true,
      "description": "Unit file name references (foo.service, bar.timer)"
    },
    {
      "symbol": "specifier_ref",
      "patterns": [
        "%[nNpPiIfcrRtTsSCdDhHvVbBGULMju]"
      ],
      "includeDeclaration": true,
      "description": "Unit specifier references (%n, %i, %u)"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_-]*"
}
