{
  "language": "powerquery",
  "referencePatterns": [
    {
      "symbol": "let_ref",
      "patterns": [
        "\\blet\\b",
        "\\bin\\b"
      ],
      "includeDeclaration": true,
      "description": "Let..in expression references"
    },
    {
      "symbol": "step_ref",
      "patterns": [
        "\\b\\w+\\s*=\\s*"
      ],
      "includeDeclaration": true,
      "description": "Step/variable assignment references"
    },
    {
      "symbol": "function_call",
      "patterns": [
        "\\b[A-Z]\\w+\\.\\w+\\s*\\(",
        "\\beach\\b",
        "\\bList\\.\\w+",
        "\\bTable\\.\\w+",
        "\\bRecord\\.\\w+",
        "\\bText\\.\\w+"
      ],
      "includeDeclaration": true,
      "description": "M library function calls"
    },
    {
      "symbol": "type_ref",
      "patterns": [
        "\\btype\\s+\\w+",
        "\\bInt64\\.Type\\b",
        "\\bText\\.Type\\b",
        "\\bNumber\\.Type\\b",
        "\\bDate\\.Type\\b"
      ],
      "includeDeclaration": true,
      "description": "Type references"
    },
    {
      "symbol": "source_ref",
      "patterns": [
        "\\bSource\\b",
        "\\b\\w+\\.Contents\\s*\\(",
        "\\bSql\\.Database\\s*\\(",
        "\\bExcel\\.Workbook\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Data source references"
    },
    {
      "symbol": "parameter_ref",
      "patterns": [
        "\\(\\w+\\s+as\\s+\\w+\\)",
        "#\\\"[^\"]+\\\""
      ],
      "includeDeclaration": true,
      "description": "Function parameters and step name references"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    },
    {
      "kind": "comment_reference",
      "pattern": "@(?:see|link|param|returns?)\\s+(\\w+)",
      "description": "Documentation reference"
    },
    {
      "kind": "decorator",
      "pattern": "@(\\w+)",
      "description": "Decorator/annotation reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_.]*",
  "includeDeclaration": true
}
