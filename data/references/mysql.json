{
  "language": "mysql",
  "referencePatterns": [
    {
      "symbol": "select_ref",
      "patterns": [
        "\\bSELECT\\b",
        "\\bFROM\\b",
        "\\bWHERE\\b",
        "\\bHAVING\\b",
        "\\bGROUP\\s+BY\\b",
        "\\bORDER\\s+BY\\b"
      ],
      "includeDeclaration": true,
      "description": "SELECT query clause references"
    },
    {
      "symbol": "write_ref",
      "patterns": [
        "\\bINSERT\\s+INTO\\b",
        "\\bUPDATE\\b",
        "\\bDELETE\\s+FROM\\b",
        "\\bREPLACE\\s+INTO\\b"
      ],
      "includeDeclaration": true,
      "description": "Write operation references"
    },
    {
      "symbol": "ddl_ref",
      "patterns": [
        "\\bCREATE\\s+TABLE\\b",
        "\\bALTER\\s+TABLE\\b",
        "\\bDROP\\s+TABLE\\b",
        "\\bCREATE\\s+INDEX\\b",
        "\\bCREATE\\s+VIEW\\b",
        "\\bCREATE\\s+DATABASE\\b"
      ],
      "includeDeclaration": true,
      "description": "DDL statement references"
    },
    {
      "symbol": "join_ref",
      "patterns": [
        "\\bJOIN\\b",
        "\\bINNER\\s+JOIN\\b",
        "\\bLEFT\\s+JOIN\\b",
        "\\bRIGHT\\s+JOIN\\b",
        "\\bCROSS\\s+JOIN\\b",
        "\\bON\\b"
      ],
      "includeDeclaration": true,
      "description": "Join clause references"
    },
    {
      "symbol": "function_call",
      "patterns": [
        "\\b(COUNT|SUM|AVG|MIN|MAX|CONCAT|SUBSTRING|DATE_FORMAT|NOW|IFNULL|COALESCE|CAST|CONVERT|GROUP_CONCAT)\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "MySQL built-in function references"
    },
    {
      "symbol": "table_ref",
      "patterns": [
        "\\bFROM\\s+`?\\w+`?",
        "\\bJOIN\\s+`?\\w+`?",
        "\\bINTO\\s+`?\\w+`?",
        "\\bUPDATE\\s+`?\\w+`?"
      ],
      "includeDeclaration": true,
      "description": "Table name references"
    },
    {
      "symbol": "column_ref",
      "patterns": [
        "`\\w+`\\.`\\w+`",
        "\\w+\\.\\w+"
      ],
      "includeDeclaration": true,
      "description": "Column and qualified name references"
    },
    {
      "symbol": "procedure_ref",
      "patterns": [
        "\\bCALL\\s+\\w+",
        "\\bCREATE\\s+PROCEDURE\\b",
        "\\bCREATE\\s+FUNCTION\\b",
        "\\bDELIMITER\\b"
      ],
      "includeDeclaration": true,
      "description": "Stored procedure and function references"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
