{
  "language": "mysql",
  "referencePatterns": [
    {
      "symbol": "select_ref",
      "patterns": [
        "\\bSELECT\\b",
        "\\bFROM\\b",
        "\\bWHERE\\b",
        "\\bHAVING\\b",
        "\\bGROUP\\s+BY\\b",
        "\\bORDER\\s+BY\\b"
      ],
      "includeDeclaration": true,
      "description": "SELECT query clause references"
    },
    {
      "symbol": "write_ref",
      "patterns": [
        "\\bINSERT\\s+INTO\\b",
        "\\bUPDATE\\b",
        "\\bDELETE\\s+FROM\\b",
        "\\bREPLACE\\s+INTO\\b"
      ],
      "includeDeclaration": true,
      "description": "Write operation references"
    },
    {
      "symbol": "ddl_ref",
      "patterns": [
        "\\bCREATE\\s+TABLE\\b",
        "\\bALTER\\s+TABLE\\b",
        "\\bDROP\\s+TABLE\\b",
        "\\bCREATE\\s+INDEX\\b",
        "\\bCREATE\\s+VIEW\\b",
        "\\bCREATE\\s+DATABASE\\b"
      ],
      "includeDeclaration": true,
      "description": "DDL statement references"
    },
    {
      "symbol": "join_ref",
      "patterns": [
        "\\bJOIN\\b",
        "\\bINNER\\s+JOIN\\b",
        "\\bLEFT\\s+JOIN\\b",
        "\\bRIGHT\\s+JOIN\\b",
        "\\bCROSS\\s+JOIN\\b",
        "\\bON\\b"
      ],
      "includeDeclaration": true,
      "description": "Join clause references"
    },
    {
      "symbol": "function_call",
      "patterns": [
        "\\b(COUNT|SUM|AVG|MIN|MAX|CONCAT|SUBSTRING|DATE_FORMAT|NOW|IFNULL|COALESCE|CAST|CONVERT|GROUP_CONCAT)\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "MySQL built-in function references"
    },
    {
      "symbol": "table_ref",
      "patterns": [
        "\\bFROM\\s+`?\\w+`?",
        "\\bJOIN\\s+`?\\w+`?",
        "\\bINTO\\s+`?\\w+`?",
        "\\bUPDATE\\s+`?\\w+`?"
      ],
      "includeDeclaration": true,
      "description": "Table name references"
    },
    {
      "symbol": "column_ref",
      "patterns": [
        "`\\w+`\\.`\\w+`",
        "\\w+\\.\\w+"
      ],
      "includeDeclaration": true,
      "description": "Column and qualified name references"
    },
    {
      "symbol": "procedure_ref",
      "patterns": [
        "\\bCALL\\s+\\w+",
        "\\bCREATE\\s+PROCEDURE\\b",
        "\\bCREATE\\s+FUNCTION\\b",
        "\\bDELIMITER\\b"
      ],
      "includeDeclaration": true,
      "description": "Stored procedure and function references"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier",
      "includeDeclaration": false,
      "symbol": "identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference",
      "includeDeclaration": false,
      "symbol": "function_call"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference",
      "includeDeclaration": false,
      "symbol": "import"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference",
      "includeDeclaration": false,
      "symbol": "type_reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference",
      "includeDeclaration": false,
      "symbol": "property_access"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference",
      "includeDeclaration": false,
      "symbol": "string_literal"
    },
    {
      "symbol": "import_statement",
      "patterns": [
        "(import|require|use|include|load)\\s+"
      ],
      "includeDeclaration": false,
      "description": "Import/include statement reference"
    },
    {
      "symbol": "function_definition",
      "patterns": [
        "(function|func|fn|def|sub|proc|method)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Function/method definition reference"
    },
    {
      "symbol": "class_definition",
      "patterns": [
        "(class|struct|type|interface|trait|record|enum)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Type definition reference"
    },
    {
      "symbol": "variable_declaration",
      "patterns": [
        "(var|let|const|val|my|local|dim|set)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Variable declaration reference"
    },
    {
      "symbol": "property_access",
      "patterns": [
        "\\.(\\w+)"
      ],
      "includeDeclaration": false,
      "description": "Property/field access reference"
    },
    {
      "symbol": "type_annotation",
      "patterns": [
        ":\\s*(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Type annotation reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "includeDeclaration": true
}
