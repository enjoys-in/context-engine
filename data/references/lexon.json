{
  "language": "lexon",
  "referencePatterns": [
    {
      "symbol": "clause_ref",
      "patterns": [
        "\\bCLAUSE\\b",
        "\\bTERMS?\\b",
        "\\bCOVENANT\\b"
      ],
      "includeDeclaration": true,
      "description": "Legal clause and covenant references"
    },
    {
      "symbol": "party_ref",
      "patterns": [
        "\\bLESSOR\\b",
        "\\bLESSEE\\b",
        "\\bPAYER\\b",
        "\\bPAYEE\\b",
        "\\bBUYER\\b",
        "\\bSELLER\\b"
      ],
      "includeDeclaration": true,
      "description": "Party role references"
    },
    {
      "symbol": "action_ref",
      "patterns": [
        "\\bPAY\\b",
        "\\bSEND\\b",
        "\\bCHARGE\\b",
        "\\bGRANT\\b",
        "\\bTERMINATE\\b",
        "\\bFIX\\b"
      ],
      "includeDeclaration": true,
      "description": "Action/verb references"
    },
    {
      "symbol": "type_ref",
      "patterns": [
        "\\bAMOUNT\\b",
        "\\bPERSON\\b",
        "\\bTEXT\\b",
        "\\bTIME\\b",
        "\\bBINARY\\b",
        "\\bDATE\\b"
      ],
      "includeDeclaration": true,
      "description": "Lexon type references"
    },
    {
      "symbol": "statement_ref",
      "patterns": [
        "\\bLEX\\b",
        "\\bPER\\b",
        "\\bIF\\b",
        "\\bTHEN\\b",
        "\\bOTHERWISE\\b"
      ],
      "includeDeclaration": true,
      "description": "Statement structure keywords"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    },
    {
      "kind": "comment_reference",
      "pattern": "@(?:see|link|param|returns?)\\s+(\\w+)",
      "description": "Documentation reference"
    },
    {
      "kind": "decorator",
      "pattern": "@(\\w+)",
      "description": "Decorator/annotation reference"
    },
    {
      "kind": "class_reference",
      "pattern": "\\b([A-Z]\\w+)\\b",
      "description": "Class/type name reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_ ]*",
  "includeDeclaration": true
}
