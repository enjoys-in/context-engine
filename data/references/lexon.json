{
  "language": "lexon",
  "referencePatterns": [
    {
      "symbol": "clause_ref",
      "patterns": [
        "\\bCLAUSE\\b",
        "\\bTERMS?\\b",
        "\\bCOVENANT\\b"
      ],
      "includeDeclaration": true,
      "description": "Legal clause and covenant references"
    },
    {
      "symbol": "party_ref",
      "patterns": [
        "\\bLESSOR\\b",
        "\\bLESSEE\\b",
        "\\bPAYER\\b",
        "\\bPAYEE\\b",
        "\\bBUYER\\b",
        "\\bSELLER\\b"
      ],
      "includeDeclaration": true,
      "description": "Party role references"
    },
    {
      "symbol": "action_ref",
      "patterns": [
        "\\bPAY\\b",
        "\\bSEND\\b",
        "\\bCHARGE\\b",
        "\\bGRANT\\b",
        "\\bTERMINATE\\b",
        "\\bFIX\\b"
      ],
      "includeDeclaration": true,
      "description": "Action/verb references"
    },
    {
      "symbol": "type_ref",
      "patterns": [
        "\\bAMOUNT\\b",
        "\\bPERSON\\b",
        "\\bTEXT\\b",
        "\\bTIME\\b",
        "\\bBINARY\\b",
        "\\bDATE\\b"
      ],
      "includeDeclaration": true,
      "description": "Lexon type references"
    },
    {
      "symbol": "statement_ref",
      "patterns": [
        "\\bLEX\\b",
        "\\bPER\\b",
        "\\bIF\\b",
        "\\bTHEN\\b",
        "\\bOTHERWISE\\b"
      ],
      "includeDeclaration": true,
      "description": "Statement structure keywords"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_ ]*"
}
