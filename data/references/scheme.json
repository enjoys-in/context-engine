{
  "language": "scheme",
  "referencePatterns": [
    {
      "symbol": "define_ref",
      "patterns": [
        "\\(define\\s+\\S+",
        "\\(define-syntax\\s+\\S+",
        "\\(define-record-type\\s+\\S+"
      ],
      "includeDeclaration": true,
      "description": "Define forms (define, define-syntax, define-record-type)"
    },
    {
      "symbol": "lambda_ref",
      "patterns": [
        "\\(lambda\\s+",
        "\\(let\\s+",
        "\\(let\\*\\s+",
        "\\(letrec\\s+"
      ],
      "includeDeclaration": true,
      "description": "Lambda and let binding forms"
    },
    {
      "symbol": "set_ref",
      "patterns": [
        "\\(set!\\s+\\S+"
      ],
      "includeDeclaration": true,
      "description": "Mutation (set!) references"
    },
    {
      "symbol": "list_ops",
      "patterns": [
        "\\(car\\s+",
        "\\(cdr\\s+",
        "\\(cons\\s+",
        "\\(list\\s+",
        "\\(append\\s+",
        "\\(length\\s+"
      ],
      "includeDeclaration": true,
      "description": "List operation references (car, cdr, cons, list)"
    },
    {
      "symbol": "higher_order",
      "patterns": [
        "\\(map\\s+",
        "\\(filter\\s+",
        "\\(fold-left\\s+",
        "\\(fold-right\\s+",
        "\\(for-each\\s+",
        "\\(apply\\s+"
      ],
      "includeDeclaration": true,
      "description": "Higher-order function references (map, filter, fold)"
    },
    {
      "symbol": "predicate_ref",
      "patterns": [
        "\\(null\\?\\s+",
        "\\(pair\\?\\s+",
        "\\(equal\\?\\s+",
        "\\(eqv\\?\\s+",
        "\\(eq\\?\\s+",
        "\\(zero\\?\\s+",
        "\\(number\\?\\s+",
        "\\(string\\?\\s+"
      ],
      "includeDeclaration": true,
      "description": "Predicate references (null?, pair?, equal?)"
    },
    {
      "symbol": "syntax_ref",
      "patterns": [
        "\\(cond\\s+",
        "\\(case\\s+",
        "\\(when\\s+",
        "\\(unless\\s+",
        "\\(begin\\s+",
        "\\(do\\s+"
      ],
      "includeDeclaration": true,
      "description": "Syntax/control form references"
    },
    {
      "symbol": "import_ref",
      "patterns": [
        "\\(import\\s+",
        "\\(library\\s+",
        "\\(require\\s+"
      ],
      "includeDeclaration": true,
      "description": "Import and library references"
    }
  ],
  "identifierPattern": "[a-zA-Z_!$%&*+/:<=>?@^~-][a-zA-Z0-9_!$%&*+/:<=>?@^~.-]*"
}
