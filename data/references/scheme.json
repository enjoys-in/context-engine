{
  "language": "scheme",
  "referencePatterns": [
    {
      "symbol": "define_ref",
      "patterns": [
        "\\(define\\s+\\S+",
        "\\(define-syntax\\s+\\S+",
        "\\(define-record-type\\s+\\S+"
      ],
      "includeDeclaration": true,
      "description": "Define forms (define, define-syntax, define-record-type)"
    },
    {
      "symbol": "lambda_ref",
      "patterns": [
        "\\(lambda\\s+",
        "\\(let\\s+",
        "\\(let\\*\\s+",
        "\\(letrec\\s+"
      ],
      "includeDeclaration": true,
      "description": "Lambda and let binding forms"
    },
    {
      "symbol": "set_ref",
      "patterns": [
        "\\(set!\\s+\\S+"
      ],
      "includeDeclaration": true,
      "description": "Mutation (set!) references"
    },
    {
      "symbol": "list_ops",
      "patterns": [
        "\\(car\\s+",
        "\\(cdr\\s+",
        "\\(cons\\s+",
        "\\(list\\s+",
        "\\(append\\s+",
        "\\(length\\s+"
      ],
      "includeDeclaration": true,
      "description": "List operation references (car, cdr, cons, list)"
    },
    {
      "symbol": "higher_order",
      "patterns": [
        "\\(map\\s+",
        "\\(filter\\s+",
        "\\(fold-left\\s+",
        "\\(fold-right\\s+",
        "\\(for-each\\s+",
        "\\(apply\\s+"
      ],
      "includeDeclaration": true,
      "description": "Higher-order function references (map, filter, fold)"
    },
    {
      "symbol": "predicate_ref",
      "patterns": [
        "\\(null\\?\\s+",
        "\\(pair\\?\\s+",
        "\\(equal\\?\\s+",
        "\\(eqv\\?\\s+",
        "\\(eq\\?\\s+",
        "\\(zero\\?\\s+",
        "\\(number\\?\\s+",
        "\\(string\\?\\s+"
      ],
      "includeDeclaration": true,
      "description": "Predicate references (null?, pair?, equal?)"
    },
    {
      "symbol": "syntax_ref",
      "patterns": [
        "\\(cond\\s+",
        "\\(case\\s+",
        "\\(when\\s+",
        "\\(unless\\s+",
        "\\(begin\\s+",
        "\\(do\\s+"
      ],
      "includeDeclaration": true,
      "description": "Syntax/control form references"
    },
    {
      "symbol": "import_ref",
      "patterns": [
        "\\(import\\s+",
        "\\(library\\s+",
        "\\(require\\s+"
      ],
      "includeDeclaration": true,
      "description": "Import and library references"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier",
      "includeDeclaration": false,
      "symbol": "identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference",
      "includeDeclaration": false,
      "symbol": "function_call"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference",
      "includeDeclaration": false,
      "symbol": "import"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference",
      "includeDeclaration": false,
      "symbol": "type_reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference",
      "includeDeclaration": false,
      "symbol": "property_access"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference",
      "includeDeclaration": false,
      "symbol": "string_literal"
    },
    {
      "symbol": "import_statement",
      "patterns": [
        "(import|require|use|include|load)\\s+"
      ],
      "includeDeclaration": false,
      "description": "Import/include statement reference"
    },
    {
      "symbol": "function_definition",
      "patterns": [
        "(function|func|fn|def|sub|proc|method)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Function/method definition reference"
    },
    {
      "symbol": "class_definition",
      "patterns": [
        "(class|struct|type|interface|trait|record|enum)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Type definition reference"
    },
    {
      "symbol": "variable_declaration",
      "patterns": [
        "(var|let|const|val|my|local|dim|set)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Variable declaration reference"
    },
    {
      "symbol": "function_call",
      "patterns": [
        "\\b(\\w+)\\s*\\("
      ],
      "includeDeclaration": false,
      "description": "Function/method call reference"
    },
    {
      "symbol": "property_access",
      "patterns": [
        "\\.(\\w+)"
      ],
      "includeDeclaration": false,
      "description": "Property/field access reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_!$%&*+/:<=>?@^~-][a-zA-Z0-9_!$%&*+/:<=>?@^~.-]*",
  "includeDeclaration": true
}
