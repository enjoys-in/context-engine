{
  "language": "scss",
  "referencePatterns": [
    {
      "symbol": "variable_ref",
      "patterns": [
        "\\$[a-zA-Z_][a-zA-Z0-9_-]*"
      ],
      "includeDeclaration": true,
      "description": "SCSS variable references ($color, $size)"
    },
    {
      "symbol": "mixin_ref",
      "patterns": [
        "@mixin\\s+\\w[\\w-]*",
        "@include\\s+\\w[\\w-]*"
      ],
      "includeDeclaration": true,
      "description": "Mixin definitions and includes"
    },
    {
      "symbol": "extend_ref",
      "patterns": [
        "@extend\\s+[.#%]\\w[\\w-]*",
        "%\\w[\\w-]*"
      ],
      "includeDeclaration": true,
      "description": "Extend and placeholder selector references"
    },
    {
      "symbol": "function_ref",
      "patterns": [
        "@function\\s+\\w[\\w-]*",
        "\\b\\w[\\w-]*\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Function definitions and calls"
    },
    {
      "symbol": "selector_ref",
      "patterns": [
        "\\.\\w[\\w-]*",
        "#\\w[\\w-]*",
        "&[a-zA-Z_.-]"
      ],
      "includeDeclaration": true,
      "description": "Class, ID, and parent selector references"
    },
    {
      "symbol": "import_ref",
      "patterns": [
        "@use\\s+'[^']+'",
        "@forward\\s+'[^']+'",
        "@import\\s+'[^']+'"
      ],
      "includeDeclaration": true,
      "description": "@use, @forward, and @import references"
    },
    {
      "symbol": "module_ref",
      "patterns": [
        "\\w+\\.\\$\\w+",
        "\\w+\\.\\w+\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Namespaced module member references"
    },
    {
      "symbol": "control_ref",
      "patterns": [
        "@if\\b",
        "@else\\b",
        "@each\\s+\\$\\w+",
        "@for\\s+\\$\\w+",
        "@while\\b"
      ],
      "includeDeclaration": true,
      "description": "Control directive references (@if, @each, @for)"
    }
  ],
  "identifierPattern": "[a-zA-Z_$][a-zA-Z0-9_-]*"
}
