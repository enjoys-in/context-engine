{
  "language": "protobuf",
  "referencePatterns": [
    {
      "symbol": "message_ref",
      "patterns": [
        "\\bmessage\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Message type definitions"
    },
    {
      "symbol": "service_ref",
      "patterns": [
        "\\bservice\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Service definitions"
    },
    {
      "symbol": "rpc_ref",
      "patterns": [
        "\\brpc\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "RPC method definitions"
    },
    {
      "symbol": "enum_ref",
      "patterns": [
        "\\benum\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Enum type definitions"
    },
    {
      "symbol": "field_ref",
      "patterns": [
        "\\b(string|bytes|bool|double|float|int32|int64|uint32|uint64|sint32|sint64|fixed32|fixed64|sfixed32|sfixed64)\\s+\\w+",
        "\\brepeated\\s+\\w+",
        "\\boptional\\s+\\w+",
        "\\brequired\\s+\\w+",
        "\\bmap<"
      ],
      "includeDeclaration": true,
      "description": "Field type and modifier references"
    },
    {
      "symbol": "import_ref",
      "patterns": [
        "\\bimport\\s+\"[^\"]+\"",
        "\\bimport\\s+public\\s+\"[^\"]+\""
      ],
      "includeDeclaration": true,
      "description": "Import references"
    },
    {
      "symbol": "package_ref",
      "patterns": [
        "\\bpackage\\s+[\\w.]+"
      ],
      "includeDeclaration": true,
      "description": "Package declarations"
    },
    {
      "symbol": "option_ref",
      "patterns": [
        "\\boption\\s+\\w+",
        "\\boption\\s+\\([^)]+\\)"
      ],
      "includeDeclaration": true,
      "description": "Option references"
    },
    {
      "symbol": "oneof_ref",
      "patterns": [
        "\\boneof\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Oneof field group references"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_.]*"
}
