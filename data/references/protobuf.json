{
  "language": "protobuf",
  "referencePatterns": [
    {
      "symbol": "message_ref",
      "patterns": [
        "\\bmessage\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Message type definitions"
    },
    {
      "symbol": "service_ref",
      "patterns": [
        "\\bservice\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Service definitions"
    },
    {
      "symbol": "rpc_ref",
      "patterns": [
        "\\brpc\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "RPC method definitions"
    },
    {
      "symbol": "enum_ref",
      "patterns": [
        "\\benum\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Enum type definitions"
    },
    {
      "symbol": "field_ref",
      "patterns": [
        "\\b(string|bytes|bool|double|float|int32|int64|uint32|uint64|sint32|sint64|fixed32|fixed64|sfixed32|sfixed64)\\s+\\w+",
        "\\brepeated\\s+\\w+",
        "\\boptional\\s+\\w+",
        "\\brequired\\s+\\w+",
        "\\bmap<"
      ],
      "includeDeclaration": true,
      "description": "Field type and modifier references"
    },
    {
      "symbol": "import_ref",
      "patterns": [
        "\\bimport\\s+\"[^\"]+\"",
        "\\bimport\\s+public\\s+\"[^\"]+\""
      ],
      "includeDeclaration": true,
      "description": "Import references"
    },
    {
      "symbol": "package_ref",
      "patterns": [
        "\\bpackage\\s+[\\w.]+"
      ],
      "includeDeclaration": true,
      "description": "Package declarations"
    },
    {
      "symbol": "option_ref",
      "patterns": [
        "\\boption\\s+\\w+",
        "\\boption\\s+\\([^)]+\\)"
      ],
      "includeDeclaration": true,
      "description": "Option references"
    },
    {
      "symbol": "oneof_ref",
      "patterns": [
        "\\boneof\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Oneof field group references"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier",
      "includeDeclaration": false,
      "symbol": "identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference",
      "includeDeclaration": false,
      "symbol": "function_call"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference",
      "includeDeclaration": false,
      "symbol": "import"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference",
      "includeDeclaration": false,
      "symbol": "type_reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference",
      "includeDeclaration": false,
      "symbol": "property_access"
    },
    {
      "symbol": "import_statement",
      "patterns": [
        "(import|require|use|include|load)\\s+"
      ],
      "includeDeclaration": false,
      "description": "Import/include statement reference"
    },
    {
      "symbol": "function_definition",
      "patterns": [
        "(function|func|fn|def|sub|proc|method)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Function/method definition reference"
    },
    {
      "symbol": "class_definition",
      "patterns": [
        "(class|struct|type|interface|trait|record|enum)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Type definition reference"
    },
    {
      "symbol": "variable_declaration",
      "patterns": [
        "(var|let|const|val|my|local|dim|set)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Variable declaration reference"
    },
    {
      "symbol": "function_call",
      "patterns": [
        "\\b(\\w+)\\s*\\("
      ],
      "includeDeclaration": false,
      "description": "Function/method call reference"
    },
    {
      "symbol": "property_access",
      "patterns": [
        "\\.(\\w+)"
      ],
      "includeDeclaration": false,
      "description": "Property/field access reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_.]*",
  "includeDeclaration": true
}
