{
  "language": "msdax",
  "referencePatterns": [
    {
      "symbol": "measure_ref",
      "patterns": [
        "\\b\\w+\\s*=\\s*",
        "DEFINE\\s+MEASURE\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Measure definitions"
    },
    {
      "symbol": "function_call",
      "patterns": [
        "\\b(CALCULATE|FILTER|ALL|VALUES|SUMX|AVERAGEX|COUNTROWS|RELATED|RELATEDTABLE|EARLIER|BLANK|IF|SWITCH|DIVIDE|FORMAT|HASONEVALUE|SELECTEDVALUE|TREATAS|USERELATIONSHIP)\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "DAX function calls"
    },
    {
      "symbol": "table_ref",
      "patterns": [
        "'[^']+'\\[",
        "\\w+\\[\\w+\\]"
      ],
      "includeDeclaration": true,
      "description": "Table and column references ('Table'[Column])"
    },
    {
      "symbol": "aggregation_ref",
      "patterns": [
        "\\b(SUM|AVERAGE|COUNT|COUNTA|COUNTBLANK|MIN|MAX|DISTINCTCOUNT)\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Aggregation function references"
    },
    {
      "symbol": "time_intel",
      "patterns": [
        "\\b(DATEADD|DATESYTD|DATESBETWEEN|TOTALYTD|SAMEPERIODLASTYEAR|PARALLELPERIOD)\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Time intelligence function references"
    },
    {
      "symbol": "variable_ref",
      "patterns": [
        "\\bVAR\\s+\\w+",
        "\\bRETURN\\b"
      ],
      "includeDeclaration": true,
      "description": "Variable and RETURN references"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier",
      "includeDeclaration": false,
      "symbol": "identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference",
      "includeDeclaration": false,
      "symbol": "function_call"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference",
      "includeDeclaration": false,
      "symbol": "import"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference",
      "includeDeclaration": false,
      "symbol": "type_reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference",
      "includeDeclaration": false,
      "symbol": "property_access"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference",
      "includeDeclaration": false,
      "symbol": "string_literal"
    },
    {
      "kind": "comment_reference",
      "pattern": "@(?:see|link|param|returns?)\\s+(\\w+)",
      "description": "Documentation reference",
      "includeDeclaration": false,
      "symbol": "comment_reference"
    },
    {
      "kind": "decorator",
      "pattern": "@(\\w+)",
      "description": "Decorator/annotation reference",
      "includeDeclaration": false,
      "symbol": "decorator"
    },
    {
      "symbol": "import_statement",
      "patterns": [
        "(import|require|use|include|load)\\s+"
      ],
      "includeDeclaration": false,
      "description": "Import/include statement reference"
    },
    {
      "symbol": "function_definition",
      "patterns": [
        "(function|func|fn|def|sub|proc|method)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Function/method definition reference"
    },
    {
      "symbol": "class_definition",
      "patterns": [
        "(class|struct|type|interface|trait|record|enum)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Type definition reference"
    },
    {
      "symbol": "variable_declaration",
      "patterns": [
        "(var|let|const|val|my|local|dim|set)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Variable declaration reference"
    },
    {
      "symbol": "property_access",
      "patterns": [
        "\\.(\\w+)"
      ],
      "includeDeclaration": false,
      "description": "Property/field access reference"
    },
    {
      "symbol": "type_annotation",
      "patterns": [
        ":\\s*(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Type annotation reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_ ]*",
  "includeDeclaration": true
}
