{
  "language": "clojure",
  "referencePatterns": [
    {
      "symbol": "defn",
      "patterns": [
        "\\(defn-?\\s+\\S+",
        "\\(defmulti\\s+\\S+",
        "\\(defmethod\\s+\\S+"
      ],
      "includeDeclaration": true,
      "description": "Function definitions (defn, defmulti, defmethod)"
    },
    {
      "symbol": "def",
      "patterns": [
        "\\(def\\s+\\S+",
        "\\(defonce\\s+\\S+"
      ],
      "includeDeclaration": true,
      "description": "Var definitions (def, defonce)"
    },
    {
      "symbol": "defmacro",
      "patterns": [
        "\\(defmacro\\s+\\S+"
      ],
      "includeDeclaration": true,
      "description": "Macro definitions"
    },
    {
      "symbol": "ns",
      "patterns": [
        "\\(ns\\s+\\S+"
      ],
      "includeDeclaration": true,
      "description": "Namespace declarations"
    },
    {
      "symbol": "require",
      "patterns": [
        "\\(:require\\s",
        "\\(require\\s+'?\\S+"
      ],
      "includeDeclaration": true,
      "description": "Require/import references"
    },
    {
      "symbol": "atom_ref",
      "patterns": [
        "\\(atom\\s+",
        "\\(deref\\s+",
        "@\\w+"
      ],
      "includeDeclaration": true,
      "description": "Atom, deref, and @ references"
    },
    {
      "symbol": "swap_reset",
      "patterns": [
        "\\(swap!\\s+",
        "\\(reset!\\s+"
      ],
      "includeDeclaration": true,
      "description": "State mutation (swap!, reset!)"
    },
    {
      "symbol": "protocol_ref",
      "patterns": [
        "\\(defprotocol\\s+\\S+",
        "\\(defrecord\\s+\\S+",
        "\\(deftype\\s+\\S+"
      ],
      "includeDeclaration": true,
      "description": "Protocol, record, and type definitions"
    },
    {
      "symbol": "keyword_ref",
      "patterns": [
        ":[a-zA-Z][a-zA-Z0-9_-]*(?:/[a-zA-Z0-9_-]+)?"
      ],
      "includeDeclaration": true,
      "description": "Keyword references"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier",
      "includeDeclaration": false,
      "symbol": "identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference",
      "includeDeclaration": false,
      "symbol": "function_call"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference",
      "includeDeclaration": false,
      "symbol": "import"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference",
      "includeDeclaration": false,
      "symbol": "type_reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference",
      "includeDeclaration": false,
      "symbol": "property_access"
    },
    {
      "symbol": "import_statement",
      "patterns": [
        "(import|require|use|include|load)\\s+"
      ],
      "includeDeclaration": false,
      "description": "Import/include statement reference"
    },
    {
      "symbol": "function_definition",
      "patterns": [
        "(function|func|fn|def|sub|proc|method)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Function/method definition reference"
    },
    {
      "symbol": "class_definition",
      "patterns": [
        "(class|struct|type|interface|trait|record|enum)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Type definition reference"
    },
    {
      "symbol": "variable_declaration",
      "patterns": [
        "(var|let|const|val|my|local|dim|set)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Variable declaration reference"
    },
    {
      "symbol": "function_call",
      "patterns": [
        "\\b(\\w+)\\s*\\("
      ],
      "includeDeclaration": false,
      "description": "Function/method call reference"
    },
    {
      "symbol": "property_access",
      "patterns": [
        "\\.(\\w+)"
      ],
      "includeDeclaration": false,
      "description": "Property/field access reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_*+!?<>=.-][a-zA-Z0-9_*+!?<>=.-]*",
  "includeDeclaration": true
}
