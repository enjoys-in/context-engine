{
  "language": "ssh_config",
  "referencePatterns": [
    {
      "symbol": "host_ref",
      "patterns": [
        "^Host\\s+\\S+",
        "^Match\\s+.+"
      ],
      "includeDeclaration": true,
      "description": "Host and Match block definitions"
    },
    {
      "symbol": "identity_ref",
      "patterns": [
        "\\bIdentityFile\\s+\\S+",
        "\\bIdentityAgent\\s+\\S+",
        "\\bCertificateFile\\s+\\S+"
      ],
      "includeDeclaration": true,
      "description": "Identity and certificate file references"
    },
    {
      "symbol": "connection_ref",
      "patterns": [
        "\\bHostName\\s+\\S+",
        "\\bPort\\s+\\d+",
        "\\bUser\\s+\\S+",
        "\\bProxyJump\\s+\\S+",
        "\\bProxyCommand\\s+"
      ],
      "includeDeclaration": true,
      "description": "Connection directive references"
    },
    {
      "symbol": "include_ref",
      "patterns": [
        "\\bInclude\\s+\\S+"
      ],
      "includeDeclaration": true,
      "description": "Include directive references"
    },
    {
      "symbol": "forward_ref",
      "patterns": [
        "\\bLocalForward\\s+",
        "\\bRemoteForward\\s+",
        "\\bDynamicForward\\s+"
      ],
      "includeDeclaration": true,
      "description": "Port forwarding directive references"
    },
    {
      "symbol": "auth_ref",
      "patterns": [
        "\\bPreferredAuthentications\\s+",
        "\\bPubkeyAuthentication\\s+",
        "\\bPasswordAuthentication\\s+"
      ],
      "includeDeclaration": true,
      "description": "Authentication directive references"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    },
    {
      "kind": "comment_reference",
      "pattern": "@(?:see|link|param|returns?)\\s+(\\w+)",
      "description": "Documentation reference"
    },
    {
      "kind": "decorator",
      "pattern": "@(\\w+)",
      "description": "Decorator/annotation reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_.-]*",
  "includeDeclaration": true
}
