{
  "language": "cameligo",
  "referencePatterns": [
    {
      "symbol": "let_binding",
      "patterns": [
        "\\blet\\s+\\w+",
        "\\blet\\s+rec\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Let bindings and recursive bindings"
    },
    {
      "symbol": "type_def",
      "patterns": [
        "\\btype\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Type definitions"
    },
    {
      "symbol": "function_call",
      "patterns": [
        "\\b\\w+\\s*\\(",
        "\\b\\w+\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Function applications"
    },
    {
      "symbol": "module_ref",
      "patterns": [
        "\\bmodule\\s+\\w+",
        "\\w+\\.\\w+"
      ],
      "includeDeclaration": true,
      "description": "Module references and qualified access"
    },
    {
      "symbol": "match_pattern",
      "patterns": [
        "\\bmatch\\s+\\w+\\s+with",
        "\\|\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Pattern matching references"
    },
    {
      "symbol": "entrypoint",
      "patterns": [
        "\\[@entry\\]",
        "\\blet\\s+main\\b"
      ],
      "includeDeclaration": true,
      "description": "Contract entrypoint references"
    },
    {
      "symbol": "variant_ref",
      "patterns": [
        "\\b[A-Z][a-zA-Z0-9_]*\\b"
      ],
      "includeDeclaration": true,
      "description": "Variant/constructor references"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    },
    {
      "kind": "comment_reference",
      "pattern": "@(?:see|link|param|returns?)\\s+(\\w+)",
      "description": "Documentation reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "includeDeclaration": true
}
