{
  "language": "cameligo",
  "referencePatterns": [
    {
      "symbol": "let_binding",
      "patterns": [
        "\\blet\\s+\\w+",
        "\\blet\\s+rec\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Let bindings and recursive bindings"
    },
    {
      "symbol": "type_def",
      "patterns": [
        "\\btype\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Type definitions"
    },
    {
      "symbol": "function_call",
      "patterns": [
        "\\b\\w+\\s*\\(",
        "\\b\\w+\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Function applications"
    },
    {
      "symbol": "module_ref",
      "patterns": [
        "\\bmodule\\s+\\w+",
        "\\w+\\.\\w+"
      ],
      "includeDeclaration": true,
      "description": "Module references and qualified access"
    },
    {
      "symbol": "match_pattern",
      "patterns": [
        "\\bmatch\\s+\\w+\\s+with",
        "\\|\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Pattern matching references"
    },
    {
      "symbol": "entrypoint",
      "patterns": [
        "\\[@entry\\]",
        "\\blet\\s+main\\b"
      ],
      "includeDeclaration": true,
      "description": "Contract entrypoint references"
    },
    {
      "symbol": "variant_ref",
      "patterns": [
        "\\b[A-Z][a-zA-Z0-9_]*\\b"
      ],
      "includeDeclaration": true,
      "description": "Variant/constructor references"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
