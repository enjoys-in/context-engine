{
  "language": "yaml",
  "referencePatterns": [
    {
      "symbol": "key_ref",
      "patterns": [
        "^\\s*[a-zA-Z_][a-zA-Z0-9_.-]*\\s*:"
      ],
      "includeDeclaration": true,
      "description": "YAML key references"
    },
    {
      "symbol": "anchor_ref",
      "patterns": [
        "&\\w+",
        "\\*\\w+"
      ],
      "includeDeclaration": true,
      "description": "Anchor (&name) and alias (*name) references"
    },
    {
      "symbol": "merge_key",
      "patterns": [
        "<<:\\s*\\*\\w+"
      ],
      "includeDeclaration": true,
      "description": "Merge key (<<: *alias) references"
    },
    {
      "symbol": "tag_ref",
      "patterns": [
        "!!\\w+",
        "!\\w+"
      ],
      "includeDeclaration": true,
      "description": "YAML tag references (!!str, !include)"
    },
    {
      "symbol": "multiline_ref",
      "patterns": [
        "[|>][+-]?\\s*$"
      ],
      "includeDeclaration": true,
      "description": "Block scalar indicator references (|, >)"
    },
    {
      "symbol": "template_ref",
      "patterns": [
        "\\{\\{\\s*[^}]+\\s*\\}\\}",
        "\\$\\{[^}]+\\}"
      ],
      "includeDeclaration": true,
      "description": "Template/variable interpolation references"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_.-]*"
}
