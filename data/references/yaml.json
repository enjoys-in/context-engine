{
  "language": "yaml",
  "referencePatterns": [
    {
      "symbol": "key_ref",
      "patterns": [
        "^\\s*[a-zA-Z_][a-zA-Z0-9_.-]*\\s*:"
      ],
      "includeDeclaration": true,
      "description": "YAML key references"
    },
    {
      "symbol": "anchor_ref",
      "patterns": [
        "&\\w+",
        "\\*\\w+"
      ],
      "includeDeclaration": true,
      "description": "Anchor (&name) and alias (*name) references"
    },
    {
      "symbol": "merge_key",
      "patterns": [
        "<<:\\s*\\*\\w+"
      ],
      "includeDeclaration": true,
      "description": "Merge key (<<: *alias) references"
    },
    {
      "symbol": "tag_ref",
      "patterns": [
        "!!\\w+",
        "!\\w+"
      ],
      "includeDeclaration": true,
      "description": "YAML tag references (!!str, !include)"
    },
    {
      "symbol": "multiline_ref",
      "patterns": [
        "[|>][+-]?\\s*$"
      ],
      "includeDeclaration": true,
      "description": "Block scalar indicator references (|, >)"
    },
    {
      "symbol": "template_ref",
      "patterns": [
        "\\{\\{\\s*[^}]+\\s*\\}\\}",
        "\\$\\{[^}]+\\}"
      ],
      "includeDeclaration": true,
      "description": "Template/variable interpolation references"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    },
    {
      "kind": "comment_reference",
      "pattern": "@(?:see|link|param|returns?)\\s+(\\w+)",
      "description": "Documentation reference"
    },
    {
      "kind": "decorator",
      "pattern": "@(\\w+)",
      "description": "Decorator/annotation reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_.-]*",
  "includeDeclaration": true
}
