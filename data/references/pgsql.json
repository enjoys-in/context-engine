{
  "language": "pgsql",
  "referencePatterns": [
    {
      "symbol": "select_ref",
      "patterns": [
        "\\bSELECT\\b",
        "\\bFROM\\b",
        "\\bWHERE\\b",
        "\\bHAVING\\b",
        "\\bGROUP\\s+BY\\b",
        "\\bORDER\\s+BY\\b"
      ],
      "includeDeclaration": true,
      "description": "SELECT query clause references"
    },
    {
      "symbol": "write_ref",
      "patterns": [
        "\\bINSERT\\s+INTO\\b",
        "\\bUPDATE\\b",
        "\\bDELETE\\s+FROM\\b",
        "\\bUPSERT\\b"
      ],
      "includeDeclaration": true,
      "description": "Write operation references"
    },
    {
      "symbol": "ddl_ref",
      "patterns": [
        "\\bCREATE\\s+TABLE\\b",
        "\\bALTER\\s+TABLE\\b",
        "\\bDROP\\s+TABLE\\b",
        "\\bCREATE\\s+INDEX\\b",
        "\\bCREATE\\s+VIEW\\b",
        "\\bCREATE\\s+SCHEMA\\b"
      ],
      "includeDeclaration": true,
      "description": "DDL statement references"
    },
    {
      "symbol": "join_ref",
      "patterns": [
        "\\bJOIN\\b",
        "\\bINNER\\s+JOIN\\b",
        "\\bLEFT\\s+JOIN\\b",
        "\\bRIGHT\\s+JOIN\\b",
        "\\bFULL\\s+JOIN\\b",
        "\\bLATERAL\\b",
        "\\bON\\b"
      ],
      "includeDeclaration": true,
      "description": "Join clause references"
    },
    {
      "symbol": "function_call",
      "patterns": [
        "\\b(COUNT|SUM|AVG|MIN|MAX|COALESCE|NULLIF|ARRAY_AGG|STRING_AGG|ROW_NUMBER|RANK|DENSE_RANK|LAG|LEAD|GENERATE_SERIES)\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "PostgreSQL built-in and window function references"
    },
    {
      "symbol": "type_ref",
      "patterns": [
        "\\bSERIAL\\b",
        "\\bBIGSERIAL\\b",
        "\\bUUID\\b",
        "\\bJSONB?\\b",
        "\\bTEXT\\b",
        "\\bBOOLEAN\\b",
        "\\bTIMESTAMPTZ?\\b",
        "\\bINTERVAL\\b"
      ],
      "includeDeclaration": true,
      "description": "PostgreSQL-specific type references"
    },
    {
      "symbol": "cte_ref",
      "patterns": [
        "\\bWITH\\s+\\w+\\s+AS",
        "\\bWITH\\s+RECURSIVE\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Common Table Expression references"
    },
    {
      "symbol": "plpgsql_ref",
      "patterns": [
        "\\bCREATE\\s+FUNCTION\\b",
        "\\bCREATE\\s+PROCEDURE\\b",
        "\\bCREATE\\s+TRIGGER\\b",
        "\\bRETURNS?\\b",
        "\\bDECLARE\\b",
        "\\bBEGIN\\b"
      ],
      "includeDeclaration": true,
      "description": "PL/pgSQL function and procedure references"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier",
      "includeDeclaration": false,
      "symbol": "identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference",
      "includeDeclaration": false,
      "symbol": "function_call"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference",
      "includeDeclaration": false,
      "symbol": "import"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference",
      "includeDeclaration": false,
      "symbol": "type_reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference",
      "includeDeclaration": false,
      "symbol": "property_access"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference",
      "includeDeclaration": false,
      "symbol": "string_literal"
    },
    {
      "symbol": "import_statement",
      "patterns": [
        "(import|require|use|include|load)\\s+"
      ],
      "includeDeclaration": false,
      "description": "Import/include statement reference"
    },
    {
      "symbol": "function_definition",
      "patterns": [
        "(function|func|fn|def|sub|proc|method)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Function/method definition reference"
    },
    {
      "symbol": "class_definition",
      "patterns": [
        "(class|struct|type|interface|trait|record|enum)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Type definition reference"
    },
    {
      "symbol": "variable_declaration",
      "patterns": [
        "(var|let|const|val|my|local|dim|set)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Variable declaration reference"
    },
    {
      "symbol": "property_access",
      "patterns": [
        "\\.(\\w+)"
      ],
      "includeDeclaration": false,
      "description": "Property/field access reference"
    },
    {
      "symbol": "type_annotation",
      "patterns": [
        ":\\s*(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Type annotation reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "includeDeclaration": true
}
