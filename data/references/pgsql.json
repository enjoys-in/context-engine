{
  "language": "pgsql",
  "referencePatterns": [
    {
      "symbol": "select_ref",
      "patterns": [
        "\\bSELECT\\b",
        "\\bFROM\\b",
        "\\bWHERE\\b",
        "\\bHAVING\\b",
        "\\bGROUP\\s+BY\\b",
        "\\bORDER\\s+BY\\b"
      ],
      "includeDeclaration": true,
      "description": "SELECT query clause references"
    },
    {
      "symbol": "write_ref",
      "patterns": [
        "\\bINSERT\\s+INTO\\b",
        "\\bUPDATE\\b",
        "\\bDELETE\\s+FROM\\b",
        "\\bUPSERT\\b"
      ],
      "includeDeclaration": true,
      "description": "Write operation references"
    },
    {
      "symbol": "ddl_ref",
      "patterns": [
        "\\bCREATE\\s+TABLE\\b",
        "\\bALTER\\s+TABLE\\b",
        "\\bDROP\\s+TABLE\\b",
        "\\bCREATE\\s+INDEX\\b",
        "\\bCREATE\\s+VIEW\\b",
        "\\bCREATE\\s+SCHEMA\\b"
      ],
      "includeDeclaration": true,
      "description": "DDL statement references"
    },
    {
      "symbol": "join_ref",
      "patterns": [
        "\\bJOIN\\b",
        "\\bINNER\\s+JOIN\\b",
        "\\bLEFT\\s+JOIN\\b",
        "\\bRIGHT\\s+JOIN\\b",
        "\\bFULL\\s+JOIN\\b",
        "\\bLATERAL\\b",
        "\\bON\\b"
      ],
      "includeDeclaration": true,
      "description": "Join clause references"
    },
    {
      "symbol": "function_call",
      "patterns": [
        "\\b(COUNT|SUM|AVG|MIN|MAX|COALESCE|NULLIF|ARRAY_AGG|STRING_AGG|ROW_NUMBER|RANK|DENSE_RANK|LAG|LEAD|GENERATE_SERIES)\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "PostgreSQL built-in and window function references"
    },
    {
      "symbol": "type_ref",
      "patterns": [
        "\\bSERIAL\\b",
        "\\bBIGSERIAL\\b",
        "\\bUUID\\b",
        "\\bJSONB?\\b",
        "\\bTEXT\\b",
        "\\bBOOLEAN\\b",
        "\\bTIMESTAMPTZ?\\b",
        "\\bINTERVAL\\b"
      ],
      "includeDeclaration": true,
      "description": "PostgreSQL-specific type references"
    },
    {
      "symbol": "cte_ref",
      "patterns": [
        "\\bWITH\\s+\\w+\\s+AS",
        "\\bWITH\\s+RECURSIVE\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Common Table Expression references"
    },
    {
      "symbol": "plpgsql_ref",
      "patterns": [
        "\\bCREATE\\s+FUNCTION\\b",
        "\\bCREATE\\s+PROCEDURE\\b",
        "\\bCREATE\\s+TRIGGER\\b",
        "\\bRETURNS?\\b",
        "\\bDECLARE\\b",
        "\\bBEGIN\\b"
      ],
      "includeDeclaration": true,
      "description": "PL/pgSQL function and procedure references"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
