{
  "language": "redshift",
  "referencePatterns": [
    {
      "symbol": "select_ref",
      "patterns": [
        "\\bSELECT\\b",
        "\\bFROM\\b",
        "\\bWHERE\\b",
        "\\bGROUP\\s+BY\\b",
        "\\bORDER\\s+BY\\b",
        "\\bLIMIT\\b"
      ],
      "includeDeclaration": true,
      "description": "SELECT query clause references"
    },
    {
      "symbol": "write_ref",
      "patterns": [
        "\\bINSERT\\s+INTO\\b",
        "\\bUPDATE\\b",
        "\\bDELETE\\s+FROM\\b",
        "\\bCOPY\\b",
        "\\bUNLOAD\\b"
      ],
      "includeDeclaration": true,
      "description": "Write and COPY/UNLOAD references"
    },
    {
      "symbol": "ddl_ref",
      "patterns": [
        "\\bCREATE\\s+TABLE\\b",
        "\\bCREATE\\s+EXTERNAL\\s+TABLE\\b",
        "\\bALTER\\s+TABLE\\b",
        "\\bDROP\\s+TABLE\\b",
        "\\bCREATE\\s+SCHEMA\\b",
        "\\bCREATE\\s+VIEW\\b"
      ],
      "includeDeclaration": true,
      "description": "DDL and external table references"
    },
    {
      "symbol": "dist_sort",
      "patterns": [
        "\\bDISTKEY\\b",
        "\\bSORTKEY\\b",
        "\\bCOMPOUND\\s+SORTKEY\\b",
        "\\bINTERLEAVED\\s+SORTKEY\\b",
        "\\bDISSTYLE\\b"
      ],
      "includeDeclaration": true,
      "description": "Distribution and sort key references"
    },
    {
      "symbol": "function_call",
      "patterns": [
        "\\b(NVL|GETDATE|DATEADD|DATEDIFF|CONVERT_TIMEZONE|LISTAGG|APPROXIMATE\\s+COUNT|MEDIAN|PERCENTILE_CONT)\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Redshift-specific function references"
    },
    {
      "symbol": "join_ref",
      "patterns": [
        "\\bJOIN\\b",
        "\\bINNER\\s+JOIN\\b",
        "\\bLEFT\\s+JOIN\\b",
        "\\bRIGHT\\s+JOIN\\b",
        "\\bCROSS\\s+JOIN\\b"
      ],
      "includeDeclaration": true,
      "description": "Join clause references"
    },
    {
      "symbol": "spectrum_ref",
      "patterns": [
        "\\bEXTERNAL\\s+SCHEMA\\b",
        "\\bEXTERNAL\\s+TABLE\\b",
        "\\bSPECTRUM\\b"
      ],
      "includeDeclaration": true,
      "description": "Redshift Spectrum external references"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    },
    {
      "kind": "comment_reference",
      "pattern": "@(?:see|link|param|returns?)\\s+(\\w+)",
      "description": "Documentation reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "includeDeclaration": true
}
