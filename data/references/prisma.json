{
  "language": "prisma",
  "referencePatterns": [
    {
      "symbol": "model_reference",
      "patterns": ["\\bmodel\\s+(\\w+)", "\\b(\\w+)\\s+(\\w+)\\[\\]", "\\b(\\w+)\\s+(\\w+)\\?"],
      "includeDeclaration": true,
      "description": "Find all references to a model type"
    },
    {
      "symbol": "field_attribute",
      "patterns": ["@id\\b", "@unique\\b", "@default\\b", "@relation\\b", "@map\\b", "@updatedAt\\b", "@ignore\\b"],
      "includeDeclaration": true,
      "description": "Find all field-level attribute usages"
    },
    {
      "symbol": "block_attribute",
      "patterns": ["@@id\\b", "@@unique\\b", "@@index\\b", "@@map\\b", "@@ignore\\b", "@@fulltext\\b", "@@schema\\b"],
      "includeDeclaration": true,
      "description": "Find all block-level attribute usages"
    },
    {
      "symbol": "enum_reference",
      "patterns": ["\\benum\\s+(\\w+)"],
      "includeDeclaration": true,
      "description": "Find all references to an enum type"
    },
    {
      "symbol": "env_usage",
      "patterns": ["env\\(\"[^\"]+\"\\)"],
      "includeDeclaration": true,
      "description": "Find all environment variable references"
    }
  ],
  "identifierPattern": "[a-zA-Z_@][a-zA-Z0-9_@.]*"
}