{
  "language": "kotlin",
  "referencePatterns": [
    {
      "symbol": "function_call",
      "patterns": [
        "\\b\\w+\\s*\\(",
        "\\b\\w+\\s*\\{"
      ],
      "includeDeclaration": true,
      "description": "Function calls and lambda invocations"
    },
    {
      "symbol": "class_usage",
      "patterns": [
        ":\\s*\\w+",
        "\\w+\\s*\\(",
        "is\\s+\\w+",
        "as\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Class/type references"
    },
    {
      "symbol": "property_access",
      "patterns": [
        "\\.\\w+",
        "\\w+\\."
      ],
      "includeDeclaration": true,
      "description": "Property access"
    },
    {
      "symbol": "import_ref",
      "patterns": [
        "import\\s+[\\w.]+"
      ],
      "includeDeclaration": true,
      "description": "Import references"
    },
    {
      "symbol": "annotation_usage",
      "patterns": [
        "@\\w+"
      ],
      "includeDeclaration": true,
      "description": "Annotation references"
    },
    {
      "symbol": "generic_type",
      "patterns": [
        "<\\w+>",
        "\\w+<"
      ],
      "includeDeclaration": true,
      "description": "Generic type parameters"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    },
    {
      "kind": "comment_reference",
      "pattern": "@(?:see|link|param|returns?)\\s+(\\w+)",
      "description": "Documentation reference"
    },
    {
      "kind": "decorator",
      "pattern": "@(\\w+)",
      "description": "Decorator/annotation reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "includeDeclaration": true
}
