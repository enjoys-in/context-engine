{
  "language": "dart",
  "referencePatterns": [
    {
      "symbol": "function_call",
      "patterns": [
        "\\b\\w+\\s*\\(",
        "\\b\\w+\\s*<[^>]*>\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Function and method calls"
    },
    {
      "symbol": "type_reference",
      "patterns": [
        ":\\s*\\w+",
        "\\w+\\s*<",
        "is\\s+\\w+",
        "as\\s+\\w+",
        "extends\\s+\\w+",
        "implements\\s+\\w+",
        "with\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Type references, casts, and hierarchy"
    },
    {
      "symbol": "mixin_usage",
      "patterns": [
        "with\\s+[\\w,\\s]+",
        "mixin\\s+\\w+\\s+on\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Mixin applications and constraints"
    },
    {
      "symbol": "import_ref",
      "patterns": [
        "import\\s+'[^']+'",
        "export\\s+'[^']+'",
        "part\\s+'[^']+'"
      ],
      "includeDeclaration": true,
      "description": "Import, export, and part references"
    },
    {
      "symbol": "annotation_usage",
      "patterns": [
        "@\\w+(?:\\.\\w+)?"
      ],
      "includeDeclaration": true,
      "description": "Annotation references (@override, @deprecated, etc.)"
    },
    {
      "symbol": "named_param",
      "patterns": [
        "\\w+\\s*:",
        "required\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Named parameter references"
    },
    {
      "symbol": "property_access",
      "patterns": [
        "\\.\\w+",
        "\\w+\\.\\w+"
      ],
      "includeDeclaration": true,
      "description": "Property and field access"
    },
    {
      "symbol": "constructor_ref",
      "patterns": [
        "\\w+(?:\\.\\w+)?\\s*\\(",
        "const\\s+\\w+\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Constructor invocations"
    },
    {
      "symbol": "generic_type",
      "patterns": [
        "<\\w+(?:\\s*,\\s*\\w+)*>"
      ],
      "includeDeclaration": true,
      "description": "Generic type parameters"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier",
      "includeDeclaration": false,
      "symbol": "identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference",
      "includeDeclaration": false,
      "symbol": "function_call"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference",
      "includeDeclaration": false,
      "symbol": "import"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference",
      "includeDeclaration": false,
      "symbol": "type_reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference",
      "includeDeclaration": false,
      "symbol": "property_access"
    },
    {
      "symbol": "import_statement",
      "patterns": [
        "(import|require|use|include|load)\\s+"
      ],
      "includeDeclaration": false,
      "description": "Import/include statement reference"
    },
    {
      "symbol": "function_definition",
      "patterns": [
        "(function|func|fn|def|sub|proc|method)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Function/method definition reference"
    },
    {
      "symbol": "class_definition",
      "patterns": [
        "(class|struct|type|interface|trait|record|enum)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Type definition reference"
    },
    {
      "symbol": "variable_declaration",
      "patterns": [
        "(var|let|const|val|my|local|dim|set)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Variable declaration reference"
    },
    {
      "symbol": "type_annotation",
      "patterns": [
        ":\\s*(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Type annotation reference"
    },
    {
      "symbol": "string_literal",
      "patterns": [
        "[\"'][^\"']+[\"']"
      ],
      "includeDeclaration": false,
      "description": "String literal reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "includeDeclaration": true
}
