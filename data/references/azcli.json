{
  "language": "azcli",
  "referencePatterns": [
    {
      "symbol": "az_command",
      "patterns": [
        "\\baz\\s+[a-z][a-z-]*",
        "\\baz\\s+[a-z-]+\\s+[a-z-]+"
      ],
      "includeDeclaration": true,
      "description": "Azure CLI command references (az group, az vm create)"
    },
    {
      "symbol": "parameter",
      "patterns": [
        "--[a-z][a-z0-9-]*",
        "-[a-zA-Z]\\b"
      ],
      "includeDeclaration": true,
      "description": "CLI parameter references (--name, --resource-group)"
    },
    {
      "symbol": "resource_group",
      "patterns": [
        "--resource-group\\s+\\S+",
        "-g\\s+\\S+"
      ],
      "includeDeclaration": true,
      "description": "Resource group references"
    },
    {
      "symbol": "subscription",
      "patterns": [
        "--subscription\\s+\\S+"
      ],
      "includeDeclaration": true,
      "description": "Subscription references"
    },
    {
      "symbol": "variable_ref",
      "patterns": [
        "\\$[a-zA-Z_][a-zA-Z0-9_]*",
        "\\$\\{[^}]+\\}"
      ],
      "includeDeclaration": true,
      "description": "Variable references in az cli scripts"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_-]*"
}
