{
  "language": "azcli",
  "referencePatterns": [
    {
      "symbol": "az_command",
      "patterns": [
        "\\baz\\s+[a-z][a-z-]*",
        "\\baz\\s+[a-z-]+\\s+[a-z-]+"
      ],
      "includeDeclaration": true,
      "description": "Azure CLI command references (az group, az vm create)"
    },
    {
      "symbol": "parameter",
      "patterns": [
        "--[a-z][a-z0-9-]*",
        "-[a-zA-Z]\\b"
      ],
      "includeDeclaration": true,
      "description": "CLI parameter references (--name, --resource-group)"
    },
    {
      "symbol": "resource_group",
      "patterns": [
        "--resource-group\\s+\\S+",
        "-g\\s+\\S+"
      ],
      "includeDeclaration": true,
      "description": "Resource group references"
    },
    {
      "symbol": "subscription",
      "patterns": [
        "--subscription\\s+\\S+"
      ],
      "includeDeclaration": true,
      "description": "Subscription references"
    },
    {
      "symbol": "variable_ref",
      "patterns": [
        "\\$[a-zA-Z_][a-zA-Z0-9_]*",
        "\\$\\{[^}]+\\}"
      ],
      "includeDeclaration": true,
      "description": "Variable references in az cli scripts"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    },
    {
      "kind": "comment_reference",
      "pattern": "@(?:see|link|param|returns?)\\s+(\\w+)",
      "description": "Documentation reference"
    },
    {
      "kind": "decorator",
      "pattern": "@(\\w+)",
      "description": "Decorator/annotation reference"
    },
    {
      "kind": "class_reference",
      "pattern": "\\b([A-Z]\\w+)\\b",
      "description": "Class/type name reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_-]*",
  "includeDeclaration": true
}
