{
  "language": "abap",
  "referencePatterns": [
    { "name": "MethodCall", "pattern": "(\\w+)->\\s*(\\w+)", "captureGroup": 2 },
    { "name": "FunctionCall", "pattern": "CALL\\s+FUNCTION\\s+'(\\w+)'", "captureGroup": 1 },
    { "name": "PerformCall", "pattern": "PERFORM\\s+(\\w+)", "captureGroup": 1 }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
