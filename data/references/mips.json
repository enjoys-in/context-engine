{
  "language": "mips",
  "referencePatterns": [
    {
      "symbol": "label_ref",
      "patterns": [
        "^\\w+:",
        "\\b\\w+:$"
      ],
      "includeDeclaration": true,
      "description": "Label definitions"
    },
    {
      "symbol": "instruction_ref",
      "patterns": [
        "\\b(add|sub|mul|div|and|or|xor|nor|sll|srl|sra|lw|sw|lb|sb|lh|sh|beq|bne|blt|bgt|ble|bge|j|jal|jr|jalr|la|li|move|nop|syscall)\\b"
      ],
      "includeDeclaration": true,
      "description": "MIPS instruction references"
    },
    {
      "symbol": "register_ref",
      "patterns": [
        "\\$[a-zA-Z0-9]+",
        "\\$(zero|at|v[01]|a[0-3]|t[0-9]|s[0-7]|k[01]|gp|sp|fp|ra)"
      ],
      "includeDeclaration": true,
      "description": "Register references ($t0, $s0, $ra, etc.)"
    },
    {
      "symbol": "directive_ref",
      "patterns": [
        "\\.(text|data|globl|word|byte|half|space|asciiz|ascii|align|float|double)\\b"
      ],
      "includeDeclaration": true,
      "description": "Assembler directive references"
    },
    {
      "symbol": "branch_target",
      "patterns": [
        "\\b(j|jal|beq|bne|blt|bgt)\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Branch and jump target references"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    },
    {
      "kind": "comment_reference",
      "pattern": "@(?:see|link|param|returns?)\\s+(\\w+)",
      "description": "Documentation reference"
    },
    {
      "kind": "decorator",
      "pattern": "@(\\w+)",
      "description": "Decorator/annotation reference"
    },
    {
      "kind": "class_reference",
      "pattern": "\\b([A-Z]\\w+)\\b",
      "description": "Class/type name reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_.$][a-zA-Z0-9_.$]*",
  "includeDeclaration": true
}
