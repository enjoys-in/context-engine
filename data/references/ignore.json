{
  "language": "ignore",
  "referencePatterns": [
    {
      "symbol": "glob_pattern",
      "patterns": ["\\*", "\\*\\*", "\\?", "\\[.*\\]"],
      "includeDeclaration": true,
      "description": "Find all glob wildcard patterns"
    },
    {
      "symbol": "negation",
      "patterns": ["^!"],
      "includeDeclaration": true,
      "description": "Find all negated (re-included) patterns"
    },
    {
      "symbol": "directory_pattern",
      "patterns": ["/$"],
      "includeDeclaration": true,
      "description": "Find all directory-only patterns"
    },
    {
      "symbol": "comment",
      "patterns": ["^\\s*#"],
      "includeDeclaration": true,
      "description": "Find all comment lines"
    }
  ],
  "identifierPattern": "[^\\s#]+"
}