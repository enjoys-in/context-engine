{
  "language": "tcl",
  "referencePatterns": [
    {
      "symbol": "proc_ref",
      "patterns": [
        "\\bproc\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Procedure definitions"
    },
    {
      "symbol": "variable_ref",
      "patterns": [
        "\\bset\\s+\\w+",
        "\\$\\w+",
        "\\$\\{[^}]+\\}",
        "\\bvariable\\s+\\w+",
        "\\bglobal\\s+\\w+",
        "\\bupvar\\s+"
      ],
      "includeDeclaration": true,
      "description": "Variable references (set, $var, variable, global)"
    },
    {
      "symbol": "command_ref",
      "patterns": [
        "\\bputs\\s+",
        "\\bexpr\\s+",
        "\\beval\\s+",
        "\\bsource\\s+",
        "\\bexec\\s+",
        "\\bcatch\\s+",
        "\\breturn\\b"
      ],
      "includeDeclaration": true,
      "description": "Built-in command references"
    },
    {
      "symbol": "control_ref",
      "patterns": [
        "\\bif\\s+",
        "\\belseif\\s+",
        "\\belse\\s*\\{",
        "\\bwhile\\s+",
        "\\bfor\\s+",
        "\\bforeach\\s+",
        "\\bswitch\\s+"
      ],
      "includeDeclaration": true,
      "description": "Control flow references"
    },
    {
      "symbol": "namespace_ref",
      "patterns": [
        "\\bnamespace\\s+eval\\s+\\w+",
        "\\bnamespace\\s+\\w+",
        "\\w+::\\w+"
      ],
      "includeDeclaration": true,
      "description": "Namespace definitions and qualified names"
    },
    {
      "symbol": "package_ref",
      "patterns": [
        "\\bpackage\\s+require\\s+\\w+",
        "\\bpackage\\s+provide\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Package require and provide references"
    },
    {
      "symbol": "list_ref",
      "patterns": [
        "\\blappend\\s+",
        "\\blindex\\s+",
        "\\bllength\\s+",
        "\\blsort\\s+",
        "\\blsearch\\s+",
        "\\blist\\s+",
        "\\bsplit\\s+",
        "\\bjoin\\s+"
      ],
      "includeDeclaration": true,
      "description": "List operation references"
    },
    {
      "symbol": "string_ref",
      "patterns": [
        "\\bstring\\s+\\w+",
        "\\bregexp\\s+",
        "\\bregsub\\s+",
        "\\bformat\\s+",
        "\\bscan\\s+"
      ],
      "includeDeclaration": true,
      "description": "String operation references"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
