{
  "language": "ecl",
  "referencePatterns": [
    {
      "symbol": "definition",
      "patterns": [
        "\\b\\w+\\s*:=",
        "\\bEXPORT\\s+\\w+",
        "\\bSHARED\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "ECL definitions, EXPORT, SHARED"
    },
    {
      "symbol": "record_ref",
      "patterns": [
        "\\bRECORD\\b",
        "\\bEND\\b",
        "\\bDATASET\\b"
      ],
      "includeDeclaration": true,
      "description": "RECORD and DATASET references"
    },
    {
      "symbol": "function_call",
      "patterns": [
        "\\b\\w+\\s*\\(",
        "\\bOUTPUT\\b",
        "\\bCOUNT\\b",
        "\\bSUM\\b",
        "\\bSORT\\b",
        "\\bFILTER\\b"
      ],
      "includeDeclaration": true,
      "description": "Function calls and built-in actions"
    },
    {
      "symbol": "import_ref",
      "patterns": [
        "\\bIMPORT\\s+\\w+",
        "\\bUSE\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "IMPORT and USE references"
    },
    {
      "symbol": "type_ref",
      "patterns": [
        "\\bSTRING\\b",
        "\\bINTEGER\\b",
        "\\bREAL\\b",
        "\\bBOOLEAN\\b",
        "\\bUNSIGNED\\b"
      ],
      "includeDeclaration": true,
      "description": "Built-in type references"
    },
    {
      "symbol": "transform_ref",
      "patterns": [
        "\\bTRANSFORM\\b",
        "\\bPROJECT\\b",
        "\\bJOIN\\b",
        "\\bROLLUP\\b"
      ],
      "includeDeclaration": true,
      "description": "Transform and join references"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
