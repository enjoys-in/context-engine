{
  "language": "bicep",
  "referencePatterns": [
    {
      "symbol": "resource_ref",
      "patterns": [
        "\\bresource\\s+\\w+",
        "\\bexisting\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Resource declarations and existing references"
    },
    {
      "symbol": "param_ref",
      "patterns": [
        "\\bparam\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Parameter declarations"
    },
    {
      "symbol": "var_ref",
      "patterns": [
        "\\bvar\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Variable declarations"
    },
    {
      "symbol": "output_ref",
      "patterns": [
        "\\boutput\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Output declarations"
    },
    {
      "symbol": "module_ref",
      "patterns": [
        "\\bmodule\\s+\\w+",
        "module\\s+\\w+\\s+'[^']+'"
      ],
      "includeDeclaration": true,
      "description": "Module references"
    },
    {
      "symbol": "type_ref",
      "patterns": [
        ":\\s*\\w+",
        "\\bstring\\b",
        "\\bint\\b",
        "\\bbool\\b",
        "\\bobject\\b",
        "\\barray\\b"
      ],
      "includeDeclaration": true,
      "description": "Type references"
    },
    {
      "symbol": "property_access",
      "patterns": [
        "\\.\\w+",
        "\\w+\\.\\w+"
      ],
      "includeDeclaration": true,
      "description": "Property access on resources and objects"
    },
    {
      "symbol": "decorator",
      "patterns": [
        "@\\w+(?:\\([^)]*\\))?"
      ],
      "includeDeclaration": true,
      "description": "Decorator references (@description, @secure, @allowed)"
    },
    {
      "symbol": "function_call",
      "patterns": [
        "\\b\\w+\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Built-in function calls (resourceGroup(), subscription())"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "includeDeclaration": true
}
