{
  "language": "docker-compose",
  "referencePatterns": [
    {
      "symbol": "service_name",
      "patterns": [
        "\\bdepends_on\\b[\\s\\S]*?\\b(\\w+)\\b",
        "\\bservice:\\s*(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Find all references to a service name (in depends_on, network_mode, links, etc.)"
    },
    {
      "symbol": "volume_name",
      "patterns": [
        "\\bvolumes\\b[\\s\\S]*?\\b(\\w+):",
        "^\\s+-\\s+(\\w+):"
      ],
      "includeDeclaration": true,
      "description": "Find all references to a named volume"
    },
    {
      "symbol": "network_name",
      "patterns": [
        "\\bnetworks\\b[\\s\\S]*?\\b(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Find all references to a network name"
    },
    {
      "symbol": "secret_name",
      "patterns": [
        "\\bsecrets\\b[\\s\\S]*?\\b(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Find all references to a secret name"
    },
    {
      "symbol": "config_name",
      "patterns": [
        "\\bconfigs\\b[\\s\\S]*?\\b(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Find all references to a config name"
    },
    {
      "symbol": "anchor_name",
      "patterns": [
        "&(\\w[\\w-]*)",
        "\\*(\\w[\\w-]*)"
      ],
      "includeDeclaration": true,
      "description": "Find all references to a YAML anchor"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    },
    {
      "kind": "comment_reference",
      "pattern": "@(?:see|link|param|returns?)\\s+(\\w+)",
      "description": "Documentation reference"
    },
    {
      "kind": "decorator",
      "pattern": "@(\\w+)",
      "description": "Decorator/annotation reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_.-]*",
  "includeDeclaration": true
}
