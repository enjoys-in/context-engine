{
  "language": "nestjs",
  "referencePatterns": [
    {
      "symbol": "Injectable",
      "patterns": [
        "@Injectable\\(\\)",
        "\\bInjectable\\b"
      ],
      "includeDeclaration": true,
      "description": "Find all @Injectable usages"
    },
    {
      "symbol": "Controller",
      "patterns": [
        "@Controller\\(",
        "\\bController\\b"
      ],
      "includeDeclaration": true,
      "description": "Find all @Controller usages"
    },
    {
      "symbol": "Module",
      "patterns": [
        "@Module\\(",
        "\\bModule\\b"
      ],
      "includeDeclaration": true,
      "description": "Find all @Module usages"
    },
    {
      "symbol": "Inject",
      "patterns": [
        "@Inject\\(",
        "\\bInject\\b"
      ],
      "includeDeclaration": true,
      "description": "Find all @Inject usages"
    },
    {
      "symbol": "Guard",
      "patterns": [
        "@UseGuards\\(",
        "\\bCanActivate\\b",
        "implements\\s+CanActivate"
      ],
      "includeDeclaration": true,
      "description": "Find guard usages"
    },
    {
      "symbol": "Pipe",
      "patterns": [
        "@UsePipes\\(",
        "\\bPipeTransform\\b",
        "implements\\s+PipeTransform"
      ],
      "includeDeclaration": true,
      "description": "Find pipe usages"
    },
    {
      "symbol": "Interceptor",
      "patterns": [
        "@UseInterceptors\\(",
        "\\bNestInterceptor\\b",
        "implements\\s+NestInterceptor"
      ],
      "includeDeclaration": true,
      "description": "Find interceptor usages"
    },
    {
      "symbol": "Filter",
      "patterns": [
        "@UseFilters\\(",
        "\\bExceptionFilter\\b",
        "@Catch\\("
      ],
      "includeDeclaration": true,
      "description": "Find filter usages"
    },
    {
      "symbol": "HttpGet",
      "patterns": [
        "@Get\\(",
        "\\.get\\("
      ],
      "includeDeclaration": true,
      "description": "Find GET route references"
    },
    {
      "symbol": "HttpPost",
      "patterns": [
        "@Post\\(",
        "\\.post\\("
      ],
      "includeDeclaration": true,
      "description": "Find POST route references"
    },
    {
      "symbol": "HttpPut",
      "patterns": [
        "@Put\\(",
        "\\.put\\("
      ],
      "includeDeclaration": true,
      "description": "Find PUT route references"
    },
    {
      "symbol": "HttpDelete",
      "patterns": [
        "@Delete\\(",
        "\\.delete\\("
      ],
      "includeDeclaration": true,
      "description": "Find DELETE route references"
    },
    {
      "symbol": "Service",
      "patterns": [
        "\\bprivate\\s+(?:readonly\\s+)?\\w+Service\\b",
        "\\w+Service\\b"
      ],
      "includeDeclaration": true,
      "description": "Find service injection references"
    },
    {
      "symbol": "Entity",
      "patterns": [
        "@Entity\\(",
        "\\bEntity\\b",
        "\\bRepository<"
      ],
      "includeDeclaration": true,
      "description": "Find entity/repository references"
    },
    {
      "symbol": "DTO",
      "patterns": [
        "\\w+Dto\\b",
        "\\w+DTO\\b"
      ],
      "includeDeclaration": true,
      "description": "Find DTO class references"
    },
    {
      "symbol": "Middleware",
      "patterns": [
        "\\bNestMiddleware\\b",
        "implements\\s+NestMiddleware",
        "\\.forRoutes\\("
      ],
      "includeDeclaration": true,
      "description": "Find middleware references"
    },
    {
      "symbol": "ConfigService",
      "patterns": [
        "\\bConfigService\\b",
        "configService\\.get\\("
      ],
      "includeDeclaration": true,
      "description": "Find config service usages"
    },
    {
      "symbol": "Gateway",
      "patterns": [
        "@WebSocketGateway\\(",
        "@SubscribeMessage\\(",
        "\\bWebSocketGateway\\b"
      ],
      "includeDeclaration": true,
      "description": "Find WebSocket gateway references"
    },
    {
      "symbol": "Array.isArray",
      "patterns": [
        "\\bArray\\.isArray\\b"
      ],
      "includeDeclaration": true,
      "description": "Array.isArray static method"
    },
    {
      "symbol": "Array.from",
      "patterns": [
        "\\bArray\\.from\\b"
      ],
      "includeDeclaration": true,
      "description": "Array.from static method"
    },
    {
      "symbol": "Object.keys",
      "patterns": [
        "\\bObject\\.keys\\b"
      ],
      "includeDeclaration": true,
      "description": "Object.keys static method"
    },
    {
      "symbol": "Object.values",
      "patterns": [
        "\\bObject\\.values\\b"
      ],
      "includeDeclaration": true,
      "description": "Object.values static method"
    },
    {
      "symbol": "Object.entries",
      "patterns": [
        "\\bObject\\.entries\\b"
      ],
      "includeDeclaration": true,
      "description": "Object.entries static method"
    },
    {
      "symbol": "Object.assign",
      "patterns": [
        "\\bObject\\.assign\\b"
      ],
      "includeDeclaration": true,
      "description": "Object.assign static method"
    },
    {
      "symbol": "Promise.all",
      "patterns": [
        "\\bPromise\\.all\\b"
      ],
      "includeDeclaration": true,
      "description": "Promise.all static method"
    },
    {
      "symbol": "Promise.resolve",
      "patterns": [
        "\\bPromise\\.resolve\\b"
      ],
      "includeDeclaration": true,
      "description": "Promise.resolve static method"
    },
    {
      "symbol": "JSON.stringify",
      "patterns": [
        "\\bJSON\\.stringify\\b"
      ],
      "includeDeclaration": true,
      "description": "JSON.stringify method"
    },
    {
      "symbol": "JSON.parse",
      "patterns": [
        "\\bJSON\\.parse\\b"
      ],
      "includeDeclaration": true,
      "description": "JSON.parse method"
    },
    {
      "symbol": "Math.floor",
      "patterns": [
        "\\bMath\\.floor\\b"
      ],
      "includeDeclaration": true,
      "description": "Math.floor method"
    },
    {
      "symbol": "Math.random",
      "patterns": [
        "\\bMath\\.random\\b"
      ],
      "includeDeclaration": true,
      "description": "Math.random method"
    },
    {
      "symbol": "setTimeout",
      "patterns": [
        "\\bsetTimeout\\b"
      ],
      "includeDeclaration": true,
      "description": "setTimeout global function"
    },
    {
      "symbol": "setInterval",
      "patterns": [
        "\\bsetInterval\\b"
      ],
      "includeDeclaration": true,
      "description": "setInterval global function"
    },
    {
      "symbol": "addEventListener",
      "patterns": [
        "\\baddEventListener\\b"
      ],
      "includeDeclaration": true,
      "description": "addEventListener method"
    },
    {
      "symbol": "querySelector",
      "patterns": [
        "\\bquerySelector\\b"
      ],
      "includeDeclaration": true,
      "description": "querySelector method"
    },
    {
      "symbol": "getElementById",
      "patterns": [
        "\\bgetElementById\\b"
      ],
      "includeDeclaration": true,
      "description": "getElementById method"
    },
    {
      "symbol": "createElement",
      "patterns": [
        "\\bcreateElement\\b"
      ],
      "includeDeclaration": true,
      "description": "createElement method"
    },
    {
      "symbol": "fetch",
      "patterns": [
        "\\bfetch\\b\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "fetch API function"
    },
    {
      "symbol": "require",
      "patterns": [
        "\\brequire\\b\\s*\\("
      ],
      "includeDeclaration": false,
      "description": "CommonJS require"
    }
  ],
  "identifierPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*"
}
