{
  "language": "sb",
  "referencePatterns": [
    {
      "symbol": "sub_func",
      "patterns": [
        "\\bSUB\\s+\\w+",
        "\\bFUNC\\s+\\w+",
        "\\bDEF\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Subroutine and function definitions"
    },
    {
      "symbol": "variable_ref",
      "patterns": [
        "\\bDIM\\s+\\w+",
        "\\bLET\\s+\\w+",
        "\\bCONST\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Variable and constant declarations"
    },
    {
      "symbol": "io_ref",
      "patterns": [
        "\\bPRINT\\b",
        "\\bINPUT\\b",
        "\\bOPEN\\b",
        "\\bCLOSE\\b",
        "\\bWRITE\\b",
        "\\bREAD\\b"
      ],
      "includeDeclaration": true,
      "description": "I/O operation references"
    },
    {
      "symbol": "control_ref",
      "patterns": [
        "\\bIF\\b",
        "\\bTHEN\\b",
        "\\bELSE\\b",
        "\\bFOR\\b",
        "\\bNEXT\\b",
        "\\bWHILE\\b",
        "\\bWEND\\b",
        "\\bDO\\b",
        "\\bLOOP\\b",
        "\\bSELECT\\b",
        "\\bCASE\\b"
      ],
      "includeDeclaration": true,
      "description": "Control flow references"
    },
    {
      "symbol": "graphics_ref",
      "patterns": [
        "\\bLINE\\b",
        "\\bCIRCLE\\b",
        "\\bRECT\\b",
        "\\bCOLOR\\b",
        "\\bAT\\b",
        "\\bPSET\\b",
        "\\bARC\\b",
        "\\bDRAW\\b"
      ],
      "includeDeclaration": true,
      "description": "Graphics command references"
    },
    {
      "symbol": "builtin_func",
      "patterns": [
        "\\b(LEN|MID|LEFT|RIGHT|STR|VAL|CHR|ASC|INSTR|REPLACE|UCASE|LCASE|SQR|ABS|INT|RND|SIN|COS|TAN|LOG|EXP)\\b"
      ],
      "includeDeclaration": true,
      "description": "Built-in function references"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    },
    {
      "kind": "comment_reference",
      "pattern": "@(?:see|link|param|returns?)\\s+(\\w+)",
      "description": "Documentation reference"
    },
    {
      "kind": "decorator",
      "pattern": "@(\\w+)",
      "description": "Decorator/annotation reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "includeDeclaration": true
}
