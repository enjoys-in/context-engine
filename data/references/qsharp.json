{
  "language": "qsharp",
  "referencePatterns": [
    {
      "symbol": "operation_ref",
      "patterns": [
        "\\boperation\\s+\\w+",
        "\\bfunction\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Operation and function definitions"
    },
    {
      "symbol": "qubit_ref",
      "patterns": [
        "\\bQubit\\b",
        "\\buse\\s+\\w+\\s*=\\s*Qubit",
        "\\bQubit\\[\\]"
      ],
      "includeDeclaration": true,
      "description": "Qubit type and allocation references"
    },
    {
      "symbol": "gate_ref",
      "patterns": [
        "\\bH\\s*\\(",
        "\\bX\\s*\\(",
        "\\bY\\s*\\(",
        "\\bZ\\s*\\(",
        "\\bCNOT\\s*\\(",
        "\\bT\\s*\\(",
        "\\bS\\s*\\(",
        "\\bRx\\s*\\(",
        "\\bRy\\s*\\(",
        "\\bRz\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Quantum gate references"
    },
    {
      "symbol": "measurement_ref",
      "patterns": [
        "\\bM\\s*\\(",
        "\\bMeasure\\s*\\(",
        "\\bMResetZ\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Measurement operation references"
    },
    {
      "symbol": "namespace_ref",
      "patterns": [
        "\\bnamespace\\s+[\\w.]+",
        "\\bopen\\s+[\\w.]+"
      ],
      "includeDeclaration": true,
      "description": "Namespace and open references"
    },
    {
      "symbol": "type_ref",
      "patterns": [
        "\\bnewtype\\s+\\w+",
        "\\bInt\\b",
        "\\bDouble\\b",
        "\\bBool\\b",
        "\\bResult\\b",
        "\\bPauli\\b"
      ],
      "includeDeclaration": true,
      "description": "Type definitions and built-in type references"
    },
    {
      "symbol": "callable_ref",
      "patterns": [
        "\\b\\w+\\s*\\(",
        "\\bAdjoint\\s+\\w+",
        "\\bControlled\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Callable invocations and functor applications"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
