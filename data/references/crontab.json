{
  "language": "crontab",
  "referencePatterns": [
    {
      "symbol": "schedule_field",
      "patterns": [
        "^[\\d*,/-]+\\s+[\\d*,/-]+\\s+[\\d*,/-]+\\s+[\\d*,/-]+\\s+[\\d*,/-]+"
      ],
      "includeDeclaration": true,
      "description": "Cron schedule expression (min hour dom mon dow)"
    },
    {
      "symbol": "command_ref",
      "patterns": [
        "\\s/[a-zA-Z0-9_/.-]+",
        "\\s\\w+\\s"
      ],
      "includeDeclaration": true,
      "description": "Command path references"
    },
    {
      "symbol": "env_variable",
      "patterns": [
        "^[A-Z_][A-Z0-9_]*=",
        "\\$[A-Z_][A-Z0-9_]*",
        "\\$\\{[^}]+\\}"
      ],
      "includeDeclaration": true,
      "description": "Environment variable definitions and references"
    },
    {
      "symbol": "special_string",
      "patterns": [
        "@(reboot|yearly|annually|monthly|weekly|daily|midnight|hourly)"
      ],
      "includeDeclaration": true,
      "description": "Special schedule strings (@reboot, @daily, etc.)"
    }
  ],
  "identifierPattern": "[a-zA-Z_/][a-zA-Z0-9_/.+-]*"
}
