{
  "language": "pascaligo",
  "referencePatterns": [
    {
      "symbol": "function_ref",
      "patterns": [
        "\\bfunction\\s+\\w+",
        "\\brecursive\\s+function\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Function definitions"
    },
    {
      "symbol": "type_ref",
      "patterns": [
        "\\btype\\s+\\w+",
        "\\brecord\\b",
        "\\bis\\b"
      ],
      "includeDeclaration": true,
      "description": "Type definitions"
    },
    {
      "symbol": "const_var",
      "patterns": [
        "\\bconst\\s+\\w+",
        "\\bvar\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Constant and variable bindings"
    },
    {
      "symbol": "entrypoint_ref",
      "patterns": [
        "\\bfunction\\s+main\\b"
      ],
      "includeDeclaration": true,
      "description": "Contract entrypoint"
    },
    {
      "symbol": "module_ref",
      "patterns": [
        "\\w+\\.\\w+"
      ],
      "includeDeclaration": true,
      "description": "Module-qualified references"
    },
    {
      "symbol": "case_ref",
      "patterns": [
        "\\bcase\\s+\\w+\\s+of",
        "\\|\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Case/variant pattern matches"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference"
    },
    {
      "kind": "string_literal",
      "pattern": "[\"']([^\"']+)[\"']",
      "description": "String literal reference"
    },
    {
      "kind": "comment_reference",
      "pattern": "@(?:see|link|param|returns?)\\s+(\\w+)",
      "description": "Documentation reference"
    },
    {
      "kind": "decorator",
      "pattern": "@(\\w+)",
      "description": "Decorator/annotation reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "includeDeclaration": true
}
