{
  "language": "pascaligo",
  "referencePatterns": [
    {
      "symbol": "function_ref",
      "patterns": [
        "\\bfunction\\s+\\w+",
        "\\brecursive\\s+function\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Function definitions"
    },
    {
      "symbol": "type_ref",
      "patterns": [
        "\\btype\\s+\\w+",
        "\\brecord\\b",
        "\\bis\\b"
      ],
      "includeDeclaration": true,
      "description": "Type definitions"
    },
    {
      "symbol": "const_var",
      "patterns": [
        "\\bconst\\s+\\w+",
        "\\bvar\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Constant and variable bindings"
    },
    {
      "symbol": "entrypoint_ref",
      "patterns": [
        "\\bfunction\\s+main\\b"
      ],
      "includeDeclaration": true,
      "description": "Contract entrypoint"
    },
    {
      "symbol": "module_ref",
      "patterns": [
        "\\w+\\.\\w+"
      ],
      "includeDeclaration": true,
      "description": "Module-qualified references"
    },
    {
      "symbol": "case_ref",
      "patterns": [
        "\\bcase\\s+\\w+\\s+of",
        "\\|\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Case/variant pattern matches"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
