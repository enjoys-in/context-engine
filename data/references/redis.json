{
  "language": "redis",
  "referencePatterns": [
    {
      "symbol": "string_cmd",
      "patterns": [
        "\\b(GET|SET|MGET|MSET|INCR|DECR|INCRBY|DECRBY|APPEND|STRLEN|SETNX|SETEX|PSETEX|GETSET|GETDEL|GETEX)\\b"
      ],
      "includeDeclaration": true,
      "description": "String command references"
    },
    {
      "symbol": "hash_cmd",
      "patterns": [
        "\\b(HGET|HSET|HMGET|HMSET|HDEL|HGETALL|HKEYS|HVALS|HINCRBY|HEXISTS|HLEN|HSCAN)\\b"
      ],
      "includeDeclaration": true,
      "description": "Hash command references"
    },
    {
      "symbol": "list_cmd",
      "patterns": [
        "\\b(LPUSH|RPUSH|LPOP|RPOP|LRANGE|LLEN|LINDEX|LINSERT|LSET|LREM|BLPOP|BRPOP)\\b"
      ],
      "includeDeclaration": true,
      "description": "List command references"
    },
    {
      "symbol": "set_cmd",
      "patterns": [
        "\\b(SADD|SREM|SMEMBERS|SISMEMBER|SCARD|SUNION|SINTER|SDIFF|SPOP|SRANDMEMBER)\\b"
      ],
      "includeDeclaration": true,
      "description": "Set command references"
    },
    {
      "symbol": "sorted_set_cmd",
      "patterns": [
        "\\b(ZADD|ZREM|ZRANGE|ZRANGEBYSCORE|ZRANK|ZSCORE|ZCARD|ZINCRBY|ZCOUNT|ZREVRANGE)\\b"
      ],
      "includeDeclaration": true,
      "description": "Sorted set command references"
    },
    {
      "symbol": "key_cmd",
      "patterns": [
        "\\b(DEL|EXISTS|EXPIRE|TTL|PTTL|PERSIST|KEYS|SCAN|TYPE|RENAME|RANDOMKEY|DUMP|RESTORE)\\b"
      ],
      "includeDeclaration": true,
      "description": "Key management command references"
    },
    {
      "symbol": "pub_sub_cmd",
      "patterns": [
        "\\b(PUBLISH|SUBSCRIBE|UNSUBSCRIBE|PSUBSCRIBE|PUNSUBSCRIBE)\\b"
      ],
      "includeDeclaration": true,
      "description": "Pub/Sub command references"
    },
    {
      "symbol": "transaction_cmd",
      "patterns": [
        "\\b(MULTI|EXEC|DISCARD|WATCH|UNWATCH)\\b"
      ],
      "includeDeclaration": true,
      "description": "Transaction command references"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_.:/-]*"
}
