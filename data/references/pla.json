{
  "language": "pla",
  "referencePatterns": [
    {
      "symbol": "input_ref",
      "patterns": [
        "\\.i\\s+\\d+",
        "\\.ilb\\s+.+"
      ],
      "includeDeclaration": true,
      "description": "Input count and label references"
    },
    {
      "symbol": "output_ref",
      "patterns": [
        "\\.o\\s+\\d+",
        "\\.ob\\s+.+"
      ],
      "includeDeclaration": true,
      "description": "Output count and label references"
    },
    {
      "symbol": "product_term",
      "patterns": [
        "^[01-]+\\s+[01-]+"
      ],
      "includeDeclaration": true,
      "description": "Product term (input-output) references"
    },
    {
      "symbol": "keyword_ref",
      "patterns": [
        "\\.type\\s+\\w+",
        "\\.p\\s+\\d+",
        "\\.e\\b",
        "\\.phase\\b"
      ],
      "includeDeclaration": true,
      "description": "PLA format keyword references"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
