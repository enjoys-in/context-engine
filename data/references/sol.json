{
  "language": "sol",
  "referencePatterns": [
    {
      "symbol": "contract_ref",
      "patterns": [
        "\\bcontract\\s+\\w+",
        "\\babstract\\s+contract\\s+\\w+",
        "\\blibrary\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Contract and library definitions"
    },
    {
      "symbol": "function_ref",
      "patterns": [
        "\\bfunction\\s+\\w+",
        "\\bconstructor\\s*\\(",
        "\\breceive\\s*\\(",
        "\\bfallback\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Function, constructor, and special function references"
    },
    {
      "symbol": "modifier_ref",
      "patterns": [
        "\\bmodifier\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Modifier definitions"
    },
    {
      "symbol": "event_ref",
      "patterns": [
        "\\bevent\\s+\\w+",
        "\\bemit\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Event definitions and emit statements"
    },
    {
      "symbol": "type_ref",
      "patterns": [
        "\\bmapping\\s*\\(",
        "\\bstruct\\s+\\w+",
        "\\benum\\s+\\w+",
        "\\binterface\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Mapping, struct, enum, and interface definitions"
    },
    {
      "symbol": "state_var",
      "patterns": [
        "\\b(uint|int|address|bool|string|bytes)\\d*\\s+\\w+",
        "\\bpublic\\b",
        "\\bprivate\\b",
        "\\binternal\\b",
        "\\bexternal\\b"
      ],
      "includeDeclaration": true,
      "description": "State variable and visibility references"
    },
    {
      "symbol": "import_ref",
      "patterns": [
        "\\bimport\\s+\"[^\"]+\"",
        "\\bimport\\s+\\{[^}]+\\}\\s+from"
      ],
      "includeDeclaration": true,
      "description": "Import references"
    },
    {
      "symbol": "inheritance_ref",
      "patterns": [
        "\\bis\\s+\\w+",
        "\\busing\\s+\\w+\\s+for\\b",
        "\\boverride\\b",
        "\\bvirtual\\b"
      ],
      "includeDeclaration": true,
      "description": "Inheritance, using-for, and override references"
    },
    {
      "symbol": "error_ref",
      "patterns": [
        "\\berror\\s+\\w+",
        "\\brevert\\s+\\w+",
        "\\brequire\\s*\\(",
        "\\bassert\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Custom error and require/assert references"
    },
    {
      "kind": "identifier",
      "pattern": "\\b[a-zA-Z_]\\w*\\b",
      "description": "Reference to an identifier",
      "includeDeclaration": false,
      "symbol": "identifier"
    },
    {
      "kind": "function_call",
      "pattern": "\\b(\\w+)\\s*\\(",
      "description": "Function call reference",
      "includeDeclaration": false,
      "symbol": "function_call"
    },
    {
      "kind": "import",
      "pattern": "(?:import|require|include|use)\\s+[\"']?([\\w./\\-]+)",
      "description": "Import/require reference",
      "includeDeclaration": false,
      "symbol": "import"
    },
    {
      "kind": "type_reference",
      "pattern": ":\\s*(\\w+)",
      "description": "Type annotation reference",
      "includeDeclaration": false,
      "symbol": "type_reference"
    },
    {
      "kind": "property_access",
      "pattern": "\\.(\\w+)",
      "description": "Property access reference",
      "includeDeclaration": false,
      "symbol": "property_access"
    },
    {
      "symbol": "import_statement",
      "patterns": [
        "(import|require|use|include|load)\\s+"
      ],
      "includeDeclaration": false,
      "description": "Import/include statement reference"
    },
    {
      "symbol": "function_definition",
      "patterns": [
        "(function|func|fn|def|sub|proc|method)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Function/method definition reference"
    },
    {
      "symbol": "class_definition",
      "patterns": [
        "(class|struct|type|interface|trait|record|enum)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Type definition reference"
    },
    {
      "symbol": "variable_declaration",
      "patterns": [
        "(var|let|const|val|my|local|dim|set)\\s+(\\w+)"
      ],
      "includeDeclaration": true,
      "description": "Variable declaration reference"
    },
    {
      "symbol": "function_call",
      "patterns": [
        "\\b(\\w+)\\s*\\("
      ],
      "includeDeclaration": false,
      "description": "Function/method call reference"
    },
    {
      "symbol": "property_access",
      "patterns": [
        "\\.(\\w+)"
      ],
      "includeDeclaration": false,
      "description": "Property/field access reference"
    }
  ],
  "identifierPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "includeDeclaration": true
}
