{
  "language": "liquid",
  "referencePatterns": [
    {
      "symbol": "tag_ref",
      "patterns": [
        "\\{%[-~]?\\s*\\w+",
        "\\{%[-~]?\\s*end\\w+"
      ],
      "includeDeclaration": true,
      "description": "Liquid tag references ({% if %}, {% for %})"
    },
    {
      "symbol": "output_ref",
      "patterns": [
        "\\{\\{\\s*[^}]+\\s*\\}\\}"
      ],
      "includeDeclaration": true,
      "description": "Output/variable references ({{ variable }})"
    },
    {
      "symbol": "filter_ref",
      "patterns": [
        "\\|\\s*\\w+"
      ],
      "includeDeclaration": true,
      "description": "Filter references (| upcase, | date)"
    },
    {
      "symbol": "variable_ref",
      "patterns": [
        "\\bassign\\s+\\w+",
        "\\bcapture\\s+\\w+",
        "\\bincrement\\s+\\w+",
        "\\bdecrement\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Variable assignment references"
    },
    {
      "symbol": "include_ref",
      "patterns": [
        "\\binclude\\s+'[^']+'",
        "\\brender\\s+'[^']+'",
        "\\bsection\\s+'[^']+'"
      ],
      "includeDeclaration": true,
      "description": "Include, render, and section references"
    },
    {
      "symbol": "object_ref",
      "patterns": [
        "\\b\\w+\\.\\w+",
        "\\bforloop\\.\\w+",
        "\\btablerowloop\\.\\w+"
      ],
      "includeDeclaration": true,
      "description": "Object property access and loop variable references"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
