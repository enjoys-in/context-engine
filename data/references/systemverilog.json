{
  "language": "systemverilog",
  "referencePatterns": [
    {
      "symbol": "module_ref",
      "patterns": [
        "\\bmodule\\s+\\w+",
        "\\bendmodule\\b"
      ],
      "includeDeclaration": true,
      "description": "Module definitions"
    },
    {
      "symbol": "interface_ref",
      "patterns": [
        "\\binterface\\s+\\w+",
        "\\bendinterface\\b"
      ],
      "includeDeclaration": true,
      "description": "Interface definitions"
    },
    {
      "symbol": "class_ref",
      "patterns": [
        "\\bclass\\s+\\w+",
        "\\bendclass\\b",
        "\\bextends\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Class definitions and inheritance"
    },
    {
      "symbol": "task_func",
      "patterns": [
        "\\btask\\s+\\w+",
        "\\bfunction\\s+\\w+"
      ],
      "includeDeclaration": true,
      "description": "Task and function definitions"
    },
    {
      "symbol": "signal_ref",
      "patterns": [
        "\\bwire\\s+",
        "\\breg\\s+",
        "\\blogic\\s+",
        "\\bbit\\s+",
        "\\binteger\\s+",
        "\\breal\\s+"
      ],
      "includeDeclaration": true,
      "description": "Signal and variable type references"
    },
    {
      "symbol": "always_ref",
      "patterns": [
        "\\balways\\b",
        "\\balways_ff\\b",
        "\\balways_comb\\b",
        "\\balways_latch\\b",
        "\\binitial\\b"
      ],
      "includeDeclaration": true,
      "description": "Always and initial block references"
    },
    {
      "symbol": "assign_ref",
      "patterns": [
        "\\bassign\\s+\\w+",
        "<=",
        "\\binput\\s+",
        "\\boutput\\s+",
        "\\binout\\s+"
      ],
      "includeDeclaration": true,
      "description": "Continuous assignment and port references"
    },
    {
      "symbol": "instance_ref",
      "patterns": [
        "\\b\\w+\\s+#?\\s*\\(",
        "\\b\\w+\\s+\\w+\\s*\\("
      ],
      "includeDeclaration": true,
      "description": "Module instantiation references"
    },
    {
      "symbol": "assertion_ref",
      "patterns": [
        "\\bassert\\b",
        "\\bproperty\\b",
        "\\bsequence\\b",
        "\\bcovergroup\\b",
        "\\bcoverpoint\\b"
      ],
      "includeDeclaration": true,
      "description": "Assertion and coverage references"
    },
    {
      "symbol": "package_ref",
      "patterns": [
        "\\bpackage\\s+\\w+",
        "\\bimport\\s+\\w+::",
        "\\binclude\\b"
      ],
      "includeDeclaration": true,
      "description": "Package and import references"
    }
  ],
  "identifierPattern": "[a-zA-Z_][a-zA-Z0-9_$]*"
}
