{
  "language": "rust",
  "triggerKinds": {
    "invoke": 0,
    "automatic": 1
  },
  "tags": {
    "aiGenerated": 1
  },
  "namingConventions": {
    "casing": [
      "snake_case",
      "PascalCase",
      "UPPER_SNAKE_CASE"
    ],
    "prefixes": {
      "variable": [
        "_"
      ],
      "function": [
        "get_",
        "set_",
        "is_",
        "has_",
        "new_",
        "from_",
        "into_",
        "as_",
        "to_",
        "try_",
        "with_"
      ],
      "trait": [],
      "module": []
    },
    "suffixes": {
      "function": [
        "_mut",
        "_ref",
        "_unchecked",
        "_or_default",
        "_or_else"
      ],
      "struct": [
        "Builder",
        "Config",
        "Options",
        "Error",
        "Result"
      ],
      "trait": [
        "able",
        "ible"
      ],
      "enum": [
        "Kind",
        "Type",
        "Error"
      ]
    },
    "patterns": {
      "variable": "[a-z][a-z0-9_]*",
      "function": "[a-z][a-z0-9_]*",
      "struct": "[A-Z][a-zA-Z0-9]*",
      "trait": "[A-Z][a-zA-Z0-9]*",
      "enum": "[A-Z][a-zA-Z0-9]*",
      "constant": "[A-Z][A-Z0-9_]*",
      "module": "[a-z][a-z0-9_]*",
      "lifetime": "'[a-z]+"
    }
  },
  "symbolKinds": [
    "variable",
    "function",
    "struct",
    "constant",
    "parameter",
    "method",
    "trait",
    "enum",
    "enumVariant",
    "module",
    "typeAlias",
    "lifetime",
    "macro"
  ],
  "renameSuggestionRules": [
    {
      "symbolKind": "function",
      "pattern": "^new$",
      "suggestedNames": [
        {
          "newSymbolName": "create",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "build",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "default",
          "tags": [
            1
          ]
        }
      ],
      "description": "Constructor rename"
    },
    {
      "symbolKind": "function",
      "pattern": "^from_",
      "suggestedNames": [
        {
          "newSymbolName": "parse_{source}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "decode_{source}",
          "tags": [
            1
          ]
        }
      ],
      "description": "From function rename"
    },
    {
      "symbolKind": "function",
      "pattern": "^into_",
      "suggestedNames": [
        {
          "newSymbolName": "to_{target}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "convert_to_{target}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Into function rename"
    },
    {
      "symbolKind": "function",
      "pattern": "^try_",
      "suggestedNames": [
        {
          "newSymbolName": "{fallible_name}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "attempt_{action}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Try function rename"
    },
    {
      "symbolKind": "trait",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{DescriptiveTrait}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "{Verb}able",
          "tags": [
            1
          ]
        }
      ],
      "description": "Trait rename"
    },
    {
      "symbolKind": "enum",
      "pattern": ".*Error$",
      "suggestedNames": [
        {
          "newSymbolName": "{Name}Error",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "{Name}Failure",
          "tags": [
            1
          ]
        }
      ],
      "description": "Error enum rename"
    },
    {
      "symbolKind": "enumVariant",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{DescriptiveVariant}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Enum variant rename"
    },
    {
      "symbolKind": "lifetime",
      "pattern": "^'a$",
      "suggestedNames": [
        {
          "newSymbolName": "'{descriptive}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "'input",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "'output",
          "tags": [
            1
          ]
        }
      ],
      "description": "Lifetime rename"
    },
    {
      "symbolKind": "macro",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{descriptive_macro}!",
          "tags": [
            1
          ]
        }
      ],
      "description": "Macro rename"
    },
    {
      "symbolKind": "module",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{descriptive_module}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Module rename"
    },
    {
      "symbolKind": "variable",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{descriptiveVariable}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Rename variable to descriptive name"
    },
    {
      "symbolKind": "function",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{descriptiveFunction}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Rename function to descriptive action name"
    }
  ],
  "reservedWords": [
    "as",
    "async",
    "await",
    "break",
    "const",
    "continue",
    "crate",
    "dyn",
    "else",
    "enum",
    "extern",
    "false",
    "fn",
    "for",
    "if",
    "impl",
    "in",
    "let",
    "loop",
    "match",
    "mod",
    "move",
    "mut",
    "pub",
    "ref",
    "return",
    "self",
    "Self",
    "static",
    "struct",
    "super",
    "trait",
    "true",
    "type",
    "union",
    "unsafe",
    "use",
    "where",
    "while",
    "yield"
  ],
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "maxLength": 255,
    "caseSensitive": true,
    "unicodeSupport": false
  }
}
