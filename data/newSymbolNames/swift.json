{
  "language": "swift",
  "triggerKinds": {
    "invoke": 0,
    "automatic": 1
  },
  "tags": {
    "aiGenerated": 1
  },
  "namingConventions": {
    "casing": [
      "camelCase",
      "PascalCase"
    ],
    "prefixes": {
      "variable": [
        "_",
        "m_"
      ],
      "function": [
        "get",
        "set",
        "is",
        "has",
        "can",
        "should",
        "will",
        "did",
        "on",
        "handle",
        "create",
        "make",
        "build",
        "init",
        "parse",
        "format",
        "to",
        "from",
        "with",
        "update",
        "delete",
        "remove",
        "add",
        "find",
        "fetch",
        "load",
        "save",
        "validate",
        "check",
        "compute",
        "calculate",
        "process",
        "transform",
        "convert",
        "render",
        "display",
        "show",
        "hide"
      ],
      "class": [
        "Abstract",
        "Base",
        "Default",
        "Custom",
        "Internal"
      ],
      "interface": [
        "I"
      ],
      "constant": [],
      "boolean": [
        "is",
        "has",
        "can",
        "should",
        "will",
        "did",
        "was",
        "needs",
        "allows",
        "supports",
        "enables"
      ]
    },
    "suffixes": {
      "variable": [],
      "function": [
        "Async",
        "Sync",
        "Safe",
        "OrThrow",
        "OrDefault",
        "OrNull",
        "IfNeeded"
      ],
      "class": [
        "Base",
        "Impl",
        "Factory",
        "Builder",
        "Handler",
        "Manager",
        "Service",
        "Controller",
        "Provider",
        "Adapter",
        "Proxy",
        "Wrapper",
        "Decorator",
        "Observer",
        "Listener",
        "Visitor",
        "Strategy",
        "Command",
        "Iterator",
        "Repository",
        "Validator",
        "Mapper",
        "Converter",
        "Transformer",
        "Helper",
        "Util",
        "Utils",
        "Config",
        "Options",
        "Params",
        "Props",
        "State",
        "Context",
        "Store",
        "Cache",
        "Pool",
        "Queue",
        "Stack",
        "Registry",
        "Resolver",
        "Dispatcher",
        "Emitter"
      ],
      "interface": [
        "able",
        "ible"
      ],
      "constant": [],
      "enum": [
        "Type",
        "Kind",
        "Status",
        "State",
        "Mode",
        "Level",
        "Category",
        "Phase"
      ]
    },
    "patterns": {
      "variable": "[a-z][a-zA-Z0-9]*",
      "function": "[a-z][a-zA-Z0-9]*",
      "class": "[A-Z][a-zA-Z0-9]*",
      "constant": "[A-Z][A-Z0-9_]*",
      "interface": "I[A-Z][a-zA-Z0-9]*",
      "enum": "[A-Z][a-zA-Z0-9]*",
      "typeParameter": "[A-Z]([a-zA-Z0-9]*)?",
      "parameter": "[a-z][a-zA-Z0-9]*"
    }
  },
  "symbolKinds": [
    "variable",
    "function",
    "class",
    "constant",
    "parameter",
    "property",
    "method",
    "protocol",
    "enum",
    "enumCase",
    "struct",
    "actor",
    "typeAlias",
    "associatedType"
  ],
  "renameSuggestionRules": [
    {
      "symbolKind": "protocol",
      "pattern": ".*able$",
      "suggestedNames": [
        {
          "newSymbolName": "{Name}able",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "{Name}Protocol",
          "tags": [
            1
          ]
        }
      ],
      "description": "Protocol rename"
    },
    {
      "symbolKind": "protocol",
      "pattern": ".*Delegate$",
      "suggestedNames": [
        {
          "newSymbolName": "{Name}Delegate",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "{Name}Handler",
          "tags": [
            1
          ]
        }
      ],
      "description": "Delegate protocol rename"
    },
    {
      "symbolKind": "actor",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{DescriptiveName}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Actor rename"
    },
    {
      "symbolKind": "struct",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{DescriptiveName}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Struct rename"
    },
    {
      "symbolKind": "enumCase",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": ".{descriptiveCase}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Enum case rename"
    },
    {
      "symbolKind": "associatedType",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{DescriptiveType}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Associated type rename"
    },
    {
      "symbolKind": "function",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{descriptiveFunction}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Function rename"
    }
  ],
  "reservedWords": [
    "associatedtype",
    "class",
    "deinit",
    "enum",
    "extension",
    "fileprivate",
    "func",
    "import",
    "init",
    "inout",
    "internal",
    "let",
    "open",
    "operator",
    "private",
    "protocol",
    "public",
    "rethrows",
    "static",
    "struct",
    "subscript",
    "typealias",
    "var",
    "break",
    "case",
    "continue",
    "default",
    "defer",
    "do",
    "else",
    "fallthrough",
    "for",
    "guard",
    "if",
    "in",
    "repeat",
    "return",
    "switch",
    "where",
    "while",
    "as",
    "Any",
    "catch",
    "false",
    "is",
    "nil",
    "self",
    "Self",
    "super",
    "throw",
    "throws",
    "true",
    "try",
    "_",
    "actor",
    "async",
    "await",
    "some"
  ],
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "maxLength": 255,
    "caseSensitive": true,
    "unicodeSupport": true
  }
}
