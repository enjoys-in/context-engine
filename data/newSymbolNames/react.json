{
  "language": "react",
  "triggerKinds": {
    "invoke": 0,
    "automatic": 1
  },
  "tags": {
    "aiGenerated": 1
  },
  "namingConventions": {
    "casing": [
      "camelCase",
      "PascalCase",
      "UPPER_SNAKE_CASE"
    ],
    "prefixes": {
      "variable": [
        "_",
        "m_"
      ],
      "function": [
        "get",
        "set",
        "is",
        "has",
        "can",
        "should",
        "will",
        "did",
        "on",
        "handle",
        "create",
        "make",
        "build",
        "init",
        "parse",
        "format",
        "to",
        "from",
        "with",
        "update",
        "delete",
        "remove",
        "add",
        "find",
        "fetch",
        "load",
        "save",
        "validate",
        "check",
        "compute",
        "calculate",
        "process",
        "transform",
        "convert",
        "render",
        "display",
        "show",
        "hide"
      ],
      "class": [
        "Abstract",
        "Base",
        "Default",
        "Custom",
        "Internal"
      ],
      "interface": [
        "I"
      ],
      "constant": [],
      "boolean": [
        "is",
        "has",
        "can",
        "should",
        "will",
        "did",
        "was",
        "needs",
        "allows",
        "supports",
        "enables"
      ]
    },
    "suffixes": {
      "variable": [],
      "function": [
        "Async",
        "Sync",
        "Safe",
        "OrThrow",
        "OrDefault",
        "OrNull",
        "IfNeeded"
      ],
      "class": [
        "Base",
        "Impl",
        "Factory",
        "Builder",
        "Handler",
        "Manager",
        "Service",
        "Controller",
        "Provider",
        "Adapter",
        "Proxy",
        "Wrapper",
        "Decorator",
        "Observer",
        "Listener",
        "Visitor",
        "Strategy",
        "Command",
        "Iterator",
        "Repository",
        "Validator",
        "Mapper",
        "Converter",
        "Transformer",
        "Helper",
        "Util",
        "Utils",
        "Config",
        "Options",
        "Params",
        "Props",
        "State",
        "Context",
        "Store",
        "Cache",
        "Pool",
        "Queue",
        "Stack",
        "Registry",
        "Resolver",
        "Dispatcher",
        "Emitter"
      ],
      "interface": [
        "able",
        "ible"
      ],
      "constant": [],
      "enum": [
        "Type",
        "Kind",
        "Status",
        "State",
        "Mode",
        "Level",
        "Category",
        "Phase"
      ]
    },
    "patterns": {
      "variable": "[a-z][a-zA-Z0-9]*",
      "function": "[a-z][a-zA-Z0-9]*",
      "class": "[A-Z][a-zA-Z0-9]*",
      "constant": "[A-Z][A-Z0-9_]*",
      "interface": "I[A-Z][a-zA-Z0-9]*",
      "enum": "[A-Z][a-zA-Z0-9]*",
      "typeParameter": "[A-Z]([a-zA-Z0-9]*)?",
      "parameter": "[a-z][a-zA-Z0-9]*"
    }
  },
  "symbolKinds": [
    "variable",
    "function",
    "class",
    "constant",
    "parameter",
    "property",
    "method",
    "interface",
    "enum",
    "typeAlias",
    "module",
    "namespace"
  ],
  "renameSuggestionRules": [
    {
      "symbolKind": "function",
      "pattern": "^handle[A-Z]",
      "suggestedNames": [
        {
          "newSymbolName": "on{Event}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "process{Event}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "{event}Handler",
          "tags": [
            1
          ]
        }
      ],
      "description": "Event handler rename"
    },
    {
      "symbolKind": "function",
      "pattern": "^get[A-Z]",
      "suggestedNames": [
        {
          "newSymbolName": "fetch{Subject}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "retrieve{Subject}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "load{Subject}",
