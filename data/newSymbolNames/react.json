    "try",
    "typeof",
    "undefined",
    "var",
    "void",
    "volatile",
    "while",
    "with",
    "yield"
  ],
  "identifierRules": {
    "start": "[a-zA-Z_$]",
    "continue": "[a-zA-Z0-9_$]",
    "maxLength": 255,
    "caseSensitive": true,
    "unicodeSupport": true
  }
}
