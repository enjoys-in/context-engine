{
  "language": "go",
  "triggerKinds": {
    "invoke": 0,
    "automatic": 1
  },
  "tags": {
    "aiGenerated": 1
  },
  "namingConventions": {
    "casing": [
      "camelCase",
      "PascalCase"
    ],
    "prefixes": {
      "variable": [],
      "function": [
        "Get",
        "Set",
        "New",
        "Make",
        "Is",
        "Has",
        "Must",
        "With"
      ],
      "interface": [],
      "receiver": []
    },
    "suffixes": {
      "function": [
        "Handler",
        "Func",
        "Middleware"
      ],
      "interface": [
        "er",
        "able",
        "ible"
      ],
      "struct": [
        "Config",
        "Options",
        "Params",
        "Result",
        "Response",
        "Request"
      ]
    },
    "patterns": {
      "exported": "[A-Z][a-zA-Z0-9]*",
      "unexported": "[a-z][a-zA-Z0-9]*",
      "interface": "[A-Z][a-zA-Z0-9]*er",
      "constant": "[A-Z][a-zA-Z0-9]*",
      "receiver": "[a-z]"
    }
  },
  "symbolKinds": [
    "variable",
    "function",
    "struct",
    "constant",
    "parameter",
    "method",
    "interface",
    "typeAlias",
    "package",
    "receiver"
  ],
  "renameSuggestionRules": [
    {
      "symbolKind": "function",
      "pattern": "^New[A-Z]",
      "suggestedNames": [
        {
          "newSymbolName": "Create{Subject}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "Make{Subject}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Constructor rename"
    },
    {
      "symbolKind": "function",
      "pattern": "^Must[A-Z]",
      "suggestedNames": [
        {
          "newSymbolName": "Ensure{Subject}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "Require{Subject}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Must function rename"
    },
    {
      "symbolKind": "interface",
      "pattern": ".*er$",
      "suggestedNames": [
        {
          "newSymbolName": "{Name}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "{Verb}er",
          "tags": [
            1
          ]
        }
      ],
      "description": "Interface rename"
    },
    {
      "symbolKind": "interface",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{Name}er",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "{Name}Interface",
          "tags": [
            1
          ]
        }
      ],
      "description": "Interface rename"
    },
    {
      "symbolKind": "receiver",
      "pattern": "^.$",
      "suggestedNames": [
        {
          "newSymbolName": "{shortTypeName}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Receiver rename"
    },
    {
      "symbolKind": "struct",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{DescriptiveName}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Struct rename"
    },
    {
      "symbolKind": "package",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{shortpackagename}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Package rename (short, lowercase)"
    }
  ],
  "reservedWords": [
    "break",
    "case",
    "chan",
    "const",
    "continue",
    "default",
    "defer",
    "else",
    "fallthrough",
    "for",
    "func",
    "go",
    "goto",
    "if",
    "import",
    "interface",
    "map",
    "package",
    "range",
    "return",
    "select",
    "struct",
    "switch",
    "type",
    "var"
  ],
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "maxLength": 255,
    "caseSensitive": true,
    "unicodeSupport": true
  }
}
