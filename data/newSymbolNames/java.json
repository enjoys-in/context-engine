{
  "language": "java",
  "triggerKinds": {
    "invoke": 0,
    "automatic": 1
  },
  "tags": {
    "aiGenerated": 1
  },
  "namingConventions": {
    "casing": [
      "camelCase",
      "PascalCase",
      "UPPER_SNAKE_CASE"
    ],
    "prefixes": {
      "variable": [
        "_",
        "m_"
      ],
      "function": [
        "get",
        "set",
        "is",
        "has",
        "can",
        "should",
        "will",
        "did",
        "on",
        "handle",
        "create",
        "make",
        "build",
        "init",
        "parse",
        "format",
        "to",
        "from",
        "with",
        "update",
        "delete",
        "remove",
        "add",
        "find",
        "fetch",
        "load",
        "save",
        "validate",
        "check",
        "compute",
        "calculate",
        "process",
        "transform",
        "convert",
        "render",
        "display",
        "show",
        "hide"
      ],
      "class": [
        "Abstract",
        "Base",
        "Default",
        "Custom",
        "Internal"
      ],
      "interface": [
        "I"
      ],
      "constant": [],
      "boolean": [
        "is",
        "has",
        "can",
        "should",
        "will",
        "did",
        "was",
        "needs",
        "allows",
        "supports",
        "enables"
      ]
    },
    "suffixes": {
      "variable": [],
      "function": [
        "Async",
        "Sync",
        "Safe",
        "OrThrow",
        "OrDefault",
        "OrNull",
        "IfNeeded"
      ],
      "class": [
        "Base",
        "Impl",
        "Factory",
        "Builder",
        "Handler",
        "Manager",
        "Service",
        "Controller",
        "Provider",
        "Adapter",
        "Proxy",
        "Wrapper",
        "Decorator",
        "Observer",
        "Listener",
        "Visitor",
        "Strategy",
        "Command",
        "Iterator",
        "Repository",
        "Validator",
        "Mapper",
        "Converter",
        "Transformer",
        "Helper",
        "Util",
        "Utils",
        "Config",
        "Options",
        "Params",
        "Props",
        "State",
        "Context",
        "Store",
        "Cache",
        "Pool",
        "Queue",
        "Stack",
        "Registry",
        "Resolver",
        "Dispatcher",
        "Emitter"
      ],
      "interface": [
        "able",
        "ible"
      ],
      "constant": [],
      "enum": [
        "Type",
        "Kind",
        "Status",
        "State",
        "Mode",
        "Level",
        "Category",
        "Phase"
      ]
    },
    "patterns": {
      "variable": "[a-z][a-zA-Z0-9]*",
      "function": "[a-z][a-zA-Z0-9]*",
      "class": "[A-Z][a-zA-Z0-9]*",
      "constant": "[A-Z][A-Z0-9_]*",
      "interface": "I[A-Z][a-zA-Z0-9]*",
      "enum": "[A-Z][a-zA-Z0-9]*",
      "typeParameter": "[A-Z]([a-zA-Z0-9]*)?",
      "parameter": "[a-z][a-zA-Z0-9]*"
    }
  },
  "symbolKinds": [
    "variable",
    "function",
    "class",
    "constant",
    "parameter",
    "property",
    "method",
    "interface",
    "enum",
    "enumConstant",
    "annotation",
    "package",
    "typeParameter"
  ],
  "renameSuggestionRules": [
    {
      "symbolKind": "method",
      "pattern": "^get[A-Z]",
      "suggestedNames": [
        {
          "newSymbolName": "fetch{Subject}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "retrieve{Subject}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "find{Subject}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Getter rename"
    },
    {
      "symbolKind": "method",
      "pattern": "^set[A-Z]",
      "suggestedNames": [
        {
          "newSymbolName": "update{Subject}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "assign{Subject}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Setter rename"
    },
    {
      "symbolKind": "method",
      "pattern": "^is[A-Z]",
      "suggestedNames": [
        {
          "newSymbolName": "has{Trait}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "check{Trait}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Boolean check rename"
    },
    {
      "symbolKind": "class",
      "pattern": ".*Impl$",
      "suggestedNames": [
        {
          "newSymbolName": "{Name}Default",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "{Name}Standard",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "{Name}Concrete",
          "tags": [
            1
          ]
        }
      ],
      "description": "Implementation class rename"
    },
    {
      "symbolKind": "class",
      "pattern": ".*DTO$",
      "suggestedNames": [
        {
          "newSymbolName": "{Name}Response",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "{Name}Payload",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "{Name}Data",
          "tags": [
            1
          ]
        }
      ],
      "description": "DTO class rename"
    },
    {
      "symbolKind": "interface",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{DescriptiveName}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "{Name}Contract",
          "tags": [
            1
          ]
        }
      ],
      "description": "Interface rename"
    },
    {
      "symbolKind": "annotation",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{DescriptiveAnnotation}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Annotation rename"
    },
    {
      "symbolKind": "enumConstant",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{DESCRIPTIVE_NAME}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Enum constant rename"
    },
    {
      "symbolKind": "typeParameter",
      "pattern": "^[A-Z]$",
      "suggestedNames": [
        {
          "newSymbolName": "T{Purpose}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Type parameter rename"
    },
    {
      "symbolKind": "package",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{descriptive.package.name}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Package rename"
    },
    {
      "symbolKind": "variable",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{descriptiveVariable}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Rename variable to descriptive name"
    },
    {
      "symbolKind": "function",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{descriptiveFunction}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Rename function to descriptive action name"
    }
  ],
  "reservedWords": [
    "abstract",
    "assert",
    "boolean",
    "break",
    "byte",
    "case",
    "catch",
    "char",
    "class",
    "const",
    "continue",
    "default",
    "do",
    "double",
    "else",
    "enum",
    "extends",
    "final",
    "finally",
    "float",
    "for",
    "goto",
    "if",
    "implements",
    "import",
    "instanceof",
    "int",
    "interface",
    "long",
    "native",
    "new",
    "null",
    "package",
    "private",
    "protected",
    "public",
    "return",
    "short",
    "static",
    "strictfp",
    "super",
    "switch",
    "synchronized",
    "this",
    "throw",
    "throws",
    "transient",
    "try",
    "var",
    "void",
    "volatile",
    "while",
    "yield",
    "permits",
    "sealed",
    "non-sealed",
    "record",
    "when"
  ],
  "identifierRules": {
    "start": "[a-zA-Z_$]",
    "continue": "[a-zA-Z0-9_$]",
    "maxLength": 65535,
    "caseSensitive": true,
    "unicodeSupport": true
  }
}
