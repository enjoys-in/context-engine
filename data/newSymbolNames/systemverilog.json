{
  "language": "systemverilog",
  "triggerKinds": {
    "invoke": 0,
    "automatic": 1
  },
  "tags": {
    "aiGenerated": 1
  },
  "namingConventions": {
    "casing": [
      "camelCase",
      "PascalCase",
      "UPPER_SNAKE_CASE"
    ],
    "prefixes": {
      "variable": [
        "_",
        "m_"
      ],
      "function": [
        "get",
        "set",
        "is",
        "has",
        "can",
        "should",
        "will",
        "did",
        "on",
        "handle",
        "create",
        "make",
        "build",
        "init",
        "parse",
        "format",
        "to",
        "from",
        "with",
        "update",
        "delete",
        "remove",
        "add",
        "find",
        "fetch",
        "load",
        "save",
        "validate",
        "check",
        "compute",
        "calculate",
        "process",
        "transform",
        "convert",
        "render",
        "display",
        "show",
        "hide"
      ],
      "class": [
        "Abstract",
        "Base",
        "Default",
        "Custom",
        "Internal"
      ],
      "interface": [
        "I"
      ],
      "constant": [],
      "boolean": [
        "is",
        "has",
        "can",
        "should",
        "will",
        "did",
        "was",
        "needs",
        "allows",
        "supports",
        "enables"
      ]
    },
    "suffixes": {
      "variable": [],
      "function": [
        "Async",
        "Sync",
        "Safe",
        "OrThrow",
        "OrDefault",
        "OrNull",
        "IfNeeded"
      ],
      "class": [
        "Base",
        "Impl",
        "Factory",
        "Builder",
        "Handler",
        "Manager",
        "Service",
        "Controller",
        "Provider",
        "Adapter",
        "Proxy",
        "Wrapper",
        "Decorator",
        "Observer",
        "Listener",
        "Visitor",
        "Strategy",
        "Command",
        "Iterator",
        "Repository",
        "Validator",
        "Mapper",
        "Converter",
        "Transformer",
        "Helper",
        "Util",
        "Utils",
        "Config",
        "Options",
        "Params",
        "Props",
        "State",
        "Context",
        "Store",
        "Cache",
        "Pool",
        "Queue",
        "Stack",
        "Registry",
        "Resolver",
        "Dispatcher",
        "Emitter"
      ],
      "interface": [
        "able",
        "ible"
      ],
      "constant": [],
      "enum": [
        "Type",
        "Kind",
        "Status",
        "State",
        "Mode",
        "Level",
        "Category",
        "Phase"
      ]
    },
    "patterns": {
      "variable": "[a-z][a-zA-Z0-9]*",
      "function": "[a-z][a-zA-Z0-9]*",
      "class": "[A-Z][a-zA-Z0-9]*",
      "constant": "[A-Z][A-Z0-9_]*",
      "interface": "I[A-Z][a-zA-Z0-9]*",
      "enum": "[A-Z][a-zA-Z0-9]*",
      "typeParameter": "[A-Z]([a-zA-Z0-9]*)?",
      "parameter": "[a-z][a-zA-Z0-9]*"
    }
  },
  "symbolKinds": [
    "variable",
    "function",
    "class",
    "constant",
    "parameter",
    "interface",
    "enum",
    "typeParameter"
  ],
  "renameSuggestionRules": [
    {
      "symbolKind": "function",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{descriptiveFunction}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Function rename"
    },
    {
      "symbolKind": "variable",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{descriptiveVariable}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Variable rename"
    },
    {
      "symbolKind": "class",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{DescriptiveName}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Class rename"
    },
    {
      "symbolKind": "constant",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{DESCRIPTIVE_NAME}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Constant rename"
    },
    {
      "symbolKind": "parameter",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{descriptiveParameter}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Rename parameter to descriptive name"
    },
    {
      "symbolKind": "interface",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{descriptiveInterface}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Rename interface with proper naming"
    },
    {
      "symbolKind": "enum",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{descriptiveEnum}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Rename enum type"
    },
    {
      "symbolKind": "typeParameter",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{descriptiveTypeParameter}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Rename type parameter"
    },
    {
      "symbolKind": "method",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{descriptiveMethod}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Rename method to descriptive action"
    },
    {
      "symbolKind": "property",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{descriptiveProperty}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Rename property to descriptive name"
    },
    {
      "symbolKind": "module",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{descriptiveModule}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Rename module/namespace"
    },
    {
      "symbolKind": "function",
      "pattern": "^get[A-Z]",
      "suggestedNames": [
        {
          "newSymbolName": "{descriptiveFunction}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Rename getter function"
    }
  ],
  "reservedWords": [
    "abstract",
    "break",
    "case",
    "catch",
    "class",
    "const",
    "continue",
    "default",
    "do",
    "else",
    "enum",
    "export",
    "extends",
    "false",
    "final",
    "finally",
    "for",
    "function",
    "if",
    "import",
    "in",
    "interface",
    "let",
    "new",
    "null",
    "package",
    "private",
    "protected",
    "public",
    "return",
    "static",
    "super",
    "switch",
    "this",
    "throw",
    "true",
    "try",
    "typeof",
    "var",
    "void",
    "while",
    "yield"
  ],
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "maxLength": 255,
    "caseSensitive": true,
    "unicodeSupport": false
  }
}
