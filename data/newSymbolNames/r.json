{
  "language": "r",
  "triggerKinds": {
    "invoke": 0,
    "automatic": 1
  },
  "tags": {
    "aiGenerated": 1
  },
  "namingConventions": {
    "casing": [
      "snake_case",
      "PascalCase",
      "UPPER_SNAKE_CASE"
    ],
    "prefixes": {
      "variable": [
        "_"
      ],
      "function": [
        "get_",
        "set_",
        "is_",
        "has_",
        "can_",
        "create_",
        "make_",
        "build_",
        "init_",
        "parse_",
        "format_",
        "to_",
        "from_",
        "update_",
        "delete_",
        "remove_",
        "add_",
        "find_",
        "fetch_",
        "load_",
        "save_",
        "validate_",
        "check_",
        "compute_",
        "calculate_",
        "process_",
        "transform_",
        "convert_"
      ],
      "class": [
        "Abstract",
        "Base"
      ],
      "boolean": [
        "is_",
        "has_",
        "can_",
        "should_",
        "was_",
        "needs_",
        "allows_"
      ]
    },
    "suffixes": {
      "variable": [],
      "function": [
        "_async",
        "_sync",
        "_safe",
        "_or_default",
        "_or_none"
      ],
      "class": [
        "Base",
        "Mixin",
        "Error",
        "Exception",
        "Factory",
        "Builder",
        "Handler",
        "Manager",
        "Service",
        "Controller",
        "Provider",
        "Adapter",
        "Helper",
        "Util"
      ],
      "module": [
        "_utils",
        "_helpers",
        "_config",
        "_constants",
        "_types"
      ]
    },
    "patterns": {
      "variable": "[a-z][a-z0-9_]*",
      "function": "[a-z][a-z0-9_]*",
      "class": "[A-Z][a-zA-Z0-9]*",
      "constant": "[A-Z][A-Z0-9_]*",
      "module": "[a-z][a-z0-9_]*"
    }
  },
  "symbolKinds": [
    "variable",
    "function",
    "class",
    "constant",
    "parameter",
    "property",
    "method",
    "module",
    "decorator",
    "typeAlias"
  ],
  "renameSuggestionRules": [
    {
      "symbolKind": "function",
      "pattern": "^get_",
      "suggestedNames": [
        {
          "newSymbolName": "fetch_{subject}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "retrieve_{subject}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "load_{subject}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Getter rename"
    },
    {
      "symbolKind": "function",
      "pattern": "^set_",
      "suggestedNames": [
        {
          "newSymbolName": "update_{subject}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "assign_{subject}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Setter rename"
    },
    {
      "symbolKind": "function",
      "pattern": "^is_",
      "suggestedNames": [
        {
          "newSymbolName": "has_{trait}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "check_{trait}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Boolean check rename"
    },
    {
      "symbolKind": "function",
      "pattern": "^create_",
      "suggestedNames": [
        {
          "newSymbolName": "build_{subject}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "make_{subject}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "generate_{subject}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Factory rename"
    },
    {
      "symbolKind": "function",
      "pattern": "^parse_",
      "suggestedNames": [
        {
          "newSymbolName": "decode_{subject}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "deserialize_{subject}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Parser rename"
    },
    {
      "symbolKind": "function",
      "pattern": "^validate_",
      "suggestedNames": [
        {
          "newSymbolName": "check_{subject}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "verify_{subject}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Validator rename"
    },
    {
      "symbolKind": "function",
      "pattern": "^_",
      "suggestedNames": [
        {
          "newSymbolName": "_{descriptive_name}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Private function rename"
    },
    {
      "symbolKind": "function",
      "pattern": "^__.*__$",
      "suggestedNames": [
        {
          "newSymbolName": "__{dunder_name}__",
          "tags": [
            1
          ]
        }
      ],
      "description": "Dunder method rename"
    },
    {
      "symbolKind": "class",
      "pattern": ".*Error$",
      "suggestedNames": [
        {
          "newSymbolName": "{Name}Exception",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "{Name}Failure",
          "tags": [
            1
          ]
        }
      ],
      "description": "Error class rename"
    },
    {
      "symbolKind": "class",
      "pattern": ".*Mixin$",
      "suggestedNames": [
        {
          "newSymbolName": "{Name}Trait",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "{Name}Capability",
          "tags": [
            1
          ]
        }
      ],
      "description": "Mixin class rename"
    },
    {
      "symbolKind": "class",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{DescriptiveName}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Class rename"
    },
    {
      "symbolKind": "variable",
      "pattern": "^(data|info|result|value|item|obj)$",
      "suggestedNames": [
        {
          "newSymbolName": "{contextual_name}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Generic variable rename"
    },
    {
      "symbolKind": "variable",
      "pattern": "^_",
      "suggestedNames": [
        {
          "newSymbolName": "_{descriptive_name}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Private variable rename"
    },
    {
      "symbolKind": "constant",
      "pattern": "^[A-Z][A-Z0-9_]+$",
      "suggestedNames": [
        {
          "newSymbolName": "{DESCRIPTIVE_NAME}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Constant rename"
    },
    {
      "symbolKind": "decorator",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{descriptive_decorator}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Decorator rename"
    }
  ],
  "reservedWords": [
    "False",
    "None",
    "True",
    "and",
    "as",
    "assert",
    "async",
    "await",
    "break",
    "class",
    "continue",
    "def",
    "del",
    "elif",
    "else",
    "except",
    "finally",
    "for",
    "from",
    "global",
    "if",
    "import",
    "in",
    "is",
    "lambda",
    "nonlocal",
    "not",
    "or",
    "pass",
    "raise",
    "return",
    "try",
    "while",
    "with",
    "yield",
    "match",
    "case",
    "type"
  ],
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "maxLength": 255,
    "caseSensitive": true,
    "unicodeSupport": true
  }
}
