{
  "language": "csharp",
  "triggerKinds": {
    "invoke": 0,
    "automatic": 1
  },
  "tags": {
    "aiGenerated": 1
  },
  "namingConventions": {
    "casing": [
      "camelCase",
      "PascalCase",
      "UPPER_SNAKE_CASE",
      "_camelCase"
    ],
    "prefixes": {
      "variable": [
        "_",
        "m_"
      ],
      "function": [
        "get",
        "set",
        "is",
        "has",
        "can",
        "should",
        "will",
        "did",
        "on",
        "handle",
        "create",
        "make",
        "build",
        "init",
        "parse",
        "format",
        "to",
        "from",
        "with",
        "update",
        "delete",
        "remove",
        "add",
        "find",
        "fetch",
        "load",
        "save",
        "validate",
        "check",
        "compute",
        "calculate",
        "process",
        "transform",
        "convert",
        "render",
        "display",
        "show",
        "hide"
      ],
      "class": [
        "Abstract",
        "Base",
        "Default",
        "Custom",
        "Internal"
      ],
      "interface": [
        "I"
      ],
      "constant": [],
      "boolean": [
        "is",
        "has",
        "can",
        "should",
        "will",
        "did",
        "was",
        "needs",
        "allows",
        "supports",
        "enables"
      ]
    },
    "suffixes": {
      "variable": [],
      "function": [
        "Async",
        "Sync",
        "Safe",
        "OrThrow",
        "OrDefault",
        "OrNull",
        "IfNeeded"
      ],
      "class": [
        "Base",
        "Impl",
        "Factory",
        "Builder",
        "Handler",
        "Manager",
        "Service",
        "Controller",
        "Provider",
        "Adapter",
        "Proxy",
        "Wrapper",
        "Decorator",
        "Observer",
        "Listener",
        "Visitor",
        "Strategy",
        "Command",
        "Iterator",
        "Repository",
        "Validator",
        "Mapper",
        "Converter",
        "Transformer",
        "Helper",
        "Util",
        "Utils",
        "Config",
        "Options",
        "Params",
        "Props",
        "State",
        "Context",
        "Store",
        "Cache",
        "Pool",
        "Queue",
        "Stack",
        "Registry",
        "Resolver",
        "Dispatcher",
        "Emitter"
      ],
      "interface": [
        "able",
        "ible"
      ],
      "constant": [],
      "enum": [
        "Type",
        "Kind",
        "Status",
        "State",
        "Mode",
        "Level",
        "Category",
        "Phase"
      ]
    },
    "patterns": {
      "variable": "[a-z][a-zA-Z0-9]*",
      "function": "[a-z][a-zA-Z0-9]*",
      "class": "[A-Z][a-zA-Z0-9]*",
      "constant": "[A-Z][A-Z0-9_]*",
      "interface": "I[A-Z][a-zA-Z0-9]*",
      "enum": "[A-Z][a-zA-Z0-9]*",
      "typeParameter": "[A-Z]([a-zA-Z0-9]*)?",
      "parameter": "[a-z][a-zA-Z0-9]*"
    }
  },
  "symbolKinds": [
    "variable",
    "function",
    "class",
    "constant",
    "parameter",
    "property",
    "method",
    "interface",
    "enum",
    "enumMember",
    "struct",
    "event",
    "delegate",
    "namespace",
    "typeParameter"
  ],
  "renameSuggestionRules": [
    {
      "symbolKind": "interface",
      "pattern": "^I[A-Z]",
      "suggestedNames": [
        {
          "newSymbolName": "I{DescriptiveName}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Interface rename (keep I prefix)"
    },
    {
      "symbolKind": "variable",
      "pattern": "^_[a-z]",
      "suggestedNames": [
        {
          "newSymbolName": "_{descriptiveName}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Private field rename"
    },
    {
      "symbolKind": "property",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{DescriptiveProperty}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Property rename"
    },
    {
      "symbolKind": "event",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "On{EventName}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "{EventName}Occurred",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "{EventName}Changed",
          "tags": [
            1
          ]
        }
      ],
      "description": "Event rename"
    },
    {
      "symbolKind": "delegate",
      "pattern": ".*Handler$",
      "suggestedNames": [
        {
          "newSymbolName": "{Name}Callback",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "{Name}Action",
          "tags": [
            1
          ]
        }
      ],
      "description": "Delegate rename"
    },
    {
      "symbolKind": "method",
      "pattern": "^Get",
      "suggestedNames": [
        {
          "newSymbolName": "Fetch{Subject}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "Retrieve{Subject}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Getter method rename"
    },
    {
      "symbolKind": "method",
      "pattern": "Async$",
      "suggestedNames": [
        {
          "newSymbolName": "{Name}Async",
          "tags": [
            1
          ]
        }
      ],
      "description": "Async method rename"
    },
    {
      "symbolKind": "struct",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{DescriptiveName}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Struct rename"
    },
    {
      "symbolKind": "class",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{DescriptiveName}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Class rename"
    },
    {
      "symbolKind": "variable",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{descriptiveVariable}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Rename variable to descriptive name"
    },
    {
      "symbolKind": "function",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{descriptiveFunction}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Rename function to descriptive action name"
    },
    {
      "symbolKind": "constant",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{descriptiveConstant}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Rename constant to descriptive UPPER_SNAKE_CASE"
    }
  ],
  "reservedWords": [
    "abstract",
    "as",
    "base",
    "bool",
    "break",
    "byte",
    "case",
    "catch",
    "char",
    "checked",
    "class",
    "const",
    "continue",
    "decimal",
    "default",
    "delegate",
    "do",
    "double",
    "else",
    "enum",
    "event",
    "explicit",
    "extern",
    "false",
    "finally",
    "fixed",
    "float",
    "for",
    "foreach",
    "goto",
    "if",
    "implicit",
    "in",
    "int",
    "interface",
    "internal",
    "is",
    "lock",
    "long",
    "namespace",
    "new",
    "null",
    "object",
    "operator",
    "out",
    "override",
    "params",
    "private",
    "protected",
    "public",
    "readonly",
    "record",
    "ref",
    "return",
    "sbyte",
    "sealed",
    "short",
    "sizeof",
    "stackalloc",
    "static",
    "string",
    "struct",
    "switch",
    "this",
    "throw",
    "true",
    "try",
    "typeof",
    "uint",
    "ulong",
    "unchecked",
    "unsafe",
    "ushort",
    "using",
    "var",
    "virtual",
    "void",
    "volatile",
    "while",
    "yield",
    "async",
    "await",
    "dynamic",
    "nameof",
    "when",
    "where",
    "with"
  ],
  "identifierRules": {
    "start": "[a-zA-Z_@]",
    "continue": "[a-zA-Z0-9_]",
    "maxLength": 511,
    "caseSensitive": true,
    "unicodeSupport": true
  }
}
