{
  "language": "ignore",
  "displayName": "Ignore Files",
  "capabilities": {
    "newSymbolNameSuggestions": true,
    "supportedSymbolKinds": [
      "variable",
      "function",
      "class",
      "method",
      "property",
      "parameter",
      "type",
      "interface",
      "enum",
      "constant"
    ]
  },
  "namingConventions": [
    "camelCase",
    "PascalCase",
    "snake_case"
  ],
  "prefixes": [
    "get",
    "set",
    "is",
    "has",
    "new"
  ],
  "suffixes": [
    "Handler",
    "Service",
    "Factory",
    "Helper",
    "Manager"
  ]
}
