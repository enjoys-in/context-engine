{
  "language": "ruby",
  "triggerKinds": {
    "invoke": 0,
    "automatic": 1
  },
  "tags": {
    "aiGenerated": 1
  },
  "namingConventions": {
    "casing": [
      "snake_case",
      "PascalCase",
      "UPPER_SNAKE_CASE"
    ],
    "prefixes": {
      "variable": [
        "@",
        "@@",
        "$"
      ],
      "method": [
        "get_",
        "set_",
        "is_",
        "has_",
        "can_",
        "create_",
        "find_",
        "fetch_",
        "build_",
        "validate_"
      ],
      "class": [
        "Abstract",
        "Base"
      ],
      "boolean": [
        "is_",
        "has_",
        "can_"
      ]
    },
    "suffixes": {
      "method": [
        "!",
        "?",
        "_safe",
        "_or_default"
      ],
      "class": [
        "Base",
        "Error",
        "Concern",
        "Service",
        "Controller",
        "Model",
        "Helper",
        "Decorator",
        "Serializer",
        "Validator",
        "Job",
        "Mailer",
        "Worker"
      ],
      "module": [
        "able",
        "ible"
      ]
    },
    "patterns": {
      "variable": "[a-z][a-z0-9_]*",
      "method": "[a-z][a-z0-9_]*[!?]?",
      "class": "[A-Z][a-zA-Z0-9]*",
      "constant": "[A-Z][A-Z0-9_]*",
      "symbol": ":[a-z][a-z0-9_]*"
    }
  },
  "symbolKinds": [
    "variable",
    "method",
    "class",
    "constant",
    "parameter",
    "module",
    "symbol",
    "instanceVariable",
    "classVariable",
    "globalVariable"
  ],
  "renameSuggestionRules": [
    {
      "symbolKind": "method",
      "pattern": "\\?$",
      "suggestedNames": [
        {
          "newSymbolName": "{predicate}?",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "is_{trait}?",
          "tags": [
            1
          ]
        }
      ],
      "description": "Predicate method rename"
    },
    {
      "symbolKind": "method",
      "pattern": "!$",
      "suggestedNames": [
        {
          "newSymbolName": "{action}!",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "{mutating_action}!",
          "tags": [
            1
          ]
        }
      ],
      "description": "Bang method rename"
    },
    {
      "symbolKind": "class",
      "pattern": ".*Controller$",
      "suggestedNames": [
        {
          "newSymbolName": "{Name}Controller",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "{Name}Handler",
          "tags": [
            1
          ]
        }
      ],
      "description": "Controller rename"
    },
    {
      "symbolKind": "class",
      "pattern": ".*Model$",
      "suggestedNames": [
        {
          "newSymbolName": "{Name}Model",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "{Name}Record",
          "tags": [
            1
          ]
        }
      ],
      "description": "Model rename"
    },
    {
      "symbolKind": "module",
      "pattern": ".*Concern$",
      "suggestedNames": [
        {
          "newSymbolName": "{Name}Behavior",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "{Name}Capability",
          "tags": [
            1
          ]
        }
      ],
      "description": "Concern rename"
    },
    {
      "symbolKind": "module",
      "pattern": ".*able$",
      "suggestedNames": [
        {
          "newSymbolName": "{Name}able",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "{Name}ible",
          "tags": [
            1
          ]
        }
      ],
      "description": "Ability module rename"
    },
    {
      "symbolKind": "symbol",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": ":{descriptive_symbol}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Symbol rename"
    },
    {
      "symbolKind": "instanceVariable",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "@{descriptive_name}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Instance variable rename"
    },
    {
      "symbolKind": "classVariable",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "@@{descriptive_name}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Class variable rename"
    },
    {
      "symbolKind": "variable",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{descriptiveVariable}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Rename variable to descriptive name"
    },
    {
      "symbolKind": "function",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{descriptiveFunction}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Rename function to descriptive action name"
    },
    {
      "symbolKind": "class",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{descriptiveClass}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Rename class to descriptive noun"
    }
  ],
  "reservedWords": [
    "BEGIN",
    "END",
    "__ENCODING__",
    "__END__",
    "__FILE__",
    "__LINE__",
    "alias",
    "and",
    "begin",
    "break",
    "case",
    "class",
    "def",
    "defined?",
    "do",
    "else",
    "elsif",
    "end",
    "ensure",
    "false",
    "for",
    "if",
    "in",
    "module",
    "next",
    "nil",
    "not",
    "or",
    "redo",
    "rescue",
    "retry",
    "return",
    "self",
    "super",
    "then",
    "true",
    "undef",
    "unless",
    "until",
    "when",
    "while",
    "yield"
  ],
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "maxLength": 255,
    "caseSensitive": true,
    "unicodeSupport": false
  }
}
