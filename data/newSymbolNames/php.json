{
  "language": "php",
  "triggerKinds": {
    "invoke": 0,
    "automatic": 1
  },
  "tags": {
    "aiGenerated": 1
  },
  "namingConventions": {
    "casing": [
      "camelCase",
      "PascalCase",
      "UPPER_SNAKE_CASE",
      "snake_case"
    ],
    "prefixes": {
      "variable": [
        "_",
        "m_"
      ],
      "function": [
        "get",
        "set",
        "is",
        "has",
        "can",
        "should",
        "will",
        "did",
        "on",
        "handle",
        "create",
        "make",
        "build",
        "init",
        "parse",
        "format",
        "to",
        "from",
        "with",
        "update",
        "delete",
        "remove",
        "add",
        "find",
        "fetch",
        "load",
        "save",
        "validate",
        "check",
        "compute",
        "calculate",
        "process",
        "transform",
        "convert",
        "render",
        "display",
        "show",
        "hide"
      ],
      "class": [
        "Abstract",
        "Base",
        "Default",
        "Custom",
        "Internal"
      ],
      "interface": [
        "I"
      ],
      "constant": [],
      "boolean": [
        "is",
        "has",
        "can",
        "should",
        "will",
        "did",
        "was",
        "needs",
        "allows",
        "supports",
        "enables"
      ]
    },
    "suffixes": {
      "variable": [],
      "function": [
        "Async",
        "Sync",
        "Safe",
        "OrThrow",
        "OrDefault",
        "OrNull",
        "IfNeeded"
      ],
      "class": [
        "Base",
        "Impl",
        "Factory",
        "Builder",
        "Handler",
        "Manager",
        "Service",
        "Controller",
        "Provider",
        "Adapter",
        "Proxy",
        "Wrapper",
        "Decorator",
        "Observer",
        "Listener",
        "Visitor",
        "Strategy",
        "Command",
        "Iterator",
        "Repository",
        "Validator",
        "Mapper",
        "Converter",
        "Transformer",
        "Helper",
        "Util",
        "Utils",
        "Config",
        "Options",
        "Params",
        "Props",
        "State",
        "Context",
        "Store",
        "Cache",
        "Pool",
        "Queue",
        "Stack",
        "Registry",
        "Resolver",
        "Dispatcher",
        "Emitter"
      ],
      "interface": [
        "able",
        "ible"
      ],
      "constant": [],
      "enum": [
        "Type",
        "Kind",
        "Status",
        "State",
        "Mode",
        "Level",
        "Category",
        "Phase"
      ]
    },
    "patterns": {
      "variable": "[a-z][a-zA-Z0-9]*",
      "function": "[a-z][a-zA-Z0-9]*",
      "class": "[A-Z][a-zA-Z0-9]*",
      "constant": "[A-Z][A-Z0-9_]*",
      "interface": "I[A-Z][a-zA-Z0-9]*",
      "enum": "[A-Z][a-zA-Z0-9]*",
      "typeParameter": "[A-Z]([a-zA-Z0-9]*)?",
      "parameter": "[a-z][a-zA-Z0-9]*"
    }
  },
  "symbolKinds": [
    "variable",
    "function",
    "class",
    "constant",
    "parameter",
    "property",
    "method",
    "interface",
    "trait",
    "enum",
    "namespace"
  ],
  "renameSuggestionRules": [
    {
      "symbolKind": "variable",
      "pattern": "^\\$",
      "suggestedNames": [
        {
          "newSymbolName": "${descriptiveName}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Variable rename"
    },
    {
      "symbolKind": "method",
      "pattern": "^get[A-Z]",
      "suggestedNames": [
        {
          "newSymbolName": "fetch{Subject}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "find{Subject}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Getter rename"
    },
    {
      "symbolKind": "method",
      "pattern": "^set[A-Z]",
      "suggestedNames": [
        {
          "newSymbolName": "update{Subject}",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "assign{Subject}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Setter rename"
    },
    {
      "symbolKind": "class",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{DescriptiveName}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Class rename"
    },
    {
      "symbolKind": "trait",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{Name}Trait",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "{Name}Behavior",
          "tags": [
            1
          ]
        }
      ],
      "description": "Trait rename"
    },
    {
      "symbolKind": "interface",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{Name}Interface",
          "tags": [
            1
          ]
        },
        {
          "newSymbolName": "{Name}Contract",
          "tags": [
            1
          ]
        }
      ],
      "description": "Interface rename"
    },
    {
      "symbolKind": "enum",
      "pattern": ".*",
      "suggestedNames": [
        {
          "newSymbolName": "{DescriptiveEnum}",
          "tags": [
            1
          ]
        }
      ],
      "description": "Enum rename"
    }
  ],
  "reservedWords": [
    "abstract",
    "and",
    "array",
    "as",
    "break",
    "callable",
    "case",
    "catch",
    "class",
    "clone",
    "const",
    "continue",
    "declare",
    "default",
    "do",
    "echo",
    "else",
    "elseif",
    "empty",
    "enddeclare",
    "endfor",
    "endforeach",
    "endif",
    "endswitch",
    "endwhile",
    "enum",
    "eval",
    "exit",
    "extends",
    "false",
    "final",
    "finally",
    "fn",
    "for",
    "foreach",
    "function",
    "global",
    "goto",
    "if",
    "implements",
    "include",
    "include_once",
    "instanceof",
    "insteadof",
    "interface",
    "isset",
    "list",
    "match",
    "namespace",
    "new",
    "null",
    "or",
    "print",
    "private",
    "protected",
    "public",
    "readonly",
    "require",
    "require_once",
    "return",
    "static",
    "switch",
    "this",
    "throw",
    "trait",
    "true",
    "try",
    "unset",
    "use",
    "var",
    "while",
    "xor",
    "yield"
  ],
  "identifierRules": {
    "start": "[a-zA-Z_\\x80-\\xff]",
    "continue": "[a-zA-Z0-9_\\x80-\\xff]",
    "maxLength": 255,
    "caseSensitive": true,
    "unicodeSupport": true
  }
}
