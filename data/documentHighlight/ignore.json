{
  "language": "ignore",
  "highlights": {
    "#": {
      "kind": 0,
      "description": "Comment line"
    },
    "!": {
      "kind": 2,
      "description": "Negation prefix — re-includes a previously ignored pattern"
    },
    "*": {
      "kind": 1,
      "description": "Glob wildcard character"
    },
    "**": {
      "kind": 1,
      "description": "Recursive directory wildcard"
    },
    "?": {
      "kind": 1,
      "description": "Single character wildcard"
    },
    "[": {
      "kind": 1,
      "description": "Character class open bracket"
    },
    "]": {
      "kind": 1,
      "description": "Character class close bracket"
    }
  },
  "bracketPairs": [
    { "open": "[", "close": "]" }
  ],
  "keywordGroups": [
    {
      "name": "wildcards",
      "keywords": ["*", "**", "?"],
      "highlightKind": 1
    },
    {
      "name": "modifiers",
      "keywords": ["!", "/"],
      "highlightKind": 2
    },
    {
      "name": "comments",
      "keywords": ["#"],
      "highlightKind": 0
    }
  ]
}