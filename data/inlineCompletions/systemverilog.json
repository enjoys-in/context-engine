{
  "language": "systemverilog",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*module\\\\s*$",
      "insertText": "module ${1:my_module} (\n\tinput  logic ${2:clk},\n\tinput  logic ${3:rst_n},\n\toutput logic ${4:out}\n);\n\t${5:// body}\nendmodule",
      "description": "Module definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*always_ff\\\\s*$",
      "insertText": "always_ff @(posedge ${1:clk} or negedge ${2:rst_n}) begin\n\tif (!${2:rst_n})\n\t\t${3:q} <= '0;\n\telse\n\t\t${3:q} <= ${4:d};\nend",
      "description": "Sequential always block",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*always_comb\\\\s*$",
      "insertText": "always_comb begin\n\t${1:out} = ${2:expression};\nend",
      "description": "Combinational always block",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*interface\\\\s*$",
      "insertText": "interface ${1:my_if};\n\tlogic ${2:valid};\n\tlogic [${3:7}:0] ${4:data};\n\n\tmodport ${5:master} (output ${2:valid}, output ${4:data});\n\tmodport ${6:slave} (input ${2:valid}, input ${4:data});\nendinterface",
      "description": "Interface definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*class\\\\s*$",
      "insertText": "class ${1:MyClass} extends ${2:uvm_object};\n\t`uvm_object_utils(${1:MyClass})\n\n\tfunction new(string name = \"${1:MyClass}\");\n\t\tsuper.new(name);\n\tendfunction\n\n\t${3:// methods}\nendclass",
      "description": "Class definition",
      "completeBracketPairs": true
    },
    {
      "trigger": "for",
      "template": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "description": "For loop",
      "triggerPattern": "for",
      "insertText": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "if",
      "template": "if (${1:condition}) {\n  ${0}\n}",
      "description": "If statement",
      "triggerPattern": "if",
      "insertText": "if (${1:condition}) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "try",
      "template": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "description": "Try-catch block",
      "triggerPattern": "try",
      "insertText": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "fn",
      "template": "function ${1:name}(${2:params}) {\n  ${0}\n}",
      "description": "Function declaration",
      "triggerPattern": "fn",
      "insertText": "function ${1:name}(${2:params}) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "log",
      "template": "console.log(${0})",
      "description": "Console log",
      "triggerPattern": "log",
      "insertText": "console.log(${0})",
      "completeBracketPairs": true
    },
    {
      "trigger": "imp",
      "template": "import { ${1:name} } from '${0:module}'",
      "description": "Import statement",
      "triggerPattern": "imp",
      "insertText": "import { ${1:name} } from '${0:module}'",
      "completeBracketPairs": true
    },
    {
      "trigger": "class",
      "template": "class ${1:Name} {\n  constructor(${2:params}) {\n    ${0}\n  }\n}",
      "description": "Class declaration",
      "triggerPattern": "class",
      "insertText": "class ${1:Name} {\n  constructor(${2:params}) {\n    ${0}\n  }\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "switch",
      "template": "switch (${1:expr}) {\n  case ${2:val}:\n    ${0}\n    break;\n  default:\n    break;\n}",
      "description": "Switch statement",
      "triggerPattern": "switch",
      "insertText": "switch (${1:expr}) {\n  case ${2:val}:\n    ${0}\n    break;\n  default:\n    break;\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "while",
      "template": "while (${1:condition}) {\n  ${0}\n}",
      "description": "While loop",
      "triggerPattern": "while",
      "insertText": "while (${1:condition}) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "map",
      "template": "${1:array}.map((${2:item}) => ${0})",
      "description": "Array map",
      "triggerPattern": "map",
      "insertText": "${1:array}.map((${2:item}) => ${0})",
      "completeBracketPairs": true
    }
  ]
}
