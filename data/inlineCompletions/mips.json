{
  "language": "mips",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*\\.data\\\\s*$",
      "insertText": ".data\n${1:label}: .${2:asciiz} ${3:\"Hello, World!\"}",
      "description": "Data section with label",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*\\.text\\\\s*$",
      "insertText": ".text\n.globl main\nmain:\n\t${1:# instructions}",
      "description": "Text section with main",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*main:\\\\s*$",
      "insertText": "main:\n\tli $v0, ${1:4}\n\tla $a0, ${2:msg}\n\tsyscall\n\tli $v0, 10\n\tsyscall",
      "description": "Main entry with print and exit syscall",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*syscall\\\\s*$",
      "insertText": "li $v0, ${1:1}\n${2:# load arguments}\nsyscall",
      "description": "Syscall with service number",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*li\\\\s*$",
      "insertText": "li $${1:v0}, ${2:0}",
      "description": "Load immediate",
      "completeBracketPairs": true
    }
  ]
}