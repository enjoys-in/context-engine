{
  "language": "coffee",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*->\\\\s*$",
      "insertText": "(${1:args}) ->\n\t${2:body}",
      "description": "Arrow function",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*class\\\\s*$",
      "insertText": "class ${1:ClassName}\n\tconstructor: (${2:args}) ->\n\t\t${3:@prop = args}",
      "description": "Class definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*for\\\\s*$",
      "insertText": "for ${1:item} in ${2:array}\n\t${3:console.log item}",
      "description": "For..in loop",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*if\\\\s*$",
      "insertText": "if ${1:condition}\n\t${2:# true branch}\nelse\n\t${3:# false branch}",
      "description": "If/else conditional",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*switch\\\\s*$",
      "insertText": "switch ${1:expr}\n\twhen ${2:value1} then ${3:result1}\n\twhen ${4:value2} then ${5:result2}\n\telse ${6:default}",
      "description": "Switch expression",
      "completeBracketPairs": true
    }
  ]
}