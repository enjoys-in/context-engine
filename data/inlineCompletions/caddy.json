{
  "language": "caddy",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*:443\\\\s*$",
      "insertText": ":443 {\n\t${1:reverse_proxy localhost:8080}\n}",
      "description": "HTTPS site block",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*reverse_proxy\\\\s*$",
      "insertText": "reverse_proxy ${1:localhost:8080}",
      "description": "Reverse proxy directive",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*file_server\\\\s*$",
      "insertText": "file_server {\n\troot ${1:/var/www/html}\n\tbrowse\n}",
      "description": "File server directive",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*tls\\\\s*$",
      "insertText": "tls ${1:email@example.com}",
      "description": "TLS configuration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*handle\\\\s*$",
      "insertText": "handle ${1:/api/*} {\n\t${2:reverse_proxy localhost:3000}\n}",
      "description": "Handle path block",
      "completeBracketPairs": true
    }
  ]
}
