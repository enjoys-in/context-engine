{
  "language": "caddy",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*:443\\\\s*$",
      "insertText": ":443 {\n\t${1:reverse_proxy localhost:8080}\n}",
      "description": "HTTPS site block",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*reverse_proxy\\\\s*$",
      "insertText": "reverse_proxy ${1:localhost:8080}",
      "description": "Reverse proxy directive",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*file_server\\\\s*$",
      "insertText": "file_server {\n\troot ${1:/var/www/html}\n\tbrowse\n}",
      "description": "File server directive",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*tls\\\\s*$",
      "insertText": "tls ${1:email@example.com}",
      "description": "TLS configuration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*handle\\\\s*$",
      "insertText": "handle ${1:/api/*} {\n\t${2:reverse_proxy localhost:3000}\n}",
      "description": "Handle path block",
      "completeBracketPairs": true
    },
    {
      "trigger": "for",
      "template": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "description": "For loop"
    },
    {
      "trigger": "if",
      "template": "if (${1:condition}) {\n  ${0}\n}",
      "description": "If statement"
    },
    {
      "trigger": "try",
      "template": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "description": "Try-catch block"
    },
    {
      "trigger": "fn",
      "template": "function ${1:name}(${2:params}) {\n  ${0}\n}",
      "description": "Function declaration"
    },
    {
      "trigger": "log",
      "template": "console.log(${0})",
      "description": "Console log"
    },
    {
      "trigger": "imp",
      "template": "import { ${1:name} } from '${0:module}'",
      "description": "Import statement"
    },
    {
      "trigger": "class",
      "template": "class ${1:Name} {\n  constructor(${2:params}) {\n    ${0}\n  }\n}",
      "description": "Class declaration"
    },
    {
      "trigger": "switch",
      "template": "switch (${1:expr}) {\n  case ${2:val}:\n    ${0}\n    break;\n  default:\n    break;\n}",
      "description": "Switch statement"
    },
    {
      "trigger": "while",
      "template": "while (${1:condition}) {\n  ${0}\n}",
      "description": "While loop"
    },
    {
      "trigger": "map",
      "template": "${1:array}.map((${2:item}) => ${0})",
      "description": "Array map"
    }
  ]
}
