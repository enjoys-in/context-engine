{
  "language": "r",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*for\\\\s*$",
      "insertText": "for (${1:i} in ${2:seq}) {\n  ${3}\n}",
      "description": "For loop",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*while\\\\s*$",
      "insertText": "while (${1:condition}) {\n  ${2}\n}",
      "description": "While loop",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*function\\\\s*$",
      "insertText": "function(${1:args}) {\n  ${2}\n}",
      "description": "Anonymous function",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*if\\\\s*$",
      "insertText": "if (${1:condition}) {\n  ${2}\n}",
      "description": "If block",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*tryCatch\\\\s*$",
      "insertText": "tryCatch({\n  ${1}\n}, error = function(e) {\n  ${2:message(e$message)}\n})",
      "description": "tryCatch block",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*\\\\w+\\\\s*<-\\\\s*R6Class\\\\s*$",
      "insertText": "R6Class(\"${1:ClassName}\",\n  public = list(\n    initialize = function(${2:}) {\n      ${3}\n    }\n  )\n)",
      "description": "R6 class definition",
      "completeBracketPairs": true
    }
  ]
}