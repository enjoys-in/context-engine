{
  "language": "nginx",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*location\\\\s*$",
      "insertText": "location ${1:/} {\n\t$0\n}",
      "description": "Location block",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*server\\\\s*$",
      "insertText": "server {\n\tlisten ${1:80};\n\tserver_name ${2:example.com};\n\t$0\n}",
      "description": "Server block",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "server\\s*\\{",
      "insertText": "server {\n\tlisten ${1:80};\n\tserver_name ${2:example.com};\n\n\tlocation / {\n\t\t$0\n\t}\n}",
      "description": "server block"
    },
    {
      "triggerPattern": "location\\s",
      "insertText": "location ${1:/path} {\n\t${2:proxy_pass http://localhost:${3:3000};}\n}",
      "description": "location block"
    },
    {
      "triggerPattern": "upstream\\s",
      "insertText": "upstream ${1:backend} {\n\tserver ${2:127.0.0.1:${3:8080}};\n}",
      "description": "upstream block"
    },
    {
      "trigger": "for",
      "template": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "description": "For loop"
    },
    {
      "trigger": "if",
      "template": "if (${1:condition}) {\n  ${0}\n}",
      "description": "If statement"
    },
    {
      "trigger": "try",
      "template": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "description": "Try-catch block"
    },
    {
      "trigger": "fn",
      "template": "function ${1:name}(${2:params}) {\n  ${0}\n}",
      "description": "Function declaration"
    },
    {
      "trigger": "log",
      "template": "console.log(${0})",
      "description": "Console log"
    },
    {
      "trigger": "imp",
      "template": "import { ${1:name} } from '${0:module}'",
      "description": "Import statement"
    },
    {
      "trigger": "class",
      "template": "class ${1:Name} {\n  constructor(${2:params}) {\n    ${0}\n  }\n}",
      "description": "Class declaration"
    },
    {
      "trigger": "switch",
      "template": "switch (${1:expr}) {\n  case ${2:val}:\n    ${0}\n    break;\n  default:\n    break;\n}",
      "description": "Switch statement"
    },
    {
      "trigger": "while",
      "template": "while (${1:condition}) {\n  ${0}\n}",
      "description": "While loop"
    },
    {
      "trigger": "map",
      "template": "${1:array}.map((${2:item}) => ${0})",
      "description": "Array map"
    }
  ]
}
