{
  "language": "pgsql",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*SELECT\\\\s*$",
      "insertText": "SELECT ${1:columns}\nFROM ${2:table}\nWHERE ${3:condition};",
      "description": "Select query with where",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*CREATE\\\\s*TABLE\\\\s*$",
      "insertText": "CREATE TABLE ${1:table_name} (\n\t${2:id} SERIAL PRIMARY KEY,\n\t${3:column} ${4:VARCHAR(255)} ${5:NOT NULL}\n);",
      "description": "Create table with serial primary key",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*CREATE\\\\s*FUNCTION\\\\s*$",
      "insertText": "CREATE OR REPLACE FUNCTION ${1:func_name}(${2:param} ${3:INTEGER})\nRETURNS ${4:VOID} AS $$\nBEGIN\n\t${5:-- body}\nEND;\n$$ LANGUAGE plpgsql;",
      "description": "Create PL/pgSQL function",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*INSERT\\\\s*INTO\\\\s*$",
      "insertText": "INSERT INTO ${1:table} (${2:columns})\nVALUES (${3:values})\nRETURNING ${4:id};",
      "description": "Insert with returning",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*ALTER\\\\s*TABLE\\\\s*$",
      "insertText": "ALTER TABLE ${1:table}\nADD COLUMN ${2:column} ${3:VARCHAR(255)} ${4:NOT NULL};",
      "description": "Alter table add column",
      "completeBracketPairs": true
    },
    {
      "trigger": "for",
      "template": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "description": "For loop"
    },
    {
      "trigger": "if",
      "template": "if (${1:condition}) {\n  ${0}\n}",
      "description": "If statement"
    },
    {
      "trigger": "try",
      "template": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "description": "Try-catch block"
    },
    {
      "trigger": "fn",
      "template": "function ${1:name}(${2:params}) {\n  ${0}\n}",
      "description": "Function declaration"
    },
    {
      "trigger": "log",
      "template": "console.log(${0})",
      "description": "Console log"
    },
    {
      "trigger": "imp",
      "template": "import { ${1:name} } from '${0:module}'",
      "description": "Import statement"
    },
    {
      "trigger": "class",
      "template": "class ${1:Name} {\n  constructor(${2:params}) {\n    ${0}\n  }\n}",
      "description": "Class declaration"
    },
    {
      "trigger": "switch",
      "template": "switch (${1:expr}) {\n  case ${2:val}:\n    ${0}\n    break;\n  default:\n    break;\n}",
      "description": "Switch statement"
    },
    {
      "trigger": "while",
      "template": "while (${1:condition}) {\n  ${0}\n}",
      "description": "While loop"
    },
    {
      "trigger": "map",
      "template": "${1:array}.map((${2:item}) => ${0})",
      "description": "Array map"
    }
  ]
}
