{
  "language": "rust",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*fn\\\\s*$",
      "insertText": "fn ${1:name}(${2:}) -> ${3:()}{\\n\\t$0\\n}",
      "description": "Function",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*struct\\\\s*$",
      "insertText": "struct ${1:Name} {\n\t${2:field}: ${3:Type},\n}",
      "description": "Struct",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*impl\\\\s*$",
      "insertText": "impl ${1:Name} {\n\t$0\n}",
      "description": "Impl block",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "fn\\s+$",
      "insertText": "${1:name}(${2:params}) -> ${3:ReturnType} {\n\t${4:todo!()}\n}",
      "description": "function declaration",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "for\\s+$",
      "insertText": "${1:item} in ${2:collection} {\n\t${3}\n}",
      "description": "for loop",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "if\\s+let\\s+$",
      "insertText": "Some(${1:value}) = ${2:option} {\n\t${3}\n}",
      "description": "if let Some",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "match\\s+$",
      "insertText": "${1:value} {\n\t${2:pattern} => ${3:result},\n\t_ => ${4:default},\n}",
      "description": "match expression",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "impl\\s+$",
      "insertText": "${1:Type} {\n\t${2}\n}",
      "description": "impl block",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "struct\\s+$",
      "insertText": "${1:Name} {\n\t${2:field}: ${3:Type},\n}",
      "description": "struct declaration",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "enum\\s+$",
      "insertText": "${1:Name} {\n\t${2:Variant},\n}",
      "description": "enum declaration",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "\\.unwrap_or\\($",
      "insertText": "${1:default})",
      "description": "unwrap_or",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "println!\\($",
      "insertText": "\"${1:text}\", ${2:value})",
      "description": "println!",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "#\\[derive\\($",
      "insertText": "Debug, Clone${1:, PartialEq})]",
      "description": "derive macro",
      "completeBracketPairs": false
    },
    {
      "trigger": "for",
      "template": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "description": "For loop"
    },
    {
      "trigger": "if",
      "template": "if (${1:condition}) {\n  ${0}\n}",
      "description": "If statement"
    }
  ]
}
