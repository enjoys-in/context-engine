{
  "language": "rust",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*fn\\\\s*$",
      "insertText": "fn ${1:name}(${2:}) -> ${3:()}{\\n\\t$0\\n}",
      "description": "Function",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*struct\\\\s*$",
      "insertText": "struct ${1:Name} {\n\t${2:field}: ${3:Type},\n}",
      "description": "Struct",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*impl\\\\s*$",
      "insertText": "impl ${1:Name} {\n\t$0\n}",
      "description": "Impl block",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "fn\\s+$",
      "insertText": "${1:name}(${2:params}) -> ${3:ReturnType} {\n\t${4:todo!()}\n}",
      "description": "function declaration",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "for\\s+$",
      "insertText": "${1:item} in ${2:collection} {\n\t${3}\n}",
      "description": "for loop",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "if\\s+let\\s+$",
      "insertText": "Some(${1:value}) = ${2:option} {\n\t${3}\n}",
      "description": "if let Some",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "match\\s+$",
      "insertText": "${1:value} {\n\t${2:pattern} => ${3:result},\n\t_ => ${4:default},\n}",
      "description": "match expression",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "impl\\s+$",
      "insertText": "${1:Type} {\n\t${2}\n}",
      "description": "impl block",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "struct\\s+$",
      "insertText": "${1:Name} {\n\t${2:field}: ${3:Type},\n}",
      "description": "struct declaration",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "enum\\s+$",
      "insertText": "${1:Name} {\n\t${2:Variant},\n}",
      "description": "enum declaration",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "\\.unwrap_or\\($",
      "insertText": "${1:default})",
      "description": "unwrap_or",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "println!\\($",
      "insertText": "\"${1:text}\", ${2:value})",
      "description": "println!",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "#\\[derive\\($",
      "insertText": "Debug, Clone${1:, PartialEq})]",
      "description": "derive macro",
      "completeBracketPairs": false
    },
    {
      "trigger": "for",
      "template": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "description": "For loop",
      "triggerPattern": "for",
      "insertText": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "if",
      "template": "if (${1:condition}) {\n  ${0}\n}",
      "description": "If statement",
      "triggerPattern": "if",
      "insertText": "if (${1:condition}) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "fn",
      "insertText": "fn ${1:name}(${2:params}) -> ${3:ReturnType} {\n\t${4}\n}",
      "description": "Function declaration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "struct",
      "insertText": "struct ${1:Name} {\n\t${2:field}: ${3:Type},\n}",
      "description": "Struct definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "enum",
      "insertText": "enum ${1:Name} {\n\t${2:Variant},\n}",
      "description": "Enum definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "impl",
      "insertText": "impl ${1:Type} {\n\t${2}\n}",
      "description": "Impl block",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "trait",
      "insertText": "trait ${1:Name} {\n\tfn ${2:method}(&self) -> ${3:Type};\n}",
      "description": "Trait definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "match",
      "insertText": "match ${1:expr} {\n\t${2:Pattern} => ${3:value},\n\t_ => ${4:default},\n}",
      "description": "Match expression",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "if_let",
      "insertText": "if let ${1:Some}(${2:val}) = ${3:expr} {\n\t${4}\n}",
      "description": "If-let expression",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "loop",
      "insertText": "loop {\n\t${1}\n\tbreak;\n}",
      "description": "Loop block",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "test",
      "insertText": "#[test]\nfn ${1:test_name}() {\n\t${2}\n}",
      "description": "Test function",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "derive",
      "insertText": "#[derive(${1:Debug, Clone})]",
      "description": "Derive macro",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "result",
      "insertText": "Result<${1:T}, ${2:Error}>",
      "description": "Result type",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "option",
      "insertText": "Option<${1:T}>",
      "description": "Option type",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "closure",
      "insertText": "|${1:params}| {\n\t${2}\n}",
      "description": "Closure",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "mod",
      "insertText": "mod ${1:name} {\n\t${2}\n}",
      "description": "Module definition",
      "completeBracketPairs": true
    }
  ]
}
