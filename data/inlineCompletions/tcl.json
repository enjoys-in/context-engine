{
  "language": "tcl",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*proc\\\\s*$",
      "insertText": "proc ${1:name} {${2:args}} {\n\t${3:body}\n}",
      "description": "Procedure definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*set\\\\s*$",
      "insertText": "set ${1:variable} ${2:value}",
      "description": "Set variable",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*foreach\\\\s*$",
      "insertText": "foreach ${1:item} ${2:\\$list} {\n\t${3:puts \\$item}\n}",
      "description": "Foreach loop",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*if\\\\s*$",
      "insertText": "if {${1:condition}} {\n\t${2:# body}\n} else {\n\t${3:# else body}\n}",
      "description": "If conditional",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*namespace\\\\s*$",
      "insertText": "namespace eval ${1:myns} {\n\tnamespace export ${2:*}\n\t${3:# body}\n}",
      "description": "Namespace definition",
      "completeBracketPairs": true
    },
    {
      "trigger": "for",
      "template": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "description": "For loop",
      "triggerPattern": "for",
      "insertText": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "if",
      "template": "if (${1:condition}) {\n  ${0}\n}",
      "description": "If statement",
      "triggerPattern": "if",
      "insertText": "if (${1:condition}) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "try",
      "template": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "description": "Try-catch block",
      "triggerPattern": "try",
      "insertText": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "fn",
      "template": "function ${1:name}(${2:params}) {\n  ${0}\n}",
      "description": "Function declaration",
      "triggerPattern": "fn",
      "insertText": "function ${1:name}(${2:params}) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "log",
      "template": "console.log(${0})",
      "description": "Console log",
      "triggerPattern": "log",
      "insertText": "console.log(${0})",
      "completeBracketPairs": true
    },
    {
      "trigger": "imp",
      "template": "import { ${1:name} } from '${0:module}'",
      "description": "Import statement",
      "triggerPattern": "imp",
      "insertText": "import { ${1:name} } from '${0:module}'",
      "completeBracketPairs": true
    },
    {
      "trigger": "class",
      "template": "class ${1:Name} {\n  constructor(${2:params}) {\n    ${0}\n  }\n}",
      "description": "Class declaration",
      "triggerPattern": "class",
      "insertText": "class ${1:Name} {\n  constructor(${2:params}) {\n    ${0}\n  }\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "switch",
      "template": "switch (${1:expr}) {\n  case ${2:val}:\n    ${0}\n    break;\n  default:\n    break;\n}",
      "description": "Switch statement",
      "triggerPattern": "switch",
      "insertText": "switch (${1:expr}) {\n  case ${2:val}:\n    ${0}\n    break;\n  default:\n    break;\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "while",
      "template": "while (${1:condition}) {\n  ${0}\n}",
      "description": "While loop",
      "triggerPattern": "while",
      "insertText": "while (${1:condition}) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "map",
      "template": "${1:array}.map((${2:item}) => ${0})",
      "description": "Array map",
      "triggerPattern": "map",
      "insertText": "${1:array}.map((${2:item}) => ${0})",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "error\\\\s+|err\\\\s+",
      "insertText": "try {\\n\\t${1:code}\\n} catch (error) {\\n\\t${2:handle}\\n}",
      "description": "Tcl error handling pattern",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "const\\\\s+|let\\\\s+|var\\\\s+",
      "insertText": "const ${1:name} = ${2:value};",
      "description": "Tcl variable declaration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "interface\\\\s+|type\\\\s+",
      "insertText": "interface ${1:Name} {\\n\\t${2:property}: ${3:type};\\n}",
      "description": "Tcl interface/type definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "enum\\\\s+",
      "insertText": "enum ${1:Name} {\\n\\t${2:Value1},\\n\\t${3:Value2},\\n}",
      "description": "Tcl enum declaration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "constructor\\\\s*\\\\(|__init__|init\\\\s*\\\\(",
      "insertText": "constructor(${1:params}) {\\n\\t${2:}\\n}",
      "description": "Tcl constructor",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "export\\\\s+",
      "insertText": "export { ${1:name} } from '${2:module}';",
      "description": "Tcl re-export",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "throw\\\\s+|raise\\\\s+",
      "insertText": "throw new ${1:Error}('${2:message}');",
      "description": "Tcl throw/raise error",
      "completeBracketPairs": true
    }
  ]
}
