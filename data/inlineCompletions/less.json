{
  "language": "less",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*@var\\\\s*$",
      "insertText": "@${1:variable}: ${2:value};",
      "description": "Variable declaration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*\\.mixin\\\\s*$",
      "insertText": ".${1:mixin}(@${2:param}) {\n\t${3:property}: @${2:param};\n}",
      "description": "Mixin definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*&:hover\\\\s*$",
      "insertText": "&:hover {\n\t${1:property}: ${2:value};\n}",
      "description": "Nested hover rule",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*@media\\\\s*$",
      "insertText": "@media (${1:max-width}: ${2:768px}) {\n\t${3:selector} {\n\t\t${4:property}: ${5:value};\n\t}\n}",
      "description": "Media query",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "display:\\s*$",
      "insertText": "${1|flex,grid,block,inline-block,none|}",
      "description": "display value",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "position:\\s*$",
      "insertText": "${1|relative,absolute,fixed,sticky|}",
      "description": "position value",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "justify-content:\\s*$",
      "insertText": "${1|center,flex-start,flex-end,space-between,space-around|}",
      "description": "justify-content value",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "align-items:\\s*$",
      "insertText": "${1|center,flex-start,flex-end,stretch,baseline|}",
      "description": "align-items value",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "@media\\s*$",
      "insertText": "(max-width: ${1:768px}) {\n\t${2}\n}",
      "description": "media query",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "transition:\\s*$",
      "insertText": "${1:all} ${2:0.3s} ${3:ease}",
      "description": "transition shorthand",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "background:\\s*$",
      "insertText": "${1:color} ${2:url()} ${3:no-repeat} ${4:center}",
      "description": "background shorthand",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "border:\\s*$",
      "insertText": "${1:1px} ${2:solid} ${3:#ccc}",
      "description": "border shorthand",
      "completeBracketPairs": false
    },
    {
      "trigger": "for",
      "template": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "description": "For loop"
    },
    {
      "trigger": "if",
      "template": "if (${1:condition}) {\n  ${0}\n}",
      "description": "If statement"
    },
    {
      "trigger": "try",
      "template": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "description": "Try-catch block"
    }
  ]
}
