{
  "language": "crontab",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*\\*\\\\s*$",
      "insertText": "* * * * * ${1:command}",
      "description": "Every minute cron job",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*@daily\\\\s*$",
      "insertText": "@daily ${1:/path/to/script.sh}",
      "description": "Daily cron job",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*@hourly\\\\s*$",
      "insertText": "@hourly ${1:/path/to/script.sh}",
      "description": "Hourly cron job",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*@\\\\s*$",
      "insertText": "@${1|reboot,hourly,daily,weekly,monthly,yearly|} ${2:command}",
      "description": "Special schedule shorthand",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*0\\\\s*$",
      "insertText": "0 ${1:0} * * ${2:*} ${3:command}",
      "description": "Custom schedule (minute hour dom month dow)",
      "completeBracketPairs": true
    }
  ]
}
