{
  "language": "java",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*for\\\\s*$",
      "insertText": "for (int ${1:i} = 0; ${1:i} < ${2:length}; ${1:i}++) {\n\t$0\n}",
      "description": "For loop",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*sout$",
      "insertText": "System.out.println(${1:});",
      "description": "Print line",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "for\\s*\\($",
      "insertText": "int ${1:i} = 0; ${1:i} < ${2:n}; ${1:i}++",
      "description": "for loop with counter",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "if\\s*\\($",
      "insertText": "${1:condition}",
      "description": "if condition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "while\\s*\\($",
      "insertText": "${1:condition}",
      "description": "while condition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "switch\\s*\\($",
      "insertText": "${1:variable}) {\n\tcase ${2:value}:\n\t\t${3:// code}\n\t\tbreak;\n\tdefault:\n\t\tbreak;\n}",
      "description": "switch statement",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "try\\s*\\{$",
      "insertText": "\n\t${1:// code}\n} catch (${2:e}) {\n\t${3:// handle}\n}",
      "description": "try-catch block",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "//\\s*TODO$",
      "insertText": ": ${1:description}",
      "description": "TODO comment",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "System\\.out\\.$",
      "insertText": "println(${1:value})",
      "description": "System.out.println",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "public\\s+class\\s+$",
      "insertText": "${1:ClassName} {\n\t${2}\n}",
      "description": "class declaration",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "public\\s+static\\s+void\\s+main\\($",
      "insertText": "String[] args) {\n\t${1:// code}\n}",
      "description": "main method",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "\\.stream\\(\\)\\.$",
      "insertText": "filter(${1:e} -> ${2:condition}).collect(Collectors.toList())",
      "description": "stream filter collect",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "@Override$",
      "insertText": "\npublic ${1:void} ${2:method}(${3:params}) {\n\t${4:// code}\n}",
      "description": "Override method",
      "completeBracketPairs": false
    },
    {
      "trigger": "for",
      "template": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "description": "For loop",
      "triggerPattern": "for",
      "insertText": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "if",
      "template": "if (${1:condition}) {\n  ${0}\n}",
      "description": "If statement",
      "triggerPattern": "if",
      "insertText": "if (${1:condition}) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "error\\\\s+|err\\\\s+",
      "insertText": "try {\\n\\t${1:code}\\n} catch (error) {\\n\\t${2:handle}\\n}",
      "description": "Java error handling pattern",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "const\\\\s+|let\\\\s+|var\\\\s+",
      "insertText": "const ${1:name} = ${2:value};",
      "description": "Java variable declaration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "interface\\\\s+|type\\\\s+",
      "insertText": "interface ${1:Name} {\\n\\t${2:property}: ${3:type};\\n}",
      "description": "Java interface/type definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "enum\\\\s+",
      "insertText": "enum ${1:Name} {\\n\\t${2:Value1},\\n\\t${3:Value2},\\n}",
      "description": "Java enum declaration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "constructor\\\\s*\\\\(|__init__|init\\\\s*\\\\(",
      "insertText": "public ${1:ClassName}(${2:params}) {\\n\\t${3:}\\n}",
      "description": "Java constructor",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "export\\\\s+",
      "insertText": "export { ${1:name} } from '${2:module}';",
      "description": "Java re-export",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "throw\\\\s+|raise\\\\s+",
      "insertText": "throw new ${1:Error}('${2:message}');",
      "description": "Java throw/raise error",
      "completeBracketPairs": true
    }
  ]
}
