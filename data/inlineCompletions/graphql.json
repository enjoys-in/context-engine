{
  "language": "graphql",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*type\\\\s*$",
      "insertText": "type ${1:Name} {\n\t${2:field}: ${3:String}\n}",
      "description": "Type definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*query\\\\s*$",
      "insertText": "query ${1:Name} {\n\t$0\n}",
      "description": "Query",
      "completeBracketPairs": true
    }
  ]
}
