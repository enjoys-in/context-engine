{
  "language": "m3",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*MODULE\\\\s*$",
      "insertText": "MODULE ${1:Name};\n\nIMPORT ${2:Fmt};\n\nBEGIN\n\t${3:(* body *)}\nEND ${1:Name}.",
      "description": "Module definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*PROCEDURE\\\\s*$",
      "insertText": "PROCEDURE ${1:Name}(${2:params}) =\nBEGIN\n\t${3:(* body *)}\nEND ${1:Name};",
      "description": "Procedure definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*VAR\\\\s*$",
      "insertText": "VAR\n\t${1:name}: ${2:INTEGER} := ${3:0};",
      "description": "Variable declaration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*BEGIN\\\\s*$",
      "insertText": "BEGIN\n\t${1:(* body *)}\nEND;",
      "description": "Begin-end block",
      "completeBracketPairs": true
    }
  ]
}