{
  "language": "sql",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*SELECT\\\\s*$",
      "insertText": "SELECT ${1:*} FROM ${2:table} WHERE ${3:condition};",
      "description": "Select query",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*CREATE\\\\s+TABLE\\\\s*$",
      "insertText": "CREATE TABLE ${1:name} (\n\t${2:id} SERIAL PRIMARY KEY,\n\t$0\n);",
      "description": "Create table",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "SELECT\\s+$",
      "insertText": "${1:columns}\nFROM ${2:table}\nWHERE ${3:condition}",
      "description": "SELECT query",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "INSERT\\s+INTO\\s+$",
      "insertText": "${1:table} (${2:columns})\nVALUES (${3:values})",
      "description": "INSERT statement",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "UPDATE\\s+$",
      "insertText": "${1:table}\nSET ${2:column} = ${3:value}\nWHERE ${4:condition}",
      "description": "UPDATE statement",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "CREATE\\s+TABLE\\s+$",
      "insertText": "${1:table_name} (\n\t${2:id} ${3:INT} PRIMARY KEY,\n\t${4:column} ${5:VARCHAR(255)}\n)",
      "description": "CREATE TABLE",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "JOIN\\s+$",
      "insertText": "${1:table} ON ${2:condition}",
      "description": "JOIN clause",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "GROUP BY\\s+$",
      "insertText": "${1:column}\nHAVING ${2:condition}",
      "description": "GROUP BY with HAVING",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "ALTER\\s+TABLE\\s+$",
      "insertText": "${1:table}\nADD COLUMN ${2:column} ${3:type}",
      "description": "ALTER TABLE",
      "completeBracketPairs": false
    }
  ]
}