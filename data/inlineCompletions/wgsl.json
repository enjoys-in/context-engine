{
  "language": "wgsl",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*fn\\\\s*$",
      "insertText": "fn ${1:name}(${2:param}: ${3:f32}) -> ${4:f32} {\n\t${5:return param;}\n}",
      "description": "Function definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*struct\\\\s*$",
      "insertText": "struct ${1:VertexOutput} {\n\t@builtin(position) ${2:pos}: vec4<f32>,\n\t@location(0) ${3:color}: vec4<f32>,\n}",
      "description": "Struct definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*@vertex\\\\s*$",
      "insertText": "@vertex\nfn ${1:vs_main}(@builtin(vertex_index) ${2:idx}: u32) -> @builtin(position) vec4<f32> {\n\t${3:return vec4<f32>(0.0, 0.0, 0.0, 1.0);}\n}",
      "description": "Vertex shader entry point",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*@fragment\\\\s*$",
      "insertText": "@fragment\nfn ${1:fs_main}() -> @location(0) vec4<f32> {\n\t${2:return vec4<f32>(1.0, 0.0, 0.0, 1.0);}\n}",
      "description": "Fragment shader entry point",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*@group\\\\s*$",
      "insertText": "@group(${1:0}) @binding(${2:0})\nvar<${3:uniform}> ${4:data}: ${5:mat4x4<f32>};",
      "description": "Binding group declaration",
      "completeBracketPairs": true
    }
  ]
}