{
  "language": "html",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*<!DOCTYPE\\\\s*$",
      "insertText": "<!DOCTYPE html>\n<html lang=\"${1:en}\">\n<head>\n\t<meta charset=\"UTF-8\">\n\t<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n\t<title>${2:Document}</title>\n</head>\n<body>\n\t${3:}\n</body>\n</html>",
      "description": "HTML5 boilerplate",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*<div\\\\s*$",
      "insertText": "<div class=\"${1:container}\">\n\t$0\n</div>",
      "description": "Div element",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*<a\\\\s*$",
      "insertText": "<a href=\"${1:#}\">${2:link text}</a>",
      "description": "Anchor link",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*<form\\\\s*$",
      "insertText": "<form action=\"${1:/submit}\" method=\"${2:post}\">\n\t<label for=\"${3:input}\">${4:Label}</label>\n\t<input type=\"${5:text}\" id=\"${3:input}\" name=\"${3:input}\">\n\t<button type=\"submit\">${6:Submit}</button>\n</form>",
      "description": "Form element",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*<table\\\\s*$",
      "insertText": "<table>\n\t<thead>\n\t\t<tr>\n\t\t\t<th>${1:Header 1}</th>\n\t\t\t<th>${2:Header 2}</th>\n\t\t</tr>\n\t</thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<td>${3:Data 1}</td>\n\t\t\t<td>${4:Data 2}</td>\n\t\t</tr>\n\t</tbody>\n</table>",
      "description": "Table element",
      "completeBracketPairs": true
    },
    {
      "trigger": "for",
      "template": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "description": "For loop"
    },
    {
      "trigger": "if",
      "template": "if (${1:condition}) {\n  ${0}\n}",
      "description": "If statement"
    },
    {
      "trigger": "try",
      "template": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "description": "Try-catch block"
    },
    {
      "trigger": "fn",
      "template": "function ${1:name}(${2:params}) {\n  ${0}\n}",
      "description": "Function declaration"
    },
    {
      "trigger": "log",
      "template": "console.log(${0})",
      "description": "Console log"
    },
    {
      "trigger": "imp",
      "template": "import { ${1:name} } from '${0:module}'",
      "description": "Import statement"
    },
    {
      "trigger": "class",
      "template": "class ${1:Name} {\n  constructor(${2:params}) {\n    ${0}\n  }\n}",
      "description": "Class declaration"
    },
    {
      "trigger": "switch",
      "template": "switch (${1:expr}) {\n  case ${2:val}:\n    ${0}\n    break;\n  default:\n    break;\n}",
      "description": "Switch statement"
    },
    {
      "trigger": "while",
      "template": "while (${1:condition}) {\n  ${0}\n}",
      "description": "While loop"
    },
    {
      "trigger": "map",
      "template": "${1:array}.map((${2:item}) => ${0})",
      "description": "Array map"
    }
  ]
}
