{
  "language": "ignore",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\s*#\\s*$",
      "insertText": "# ${1:Section name}",
      "description": "Comment section header",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "^\\s*\\*\\.$",
      "insertText": "*.${1:ext}",
      "description": "Wildcard extension pattern",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "^\\s*node$",
      "insertText": "node_modules/",
      "description": "Ignore node_modules directory",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "^\\s*\\.env$",
      "insertText": ".env\n.env.local\n.env.*.local",
      "description": "Ignore environment files",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "^\\s*dist$",
      "insertText": "dist/\nbuild/\nout/",
      "description": "Ignore build output directories",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "^\\s*\\*\\*/$",
      "insertText": "**/${1:pattern}",
      "description": "Recursive directory pattern",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "^\\s*!$",
      "insertText": "!${1:pattern}",
      "description": "Re-include a previously ignored pattern",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "for\\\\s+",
      "insertText": "for (let ${1:i} = 0; ${1:i} < ${2:n}; ${1:i}++) {\\n\\t${3:}\\n}",
      "description": "Complete Ignore Files for loop pattern",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "if\\\\s+",
      "insertText": "if (${1:condition}) {\\n\\t${2:}\\n}",
      "description": "Complete Ignore Files if statement",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "function\\\\s+|def\\\\s+|fn\\\\s+|func\\\\s+",
      "insertText": "function ${1:name}(${2:params}) {\\n\\t${3:}\\n}",
      "description": "Complete Ignore Files function declaration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "class\\\\s+",
      "insertText": "class ${1:Name} {\\n\\t${2:}\\n}",
      "description": "Complete Ignore Files class declaration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "try\\\\s*",
      "insertText": "try {\\n\\t${1:}\\n} catch (${2:error}) {\\n\\t${3:}\\n}",
      "description": "Complete Ignore Files try-catch block",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "import\\\\s+",
      "insertText": "import { ${2:name} } from '${1:module}';",
      "description": "Complete Ignore Files import statement",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "switch\\\\s+|match\\\\s+",
      "insertText": "switch (${1:expr}) {\\n\\tcase ${2:val}:\\n\\t\\t${3:break};\\n\\tdefault:\\n\\t\\t${4:break};\\n}",
      "description": "Complete Ignore Files switch/match statement",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "while\\\\s+",
      "insertText": "while (${1:condition}) {\\n\\t${2:}\\n}",
      "description": "Complete Ignore Files while loop",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "return\\\\s+",
      "insertText": "return ${1:value};",
      "description": "Complete Ignore Files return statement",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "console\\\\.|print|log|echo|puts",
      "insertText": "console.log(${1:value});",
      "description": "Complete Ignore Files logging/output",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "//\\\\s+TODO|#\\\\s+TODO",
      "insertText": "// TODO: implement ${1:feature}",
      "description": "TODO comment template",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "async\\\\s+|await\\\\s+",
      "insertText": "async function ${1:name}(${2:params}) {\\n\\tconst ${3:result} = await ${4:promise};\\n\\treturn ${3:result};\\n}",
      "description": "Complete Ignore Files async/await pattern",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "test\\\\s+|describe\\\\s+|it\\\\s+",
      "insertText": "describe('${1:subject}', () => {\\n\\tit('should ${2:behavior}', () => {\\n\\t\\t${3:expect}\\n\\t});\\n});",
      "description": "Complete Ignore Files test template",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "map\\\\(|filter\\\\(|reduce\\\\(",
      "insertText": ".map((${1:item}) => ${2:transform})",
      "description": "Complete Ignore Files collection operation",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "struct\\\\s+|type\\\\s+|interface\\\\s+",
      "insertText": "type ${1:Name} = {\\n\\t${2:property}: ${3:type};\\n};",
      "description": "Complete Ignore Files type definition",
      "completeBracketPairs": true
    }
  ]
}
