{
  "language": "apex",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*public class\\\\s*$",
      "insertText": "public class ${1:ClassName} {\n\t${2:// class body}\n}",
      "description": "Public class",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*public void\\\\s*$",
      "insertText": "public void ${1:methodName}(${2:}) {\n\t${3:// method body}\n}",
      "description": "Public void method",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*for\\\\s*$",
      "insertText": "for (${1:Integer} ${2:i} = 0; ${2:i} < ${3:size}; ${2:i}++) {\n\t${4:// loop body}\n}",
      "description": "For loop",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*try\\\\s*$",
      "insertText": "try {\n\t${1:// try body}\n} catch (${2:Exception} ${3:e}) {\n\tSystem.debug(${3:e}.getMessage());\n}",
      "description": "Try/catch block",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*if\\\\s*$",
      "insertText": "if (${1:condition}) {\n\t${2:// true branch}\n} else {\n\t${3:// false branch}\n}",
      "description": "If/else conditional",
      "completeBracketPairs": true
    },
    {
      "trigger": "for",
      "template": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "description": "For loop"
    },
    {
      "trigger": "if",
      "template": "if (${1:condition}) {\n  ${0}\n}",
      "description": "If statement"
    },
    {
      "trigger": "try",
      "template": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "description": "Try-catch block"
    },
    {
      "trigger": "fn",
      "template": "function ${1:name}(${2:params}) {\n  ${0}\n}",
      "description": "Function declaration"
    },
    {
      "trigger": "log",
      "template": "console.log(${0})",
      "description": "Console log"
    },
    {
      "trigger": "imp",
      "template": "import { ${1:name} } from '${0:module}'",
      "description": "Import statement"
    },
    {
      "trigger": "class",
      "template": "class ${1:Name} {\n  constructor(${2:params}) {\n    ${0}\n  }\n}",
      "description": "Class declaration"
    },
    {
      "trigger": "switch",
      "template": "switch (${1:expr}) {\n  case ${2:val}:\n    ${0}\n    break;\n  default:\n    break;\n}",
      "description": "Switch statement"
    },
    {
      "trigger": "while",
      "template": "while (${1:condition}) {\n  ${0}\n}",
      "description": "While loop"
    },
    {
      "trigger": "map",
      "template": "${1:array}.map((${2:item}) => ${0})",
      "description": "Array map"
    }
  ]
}
