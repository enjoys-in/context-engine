{
  "language": "abap",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*FORM\\\\s*$",
      "insertText": "FORM ${1:form_name}.\n\t${2:* processing logic}\nENDFORM.",
      "description": "FORM subroutine",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*METHOD\\\\s*$",
      "insertText": "METHOD ${1:method_name}.\n\t${2:* method logic}\nENDMETHOD.",
      "description": "METHOD definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*SELECT\\\\s*$",
      "insertText": "SELECT ${1:*}\n\tFROM ${2:table_name}\n\tINTO TABLE @DATA(${3:lt_result})\n\tWHERE ${4:condition}.",
      "description": "SELECT query",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*LOOP\\\\s*$",
      "insertText": "LOOP AT ${1:lt_table} INTO DATA(${2:ls_row}).\n\t${3:* loop body}\nENDLOOP.",
      "description": "LOOP AT internal table",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*IF\\\\s*$",
      "insertText": "IF ${1:condition}.\n\t${2:* true branch}\nELSE.\n\t${3:* false branch}\nENDIF.",
      "description": "IF/ELSE conditional",
      "completeBracketPairs": true
    },
    {
      "trigger": "for",
      "template": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "description": "For loop"
    },
    {
      "trigger": "if",
      "template": "if (${1:condition}) {\n  ${0}\n}",
      "description": "If statement"
    },
    {
      "trigger": "try",
      "template": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "description": "Try-catch block"
    },
    {
      "trigger": "fn",
      "template": "function ${1:name}(${2:params}) {\n  ${0}\n}",
      "description": "Function declaration"
    },
    {
      "trigger": "log",
      "template": "console.log(${0})",
      "description": "Console log"
    },
    {
      "trigger": "imp",
      "template": "import { ${1:name} } from '${0:module}'",
      "description": "Import statement"
    },
    {
      "trigger": "class",
      "template": "class ${1:Name} {\n  constructor(${2:params}) {\n    ${0}\n  }\n}",
      "description": "Class declaration"
    },
    {
      "trigger": "switch",
      "template": "switch (${1:expr}) {\n  case ${2:val}:\n    ${0}\n    break;\n  default:\n    break;\n}",
      "description": "Switch statement"
    },
    {
      "trigger": "while",
      "template": "while (${1:condition}) {\n  ${0}\n}",
      "description": "While loop"
    },
    {
      "trigger": "map",
      "template": "${1:array}.map((${2:item}) => ${0})",
      "description": "Array map"
    }
  ]
}
