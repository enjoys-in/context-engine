{
  "language": "abap",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*FORM\\\\s*$",
      "insertText": "FORM ${1:form_name}.\n\t${2:* processing logic}\nENDFORM.",
      "description": "FORM subroutine",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*METHOD\\\\s*$",
      "insertText": "METHOD ${1:method_name}.\n\t${2:* method logic}\nENDMETHOD.",
      "description": "METHOD definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*SELECT\\\\s*$",
      "insertText": "SELECT ${1:*}\n\tFROM ${2:table_name}\n\tINTO TABLE @DATA(${3:lt_result})\n\tWHERE ${4:condition}.",
      "description": "SELECT query",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*LOOP\\\\s*$",
      "insertText": "LOOP AT ${1:lt_table} INTO DATA(${2:ls_row}).\n\t${3:* loop body}\nENDLOOP.",
      "description": "LOOP AT internal table",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*IF\\\\s*$",
      "insertText": "IF ${1:condition}.\n\t${2:* true branch}\nELSE.\n\t${3:* false branch}\nENDIF.",
      "description": "IF/ELSE conditional",
      "completeBracketPairs": true
    }
  ]
}
