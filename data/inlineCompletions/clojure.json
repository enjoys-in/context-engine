{
  "language": "clojure",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*\\(defn\\\\s*$",
      "insertText": "(defn ${1:name}\n  [${2:args}]\n  ${3:body})",
      "description": "Function definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*\\(let\\\\s*$",
      "insertText": "(let [${1:binding} ${2:value}]\n  ${3:body})",
      "description": "Let binding",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*\\(if\\\\s*$",
      "insertText": "(if ${1:condition}\n  ${2:then-expr}\n  ${3:else-expr})",
      "description": "If conditional",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*\\(fn\\\\s*$",
      "insertText": "(fn [${1:args}]\n  ${2:body})",
      "description": "Anonymous function",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*\\(loop\\\\s*$",
      "insertText": "(loop [${1:i} ${2:0}]\n  (when (< ${1:i} ${3:10})\n    ${4:body}\n    (recur (inc ${1:i}))))",
      "description": "Loop/recur",
      "completeBracketPairs": true
    }
  ]
}