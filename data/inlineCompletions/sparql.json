{
  "language": "sparql",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*SELECT\\\\s*$",
      "insertText": "SELECT ${1:?subject} ${2:?predicate} ${3:?object}\nWHERE {\n\t${4:?subject} ${5:?predicate} ${6:?object} .\n}\nLIMIT ${7:100}",
      "description": "SELECT query",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*PREFIX\\\\s*$",
      "insertText": "PREFIX ${1:prefix}: <${2:http://example.org/}>",
      "description": "PREFIX declaration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*WHERE\\\\s*$",
      "insertText": "WHERE {\n\t${1:?subject} ${2:?predicate} ${3:?object} .\n}",
      "description": "WHERE clause",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*OPTIONAL\\\\s*$",
      "insertText": "OPTIONAL {\n\t${1:?subject} ${2:?predicate} ${3:?object} .\n}",
      "description": "OPTIONAL pattern",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*FILTER\\\\s*$",
      "insertText": "FILTER (${1:?variable} ${2:=} ${3:value})",
      "description": "FILTER expression",
      "completeBracketPairs": true
    },
    {
      "trigger": "for",
      "template": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "description": "For loop"
    },
    {
      "trigger": "if",
      "template": "if (${1:condition}) {\n  ${0}\n}",
      "description": "If statement"
    },
    {
      "trigger": "try",
      "template": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "description": "Try-catch block"
    },
    {
      "trigger": "fn",
      "template": "function ${1:name}(${2:params}) {\n  ${0}\n}",
      "description": "Function declaration"
    },
    {
      "trigger": "log",
      "template": "console.log(${0})",
      "description": "Console log"
    },
    {
      "trigger": "imp",
      "template": "import { ${1:name} } from '${0:module}'",
      "description": "Import statement"
    },
    {
      "trigger": "class",
      "template": "class ${1:Name} {\n  constructor(${2:params}) {\n    ${0}\n  }\n}",
      "description": "Class declaration"
    },
    {
      "trigger": "switch",
      "template": "switch (${1:expr}) {\n  case ${2:val}:\n    ${0}\n    break;\n  default:\n    break;\n}",
      "description": "Switch statement"
    },
    {
      "trigger": "while",
      "template": "while (${1:condition}) {\n  ${0}\n}",
      "description": "While loop"
    },
    {
      "trigger": "map",
      "template": "${1:array}.map((${2:item}) => ${0})",
      "description": "Array map"
    }
  ]
}
