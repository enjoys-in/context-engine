{
  "language": "postiats",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*fun\\\\s*$",
      "insertText": "fun ${1:name}(${2:arg}: ${3:int}): ${4:int} = ${5:arg}",
      "description": "Function definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*val\\\\s*$",
      "insertText": "val ${1:name} = ${2:expression}",
      "description": "Value binding",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*implement\\\\s*$",
      "insertText": "implement\n${1:name}(${2:args}) = ${3:expression}",
      "description": "Implement declaration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*datatype\\\\s*$",
      "insertText": "datatype ${1:name} =\n  | ${2:Constructor1} of ${3:int}\n  | ${4:Constructor2} of ${5:string}",
      "description": "Datatype definition",
      "completeBracketPairs": true
    }
  ]
}