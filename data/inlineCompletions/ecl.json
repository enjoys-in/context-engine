{
  "language": "ecl",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*RECORD\\\\s*$",
      "insertText": "${1:RecordName} := RECORD\n\t${2:STRING} ${3:field1};\n\t${4:INTEGER} ${5:field2};\nEND;",
      "description": "RECORD definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*DATASET\\\\s*$",
      "insertText": "${1:ds} := DATASET('${2:~file::scope::name}', ${3:RecordLayout}, ${4:THOR});",
      "description": "DATASET declaration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*OUTPUT\\\\s*$",
      "insertText": "OUTPUT(${1:dataset}, NAMED('${2:ResultName}'));",
      "description": "OUTPUT result",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*TRANSFORM\\\\s*$",
      "insertText": "${1:OutRec} ${2:xform}(${3:InRec} ${4:L}) := TRANSFORM\n\tSELF.${5:field} := ${4:L}.${6:field};\n\tSELF := ${4:L};\nEND;",
      "description": "TRANSFORM function",
      "completeBracketPairs": true
    }
  ]
}