{
  "language": "msdax",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*EVALUATE\\\\s*$",
      "insertText": "EVALUATE\n\tSUMMARIZECOLUMNS(\n\t\t${1:Table}[${2:Column}],\n\t\t\"${3:Measure}\", ${4:[Measure]}\n\t)",
      "description": "Evaluate query",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*DEFINE\\\\s*MEASURE\\\\s*$",
      "insertText": "DEFINE MEASURE ${1:Table}[${2:MeasureName}] =\n\tCALCULATE(\n\t\t${3:SUM}(${4:Table}[${5:Column}]),\n\t\t${6:filter}\n\t)",
      "description": "Define measure",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*CALCULATE\\\\s*$",
      "insertText": "CALCULATE(\n\t${1:expression},\n\t${2:Table}[${3:Column}] = \"${4:Value}\"\n)",
      "description": "Calculate with filter",
      "completeBracketPairs": true
    }
  ]
}