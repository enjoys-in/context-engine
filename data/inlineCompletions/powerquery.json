{
  "language": "powerquery",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*let\\\\s*$",
      "insertText": "let\n\t${1:Source} = ${2:expression},\n\t${3:Result} = ${4:transformation}\nin\n\t${3:Result}",
      "description": "Let expression",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*each\\\\s*$",
      "insertText": "each ${1:[${2:ColumnName}]}",
      "description": "Each row accessor",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*Table\\.FromRecords\\\\s*$",
      "insertText": "Table.FromRecords({\n\t[${1:Column1} = ${2:value1}, ${3:Column2} = ${4:value2}]\n})",
      "description": "Table from records",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*List\\.Transform\\\\s*$",
      "insertText": "List.Transform(${1:list}, each _ ${2:+ 1})",
      "description": "List transform",
      "completeBracketPairs": true
    },
    {
      "trigger": "for",
      "template": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "description": "For loop",
      "triggerPattern": "for",
      "insertText": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "if",
      "template": "if (${1:condition}) {\n  ${0}\n}",
      "description": "If statement",
      "triggerPattern": "if",
      "insertText": "if (${1:condition}) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "try",
      "template": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "description": "Try-catch block",
      "triggerPattern": "try",
      "insertText": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "fn",
      "template": "function ${1:name}(${2:params}) {\n  ${0}\n}",
      "description": "Function declaration",
      "triggerPattern": "fn",
      "insertText": "function ${1:name}(${2:params}) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "log",
      "template": "console.log(${0})",
      "description": "Console log",
      "triggerPattern": "log",
      "insertText": "console.log(${0})",
      "completeBracketPairs": true
    },
    {
      "trigger": "imp",
      "template": "import { ${1:name} } from '${0:module}'",
      "description": "Import statement",
      "triggerPattern": "imp",
      "insertText": "import { ${1:name} } from '${0:module}'",
      "completeBracketPairs": true
    },
    {
      "trigger": "class",
      "template": "class ${1:Name} {\n  constructor(${2:params}) {\n    ${0}\n  }\n}",
      "description": "Class declaration",
      "triggerPattern": "class",
      "insertText": "class ${1:Name} {\n  constructor(${2:params}) {\n    ${0}\n  }\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "switch",
      "template": "switch (${1:expr}) {\n  case ${2:val}:\n    ${0}\n    break;\n  default:\n    break;\n}",
      "description": "Switch statement",
      "triggerPattern": "switch",
      "insertText": "switch (${1:expr}) {\n  case ${2:val}:\n    ${0}\n    break;\n  default:\n    break;\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "while",
      "template": "while (${1:condition}) {\n  ${0}\n}",
      "description": "While loop",
      "triggerPattern": "while",
      "insertText": "while (${1:condition}) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "map",
      "template": "${1:array}.map((${2:item}) => ${0})",
      "description": "Array map",
      "triggerPattern": "map",
      "insertText": "${1:array}.map((${2:item}) => ${0})",
      "completeBracketPairs": true
    },
    {
      "trigger": "filter",
      "template": "${1:array}.filter((${2:item}) => ${0})",
      "description": "Array filter",
      "triggerPattern": "filter",
      "insertText": "${1:array}.filter((${2:item}) => ${0})",
      "completeBracketPairs": true
    }
  ]
}
