{
  "language": "sol",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*contract\\\\s*$",
      "insertText": "contract ${1:MyContract} {\n\t${2:// state variables and functions}\n}",
      "description": "Contract definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*function\\\\s*$",
      "insertText": "function ${1:name}(${2:params}) ${3:public} ${4:returns (${5:uint256})} {\n\t${6:// body}\n}",
      "description": "Function definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*mapping\\\\s*$",
      "insertText": "mapping(${1:address} => ${2:uint256}) ${3:public} ${4:balances};",
      "description": "Mapping declaration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*modifier\\\\s*$",
      "insertText": "modifier ${1:onlyOwner}() {\n\trequire(${2:msg.sender == owner}, \"${3:Not authorized}\");\n\t_;\n}",
      "description": "Modifier definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*event\\\\s*$",
      "insertText": "event ${1:Transfer}(${2:address indexed from}, ${3:address indexed to}, ${4:uint256 value});",
      "description": "Event declaration",
      "completeBracketPairs": true
    },
    {
      "trigger": "for",
      "template": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "description": "For loop"
    },
    {
      "trigger": "if",
      "template": "if (${1:condition}) {\n  ${0}\n}",
      "description": "If statement"
    },
    {
      "trigger": "try",
      "template": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "description": "Try-catch block"
    },
    {
      "trigger": "fn",
      "template": "function ${1:name}(${2:params}) {\n  ${0}\n}",
      "description": "Function declaration"
    },
    {
      "trigger": "log",
      "template": "console.log(${0})",
      "description": "Console log"
    },
    {
      "trigger": "imp",
      "template": "import { ${1:name} } from '${0:module}'",
      "description": "Import statement"
    },
    {
      "trigger": "class",
      "template": "class ${1:Name} {\n  constructor(${2:params}) {\n    ${0}\n  }\n}",
      "description": "Class declaration"
    },
    {
      "trigger": "switch",
      "template": "switch (${1:expr}) {\n  case ${2:val}:\n    ${0}\n    break;\n  default:\n    break;\n}",
      "description": "Switch statement"
    },
    {
      "trigger": "while",
      "template": "while (${1:condition}) {\n  ${0}\n}",
      "description": "While loop"
    },
    {
      "trigger": "map",
      "template": "${1:array}.map((${2:item}) => ${0})",
      "description": "Array map"
    }
  ]
}
