{
  "language": "ssh_config",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*Host\\\\s*$",
      "insertText": "Host ${1:alias}\n\tHostName ${2:example.com}\n\tUser ${3:user}\n\tIdentityFile ${4:~/.ssh/id_rsa}",
      "description": "Host entry",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*IdentityFile\\\\s*$",
      "insertText": "IdentityFile ${1:~/.ssh/id_ed25519}",
      "description": "IdentityFile path",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*ProxyJump\\\\s*$",
      "insertText": "ProxyJump ${1:bastion-host}",
      "description": "ProxyJump through bastion",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*LocalForward\\\\s*$",
      "insertText": "LocalForward ${1:8080} ${2:localhost}:${3:80}",
      "description": "Local port forwarding",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*Match\\\\s*$",
      "insertText": "Match Host ${1:*.example.com}\n\t${2:User} ${3:deploy}",
      "description": "Match conditional block",
      "completeBracketPairs": true
    },
    {
      "trigger": "for",
      "template": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "description": "For loop"
    },
    {
      "trigger": "if",
      "template": "if (${1:condition}) {\n  ${0}\n}",
      "description": "If statement"
    },
    {
      "trigger": "try",
      "template": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "description": "Try-catch block"
    },
    {
      "trigger": "fn",
      "template": "function ${1:name}(${2:params}) {\n  ${0}\n}",
      "description": "Function declaration"
    },
    {
      "trigger": "log",
      "template": "console.log(${0})",
      "description": "Console log"
    },
    {
      "trigger": "imp",
      "template": "import { ${1:name} } from '${0:module}'",
      "description": "Import statement"
    },
    {
      "trigger": "class",
      "template": "class ${1:Name} {\n  constructor(${2:params}) {\n    ${0}\n  }\n}",
      "description": "Class declaration"
    },
    {
      "trigger": "switch",
      "template": "switch (${1:expr}) {\n  case ${2:val}:\n    ${0}\n    break;\n  default:\n    break;\n}",
      "description": "Switch statement"
    },
    {
      "trigger": "while",
      "template": "while (${1:condition}) {\n  ${0}\n}",
      "description": "While loop"
    },
    {
      "trigger": "map",
      "template": "${1:array}.map((${2:item}) => ${0})",
      "description": "Array map"
    }
  ]
}
