{
  "language": "pascal",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*program\\\\s*$",
      "insertText": "program ${1:Name};\n\nbegin\n\t${2:writeln('Hello, World!');}\nend.",
      "description": "Program skeleton",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*procedure\\\\s*$",
      "insertText": "procedure ${1:Name}(${2:param}: ${3:Integer});\nbegin\n\t${4:{ body }}\nend;",
      "description": "Procedure definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*function\\\\s*$",
      "insertText": "function ${1:Name}(${2:param}: ${3:Integer}): ${4:Integer};\nbegin\n\t${5:Result := ${2:param};}\nend;",
      "description": "Function definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*begin\\\\s*$",
      "insertText": "begin\n\t${1:{ body }}\nend;",
      "description": "Begin-end block",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*for\\\\s*$",
      "insertText": "for ${1:i} := ${2:0} to ${3:10} do\nbegin\n\t${4:{ body }}\nend;",
      "description": "For..to..do loop",
      "completeBracketPairs": true
    }
  ]
}