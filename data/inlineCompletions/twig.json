{
  "language": "twig",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*\\{%\\\\s+block\\\\s*$",
      "insertText": "{% block ${1:name} %}\n\t${2:content}\n{% endblock %}",
      "description": "Block definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*\\{%\\\\s+if\\\\s*$",
      "insertText": "{% if ${1:condition} %}\n\t${2:content}\n{% else %}\n\t${3:fallback}\n{% endif %}",
      "description": "If conditional",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*\\{%\\\\s+for\\\\s*$",
      "insertText": "{% for ${1:item} in ${2:items} %}\n\t{{ ${1:item}.${3:name} }}\n{% endfor %}",
      "description": "For loop",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*\\{\\{\\\\s*$",
      "insertText": "{{ ${1:variable}|${2:escape} }}",
      "description": "Variable output with filter",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*\\{%\\\\s+extends\\\\s*$",
      "insertText": "{% extends '${1:base.html.twig}' %}",
      "description": "Template inheritance",
      "completeBracketPairs": true
    }
  ]
}