{
  "language": "php",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*foreach\\\\s*$",
      "insertText": "foreach (${1:\\$array} as ${2:\\$key} => ${3:\\$value}) {\n\t$0\n}",
      "description": "Foreach loop",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*function\\\\s*$",
      "insertText": "function ${1:name}(${2:params}): ${3:void} {\n\t$0\n}",
      "description": "Function",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "function\\s+$",
      "insertText": "${1:name}(${2:params}): ${3:void} {\n\t${4}\n}",
      "description": "function declaration",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "class\\s+$",
      "insertText": "${1:ClassName} {\n\tpublic function __construct(${2:params}) {\n\t\t${3}\n\t}\n}",
      "description": "class declaration",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "foreach\\s*\\($",
      "insertText": "${1:\\$array} as ${2:\\$key} => ${3:\\$value}) {\n\t${4}\n}",
      "description": "foreach loop",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "if\\s*\\($",
      "insertText": "${1:condition}",
      "description": "if condition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "try\\s*\\{$",
      "insertText": "\n\t${1}\n} catch (\\Exception ${2:\\$e}) {\n\t${3}\n}",
      "description": "try-catch",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "echo\\s+$",
      "insertText": "\"${1:text}\"",
      "description": "echo statement",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "\\$this->$",
      "insertText": "${1:property}",
      "description": "this property",
      "completeBracketPairs": false
    },
    {
      "trigger": "for",
      "template": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "description": "For loop",
      "triggerPattern": "for",
      "insertText": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "if",
      "template": "if (${1:condition}) {\n  ${0}\n}",
      "description": "If statement",
      "triggerPattern": "if",
      "insertText": "if (${1:condition}) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "try",
      "template": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "description": "Try-catch block",
      "triggerPattern": "try",
      "insertText": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "fn",
      "template": "function ${1:name}(${2:params}) {\n  ${0}\n}",
      "description": "Function declaration",
      "triggerPattern": "fn",
      "insertText": "function ${1:name}(${2:params}) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "log",
      "template": "console.log(${0})",
      "description": "Console log",
      "triggerPattern": "log",
      "insertText": "console.log(${0})",
      "completeBracketPairs": true
    },
    {
      "trigger": "imp",
      "template": "import { ${1:name} } from '${0:module}'",
      "description": "Import statement",
      "triggerPattern": "imp",
      "insertText": "import { ${1:name} } from '${0:module}'",
      "completeBracketPairs": true
    }
  ]
}
