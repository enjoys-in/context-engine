{
  "language": "objective-c",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*@interface\\\\s*$",
      "insertText": "@interface ${1:ClassName} : ${2:NSObject}\n\n@property (nonatomic, ${3:strong}) ${4:NSString} *${5:name};\n\n- (void)${6:methodName};\n\n@end",
      "description": "Interface declaration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*@implementation\\\\s*$",
      "insertText": "@implementation ${1:ClassName}\n\n- (void)${2:methodName} {\n\t${3:// implementation}\n}\n\n@end",
      "description": "Implementation block",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*-\\\\s*\\(void\\)\\\\s*$",
      "insertText": "- (void)${1:methodName}:(${2:NSString} *)${3:param} {\n\t${4:// body}\n}",
      "description": "Instance method",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*@property\\\\s*$",
      "insertText": "@property (nonatomic, ${1:strong}) ${2:NSString} *${3:propertyName};",
      "description": "Property declaration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*\\[\\\\s*$",
      "insertText": "[${1:object} ${2:message}:${3:argument}]",
      "description": "Message send expression",
      "completeBracketPairs": true
    },
    {
      "trigger": "for",
      "template": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "description": "For loop"
    },
    {
      "trigger": "if",
      "template": "if (${1:condition}) {\n  ${0}\n}",
      "description": "If statement"
    },
    {
      "trigger": "try",
      "template": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "description": "Try-catch block"
    },
    {
      "trigger": "fn",
      "template": "function ${1:name}(${2:params}) {\n  ${0}\n}",
      "description": "Function declaration"
    },
    {
      "trigger": "log",
      "template": "console.log(${0})",
      "description": "Console log"
    },
    {
      "trigger": "imp",
      "template": "import { ${1:name} } from '${0:module}'",
      "description": "Import statement"
    },
    {
      "trigger": "class",
      "template": "class ${1:Name} {\n  constructor(${2:params}) {\n    ${0}\n  }\n}",
      "description": "Class declaration"
    },
    {
      "trigger": "switch",
      "template": "switch (${1:expr}) {\n  case ${2:val}:\n    ${0}\n    break;\n  default:\n    break;\n}",
      "description": "Switch statement"
    },
    {
      "trigger": "while",
      "template": "while (${1:condition}) {\n  ${0}\n}",
      "description": "While loop"
    },
    {
      "trigger": "map",
      "template": "${1:array}.map((${2:item}) => ${0})",
      "description": "Array map"
    }
  ]
}
