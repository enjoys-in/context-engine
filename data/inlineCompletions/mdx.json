{
  "language": "mdx",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*import\\\\s*$",
      "insertText": "import ${1:Component} from '${2:./components/${1:Component}}'",
      "description": "Import component",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*export\\\\s*default\\\\s*$",
      "insertText": "export default ({ ${1:children} }) => (\n\t<${2:Layout}>\n\t\t{${1:children}}\n\t</${2:Layout}>\n)",
      "description": "Export default layout",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*<Component\\\\s*$",
      "insertText": "<${1:Component} ${2:prop}={${3:value}} />",
      "description": "JSX component usage",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*---\\\\s*$",
      "insertText": "---\ntitle: ${1:Title}\ndescription: ${2:Description}\n---",
      "description": "Frontmatter block",
      "completeBracketPairs": true
    }
  ]
}