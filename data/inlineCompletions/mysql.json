{
  "language": "mysql",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*SELECT\\\\s*$",
      "insertText": "SELECT ${1:columns}\nFROM ${2:table}\nWHERE ${3:condition};",
      "description": "Select query with where",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*INSERT\\\\s*INTO\\\\s*$",
      "insertText": "INSERT INTO ${1:table} (${2:columns})\nVALUES (${3:values});",
      "description": "Insert into table",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*CREATE\\\\s*TABLE\\\\s*$",
      "insertText": "CREATE TABLE ${1:table_name} (\n\t${2:id} INT AUTO_INCREMENT PRIMARY KEY,\n\t${3:column} ${4:VARCHAR(255)} ${5:NOT NULL}\n) ENGINE=InnoDB;",
      "description": "Create table",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*JOIN\\\\s*$",
      "insertText": "JOIN ${1:table} ON ${2:table1}.${3:id} = ${1:table}.${4:foreign_id}",
      "description": "Join clause",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*ALTER\\\\s*TABLE\\\\s*$",
      "insertText": "ALTER TABLE ${1:table}\nADD COLUMN ${2:column} ${3:VARCHAR(255)} ${4:NOT NULL};",
      "description": "Alter table add column",
      "completeBracketPairs": true
    }
  ]
}