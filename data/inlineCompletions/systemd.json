{
  "language": "systemd",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*\\[Unit\\]\\\\s*$",
      "insertText": "[Unit]\nDescription=${1:My Service}\nAfter=${2:network.target}\nWants=${3:network-online.target}",
      "description": "[Unit] section",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*\\[Service\\]\\\\s*$",
      "insertText": "[Service]\nType=${1:simple}\nUser=${2:www-data}\nExecStart=${3:/usr/bin/myapp}\nRestart=${4:on-failure}\nRestartSec=${5:5}",
      "description": "[Service] section",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*\\[Install\\]\\\\s*$",
      "insertText": "[Install]\nWantedBy=${1:multi-user.target}",
      "description": "[Install] section",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*\\[Timer\\]\\\\s*$",
      "insertText": "[Timer]\nOnCalendar=${1:*-*-* 00:00:00}\nPersistent=${2:true}\nUnit=${3:mytask.service}",
      "description": "[Timer] section",
      "completeBracketPairs": true
    }
  ]
}
