{
  "language": "cypher",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*MATCH\\\\s*$",
      "insertText": "MATCH (${1:n}:${2:Label})\nWHERE ${1:n}.${3:property} = '${4:value}'\nRETURN ${1:n}",
      "description": "MATCH node query",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*CREATE\\\\s*$",
      "insertText": "CREATE (${1:n}:${2:Label} {${3:name}: '${4:value}'})\nRETURN ${1:n}",
      "description": "CREATE node",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*MERGE\\\\s*$",
      "insertText": "MERGE (${1:n}:${2:Label} {${3:key}: '${4:value}'})\nON CREATE SET ${1:n}.${5:created} = timestamp()\nON MATCH SET ${1:n}.${6:updated} = timestamp()\nRETURN ${1:n}",
      "description": "MERGE with ON CREATE/MATCH",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*RETURN\\\\s*$",
      "insertText": "RETURN ${1:n}.${2:property} AS ${3:alias}",
      "description": "RETURN with alias",
      "completeBracketPairs": true
    }
  ]
}