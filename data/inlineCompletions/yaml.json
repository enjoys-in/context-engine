{
  "language": "yaml",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*-\\\\s*$",
      "insertText": "- ${1:item}",
      "description": "List item",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*name:\\\\s*$",
      "insertText": "name: ${1:value}\ndescription: ${2:description}\nversion: ${3:1.0.0}",
      "description": "Common metadata block",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*env:\\\\s*$",
      "insertText": "env:\n  - name: ${1:VAR_NAME}\n    value: ${2:value}",
      "description": "Environment variable list",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*\\|\\\\s*$",
      "insertText": "|\n  ${1:multiline}\n  ${2:string content}",
      "description": "Multiline literal block scalar",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*---\\\\s*$",
      "insertText": "---\n${1:key}: ${2:value}",
      "description": "Document start marker",
      "completeBracketPairs": true
    }
  ]
}
