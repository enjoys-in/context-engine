{
  "language": "restructuredtext",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*\\.\\.\\\\s+directive\\\\s*$",
      "insertText": ".. ${1:directive}::\n\n\t${2:content}",
      "description": "reStructuredText directive",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*\\.\\.\\\\s+code-block\\\\s*$",
      "insertText": ".. code-block:: ${1:python}\n\n\t${2:code}",
      "description": "Code block directive",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*\\.\\.\\\\s+image\\\\s*$",
      "insertText": ".. image:: ${1:path/to/image.png}\n\t:alt: ${2:Alt text}\n\t:width: ${3:400px}",
      "description": "Image directive",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*\\.\\.\\\\s+toctree\\\\s*$",
      "insertText": ".. toctree::\n\t:maxdepth: ${1:2}\n\t:caption: ${2:Contents}\n\n\t${3:document}",
      "description": "Table of contents tree",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*\\.\\.\\\\s+note\\\\s*$",
      "insertText": ".. note::\n\n\t${1:Note text here.}",
      "description": "Note admonition",
      "completeBracketPairs": true
    },
    {
      "trigger": "for",
      "template": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "description": "For loop"
    },
    {
      "trigger": "if",
      "template": "if (${1:condition}) {\n  ${0}\n}",
      "description": "If statement"
    },
    {
      "trigger": "try",
      "template": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "description": "Try-catch block"
    },
    {
      "trigger": "fn",
      "template": "function ${1:name}(${2:params}) {\n  ${0}\n}",
      "description": "Function declaration"
    },
    {
      "trigger": "log",
      "template": "console.log(${0})",
      "description": "Console log"
    },
    {
      "trigger": "imp",
      "template": "import { ${1:name} } from '${0:module}'",
      "description": "Import statement"
    },
    {
      "trigger": "class",
      "template": "class ${1:Name} {\n  constructor(${2:params}) {\n    ${0}\n  }\n}",
      "description": "Class declaration"
    },
    {
      "trigger": "switch",
      "template": "switch (${1:expr}) {\n  case ${2:val}:\n    ${0}\n    break;\n  default:\n    break;\n}",
      "description": "Switch statement"
    },
    {
      "trigger": "while",
      "template": "while (${1:condition}) {\n  ${0}\n}",
      "description": "While loop"
    },
    {
      "trigger": "map",
      "template": "${1:array}.map((${2:item}) => ${0})",
      "description": "Array map"
    }
  ]
}
