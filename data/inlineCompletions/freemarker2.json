{
  "language": "freemarker2",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*<#if\\\\s*$",
      "insertText": "<#if ${1:condition}>\n\t${2:content}\n<#else>\n\t${3:alternative}\n</#if>",
      "description": "If/else directive",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*<#list\\\\s*$",
      "insertText": "<#list ${1:items} as ${2:item}>\n\t${3:item}\n</#list>",
      "description": "List iteration directive",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*<#assign\\\\s*$",
      "insertText": "<#assign ${1:varName} = ${2:value}>",
      "description": "Variable assignment",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*<#macro\\\\s*$",
      "insertText": "<#macro ${1:macroName} ${2:param1}>\n\t${3:content}\n</#macro>",
      "description": "Macro definition",
      "completeBracketPairs": true
    }
  ]
}