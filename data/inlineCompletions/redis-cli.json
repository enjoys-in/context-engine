{
  "language": "redis-cli",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*SET\\\\s*$",
      "insertText": "SET ${1:key} ${2:value} EX ${3:seconds}",
      "description": "SET key with expiration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*GET\\\\s*$",
      "insertText": "GET ${1:key}",
      "description": "GET value by key",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*HSET\\\\s*$",
      "insertText": "HSET ${1:hash} ${2:field} ${3:value}",
      "description": "HSET hash field value",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*LPUSH\\\\s*$",
      "insertText": "LPUSH ${1:key} ${2:value}",
      "description": "LPUSH element to list",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*SUBSCRIBE\\\\s*$",
      "insertText": "SUBSCRIBE ${1:channel}",
      "description": "SUBSCRIBE to a channel",
      "completeBracketPairs": true
    }
  ]
}
