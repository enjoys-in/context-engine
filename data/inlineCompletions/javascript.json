{
  "language": "javascript",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*for\\\\s*$",
      "insertText": "for (let ${1:i} = 0; ${1:i} < ${2:array}.length; ${1:i}++) {\n\t$0\n}",
      "description": "For loop",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*const.*=>$",
      "insertText": "const ${1:name} = (${2:params}) => {\n\t$0\n};",
      "description": "Arrow function",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*rfc\\\\s*$",
      "insertText": "function ${1:Component}() {\n\treturn (\n\t\t<div className=\"${2}\">${3}</div>\n\t);\n}\n\nexport default ${1:Component};",
      "description": "React function component (JSX)",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*useState\\\\s*$",
      "insertText": "const [${1:state}, set${2:State}] = useState(${3:initial});",
      "description": "React useState hook",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "for\\s*\\($",
      "insertText": "int ${1:i} = 0; ${1:i} < ${2:n}; ${1:i}++",
      "description": "for loop with counter",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "if\\s*\\($",
      "insertText": "${1:condition}",
      "description": "if condition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "while\\s*\\($",
      "insertText": "${1:condition}",
      "description": "while condition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "switch\\s*\\($",
      "insertText": "${1:variable}) {\n\tcase ${2:value}:\n\t\t${3:// code}\n\t\tbreak;\n\tdefault:\n\t\tbreak;\n}",
      "description": "switch statement",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "try\\s*\\{$",
      "insertText": "\n\t${1:// code}\n} catch (${2:e}) {\n\t${3:// handle}\n}",
      "description": "try-catch block",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "\\bconsole\\.$",
      "insertText": "log(${1:value})",
      "description": "console.log",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "//\\s*TODO$",
      "insertText": ": ${1:description}",
      "description": "TODO comment",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "\\bconst\\s+(\\w+)\\s*=\\s*async\\s*\\($",
      "insertText": "${1:params}) => {\n\t${2:// code}\n}",
      "description": "async arrow function",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "\\bconst\\s+(\\w+)\\s*=\\s*\\($",
      "insertText": "${1:params}) => {\n\t${2:// code}\n}",
      "description": "arrow function",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "\\bimport\\s*\\{$",
      "insertText": " ${1:name} } from '${2:module}'",
      "description": "import statement",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "\\.map\\($",
      "insertText": "(${1:item}) => ${2:item}",
      "description": "map callback",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "\\.filter\\($",
      "insertText": "(${1:item}) => ${2:condition}",
      "description": "filter callback",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "\\.reduce\\($",
      "insertText": "(${1:acc}, ${2:item}) => ${3:acc}, ${4:initialValue}",
      "description": "reduce callback",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "\\.forEach\\($",
      "insertText": "(${1:item}) => {\n\t${2:// code}\n}",
      "description": "forEach callback",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "new Promise\\($",
      "insertText": "(resolve, reject) => {\n\t${1:// code}\n}",
      "description": "Promise constructor",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "\\bawait\\s+fetch\\($",
      "insertText": "'${1:url}', {\n\tmethod: '${2:GET}',\n\theaders: { 'Content-Type': 'application/json' }\n}",
      "description": "fetch with options",
      "completeBracketPairs": true
    }
  ]
}