{
  "language": "ruby",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*def\\\\s*$",
      "insertText": "def ${1:name}\n\t$0\nend",
      "description": "Method",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*class\\\\s*$",
      "insertText": "class ${1:Name}\n\tdef initialize${2:}\n\t\t$0\n\tend\nend",
      "description": "Class",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "def\\s+$",
      "insertText": "${1:method_name}(${2:params})\n\t${3}\nend",
      "description": "method definition",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "class\\s+$",
      "insertText": "${1:ClassName}\n\tdef initialize(${2:params})\n\t\t${3}\n\tend\nend",
      "description": "class definition",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "\\.each\\s+do\\s*$",
      "insertText": "|${1:item}|\n\t${2}\nend",
      "description": "each block",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "\\.map\\s*\\{\\s*$",
      "insertText": "|${1:item}| ${2:item} }",
      "description": "map block",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "\\.select\\s*\\{\\s*$",
      "insertText": "|${1:item}| ${2:condition} }",
      "description": "select block",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "if\\s+$",
      "insertText": "${1:condition}\n\t${2}\nend",
      "description": "if block",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "begin$",
      "insertText": "\n\t${1}\nrescue ${2:StandardError} => ${3:e}\n\t${4}\nend",
      "description": "begin rescue",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "puts\\s+$",
      "insertText": "\"${1:text}\"",
      "description": "puts string",
      "completeBracketPairs": false
    }
  ]
}