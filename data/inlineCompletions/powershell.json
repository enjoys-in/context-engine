{
  "language": "powershell",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*foreach\\\\s*$",
      "insertText": "foreach (${1:\\$item} in ${2:\\$collection}) {\n\t$0\n}",
      "description": "Foreach loop",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*function\\\\s*$",
      "insertText": "function ${1:Name} {\n\tparam(\n\t\t${2:}\n\t)\n\t$0\n}",
      "description": "Function with param",
      "completeBracketPairs": true
    }
  ]
}
