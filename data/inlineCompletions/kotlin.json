{
  "language": "kotlin",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\s*fun\\s+main\\s*$",
      "insertText": "fun main(args: Array<String>) {\n\t${1:println(\"Hello, World!\")}\n}",
      "description": "Main function",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\s*fun\\s+\\w+\\($",
      "insertText": "${1:param}: ${2:Type}): ${3:Unit} {\n\t$0\n}",
      "description": "Complete function signature",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\s*for\\s*$",
      "insertText": "for (${1:item} in ${2:collection}) {\n\t$0\n}",
      "description": "For loop",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\s*when\\s*$",
      "insertText": "when (${1:value}) {\n\t${2:condition} -> ${3:result}\n\telse -> ${4:default}\n}",
      "description": "When expression",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\s*data\\s+class\\s*$",
      "insertText": "data class ${1:Name}(\n\tval ${2:property}: ${3:Type}\n)",
      "description": "Data class",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\s*sealed\\s+class\\s*$",
      "insertText": "sealed class ${1:Name} {\n\tdata class ${2:Variant}(val ${3:value}: ${4:Type}) : ${1:Name}()\n\tobject ${5:Empty} : ${1:Name}()\n}",
      "description": "Sealed class",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\s*try\\s*$",
      "insertText": "try {\n\t${1:// code}\n} catch (e: ${2:Exception}) {\n\t${3:e.printStackTrace()}\n}",
      "description": "Try-catch block",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\s*suspend\\s+fun\\s*$",
      "insertText": "suspend fun ${1:name}(${2:params}): ${3:Unit} {\n\t$0\n}",
      "description": "Suspend function",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\s*class\\s+\\w+\\s*$",
      "insertText": "class ${1:Name}(\n\tprivate val ${2:property}: ${3:Type}\n) {\n\t$0\n}",
      "description": "Class with primary constructor",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\s*enum\\s+class\\s*$",
      "insertText": "enum class ${1:Name} {\n\t${2:VALUE1},\n\t${3:VALUE2}\n}",
      "description": "Enum class",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\s*interface\\s+\\w+\\s*$",
      "insertText": "interface ${1:Name} {\n\tfun ${2:method}(${3:params}): ${4:Unit}\n}",
      "description": "Interface declaration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "\\.let\\s*$",
      "insertText": ".let { ${1:it} ->\n\t$0\n}",
      "description": "Scope function let",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "\\.apply\\s*$",
      "insertText": ".apply {\n\t$0\n}",
      "description": "Scope function apply",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\s*launch\\s*$",
      "insertText": "launch {\n\t$0\n}",
      "description": "Coroutine launch",
      "completeBracketPairs": true
    }
  ]
}