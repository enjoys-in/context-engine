{
  "language": "dockerfile",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*FROM\\\\s*$",
      "insertText": "FROM ${1:ubuntu:latest}\n$0",
      "description": "FROM base image",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*RUN\\\\s*$",
      "insertText": "RUN ${1:apt-get update && apt-get install -y} ${2:package}",
      "description": "RUN command",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*COPY\\\\s*$",
      "insertText": "COPY ${1:.} ${2:/app}",
      "description": "COPY files into image",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*EXPOSE\\\\s*$",
      "insertText": "EXPOSE ${1:8080}\nCMD [\"${2:node}\", \"${3:server.js}\"]",
      "description": "EXPOSE port and CMD",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*ENTRYPOINT\\\\s*$",
      "insertText": "ENTRYPOINT [\"${1:executable}\", \"${2:arg1}\"]",
      "description": "ENTRYPOINT instruction",
      "completeBracketPairs": true
    }
  ]
}
