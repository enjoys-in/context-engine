{
  "language": "bicep",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*resource\\\\s*$",
      "insertText": "resource ${1:symbolicName} '${2:Microsoft.Storage/storageAccounts@2023-01-01}' = {\n\tname: '${3:name}'\n\tlocation: ${4:location}\n\tproperties: {\n\t\t${5:}\n\t}\n}",
      "description": "Resource declaration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*module\\\\s*$",
      "insertText": "module ${1:moduleName} '${2:./module.bicep}' = {\n\tname: '${3:deploymentName}'\n\tparams: {\n\t\t${4:}\n\t}\n}",
      "description": "Module declaration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*param\\\\s*$",
      "insertText": "param ${1:paramName} ${2:string}",
      "description": "Parameter declaration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*var\\\\s*$",
      "insertText": "var ${1:varName} = ${2:'value'}",
      "description": "Variable declaration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*output\\\\s*$",
      "insertText": "output ${1:outputName} ${2:string} = ${3:value}",
      "description": "Output declaration",
      "completeBracketPairs": true
    },
    {
      "trigger": "for",
      "template": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "description": "For loop"
    },
    {
      "trigger": "if",
      "template": "if (${1:condition}) {\n  ${0}\n}",
      "description": "If statement"
    },
    {
      "trigger": "try",
      "template": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "description": "Try-catch block"
    },
    {
      "trigger": "fn",
      "template": "function ${1:name}(${2:params}) {\n  ${0}\n}",
      "description": "Function declaration"
    },
    {
      "trigger": "log",
      "template": "console.log(${0})",
      "description": "Console log"
    },
    {
      "trigger": "imp",
      "template": "import { ${1:name} } from '${0:module}'",
      "description": "Import statement"
    },
    {
      "trigger": "class",
      "template": "class ${1:Name} {\n  constructor(${2:params}) {\n    ${0}\n  }\n}",
      "description": "Class declaration"
    },
    {
      "trigger": "switch",
      "template": "switch (${1:expr}) {\n  case ${2:val}:\n    ${0}\n    break;\n  default:\n    break;\n}",
      "description": "Switch statement"
    },
    {
      "trigger": "while",
      "template": "while (${1:condition}) {\n  ${0}\n}",
      "description": "While loop"
    },
    {
      "trigger": "map",
      "template": "${1:array}.map((${2:item}) => ${0})",
      "description": "Array map"
    }
  ]
}
