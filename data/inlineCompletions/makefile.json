{
  "language": "makefile",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*target\\\\s*$",
      "insertText": "${1:target}: ${2:dependencies}\n\t${3:command}",
      "description": "Make target with dependencies",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*\\.PHONY\\\\s*$",
      "insertText": ".PHONY: ${1:target}",
      "description": ".PHONY declaration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*ifdef\\\\s*$",
      "insertText": "ifdef ${1:VARIABLE}\n\t${2:# conditional commands}\nendif",
      "description": "Ifdef conditional",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*define\\\\s*$",
      "insertText": "define ${1:VARIABLE}\n${2:value}\nendef",
      "description": "Multi-line variable definition",
      "completeBracketPairs": true
    }
  ]
}
