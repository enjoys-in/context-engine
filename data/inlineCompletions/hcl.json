{
  "language": "hcl",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*resource\\\\s*$",
      "insertText": "resource \"${1:aws_instance}\" \"${2:name}\" {\n\t$0\n}",
      "description": "Resource block",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*variable\\\\s*$",
      "insertText": "variable \"${1:name}\" {\n\ttype = ${2:string}\n\tdefault = ${3:\"\"}\n}",
      "description": "Variable block",
      "completeBracketPairs": true
    }
  ]
}
