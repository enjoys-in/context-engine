{
  "language": "protobuf",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*message\\\\s*$",
      "insertText": "message ${1:Name} {\n\t${2:string} ${3:field} = ${4:1};\n}",
      "description": "Message",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*service\\\\s*$",
      "insertText": "service ${1:Name} {\n\trpc ${2:Method}(${3:Request}) returns (${4:Response});\n}",
      "description": "Service",
      "completeBracketPairs": true
    }
  ]
}
