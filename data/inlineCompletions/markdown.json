{
  "language": "markdown",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*#heading\\\\s*$",
      "insertText": "# ${1:Heading}\n\n${2:Content}",
      "description": "Heading with content",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*link\\\\s*$",
      "insertText": "[${1:text}](${2:url})",
      "description": "Markdown link",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*image\\\\s*$",
      "insertText": "![${1:alt text}](${2:url})",
      "description": "Markdown image",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*```\\\\s*$",
      "insertText": "```${1:language}\n${2:code}\n```",
      "description": "Fenced code block",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*table\\\\s*$",
      "insertText": "| ${1:Header 1} | ${2:Header 2} | ${3:Header 3} |\n| --- | --- | --- |\n| ${4:cell} | ${5:cell} | ${6:cell} |",
      "description": "Markdown table",
      "completeBracketPairs": true
    }
  ]
}
