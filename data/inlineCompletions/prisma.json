{
  "language": "prisma",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\s*model\\s+\\w+\\s*\\{\\s*$",
      "insertText": "\n  id        Int      @id @default(autoincrement())\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n",
      "description": "Common model fields (id, timestamps)",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\s*datasource\\s+\\w+\\s*\\{\\s*$",
      "insertText": "\n  provider = \"postgresql\"\n  url      = env(\"DATABASE_URL\")\n",
      "description": "PostgreSQL datasource configuration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\s*generator\\s+\\w+\\s*\\{\\s*$",
      "insertText": "\n  provider = \"prisma-client-js\"\n",
      "description": "Prisma Client generator",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\s*enum\\s+\\w+\\s*\\{\\s*$",
      "insertText": "\n  ${1:VALUE1}\n  ${2:VALUE2}\n",
      "description": "Enum values",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\s+\\w+\\s+\\w+\\s+@relation\\($",
      "insertText": "fields: [${1:foreignKeyId}], references: [${2:id}])",
      "description": "Complete relation arguments",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\s+\\w+\\s+DateTime\\s*$",
      "insertText": " @default(now())",
      "description": "DateTime with now() default",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "^\\s+id\\s+Int\\s*$",
      "insertText": " @id @default(autoincrement())",
      "description": "Int id with autoincrement",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "^\\s+id\\s+String\\s*$",
      "insertText": " @id @default(uuid())",
      "description": "String id with UUID",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "for\\\\s+",
      "insertText": "for (let ${1:i} = 0; ${1:i} < ${2:n}; ${1:i}++) {\\n\\t${3:}\\n}",
      "description": "Complete Prisma for loop pattern",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "if\\\\s+",
      "insertText": "if (${1:condition}) {\\n\\t${2:}\\n}",
      "description": "Complete Prisma if statement",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "function\\\\s+|def\\\\s+|fn\\\\s+|func\\\\s+",
      "insertText": "function ${1:name}(${2:params}) {\\n\\t${3:}\\n}",
      "description": "Complete Prisma function declaration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "class\\\\s+",
      "insertText": "class ${1:Name} {\\n\\t${2:}\\n}",
      "description": "Complete Prisma class declaration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "try\\\\s*",
      "insertText": "try {\\n\\t${1:}\\n} catch (${2:error}) {\\n\\t${3:}\\n}",
      "description": "Complete Prisma try-catch block",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "import\\\\s+",
      "insertText": "import { ${2:name} } from '${1:module}';",
      "description": "Complete Prisma import statement",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "switch\\\\s+|match\\\\s+",
      "insertText": "switch (${1:expr}) {\\n\\tcase ${2:val}:\\n\\t\\t${3:break};\\n\\tdefault:\\n\\t\\t${4:break};\\n}",
      "description": "Complete Prisma switch/match statement",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "while\\\\s+",
      "insertText": "while (${1:condition}) {\\n\\t${2:}\\n}",
      "description": "Complete Prisma while loop",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "return\\\\s+",
      "insertText": "return ${1:value};",
      "description": "Complete Prisma return statement",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "console\\\\.|print|log|echo|puts",
      "insertText": "console.log(${1:value});",
      "description": "Complete Prisma logging/output",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "//\\\\s+TODO|#\\\\s+TODO",
      "insertText": "// TODO: implement ${1:feature}",
      "description": "TODO comment template",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "async\\\\s+|await\\\\s+",
      "insertText": "async function ${1:name}(${2:params}) {\\n\\tconst ${3:result} = await ${4:promise};\\n\\treturn ${3:result};\\n}",
      "description": "Complete Prisma async/await pattern",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "test\\\\s+|describe\\\\s+|it\\\\s+",
      "insertText": "describe('${1:subject}', () => {\\n\\tit('should ${2:behavior}', () => {\\n\\t\\t${3:expect}\\n\\t});\\n});",
      "description": "Complete Prisma test template",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "map\\\\(|filter\\\\(|reduce\\\\(",
      "insertText": ".map((${1:item}) => ${2:transform})",
      "description": "Complete Prisma collection operation",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "struct\\\\s+|type\\\\s+|interface\\\\s+",
      "insertText": "type ${1:Name} = {\\n\\t${2:property}: ${3:type};\\n};",
      "description": "Complete Prisma type definition",
      "completeBracketPairs": true
    }
  ]
}
