{
  "language": "st",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*method\\\\s*$",
      "insertText": "${1:methodName}\n\t| ${2:temp} |\n\t${3:^ self}",
      "description": "Method definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*ifTrue\\\\s*$",
      "insertText": "${1:condition} ifTrue: [ ${2:trueBlock} ] ifFalse: [ ${3:falseBlock} ]",
      "description": "ifTrue:ifFalse: conditional",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*do\\\\s*$",
      "insertText": "${1:collection} do: [ :${2:each} | ${3:each printNl} ]",
      "description": "do: iteration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*collect\\\\s*$",
      "insertText": "${1:collection} collect: [ :${2:each} | ${3:each * 2} ]",
      "description": "collect: mapping",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*subclass\\\\s*$",
      "insertText": "${1:Object} subclass: #${2:MyClass}\n\tinstanceVariableNames: '${3:var1 var2}'\n\tclassVariableNames: ''\n\tpoolDictionaries: ''\n\tcategory: '${4:MyCategory}'",
      "description": "Subclass definition",
      "completeBracketPairs": true
    }
  ]
}