{
  "language": "doctest",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*>>>\\\\s*$",
      "insertText": ">>> ${1:expression}\n${2:expected_output}",
      "description": "Doctest test case",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*\\.\\.\\.\\\\s*$",
      "insertText": "... ${1:continuation_line}",
      "description": "Continuation line",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*>>> def\\\\s*$",
      "insertText": ">>> def ${1:func}(${2:args}):\n...     ${3:return args}\n>>> ${1:func}(${4:value})\n${5:expected}",
      "description": "Function test pattern",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": ">>>\\s*def",
      "insertText": ">>> def ${1:func}(${2:args}):\n...     ${3:pass}\n>>> $1($4)\n$0",
      "description": "function doctest",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": ">>>\\s*class",
      "insertText": ">>> class ${1:Name}:\n...     def __init__(self):\n...         ${2:pass}",
      "description": "class doctest",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": ">>>\\s*for",
      "insertText": ">>> for ${1:item} in ${2:iterable}:\n...     print($1)",
      "description": "for loop doctest",
      "completeBracketPairs": true
    },
    {
      "trigger": "for",
      "template": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "description": "For loop",
      "triggerPattern": "for",
      "insertText": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "if",
      "template": "if (${1:condition}) {\n  ${0}\n}",
      "description": "If statement",
      "triggerPattern": "if",
      "insertText": "if (${1:condition}) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "try",
      "template": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "description": "Try-catch block",
      "triggerPattern": "try",
      "insertText": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "fn",
      "template": "function ${1:name}(${2:params}) {\n  ${0}\n}",
      "description": "Function declaration",
      "triggerPattern": "fn",
      "insertText": "function ${1:name}(${2:params}) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "log",
      "template": "console.log(${0})",
      "description": "Console log",
      "triggerPattern": "log",
      "insertText": "console.log(${0})",
      "completeBracketPairs": true
    },
    {
      "trigger": "imp",
      "template": "import { ${1:name} } from '${0:module}'",
      "description": "Import statement",
      "triggerPattern": "imp",
      "insertText": "import { ${1:name} } from '${0:module}'",
      "completeBracketPairs": true
    },
    {
      "trigger": "class",
      "template": "class ${1:Name} {\n  constructor(${2:params}) {\n    ${0}\n  }\n}",
      "description": "Class declaration",
      "triggerPattern": "class",
      "insertText": "class ${1:Name} {\n  constructor(${2:params}) {\n    ${0}\n  }\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "switch",
      "template": "switch (${1:expr}) {\n  case ${2:val}:\n    ${0}\n    break;\n  default:\n    break;\n}",
      "description": "Switch statement",
      "triggerPattern": "switch",
      "insertText": "switch (${1:expr}) {\n  case ${2:val}:\n    ${0}\n    break;\n  default:\n    break;\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "while",
      "template": "while (${1:condition}) {\n  ${0}\n}",
      "description": "While loop",
      "triggerPattern": "while",
      "insertText": "while (${1:condition}) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "def",
      "insertText": "def ${1:name}(${2:self}):\n\t${3:pass}",
      "description": "Function definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "ife",
      "insertText": "if ${1:condition}:\n\t${2:pass}\nelse:\n\t${3:pass}",
      "description": "If-else statement",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "with",
      "insertText": "with ${1:expression} as ${2:var}:\n\t${3:pass}",
      "description": "With statement",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "lambda",
      "insertText": "lambda ${1:x}: ${2:expression}",
      "description": "Lambda expression",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "list_comp",
      "insertText": "[${1:expr} for ${2:item} in ${3:iterable}]",
      "description": "List comprehension",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "dict_comp",
      "insertText": "{${1:key}: ${2:value} for ${3:item} in ${4:iterable}}",
      "description": "Dict comprehension",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "decorator",
      "insertText": "@${1:decorator}\ndef ${2:name}(${3:self}):\n\t${4:pass}",
      "description": "Decorated function",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "async_def",
      "insertText": "async def ${1:name}(${2:self}):\n\t${3:pass}",
      "description": "Async function",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "dataclass",
      "insertText": "@dataclass\nclass ${1:Name}:\n\t${2:field}: ${3:str}",
      "description": "Dataclass",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "main",
      "insertText": "if __name__ == '__main__':\n\t${1:main()}",
      "description": "Main entry point",
      "completeBracketPairs": false
    }
  ]
}
