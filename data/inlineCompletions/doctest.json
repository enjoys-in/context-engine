{
  "language": "doctest",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*>>>\\\\s*$",
      "insertText": ">>> ${1:expression}\n${2:expected_output}",
      "description": "Doctest test case",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*\\.\\.\\.\\\\s*$",
      "insertText": "... ${1:continuation_line}",
      "description": "Continuation line",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*>>> def\\\\s*$",
      "insertText": ">>> def ${1:func}(${2:args}):\n...     ${3:return args}\n>>> ${1:func}(${4:value})\n${5:expected}",
      "description": "Function test pattern",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": ">>>\\s*def",
      "insertText": ">>> def ${1:func}(${2:args}):\n...     ${3:pass}\n>>> $1($4)\n$0",
      "description": "function doctest"
    },
    {
      "triggerPattern": ">>>\\s*class",
      "insertText": ">>> class ${1:Name}:\n...     def __init__(self):\n...         ${2:pass}",
      "description": "class doctest"
    },
    {
      "triggerPattern": ">>>\\s*for",
      "insertText": ">>> for ${1:item} in ${2:iterable}:\n...     print($1)",
      "description": "for loop doctest"
    },
    {
      "trigger": "for",
      "template": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "description": "For loop"
    },
    {
      "trigger": "if",
      "template": "if (${1:condition}) {\n  ${0}\n}",
      "description": "If statement"
    },
    {
      "trigger": "try",
      "template": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "description": "Try-catch block"
    },
    {
      "trigger": "fn",
      "template": "function ${1:name}(${2:params}) {\n  ${0}\n}",
      "description": "Function declaration"
    },
    {
      "trigger": "log",
      "template": "console.log(${0})",
      "description": "Console log"
    },
    {
      "trigger": "imp",
      "template": "import { ${1:name} } from '${0:module}'",
      "description": "Import statement"
    },
    {
      "trigger": "class",
      "template": "class ${1:Name} {\n  constructor(${2:params}) {\n    ${0}\n  }\n}",
      "description": "Class declaration"
    },
    {
      "trigger": "switch",
      "template": "switch (${1:expr}) {\n  case ${2:val}:\n    ${0}\n    break;\n  default:\n    break;\n}",
      "description": "Switch statement"
    },
    {
      "trigger": "while",
      "template": "while (${1:condition}) {\n  ${0}\n}",
      "description": "While loop"
    }
  ]
}
