{
  "language": "sb",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*Sub\\\\s*$",
      "insertText": "Sub ${1:Name}\n\t${2:' statements}\nEndSub",
      "description": "Sub procedure",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*Function\\\\s*$",
      "insertText": "Function ${1:Name}(${2:param})\n\t${3:' statements}\n\t${1:Name} = ${4:result}\nEndFunction",
      "description": "Function definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*If\\\\s*$",
      "insertText": "If ${1:condition} Then\n\t${2:' statements}\nElse\n\t${3:' statements}\nEndIf",
      "description": "If..Then..Else block",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*For\\\\s*$",
      "insertText": "For ${1:i} = ${2:1} To ${3:10}\n\t${4:' statements}\nEndFor",
      "description": "For loop",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*Dim\\\\s*$",
      "insertText": "Dim ${1:variable} As ${2:Integer}",
      "description": "Variable declaration",
      "completeBracketPairs": true
    }
  ]
}