{
  "language": "cameligo",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*let\\\\s*$",
      "insertText": "let ${1:name} : ${2:int} = ${3:0}",
      "description": "Let binding",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*match\\\\s*$",
      "insertText": "match ${1:expr} with\n| ${2:pattern1} -> ${3:result1}\n| ${4:pattern2} -> ${5:result2}",
      "description": "Match expression",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*type\\\\s*$",
      "insertText": "type ${1:name} =\n| ${2:Variant1} of ${3:int}\n| ${4:Variant2} of ${5:string}",
      "description": "Type declaration with variants",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*let rec\\\\s*$",
      "insertText": "let rec ${1:name} (${2:param} : ${3:int}) : ${4:int} =\n\tif ${5:param = 0} then ${6:1}\n\telse ${7:name (param - 1)}",
      "description": "Recursive function",
      "completeBracketPairs": true
    }
  ]
}