{
  "language": "zsh",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*if\\\\s*$",
      "insertText": "if [[ ${1:condition} ]]; then\n\t$0\nfi",
      "description": "If block",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*for\\\\s*$",
      "insertText": "for ${1:i} in ${2:items}; do\n\t$0\ndone",
      "description": "For loop",
      "completeBracketPairs": true
    }
  ]
}
