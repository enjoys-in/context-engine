{
  "language": "json",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*\\{\\\\s*$",
      "insertText": "{\n\t\"${1:key}\": \"${2:value}\"\n}",
      "description": "JSON object",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*\"\\\\s*$",
      "insertText": "\"${1:key}\": \"${2:value}\"",
      "description": "Key-value pair (string)",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*\\[\\\\s*$",
      "insertText": "[\n\t${1:}\n]",
      "description": "JSON array",
      "completeBracketPairs": true
    }
  ]
}
