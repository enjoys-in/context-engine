{
  "language": "lua",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*for\\\\s*$",
      "insertText": "for ${1:i} = ${2:1}, ${3:10} do\n\t$0\nend",
      "description": "For loop",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*function\\\\s*$",
      "insertText": "function ${1:name}(${2:})\n\t$0\nend",
      "description": "Function definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "function\\s+$",
      "insertText": "${1:name}(${2:params})\n\t${3}\nend",
      "description": "function definition",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "local\\s+function\\s+$",
      "insertText": "${1:name}(${2:params})\n\t${3}\nend",
      "description": "local function",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "for\\s+$",
      "insertText": "${1:i} = ${2:1}, ${3:10} do\n\t${4}\nend",
      "description": "numeric for",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "for\\s+.*in\\s+$",
      "insertText": "${1:pairs}(${2:table}) do\n\t${3}\nend",
      "description": "generic for",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "if\\s+$",
      "insertText": "${1:condition} then\n\t${2}\nend",
      "description": "if block",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "print\\($",
      "insertText": "\"${1:text}\")",
      "description": "print",
      "completeBracketPairs": false
    }
  ]
}