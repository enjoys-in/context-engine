{
  "language": "c",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*for\\\\s*$",
      "insertText": "for (int ${1:i} = 0; ${1:i} < ${2:n}; ${1:i}++) {\n\t$0\n}",
      "description": "For loop",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*if\\\\s*$",
      "insertText": "if (${1:condition}) {\n\t$0\n}",
      "description": "If block",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "for\\s*\\($",
      "insertText": "int ${1:i} = 0; ${1:i} < ${2:n}; ${1:i}++",
      "description": "for loop",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "if\\s*\\($",
      "insertText": "${1:condition}",
      "description": "if condition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "while\\s*\\($",
      "insertText": "${1:condition}",
      "description": "while condition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "printf\\($",
      "insertText": "\"${1:%s}\\n\", ${2:value})",
      "description": "printf",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "#include\\s+$",
      "insertText": "<${1:stdio.h}>",
      "description": "include header",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "switch\\s*\\($",
      "insertText": "${1:var}) {\ncase ${2:val}:\n\t${3}\n\tbreak;\ndefault:\n\tbreak;\n}",
      "description": "switch",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "struct\\s+$",
      "insertText": "${1:name} {\n\t${2:int field};\n}",
      "description": "struct declaration",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "typedef\\s+$",
      "insertText": "${1:type} ${2:name}",
      "description": "typedef",
      "completeBracketPairs": false
    },
    {
      "trigger": "for",
      "template": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "description": "For loop",
      "triggerPattern": "for",
      "insertText": "for (let i = 0; i < ${1:length}; i++) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "if",
      "template": "if (${1:condition}) {\n  ${0}\n}",
      "description": "If statement",
      "triggerPattern": "if",
      "insertText": "if (${1:condition}) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "try",
      "template": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "description": "Try-catch block",
      "triggerPattern": "try",
      "insertText": "try {\n  ${0}\n} catch (${1:error}) {\n  \n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "fn",
      "template": "function ${1:name}(${2:params}) {\n  ${0}\n}",
      "description": "Function declaration",
      "triggerPattern": "fn",
      "insertText": "function ${1:name}(${2:params}) {\n  ${0}\n}",
      "completeBracketPairs": true
    },
    {
      "trigger": "log",
      "template": "console.log(${0})",
      "description": "Console log",
      "triggerPattern": "log",
      "insertText": "console.log(${0})",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "error\\\\s+|err\\\\s+",
      "insertText": "try {\\n\\t${1:code}\\n} catch (error) {\\n\\t${2:handle}\\n}",
      "description": "C error handling pattern",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "const\\\\s+|let\\\\s+|var\\\\s+",
      "insertText": "const ${1:name} = ${2:value};",
      "description": "C variable declaration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "interface\\\\s+|type\\\\s+",
      "insertText": "interface ${1:Name} {\\n\\t${2:property}: ${3:type};\\n}",
      "description": "C interface/type definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "enum\\\\s+",
      "insertText": "enum ${1:Name} {\\n\\t${2:Value1},\\n\\t${3:Value2},\\n}",
      "description": "C enum declaration",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "constructor\\\\s*\\\\(|__init__|init\\\\s*\\\\(",
      "insertText": "constructor(${1:params}) {\\n\\t${2:}\\n}",
      "description": "C constructor",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "export\\\\s+",
      "insertText": "export { ${1:name} } from '${2:module}';",
      "description": "C re-export",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "throw\\\\s+|raise\\\\s+",
      "insertText": "throw new ${1:Error}('${2:message}');",
      "description": "C throw/raise error",
      "completeBracketPairs": true
    }
  ]
}
