{
  "language": "python",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*for\\\\s*$",
      "insertText": "for ${1:item} in ${2:iterable}:\n\t${3:pass}",
      "description": "For loop",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*def\\\\s*$",
      "insertText": "def ${1:name}(${2:self}):\n\t${3:pass}",
      "description": "Function",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*class\\\\s*$",
      "insertText": "class ${1:Name}:\n\tdef __init__(self${2:}):\n\t\t${3:pass}",
      "description": "Class",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "for\\s+$",
      "insertText": "${1:item} in ${2:iterable}:",
      "description": "for loop",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "if\\s+$",
      "insertText": "${1:condition}:",
      "description": "if condition",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "def\\s+$",
      "insertText": "${1:function_name}(${2:params}):\n\t${3:pass}",
      "description": "function definition",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "class\\s+$",
      "insertText": "${1:ClassName}:\n\tdef __init__(self${2:, params}):\n\t\t${3:pass}",
      "description": "class definition",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "with\\s+$",
      "insertText": "open('${1:file}', '${2:r}') as ${3:f}:",
      "description": "with statement",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "try:$",
      "insertText": "\n\t${1:pass}\nexcept ${2:Exception} as ${3:e}:\n\t${4:pass}",
      "description": "try-except block",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "\\bprint\\($",
      "insertText": "f\"${1:text}\"",
      "description": "f-string print",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "\\bimport\\s+$",
      "insertText": "${1:module}",
      "description": "import module",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "\\bfrom\\s+$",
      "insertText": "${1:module} import ${2:name}",
      "description": "from import",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "\\blambda\\s+$",
      "insertText": "${1:x}: ${2:x}",
      "description": "lambda expression",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "#\\s*TODO$",
      "insertText": ": ${1:description}",
      "description": "TODO comment",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "\\[.*\\bfor\\s+$",
      "insertText": "${1:item} in ${2:iterable}]",
      "description": "list comprehension",
      "completeBracketPairs": false
    }
  ]
}