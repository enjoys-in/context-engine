{
  "language": "python",
  "inlineCompletions": [
    {
      "triggerPattern": "^\\\\s*for\\\\s*$",
      "insertText": "for ${1:item} in ${2:iterable}:\n\t${3:pass}",
      "description": "For loop",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*def\\\\s*$",
      "insertText": "def ${1:name}(${2:self}):\n\t${3:pass}",
      "description": "Function",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "^\\\\s*class\\\\s*$",
      "insertText": "class ${1:Name}:\n\tdef __init__(self${2:}):\n\t\t${3:pass}",
      "description": "Class",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "for\\s+$",
      "insertText": "${1:item} in ${2:iterable}:",
      "description": "for loop",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "if\\s+$",
      "insertText": "${1:condition}:",
      "description": "if condition",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "def\\s+$",
      "insertText": "${1:function_name}(${2:params}):\n\t${3:pass}",
      "description": "function definition",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "class\\s+$",
      "insertText": "${1:ClassName}:\n\tdef __init__(self${2:, params}):\n\t\t${3:pass}",
      "description": "class definition",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "with\\s+$",
      "insertText": "open('${1:file}', '${2:r}') as ${3:f}:",
      "description": "with statement",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "try:$",
      "insertText": "\n\t${1:pass}\nexcept ${2:Exception} as ${3:e}:\n\t${4:pass}",
      "description": "try-except block",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "\\bprint\\($",
      "insertText": "f\"${1:text}\"",
      "description": "f-string print",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "\\bimport\\s+$",
      "insertText": "${1:module}",
      "description": "import module",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "\\bfrom\\s+$",
      "insertText": "${1:module} import ${2:name}",
      "description": "from import",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "\\blambda\\s+$",
      "insertText": "${1:x}: ${2:x}",
      "description": "lambda expression",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "#\\s*TODO$",
      "insertText": ": ${1:description}",
      "description": "TODO comment",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "\\[.*\\bfor\\s+$",
      "insertText": "${1:item} in ${2:iterable}]",
      "description": "list comprehension",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "def",
      "insertText": "def ${1:name}(${2:self}):\n\t${3:pass}",
      "description": "Function definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "class",
      "insertText": "class ${1:Name}:\n\tdef __init__(self${2:, args}):\n\t\t${3:pass}",
      "description": "Class definition",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "if",
      "insertText": "if ${1:condition}:\n\t${2:pass}",
      "description": "If statement",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "ife",
      "insertText": "if ${1:condition}:\n\t${2:pass}\nelse:\n\t${3:pass}",
      "description": "If-else statement",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "for",
      "insertText": "for ${1:item} in ${2:iterable}:\n\t${3:pass}",
      "description": "For loop",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "while",
      "insertText": "while ${1:condition}:\n\t${2:pass}",
      "description": "While loop",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "try",
      "insertText": "try:\n\t${1:pass}\nexcept ${2:Exception} as ${3:e}:\n\t${4:pass}",
      "description": "Try-except block",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "with",
      "insertText": "with ${1:expression} as ${2:var}:\n\t${3:pass}",
      "description": "With statement",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "lambda",
      "insertText": "lambda ${1:x}: ${2:expression}",
      "description": "Lambda expression",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "list_comp",
      "insertText": "[${1:expr} for ${2:item} in ${3:iterable}]",
      "description": "List comprehension",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "dict_comp",
      "insertText": "{${1:key}: ${2:value} for ${3:item} in ${4:iterable}}",
      "description": "Dict comprehension",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "decorator",
      "insertText": "@${1:decorator}\ndef ${2:name}(${3:self}):\n\t${4:pass}",
      "description": "Decorated function",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "async_def",
      "insertText": "async def ${1:name}(${2:self}):\n\t${3:pass}",
      "description": "Async function",
      "completeBracketPairs": true
    },
    {
      "triggerPattern": "dataclass",
      "insertText": "@dataclass\nclass ${1:Name}:\n\t${2:field}: ${3:str}",
      "description": "Dataclass",
      "completeBracketPairs": false
    },
    {
      "triggerPattern": "main",
      "insertText": "if __name__ == '__main__':\n\t${1:main()}",
      "description": "Main entry point",
      "completeBracketPairs": false
    }
  ]
}
