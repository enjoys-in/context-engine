{
  "language": "dotenv",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": [
      "export"
    ]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "^(?:export\\s+)?([a-zA-Z_][a-zA-Z0-9_]*)\\s*=",
      "captureGroup": 1,
      "description": "Dotenv variable name"
    },
    {
      "pattern": "\\$\\{?([a-zA-Z_][a-zA-Z0-9_]*)\\}?",
      "captureGroup": 1,
      "description": "Dotenv variable reference"
    }
  ]
}
