{
  "language": "java",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "identifierRules": {
    "start": "[a-zA-Z_$]",
    "continue": "[a-zA-Z0-9_$]",
    "forbidden": [
      "abstract", "assert", "boolean", "break", "byte", "case", "catch",
      "char", "class", "const", "continue", "default", "do", "double",
      "else", "enum", "extends", "final", "finally", "float", "for",
      "goto", "if", "implements", "import", "instanceof", "int", "interface",
      "long", "native", "new", "null", "package", "private", "protected",
      "public", "return", "short", "static", "strictfp", "super", "switch",
      "synchronized", "this", "throw", "throws", "transient", "try", "void",
      "volatile", "while", "true", "false", "var", "yield", "record",
      "sealed", "permits", "non-sealed"
    ]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_$][a-zA-Z0-9_$]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\bclass\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)",
      "captureGroup": 1,
      "description": "Java class name"
    },
    {
      "pattern": "\\b([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*\\(",
      "captureGroup": 1,
      "description": "Java method or constructor name"
    },
    {
      "pattern": "\\b([a-zA-Z_$][a-zA-Z0-9_$]*)\\b",
      "captureGroup": 1,
      "description": "Java identifier"
    }
  ]
}
