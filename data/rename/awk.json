{
  "language": "awk",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": [
      "BEGIN", "END", "if", "else", "while", "for", "do", "break", "continue",
      "function", "return", "delete", "exit", "getline", "next", "nextfile",
      "print", "printf", "sprintf", "substr", "split", "sub", "gsub", "match",
      "tolower", "toupper", "length", "index", "in"
    ]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "AWK variable or function name"
    },
    {
      "pattern": "\\$([0-9]+)",
      "captureGroup": 0,
      "description": "AWK field reference"
    }
  ]
}
