{
  "language": "bicep",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": [
      "targetScope", "resource", "module", "param", "var", "output", "for",
      "in", "if", "existing", "import", "as", "type", "with", "metadata",
      "true", "false", "null", "string", "int", "bool", "object", "array",
      "func", "assert", "using", "test", "extension"
    ]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "(?:param|var|output|resource|module)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captureGroup": 1,
      "description": "Bicep declaration name"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Bicep identifier"
    }
  ]
}
