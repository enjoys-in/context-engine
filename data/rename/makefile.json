{
  "language": "makefile",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_.-]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_.-]",
    "forbidden": [
      "define",
      "endef",
      "undefine",
      "ifdef",
      "ifndef",
      "ifeq",
      "ifneq",
      "else",
      "endif",
      "include",
      "sinclude",
      "override",
      "export",
      "unexport",
      "private",
      "vpath",
      "PHONY",
      "SUFFIXES",
      "DEFAULT",
      "PRECIOUS",
      "INTERMEDIATE",
      "SECONDARY",
      "SECONDEXPANSION",
      "DELETE_ON_ERROR",
      "IGNORE",
      "LOW_RESOLUTION_TIME",
      "SILENT",
      "EXPORT_ALL_VARIABLES",
      "NOTPARALLEL",
      "ONESHELL",
      "POSIX"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_.-]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "^([a-zA-Z_][a-zA-Z0-9_.-]*)\\s*[:?+]?=",
      "captureGroup": 1,
      "description": "Makefile variable definition"
    },
    {
      "pattern": "^([a-zA-Z_][a-zA-Z0-9_.-]*)\\s*:",
      "captureGroup": 1,
      "description": "Makefile target"
    },
    {
      "pattern": "\\$[({]([a-zA-Z_][a-zA-Z0-9_.-]*)[)}]",
      "captureGroup": 1,
      "description": "Makefile variable reference"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
