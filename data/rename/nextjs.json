{
  "language": "nextjs",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "identifierRules": {
    "start": "[a-zA-Z_$]",
    "continue": "[a-zA-Z0-9_$]",
    "forbidden": [
      "break",
      "case",
      "catch",
      "continue",
      "debugger",
      "default",
      "delete",
      "do",
      "else",
      "finally",
      "for",
      "function",
      "if",
      "in",
      "instanceof",
      "new",
      "return",
      "switch",
      "this",
      "throw",
      "try",
      "typeof",
      "var",
      "void",
      "while",
      "with",
      "class",
      "const",
      "enum",
      "export",
      "extends",
      "import",
      "super",
      "implements",
      "interface",
      "let",
      "package",
      "private",
      "protected",
      "public",
      "static",
      "yield",
      "await",
      "async",
      "of",
      "null",
      "undefined",
      "true",
      "false",
      "NaN",
      "Infinity"
    ]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 256,
    "pattern": "^[a-zA-Z_$][a-zA-Z0-9_$]*$"
  },
  "prepareRenamePatterns": [
    {
      "name": "Component name",
      "pattern": "(?:export\\s+default\\s+)?function\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Rename component/function declaration"
    },
    {
      "name": "Arrow component",
      "pattern": "(?:export\\s+)?const\\s+(\\w+)\\s*[:=]",
      "captureGroup": 1,
      "description": "Rename const/arrow function"
    },
    {
      "name": "Hook name",
      "pattern": "(?:function|const)\\s+(use[A-Z]\\w*)",
      "captureGroup": 1,
      "description": "Rename custom hook"
    },
    {
      "name": "Type/Interface",
      "pattern": "(?:type|interface)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Rename type or interface"
    },
    {
      "name": "Parameter",
      "pattern": "(?:function\\s+\\w+|=>)\\s*\\(([^)]*)",
      "captureGroup": 1,
      "description": "Rename function parameters"
    },
    {
      "name": "Destructured prop",
      "pattern": "\\{\\s*([a-zA-Z_$][\\w$]*)(?:\\s*[:,}])",
      "captureGroup": 1,
      "description": "Rename destructured variable"
    },
    {
      "name": "Import alias",
      "pattern": "import\\s+(?:\\{[^}]*\\}|\\w+)\\s+from",
      "captureGroup": 0,
      "description": "Rename imported symbol"
    },
    {
      "name": "Enum member",
      "pattern": "^\\s*(\\w+)\\s*[=,]",
      "captureGroup": 1,
      "description": "Rename enum member"
    }
  ]
}
