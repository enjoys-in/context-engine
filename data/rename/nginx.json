{
  "language": "nginx",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_.]*|\\$[a-zA-Z_][a-zA-Z0-9_]*",
  "identifierRules": {
    "start": "[a-zA-Z_$]",
    "continue": "[a-zA-Z0-9_.]",
    "forbidden": [
      "server",
      "location",
      "upstream",
      "http",
      "events",
      "worker_processes",
      "listen",
      "server_name",
      "root",
      "index",
      "proxy_pass",
      "include",
      "error_log",
      "access_log",
      "return",
      "rewrite",
      "if",
      "set",
      "map",
      "geo",
      "limit_req",
      "limit_conn",
      "ssl_certificate",
      "ssl_certificate_key",
      "try_files",
      "error_page",
      "add_header",
      "expires",
      "gzip",
      "sendfile",
      "keepalive_timeout"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_$][a-zA-Z0-9_.]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\$(\\w+)",
      "captureGroup": 1,
      "description": "Nginx variable"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Directive or named value"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
