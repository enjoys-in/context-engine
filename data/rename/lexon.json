{
  "language": "lexon",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_ ]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_ ]",
    "forbidden": [
      "LEX", "CLAUSE", "TERM", "TERMS", "CONDITION", "PROVIDED", "SHALL",
      "MAY", "IS", "BE", "NO", "THE", "A", "AN", "DEFINED", "AS",
      "MEANS", "INCLUDES", "EXCLUDES", "PARTY", "AMOUNT", "DATE",
      "PERCENT", "FIXED", "PER", "ANNUM", "TRUE", "FALSE"
    ]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_ ]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\"([^\"]+)\"",
      "captureGroup": 1,
      "description": "Lexon quoted term"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Lexon identifier"
    }
  ]
}
