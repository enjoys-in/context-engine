{
  "language": "toml",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_-]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_-]",
    "forbidden": ["true", "false", "inf", "nan"]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_-]*$|^\"[^\"]+\"$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\[\\[?([a-zA-Z_][a-zA-Z0-9_.\\-]*)\\]\\]?",
      "captureGroup": 1,
      "description": "Table or array-of-tables header"
    },
    {
      "pattern": "^([a-zA-Z_][a-zA-Z0-9_-]*)\\s*=",
      "captureGroup": 1,
      "description": "Key name"
    }
  ]
}
