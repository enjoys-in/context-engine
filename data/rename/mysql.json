{
  "language": "mysql",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*|`[^`]+`",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": ["SELECT", "FROM", "WHERE", "INSERT", "UPDATE", "DELETE", "CREATE", "DROP", "ALTER", "TABLE", "INDEX", "VIEW", "DATABASE", "JOIN", "INNER", "LEFT", "RIGHT", "OUTER", "ON", "AND", "OR", "NOT", "NULL", "IS", "IN", "BETWEEN", "LIKE", "ORDER", "BY", "GROUP", "HAVING", "LIMIT", "OFFSET", "UNION", "AS", "SET", "VALUES", "INTO", "DISTINCT", "COUNT", "SUM", "AVG", "MAX", "MIN", "IF", "ELSE", "THEN", "WHEN", "CASE", "END", "BEGIN", "DECLARE", "PROCEDURE", "FUNCTION", "TRIGGER", "PRIMARY", "KEY", "FOREIGN", "REFERENCES", "CONSTRAINT", "DEFAULT", "AUTO_INCREMENT", "INT", "VARCHAR", "TEXT", "BOOLEAN", "DATE", "TIMESTAMP"]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 64,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$|^`[^`]+`$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "`([^`]+)`",
      "captureGroup": 1,
      "description": "Backtick-quoted identifier"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Unquoted identifier (table, column, alias, variable)"
    }
  ]
}
