{
  "language": "st",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": ["self", "super", "true", "false", "nil", "thisContext", "Transcript", "Array", "OrderedCollection", "Dictionary", "Set", "Bag", "String", "Symbol", "Number", "Integer", "Float", "Character", "Boolean", "True", "False", "UndefinedObject", "Object", "Class", "Metaclass", "Block", "Message", "Compiler", "SmallInteger", "LargePositiveInteger", "LargeNegativeInteger"]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Variable, method, class, or message name"
    }
  ]
}
