{
  "language": "ecl",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": [
      "BOOLEAN",
      "INTEGER",
      "UNSIGNED",
      "REAL",
      "DECIMAL",
      "STRING",
      "QSTRING",
      "UNICODE",
      "DATA",
      "VARSTRING",
      "VARUNICODE",
      "RECORD",
      "END",
      "SET",
      "OF",
      "DATASET",
      "OUTPUT",
      "EXPORT",
      "IMPORT",
      "MODULE",
      "INTERFACE",
      "FUNCTION",
      "MACRO",
      "ENDMACRO",
      "IF",
      "THEN",
      "ELSE",
      "ELSEIF",
      "ENDIF",
      "MAP",
      "CASE",
      "CHOOSE",
      "WHICH",
      "REJECTED",
      "TRANSFORM",
      "PROJECT",
      "JOIN",
      "SORT",
      "GROUP",
      "TABLE",
      "DEDUP",
      "ROLLUP",
      "SELF",
      "LEFT",
      "RIGHT",
      "COUNTER",
      "ROWS",
      "XMLPROJECT"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*:=",
      "captureGroup": 1,
      "description": "ECL definition assignment"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "ECL identifier"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
