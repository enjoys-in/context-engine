{
  "language": "javascript",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "identifierRules": {
    "start": "[a-zA-Z_$]",
    "continue": "[a-zA-Z0-9_$]",
    "forbidden": [
      "abstract",
      "arguments",
      "async",
      "await",
      "boolean",
      "break",
      "byte",
      "case",
      "catch",
      "char",
      "class",
      "const",
      "continue",
      "debugger",
      "default",
      "delete",
      "do",
      "double",
      "else",
      "enum",
      "eval",
      "export",
      "extends",
      "false",
      "final",
      "finally",
      "float",
      "for",
      "function",
      "goto",
      "if",
      "implements",
      "import",
      "in",
      "instanceof",
      "int",
      "interface",
      "let",
      "long",
      "native",
      "new",
      "null",
      "of",
      "package",
      "private",
      "protected",
      "public",
      "return",
      "short",
      "static",
      "super",
      "switch",
      "synchronized",
      "this",
      "throw",
      "throws",
      "transient",
      "true",
      "try",
      "typeof",
      "undefined",
      "var",
      "void",
      "volatile",
      "while",
      "with",
      "yield"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_$][a-zA-Z0-9_$]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\b(?:function|class)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)",
      "captureGroup": 1,
      "description": "JavaScript function or class declaration"
    },
    {
      "pattern": "\\b(?:const|let|var)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)",
      "captureGroup": 1,
      "description": "JavaScript variable declaration"
    },
    {
      "pattern": "\\b([a-zA-Z_$][a-zA-Z0-9_$]*)\\b",
      "captureGroup": 1,
      "description": "JavaScript identifier"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
