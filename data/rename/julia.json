{
  "language": "julia",
  "wordPattern": "[a-zA-Z_\\u00A1-\\uFFFF][a-zA-Z0-9_!\\u00A1-\\uFFFF]*",
  "identifierRules": {
    "start": "[a-zA-Z_\\u00A1-\\uFFFF]",
    "continue": "[a-zA-Z0-9_!\\u00A1-\\uFFFF]",
    "forbidden": [
      "baremodule",
      "begin",
      "break",
      "catch",
      "const",
      "continue",
      "do",
      "else",
      "elseif",
      "end",
      "export",
      "false",
      "finally",
      "for",
      "function",
      "global",
      "if",
      "import",
      "in",
      "isa",
      "let",
      "local",
      "macro",
      "module",
      "mutable",
      "new",
      "outer",
      "quote",
      "return",
      "struct",
      "true",
      "try",
      "type",
      "typealias",
      "using",
      "where",
      "while",
      "abstract",
      "primitive",
      "nothing",
      "missing",
      "Inf",
      "NaN"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_!]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\bfunction\\s+([a-zA-Z_][a-zA-Z0-9_!]*)",
      "captureGroup": 1,
      "description": "Julia function definition"
    },
    {
      "pattern": "\\bstruct\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captureGroup": 1,
      "description": "Julia struct definition"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_!]*)\\b",
      "captureGroup": 1,
      "description": "Julia identifier"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
