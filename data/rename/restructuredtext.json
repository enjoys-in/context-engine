{
  "language": "restructuredtext",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_-]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_-]",
    "forbidden": ["image", "figure", "code", "code-block", "contents", "toctree", "include", "raw", "note", "warning", "tip", "important", "danger", "error", "hint", "attention", "caution", "admonition", "topic", "sidebar", "rubric", "epigraph", "highlights", "pull-quote", "container", "class", "role", "default-role"]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_-]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\.\\.\\s+_([a-zA-Z_][a-zA-Z0-9_-]*):",
      "captureGroup": 1,
      "description": "Hyperlink target / anchor label"
    },
    {
      "pattern": ":ref:`([a-zA-Z_][a-zA-Z0-9_-]*)`",
      "captureGroup": 1,
      "description": "Cross-reference label"
    },
    {
      "pattern": "\\|([a-zA-Z_][a-zA-Z0-9_-]*)\\|",
      "captureGroup": 1,
      "description": "Substitution reference"
    }
  ]
}
