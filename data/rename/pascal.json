{
  "language": "pascal",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": [
      "and",
      "array",
      "begin",
      "case",
      "const",
      "div",
      "do",
      "downto",
      "else",
      "end",
      "file",
      "for",
      "function",
      "goto",
      "if",
      "in",
      "label",
      "mod",
      "nil",
      "not",
      "of",
      "or",
      "packed",
      "procedure",
      "program",
      "record",
      "repeat",
      "set",
      "then",
      "to",
      "type",
      "unit",
      "until",
      "uses",
      "var",
      "while",
      "with",
      "interface",
      "implementation",
      "class",
      "object",
      "constructor",
      "destructor",
      "inherited",
      "property",
      "try",
      "except",
      "finally",
      "raise"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Variable, procedure, function, type, or unit name"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
