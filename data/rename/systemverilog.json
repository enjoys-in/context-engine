{
  "language": "systemverilog",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_$]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_$]",
    "forbidden": ["always", "always_comb", "always_ff", "always_latch", "and", "assign", "automatic", "begin", "bit", "buf", "byte", "case", "casex", "casez", "class", "clocking", "constraint", "covergroup", "coverpoint", "default", "defparam", "disable", "do", "edge", "else", "end", "endcase", "endclass", "endclocking", "endfunction", "endgenerate", "endinterface", "endmodule", "endpackage", "endprimitive", "endprogram", "endproperty", "endsequence", "endtable", "endtask", "enum", "event", "export", "extends", "extern", "final", "for", "force", "foreach", "forever", "fork", "function", "generate", "if", "import", "initial", "input", "int", "integer", "interface", "join", "logic", "longint", "module", "nand", "negedge", "new", "nor", "not", "or", "output", "package", "parameter", "posedge", "primitive", "program", "property", "rand", "randc", "real", "reg", "repeat", "return", "sequence", "shortint", "signed", "static", "string", "struct", "super", "task", "this", "time", "typedef", "union", "unique", "unsigned", "var", "virtual", "void", "wait", "while", "wire", "with", "xnor", "xor"]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_$]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_$]*)\\b",
      "captureGroup": 1,
      "description": "Module, variable, signal, port, function, task, class, or type name"
    }
  ]
}
