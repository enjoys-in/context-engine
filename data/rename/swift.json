{
  "language": "swift",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*|`[a-zA-Z_][a-zA-Z0-9_]*`",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": ["associatedtype", "class", "deinit", "enum", "extension", "fileprivate", "func", "import", "init", "inout", "internal", "let", "open", "operator", "private", "precedencegroup", "protocol", "public", "rethrows", "static", "struct", "subscript", "typealias", "var", "break", "case", "catch", "continue", "default", "defer", "do", "else", "fallthrough", "for", "guard", "if", "in", "repeat", "return", "switch", "throw", "try", "where", "while", "as", "Any", "false", "is", "nil", "self", "Self", "super", "throws", "true", "async", "await", "actor", "some", "any", "macro"]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$|^`[a-zA-Z_][a-zA-Z0-9_]*`$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "`([a-zA-Z_][a-zA-Z0-9_]*)`",
      "captureGroup": 1,
      "description": "Backtick-escaped identifier"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Variable, function, class, struct, enum, protocol, or type name"
    }
  ]
}
