{
  "language": "ignore",
  "displayName": "Ignore Files",
  "capabilities": {
    "rename": true,
    "prepareRename": true
  },
  "supportedSymbols": [
    "variable",
    "function",
    "class",
    "method",
    "property",
    "parameter",
    "type",
    "interface",
    "enum",
    "constant",
    "module"
  ],
  "validationRules": {
    "identifierPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
    "reservedWords": [
      ".gitignore",
      ".dockerignore",
      ".npmignore",
      "#",
      "!",
      "*",
      "**",
      "?"
    ],
    "caseSensitive": true
  }
}
