{
  "language": "prisma",
  "displayName": "Prisma",
  "capabilities": {
    "rename": true,
    "prepareRename": true
  },
  "supportedSymbols": [
    "variable",
    "function",
    "class",
    "method",
    "property",
    "parameter",
    "type",
    "interface",
    "enum",
    "constant",
    "module"
  ],
  "validationRules": {
    "identifierPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
    "reservedWords": [
      "model",
      "enum",
      "datasource",
      "generator",
      "@id",
      "@unique",
      "@relation",
      "@default",
      "@map",
      "@updatedAt"
    ],
    "caseSensitive": true
  }
}
