{
  "language": "cypher",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*|`[^`]+`",
  "identifierRules": {
    "start": "[a-zA-Z_`]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": [
      "MATCH",
      "OPTIONAL",
      "WHERE",
      "RETURN",
      "WITH",
      "UNWIND",
      "ORDER",
      "BY",
      "SKIP",
      "LIMIT",
      "CREATE",
      "DELETE",
      "DETACH",
      "SET",
      "REMOVE",
      "MERGE",
      "ON",
      "CALL",
      "YIELD",
      "UNION",
      "ALL",
      "AS",
      "AND",
      "OR",
      "NOT",
      "IN",
      "IS",
      "NULL",
      "TRUE",
      "FALSE",
      "EXISTS",
      "CASE",
      "WHEN",
      "THEN",
      "ELSE",
      "END",
      "DISTINCT",
      "FOREACH",
      "LOAD",
      "CSV",
      "FROM",
      "CONSTRAINT",
      "INDEX",
      "DROP",
      "STARTS",
      "ENDS",
      "CONTAINS"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\(([a-zA-Z_][a-zA-Z0-9_]*)(?::[a-zA-Z_][a-zA-Z0-9_]*)?\\)",
      "captureGroup": 1,
      "description": "Cypher node variable"
    },
    {
      "pattern": "\\[([a-zA-Z_][a-zA-Z0-9_]*)(?::[a-zA-Z_][a-zA-Z0-9_]*)?\\]",
      "captureGroup": 1,
      "description": "Cypher relationship variable"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Cypher identifier"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
