{
  "language": "redshift",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*|\"[^\"]+\"",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": ["SELECT", "FROM", "WHERE", "INSERT", "UPDATE", "DELETE", "CREATE", "DROP", "ALTER", "TABLE", "VIEW", "SCHEMA", "DATABASE", "JOIN", "INNER", "LEFT", "RIGHT", "FULL", "OUTER", "CROSS", "ON", "AND", "OR", "NOT", "NULL", "IS", "IN", "BETWEEN", "LIKE", "ORDER", "BY", "GROUP", "HAVING", "LIMIT", "UNION", "ALL", "AS", "SET", "VALUES", "INTO", "DISTINCT", "WITH", "CASE", "WHEN", "THEN", "ELSE", "END", "EXISTS", "COPY", "UNLOAD", "VACUUM", "ANALYZE", "GRANT", "REVOKE", "DISTKEY", "SORTKEY", "DISTSTYLE", "INTERLEAVED", "ENCODE", "IDENTITY", "DEFAULT", "PRIMARY", "KEY", "FOREIGN", "REFERENCES"]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 127,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$|^\"[^\"]+\"$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\"([^\"]+)\"",
      "captureGroup": 1,
      "description": "Double-quoted identifier"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Unquoted identifier (table, column, schema)"
    }
  ]
}
