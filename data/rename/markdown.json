{
  "language": "markdown",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_-]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_-]",
    "forbidden": []
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[^\\[\\]()]+$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\[([^\\]]+)\\]\\([^)]+\\)",
      "captureGroup": 1,
      "description": "Markdown link text"
    },
    {
      "pattern": "\\[([^\\]]+)\\]:\\s+",
      "captureGroup": 1,
      "description": "Markdown reference link label"
    },
    {
      "pattern": "#{1,6}\\s+(.+)$",
      "captureGroup": 1,
      "description": "Markdown heading text"
    }
  ]
}
