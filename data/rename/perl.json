{
  "language": "perl",
  "wordPattern": "[\\$@%&*][a-zA-Z_][a-zA-Z0-9_]*(?:::[a-zA-Z_][a-zA-Z0-9_]*)*|[a-zA-Z_][a-zA-Z0-9_]*",
  "identifierRules": {
    "start": "[a-zA-Z_$@%&*]",
    "continue": "[a-zA-Z0-9_:]",
    "forbidden": [
      "use",
      "my",
      "our",
      "local",
      "sub",
      "if",
      "elsif",
      "else",
      "unless",
      "while",
      "until",
      "for",
      "foreach",
      "do",
      "return",
      "last",
      "next",
      "redo",
      "goto",
      "die",
      "warn",
      "print",
      "say",
      "chomp",
      "chop",
      "push",
      "pop",
      "shift",
      "unshift",
      "splice",
      "package",
      "require",
      "BEGIN",
      "END",
      "eval",
      "exec",
      "system",
      "open",
      "close",
      "read",
      "write",
      "defined",
      "undef",
      "exists",
      "delete",
      "keys",
      "values",
      "each",
      "map",
      "grep",
      "sort",
      "reverse",
      "join",
      "split",
      "qw",
      "qq",
      "qr"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[\\$@%&*]?[a-zA-Z_][a-zA-Z0-9_]*(?:::[a-zA-Z_][a-zA-Z0-9_]*)*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "([\\$@%])([a-zA-Z_][a-zA-Z0-9_]*(?:::[a-zA-Z_][a-zA-Z0-9_]*)*)",
      "captureGroup": 2,
      "description": "Sigiled variable ($scalar, @array, %hash)"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Subroutine or bareword identifier"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
