{
  "language": "caddy",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_.-]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_.-]",
    "forbidden": [
      "http",
      "https",
      "tls",
      "encode",
      "file_server",
      "reverse_proxy",
      "header",
      "redir",
      "rewrite",
      "respond",
      "root",
      "try_files",
      "php_fastcgi",
      "basicauth",
      "log",
      "import",
      "handle",
      "handle_path",
      "route",
      "abort",
      "bind",
      "error",
      "map",
      "method",
      "metrics",
      "push",
      "request_body",
      "request_header",
      "templates",
      "tracing",
      "uri",
      "vars"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_.-]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\{([a-zA-Z_][a-zA-Z0-9_.]*)\\}",
      "captureGroup": 1,
      "description": "Caddy placeholder variable"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_.-]*)\\b",
      "captureGroup": 1,
      "description": "Caddy directive or site address"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
