{
  "language": "cameligo",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_']*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_']",
    "forbidden": [
      "let",
      "in",
      "if",
      "then",
      "else",
      "match",
      "with",
      "fun",
      "rec",
      "type",
      "of",
      "begin",
      "end",
      "module",
      "struct",
      "sig",
      "val",
      "and",
      "or",
      "not",
      "true",
      "false",
      "mod",
      "land",
      "lor",
      "lxor",
      "lsl",
      "lsr",
      "asr"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_']*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\blet\\s+([a-zA-Z_][a-zA-Z0-9_']*)",
      "captureGroup": 1,
      "description": "CameLIGO let binding name"
    },
    {
      "pattern": "\\btype\\s+([a-zA-Z_][a-zA-Z0-9_']*)",
      "captureGroup": 1,
      "description": "CameLIGO type definition name"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_']*)\\b",
      "captureGroup": 1,
      "description": "CameLIGO identifier"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
