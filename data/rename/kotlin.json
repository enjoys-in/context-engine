{
  "language": "kotlin",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*|`[^`]+`",
  "identifierRules": {
    "start": "[a-zA-Z_`]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": [
      "abstract",
      "actual",
      "annotation",
      "as",
      "break",
      "by",
      "catch",
      "class",
      "companion",
      "const",
      "constructor",
      "continue",
      "crossinline",
      "data",
      "delegate",
      "do",
      "dynamic",
      "else",
      "enum",
      "expect",
      "external",
      "false",
      "field",
      "final",
      "finally",
      "for",
      "fun",
      "get",
      "if",
      "import",
      "in",
      "infix",
      "init",
      "inline",
      "inner",
      "interface",
      "internal",
      "is",
      "it",
      "lateinit",
      "noinline",
      "null",
      "object",
      "open",
      "operator",
      "out",
      "override",
      "package",
      "param",
      "private",
      "property",
      "protected",
      "public",
      "reified",
      "return",
      "sealed",
      "set",
      "setparam",
      "super",
      "suspend",
      "tailrec",
      "this",
      "throw",
      "true",
      "try",
      "typealias",
      "typeof",
      "val",
      "value",
      "var",
      "vararg",
      "when",
      "where",
      "while"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\b(?:fun|class|interface|object|val|var)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captureGroup": 1,
      "description": "Kotlin declaration name"
    },
    {
      "pattern": "`([^`]+)`",
      "captureGroup": 1,
      "description": "Kotlin backtick-escaped identifier"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Kotlin identifier"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
