{
  "language": "postiats",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_']*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_']",
    "forbidden": ["abstype", "abst0ype", "absvtype", "absvt0ype", "and", "assume", "begin", "case", "classdec", "datasort", "datatype", "datavtype", "do", "dynload", "else", "end", "exception", "extern", "fix", "fn", "for", "fun", "if", "implement", "implmnt", "in", "include", "infix", "infixl", "infixr", "lam", "let", "llam", "local", "macdef", "nonfix", "of", "op", "overload", "prfn", "prfun", "prval", "reassume", "rec", "scase", "sif", "sortdef", "sta", "stadef", "staload", "stavar", "then", "try", "tkindef", "typedef", "val", "var", "when", "where", "while", "with", "withtype"]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_']*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_']*)\\b",
      "captureGroup": 1,
      "description": "Variable, function, type, or sort name"
    }
  ]
}
