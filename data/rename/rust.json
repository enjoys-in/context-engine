{
  "language": "rust",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": [
      "as",
      "async",
      "await",
      "break",
      "const",
      "continue",
      "crate",
      "dyn",
      "else",
      "enum",
      "extern",
      "false",
      "fn",
      "for",
      "if",
      "impl",
      "in",
      "let",
      "loop",
      "match",
      "mod",
      "move",
      "mut",
      "pub",
      "ref",
      "return",
      "self",
      "Self",
      "static",
      "struct",
      "super",
      "trait",
      "true",
      "type",
      "unsafe",
      "use",
      "where",
      "while",
      "abstract",
      "become",
      "box",
      "do",
      "final",
      "macro",
      "override",
      "priv",
      "try",
      "typeof",
      "unsized",
      "virtual",
      "yield"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Variable, function, struct, enum, trait, type, or module name"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
