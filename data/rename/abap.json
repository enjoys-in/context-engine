{
  "language": "abap",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": [
      "REPORT", "DATA", "TYPE", "TYPES", "CLASS", "METHOD", "METHODS", "ENDCLASS",
      "ENDMETHOD", "IF", "ELSE", "ELSEIF", "ENDIF", "DO", "ENDDO", "WHILE",
      "ENDWHILE", "LOOP", "ENDLOOP", "FORM", "ENDFORM", "FUNCTION", "ENDFUNCTION",
      "MODULE", "ENDMODULE", "SELECT", "ENDSELECT", "WRITE", "MOVE", "CALL",
      "PERFORM", "TABLES", "APPEND", "READ", "MODIFY", "DELETE", "INSERT",
      "CLEAR", "REFRESH", "SORT", "DESCRIBE", "IMPORT", "EXPORT", "RAISING"
    ]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 30,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "ABAP variable, type, or method name"
    }
  ]
}
