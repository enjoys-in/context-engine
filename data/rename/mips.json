{
  "language": "mips",
  "wordPattern": "\\$?[a-zA-Z_][a-zA-Z0-9_]*",
  "identifierRules": {
    "start": "[a-zA-Z_$]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": [
      "add",
      "addi",
      "addiu",
      "addu",
      "and",
      "andi",
      "beq",
      "bgez",
      "bgtz",
      "blez",
      "bltz",
      "bne",
      "div",
      "divu",
      "j",
      "jal",
      "jalr",
      "jr",
      "lb",
      "lbu",
      "lh",
      "lhu",
      "lui",
      "lw",
      "mfhi",
      "mflo",
      "mult",
      "multu",
      "nop",
      "nor",
      "or",
      "ori",
      "sb",
      "sh",
      "sll",
      "sllv",
      "slt",
      "slti",
      "sltiu",
      "sltu",
      "sra",
      "srav",
      "srl",
      "srlv",
      "sub",
      "subu",
      "sw",
      "syscall",
      "xor",
      "xori",
      "la",
      "li",
      "move",
      "blt",
      "bgt",
      "ble",
      "bge",
      ".text",
      ".data",
      ".globl",
      ".word",
      ".byte",
      ".half",
      ".space",
      ".ascii",
      ".asciiz",
      ".align"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^\\$?[a-zA-Z_][a-zA-Z0-9_]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "^([a-zA-Z_][a-zA-Z0-9_]*):",
      "captureGroup": 1,
      "description": "MIPS label definition"
    },
    {
      "pattern": "(\\$[a-zA-Z_][a-zA-Z0-9_]*)",
      "captureGroup": 1,
      "description": "MIPS register reference"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "MIPS identifier or label reference"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
