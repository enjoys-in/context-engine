{
  "language": "powerquery",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_.]*|#\"[^\"]+\"",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_.]",
    "forbidden": [
      "and",
      "as",
      "each",
      "else",
      "error",
      "false",
      "if",
      "in",
      "is",
      "let",
      "meta",
      "not",
      "null",
      "or",
      "otherwise",
      "section",
      "shared",
      "then",
      "true",
      "try",
      "type",
      "optional",
      "nullable",
      "table",
      "record",
      "list",
      "text",
      "number",
      "logical",
      "date",
      "time",
      "datetime",
      "datetimezone",
      "duration",
      "binary",
      "any",
      "none",
      "function"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_.]*$|^#\"[^\"]+\"$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "#\"([^\"]+)\"",
      "captureGroup": 1,
      "description": "Quoted identifier"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_.]*)\\b",
      "captureGroup": 1,
      "description": "Variable, function, or step name"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
