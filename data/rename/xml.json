{
  "language": "xml",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_.:/-]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_.:-]",
    "forbidden": [
      "xml",
      "xmlns",
      "xsi",
      "xsd",
      "xsl",
      "xlink",
      "CDATA",
      "DOCTYPE",
      "ELEMENT",
      "ATTLIST",
      "ENTITY",
      "NOTATION",
      "SYSTEM",
      "PUBLIC",
      "NDATA",
      "REQUIRED",
      "IMPLIED",
      "FIXED",
      "PCDATA",
      "ANY",
      "EMPTY"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_.:-]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "</?([a-zA-Z_][a-zA-Z0-9_.:-]*)",
      "captureGroup": 1,
      "description": "Element tag name"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_.:-]*)\\s*=",
      "captureGroup": 1,
      "description": "Attribute name"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
