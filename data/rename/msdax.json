{
  "language": "msdax",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*|\\[[^\\]]+\\]",
  "identifierRules": {
    "start": "[a-zA-Z_\\[]",
    "continue": "[a-zA-Z0-9_ ]",
    "forbidden": [
      "EVALUATE",
      "DEFINE",
      "MEASURE",
      "VAR",
      "RETURN",
      "ORDER",
      "BY",
      "ASC",
      "DESC",
      "TABLE",
      "COLUMN",
      "ROW",
      "TRUE",
      "FALSE",
      "BLANK",
      "CALCULATE",
      "CALCULATETABLE",
      "FILTER",
      "ALL",
      "ALLEXCEPT",
      "ALLSELECTED",
      "VALUES",
      "DISTINCT",
      "RELATED",
      "RELATEDTABLE",
      "SUMMARIZE",
      "SUMMARIZECOLUMNS",
      "ADDCOLUMNS",
      "SELECTCOLUMNS",
      "TOPN",
      "GENERATE",
      "GENERATEALL",
      "CROSSJOIN",
      "UNION",
      "INTERSECT",
      "EXCEPT",
      "DATATABLE",
      "IF",
      "SWITCH",
      "AND",
      "OR",
      "NOT",
      "IN",
      "SUM",
      "AVERAGE",
      "MIN",
      "MAX",
      "COUNT",
      "COUNTA",
      "COUNTBLANK",
      "COUNTROWS",
      "DISTINCTCOUNT"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_ ]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\[([^\\]]+)\\]",
      "captureGroup": 1,
      "description": "DAX bracketed column or measure reference"
    },
    {
      "pattern": "\\bVAR\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captureGroup": 1,
      "description": "DAX variable name"
    },
    {
      "pattern": "\\bMEASURE\\s+[^=]+=\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
      "captureGroup": 1,
      "description": "DAX measure name"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "DAX identifier"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
