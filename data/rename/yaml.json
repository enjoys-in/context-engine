{
  "language": "yaml",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_.-]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_.-]",
    "forbidden": [
      "true",
      "false",
      "null",
      "yes",
      "no",
      "on",
      "off",
      "True",
      "False",
      "Null",
      "Yes",
      "No",
      "On",
      "Off",
      "TRUE",
      "FALSE",
      "NULL",
      "YES",
      "NO",
      "ON",
      "OFF"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_.-]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "&([a-zA-Z_][a-zA-Z0-9_.-]*)",
      "captureGroup": 1,
      "description": "Anchor name"
    },
    {
      "pattern": "\\*([a-zA-Z_][a-zA-Z0-9_.-]*)",
      "captureGroup": 1,
      "description": "Alias reference"
    },
    {
      "pattern": "^\\s*([a-zA-Z_][a-zA-Z0-9_.-]*)\\s*:",
      "captureGroup": 1,
      "description": "Mapping key"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
