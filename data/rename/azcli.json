{
  "language": "azcli",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_-]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_-]",
    "forbidden": [
      "az", "group", "account", "login", "logout", "configure", "interactive",
      "feedback", "find", "rest", "version", "upgrade", "extension", "cloud",
      "resource", "vm", "network", "storage", "webapp", "functionapp", "keyvault",
      "monitor", "sql", "cosmosdb", "aks", "acr", "appservice", "batch",
      "cognitiveservices", "eventhubs", "servicebus"
    ]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_-]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "--([a-zA-Z_][a-zA-Z0-9_-]*)",
      "captureGroup": 1,
      "description": "Azure CLI parameter name"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_-]*)\\b",
      "captureGroup": 1,
      "description": "Azure CLI command or variable name"
    }
  ]
}
