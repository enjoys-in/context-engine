{
  "language": "liquid",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_.-]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_.-]",
    "forbidden": [
      "assign",
      "capture",
      "endcapture",
      "case",
      "endcase",
      "when",
      "comment",
      "endcomment",
      "cycle",
      "decrement",
      "for",
      "endfor",
      "if",
      "endif",
      "else",
      "elsif",
      "include",
      "render",
      "increment",
      "raw",
      "endraw",
      "tablerow",
      "endtablerow",
      "unless",
      "endunless",
      "contains",
      "in",
      "with",
      "as",
      "break",
      "continue",
      "limit",
      "offset",
      "reversed",
      "true",
      "false",
      "nil",
      "blank",
      "empty"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_.-]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\{%\\s*assign\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*=",
      "captureGroup": 1,
      "description": "Liquid variable assignment"
    },
    {
      "pattern": "\\{\\{\\s*([a-zA-Z_][a-zA-Z0-9_.-]*)\\s*\\}\\}",
      "captureGroup": 1,
      "description": "Liquid output expression"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Liquid identifier"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
