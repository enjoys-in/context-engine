{
  "language": "ssh_config",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_-]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_-]",
    "forbidden": [
      "Host",
      "Match",
      "HostName",
      "User",
      "Port",
      "IdentityFile",
      "IdentitiesOnly",
      "ForwardAgent",
      "ForwardX11",
      "ProxyJump",
      "ProxyCommand",
      "LocalForward",
      "RemoteForward",
      "DynamicForward",
      "ServerAliveInterval",
      "ServerAliveCountMax",
      "StrictHostKeyChecking",
      "UserKnownHostsFile",
      "AddKeysToAgent",
      "Compression",
      "LogLevel",
      "SendEnv",
      "SetEnv",
      "Include",
      "PasswordAuthentication",
      "PubkeyAuthentication",
      "PreferredAuthentications",
      "Ciphers",
      "MACs",
      "KexAlgorithms"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_*?][a-zA-Z0-9_.*?-]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "Host\\s+([a-zA-Z_*?][a-zA-Z0-9_.*?-]*)",
      "captureGroup": 1,
      "description": "Host alias pattern"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_-]*)\\b",
      "captureGroup": 1,
      "description": "Configuration directive or value"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
