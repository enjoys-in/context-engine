{
  "language": "mdx",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "identifierRules": {
    "start": "[a-zA-Z_$]",
    "continue": "[a-zA-Z0-9_$]",
    "forbidden": [
      "import", "export", "default", "from", "as", "const", "let", "var",
      "function", "class", "extends", "return", "if", "else", "for",
      "while", "do", "switch", "case", "break", "continue", "true",
      "false", "null", "undefined", "this", "new", "typeof", "instanceof"
    ]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_$][a-zA-Z0-9_$]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "<([A-Z][a-zA-Z0-9_$]*)",
      "captureGroup": 1,
      "description": "MDX/JSX component name"
    },
    {
      "pattern": "\\b(?:import|export)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)",
      "captureGroup": 1,
      "description": "MDX import/export name"
    },
    {
      "pattern": "\\b([a-zA-Z_$][a-zA-Z0-9_$]*)\\b",
      "captureGroup": 1,
      "description": "MDX identifier"
    }
  ]
}
