{
  "language": "crontab",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": [
      "SHELL", "PATH", "MAILTO", "HOME", "LOGNAME", "CRON_TZ",
      "reboot", "yearly", "annually", "monthly", "weekly", "daily",
      "midnight", "hourly"
    ]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "^([a-zA-Z_][a-zA-Z0-9_]*)\\s*=",
      "captureGroup": 1,
      "description": "Crontab environment variable"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Crontab identifier"
    }
  ]
}
