{
  "language": "json",
  "wordPattern": "\"[^\"]*\"",
  "identifierRules": {
    "start": "[a-zA-Z_$\"]",
    "continue": "[a-zA-Z0-9_$. -]",
    "forbidden": [
      "true", "false", "null"
    ]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[^\"]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\"([^\"]+)\"\\s*:",
      "captureGroup": 1,
      "description": "JSON object key"
    }
  ]
}
