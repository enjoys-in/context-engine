{
  "language": "json",
  "wordPattern": "\"[^\"]*\"",
  "identifierRules": {
    "start": "[a-zA-Z_$\"]",
    "continue": "[a-zA-Z0-9_$. -]",
    "forbidden": [
      "true",
      "false",
      "null"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[^\"]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\"([^\"]+)\"\\s*:",
      "captureGroup": 1,
      "description": "JSON object key"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
