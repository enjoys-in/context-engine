{
  "language": "r",
  "wordPattern": "[a-zA-Z_.][a-zA-Z0-9_.]*",
  "identifierRules": {
    "start": "[a-zA-Z_.]",
    "continue": "[a-zA-Z0-9_.]",
    "forbidden": ["if", "else", "repeat", "while", "function", "for", "in", "next", "break", "TRUE", "FALSE", "NULL", "Inf", "NaN", "NA", "NA_integer_", "NA_real_", "NA_complex_", "NA_character_", "return", "invisible", "library", "require", "source", "list", "c", "data.frame", "matrix", "vector", "factor", "class", "switch"]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_.][a-zA-Z0-9_.]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\b([a-zA-Z_.][a-zA-Z0-9_.]*)\\b",
      "captureGroup": 1,
      "description": "Variable, function, or parameter name"
    }
  ]
}
