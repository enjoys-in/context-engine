{
  "language": "html",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_-]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_-]",
    "forbidden": [
      "html", "head", "body", "div", "span", "p", "a", "img", "input",
      "button", "form", "table", "tr", "td", "th", "ul", "ol", "li",
      "script", "style", "link", "meta", "title", "header", "footer",
      "nav", "main", "section", "article", "aside", "template", "slot",
      "canvas", "video", "audio", "source", "iframe"
    ]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_-]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "id\\s*=\\s*[\"']([a-zA-Z_][a-zA-Z0-9_-]*)[\"']",
      "captureGroup": 1,
      "description": "HTML element id attribute"
    },
    {
      "pattern": "class\\s*=\\s*[\"']([a-zA-Z_][a-zA-Z0-9_ -]*)[\"']",
      "captureGroup": 1,
      "description": "HTML element class attribute"
    },
    {
      "pattern": "</?([a-zA-Z_][a-zA-Z0-9_-]*)",
      "captureGroup": 1,
      "description": "HTML tag name"
    }
  ]
}
