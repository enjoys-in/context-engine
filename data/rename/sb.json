{
  "language": "sb",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": ["If", "Then", "Else", "ElseIf", "EndIf", "While", "EndWhile", "For", "To", "Step", "EndFor", "Sub", "EndSub", "Goto", "And", "Or", "Not", "TextWindow", "GraphicsWindow", "Math", "Array", "Stack", "Clock", "Desktop", "Dictionary", "File", "Flickr", "ImageList", "Mouse", "Network", "Program", "Shapes", "Sound", "Text", "Timer", "Turtle", "Controls"]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Variable or subroutine name"
    }
  ]
}
