{
  "language": "redis-cli",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_:.-]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_:.-]",
    "forbidden": [
      "GET",
      "SET",
      "DEL",
      "EXISTS",
      "KEYS",
      "EXPIRE",
      "TTL",
      "PERSIST",
      "RENAME",
      "TYPE",
      "HGET",
      "HSET",
      "HDEL",
      "HGETALL",
      "HMSET",
      "HMGET",
      "LPUSH",
      "RPUSH",
      "LPOP",
      "RPOP",
      "LRANGE",
      "LLEN",
      "SADD",
      "SREM",
      "SMEMBERS",
      "SISMEMBER",
      "ZADD",
      "ZREM",
      "ZRANGE",
      "ZSCORE",
      "PUBLISH",
      "SUBSCRIBE",
      "UNSUBSCRIBE",
      "MULTI",
      "EXEC",
      "DISCARD",
      "WATCH",
      "UNWATCH",
      "PING",
      "AUTH",
      "SELECT",
      "INFO",
      "CONFIG",
      "FLUSHDB",
      "FLUSHALL",
      "DBSIZE",
      "SCAN",
      "HSCAN",
      "SSCAN",
      "ZSCAN",
      "CLUSTER",
      "SENTINEL"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 512,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_:.-]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_:.-]*)\\b",
      "captureGroup": 1,
      "description": "Key name or variable in CLI context"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
