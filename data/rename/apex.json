{
  "language": "apex",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": [
      "abstract",
      "after",
      "before",
      "break",
      "catch",
      "class",
      "continue",
      "delete",
      "do",
      "else",
      "enum",
      "extends",
      "final",
      "finally",
      "for",
      "global",
      "if",
      "implements",
      "import",
      "insert",
      "instanceof",
      "interface",
      "merge",
      "new",
      "null",
      "on",
      "override",
      "private",
      "protected",
      "public",
      "return",
      "static",
      "super",
      "switch",
      "testmethod",
      "this",
      "throw",
      "transient",
      "trigger",
      "try",
      "undelete",
      "update",
      "upsert",
      "virtual",
      "void",
      "webservice",
      "while",
      "with",
      "without"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Apex class, method, variable, or field name"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
