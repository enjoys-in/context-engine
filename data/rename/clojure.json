{
  "language": "clojure",
  "wordPattern": "[a-zA-Z_*+!?<>=.-][a-zA-Z0-9_*+!?<>=./-]*",
  "identifierRules": {
    "start": "[a-zA-Z_*+!?<>=.-]",
    "continue": "[a-zA-Z0-9_*+!?<>=./-]",
    "forbidden": [
      "def",
      "defn",
      "defmacro",
      "defmethod",
      "defmulti",
      "defonce",
      "defprotocol",
      "defrecord",
      "defstruct",
      "deftype",
      "fn",
      "if",
      "do",
      "let",
      "loop",
      "recur",
      "throw",
      "try",
      "catch",
      "finally",
      "monitor-enter",
      "monitor-exit",
      "quote",
      "var",
      "import",
      "new",
      "set!",
      "nil",
      "true",
      "false",
      "ns",
      "in-ns",
      "require",
      "use",
      "refer",
      "cond",
      "case",
      "when",
      "when-not",
      "and",
      "or",
      "not"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_*+!?<>=.-][a-zA-Z0-9_*+!?<>=./-]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\(def[n]?\\s+([a-zA-Z_*+!?<>=.-][a-zA-Z0-9_*+!?<>=./-]*)",
      "captureGroup": 1,
      "description": "Clojure def/defn binding name"
    },
    {
      "pattern": "([a-zA-Z_*+!?<>=.-][a-zA-Z0-9_*+!?<>=./-]*)",
      "captureGroup": 1,
      "description": "Clojure symbol"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
