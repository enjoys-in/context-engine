{
  "language": "razor",
  "wordPattern": "@?[a-zA-Z_][a-zA-Z0-9_]*",
  "identifierRules": {
    "start": "[a-zA-Z_@]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": [
      "@model",
      "@page",
      "@using",
      "@inject",
      "@inherits",
      "@functions",
      "@code",
      "@section",
      "@layout",
      "@implements",
      "@attribute",
      "@namespace",
      "@addTagHelper",
      "@removeTagHelper",
      "@tagHelperPrefix",
      "if",
      "else",
      "for",
      "foreach",
      "while",
      "do",
      "switch",
      "case",
      "break",
      "continue",
      "return",
      "try",
      "catch",
      "finally",
      "throw",
      "using",
      "lock",
      "await"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^@?[a-zA-Z_][a-zA-Z0-9_]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "@([a-zA-Z_][a-zA-Z0-9_]*)",
      "captureGroup": 1,
      "description": "Razor directive or expression variable"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "C# variable, method, class, or property name"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
