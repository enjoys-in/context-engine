{
  "language": "shell",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*|\\$[a-zA-Z_][a-zA-Z0-9_]*|\\$\\{[a-zA-Z_][a-zA-Z0-9_]*\\}",
  "identifierRules": {
    "start": "[a-zA-Z_$]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": [
      "if",
      "then",
      "else",
      "elif",
      "fi",
      "for",
      "while",
      "until",
      "do",
      "done",
      "case",
      "esac",
      "in",
      "function",
      "select",
      "time",
      "coproc",
      "break",
      "continue",
      "return",
      "exit",
      "export",
      "readonly",
      "local",
      "declare",
      "typeset",
      "unset",
      "shift",
      "trap",
      "eval",
      "exec",
      "source",
      "alias",
      "unalias",
      "set",
      "true",
      "false",
      "setopt",
      "unsetopt",
      "autoload",
      "zmodload",
      "zstyle",
      "compdef",
      "compadd",
      "compctl",
      "bindkey",
      "zle",
      "emulate",
      "foreach",
      "end",
      "repeat",
      "always",
      "nocorrect",
      "noglob"
    ]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^\\$?[a-zA-Z_][a-zA-Z0-9_]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\$\\{([a-zA-Z_][a-zA-Z0-9_]*)\\}",
      "captureGroup": 1,
      "description": "Brace-expanded variable"
    },
    {
      "pattern": "\\$([a-zA-Z_][a-zA-Z0-9_]*)",
      "captureGroup": 1,
      "description": "Shell variable reference"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Function or variable name"
    },
    {
      "pattern": "\\$\\{?([a-zA-Z_][a-zA-Z0-9_]*)\\}?",
      "captureGroup": 1,
      "description": "Shell variable reference"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(\\)",
      "captureGroup": 1,
      "description": "Shell function definition"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)=",
      "captureGroup": 1,
      "description": "Shell variable assignment"
    }
  ]
}
