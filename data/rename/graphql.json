{
  "language": "graphql",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": [
      "query", "mutation", "subscription", "fragment", "on", "type", "interface",
      "union", "enum", "scalar", "input", "extend", "schema", "directive",
      "implements", "repeatable", "true", "false", "null", "Int", "Float",
      "String", "Boolean", "ID"
    ]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\btype\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captureGroup": 1,
      "description": "GraphQL type name"
    },
    {
      "pattern": "\\b(?:query|mutation|subscription)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captureGroup": 1,
      "description": "GraphQL operation name"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*:",
      "captureGroup": 1,
      "description": "GraphQL field name"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "GraphQL identifier"
    }
  ]
}
