{
  "language": "qsharp",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": [
      "body",
      "adjoint",
      "controlled",
      "operation",
      "function",
      "newtype",
      "namespace",
      "open",
      "as",
      "if",
      "elif",
      "else",
      "repeat",
      "until",
      "fixup",
      "for",
      "in",
      "while",
      "return",
      "fail",
      "within",
      "apply",
      "use",
      "borrow",
      "let",
      "mutable",
      "set",
      "true",
      "false",
      "not",
      "and",
      "or",
      "Qubit",
      "Result",
      "Zero",
      "One",
      "Pauli",
      "PauliI",
      "PauliX",
      "PauliY",
      "PauliZ",
      "Int",
      "Double",
      "Bool",
      "String",
      "Unit",
      "Range"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Operation, function, variable, type, or namespace name"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
