{
  "language": "scss",
  "wordPattern": "\\$[a-zA-Z_][a-zA-Z0-9_-]*|[a-zA-Z_][a-zA-Z0-9_-]*|%[a-zA-Z_][a-zA-Z0-9_-]*",
  "identifierRules": {
    "start": "[a-zA-Z_$%]",
    "continue": "[a-zA-Z0-9_-]",
    "forbidden": [
      "@import",
      "@use",
      "@forward",
      "@mixin",
      "@include",
      "@function",
      "@return",
      "@if",
      "@else",
      "@each",
      "@for",
      "@while",
      "@extend",
      "@at-root",
      "@error",
      "@warn",
      "@debug",
      "@media",
      "@supports",
      "@keyframes",
      "@font-face",
      "@charset",
      "true",
      "false",
      "null",
      "from",
      "through",
      "to",
      "in",
      "not",
      "and",
      "or"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[$%]?[a-zA-Z_][a-zA-Z0-9_-]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "(\\$[a-zA-Z_][a-zA-Z0-9_-]*)",
      "captureGroup": 1,
      "description": "SCSS variable"
    },
    {
      "pattern": "(%[a-zA-Z_][a-zA-Z0-9_-]*)",
      "captureGroup": 1,
      "description": "Placeholder selector"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_-]*)\\b",
      "captureGroup": 1,
      "description": "Mixin, function, or class name"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
