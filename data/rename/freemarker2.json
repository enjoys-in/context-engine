{
  "language": "freemarker2",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": [
      "if",
      "else",
      "elseif",
      "list",
      "items",
      "sep",
      "break",
      "continue",
      "include",
      "import",
      "assign",
      "local",
      "global",
      "setting",
      "macro",
      "nested",
      "return",
      "function",
      "switch",
      "case",
      "default",
      "attempt",
      "recover",
      "ftl",
      "flush",
      "stop",
      "visit",
      "recurse",
      "fallback",
      "noparse",
      "compress",
      "escape",
      "noescape",
      "as",
      "in",
      "using",
      "true",
      "false"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "<#assign\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captureGroup": 1,
      "description": "FreeMarker variable assignment"
    },
    {
      "pattern": "<#macro\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captureGroup": 1,
      "description": "FreeMarker macro definition"
    },
    {
      "pattern": "<#function\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captureGroup": 1,
      "description": "FreeMarker function definition"
    },
    {
      "pattern": "\\$\\{([a-zA-Z_][a-zA-Z0-9_.]*)\\}",
      "captureGroup": 1,
      "description": "FreeMarker interpolation variable"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
