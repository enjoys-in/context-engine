{
  "language": "powershell",
  "wordPattern": "\\$[a-zA-Z_][a-zA-Z0-9_]*|[a-zA-Z_][a-zA-Z0-9_-]*",
  "identifierRules": {
    "start": "[a-zA-Z_$]",
    "continue": "[a-zA-Z0-9_-]",
    "forbidden": [
      "begin",
      "break",
      "catch",
      "class",
      "continue",
      "data",
      "define",
      "do",
      "dynamicparam",
      "else",
      "elseif",
      "end",
      "enum",
      "exit",
      "filter",
      "finally",
      "for",
      "foreach",
      "from",
      "function",
      "hidden",
      "if",
      "in",
      "inlinescript",
      "param",
      "process",
      "return",
      "static",
      "switch",
      "throw",
      "trap",
      "try",
      "until",
      "using",
      "var",
      "while",
      "workflow",
      "parallel",
      "sequence",
      "configuration"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^\\$?[a-zA-Z_][a-zA-Z0-9_-]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "(\\$[a-zA-Z_][a-zA-Z0-9_]*)",
      "captureGroup": 1,
      "description": "PowerShell variable"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_-]*)\\b",
      "captureGroup": 1,
      "description": "Function, cmdlet, or parameter name"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
