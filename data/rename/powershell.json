{
  "language": "powershell",
  "wordPattern": "\\$[a-zA-Z_][a-zA-Z0-9_]*|[a-zA-Z_][a-zA-Z0-9_-]*",
  "identifierRules": {
    "start": "[a-zA-Z_$]",
    "continue": "[a-zA-Z0-9_-]",
    "forbidden": ["begin", "break", "catch", "class", "continue", "data", "define", "do", "dynamicparam", "else", "elseif", "end", "enum", "exit", "filter", "finally", "for", "foreach", "from", "function", "hidden", "if", "in", "inlinescript", "param", "process", "return", "static", "switch", "throw", "trap", "try", "until", "using", "var", "while", "workflow", "parallel", "sequence", "configuration"]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^\\$?[a-zA-Z_][a-zA-Z0-9_-]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "(\\$[a-zA-Z_][a-zA-Z0-9_]*)",
      "captureGroup": 1,
      "description": "PowerShell variable"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_-]*)\\b",
      "captureGroup": 1,
      "description": "Function, cmdlet, or parameter name"
    }
  ]
}
