{
  "language": "scheme",
  "wordPattern": "[a-zA-Z!$%&*+\\-./:<=>?@^_~][a-zA-Z0-9!$%&*+\\-./:<=>?@^_~]*",
  "identifierRules": {
    "start": "[a-zA-Z!$%&*+\\-./:<=>?@^_~]",
    "continue": "[a-zA-Z0-9!$%&*+\\-./:<=>?@^_~]",
    "forbidden": [
      "define",
      "lambda",
      "if",
      "cond",
      "else",
      "and",
      "or",
      "not",
      "let",
      "let*",
      "letrec",
      "begin",
      "do",
      "set!",
      "quote",
      "quasiquote",
      "unquote",
      "unquote-splicing",
      "define-syntax",
      "syntax-rules",
      "define-record-type",
      "case",
      "when",
      "unless",
      "delay",
      "force",
      "values",
      "call-with-current-continuation",
      "call/cc",
      "apply",
      "map",
      "for-each",
      "import",
      "export",
      "library",
      "include"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z!$%&*+\\-./:<=>?@^_~][a-zA-Z0-9!$%&*+\\-./:<=>?@^_~]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "([a-zA-Z!$%&*+\\-./:<=>?@^_~][a-zA-Z0-9!$%&*+\\-./:<=>?@^_~]*)",
      "captureGroup": 1,
      "description": "Variable, function, macro, or syntax binding"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
