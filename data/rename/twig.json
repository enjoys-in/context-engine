{
  "language": "twig",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": ["autoescape", "block", "do", "embed", "extends", "flush", "for", "from", "if", "import", "include", "macro", "sandbox", "set", "spaceless", "use", "verbatim", "with", "endautoescape", "endblock", "endembed", "endfor", "endif", "endmacro", "endsandbox", "endset", "endspaceless", "endwith", "else", "elseif", "in", "is", "not", "and", "or", "true", "false", "null", "none", "defined", "empty", "even", "odd", "iterable", "sameas"]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\{\\{\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
      "captureGroup": 1,
      "description": "Twig output variable"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Variable, macro, block, or filter name"
    }
  ]
}
