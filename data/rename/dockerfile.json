{
  "language": "dockerfile",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_.-]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_.-]",
    "forbidden": [
      "FROM", "AS", "RUN", "CMD", "LABEL", "MAINTAINER", "EXPOSE", "ENV",
      "ADD", "COPY", "ENTRYPOINT", "VOLUME", "USER", "WORKDIR", "ARG",
      "ONBUILD", "STOPSIGNAL", "HEALTHCHECK", "SHELL", "NONE"
    ]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_.-]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "FROM\\s+\\S+\\s+AS\\s+([a-zA-Z_][a-zA-Z0-9_.-]*)",
      "captureGroup": 1,
      "description": "Dockerfile build stage alias"
    },
    {
      "pattern": "ARG\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captureGroup": 1,
      "description": "Dockerfile ARG variable name"
    },
    {
      "pattern": "ENV\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captureGroup": 1,
      "description": "Dockerfile ENV variable name"
    },
    {
      "pattern": "\\$\\{?([a-zA-Z_][a-zA-Z0-9_]*)\\}?",
      "captureGroup": 1,
      "description": "Dockerfile variable reference"
    }
  ]
}
