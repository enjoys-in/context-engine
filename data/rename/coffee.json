{
  "language": "coffee",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "identifierRules": {
    "start": "[a-zA-Z_$]",
    "continue": "[a-zA-Z0-9_$]",
    "forbidden": [
      "and", "break", "by", "catch", "class", "continue", "debugger", "delete",
      "do", "else", "extends", "false", "finally", "for", "if", "in",
      "instanceof", "is", "isnt", "loop", "new", "no", "not", "null",
      "of", "off", "on", "or", "return", "super", "switch", "then",
      "this", "throw", "true", "try", "typeof", "undefined", "unless",
      "until", "when", "while", "yes", "yield"
    ]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_$][a-zA-Z0-9_$]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\b([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*[=:]",
      "captureGroup": 1,
      "description": "CoffeeScript variable or property assignment"
    },
    {
      "pattern": "\\b([a-zA-Z_$][a-zA-Z0-9_$]*)\\b",
      "captureGroup": 1,
      "description": "CoffeeScript identifier"
    }
  ]
}
