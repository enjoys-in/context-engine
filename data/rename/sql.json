{
  "language": "sql",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*|\\[[^\\]]+\\]|\"[^\"]+\"",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": [
      "SELECT",
      "FROM",
      "WHERE",
      "INSERT",
      "UPDATE",
      "DELETE",
      "CREATE",
      "DROP",
      "ALTER",
      "TABLE",
      "INDEX",
      "VIEW",
      "DATABASE",
      "JOIN",
      "INNER",
      "LEFT",
      "RIGHT",
      "FULL",
      "OUTER",
      "CROSS",
      "ON",
      "AND",
      "OR",
      "NOT",
      "NULL",
      "IS",
      "IN",
      "BETWEEN",
      "LIKE",
      "ORDER",
      "BY",
      "GROUP",
      "HAVING",
      "LIMIT",
      "OFFSET",
      "UNION",
      "INTERSECT",
      "EXCEPT",
      "ALL",
      "AS",
      "SET",
      "VALUES",
      "INTO",
      "DISTINCT",
      "EXISTS",
      "CASE",
      "WHEN",
      "THEN",
      "ELSE",
      "END",
      "BEGIN",
      "COMMIT",
      "ROLLBACK",
      "TRANSACTION",
      "GRANT",
      "REVOKE",
      "PRIMARY",
      "KEY",
      "FOREIGN",
      "REFERENCES",
      "CONSTRAINT",
      "DEFAULT",
      "CHECK",
      "UNIQUE",
      "COUNT",
      "SUM",
      "AVG",
      "MAX",
      "MIN",
      "DECLARE",
      "CURSOR",
      "FETCH",
      "CLOSE",
      "OPEN",
      "EXEC",
      "EXECUTE",
      "PROCEDURE",
      "FUNCTION",
      "TRIGGER",
      "WITH"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 128,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$|^\\[[^\\]]+\\]$|^\"[^\"]+\"$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\[([^\\]]+)\\]",
      "captureGroup": 1,
      "description": "Bracket-quoted identifier"
    },
    {
      "pattern": "\"([^\"]+)\"",
      "captureGroup": 1,
      "description": "Double-quoted identifier"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Unquoted identifier (table, column, alias, procedure)"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
