{
  "language": "docker-compose",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_.-]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_.-]",
    "forbidden": [
      "version", "services", "networks", "volumes", "configs", "secrets",
      "build", "image", "container_name", "command", "entrypoint", "environment",
      "env_file", "ports", "expose", "depends_on", "restart", "deploy",
      "healthcheck", "logging", "labels", "links", "external", "driver",
      "driver_opts", "attachable", "internal", "name", "extends", "profiles",
      "pull_policy", "replicas", "resources"
    ]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_.-]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "^\\s*([a-zA-Z_][a-zA-Z0-9_.-]*)\\s*:",
      "captureGroup": 1,
      "description": "Docker Compose service or key name"
    },
    {
      "pattern": "\\$\\{([a-zA-Z_][a-zA-Z0-9_]*)\\}",
      "captureGroup": 1,
      "description": "Docker Compose variable interpolation"
    }
  ]
}
