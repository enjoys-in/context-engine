{
  "language": "nestjs",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "identifierRules": {
    "start": "[a-zA-Z_$]",
    "continue": "[a-zA-Z0-9_$]",
    "forbidden": [
      "break",
      "case",
      "catch",
      "continue",
      "debugger",
      "default",
      "delete",
      "do",
      "else",
      "finally",
      "for",
      "function",
      "if",
      "in",
      "instanceof",
      "new",
      "return",
      "switch",
      "this",
      "throw",
      "try",
      "typeof",
      "var",
      "void",
      "while",
      "with",
      "class",
      "const",
      "enum",
      "export",
      "extends",
      "import",
      "super",
      "implements",
      "interface",
      "let",
      "package",
      "private",
      "protected",
      "public",
      "static",
      "yield",
      "await",
      "async",
      "of",
      "null",
      "undefined",
      "true",
      "false",
      "NaN",
      "Infinity"
    ]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 256,
    "pattern": "^[a-zA-Z_$][a-zA-Z0-9_$]*$"
  },
  "prepareRenamePatterns": [
    {
      "name": "Class name",
      "pattern": "class\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Rename class declaration"
    },
    {
      "name": "Method name",
      "pattern": "(?:async\\s+)?(\\w+)\\s*\\([^)]*\\)\\s*(?::\\s*\\w+)?\\s*\\{",
      "captureGroup": 1,
      "description": "Rename method"
    },
    {
      "name": "Interface",
      "pattern": "interface\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Rename interface"
    },
    {
      "name": "Type alias",
      "pattern": "type\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "description": "Rename type alias"
    },
    {
      "name": "Enum name",
      "pattern": "enum\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Rename enum"
    },
    {
      "name": "Parameter",
      "pattern": "(?:@\\w+\\([^)]*\\)\\s*)?(\\w+)\\s*:\\s*\\w+",
      "captureGroup": 1,
      "description": "Rename parameter"
    },
    {
      "name": "Variable",
      "pattern": "(?:const|let|var)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Rename variable"
    },
    {
      "name": "Property",
      "pattern": "(?:private|protected|public|readonly)\\s+(?:readonly\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Rename property"
    },
    {
      "name": "Import alias",
      "pattern": "import\\s+(?:\\{[^}]*\\}|\\w+)\\s+from",
      "captureGroup": 0,
      "description": "Rename imported symbol"
    }
  ]
}
