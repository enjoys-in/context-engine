{
  "language": "pgsql",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*|\"[^\"]+\"",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": ["SELECT", "FROM", "WHERE", "INSERT", "UPDATE", "DELETE", "CREATE", "DROP", "ALTER", "TABLE", "INDEX", "VIEW", "SCHEMA", "DATABASE", "JOIN", "INNER", "LEFT", "RIGHT", "FULL", "OUTER", "CROSS", "ON", "AND", "OR", "NOT", "NULL", "IS", "IN", "BETWEEN", "LIKE", "ILIKE", "ORDER", "BY", "GROUP", "HAVING", "LIMIT", "OFFSET", "UNION", "INTERSECT", "EXCEPT", "AS", "SET", "VALUES", "INTO", "DISTINCT", "RETURNING", "WITH", "RECURSIVE", "CASE", "WHEN", "THEN", "ELSE", "END", "BEGIN", "COMMIT", "ROLLBACK", "FUNCTION", "PROCEDURE", "TRIGGER", "RETURNS", "LANGUAGE", "DECLARE", "RAISE", "PERFORM", "EXECUTE", "PRIMARY", "KEY", "FOREIGN", "REFERENCES", "CONSTRAINT", "DEFAULT", "SERIAL", "BIGSERIAL", "INTEGER", "TEXT", "BOOLEAN", "TIMESTAMP", "JSONB", "ARRAY"]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 63,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$|^\"[^\"]+\"$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\"([^\"]+)\"",
      "captureGroup": 1,
      "description": "Double-quoted identifier"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Unquoted identifier (table, column, function, schema)"
    }
  ]
}
