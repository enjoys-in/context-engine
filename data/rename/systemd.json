{
  "language": "systemd",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_-]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_-]",
    "forbidden": [
      "Unit",
      "Service",
      "Install",
      "Timer",
      "Socket",
      "Mount",
      "Automount",
      "Swap",
      "Path",
      "Slice",
      "Scope",
      "Description",
      "After",
      "Before",
      "Requires",
      "Wants",
      "BindsTo",
      "PartOf",
      "Conflicts",
      "WantedBy",
      "RequiredBy",
      "Also",
      "Alias",
      "Type",
      "ExecStart",
      "ExecStop",
      "ExecReload",
      "ExecStartPre",
      "ExecStartPost",
      "ExecStopPost",
      "Restart",
      "RestartSec",
      "User",
      "Group",
      "WorkingDirectory",
      "Environment",
      "EnvironmentFile",
      "StandardOutput",
      "StandardError",
      "PIDFile",
      "RemainAfterExit",
      "KillMode",
      "TimeoutStartSec",
      "TimeoutStopSec"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_-]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\[([a-zA-Z_][a-zA-Z0-9_-]*)\\]",
      "captureGroup": 1,
      "description": "Section name"
    },
    {
      "pattern": "^([a-zA-Z_][a-zA-Z0-9_-]*)=",
      "captureGroup": 1,
      "description": "Directive key name"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
