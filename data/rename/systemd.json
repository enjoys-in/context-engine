{
  "language": "systemd",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_-]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_-]",
    "forbidden": ["Unit", "Service", "Install", "Timer", "Socket", "Mount", "Automount", "Swap", "Path", "Slice", "Scope", "Description", "After", "Before", "Requires", "Wants", "BindsTo", "PartOf", "Conflicts", "WantedBy", "RequiredBy", "Also", "Alias", "Type", "ExecStart", "ExecStop", "ExecReload", "ExecStartPre", "ExecStartPost", "ExecStopPost", "Restart", "RestartSec", "User", "Group", "WorkingDirectory", "Environment", "EnvironmentFile", "StandardOutput", "StandardError", "PIDFile", "RemainAfterExit", "KillMode", "TimeoutStartSec", "TimeoutStopSec"]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_-]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\[([a-zA-Z_][a-zA-Z0-9_-]*)\\]",
      "captureGroup": 1,
      "description": "Section name"
    },
    {
      "pattern": "^([a-zA-Z_][a-zA-Z0-9_-]*)=",
      "captureGroup": 1,
      "description": "Directive key name"
    }
  ]
}
