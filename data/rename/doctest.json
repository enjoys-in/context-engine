{
  "language": "doctest",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": [
      "def", "class", "import", "from", "return", "if", "else", "elif",
      "for", "while", "try", "except", "finally", "with", "as", "pass",
      "break", "continue", "raise", "yield", "lambda", "and", "or", "not",
      "in", "is", "True", "False", "None", "global", "nonlocal", "assert",
      "del", "async", "await"
    ]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": ">>>\\s+.*\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Python identifier in doctest example"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Doctest identifier"
    }
  ]
}
