{
  "language": "sparql",
  "wordPattern": "\\?[a-zA-Z_][a-zA-Z0-9_]*|[a-zA-Z_][a-zA-Z0-9_]*:[a-zA-Z_][a-zA-Z0-9_]*|[a-zA-Z_][a-zA-Z0-9_]*",
  "identifierRules": {
    "start": "[a-zA-Z_?]",
    "continue": "[a-zA-Z0-9_:]",
    "forbidden": ["SELECT", "CONSTRUCT", "DESCRIBE", "ASK", "WHERE", "FROM", "NAMED", "PREFIX", "BASE", "OPTIONAL", "UNION", "FILTER", "GRAPH", "ORDER", "BY", "LIMIT", "OFFSET", "DISTINCT", "REDUCED", "AS", "GROUP", "HAVING", "VALUES", "BIND", "SERVICE", "MINUS", "EXISTS", "NOT", "IN", "INSERT", "DELETE", "LOAD", "CLEAR", "DROP", "CREATE", "ADD", "MOVE", "COPY", "WITH", "USING", "DEFAULT", "ALL", "SILENT", "DATA", "ASC", "DESC", "STR", "LANG", "DATATYPE", "BOUND", "SAMETERM", "ISIRI", "ISURI", "ISBLANK", "ISLITERAL", "REGEX", "SUBSTR", "true", "false"]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^\\??[a-zA-Z_][a-zA-Z0-9_]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\?([a-zA-Z_][a-zA-Z0-9_]*)",
      "captureGroup": 1,
      "description": "SPARQL variable"
    },
    {
      "pattern": "([a-zA-Z_][a-zA-Z0-9_]*):[a-zA-Z_][a-zA-Z0-9_]*",
      "captureGroup": 1,
      "description": "Namespace prefix"
    }
  ]
}
