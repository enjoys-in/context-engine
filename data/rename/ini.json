{
  "language": "ini",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_.:-]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_.:-]",
    "forbidden": [
      "true", "false", "yes", "no", "on", "off", "none", "null"
    ]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_.:-]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "^\\[([a-zA-Z_][a-zA-Z0-9_.:-]*)\\]",
      "captureGroup": 1,
      "description": "INI section name"
    },
    {
      "pattern": "^([a-zA-Z_][a-zA-Z0-9_.:-]*)\\s*=",
      "captureGroup": 1,
      "description": "INI key name"
    }
  ]
}
