{
  "language": "flow9",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": [
      "import", "export", "if", "else", "switch", "default", "native",
      "ref", "deref", "true", "false", "cast", "unsafe", "require",
      "forbid", "with", "mutable", "bool", "int", "double", "string",
      "void", "flow", "array", "maybe", "Some", "None"
    ]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "captureGroup": 1,
      "description": "Flow9 function name"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Flow9 identifier"
    }
  ]
}
