{
  "language": "hcl",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_-]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_-]",
    "forbidden": [
      "resource",
      "data",
      "variable",
      "output",
      "locals",
      "module",
      "provider",
      "terraform",
      "backend",
      "provisioner",
      "connection",
      "lifecycle",
      "for_each",
      "count",
      "depends_on",
      "for",
      "in",
      "if",
      "else",
      "endif",
      "endfor",
      "true",
      "false",
      "null",
      "dynamic",
      "content",
      "moved",
      "import",
      "required_providers",
      "required_version",
      "check"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_-]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\b(?:resource|data|variable|output|module)\\s+\"([a-zA-Z_][a-zA-Z0-9_-]*)\"",
      "captureGroup": 1,
      "description": "HCL block type name"
    },
    {
      "pattern": "\\b(?:resource|data)\\s+\"[^\"]+\"\\s+\"([a-zA-Z_][a-zA-Z0-9_-]*)\"",
      "captureGroup": 1,
      "description": "HCL resource or data source local name"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_-]*)\\s*=",
      "captureGroup": 1,
      "description": "HCL attribute assignment"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_-]*)\\b",
      "captureGroup": 1,
      "description": "HCL identifier"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
