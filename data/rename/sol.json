{
  "language": "sol",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "identifierRules": {
    "start": "[a-zA-Z_$]",
    "continue": "[a-zA-Z0-9_$]",
    "forbidden": ["pragma", "solidity", "import", "contract", "library", "interface", "abstract", "is", "using", "for", "struct", "enum", "event", "modifier", "function", "constructor", "fallback", "receive", "mapping", "address", "bool", "string", "bytes", "uint", "int", "uint256", "int256", "uint8", "public", "private", "internal", "external", "pure", "view", "payable", "constant", "immutable", "memory", "storage", "calldata", "if", "else", "while", "do", "for", "break", "continue", "return", "emit", "revert", "require", "assert", "new", "delete", "true", "false", "this", "super", "msg", "block", "tx", "abi", "type", "virtual", "override"]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_$][a-zA-Z0-9_$]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\b([a-zA-Z_$][a-zA-Z0-9_$]*)\\b",
      "captureGroup": 1,
      "description": "Contract, function, variable, event, modifier, or type name"
    }
  ]
}
