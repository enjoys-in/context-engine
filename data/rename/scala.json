{
  "language": "scala",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*|`[^`]+`",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": ["abstract", "case", "catch", "class", "def", "do", "else", "enum", "export", "extends", "false", "final", "finally", "for", "forSome", "given", "if", "implicit", "import", "lazy", "match", "new", "null", "object", "override", "package", "private", "protected", "return", "sealed", "super", "then", "this", "throw", "trait", "true", "try", "type", "val", "var", "while", "with", "yield", "using", "end", "extension", "transparent", "inline", "opaque"]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$|^`[^`]+`$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "`([^`]+)`",
      "captureGroup": 1,
      "description": "Backtick-quoted identifier"
    },
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Variable, method, class, trait, object, or type name"
    }
  ]
}
