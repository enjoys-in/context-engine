{
  "language": "less",
  "wordPattern": "[@a-zA-Z_-][a-zA-Z0-9_-]*",
  "identifierRules": {
    "start": "[@a-zA-Z_-]",
    "continue": "[a-zA-Z0-9_-]",
    "forbidden": [
      "when", "not", "and", "or", "true", "false", "each", "if", "else",
      "import", "extend", "mixin", "default", "undefined"
    ]
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[@a-zA-Z_-][a-zA-Z0-9_-]*$"
  },
  "prepareRenamePatterns": [
    {
      "pattern": "(@[a-zA-Z_-][a-zA-Z0-9_-]*)\\s*:",
      "captureGroup": 1,
      "description": "Less variable definition"
    },
    {
      "pattern": "\\.([a-zA-Z_-][a-zA-Z0-9_-]*)\\s*\\(",
      "captureGroup": 1,
      "description": "Less mixin definition or call"
    },
    {
      "pattern": "(@[a-zA-Z_-][a-zA-Z0-9_-]*)",
      "captureGroup": 1,
      "description": "Less variable reference"
    },
    {
      "pattern": "\\.([a-zA-Z_-][a-zA-Z0-9_-]*)",
      "captureGroup": 1,
      "description": "Less class selector"
    }
  ]
}
