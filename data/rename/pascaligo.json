{
  "language": "pascaligo",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "identifierRules": {
    "start": "[a-zA-Z_]",
    "continue": "[a-zA-Z0-9_]",
    "forbidden": [
      "begin",
      "block",
      "case",
      "const",
      "contains",
      "do",
      "else",
      "end",
      "for",
      "from",
      "function",
      "if",
      "in",
      "is",
      "list",
      "map",
      "mod",
      "nil",
      "not",
      "of",
      "or",
      "patch",
      "record",
      "remove",
      "set",
      "skip",
      "step",
      "then",
      "to",
      "type",
      "var",
      "while",
      "with",
      "and",
      "attributes",
      "big_map"
    ],
    "validPattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "reservedWords": [],
    "caseSensitive": true
  },
  "renameValidation": {
    "allowEmpty": false,
    "maxLength": 255,
    "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
    "rejectPattern": "^\\d|\\s",
    "allowEmptyName": false
  },
  "prepareRenamePatterns": [
    {
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captureGroup": 1,
      "description": "Variable, function, type, or constant name"
    }
  ],
  "renameStrategy": {
    "scopeAware": true,
    "updateImports": true,
    "updateStrings": false,
    "updateComments": false,
    "preview": true
  }
}
