{
  "language": "prisma",
  "declarations": {
    "model": {
      "signature": "model ModelName { ... }",
      "description": "Data model declaration mapping to a database table",
      "type": "class",
      "module": "schema"
    },
    "enum": {
      "signature": "enum EnumName { VALUE1 VALUE2 }",
      "description": "Enum type declaration",
      "type": "enum",
      "module": "schema"
    },
    "datasource": {
      "signature": "datasource name { ... }",
      "description": "Database connection configuration block",
      "type": "module",
      "module": "schema"
    },
    "generator": {
      "signature": "generator name { ... }",
      "description": "Code generator configuration block",
      "type": "module",
      "module": "schema"
    },
    "type": {
      "signature": "type TypeName { ... }",
      "description": "Composite type declaration (MongoDB)",
      "type": "type_alias",
      "module": "schema"
    },
    "view": {
      "signature": "view ViewName { ... }",
      "description": "Database view declaration",
      "type": "class",
      "module": "schema"
    }
  },
  "declarationPatterns": [
    {
      "name": "Model Declaration",
      "pattern": "^\\s*model\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Enum Declaration",
      "pattern": "^\\s*enum\\s+(\\w+)",
      "captureGroup": 1,
      "type": "enum"
    },
    {
      "name": "Datasource Block",
      "pattern": "^\\s*datasource\\s+(\\w+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Generator Block",
      "pattern": "^\\s*generator\\s+(\\w+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Composite Type",
      "pattern": "^\\s*type\\s+(\\w+)",
      "captureGroup": 1,
      "type": "type_alias"
    },
    {
      "name": "View Declaration",
      "pattern": "^\\s*view\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Field Declaration",
      "pattern": "^\\s+(\\w+)\\s+(String|Int|BigInt|Float|Decimal|Boolean|DateTime|Json|Bytes|\\w+)",
      "captureGroup": 1,
      "type": "variable"
    }
  ]
}