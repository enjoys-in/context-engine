{
  "language": "st",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Program",
      "pattern": "^\\s*PROGRAM\\s+(\\w+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "FunctionBlock",
      "pattern": "^\\s*FUNCTION_BLOCK\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Function",
      "pattern": "^\\s*FUNCTION\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Type",
      "pattern": "^\\s*TYPE\\s+(\\w+)",
      "captureGroup": 1,
      "type": "type"
    }
  ]
}