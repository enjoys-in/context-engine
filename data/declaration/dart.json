{
  "language": "dart",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Class Declaration",
      "pattern": "^\\s*(?:(?:abstract|sealed|interface|base|final|mixin)\\s+)*class\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Mixin Declaration",
      "pattern": "^\\s*(?:(?:base)\\s+)?mixin\\s+(\\w+)",
      "captureGroup": 1,
      "type": "mixin"
    },
    {
      "name": "Enum Declaration",
      "pattern": "^\\s*enum\\s+(\\w+)",
      "captureGroup": 1,
      "type": "enum"
    },
    {
      "name": "Extension Declaration",
      "pattern": "^\\s*extension\\s+(\\w+)\\s+on\\s+\\w+",
      "captureGroup": 1,
      "type": "extension"
    },
    {
      "name": "Extension Type Declaration",
      "pattern": "^\\s*extension\\s+type\\s+(\\w+)",
      "captureGroup": 1,
      "type": "extension_type"
    },
    {
      "name": "Top-Level Function",
      "pattern": "^(?:\\w+(?:<[^>]*>)?\\s+)?(\\w+)\\s*(?:<[^>]*>)?\\s*\\([^)]*\\)\\s*(?:async\\*?|sync\\*)?\\s*[{=]",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Typedef Declaration",
      "pattern": "^\\s*typedef\\s+(\\w+)",
      "captureGroup": 1,
      "type": "type_alias"
    },
    {
      "name": "Variable Declaration (var)",
      "pattern": "^\\s*var\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Final Variable",
      "pattern": "^\\s*final\\s+(?:\\w+(?:<[^>]*>)?\\s+)?(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Const Variable",
      "pattern": "^\\s*const\\s+(?:\\w+(?:<[^>]*>)?\\s+)?(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "constant"
    },
    {
      "name": "Late Variable",
      "pattern": "^\\s*late\\s+(?:final\\s+)?(?:\\w+(?:<[^>]*>)?\\s+)?(\\w+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Abstract Class",
      "pattern": "^\\s*abstract\\s+(?:interface\\s+|base\\s+|final\\s+)?class\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Sealed Class",
      "pattern": "^\\s*sealed\\s+class\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Factory Constructor",
      "pattern": "^\\s*factory\\s+(\\w+(?:\\.\\w+)?)\\s*\\(",
      "captureGroup": 1,
      "type": "constructor"
    },
    {
      "name": "Named Constructor",
      "pattern": "^\\s*(?:const\\s+)?\\w+\\.(\\w+)\\s*\\(",
      "captureGroup": 1,
      "type": "constructor"
    },
    {
      "name": "Getter",
      "pattern": "^\\s*(?:(?:static|external)\\s+)*(?:\\w+\\s+)?get\\s+(\\w+)",
      "captureGroup": 1,
      "type": "property"
    },
    {
      "name": "Setter",
      "pattern": "^\\s*(?:(?:static|external)\\s+)*set\\s+(\\w+)",
      "captureGroup": 1,
      "type": "property"
    },
    {
      "name": "Library Declaration",
      "pattern": "^\\s*library\\s+([\\w.]+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Part Directive",
      "pattern": "^\\s*part\\s+'([^']+)'",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
