{
  "language": "mdx",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Import",
      "pattern": "^import\\s+.*from\\s+'([^']+)'",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Export",
      "pattern": "^export\\s+(?:default\\s+)?(?:function|const|class)\\s+(\\w+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Heading",
      "pattern": "^(#{1,6})\\s+(.+)$",
      "captureGroup": 2,
      "type": "string"
    }
  ]
}