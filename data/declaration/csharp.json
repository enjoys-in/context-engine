  "declarationPatterns": [
    {
      "name": "Class",
      "pattern": "^\\\\s*(?:public|private|protected|internal|static|abstract|sealed|partial)?\\\\s*class\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Interface",
      "pattern": "^\\\\s*(?:public|private|protected|internal)?\\\\s*interface\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "interface"
    },
    {
      "name": "Method",
      "pattern": "^\\\\s*(?:public|private|protected|internal|static|virtual|override|abstract|async)?\\\\s*[\\\\w<>\\\\[\\\\],?]+\\\\s+(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "type": "method"
    },
    {
      "name": "Enum",
      "pattern": "^\\\\s*(?:public|private|protected|internal)?\\\\s*enum\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "enum"
    },
    {
      "name": "Struct",
      "pattern": "^\\\\s*(?:public|private|protected|internal)?\\\\s*struct\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "struct"
    },
    {
      "name": "Namespace",
      "pattern": "^\\\\s*namespace\\\\s+([\\\\w.]+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
