{
  "language": "sparql",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Prefix",
      "pattern": "^PREFIX\\s+(\\w+):",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Variable",
      "pattern": "\\?(\\w+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "prefix",
      "pattern": "PREFIX\\s+(\\w+):\\s*<",
      "captureGroup": 1,
      "type": "prefix"
    },
    {
      "name": "variable",
      "pattern": "(\\?\\w+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "named_graph",
      "pattern": "GRAPH\\s+<([^>]+)>",
      "captureGroup": 1,
      "type": "named_graph"
    },
    {
      "name": "function",
      "pattern": "BIND\\s*\\(.*AS\\s+(\\?\\w+)",
      "captureGroup": 1,
      "type": "binding"
    },
    {
      "name": "subquery",
      "pattern": "SELECT.*WHERE",
      "captureGroup": 0,
      "type": "subquery"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
