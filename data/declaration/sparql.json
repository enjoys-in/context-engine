{
  "language": "sparql",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Prefix",
      "pattern": "^PREFIX\\s+(\\w+):",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Variable",
      "pattern": "\\?(\\w+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "prefix",
      "pattern": "PREFIX\\s+(\\w+):\\s*<",
      "captureGroup": 1,
      "type": "prefix"
    },
    {
      "name": "variable",
      "pattern": "(\\?\\w+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "named_graph",
      "pattern": "GRAPH\\s+<([^>]+)>",
      "captureGroup": 1,
      "type": "named_graph"
    },
    {
      "name": "function",
      "pattern": "BIND\\s*\\(.*AS\\s+(\\?\\w+)",
      "captureGroup": 1,
      "type": "binding"
    },
    {
      "name": "subquery",
      "pattern": "SELECT.*WHERE",
      "captureGroup": 0,
      "type": "subquery"
    }
  ]
}
