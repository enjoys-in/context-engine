{
  "language": "graphql",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Type",
      "pattern": "^\\\\s*type\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Input",
      "pattern": "^\\\\s*input\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "struct"
    },
    {
      "name": "Enum",
      "pattern": "^\\\\s*enum\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "enum"
    },
    {
      "name": "Interface",
      "pattern": "^\\\\s*interface\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "interface"
    },
    {
      "name": "Fragment",
      "pattern": "^\\\\s*fragment\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Query",
      "pattern": "^\\\\s*(?:query|mutation|subscription)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "function"
    }
  ]
}
