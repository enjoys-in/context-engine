{
  "language": "graphql",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Type",
      "pattern": "^\\\\s*type\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Input",
      "pattern": "^\\\\s*input\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "struct"
    },
    {
      "name": "Enum",
      "pattern": "^\\\\s*enum\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "enum"
    },
    {
      "name": "Interface",
      "pattern": "^\\\\s*interface\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "interface"
    },
    {
      "name": "Fragment",
      "pattern": "^\\\\s*fragment\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Query",
      "pattern": "^\\\\s*(?:query|mutation|subscription)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
