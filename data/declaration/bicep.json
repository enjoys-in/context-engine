{
  "language": "bicep",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Resource",
      "pattern": "^\\s*resource\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Parameter",
      "pattern": "^\\s*param\\s+(\\w+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Variable",
      "pattern": "^\\s*var\\s+(\\w+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Output",
      "pattern": "^\\s*output\\s+(\\w+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Module",
      "pattern": "^\\s*module\\s+(\\w+)",
      "captureGroup": 1,
      "type": "module"
    }
  ]
}