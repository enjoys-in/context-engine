{
  "language": "qsharp",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Namespace",
      "pattern": "^\\s*namespace\\s+(\\S+)",
      "captureGroup": 1,
      "type": "namespace"
    },
    {
      "name": "Operation",
      "pattern": "^\\s*operation\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Function",
      "pattern": "^\\s*function\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Newtype",
      "pattern": "^\\s*newtype\\s+(\\w+)",
      "captureGroup": 1,
      "type": "type"
    }
  ]
}