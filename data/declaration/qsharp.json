{
  "language": "qsharp",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Namespace",
      "pattern": "^\\s*namespace\\s+(\\S+)",
      "captureGroup": 1,
      "type": "namespace"
    },
    {
      "name": "Operation",
      "pattern": "^\\s*operation\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Function",
      "pattern": "^\\s*function\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Newtype",
      "pattern": "^\\s*newtype\\s+(\\w+)",
      "captureGroup": 1,
      "type": "type"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
