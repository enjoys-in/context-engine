{
  "language": "razor",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Model",
      "pattern": "@model\\s+(\\S+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Section",
      "pattern": "@section\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "CodeBlock",
      "pattern": "@functions|@code",
      "captureGroup": 0,
      "type": "function"
    }
  ]
}