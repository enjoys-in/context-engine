{
  "language": "objective-c",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Interface",
      "pattern": "@interface\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Implementation",
      "pattern": "@implementation\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Protocol",
      "pattern": "@protocol\\s+(\\w+)",
      "captureGroup": 1,
      "type": "interface"
    },
    {
      "name": "Method",
      "pattern": "^\\s*[-+]\\s*\\([^)]+\\)(\\w+)",
      "captureGroup": 1,
      "type": "method"
    },
    {
      "name": "Property",
      "pattern": "@property\\s+.*\\s+(\\w+);",
      "captureGroup": 1,
      "type": "property"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
