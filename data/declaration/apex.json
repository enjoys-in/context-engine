{
  "language": "apex",
  "declarations": {},
  "declarationPatterns": [
    { "name": "Class", "pattern": "^\\s*(?:public|private|global)?\\s*class\\s+(\\w+)", "captureGroup": 1, "type": "class" },
    { "name": "Interface", "pattern": "^\\s*(?:public|global)\\s+interface\\s+(\\w+)", "captureGroup": 1, "type": "interface" },
    { "name": "Method", "pattern": "^\\s*(?:public|private|protected|global)?\\s*(?:static\\s+)?\\w+\\s+(\\w+)\\s*\\(", "captureGroup": 1, "type": "method" },
    { "name": "Variable", "pattern": "^\\s*(?:public|private|protected)?\\s*(?:static\\s+)?(?:final\\s+)?\\w+\\s+(\\w+)\\s*[=;]", "captureGroup": 1, "type": "variable" }
  ]
}
