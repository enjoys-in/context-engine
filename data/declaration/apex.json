{
  "language": "apex",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Class",
      "pattern": "^\\s*(?:public|private|global)?\\s*class\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Interface",
      "pattern": "^\\s*(?:public|global)\\s+interface\\s+(\\w+)",
      "captureGroup": 1,
      "type": "interface"
    },
    {
      "name": "Method",
      "pattern": "^\\s*(?:public|private|protected|global)?\\s*(?:static\\s+)?\\w+\\s+(\\w+)\\s*\\(",
      "captureGroup": 1,
      "type": "method"
    },
    {
      "name": "Variable",
      "pattern": "^\\s*(?:public|private|protected)?\\s*(?:static\\s+)?(?:final\\s+)?\\w+\\s+(\\w+)\\s*[=;]",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
