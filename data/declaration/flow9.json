{
  "language": "flow9",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Function",
      "pattern": "^\\s*(\\w+)\\s*\\(.*\\)\\s*->",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Import",
      "pattern": "^\\s*import\\s+(\\S+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "function",
      "pattern": "(\\w+)\\s*\\([^)]*\\)\\s*->\\s*\\w+\\s*\\{",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "struct",
      "pattern": "(\\w+)\\s*\\(",
      "captureGroup": 1,
      "type": "struct"
    },
    {
      "name": "union",
      "pattern": "(\\w+)\\s*::=",
      "captureGroup": 1,
      "type": "union"
    },
    {
      "name": "import",
      "pattern": "import\\s+([\\w/]+)",
      "captureGroup": 1,
      "type": "import"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
