{
  "language": "flow9",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Function",
      "pattern": "^\\s*(\\w+)\\s*\\(.*\\)\\s*->",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Import",
      "pattern": "^\\s*import\\s+(\\S+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "function",
      "pattern": "(\\w+)\\s*\\([^)]*\\)\\s*->\\s*\\w+\\s*\\{",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "struct",
      "pattern": "(\\w+)\\s*\\(",
      "captureGroup": 1,
      "type": "struct"
    },
    {
      "name": "union",
      "pattern": "(\\w+)\\s*::=",
      "captureGroup": 1,
      "type": "union"
    },
    {
      "name": "import",
      "pattern": "import\\s+([\\w/]+)",
      "captureGroup": 1,
      "type": "import"
    }
  ]
}
