{
  "language": "azcli",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Command",
      "pattern": "^\\s*(az\\s+\\w+(?:\\s+\\w+)*)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "resource_group",
      "pattern": "az\\s+group\\s+create\\s+.*--name\\s+(\\S+)",
      "captureGroup": 1,
      "type": "resource_group"
    },
    {
      "name": "storage_account",
      "pattern": "az\\s+storage\\s+account\\s+create\\s+.*--name\\s+(\\S+)",
      "captureGroup": 1,
      "type": "storage_account"
    },
    {
      "name": "webapp",
      "pattern": "az\\s+webapp\\s+create\\s+.*--name\\s+(\\S+)",
      "captureGroup": 1,
      "type": "webapp"
    },
    {
      "name": "vm",
      "pattern": "az\\s+vm\\s+create\\s+.*--name\\s+(\\S+)",
      "captureGroup": 1,
      "type": "virtual_machine"
    },
    {
      "name": "variable",
      "pattern": "(\\w+)\\s*=\\s*\\$\\(az",
      "captureGroup": 1,
      "type": "variable"
    }
  ]
}
