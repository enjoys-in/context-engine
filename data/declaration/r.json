  "declarationPatterns": [
    {
      "name": "function_decl",
      "pattern": "(\\w+)\\s*<-\\s*function\\s*\\(",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "assignment",
      "pattern": "(\\w+)\\s*<-",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "right_assign",
      "pattern": "->\\s*(\\w+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "class_decl",
      "pattern": "setClass\\s*\\(\\s*[\"'](\\w+)[\"']",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "method_decl",
      "pattern": "setMethod\\s*\\(\\s*[\"'](\\w+)[\"']",
      "captureGroup": 1,
      "type": "method"
    },
    {
      "name": "library",
      "pattern": "library\\s*\\(\\s*(\\w+)\\s*\\)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
