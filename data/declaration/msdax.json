{
  "language": "msdax",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Measure",
      "pattern": "^\\s*(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Variable",
      "pattern": "^\\s*VAR\\s+(\\w+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "measure",
      "pattern": "DEFINE\\s+MEASURE\\s+\\w+\\[(\\w[\\w\\s]+?)\\]",
      "captureGroup": 1,
      "type": "measure"
    },
    {
      "name": "variable",
      "pattern": "VAR\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "table",
      "pattern": "DEFINE\\s+TABLE\\s+(\\w+)",
      "captureGroup": 1,
      "type": "table"
    },
    {
      "name": "column",
      "pattern": "DEFINE\\s+COLUMN\\s+\\w+\\[(\\w[\\w\\s]+?)\\]",
      "captureGroup": 1,
      "type": "column"
    }
  ]
}
