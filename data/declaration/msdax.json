{
  "language": "msdax",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Measure",
      "pattern": "^\\s*(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Variable",
      "pattern": "^\\s*VAR\\s+(\\w+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "measure",
      "pattern": "DEFINE\\s+MEASURE\\s+\\w+\\[(\\w[\\w\\s]+?)\\]",
      "captureGroup": 1,
      "type": "measure"
    },
    {
      "name": "variable",
      "pattern": "VAR\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "table",
      "pattern": "DEFINE\\s+TABLE\\s+(\\w+)",
      "captureGroup": 1,
      "type": "table"
    },
    {
      "name": "column",
      "pattern": "DEFINE\\s+COLUMN\\s+\\w+\\[(\\w[\\w\\s]+?)\\]",
      "captureGroup": 1,
      "type": "column"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
