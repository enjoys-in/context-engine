{
  "language": "dockerfile",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Stage",
      "pattern": "^\\\\s*FROM\\\\s+\\\\S+\\\\s+AS\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Arg",
      "pattern": "^\\\\s*ARG\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Env",
      "pattern": "^\\\\s*ENV\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "variable"
    }
  ]
}
