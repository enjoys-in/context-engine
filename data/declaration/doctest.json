{
  "language": "doctest",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "TestCase",
      "pattern": "^>>>\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "test_function",
      "pattern": ">>>\\s+def\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "test_class",
      "pattern": ">>>\\s+class\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "test_variable",
      "pattern": ">>>\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "test_import",
      "pattern": ">>>\\s+(?:from\\s+\\w+\\s+)?import\\s+(\\w+)",
      "captureGroup": 1,
      "type": "import"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
