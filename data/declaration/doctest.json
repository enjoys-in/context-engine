{
  "language": "doctest",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "TestCase",
      "pattern": "^>>>\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "test_function",
      "pattern": ">>>\\s+def\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "test_class",
      "pattern": ">>>\\s+class\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "test_variable",
      "pattern": ">>>\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "test_import",
      "pattern": ">>>\\s+(?:from\\s+\\w+\\s+)?import\\s+(\\w+)",
      "captureGroup": 1,
      "type": "import"
    }
  ]
}
