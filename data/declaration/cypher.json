{
  "language": "cypher",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "variable",
      "pattern": "(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "node_label",
      "pattern": ":\\s*(\\w+)",
      "captureGroup": 1,
      "type": "label"
    },
    {
      "name": "relationship_type",
      "pattern": "\\[:\\s*(\\w+)",
      "captureGroup": 1,
      "type": "relationship"
    },
    {
      "name": "function",
      "pattern": "FUNCTION\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "procedure",
      "pattern": "PROCEDURE\\s+(\\w+)",
      "captureGroup": 1,
      "type": "procedure"
    }
  ]
}
