{
  "language": "cypher",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "variable",
      "pattern": "(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "node_label",
      "pattern": ":\\s*(\\w+)",
      "captureGroup": 1,
      "type": "label"
    },
    {
      "name": "relationship_type",
      "pattern": "\\[:\\s*(\\w+)",
      "captureGroup": 1,
      "type": "relationship"
    },
    {
      "name": "function",
      "pattern": "FUNCTION\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "procedure",
      "pattern": "PROCEDURE\\s+(\\w+)",
      "captureGroup": 1,
      "type": "procedure"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
