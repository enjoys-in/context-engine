{
  "language": "scala",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Method Definition",
      "pattern": "^\\s*(?:(?:override|private|protected|final|abstract|implicit|inline|transparent)\\s+)*def\\s+(\\w+)",
      "captureGroup": 1,
      "type": "method"
    },
    {
      "name": "Class Declaration",
      "pattern": "^\\s*(?:(?:abstract|sealed|final|open)\\s+)*class\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Object Declaration",
      "pattern": "^\\s*(?:case\\s+)?object\\s+(\\w+)",
      "captureGroup": 1,
      "type": "object"
    },
    {
      "name": "Trait Declaration",
      "pattern": "^\\s*(?:sealed\\s+)?trait\\s+(\\w+)",
      "captureGroup": 1,
      "type": "trait"
    },
    {
      "name": "Val Declaration",
      "pattern": "^\\s*(?:(?:override|private|protected|final|lazy|implicit)\\s+)*val\\s+(\\w+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Var Declaration",
      "pattern": "^\\s*(?:(?:override|private|protected)\\s+)*var\\s+(\\w+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Type Alias",
      "pattern": "^\\s*(?:(?:override|private|protected|opaque)\\s+)*type\\s+(\\w+)",
      "captureGroup": 1,
      "type": "type_alias"
    },
    {
      "name": "Enum Declaration",
      "pattern": "^\\s*enum\\s+(\\w+)",
      "captureGroup": 1,
      "type": "enum"
    },
    {
      "name": "Given Instance",
      "pattern": "^\\s*given\\s+(\\w+)\\s*:",
      "captureGroup": 1,
      "type": "given"
    },
    {
      "name": "Anonymous Given",
      "pattern": "^\\s*given\\s+(\\w+(?:\\[.*?\\])?)\\s+with",
      "captureGroup": 1,
      "type": "given"
    },
    {
      "name": "Extension Block",
      "pattern": "^\\s*extension\\s*\\(.*?:\\s*(\\w+)",
      "captureGroup": 1,
      "type": "extension"
    },
    {
      "name": "Package Declaration",
      "pattern": "^\\s*package\\s+([\\w.]+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Case Class",
      "pattern": "^\\s*case\\s+class\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Case Object",
      "pattern": "^\\s*case\\s+object\\s+(\\w+)",
      "captureGroup": 1,
      "type": "object"
    },
    {
      "name": "Implicit Class",
      "pattern": "^\\s*implicit\\s+class\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Abstract Class",
      "pattern": "^\\s*abstract\\s+class\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Opaque Type",
      "pattern": "^\\s*opaque\\s+type\\s+(\\w+)",
      "captureGroup": 1,
      "type": "type_alias"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
