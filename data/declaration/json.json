{
  "language": "json",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Key",
      "pattern": "\"(\\\\w+)\"\\\\s*:",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "top_level_key",
      "pattern": "^\\s*\"(\\w+)\"\\s*:",
      "captureGroup": 1,
      "type": "key"
    },
    {
      "name": "nested_key",
      "pattern": "\"(\\w+)\"\\s*:",
      "captureGroup": 1,
      "type": "property"
    },
    {
      "name": "schema_def",
      "pattern": "\"\\$ref\"\\s*:\\s*\"#/definitions/(\\w+)\"",
      "captureGroup": 1,
      "type": "schema_reference"
    }
  ]
}
