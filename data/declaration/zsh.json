  "declarationPatterns": [
    {
      "name": "Function (keyword)",
      "pattern": "^\\\\s*function\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Function (parens)",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*\\\\(\\\\)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Variable",
