{
  "language": "m3",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Module",
      "pattern": "^\\s*MODULE\\s+(\\w+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Interface",
      "pattern": "^\\s*INTERFACE\\s+(\\w+)",
      "captureGroup": 1,
      "type": "interface"
    },
    {
      "name": "Procedure",
      "pattern": "^\\s*PROCEDURE\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Type",
      "pattern": "^\\s*TYPE\\s+(\\w+)",
      "captureGroup": 1,
      "type": "type"
    }
  ]
}