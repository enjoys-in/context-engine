{
  "language": "freemarker2",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Macro",
      "pattern": "<#macro\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Function",
      "pattern": "<#function\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Assign",
      "pattern": "<#assign\\s+(\\w+)",
      "captureGroup": 1,
      "type": "variable"
    }
  ]
}