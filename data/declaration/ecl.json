{
  "language": "ecl",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Definition",
      "pattern": "^\\s*(\\w+)\\s*:=",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Module",
      "pattern": "^\\s*EXPORT\\s+(\\w+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Record",
      "pattern": "^\\s*(\\w+)\\s*:=\\s*RECORD",
      "captureGroup": 1,
      "type": "struct"
    }
  ]
}