{
  "language": "elixir",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Module",
      "pattern": "^\\s*defmodule\\s+(\\S+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Function",
      "pattern": "^\\s*def[p]?\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Macro",
      "pattern": "^\\s*defmacro[p]?\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Struct",
      "pattern": "^\\s*defstruct\\b",
      "captureGroup": 0,
      "type": "struct"
    },
    {
      "name": "Protocol",
      "pattern": "^\\s*defprotocol\\s+(\\S+)",
      "captureGroup": 1,
      "type": "interface"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
