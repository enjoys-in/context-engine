{
  "language": "sb",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Sub",
      "pattern": "^\\s*Sub\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Label",
      "pattern": "^(\\w+):",
      "captureGroup": 1,
      "type": "constant"
    },
    {
      "name": "subroutine",
      "pattern": "Sub\\s+(\\w+)",
      "captureGroup": 1,
      "type": "subroutine"
    },
    {
      "name": "variable",
      "pattern": "(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "label",
      "pattern": "^(\\w+):",
      "captureGroup": 1,
      "type": "label"
    },
    {
      "name": "array",
      "pattern": "(\\w+)\\[(\\d+)\\]\\s*=",
      "captureGroup": 1,
      "type": "array"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
