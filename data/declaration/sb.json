{
  "language": "sb",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Sub",
      "pattern": "^\\s*Sub\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Label",
      "pattern": "^(\\w+):",
      "captureGroup": 1,
      "type": "constant"
    },
    {
      "name": "subroutine",
      "pattern": "Sub\\s+(\\w+)",
      "captureGroup": 1,
      "type": "subroutine"
    },
    {
      "name": "variable",
      "pattern": "(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "label",
      "pattern": "^(\\w+):",
      "captureGroup": 1,
      "type": "label"
    },
    {
      "name": "array",
      "pattern": "(\\w+)\\[(\\d+)\\]\\s*=",
      "captureGroup": 1,
      "type": "array"
    }
  ]
}
