{
  "language": "crontab",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Cron Entry",
      "pattern": "^\\\\s*(\\\\S+\\\\s+\\\\S+\\\\s+\\\\S+\\\\s+\\\\S+\\\\s+\\\\S+)\\\\s+(.+)",
      "captureGroup": 0,
      "type": "function"
    },
    {
      "name": "cron_job",
      "pattern": "^(\\S+\\s+\\S+\\s+\\S+\\s+\\S+\\s+\\S+)\\s+(.+)",
      "captureGroup": 2,
      "type": "job"
    },
    {
      "name": "env_variable",
      "pattern": "^(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "environment_variable"
    },
    {
      "name": "shell",
      "pattern": "^SHELL\\s*=\\s*(\\S+)",
      "captureGroup": 1,
      "type": "shell"
    },
    {
      "name": "mailto",
      "pattern": "^MAILTO\\s*=\\s*(\\S+)",
      "captureGroup": 1,
      "type": "mailto"
    }
  ]
}
