{
  "language": "crontab",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Cron Entry",
      "pattern": "^\\\\s*(\\\\S+\\\\s+\\\\S+\\\\s+\\\\S+\\\\s+\\\\S+\\\\s+\\\\S+)\\\\s+(.+)",
      "captureGroup": 0,
      "type": "function"
    },
    {
      "name": "cron_job",
      "pattern": "^(\\S+\\s+\\S+\\s+\\S+\\s+\\S+\\s+\\S+)\\s+(.+)",
      "captureGroup": 2,
      "type": "job"
    },
    {
      "name": "env_variable",
      "pattern": "^(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "environment_variable"
    },
    {
      "name": "shell",
      "pattern": "^SHELL\\s*=\\s*(\\S+)",
      "captureGroup": 1,
      "type": "shell"
    },
    {
      "name": "mailto",
      "pattern": "^MAILTO\\s*=\\s*(\\S+)",
      "captureGroup": 1,
      "type": "mailto"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
