{
  "language": "protobuf",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Message",
      "pattern": "^\\\\s*message\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Service",
      "pattern": "^\\\\s*service\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "interface"
    },
    {
      "name": "Enum",
      "pattern": "^\\\\s*enum\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "enum"
    },
    {
      "name": "RPC",
      "pattern": "^\\\\s*rpc\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "method"
    }
  ]
}
