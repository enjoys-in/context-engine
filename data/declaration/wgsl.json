{
  "language": "wgsl",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Function",
      "pattern": "^\\s*(?:@\\w+\\s+)*fn\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Struct",
      "pattern": "^\\s*struct\\s+(\\w+)",
      "captureGroup": 1,
      "type": "struct"
    },
    {
      "name": "Global",
      "pattern": "^\\s*(?:@group\\(\\d+\\)\\s+@binding\\(\\d+\\)\\s+)?var(?:<[^>]+>)?\\s+(\\w+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Const",
      "pattern": "^\\s*(?:override|const)\\s+(\\w+)",
      "captureGroup": 1,
      "type": "constant"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
