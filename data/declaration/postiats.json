{
  "language": "postiats",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Function",
      "pattern": "^\\s*fun\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Implement",
      "pattern": "^\\s*implement\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Val",
      "pattern": "^\\s*val\\s+(\\w+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Datatype",
      "pattern": "^\\s*datatype\\s+(\\w+)",
      "captureGroup": 1,
      "type": "type"
    }
  ]
}