{
  "language": "coffee",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Class",
      "pattern": "^\\s*class\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Function",
      "pattern": "^\\s*(\\w+)\\s*[:=]\\s*(?:\\(.*\\))?\\s*[-=]>",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Assignment",
      "pattern": "^\\s*(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "variable"
    }
  ]
}