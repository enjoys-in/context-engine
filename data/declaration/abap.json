{
  "language": "abap",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Data",
      "pattern": "^\\s*DATA[:\\s]\\s*(\\w+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Types",
      "pattern": "^\\s*TYPES[:\\s]\\s*(\\w+)",
      "captureGroup": 1,
      "type": "type"
    },
    {
      "name": "Class",
      "pattern": "^\\s*CLASS\\s+(\\w+)\\s+DEFINITION",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Method",
      "pattern": "^\\s*METHODS\\s+(\\w+)",
      "captureGroup": 1,
      "type": "method"
    },
    {
      "name": "Interface",
      "pattern": "^\\s*INTERFACE\\s+(\\w+)",
      "captureGroup": 1,
      "type": "interface"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
