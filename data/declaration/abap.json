{
  "language": "abap",
  "declarations": {},
  "declarationPatterns": [
    { "name": "Data", "pattern": "^\\s*DATA[:\\s]\\s*(\\w+)", "captureGroup": 1, "type": "variable" },
    { "name": "Types", "pattern": "^\\s*TYPES[:\\s]\\s*(\\w+)", "captureGroup": 1, "type": "type" },
    { "name": "Class", "pattern": "^\\s*CLASS\\s+(\\w+)\\s+DEFINITION", "captureGroup": 1, "type": "class" },
    { "name": "Method", "pattern": "^\\s*METHODS\\s+(\\w+)", "captureGroup": 1, "type": "method" },
    { "name": "Interface", "pattern": "^\\s*INTERFACE\\s+(\\w+)", "captureGroup": 1, "type": "interface" }
  ]
}
