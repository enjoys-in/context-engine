{
  "language": "ssh_config",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Host",
      "pattern": "^\\\\s*Host\\\\s+(\\\\S+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Match",
      "pattern": "^\\\\s*Match\\\\s+(.+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "host_block",
      "pattern": "^Host\\s+(.+)",
      "captureGroup": 1,
      "type": "host"
    },
    {
      "name": "match_block",
      "pattern": "^Match\\s+(.+)",
      "captureGroup": 1,
      "type": "match"
    },
    {
      "name": "identity_file",
      "pattern": "IdentityFile\\s+(\\S+)",
      "captureGroup": 1,
      "type": "identity_file"
    },
    {
      "name": "local_forward",
      "pattern": "LocalForward\\s+(\\d+)\\s+(\\S+)",
      "captureGroup": 1,
      "type": "port_forward"
    },
    {
      "name": "include",
      "pattern": "Include\\s+(\\S+)",
      "captureGroup": 1,
      "type": "include"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
