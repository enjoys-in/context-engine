{
  "language": "ssh_config",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Host",
      "pattern": "^\\\\s*Host\\\\s+(\\\\S+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Match",
      "pattern": "^\\\\s*Match\\\\s+(.+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "host_block",
      "pattern": "^Host\\s+(.+)",
      "captureGroup": 1,
      "type": "host"
    },
    {
      "name": "match_block",
      "pattern": "^Match\\s+(.+)",
      "captureGroup": 1,
      "type": "match"
    },
    {
      "name": "identity_file",
      "pattern": "IdentityFile\\s+(\\S+)",
      "captureGroup": 1,
      "type": "identity_file"
    },
    {
      "name": "local_forward",
      "pattern": "LocalForward\\s+(\\d+)\\s+(\\S+)",
      "captureGroup": 1,
      "type": "port_forward"
    },
    {
      "name": "include",
      "pattern": "Include\\s+(\\S+)",
      "captureGroup": 1,
      "type": "include"
    }
  ]
}
