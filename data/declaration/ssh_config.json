{
  "language": "ssh_config",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Host",
      "pattern": "^\\\\s*Host\\\\s+(\\\\S+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Match",
      "pattern": "^\\\\s*Match\\\\s+(.+)",
      "captureGroup": 1,
      "type": "module"
    }
  ]
}
