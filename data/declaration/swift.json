{
  "language": "swift",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Function Declaration",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public|open|override|final|static|class|mutating|nonmutating|nonisolated)\\s+)*func\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Class Declaration",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public|open|final)\\s+)*class\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Struct Declaration",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public)\\s+)*struct\\s+(\\w+)",
      "captureGroup": 1,
      "type": "struct"
    },
    {
      "name": "Enum Declaration",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public)\\s+)*enum\\s+(\\w+)",
      "captureGroup": 1,
      "type": "enum"
    },
    {
      "name": "Protocol Declaration",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public)\\s+)*protocol\\s+(\\w+)",
      "captureGroup": 1,
      "type": "protocol"
    },
    {
      "name": "Type Alias",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public)\\s+)*typealias\\s+(\\w+)",
      "captureGroup": 1,
      "type": "type_alias"
    },
    {
      "name": "Let Declaration",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public|open|static|class)\\s+)*let\\s+(\\w+)",
      "captureGroup": 1,
      "type": "constant"
    },
    {
      "name": "Var Declaration",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public|open|static|class|lazy|weak|unowned|@\\w+\\s*)\\s+)*var\\s+(\\w+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Initializer Declaration",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public|required|convenience|override)\\s+)*init[?!]?\\s*\\(",
      "captureGroup": 0,
      "type": "initializer"
    },
    {
      "name": "Extension Declaration",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public)\\s+)*extension\\s+(\\w+)",
      "captureGroup": 1,
      "type": "extension"
    },
    {
      "name": "Actor Declaration",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public)\\s+)*actor\\s+(\\w+)",
      "captureGroup": 1,
      "type": "actor"
    },
    {
      "name": "Subscript Declaration",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public|open|override|static|class)\\s+)*subscript\\s*\\(",
      "captureGroup": 0,
      "type": "subscript"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
