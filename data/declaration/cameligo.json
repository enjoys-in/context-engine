{
  "language": "cameligo",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Let",
      "pattern": "^\\s*let\\s+(\\w+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Type",
      "pattern": "^\\s*type\\s+(\\w+)",
      "captureGroup": 1,
      "type": "type"
    },
    {
      "name": "Module",
      "pattern": "^\\s*module\\s+(\\w+)",
      "captureGroup": 1,
      "type": "module"
    }
  ]
}