{
  "language": "systemverilog",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Module",
      "pattern": "^\\s*module\\s+(\\w+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Interface",
      "pattern": "^\\s*interface\\s+(\\w+)",
      "captureGroup": 1,
      "type": "interface"
    },
    {
      "name": "Class",
      "pattern": "^\\s*(?:virtual\\s+)?class\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Function",
      "pattern": "^\\s*(?:virtual\\s+)?function\\s+\\w+\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Task",
      "pattern": "^\\s*task\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    }
  ]
}