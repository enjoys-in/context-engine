{
  "language": "redshift",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Table",
      "pattern": "CREATE\\s+TABLE\\s+(?:IF\\s+NOT\\s+EXISTS\\s+)?(\\S+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "View",
      "pattern": "CREATE\\s+VIEW\\s+(\\S+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "table",
      "pattern": "CREATE\\s+TABLE\\s+(?:IF\\s+NOT\\s+EXISTS\\s+)?([\\w.]+)",
      "captureGroup": 1,
      "type": "table"
    },
    {
      "name": "view",
      "pattern": "CREATE\\s+(?:OR\\s+REPLACE\\s+)?VIEW\\s+([\\w.]+)",
      "captureGroup": 1,
      "type": "view"
    },
    {
      "name": "function",
      "pattern": "CREATE\\s+(?:OR\\s+REPLACE\\s+)?FUNCTION\\s+([\\w.]+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "schema",
      "pattern": "CREATE\\s+SCHEMA\\s+(?:IF\\s+NOT\\s+EXISTS\\s+)?(\\w+)",
      "captureGroup": 1,
      "type": "schema"
    },
    {
      "name": "column",
      "pattern": "(\\w+)\\s+(?:VARCHAR|INTEGER|BOOLEAN|TIMESTAMP|DATE|DECIMAL|FLOAT|BIGINT|SMALLINT|CHAR)",
      "captureGroup": 1,
      "type": "column"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
