{
  "language": "powerquery",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Step",
      "pattern": "^\\s*(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Section",
      "pattern": "^\\s*section\\s+(\\w+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "let_binding",
      "pattern": "let\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "function",
      "pattern": "(\\w+)\\s*=\\s*\\([^)]*\\)\\s*=>",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "section",
      "pattern": "section\\s+(\\w+)",
      "captureGroup": 1,
      "type": "section"
    },
    {
      "name": "type_def",
      "pattern": "type\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "type"
    },
    {
      "name": "query_step",
      "pattern": "#\"([^\"]+)\"\\s*=",
      "captureGroup": 1,
      "type": "step"
    }
  ]
}
