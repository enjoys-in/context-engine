{
  "language": "powerquery",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Step",
      "pattern": "^\\s*(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Section",
      "pattern": "^\\s*section\\s+(\\w+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "let_binding",
      "pattern": "let\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "function",
      "pattern": "(\\w+)\\s*=\\s*\\([^)]*\\)\\s*=>",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "section",
      "pattern": "section\\s+(\\w+)",
      "captureGroup": 1,
      "type": "section"
    },
    {
      "name": "type_def",
      "pattern": "type\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "type"
    },
    {
      "name": "query_step",
      "pattern": "#\"([^\"]+)\"\\s*=",
      "captureGroup": 1,
      "type": "step"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
