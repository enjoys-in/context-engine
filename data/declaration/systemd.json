{
  "language": "systemd",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Section",
      "pattern": "^\\\\[([^\\\\]]+)\\\\]",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Directive",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*=",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "unit_section",
      "pattern": "^\\[(\\w+)\\]",
      "captureGroup": 1,
      "type": "section"
    },
    {
      "name": "exec_start",
      "pattern": "ExecStart=([-+!@:]*)(\\S+)",
      "captureGroup": 2,
      "type": "service_command"
    },
    {
      "name": "environment",
      "pattern": "Environment=\"(\\w+)=",
      "captureGroup": 1,
      "type": "environment_variable"
    },
    {
      "name": "wants",
      "pattern": "Wants=(\\S+)",
      "captureGroup": 1,
      "type": "dependency"
    },
    {
      "name": "after",
      "pattern": "After=(\\S+)",
      "captureGroup": 1,
      "type": "ordering"
    },
    {
      "name": "alias",
      "pattern": "Alias=(\\S+)",
      "captureGroup": 1,
      "type": "alias"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
