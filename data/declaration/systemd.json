{
  "language": "systemd",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Section",
      "pattern": "^\\\\[([^\\\\]]+)\\\\]",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Directive",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*=",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "unit_section",
      "pattern": "^\\[(\\w+)\\]",
      "captureGroup": 1,
      "type": "section"
    },
    {
      "name": "exec_start",
      "pattern": "ExecStart=([-+!@:]*)(\\S+)",
      "captureGroup": 2,
      "type": "service_command"
    },
    {
      "name": "environment",
      "pattern": "Environment=\"(\\w+)=",
      "captureGroup": 1,
      "type": "environment_variable"
    },
    {
      "name": "wants",
      "pattern": "Wants=(\\S+)",
      "captureGroup": 1,
      "type": "dependency"
    },
    {
      "name": "after",
      "pattern": "After=(\\S+)",
      "captureGroup": 1,
      "type": "ordering"
    },
    {
      "name": "alias",
      "pattern": "Alias=(\\S+)",
      "captureGroup": 1,
      "type": "alias"
    }
  ]
}
