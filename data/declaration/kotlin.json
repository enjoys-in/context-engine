{
  "language": "kotlin",
  "declarations": {},
  "declarationPatterns": [
    {"name": "Function Declaration", "pattern": "^\\s*(?:(?:private|protected|internal|public|override|open|abstract|suspend|inline|infix|operator|tailrec)\\s+)*fun\\s+(\\w+)", "captureGroup": 1, "type": "function"},
    {"name": "Class Declaration", "pattern": "^\\s*(?:(?:private|protected|internal|public|abstract|open|sealed|data|inner|enum|annotation)\\s+)*class\\s+(\\w+)", "captureGroup": 1, "type": "class"},
    {"name": "Interface Declaration", "pattern": "^\\s*(?:(?:private|protected|internal|public|sealed)\\s+)*interface\\s+(\\w+)", "captureGroup": 1, "type": "interface"},
    {"name": "Object Declaration", "pattern": "^\\s*(?:(?:private|protected|internal|public)\\s+)*object\\s+(\\w+)", "captureGroup": 1, "type": "module"},
    {"name": "Property Declaration", "pattern": "^\\s*(?:(?:private|protected|internal|public|override|open|const|lateinit)\\s+)*(?:val|var)\\s+(\\w+)", "captureGroup": 1, "type": "variable"},
    {"name": "Type Alias", "pattern": "^\\s*typealias\\s+(\\w+)", "captureGroup": 1, "type": "type_alias"},
    {"name": "Enum Declaration", "pattern": "^\\s*enum\\s+class\\s+(\\w+)", "captureGroup": 1, "type": "enum"},
    {"name": "Companion Object", "pattern": "^\\s*companion\\s+object\\s+(\\w+)", "captureGroup": 1, "type": "module"}
  ]
}