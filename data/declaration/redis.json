{
  "language": "redis",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "key",
      "pattern": "SET\\s+(\\S+)",
      "captureGroup": 1,
      "type": "key"
    },
    {
      "name": "hash_field",
      "pattern": "HSET\\s+\\S+\\s+(\\S+)",
      "captureGroup": 1,
      "type": "field"
    },
    {
      "name": "stream",
      "pattern": "XADD\\s+(\\S+)",
      "captureGroup": 1,
      "type": "stream"
    },
    {
      "name": "group",
      "pattern": "XGROUP\\s+CREATE\\s+\\S+\\s+(\\S+)",
      "captureGroup": 1,
      "type": "group"
    },
    {
      "name": "function_def",
      "pattern": "FUNCTION\\s+LOAD\\s+.*name\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
