{
  "language": "redis",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "key",
      "pattern": "SET\\s+(\\S+)",
      "captureGroup": 1,
      "type": "key"
    },
    {
      "name": "hash_field",
      "pattern": "HSET\\s+\\S+\\s+(\\S+)",
      "captureGroup": 1,
      "type": "field"
    },
    {
      "name": "stream",
      "pattern": "XADD\\s+(\\S+)",
      "captureGroup": 1,
      "type": "stream"
    },
    {
      "name": "group",
      "pattern": "XGROUP\\s+CREATE\\s+\\S+\\s+(\\S+)",
      "captureGroup": 1,
      "type": "group"
    },
    {
      "name": "function_def",
      "pattern": "FUNCTION\\s+LOAD\\s+.*name\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    }
  ]
}
