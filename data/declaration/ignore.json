{
  "language": "ignore",
  "declarations": {
    "#": {
      "signature": "# comment",
      "description": "Comment syntax — lines beginning with # are ignored by the pattern matcher",
      "type": "keyword",
      "module": "syntax"
    },
    "*": {
      "signature": "* (wildcard)",
      "description": "Glob wildcard matching any characters except /",
      "type": "keyword",
      "module": "syntax"
    },
    "**": {
      "signature": "** (double star)",
      "description": "Recursive wildcard matching zero or more directories",
      "type": "keyword",
      "module": "syntax"
    },
    "?": {
      "signature": "? (single char)",
      "description": "Matches exactly one character except /",
      "type": "keyword",
      "module": "syntax"
    },
    "!": {
      "signature": "! (negation)",
      "description": "Negation prefix to re-include previously ignored files",
      "type": "keyword",
      "module": "syntax"
    },
    "/": {
      "signature": "/ (anchor/directory)",
      "description": "Leading / anchors to root; trailing / matches directories only",
      "type": "keyword",
      "module": "syntax"
    }
  },
  "declarationPatterns": [
    {
      "name": "Comment Section",
      "pattern": "^\\s*#\\s*(.+)",
      "captureGroup": 1,
      "type": "constant"
    },
    {
      "name": "Negated Pattern",
      "pattern": "^\\s*!(.+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Directory Pattern",
      "pattern": "^\\s*([^#!\\s][^\\s]*)/$",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "File/Glob Pattern",
      "pattern": "^\\s*([^#!\\s/][^\\s]*)\\s*$",
      "captureGroup": 1,
      "type": "variable"
    }
  ]
}