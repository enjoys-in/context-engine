{
  "language": "ini",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Section",
      "pattern": "^\\\\s*\\\\[([^\\\\]]+)\\\\]",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Key",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*=",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "section",
      "pattern": "^\\[(\\w[\\w\\s.-]*)\\]",
      "captureGroup": 1,
      "type": "section"
    },
    {
      "name": "key",
      "pattern": "^(\\w[\\w.-]*)\\s*=",
      "captureGroup": 1,
      "type": "key"
    },
    {
      "name": "subsection",
      "pattern": "^\\[(\\w+)\\s+\"([^\"]+)\"\\]",
      "captureGroup": 1,
      "type": "subsection"
    }
  ]
}
