{
  "language": "ini",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Section",
      "pattern": "^\\\\s*\\\\[([^\\\\]]+)\\\\]",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Key",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*=",
      "captureGroup": 1,
      "type": "variable"
    }
  ]
}
