  "declarationPatterns": [
    {
      "name": "Function",
      "pattern": "^\\\\s*(?:public|private|protected|static)?\\\\s*function\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Class",
      "pattern": "^\\\\s*(?:abstract|final)?\\\\s*class\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Interface",
      "pattern": "^\\\\s*interface\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "interface"
    },
    {
      "name": "Trait",
      "pattern": "^\\\\s*trait\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Enum",
      "pattern": "^\\\\s*enum\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "enum"
    },
    {
      "name": "Namespace",
      "pattern": "^\\\\s*namespace\\\\s+([\\\\w\\\\\\\\]+)",
      "captureGroup": 1,
      "type": "module"
    }
  ]
