{
  "language": "clojure",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Function",
      "pattern": "^\\s*\\(defn-?\\s+(\\S+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Def",
      "pattern": "^\\s*\\(def\\s+(\\S+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Macro",
      "pattern": "^\\s*\\(defmacro\\s+(\\S+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Protocol",
      "pattern": "^\\s*\\(defprotocol\\s+(\\S+)",
      "captureGroup": 1,
      "type": "interface"
    },
    {
      "name": "Record",
      "pattern": "^\\s*\\(defrecord\\s+(\\S+)",
      "captureGroup": 1,
      "type": "class"
    }
  ]
}