{
  "language": "clojure",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Function",
      "pattern": "^\\s*\\(defn-?\\s+(\\S+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Def",
      "pattern": "^\\s*\\(def\\s+(\\S+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Macro",
      "pattern": "^\\s*\\(defmacro\\s+(\\S+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Protocol",
      "pattern": "^\\s*\\(defprotocol\\s+(\\S+)",
      "captureGroup": 1,
      "type": "interface"
    },
    {
      "name": "Record",
      "pattern": "^\\s*\\(defrecord\\s+(\\S+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
