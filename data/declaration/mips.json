{
  "language": "mips",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Label",
      "pattern": "^(\\w+):",
      "captureGroup": 1,
      "type": "constant"
    },
    {
      "name": "Directive",
      "pattern": "^\\s*(\\.\\w+)",
      "captureGroup": 1,
      "type": "string"
    },
    {
      "name": "label",
      "pattern": "^(\\w+):",
      "captureGroup": 1,
      "type": "label"
    },
    {
      "name": "data_label",
      "pattern": "^(\\w+):\\s+\\.(word|half|byte|float|double|asciiz|space)",
      "captureGroup": 1,
      "type": "data_label"
    },
    {
      "name": "macro",
      "pattern": "\\.macro\\s+(\\w+)",
      "captureGroup": 1,
      "type": "macro"
    },
    {
      "name": "eqv_constant",
      "pattern": "\\.eqv\\s+(\\w+)",
      "captureGroup": 1,
      "type": "constant"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
