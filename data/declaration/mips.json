{
  "language": "mips",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Label",
      "pattern": "^(\\w+):",
      "captureGroup": 1,
      "type": "constant"
    },
    {
      "name": "Directive",
      "pattern": "^\\s*(\\.\\w+)",
      "captureGroup": 1,
      "type": "string"
    },
    {
      "name": "label",
      "pattern": "^(\\w+):",
      "captureGroup": 1,
      "type": "label"
    },
    {
      "name": "data_label",
      "pattern": "^(\\w+):\\s+\\.(word|half|byte|float|double|asciiz|space)",
      "captureGroup": 1,
      "type": "data_label"
    },
    {
      "name": "macro",
      "pattern": "\\.macro\\s+(\\w+)",
      "captureGroup": 1,
      "type": "macro"
    },
    {
      "name": "eqv_constant",
      "pattern": "\\.eqv\\s+(\\w+)",
      "captureGroup": 1,
      "type": "constant"
    }
  ]
}
