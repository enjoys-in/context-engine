  "declarationPatterns": [
    {
      "name": "Function Declaration",
      "pattern": "^\\\\s*(?:export\\\\s+)?(?:async\\\\s+)?function\\\\s*\\\\*?\\\\s*(\\\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Class",
      "pattern": "^\\\\s*(?:export\\\\s+)?class\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Const/Let/Var",
      "pattern": "^\\\\s*(?:export\\\\s+)?(?:const|let|var)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Arrow Function",
      "pattern": "^\\\\s*(?:export\\\\s+)?(?:const|let|var)\\\\s+(\\\\w+)\\\\s*=\\\\s*(?:async\\\\s+)?(?:\\\\([^)]*\\\\)|\\\\w+)\\\\s*=>",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Method",
      "pattern": "^\\\\s*(?:async\\\\s+)?(?:static\\\\s+)?(?:get\\\\s+|set\\\\s+)?(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "type": "method"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
