{
  "language": "yaml",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Key",
      "pattern": "^\\\\s*(\\\\w[\\\\w.-]*)\\\\s*:",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Anchor",
      "pattern": "&(\\\\w+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Alias",
      "pattern": "\\\\*(\\\\w+)",
      "captureGroup": 1,
      "type": "variable"
    }
  ]
}
