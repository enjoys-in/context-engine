{
  "language": "pgsql",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Table",
      "pattern": "CREATE\\s+TABLE\\s+(?:IF\\s+NOT\\s+EXISTS\\s+)?(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Function",
      "pattern": "CREATE\\s+(?:OR\\s+REPLACE\\s+)?FUNCTION\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "View",
      "pattern": "CREATE\\s+(?:MATERIALIZED\\s+)?VIEW\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Index",
      "pattern": "CREATE\\s+(?:UNIQUE\\s+)?INDEX\\s+(\\w+)",
      "captureGroup": 1,
      "type": "constant"
    },
    {
      "name": "Type",
      "pattern": "CREATE\\s+TYPE\\s+(\\w+)",
      "captureGroup": 1,
      "type": "type"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
