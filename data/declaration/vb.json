{
  "language": "vb",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Class",
      "pattern": "^\\s*(?:Public|Private|Friend)?\\s*(?:Partial\\s+)?Class\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Module",
      "pattern": "^\\s*Module\\s+(\\w+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Sub",
      "pattern": "^\\s*(?:Public|Private|Protected|Friend)?\\s*(?:Shared\\s+)?Sub\\s+(\\w+)",
      "captureGroup": 1,
      "type": "method"
    },
    {
      "name": "Function",
      "pattern": "^\\s*(?:Public|Private|Protected|Friend)?\\s*(?:Shared\\s+)?Function\\s+(\\w+)",
      "captureGroup": 1,
      "type": "method"
    },
    {
      "name": "Property",
      "pattern": "^\\s*(?:Public|Private)?\\s*Property\\s+(\\w+)",
      "captureGroup": 1,
      "type": "property"
    }
  ]
}