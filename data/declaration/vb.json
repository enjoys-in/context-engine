{
  "language": "vb",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Class",
      "pattern": "^\\s*(?:Public|Private|Friend)?\\s*(?:Partial\\s+)?Class\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Module",
      "pattern": "^\\s*Module\\s+(\\w+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Sub",
      "pattern": "^\\s*(?:Public|Private|Protected|Friend)?\\s*(?:Shared\\s+)?Sub\\s+(\\w+)",
      "captureGroup": 1,
      "type": "method"
    },
    {
      "name": "Function",
      "pattern": "^\\s*(?:Public|Private|Protected|Friend)?\\s*(?:Shared\\s+)?Function\\s+(\\w+)",
      "captureGroup": 1,
      "type": "method"
    },
    {
      "name": "Property",
      "pattern": "^\\s*(?:Public|Private)?\\s*Property\\s+(\\w+)",
      "captureGroup": 1,
      "type": "property"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
