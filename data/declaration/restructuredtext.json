{
  "language": "restructuredtext",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Section",
      "pattern": "^(.+)\\n[=\\-~^]+$",
      "captureGroup": 1,
      "type": "string"
    },
    {
      "name": "Directive",
      "pattern": "^\\.\\. (\\w+)::",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "section",
      "pattern": "^(.+)\\n[=\\-~^\"]+$",
      "captureGroup": 1,
      "type": "section"
    },
    {
      "name": "directive",
      "pattern": "\\.\\.\\s+([\\w-]+)::",
      "captureGroup": 1,
      "type": "directive"
    },
    {
      "name": "substitution",
      "pattern": "\\.\\.\\s+\\|([\\w\\s]+)\\|",
      "captureGroup": 1,
      "type": "substitution"
    },
    {
      "name": "footnote",
      "pattern": "\\.\\.\\s+\\[([\\w#]+)\\]",
      "captureGroup": 1,
      "type": "footnote"
    },
    {
      "name": "target",
      "pattern": "\\.\\.\\s+_(\\w+):",
      "captureGroup": 1,
      "type": "hyperlink_target"
    },
    {
      "name": "role",
      "pattern": ":(\\w+):`([^`]+)`",
      "captureGroup": 1,
      "type": "role"
    }
  ]
}
