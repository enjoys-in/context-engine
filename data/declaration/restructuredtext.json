{
  "language": "restructuredtext",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Section",
      "pattern": "^(.+)\\n[=\\-~^]+$",
      "captureGroup": 1,
      "type": "string"
    },
    {
      "name": "Directive",
      "pattern": "^\\.\\. (\\w+)::",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "section",
      "pattern": "^(.+)\\n[=\\-~^\"]+$",
      "captureGroup": 1,
      "type": "section"
    },
    {
      "name": "directive",
      "pattern": "\\.\\.\\s+([\\w-]+)::",
      "captureGroup": 1,
      "type": "directive"
    },
    {
      "name": "substitution",
      "pattern": "\\.\\.\\s+\\|([\\w\\s]+)\\|",
      "captureGroup": 1,
      "type": "substitution"
    },
    {
      "name": "footnote",
      "pattern": "\\.\\.\\s+\\[([\\w#]+)\\]",
      "captureGroup": 1,
      "type": "footnote"
    },
    {
      "name": "target",
      "pattern": "\\.\\.\\s+_(\\w+):",
      "captureGroup": 1,
      "type": "hyperlink_target"
    },
    {
      "name": "role",
      "pattern": ":(\\w+):`([^`]+)`",
      "captureGroup": 1,
      "type": "role"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
