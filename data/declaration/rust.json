  "declarationPatterns": [
    {
      "name": "Function",
      "pattern": "^\\\\s*(?:pub\\\\s+)?(?:async\\\\s+)?fn\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Struct",
      "pattern": "^\\\\s*(?:pub\\\\s+)?struct\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "struct"
    },
    {
      "name": "Enum",
      "pattern": "^\\\\s*(?:pub\\\\s+)?enum\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "enum"
    },
    {
      "name": "Trait",
      "pattern": "^\\\\s*(?:pub\\\\s+)?(?:unsafe\\\\s+)?trait\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "interface"
    },
    {
      "name": "Impl",
      "pattern": "^\\\\s*impl(?:<[^>]*>)?\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Type Alias",
      "pattern": "^\\\\s*(?:pub\\\\s+)?type\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Module",
      "pattern": "^\\\\s*(?:pub\\\\s+)?mod\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Const",
      "pattern": "^\\\\s*(?:pub\\\\s+)?const\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "type": "constant"
    },
    {
      "name": "Static",
      "pattern": "^\\\\s*(?:pub\\\\s+)?static\\\\s+(?:mut\\\\s+)?(\\\\w+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
