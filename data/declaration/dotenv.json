{
  "language": "dotenv",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Variable",
      "pattern": "^\\\\s*(?:export\\\\s+)?(\\\\w+)\\\\s*=",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "env_variable",
      "pattern": "^(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "export_variable",
      "pattern": "^export\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "export"
    },
    {
      "name": "database_url",
      "pattern": "^(DATABASE_URL|DB_\\w+)\\s*=",
      "captureGroup": 1,
      "type": "database_config"
    },
    {
      "name": "api_key",
      "pattern": "^(\\w*API_KEY\\w*|\\w*SECRET\\w*|\\w*TOKEN\\w*)\\s*=",
      "captureGroup": 1,
      "type": "secret"
    },
    {
      "name": "port",
      "pattern": "^(PORT|\\w*_PORT)\\s*=",
      "captureGroup": 1,
      "type": "port_config"
    }
  ]
}
