{
  "language": "dotenv",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Variable",
      "pattern": "^\\\\s*(?:export\\\\s+)?(\\\\w+)\\\\s*=",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "env_variable",
      "pattern": "^(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "export_variable",
      "pattern": "^export\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "export"
    },
    {
      "name": "database_url",
      "pattern": "^(DATABASE_URL|DB_\\w+)\\s*=",
      "captureGroup": 1,
      "type": "database_config"
    },
    {
      "name": "api_key",
      "pattern": "^(\\w*API_KEY\\w*|\\w*SECRET\\w*|\\w*TOKEN\\w*)\\s*=",
      "captureGroup": 1,
      "type": "secret"
    },
    {
      "name": "port",
      "pattern": "^(PORT|\\w*_PORT)\\s*=",
      "captureGroup": 1,
      "type": "port_config"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
