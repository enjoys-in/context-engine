{
  "language": "pascal",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Program",
      "pattern": "^\\s*program\\s+(\\w+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Unit",
      "pattern": "^\\s*unit\\s+(\\w+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Procedure",
      "pattern": "^\\s*procedure\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Function",
      "pattern": "^\\s*function\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Type",
      "pattern": "^\\s*(T\\w+)\\s*=\\s*class",
      "captureGroup": 1,
      "type": "class"
    }
  ]
}