{
  "language": "docker-compose",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Service",
      "pattern": "^\\s*services:\\s*\\n\\s{2}(\\w[\\w.-]*):",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Network",
      "pattern": "^networks:\\s*\\n\\s{2}(\\w[\\w.-]*):",
      "captureGroup": 1,
      "type": "namespace"
    },
    {
      "name": "Volume",
      "pattern": "^volumes:\\s*\\n\\s{2}(\\w[\\w.-]*):",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Secret",
      "pattern": "^secrets:\\s*\\n\\s{2}(\\w[\\w.-]*):",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Config",
      "pattern": "^configs:\\s*\\n\\s{2}(\\w[\\w.-]*):",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "YamlAnchor",
      "pattern": "&(\\w[\\w.-]*)\\s",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
