{
  "language": "docker-compose",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Service",
      "pattern": "^\\s*services:\\s*\\n\\s{2}(\\w[\\w.-]*):",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Network",
      "pattern": "^networks:\\s*\\n\\s{2}(\\w[\\w.-]*):",
      "captureGroup": 1,
      "type": "namespace"
    },
    {
      "name": "Volume",
      "pattern": "^volumes:\\s*\\n\\s{2}(\\w[\\w.-]*):",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Secret",
      "pattern": "^secrets:\\s*\\n\\s{2}(\\w[\\w.-]*):",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Config",
      "pattern": "^configs:\\s*\\n\\s{2}(\\w[\\w.-]*):",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "YamlAnchor",
      "pattern": "&(\\w[\\w.-]*)\\s",
      "captureGroup": 1,
      "type": "variable"
    }
  ]
}
