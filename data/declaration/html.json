{
  "language": "html",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "ID",
      "pattern": "id=\"([^\"]+)\"",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Class",
      "pattern": "class=\"([^\"]+)\"",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "element_id",
      "pattern": "id\\s*=\\s*[\"'](\\w+)[\"']",
      "captureGroup": 1,
      "type": "id"
    },
    {
      "name": "element_class",
      "pattern": "class\\s*=\\s*[\"']([\\w\\s-]+)[\"']",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "data_attribute",
      "pattern": "(data-[\\w-]+)\\s*=",
      "captureGroup": 1,
      "type": "data_attribute"
    },
    {
      "name": "form_name",
      "pattern": "name\\s*=\\s*[\"'](\\w+)[\"']",
      "captureGroup": 1,
      "type": "form_field"
    },
    {
      "name": "custom_element",
      "pattern": "<([a-z]+-[a-z][\\w-]*)",
      "captureGroup": 1,
      "type": "custom_element"
    },
    {
      "name": "script_src",
      "pattern": "<script\\s+src\\s*=\\s*[\"']([^\"']+)[\"']",
      "captureGroup": 1,
      "type": "script"
    },
    {
      "name": "link_href",
      "pattern": "<link\\s+.*href\\s*=\\s*[\"']([^\"']+)[\"']",
      "captureGroup": 1,
      "type": "stylesheet"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
