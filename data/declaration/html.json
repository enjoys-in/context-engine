{
  "language": "html",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "ID",
      "pattern": "id=\"([^\"]+)\"",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Class",
      "pattern": "class=\"([^\"]+)\"",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "element_id",
      "pattern": "id\\s*=\\s*[\"'](\\w+)[\"']",
      "captureGroup": 1,
      "type": "id"
    },
    {
      "name": "element_class",
      "pattern": "class\\s*=\\s*[\"']([\\w\\s-]+)[\"']",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "data_attribute",
      "pattern": "(data-[\\w-]+)\\s*=",
      "captureGroup": 1,
      "type": "data_attribute"
    },
    {
      "name": "form_name",
      "pattern": "name\\s*=\\s*[\"'](\\w+)[\"']",
      "captureGroup": 1,
      "type": "form_field"
    },
    {
      "name": "custom_element",
      "pattern": "<([a-z]+-[a-z][\\w-]*)",
      "captureGroup": 1,
      "type": "custom_element"
    },
    {
      "name": "script_src",
      "pattern": "<script\\s+src\\s*=\\s*[\"']([^\"']+)[\"']",
      "captureGroup": 1,
      "type": "script"
    },
    {
      "name": "link_href",
      "pattern": "<link\\s+.*href\\s*=\\s*[\"']([^\"']+)[\"']",
      "captureGroup": 1,
      "type": "stylesheet"
    }
  ]
}
