{
  "language": "pla",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Module",
      "pattern": "^\\s*module\\s+(\\w+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "procedure",
      "pattern": "PROCEDURE\\s+(\\w+)",
      "captureGroup": 1,
      "type": "procedure"
    },
    {
      "name": "function",
      "pattern": "FUNCTION\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "type",
      "pattern": "TYPE\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "type"
    },
    {
      "name": "constant",
      "pattern": "CONST\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "constant"
    },
    {
      "name": "variable",
      "pattern": "VAR\\s+(\\w+)\\s*:",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "record",
      "pattern": "(\\w+)\\s*=\\s*RECORD",
      "captureGroup": 1,
      "type": "record"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
