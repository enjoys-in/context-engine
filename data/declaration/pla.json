{
  "language": "pla",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Module",
      "pattern": "^\\s*module\\s+(\\w+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "procedure",
      "pattern": "PROCEDURE\\s+(\\w+)",
      "captureGroup": 1,
      "type": "procedure"
    },
    {
      "name": "function",
      "pattern": "FUNCTION\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "type",
      "pattern": "TYPE\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "type"
    },
    {
      "name": "constant",
      "pattern": "CONST\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "type": "constant"
    },
    {
      "name": "variable",
      "pattern": "VAR\\s+(\\w+)\\s*:",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "record",
      "pattern": "(\\w+)\\s*=\\s*RECORD",
      "captureGroup": 1,
      "type": "record"
    }
  ]
}
