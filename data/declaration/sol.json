{
  "language": "sol",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Contract",
      "pattern": "^\\s*(?:abstract\\s+)?contract\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Interface",
      "pattern": "^\\s*interface\\s+(\\w+)",
      "captureGroup": 1,
      "type": "interface"
    },
    {
      "name": "Library",
      "pattern": "^\\s*library\\s+(\\w+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Function",
      "pattern": "^\\s*function\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Event",
      "pattern": "^\\s*event\\s+(\\w+)",
      "captureGroup": 1,
      "type": "event"
    }
  ]
}