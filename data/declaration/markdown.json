{
  "language": "markdown",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Heading",
      "pattern": "^(#{1,6})\\\\s+(.+)",
      "captureGroup": 2,
      "type": "module"
    },
    {
      "name": "Link Definition",
      "pattern": "^\\\\[(\\\\w+)\\\\]:",
      "captureGroup": 1,
      "type": "variable"
    }
  ]
}
