{
  "language": "markdown",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Heading",
      "pattern": "^(#{1,6})\\\\s+(.+)",
      "captureGroup": 2,
      "type": "module"
    },
    {
      "name": "Link Definition",
      "pattern": "^\\\\[(\\\\w+)\\\\]:",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "heading",
      "pattern": "^(#{1,6})\\s+(.+)",
      "captureGroup": 2,
      "type": "heading"
    },
    {
      "name": "link_ref",
      "pattern": "^\\[(\\w[\\w\\s-]*)\\]:\\s+",
      "captureGroup": 1,
      "type": "link_reference"
    },
    {
      "name": "footnote",
      "pattern": "^\\[\\^(\\w+)\\]:",
      "captureGroup": 1,
      "type": "footnote"
    },
    {
      "name": "anchor",
      "pattern": "<a\\s+(?:name|id)\\s*=\\s*[\"'](\\w+)[\"']",
      "captureGroup": 1,
      "type": "anchor"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
