{
  "language": "markdown",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Heading",
      "pattern": "^(#{1,6})\\\\s+(.+)",
      "captureGroup": 2,
      "type": "module"
    },
    {
      "name": "Link Definition",
      "pattern": "^\\\\[(\\\\w+)\\\\]:",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "heading",
      "pattern": "^(#{1,6})\\s+(.+)",
      "captureGroup": 2,
      "type": "heading"
    },
    {
      "name": "link_ref",
      "pattern": "^\\[(\\w[\\w\\s-]*)\\]:\\s+",
      "captureGroup": 1,
      "type": "link_reference"
    },
    {
      "name": "footnote",
      "pattern": "^\\[\\^(\\w+)\\]:",
      "captureGroup": 1,
      "type": "footnote"
    },
    {
      "name": "anchor",
      "pattern": "<a\\s+(?:name|id)\\s*=\\s*[\"'](\\w+)[\"']",
      "captureGroup": 1,
      "type": "anchor"
    }
  ]
}
