{
  "language": "julia",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Function",
      "pattern": "^\\s*function\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Struct",
      "pattern": "^\\s*(?:mutable\\s+)?struct\\s+(\\w+)",
      "captureGroup": 1,
      "type": "struct"
    },
    {
      "name": "Module",
      "pattern": "^\\s*module\\s+(\\w+)",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Macro",
      "pattern": "^\\s*macro\\s+(\\w+)",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "Const",
      "pattern": "^\\s*const\\s+(\\w+)",
      "captureGroup": 1,
      "type": "constant"
    }
  ]
}