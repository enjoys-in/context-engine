{
  "language": "lexon",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Lex",
      "pattern": "^LEX\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Clause",
      "pattern": "^CLAUSE:\\s+(.+)\\.",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "clause",
      "pattern": "CLAUSE\\s+(\\w[\\w\\s]+?)\\s*\\.",
      "captureGroup": 1,
      "type": "clause"
    },
    {
      "name": "term",
      "pattern": "(\\w+)\\s+is\\s+",
      "captureGroup": 1,
      "type": "term"
    },
    {
      "name": "party",
      "pattern": "(\\w+)\\s+is\\s+a\\s+person",
      "captureGroup": 1,
      "type": "party"
    },
    {
      "name": "action",
      "pattern": "(\\w+)\\s+may\\s+",
      "captureGroup": 1,
      "type": "action"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
