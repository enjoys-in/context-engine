{
  "language": "lexon",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Lex",
      "pattern": "^LEX\\s+(\\w+)",
      "captureGroup": 1,
      "type": "class"
    },
    {
      "name": "Clause",
      "pattern": "^CLAUSE:\\s+(.+)\\.",
      "captureGroup": 1,
      "type": "function"
    },
    {
      "name": "clause",
      "pattern": "CLAUSE\\s+(\\w[\\w\\s]+?)\\s*\\.",
      "captureGroup": 1,
      "type": "clause"
    },
    {
      "name": "term",
      "pattern": "(\\w+)\\s+is\\s+",
      "captureGroup": 1,
      "type": "term"
    },
    {
      "name": "party",
      "pattern": "(\\w+)\\s+is\\s+a\\s+person",
      "captureGroup": 1,
      "type": "party"
    },
    {
      "name": "action",
      "pattern": "(\\w+)\\s+may\\s+",
      "captureGroup": 1,
      "type": "action"
    }
  ]
}
