  "declarationPatterns": [
    {
      "name": "key_set",
      "pattern": "^\\s*SET\\s+(\\S+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "hash_set",
      "pattern": "^\\s*HSET\\s+(\\S+)\\s+(\\S+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "list_push",
      "pattern": "^\\s*(?:LPUSH|RPUSH)\\s+(\\S+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "set_add",
      "pattern": "^\\s*SADD\\s+(\\S+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "sorted_set_add",
      "pattern": "^\\s*ZADD\\s+(\\S+)",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "pattern": "(?:let|var|const|val|auto|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Variable declaration",
      "kind": "variable"
    },
    {
      "pattern": "(?:function|def|fn|func|fun|sub|proc|method)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Function declaration",
      "kind": "function"
    },
    {
      "pattern": "(?:class|struct|type|interface|enum|trait|module|namespace|record)\\s+(\\w+)",
      "captureGroup": 1,
      "description": "Class/Type declaration",
      "kind": "class"
    },
    {
      "pattern": "(?:const|final|readonly|immutable|static)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "description": "Constant declaration",
      "kind": "constant"
    },
    {
      "pattern": "(?:import|require|use|include|from)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "description": "Import declaration",
      "kind": "import"
    }
  ]
}
