{
  "language": "toml",
  "declarations": {},
  "declarationPatterns": [
    {
      "name": "Table",
      "pattern": "^\\\\s*\\\\[([^\\\\[\\\\]]+)\\\\]",
      "captureGroup": 1,
      "type": "module"
    },
    {
      "name": "Array of Tables",
      "pattern": "^\\\\s*\\\\[\\\\[([^\\\\[\\\\]]+)\\\\]\\\\]",
      "captureGroup": 1,
      "type": "variable"
    },
    {
      "name": "Key",
      "pattern": "^\\\\s*([\\\\w.-]+)\\\\s*=",
      "captureGroup": 1,
      "type": "variable"
    }
  ]
}
