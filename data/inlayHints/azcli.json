{
  "language": "azcli",
  "inlayHintPatterns": [
    {
      "pattern": "az\\s+[\\w-]+\\s+[\\w-]+",
      "kind": 2,
      "label": "--{param}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names for Azure CLI command arguments"
    },
    {
      "kind": "parameter",
      "description": "Parameter name hints",
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "display": "parameterName:",
      "position": "before"
    },
    {
      "kind": "type",
      "description": "Inferred type hints",
      "pattern": "(?:let|var|val|const|auto)\\s+(\\w+)\\s*=",
      "display": ": inferredType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Return type hints",
      "pattern": "(?:function|def|fn|func|fun)\\s+\\w+\\s*\\([^)]*\\)\\s*(?:=>|->|:)?",
      "display": "-> returnType",
      "position": "after"
    },
    {
      "kind": "enum",
      "description": "Enum member value hints",
      "pattern": "(?:enum|const)\\s+\\w+",
      "display": "= value",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Chained method result type",
      "pattern": "\\.(\\w+)\\(",
      "display": ": resultType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Destructuring type hints",
      "pattern": "(?:const|let|var)\\s*[{\\[]",
      "display": ": type",
      "position": "inline"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"|'[^']*'",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\d+",
      "type": "integer"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "boolean"
    }
  }
}
