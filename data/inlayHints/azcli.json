{
  "language": "azcli",
  "inlayHintPatterns": [
    {
      "pattern": "az\\s+[\\w-]+\\s+[\\w-]+",
      "kind": 2,
      "label": "--{param}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names for Azure CLI command arguments"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"|'[^']*'",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\d+",
      "type": "integer"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "boolean"
    }
  }
}
