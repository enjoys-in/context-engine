{
  "language": "postiats",
  "inlayHintPatterns": [
    {
      "pattern": "val\\s+(\\w+)\\s*=",
      "kind": 1,
      "label": ": {type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show inferred types for val bindings"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "double"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "bool"
    }
  }
}
