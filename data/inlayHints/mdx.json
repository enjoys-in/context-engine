{
  "language": "mdx",
  "inlayHintPatterns": [
    {
      "pattern": "<(\\w+)\\s+",
      "kind": 2,
      "label": "{prop_name}=",
      "position": "before_each_prop",
      "paddingRight": true,
      "description": "Show prop names and expected types for JSX components"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\{\\d+\\}",
      "type": "number"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "boolean"
    },
    "null_literal": {
      "pattern": "\\b(null|undefined)\\b",
      "type": "null"
    }
  }
}
