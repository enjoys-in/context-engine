{
  "language": "protobuf",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s+(\\w+)\\s*=\\s*(\\d+)",
      "kind": 1,
      "label": "field #{tag}",
      "position": "after_field_number",
      "paddingLeft": true,
      "description": "Show field type and tag number annotations"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "int32"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "bool"
    }
  }
}
