{
  "language": "flow9",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at function call sites"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "double"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "bool"
    }
  }
}
