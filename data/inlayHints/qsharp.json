{
  "language": "qsharp",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at Q# operation and function call sites"
    },
    {
      "pattern": "let\\s+(\\w+)\\s*=",
      "kind": 1,
      "label": ": {type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show inferred types for let bindings"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "String"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "Double"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "Bool"
    },
    "qubit_literal": {
      "pattern": "\\b(Zero|One)\\b",
      "type": "Result"
    }
  }
}
