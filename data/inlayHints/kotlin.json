{
  "language": "kotlin",
  "inlayHintPatterns": [
    {
      "pattern": "(?:val|var)\\s+(\\w+)\\s*=\\s*(.+)",
      "kind": 1,
      "label": ": {inferred_type}",
      "position": "after_capture_1",
      "paddingLeft": true,
      "description": "Show inferred type for variable assignments"
    },
    {
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at call sites"
    },
    {
      "pattern": "fun\\s+\\w+\\([^)]*\\)\\s*=\\s*",
      "kind": 1,
      "label": ": {inferred_type}",
      "position": "after_equals",
      "paddingLeft": true,
      "description": "Show return type for expression functions"
    },
    {
      "pattern": "\\blambda\\b|\\{\\s*\\w+\\s*->",
      "kind": 1,
      "label": ": {inferred_type}",
      "position": "after_param",
      "paddingLeft": true,
      "description": "Show lambda parameter types"
    },
    {
      "kind": "parameter",
      "description": "Parameter name hints",
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "display": "parameterName:",
      "position": "before"
    },
    {
      "kind": "type",
      "description": "Inferred type hints",
      "pattern": "(?:let|var|val|const|auto)\\s+(\\w+)\\s*=",
      "display": ": inferredType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Return type hints",
      "pattern": "(?:function|def|fn|func|fun)\\s+\\w+\\s*\\([^)]*\\)\\s*(?:=>|->|:)?",
      "display": "-> returnType",
      "position": "after"
    },
    {
      "kind": "enum",
      "description": "Enum member value hints",
      "pattern": "(?:enum|const)\\s+\\w+",
      "display": "= value",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Chained method result type",
      "pattern": "\\.(\\w+)\\(",
      "display": ": resultType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Destructuring type hints",
      "pattern": "(?:const|let|var)\\s*[{\\[]",
      "display": ": type",
      "position": "inline"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\".*\"",
      "type": "String"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "Int"
    },
    "long_literal": {
      "pattern": "\\d+L",
      "type": "Long"
    },
    "float_literal": {
      "pattern": "\\d+\\.\\d+[fF]",
      "type": "Float"
    },
    "double_literal": {
      "pattern": "\\d+\\.\\d+(?!f)",
      "type": "Double"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "Boolean"
    },
    "char_literal": {
      "pattern": "'.'",
      "type": "Char"
    },
    "null_literal": {
      "pattern": "\\bnull\\b",
      "type": "Nothing?"
    },
    "list_literal": {
      "pattern": "listOf\\(",
      "type": "List<T>"
    },
    "map_literal": {
      "pattern": "mapOf\\(",
      "type": "Map<K, V>"
    },
    "set_literal": {
      "pattern": "setOf\\(",
      "type": "Set<T>"
    },
    "array_literal": {
      "pattern": "arrayOf\\(",
      "type": "Array<T>"
    }
  }
}
