{
  "language": "xml",
  "inlayHintPatterns": [
    {
      "pattern": "</(\\w+)>",
      "kind": 1,
      "label": "<!-- /{tag} -->",
      "position": "after_closing_tag",
      "paddingLeft": true,
      "description": "Show matching element name hint on deeply nested closing tags"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"|'[^']*'",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "number"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "boolean"
    }
  }
}
