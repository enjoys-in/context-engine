{
  "language": "twig",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at Twig function and filter call sites"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "['\"].*['\"]",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "number"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "boolean"
    },
    "null_literal": {
      "pattern": "\\b(null|none)\\b",
      "type": "null"
    },
    "array_literal": {
      "pattern": "\\[.*\\]",
      "type": "array"
    },
    "hash_literal": {
      "pattern": "\\{.*:.*\\}",
      "type": "hash"
    }
  }
}
