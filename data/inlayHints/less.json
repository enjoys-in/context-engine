{
  "language": "less",
  "inlayHintPatterns": [
    {
      "pattern": "\\.([\\w-]+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at mixin call sites"
    },
    {
      "pattern": "@([\\w-]+)\\s*:",
      "kind": 1,
      "label": ": {type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show inferred value types for LESS variables"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "['\"].*['\"]",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?(px|em|rem|%|vw|vh)?",
      "type": "dimension"
    },
    "color_literal": {
      "pattern": "#[0-9a-fA-F]{3,8}",
      "type": "color"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "boolean"
    }
  }
}
