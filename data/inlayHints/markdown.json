{
  "language": "markdown",
  "inlayHintPatterns": [
    {
      "pattern": "^(#{1,6})\\s+",
      "kind": 1,
      "label": "H{level}",
      "position": "before_heading",
      "paddingRight": true,
      "description": "Show heading level indicator for ATX headings"
    },
    {
      "kind": "parameter",
      "description": "Parameter name hints",
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "display": "parameterName:",
      "position": "before"
    },
    {
      "kind": "type",
      "description": "Inferred type hints",
      "pattern": "(?:let|var|val|const|auto)\\s+(\\w+)\\s*=",
      "display": ": inferredType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Return type hints",
      "pattern": "(?:function|def|fn|func|fun)\\s+\\w+\\s*\\([^)]*\\)\\s*(?:=>|->|:)?",
      "display": "-> returnType",
      "position": "after"
    },
    {
      "kind": "enum",
      "description": "Enum member value hints",
      "pattern": "(?:enum|const)\\s+\\w+",
      "display": "= value",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Chained method result type",
      "pattern": "\\.(\\w+)\\(",
      "display": ": resultType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Destructuring type hints",
      "pattern": "(?:const|let|var)\\s*[{\\[]",
      "display": ": type",
      "position": "inline"
    }
  ],
  "typeInferenceRules": {
    "link_literal": {
      "pattern": "\\[.*\\]\\(.*\\)",
      "type": "link"
    },
    "image_literal": {
      "pattern": "!\\[.*\\]\\(.*\\)",
      "type": "image"
    },
    "code_literal": {
      "pattern": "`[^`]+`",
      "type": "code"
    }
  }
}
