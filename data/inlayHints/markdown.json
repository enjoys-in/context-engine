{
  "language": "markdown",
  "inlayHintPatterns": [
    {
      "pattern": "^(#{1,6})\\s+",
      "kind": 1,
      "label": "H{level}",
      "position": "before_heading",
      "paddingRight": true,
      "description": "Show heading level indicator for ATX headings"
    }
  ],
  "typeInferenceRules": {
    "link_literal": {
      "pattern": "\\[.*\\]\\(.*\\)",
      "type": "link"
    },
    "image_literal": {
      "pattern": "!\\[.*\\]\\(.*\\)",
      "type": "image"
    },
    "code_literal": {
      "pattern": "`[^`]+`",
      "type": "code"
    }
  }
}
