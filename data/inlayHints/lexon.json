{
  "language": "lexon",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s+is\\s+",
      "kind": 1,
      "label": ": {type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show types for variable declarations"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "text"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "amount"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "binary"
    }
  }
}
