{
  "language": "coffee",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at function call sites"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "['\"].*['\"]",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "number"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false|yes|no|on|off)\\b",
      "type": "boolean"
    },
    "null_literal": {
      "pattern": "\\b(null|undefined)\\b",
      "type": "null"
    },
    "array_literal": {
      "pattern": "\\[.*\\]",
      "type": "Array"
    },
    "object_literal": {
      "pattern": "\\{.*\\}",
      "type": "Object"
    }
  }
}
