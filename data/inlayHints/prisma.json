{
  "language": "prisma",
  "inlayHintPatterns": [
    {
      "pattern": "^\\s+(\\w+)\\s+(String|Int|BigInt|Float|Decimal|Boolean|DateTime|Json|Bytes)(\\?)?\\s+@id",
      "kind": 1,
      "label": " (primary key)",
      "position": "after_capture_1",
      "paddingLeft": true,
      "description": "Indicate this field is the primary key"
    },
    {
      "pattern": "^\\s+(\\w+)\\s+(\\w+)\\s+@relation\\(",
      "kind": 2,
      "label": "relation: ",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show relation type for relation fields"
    },
    {
      "pattern": "^\\s+(\\w+)\\s+(\\w+)\\[\\]",
      "kind": 1,
      "label": " (one-to-many)",
      "position": "after_capture_1",
      "paddingLeft": true,
      "description": "Indicate this is a one-to-many relation"
    },
    {
      "pattern": "^\\s+(\\w+)\\s+(\\w+)\\?\\s*$",
      "kind": 1,
      "label": " (optional)",
      "position": "after_capture_1",
      "paddingLeft": true,
      "description": "Indicate this field is optional/nullable"
    },
    {
      "pattern": "@default\\((\\w+)\\(\\)\\)",
      "kind": 1,
      "label": " → {1}",
      "position": "after_capture_1",
      "paddingLeft": true,
      "description": "Show the default value function"
    }
  ],
  "typeInferenceRules": {
    "string_literal": { "pattern": "\"[^\"]*\"", "type": "String" },
    "number_literal": { "pattern": "\\d+", "type": "Int" },
    "boolean_literal": { "pattern": "\\b(true|false)\\b", "type": "Boolean" }
  }
}