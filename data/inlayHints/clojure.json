{
  "language": "clojure",
  "inlayHintPatterns": [
    {
      "pattern": "\\((\\w[\\w-]*)\\s+",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at function call sites"
    },
    {
      "pattern": "\\(def\\s+(\\w+)\\s+",
      "kind": 1,
      "label": ": {type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show inferred types for def bindings"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "String"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "Number"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "Boolean"
    },
    "null_literal": {
      "pattern": "\\b(nil)\\b",
      "type": "nil"
    },
    "keyword_literal": {
      "pattern": ":[\\w-]+",
      "type": "Keyword"
    },
    "vector_literal": {
      "pattern": "\\[.*\\]",
      "type": "PersistentVector"
    },
    "map_literal": {
      "pattern": "\\{.*\\}",
      "type": "PersistentHashMap"
    }
  }
}
