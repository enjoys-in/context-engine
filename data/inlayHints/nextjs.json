{
  "language": "nextjs",
  "inlayHintPatterns": [
    {
      "pattern": "(?:const|let|var)\\s+(\\w+)\\s*=\\s*(?!\\{|\\[|\\(|function|class|new)(.+)",
      "kind": 1,
      "label": ": ${inferredType}",
      "position": "afterIdentifier",
      "paddingLeft": false,
      "paddingRight": true,
      "description": "Infer type for variable assignments"
    },
    {
      "pattern": "const\\s+\\[(\\w+),\\s*set\\w+\\]\\s*=\\s*useState\\(([^)]*?)\\)",
      "kind": 1,
      "label": ": ${inferredType}",
      "position": "afterIdentifier",
      "paddingLeft": false,
      "paddingRight": true,
      "description": "Infer useState generic type from initial value"
    },
    {
      "pattern": "const\\s+(router)\\s*=\\s*useRouter\\(\\)",
      "kind": 1,
      "label": ": AppRouterInstance",
      "position": "afterIdentifier",
      "paddingLeft": false,
      "paddingRight": true,
      "description": "Show useRouter return type"
    },
    {
      "pattern": "const\\s+(pathname)\\s*=\\s*usePathname\\(\\)",
      "kind": 1,
      "label": ": string",
      "position": "afterIdentifier",
      "paddingLeft": false,
      "paddingRight": true,
      "description": "Show usePathname return type"
    },
    {
      "pattern": "const\\s+(searchParams)\\s*=\\s*useSearchParams\\(\\)",
      "kind": 1,
      "label": ": ReadonlyURLSearchParams",
      "position": "afterIdentifier",
      "paddingLeft": false,
      "paddingRight": true,
      "description": "Show useSearchParams return type"
    },
    {
      "pattern": "export\\s+default\\s+(?:async\\s+)?function\\s+\\w+\\(\\s*\\{\\s*(params)\\s*\\}",
      "kind": 1,
      "label": ": { [key: string]: string | string[] }",
      "position": "afterIdentifier",
      "paddingLeft": false,
      "paddingRight": true,
      "description": "Annotate params type in page components"
    },
    {
      "pattern": "export\\s+default\\s+(?:async\\s+)?function\\s+\\w+\\(\\s*\\{[^}]*(searchParams)[^}]*\\}",
      "kind": 1,
      "label": ": { [key: string]: string | string[] | undefined }",
      "position": "afterIdentifier",
      "paddingLeft": false,
      "paddingRight": true,
      "description": "Annotate searchParams type in page components"
    },
    {
      "pattern": "const\\s+(\\w+)\\s*=\\s*await\\s+fetch\\(",
      "kind": 1,
      "label": ": Response",
      "position": "afterIdentifier",
      "paddingLeft": false,
      "paddingRight": true,
      "description": "Show fetch response type"
    },
    {
      "pattern": "async\\s+function\\s+\\w+Action\\([^)]*\\)\\s*(?::\\s*Promise<([^>]+)>)?",
      "kind": 1,
      "label": "=> Promise<void>",
      "position": "afterParameters",
      "paddingLeft": true,
      "paddingRight": false,
      "description": "Show server action return type"
    },
    {
      "pattern": "\\b(?:redirect|notFound|revalidatePath|revalidateTag)\\(([^,)]+)",
      "kind": 2,
      "label": "url:",
      "position": "beforeArgument",
      "paddingLeft": false,
      "paddingRight": true,
      "description": "Parameter name hints at call sites"
    },
    {
      "pattern": "export\\s+(?:async\\s+)?function\\s+(?:GET|POST|PUT|PATCH|DELETE)\\s*\\(\\s*(\\w+)",
      "kind": 1,
      "label": ": NextRequest",
      "position": "afterIdentifier",
      "paddingLeft": false,
      "paddingRight": true,
      "description": "Annotate route handler request parameter type"
    },
    {
      "pattern": "export\\s+(?:async\\s+)?function\\s+(?:GET|POST|PUT|PATCH|DELETE)\\s*\\([^,]+,\\s*\\{\\s*(params)\\s*\\}",
      "kind": 1,
      "label": ": { [key: string]: string }",
      "position": "afterIdentifier",
      "paddingLeft": false,
      "paddingRight": true,
      "description": "Annotate route handler context params type"
    },
    {
      "kind": "parameter",
      "description": "Parameter name hints",
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "display": "parameterName:",
      "position": "before"
    },
    {
      "kind": "type",
      "description": "Inferred type hints",
      "pattern": "(?:let|var|val|const|auto)\\s+(\\w+)\\s*=",
      "display": ": inferredType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Return type hints",
      "pattern": "(?:function|def|fn|func|fun)\\s+\\w+\\s*\\([^)]*\\)\\s*(?:=>|->|:)?",
      "display": "-> returnType",
      "position": "after"
    },
    {
      "kind": "enum",
      "description": "Enum member value hints",
      "pattern": "(?:enum|const)\\s+\\w+",
      "display": "= value",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Chained method result type",
      "pattern": "\\.(\\w+)\\(",
      "display": ": resultType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Destructuring type hints",
      "pattern": "(?:const|let|var)\\s*[{\\[]",
      "display": ": type",
      "position": "inline"
    }
  ],
  "typeInferenceRules": {
    "string": {
      "pattern": "^[\"'`]",
      "type": "string"
    },
    "number": {
      "pattern": "^\\d+\\.?\\d*$",
      "type": "number"
    },
    "boolean": {
      "pattern": "^(true|false)$",
      "type": "boolean"
    },
    "array": {
      "pattern": "^\\[",
      "type": "Array<unknown>"
    },
    "null": {
      "pattern": "^null$",
      "type": "null"
    },
    "object": {
      "pattern": "^\\{",
      "type": "Record<string, unknown>"
    },
    "jsx": {
      "pattern": "^<[A-Z]",
      "type": "JSX.Element"
    }
  }
}
