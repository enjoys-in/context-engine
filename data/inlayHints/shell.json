{
  "language": "shell",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*=\\s*",
      "kind": 1,
      "label": ": {type}",
      "position": "after_value",
      "paddingLeft": true,
      "description": "Show inferred types for shell variable assignments"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "['\"].*['\"]",
      "type": "string"
    },
    "number_literal": {
      "pattern": "^\\d+$",
      "type": "integer"
    },
    "array_literal": {
      "pattern": "\\(.*\\)",
      "type": "array"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "string"
    },
    "path_literal": {
      "pattern": "(/[\\w.-]+)+",
      "type": "path"
    }
  }
}
