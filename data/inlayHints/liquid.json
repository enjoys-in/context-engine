{
  "language": "liquid",
  "inlayHintPatterns": [
    {
      "pattern": "\\{\\{\\s*(\\w+)",
      "kind": 1,
      "label": ": {type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show inferred types for Liquid output variables"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "['\"].*['\"]",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "number"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "boolean"
    },
    "null_literal": {
      "pattern": "\\b(nil|null|empty|blank)\\b",
      "type": "nil"
    }
  }
}
