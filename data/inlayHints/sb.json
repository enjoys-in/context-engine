{
  "language": "sb",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\.(\\w+)\\s*\\(([^)]*)\\)",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at Small Basic method call sites"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "String"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "Number"
    },
    "boolean_literal": {
      "pattern": "\"(True|False)\"",
      "type": "Boolean"
    }
  }
}
