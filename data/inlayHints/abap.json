{
  "language": "abap",
  "inlayHintPatterns": [
    {
      "pattern": "(CALL\\s+METHOD|CALL\\s+FUNCTION)\\s+(\\w+)",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at ABAP method and function call sites"
    },
    {
      "pattern": "DATA\\s+(\\w+)\\s+TYPE",
      "kind": 1,
      "label": ": {type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show inferred types for DATA declarations"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "'[^']*'",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "number"
    },
    "boolean_literal": {
      "pattern": "\\b(ABAP_TRUE|ABAP_FALSE)\\b",
      "type": "boolean"
    },
    "null_literal": {
      "pattern": "\\b(INITIAL)\\b",
      "type": "initial"
    }
  }
}
