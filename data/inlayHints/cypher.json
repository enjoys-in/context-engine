{
  "language": "cypher",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at Cypher function call sites"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "['\"].*['\"]",
      "type": "String"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "Number"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "Boolean"
    },
    "null_literal": {
      "pattern": "\\b(null)\\b",
      "type": "null"
    }
  }
}
