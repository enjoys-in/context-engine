{
  "language": "systemd",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*=\\s*(.+)",
      "kind": 1,
      "label": ": {type}",
      "position": "after_value",
      "paddingLeft": true,
      "description": "Show expected value types for systemd unit directives"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\d+",
      "type": "integer"
    },
    "boolean_literal": {
      "pattern": "\\b(yes|no|true|false|on|off|1|0)\\b",
      "type": "boolean"
    },
    "time_literal": {
      "pattern": "\\d+(s|ms|min|m|h|d|w)",
      "type": "timespan"
    },
    "size_literal": {
      "pattern": "\\d+(K|M|G|T)",
      "type": "size"
    },
    "path_literal": {
      "pattern": "/[\\w/.-]+",
      "type": "path"
    }
  }
}
