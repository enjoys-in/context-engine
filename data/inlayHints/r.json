{
  "language": "r",
  "inlayHintPatterns": [
    {
      "pattern": "(\\\\w[\\\\w.]*)\\\\s*\\\\(([^)]+)\\\\)",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at function call sites"
    },
    {
      "pattern": "(\\\\w[\\\\w.]*)\\\\s*<-\\\\s*(.+)",
      "kind": 1,
      "label": ": {inferred_type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show inferred type for <- assignments"
    },
    {
      "pattern": "(.+)\\\\s*->\\\\s*(\\\\w[\\\\w.]*)",
      "kind": 1,
      "label": ": {inferred_type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show inferred type for -> assignments"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"|'[^']*'",
      "type": "character"
    },
    "integer_literal": {
      "pattern": "\\\\d+L",
      "type": "integer"
    },
    "number_literal": {
      "pattern": "\\\\d+(\\\\.\\\\d+)?(?!L)",
      "type": "double"
    },
    "boolean_literal": {
      "pattern": "\\\\b(TRUE|FALSE)\\\\b",
      "type": "logical"
    },
    "null_literal": {
      "pattern": "\\\\bNULL\\\\b",
      "type": "NULL"
    },
    "na_literal": {
      "pattern": "\\\\bNA\\\\b",
      "type": "logical (NA)"
    },
    "na_integer_literal": {
      "pattern": "\\\\bNA_integer_\\\\b",
      "type": "integer (NA)"
    },
    "na_real_literal": {
      "pattern": "\\\\bNA_real_\\\\b",
      "type": "double (NA)"
    },
    "na_character_literal": {
      "pattern": "\\\\bNA_character_\\\\b",
      "type": "character (NA)"
    },
    "complex_literal": {
      "pattern": "\\\\d+(\\\\.\\\\d+)?[+-]\\\\d+(\\\\.\\\\d+)?i",
      "type": "complex"
    },
    "vector_literal": {
      "pattern": "\\\\bc\\\\s*\\\\(",
      "type": "vector"
    },
    "list_literal": {
      "pattern": "\\\\blist\\\\s*\\\\(",
      "type": "list"
    },
    "data_frame_literal": {
      "pattern": "\\\\bdata\\\\.frame\\\\s*\\\\(",
      "type": "data.frame"
    },
    "matrix_literal": {
      "pattern": "\\\\bmatrix\\\\s*\\\\(",
      "type": "matrix"
    },
    "factor_literal": {
      "pattern": "\\\\bfactor\\\\s*\\\\(",
      "type": "factor"
    },
    "function_literal": {
      "pattern": "\\\\bfunction\\\\s*\\\\(",
      "type": "function"
    }
  }
}