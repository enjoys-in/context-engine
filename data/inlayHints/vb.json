{
  "language": "vb",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "{param_name}:=",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at VB.NET method call sites"
    },
    {
      "pattern": "Dim\\s+(\\w+)\\s*=",
      "kind": 1,
      "label": "As {type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show inferred types for Dim declarations without explicit As clause"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "String"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "Integer"
    },
    "boolean_literal": {
      "pattern": "\\b(True|False)\\b",
      "type": "Boolean"
    },
    "null_literal": {
      "pattern": "\\b(Nothing)\\b",
      "type": "Nothing"
    },
    "date_literal": {
      "pattern": "#[^#]+#",
      "type": "Date"
    }
  }
}
