{
  "language": "pascaligo",
  "inlayHintPatterns": [
    {
      "pattern": "const\\s+(\\w+)\\s*=",
      "kind": 1,
      "label": ": {type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show inferred types for const declarations"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\d+",
      "type": "int"
    },
    "boolean_literal": {
      "pattern": "\\b(True|False)\\b",
      "type": "bool"
    }
  }
}
