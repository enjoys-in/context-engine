{
  "language": "elixir",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\.?(\\w+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at function call sites"
    },
    {
      "pattern": "(\\w+)\\s*=\\s*",
      "kind": 1,
      "label": ": {type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show inferred types for variable bindings"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "binary (String)"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "number"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "boolean"
    },
    "null_literal": {
      "pattern": "\\b(nil)\\b",
      "type": "nil"
    },
    "atom_literal": {
      "pattern": ":[\\w?!]+",
      "type": "atom"
    },
    "list_literal": {
      "pattern": "\\[.*\\]",
      "type": "list"
    },
    "tuple_literal": {
      "pattern": "\\{.*\\}",
      "type": "tuple"
    },
    "map_literal": {
      "pattern": "%\\{.*\\}",
      "type": "map"
    }
  }
}
