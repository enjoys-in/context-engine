{
  "language": "mysql",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at MySQL function call sites"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "'[^']*'",
      "type": "VARCHAR"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "DECIMAL"
    },
    "boolean_literal": {
      "pattern": "\\b(TRUE|FALSE)\\b",
      "type": "BOOLEAN"
    },
    "null_literal": {
      "pattern": "\\b(NULL)\\b",
      "type": "NULL"
    },
    "date_literal": {
      "pattern": "'\\d{4}-\\d{2}-\\d{2}'",
      "type": "DATE"
    }
  }
}
