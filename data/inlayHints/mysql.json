{
  "language": "mysql",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at MySQL function call sites"
    },
    {
      "kind": "parameter",
      "description": "Parameter name hints",
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "display": "parameterName:",
      "position": "before"
    },
    {
      "kind": "type",
      "description": "Inferred type hints",
      "pattern": "(?:let|var|val|const|auto)\\s+(\\w+)\\s*=",
      "display": ": inferredType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Return type hints",
      "pattern": "(?:function|def|fn|func|fun)\\s+\\w+\\s*\\([^)]*\\)\\s*(?:=>|->|:)?",
      "display": "-> returnType",
      "position": "after"
    },
    {
      "kind": "enum",
      "description": "Enum member value hints",
      "pattern": "(?:enum|const)\\s+\\w+",
      "display": "= value",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Chained method result type",
      "pattern": "\\.(\\w+)\\(",
      "display": ": resultType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Destructuring type hints",
      "pattern": "(?:const|let|var)\\s*[{\\[]",
      "display": ": type",
      "position": "inline"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "'[^']*'",
      "type": "VARCHAR"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "DECIMAL"
    },
    "boolean_literal": {
      "pattern": "\\b(TRUE|FALSE)\\b",
      "type": "BOOLEAN"
    },
    "null_literal": {
      "pattern": "\\b(NULL)\\b",
      "type": "NULL"
    },
    "date_literal": {
      "pattern": "'\\d{4}-\\d{2}-\\d{2}'",
      "type": "DATE"
    }
  }
}
