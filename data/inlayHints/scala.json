{
  "language": "scala",
  "inlayHintPatterns": [
    {
      "pattern": "val\\s+(\\w+)\\s*=\\s*(.+)",
      "kind": 1,
      "label": ": {inferred_type}",
      "position": "after_capture_1",
      "paddingLeft": true,
      "description": "Show inferred type for val assignments without explicit type"
    },
    {
      "pattern": "var\\s+(\\w+)\\s*=\\s*(.+)",
      "kind": 1,
      "label": ": {inferred_type}",
      "position": "after_capture_1",
      "paddingLeft": true,
      "description": "Show inferred type for var assignments without explicit type"
    },
    {
      "pattern": "def\\s+(\\w+)(?:\\([^)]*\\))*\\s*=\\s*(?!\\{)",
      "kind": 1,
      "label": ": {inferred_type}",
      "position": "after_params",
      "paddingLeft": true,
      "description": "Show inferred return type for methods without explicit annotation"
    },
    {
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at function call sites"
    },
    {
      "pattern": "for\\s*\\{?\\s*(\\w+)\\s*<-",
      "kind": 1,
      "label": ": {inferred_type}",
      "position": "after_capture_1",
      "paddingLeft": true,
      "description": "Show inferred type of generator variable in for-comprehension"
    },
    {
      "pattern": "case\\s+(\\w+)\\s*=>",
      "kind": 1,
      "label": ": {inferred_type}",
      "position": "after_capture_1",
      "paddingLeft": true,
      "description": "Show inferred type of pattern match variable"
    },
    {
      "pattern": "\\b(\\w+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "(implicit {implicit_name})",
      "position": "after_args",
      "paddingLeft": true,
      "description": "Show implicit parameters being passed at call sites"
    },
    {
      "pattern": "\\.map\\s*\\(\\s*(\\w+)\\s*=>",
      "kind": 1,
      "label": ": {inferred_type}",
      "position": "after_capture_1",
      "paddingLeft": true,
      "description": "Show inferred type of lambda parameter"
    },
    {
      "pattern": "\\.flatMap\\s*\\(\\s*(\\w+)\\s*=>",
      "kind": 1,
      "label": ": {inferred_type}",
      "position": "after_capture_1",
      "paddingLeft": true,
      "description": "Show inferred type of flatMap lambda parameter"
    },
    {
      "pattern": "\\.filter\\s*\\(\\s*(\\w+)\\s*=>",
      "kind": 1,
      "label": ": {inferred_type}",
      "position": "after_capture_1",
      "paddingLeft": true,
      "description": "Show inferred type of filter lambda parameter"
    },
    {
      "pattern": "lazy\\s+val\\s+(\\w+)\\s*=",
      "kind": 1,
      "label": ": {inferred_type}",
      "position": "after_capture_1",
      "paddingLeft": true,
      "description": "Show inferred type for lazy val without explicit type"
    },
    {
      "kind": "parameter",
      "description": "Parameter name hints",
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "display": "parameterName:",
      "position": "before"
    },
    {
      "kind": "type",
      "description": "Inferred type hints",
      "pattern": "(?:let|var|val|const|auto)\\s+(\\w+)\\s*=",
      "display": ": inferredType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Return type hints",
      "pattern": "(?:function|def|fn|func|fun)\\s+\\w+\\s*\\([^)]*\\)\\s*(?:=>|->|:)?",
      "display": "-> returnType",
      "position": "after"
    },
    {
      "kind": "enum",
      "description": "Enum member value hints",
      "pattern": "(?:enum|const)\\s+\\w+",
      "display": "= value",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Chained method result type",
      "pattern": "\\.(\\w+)\\(",
      "display": ": resultType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Destructuring type hints",
      "pattern": "(?:const|let|var)\\s*[{\\[]",
      "display": ": type",
      "position": "inline"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "String"
    },
    "multiline_string": {
      "pattern": "\"\"\"[\\s\\S]*?\"\"\"",
      "type": "String"
    },
    "interpolated_string": {
      "pattern": "[sf]\"[^\"]*\"",
      "type": "String"
    },
    "int_literal": {
      "pattern": "\\b\\d+\\b(?![.LlFfDd])",
      "type": "Int"
    },
    "long_literal": {
      "pattern": "\\b\\d+[Ll]\\b",
      "type": "Long"
    },
    "float_literal": {
      "pattern": "\\b\\d+\\.\\d+[Ff]\\b",
      "type": "Float"
    },
    "double_literal": {
      "pattern": "\\b\\d+\\.\\d+\\b(?![Ff])",
      "type": "Double"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "Boolean"
    },
    "char_literal": {
      "pattern": "'[^']'",
      "type": "Char"
    },
    "null_literal": {
      "pattern": "\\bnull\\b",
      "type": "Null"
    },
    "list_literal": {
      "pattern": "List\\s*\\(",
      "type": "List[T]"
    },
    "map_literal": {
      "pattern": "Map\\s*\\(",
      "type": "Map[K, V]"
    },
    "set_literal": {
      "pattern": "Set\\s*\\(",
      "type": "Set[T]"
    },
    "vector_literal": {
      "pattern": "Vector\\s*\\(",
      "type": "Vector[T]"
    },
    "array_literal": {
      "pattern": "Array\\s*\\(",
      "type": "Array[T]"
    },
    "option_some": {
      "pattern": "Some\\s*\\(",
      "type": "Option[T]"
    },
    "option_none": {
      "pattern": "\\bNone\\b",
      "type": "Option[Nothing]"
    },
    "tuple_literal": {
      "pattern": "\\(\\s*[^)]+\\s*,",
      "type": "(T1, T2, ...)"
    },
    "future_expr": {
      "pattern": "Future\\s*[{(]",
      "type": "Future[T]"
    },
    "try_expr": {
      "pattern": "Try\\s*[{(]",
      "type": "Try[T]"
    },
    "right_expr": {
      "pattern": "Right\\s*\\(",
      "type": "Either[Nothing, T]"
    },
    "left_expr": {
      "pattern": "Left\\s*\\(",
      "type": "Either[T, Nothing]"
    },
    "constructor_call": {
      "pattern": "new\\s+[A-Z]\\w*",
      "type": "{constructor_class}"
    },
    "range_expr": {
      "pattern": "\\d+\\s+(?:to|until)\\s+\\d+",
      "type": "Range"
    }
  }
}
