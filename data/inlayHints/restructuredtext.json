{
  "language": "restructuredtext",
  "inlayHintPatterns": [
    {
      "pattern": "^(={3,}|-{3,}|~{3,}|\\^{3,})$",
      "kind": 1,
      "label": "H{level}",
      "position": "before_heading",
      "paddingRight": true,
      "description": "Show heading level for section underline markers"
    },
    {
      "kind": "parameter",
      "description": "Parameter name hints",
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "display": "parameterName:",
      "position": "before"
    },
    {
      "kind": "type",
      "description": "Inferred type hints",
      "pattern": "(?:let|var|val|const|auto)\\s+(\\w+)\\s*=",
      "display": ": inferredType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Return type hints",
      "pattern": "(?:function|def|fn|func|fun)\\s+\\w+\\s*\\([^)]*\\)\\s*(?:=>|->|:)?",
      "display": "-> returnType",
      "position": "after"
    },
    {
      "kind": "enum",
      "description": "Enum member value hints",
      "pattern": "(?:enum|const)\\s+\\w+",
      "display": "= value",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Chained method result type",
      "pattern": "\\.(\\w+)\\(",
      "display": ": resultType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Destructuring type hints",
      "pattern": "(?:const|let|var)\\s*[{\\[]",
      "display": ": type",
      "position": "inline"
    }
  ],
  "typeInferenceRules": {
    "role_literal": {
      "pattern": ":[\\w-]+:`[^`]*`",
      "type": "role"
    },
    "directive_literal": {
      "pattern": "\\.\\.\\s+[\\w-]+::",
      "type": "directive"
    },
    "reference_literal": {
      "pattern": "`[^`]+`_",
      "type": "reference"
    }
  }
}
