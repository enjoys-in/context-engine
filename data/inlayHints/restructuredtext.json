{
  "language": "restructuredtext",
  "inlayHintPatterns": [
    {
      "pattern": "^(={3,}|-{3,}|~{3,}|\\^{3,})$",
      "kind": 1,
      "label": "H{level}",
      "position": "before_heading",
      "paddingRight": true,
      "description": "Show heading level for section underline markers"
    }
  ],
  "typeInferenceRules": {
    "role_literal": {
      "pattern": ":[\\w-]+:`[^`]*`",
      "type": "role"
    },
    "directive_literal": {
      "pattern": "\\.\\.\\s+[\\w-]+::",
      "type": "directive"
    },
    "reference_literal": {
      "pattern": "`[^`]+`_",
      "type": "reference"
    }
  }
}
