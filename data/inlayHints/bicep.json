{
  "language": "bicep",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at Bicep function call sites"
    },
    {
      "pattern": "var\\s+(\\w+)\\s*=",
      "kind": 1,
      "label": ": {type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show inferred types for var declarations"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "'[^']*'",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\d+",
      "type": "int"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "bool"
    },
    "null_literal": {
      "pattern": "\\b(null)\\b",
      "type": "null"
    },
    "array_literal": {
      "pattern": "\\[.*\\]",
      "type": "array"
    },
    "object_literal": {
      "pattern": "\\{.*\\}",
      "type": "object"
    }
  }
}
