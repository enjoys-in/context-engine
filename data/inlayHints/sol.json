{
  "language": "sol",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at Solidity function call sites"
    },
    {
      "pattern": "var\\s+(\\w+)\\s*=",
      "kind": 1,
      "label": ": {type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show inferred types for var declarations"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "uint256"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "bool"
    },
    "address_literal": {
      "pattern": "0x[0-9a-fA-F]{40}",
      "type": "address"
    },
    "hex_literal": {
      "pattern": "hex\"[0-9a-fA-F]+\"",
      "type": "bytes"
    }
  }
}
