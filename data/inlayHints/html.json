{
  "language": "html",
  "inlayHintPatterns": [
    {
      "pattern": "<(\\w+)",
      "kind": 1,
      "label": "/{tag}",
      "position": "after_closing_tag",
      "paddingLeft": true,
      "description": "Show matching tag name hints on closing tags"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"|'[^']*'",
      "type": "DOMString"
    },
    "number_literal": {
      "pattern": "\\d+",
      "type": "number"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "boolean"
    }
  }
}
