{
  "language": "html",
  "inlayHintPatterns": [],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "['\"].*['\"]",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\\\d+(\\\\.\\\\d+)?",
      "type": "number"
    },
    "boolean_literal": {
      "pattern": "\\\\b(true|false)\\\\b",
      "type": "boolean"
    },
    "array_literal": {
      "pattern": "\\\\[.*\\\\]",
      "type": "array"
    },
    "null_literal": {
      "pattern": "\\\\b(null)\\\\b",
      "type": "null"
    }
  }
}
