{
  "language": "objective-c",
  "inlayHintPatterns": [
    {
      "pattern": "\\[(\\w+)\\s+(\\w+):",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter labels at Objective-C message send sites"
    },
    {
      "pattern": "(id|\\w+\\s*\\*)\\s+(\\w+)\\s*=",
      "kind": 1,
      "label": ": {type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show inferred types for id and auto-typed variables"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "@\"[^\"]*\"",
      "type": "NSString *"
    },
    "number_literal": {
      "pattern": "@\\d+(\\.\\d+)?|\\d+(\\.\\d+)?",
      "type": "NSNumber *"
    },
    "boolean_literal": {
      "pattern": "\\b(YES|NO|true|false)\\b",
      "type": "BOOL"
    },
    "null_literal": {
      "pattern": "\\b(nil|Nil|NULL)\\b",
      "type": "nil"
    },
    "array_literal": {
      "pattern": "@\\[.*\\]",
      "type": "NSArray *"
    },
    "dict_literal": {
      "pattern": "@\\{.*\\}",
      "type": "NSDictionary *"
    }
  }
}
