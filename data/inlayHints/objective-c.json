{
  "language": "objective-c",
  "inlayHintPatterns": [
    {
      "pattern": "\\[(\\w+)\\s+(\\w+):",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter labels at Objective-C message send sites"
    },
    {
      "pattern": "(id|\\w+\\s*\\*)\\s+(\\w+)\\s*=",
      "kind": 1,
      "label": ": {type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show inferred types for id and auto-typed variables"
    },
    {
      "kind": "parameter",
      "description": "Parameter name hints",
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "display": "parameterName:",
      "position": "before"
    },
    {
      "kind": "type",
      "description": "Inferred type hints",
      "pattern": "(?:let|var|val|const|auto)\\s+(\\w+)\\s*=",
      "display": ": inferredType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Return type hints",
      "pattern": "(?:function|def|fn|func|fun)\\s+\\w+\\s*\\([^)]*\\)\\s*(?:=>|->|:)?",
      "display": "-> returnType",
      "position": "after"
    },
    {
      "kind": "enum",
      "description": "Enum member value hints",
      "pattern": "(?:enum|const)\\s+\\w+",
      "display": "= value",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Chained method result type",
      "pattern": "\\.(\\w+)\\(",
      "display": ": resultType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Destructuring type hints",
      "pattern": "(?:const|let|var)\\s*[{\\[]",
      "display": ": type",
      "position": "inline"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "@\"[^\"]*\"",
      "type": "NSString *"
    },
    "number_literal": {
      "pattern": "@\\d+(\\.\\d+)?|\\d+(\\.\\d+)?",
      "type": "NSNumber *"
    },
    "boolean_literal": {
      "pattern": "\\b(YES|NO|true|false)\\b",
      "type": "BOOL"
    },
    "null_literal": {
      "pattern": "\\b(nil|Nil|NULL)\\b",
      "type": "nil"
    },
    "array_literal": {
      "pattern": "@\\[.*\\]",
      "type": "NSArray *"
    },
    "dict_literal": {
      "pattern": "@\\{.*\\}",
      "type": "NSDictionary *"
    }
  }
}
