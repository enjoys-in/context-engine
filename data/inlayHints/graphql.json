{
  "language": "graphql",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "{arg_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show argument names at field and directive call sites"
    },
    {
      "pattern": "(\\w+)\\s*:",
      "kind": 1,
      "label": ": {type}",
      "position": "after_field",
      "paddingLeft": true,
      "description": "Show field return types in selections"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "String"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "Int"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "Boolean"
    },
    "null_literal": {
      "pattern": "\\b(null)\\b",
      "type": "null"
    },
    "enum_literal": {
      "pattern": "\\b[A-Z_]+\\b",
      "type": "Enum"
    }
  }
}
