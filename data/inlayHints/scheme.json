{
  "language": "scheme",
  "inlayHintPatterns": [
    {
      "pattern": "\\((\\w[\\w-!?]*)\\s+",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at function application sites"
    },
    {
      "pattern": "\\(define\\s+\\(?(\\w+)\\)?",
      "kind": 1,
      "label": ": {type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show inferred types for define bindings"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\d+(/\\d+)?(\\.\\d+)?",
      "type": "number"
    },
    "boolean_literal": {
      "pattern": "#[tf]",
      "type": "boolean"
    },
    "null_literal": {
      "pattern": "'\\(\\)|\\(\\)",
      "type": "null/empty list"
    },
    "char_literal": {
      "pattern": "#\\\\.",
      "type": "char"
    },
    "symbol_literal": {
      "pattern": "'[\\w-]+",
      "type": "symbol"
    },
    "vector_literal": {
      "pattern": "#\\(.*\\)",
      "type": "vector"
    }
  }
}
