{
  "language": "scheme",
  "inlayHintPatterns": [
    {
      "pattern": "\\((\\w[\\w-!?]*)\\s+",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at function application sites"
    },
    {
      "pattern": "\\(define\\s+\\(?(\\w+)\\)?",
      "kind": 1,
      "label": ": {type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show inferred types for define bindings"
    },
    {
      "kind": "parameter",
      "description": "Parameter name hints",
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "display": "parameterName:",
      "position": "before"
    },
    {
      "kind": "type",
      "description": "Inferred type hints",
      "pattern": "(?:let|var|val|const|auto)\\s+(\\w+)\\s*=",
      "display": ": inferredType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Return type hints",
      "pattern": "(?:function|def|fn|func|fun)\\s+\\w+\\s*\\([^)]*\\)\\s*(?:=>|->|:)?",
      "display": "-> returnType",
      "position": "after"
    },
    {
      "kind": "enum",
      "description": "Enum member value hints",
      "pattern": "(?:enum|const)\\s+\\w+",
      "display": "= value",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Chained method result type",
      "pattern": "\\.(\\w+)\\(",
      "display": ": resultType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Destructuring type hints",
      "pattern": "(?:const|let|var)\\s*[{\\[]",
      "display": ": type",
      "position": "inline"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\d+(/\\d+)?(\\.\\d+)?",
      "type": "number"
    },
    "boolean_literal": {
      "pattern": "#[tf]",
      "type": "boolean"
    },
    "null_literal": {
      "pattern": "'\\(\\)|\\(\\)",
      "type": "null/empty list"
    },
    "char_literal": {
      "pattern": "#\\\\.",
      "type": "char"
    },
    "symbol_literal": {
      "pattern": "'[\\w-]+",
      "type": "symbol"
    },
    "vector_literal": {
      "pattern": "#\\(.*\\)",
      "type": "vector"
    }
  }
}
