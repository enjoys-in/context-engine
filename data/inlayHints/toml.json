{
  "language": "toml",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*=\\s*(.+)",
      "kind": 1,
      "label": ": {type}",
      "position": "after_value",
      "paddingLeft": true,
      "description": "Show inferred TOML value types for key-value pairs"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"|'[^']*'",
      "type": "string"
    },
    "number_literal": {
      "pattern": "[+-]?\\d+(\\.\\d+)?([eE][+-]?\\d+)?",
      "type": "number"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "boolean"
    },
    "datetime_literal": {
      "pattern": "\\d{4}-\\d{2}-\\d{2}",
      "type": "datetime"
    },
    "array_literal": {
      "pattern": "\\[.*\\]",
      "type": "array"
    },
    "table_literal": {
      "pattern": "\\{.*\\}",
      "type": "inline_table"
    }
  }
}
