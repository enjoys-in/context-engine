{
  "language": "angular",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*=\\s*inject\\s*\\(\\s*(\\w+)\\s*\\)",
      "captureGroup": 1,
      "label": ": ${2}",
      "kind": 1,
      "tooltip": "Injected type from inject() call",
      "position": "after"
    },
    {
      "pattern": "(\\w+)\\s*=\\s*signal\\s*<([^>]+)>\\s*\\(",
      "captureGroup": 1,
      "label": ": WritableSignal<${2}>",
      "kind": 1,
      "tooltip": "Writable signal type",
      "position": "after"
    },
    {
      "pattern": "(\\w+)\\s*=\\s*signal\\s*\\(\\s*(['\"])(.+?)\\2\\s*\\)",
      "captureGroup": 1,
      "label": ": WritableSignal<string>",
      "kind": 1,
      "tooltip": "Signal inferred as string type",
      "position": "after"
    },
    {
      "pattern": "(\\w+)\\s*=\\s*computed\\s*\\(",
      "captureGroup": 1,
      "label": ": Signal<…>",
      "kind": 1,
      "tooltip": "Computed signal return type",
      "position": "after"
    },
    {
      "pattern": "(\\w+)\\s*=\\s*input(?:\\.required)?\\s*<([^>]+)>\\s*\\(",
      "captureGroup": 1,
      "label": ": InputSignal<${2}>",
      "kind": 1,
      "tooltip": "Signal-based input type",
      "position": "after"
    },
    {
      "pattern": "(\\w+)\\s*=\\s*output\\s*<([^>]+)>\\s*\\(",
      "captureGroup": 1,
      "label": ": OutputEmitterRef<${2}>",
      "kind": 1,
      "tooltip": "Signal-based output event type",
      "position": "after"
    },
    {
      "pattern": "\\|\\s*(\\w+)\\b",
      "captureGroup": 1,
      "label": "→ transformed",
      "kind": 2,
      "tooltip": "Pipe transform return value",
      "position": "after"
    },
    {
      "pattern": "new\\s+FormControl\\s*<([^>]+)>\\s*\\(",
      "captureGroup": 1,
      "label": "FormControl<${1}>",
      "kind": 1,
      "tooltip": "Typed form control value type",
      "position": "after"
    },
    {
      "pattern": "\\.subscribe\\s*\\(\\s*(\\w+)\\s*=>",
      "captureGroup": 1,
      "label": ": Observable emission",
      "kind": 1,
      "tooltip": "Observable subscription callback parameter",
      "position": "after"
    },
    {
      "pattern": "this\\.route\\.(?:params|queryParams|paramMap)\\b",
      "captureGroup": 0,
      "label": ": Observable<Params>",
      "kind": 1,
      "tooltip": "Route parameter observable type",
      "position": "after"
    },
    {
      "kind": "parameter",
      "description": "Parameter name hints",
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "display": "parameterName:",
      "position": "before"
    },
    {
      "kind": "type",
      "description": "Inferred type hints",
      "pattern": "(?:let|var|val|const|auto)\\s+(\\w+)\\s*=",
      "display": ": inferredType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Return type hints",
      "pattern": "(?:function|def|fn|func|fun)\\s+\\w+\\s*\\([^)]*\\)\\s*(?:=>|->|:)?",
      "display": "-> returnType",
      "position": "after"
    },
    {
      "kind": "enum",
      "description": "Enum member value hints",
      "pattern": "(?:enum|const)\\s+\\w+",
      "display": "= value",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Chained method result type",
      "pattern": "\\.(\\w+)\\(",
      "display": ": resultType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Destructuring type hints",
      "pattern": "(?:const|let|var)\\s*[{\\[]",
      "display": ": type",
      "position": "inline"
    }
  ],
  "typeInferenceRules": [
    {
      "pattern": "(\\w+)\\s*=\\s*signal\\s*\\(\\s*(\\d+)\\s*\\)",
      "inferredType": "WritableSignal<number>",
      "description": "Numeric literal initializer infers number signal"
    },
    {
      "pattern": "(\\w+)\\s*=\\s*signal\\s*\\(\\s*true|false\\s*\\)",
      "inferredType": "WritableSignal<boolean>",
      "description": "Boolean literal initializer infers boolean signal"
    },
    {
      "pattern": "(\\w+)\\s*=\\s*signal\\s*\\(\\s*['\"].*?['\"]\\s*\\)",
      "inferredType": "WritableSignal<string>",
      "description": "String literal initializer infers string signal"
    },
    {
      "pattern": "(\\w+)\\s*=\\s*signal\\s*\\(\\s*\\[\\]\\s*\\)",
      "inferredType": "WritableSignal<any[]>",
      "description": "Empty array initializer infers array signal"
    },
    {
      "pattern": "(\\w+)\\s*=\\s*inject\\s*\\(\\s*(\\w+)\\s*\\)",
      "inferredType": "${2}",
      "description": "inject() call infers the type of the provided token"
    },
    {
      "pattern": "new\\s+FormControl\\s*\\(\\s*['\"].*?['\"]\\s*\\)",
      "inferredType": "FormControl<string | null>",
      "description": "FormControl with string initial value"
    },
    {
      "pattern": "new\\s+FormGroup\\s*\\(\\s*\\{",
      "inferredType": "FormGroup",
      "description": "FormGroup inferred from object literal controls"
    }
  ]
}
