{
  "language": "julia",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at function call sites"
    },
    {
      "pattern": "(\\w+)\\s*=\\s*",
      "kind": 1,
      "label": ":: {type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show inferred types for variable assignments"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "String"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "Number"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "Bool"
    },
    "null_literal": {
      "pattern": "\\b(nothing)\\b",
      "type": "Nothing"
    },
    "array_literal": {
      "pattern": "\\[.*\\]",
      "type": "Array"
    },
    "tuple_literal": {
      "pattern": "\\(.*,.*\\)",
      "type": "Tuple"
    },
    "symbol_literal": {
      "pattern": ":[\\w]+",
      "type": "Symbol"
    }
  }
}
