{
  "language": "pgsql",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at PostgreSQL function call sites"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "'[^']*'",
      "type": "text"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "numeric"
    },
    "boolean_literal": {
      "pattern": "\\b(TRUE|FALSE|true|false)\\b",
      "type": "boolean"
    },
    "null_literal": {
      "pattern": "\\b(NULL)\\b",
      "type": "null"
    },
    "date_literal": {
      "pattern": "'\\d{4}-\\d{2}-\\d{2}'",
      "type": "date"
    },
    "json_literal": {
      "pattern": "'\\{.*\\}'::json",
      "type": "json"
    }
  }
}
