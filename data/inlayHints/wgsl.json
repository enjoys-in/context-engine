{
  "language": "wgsl",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at WGSL function call sites"
    },
    {
      "pattern": "let\\s+(\\w+)\\s*=",
      "kind": 1,
      "label": ": {type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show inferred types for let declarations"
    }
  ],
  "typeInferenceRules": {
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?[fhiu]?",
      "type": "f32"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "bool"
    },
    "vector_literal": {
      "pattern": "vec[234][fhiu]?\\(",
      "type": "vec"
    },
    "matrix_literal": {
      "pattern": "mat[234]x[234][f]?\\(",
      "type": "mat"
    }
  }
}
