{
  "language": "ecl",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at ECL function calls"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "'[^']*'",
      "type": "STRING"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "REAL"
    },
    "boolean_literal": {
      "pattern": "\\b(TRUE|FALSE)\\b",
      "type": "BOOLEAN"
    }
  }
}
