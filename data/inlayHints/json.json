{
  "language": "json",
  "inlayHintPatterns": [
    {
      "pattern": "\\[",
      "kind": 1,
      "label": "[{index}]",
      "position": "before_array_item",
      "paddingRight": true,
      "description": "Show array index hints for items in JSON arrays"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "string"
    },
    "number_literal": {
      "pattern": "-?\\d+(\\.\\d+)?([eE][+-]?\\d+)?",
      "type": "number"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "boolean"
    },
    "null_literal": {
      "pattern": "\\b(null)\\b",
      "type": "null"
    },
    "object_literal": {
      "pattern": "\\{.*\\}",
      "type": "object"
    },
    "array_literal": {
      "pattern": "\\[.*\\]",
      "type": "array"
    }
  }
}
