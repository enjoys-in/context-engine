{
  "language": "freemarker2",
  "inlayHintPatterns": [
    {
      "pattern": "<#macro\\s+(\\w+)",
      "kind": 2,
      "label": "{param_name}=",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at macro invocation sites"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "number"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "boolean"
    }
  }
}
