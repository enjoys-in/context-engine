{
  "language": "scss",
  "inlayHintPatterns": [
    {
      "pattern": "@include\\s+([\\w-]+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "${param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at mixin include sites"
    },
    {
      "pattern": "\\$([\\w-]+)\\s*:",
      "kind": 1,
      "label": ": {type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show inferred value types for SCSS variables"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "['\"].*['\"]",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?(px|em|rem|%|vw|vh)?",
      "type": "dimension"
    },
    "color_literal": {
      "pattern": "#[0-9a-fA-F]{3,8}",
      "type": "color"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "boolean"
    },
    "null_literal": {
      "pattern": "\\b(null)\\b",
      "type": "null"
    },
    "list_literal": {
      "pattern": "\\(.*,.*\\)",
      "type": "list"
    },
    "map_literal": {
      "pattern": "\\(.*:.*\\)",
      "type": "map"
    }
  }
}
