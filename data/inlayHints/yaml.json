{
  "language": "yaml",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+):\\s*(.+)",
      "kind": 1,
      "label": ": {type}",
      "position": "after_value",
      "paddingLeft": true,
      "description": "Show inferred YAML value types for mapping entries"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "['\"].*['\"]",
      "type": "string"
    },
    "number_literal": {
      "pattern": "[+-]?\\d+(\\.\\d+)?([eE][+-]?\\d+)?",
      "type": "number"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false|yes|no|on|off)\\b",
      "type": "boolean"
    },
    "null_literal": {
      "pattern": "\\b(null|~)\\b",
      "type": "null"
    },
    "timestamp_literal": {
      "pattern": "\\d{4}-\\d{2}-\\d{2}",
      "type": "timestamp"
    }
  }
}
