{
  "language": "mips",
  "inlayHintPatterns": [
    {
      "pattern": "(\\$\\w+)",
      "kind": 1,
      "label": "({reg_name})",
      "position": "after_register",
      "paddingLeft": true,
      "description": "Show conventional register names for numeric register references"
    },
    {
      "kind": "parameter",
      "description": "Parameter name hints",
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "display": "parameterName:",
      "position": "before"
    },
    {
      "kind": "type",
      "description": "Inferred type hints",
      "pattern": "(?:let|var|val|const|auto)\\s+(\\w+)\\s*=",
      "display": ": inferredType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Return type hints",
      "pattern": "(?:function|def|fn|func|fun)\\s+\\w+\\s*\\([^)]*\\)\\s*(?:=>|->|:)?",
      "display": "-> returnType",
      "position": "after"
    },
    {
      "kind": "enum",
      "description": "Enum member value hints",
      "pattern": "(?:enum|const)\\s+\\w+",
      "display": "= value",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Chained method result type",
      "pattern": "\\.(\\w+)\\(",
      "display": ": resultType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Destructuring type hints",
      "pattern": "(?:const|let|var)\\s*[{\\[]",
      "display": ": type",
      "position": "inline"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "asciiz"
    },
    "number_literal": {
      "pattern": "-?\\d+",
      "type": "word"
    },
    "hex_literal": {
      "pattern": "0x[0-9a-fA-F]+",
      "type": "word"
    },
    "register_literal": {
      "pattern": "\\$\\d+|\\$[a-z]\\d+",
      "type": "register"
    }
  }
}
