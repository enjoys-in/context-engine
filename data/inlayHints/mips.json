{
  "language": "mips",
  "inlayHintPatterns": [
    {
      "pattern": "(\\$\\w+)",
      "kind": 1,
      "label": "({reg_name})",
      "position": "after_register",
      "paddingLeft": true,
      "description": "Show conventional register names for numeric register references"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "asciiz"
    },
    "number_literal": {
      "pattern": "-?\\d+",
      "type": "word"
    },
    "hex_literal": {
      "pattern": "0x[0-9a-fA-F]+",
      "type": "word"
    },
    "register_literal": {
      "pattern": "\\$\\d+|\\$[a-z]\\d+",
      "type": "register"
    }
  }
}
