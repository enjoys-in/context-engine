{
  "language": "sparql",
  "inlayHintPatterns": [
    {
      "pattern": "(\\?\\w+)",
      "kind": 1,
      "label": ": {type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show inferred types for SPARQL query variables"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "xsd:string"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "xsd:decimal"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "xsd:boolean"
    },
    "uri_literal": {
      "pattern": "<[^>]+>",
      "type": "IRI"
    }
  }
}
