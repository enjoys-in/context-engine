{
  "language": "tcl",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s+",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at Tcl procedure call sites"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"|\\{[^}]*\\}",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "number"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false|yes|no|1|0)\\b",
      "type": "boolean"
    },
    "list_literal": {
      "pattern": "\\{[^}]+\\}",
      "type": "list"
    }
  }
}
