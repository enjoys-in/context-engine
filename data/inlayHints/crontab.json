{
  "language": "crontab",
  "inlayHintPatterns": [
    {
      "pattern": "^(\\S+)\\s+(\\S+)\\s+(\\S+)\\s+(\\S+)\\s+(\\S+)",
      "kind": 2,
      "label": "min hr dom mon dow",
      "position": "above_line",
      "paddingRight": true,
      "description": "Show field position labels for cron expression fields"
    }
  ],
  "typeInferenceRules": {
    "number_literal": {
      "pattern": "\\d+",
      "type": "integer"
    },
    "range_literal": {
      "pattern": "\\d+-\\d+",
      "type": "range"
    },
    "step_literal": {
      "pattern": "\\*/\\d+",
      "type": "step"
    }
  }
}
