{
  "language": "pascal",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at procedure/function call sites"
    },
    {
      "pattern": "var\\s+(\\w+)\\s*:=",
      "kind": 1,
      "label": ": {type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show inferred types for inline variable declarations"
    },
    {
      "kind": "parameter",
      "description": "Parameter name hints",
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "display": "parameterName:",
      "position": "before"
    },
    {
      "kind": "type",
      "description": "Inferred type hints",
      "pattern": "(?:let|var|val|const|auto)\\s+(\\w+)\\s*=",
      "display": ": inferredType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Return type hints",
      "pattern": "(?:function|def|fn|func|fun)\\s+\\w+\\s*\\([^)]*\\)\\s*(?:=>|->|:)?",
      "display": "-> returnType",
      "position": "after"
    },
    {
      "kind": "enum",
      "description": "Enum member value hints",
      "pattern": "(?:enum|const)\\s+\\w+",
      "display": "= value",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Chained method result type",
      "pattern": "\\.(\\w+)\\(",
      "display": ": resultType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Destructuring type hints",
      "pattern": "(?:const|let|var)\\s*[{\\[]",
      "display": ": type",
      "position": "inline"
    },
    {
      "kind": "type",
      "pattern": "(const|let|var)\\\\s+(\\\\w+)",
      "label": ": {inferred_type}",
      "position": "after",
      "paddingLeft": true,
      "description": "Type inference for Pascal variable declarations"
    },
    {
      "kind": "parameter",
      "pattern": "\\\\b(\\\\w+)\\\\s*\\\\(",
      "label": "{param_name}:",
      "position": "before",
      "paddingRight": true,
      "description": "Parameter name hints for Pascal function calls"
    },
    {
      "kind": "type",
      "pattern": "\\\\breturn\\\\s+",
      "label": "-> {return_type}",
      "position": "after",
      "paddingLeft": true,
      "description": "Return type hints for Pascal functions"
    },
    {
      "kind": "parameter",
      "pattern": "\\\\b(true|false|null|undefined|nil|None)\\\\b",
      "label": "{param_name}:",
      "position": "before",
      "paddingRight": true,
      "description": "Boolean/null literal parameter hints"
    },
    {
      "kind": "type",
      "pattern": "\\\\[([^\\\\]]+)\\\\]",
      "label": ": {element_type}[]",
      "position": "after",
      "paddingLeft": true,
      "description": "Array literal type hints"
    },
    {
      "kind": "type",
      "pattern": "\\\\{([^}]+)\\\\}",
      "label": ": {object_type}",
      "position": "after",
      "paddingLeft": true,
      "description": "Object literal type hints"
    },
    {
      "kind": "parameter",
      "pattern": "\\\\b\\\\d+\\\\.?\\\\d*\\\\b",
      "label": "{param_name}:",
      "position": "before",
      "paddingRight": true,
      "description": "Numeric literal parameter hints"
    },
    {
      "kind": "parameter",
      "pattern": "\"[^\"]*\"",
      "label": "{param_name}:",
      "position": "before",
      "paddingRight": true,
      "description": "String literal parameter hints"
    },
    {
      "kind": "type",
      "pattern": "\\\\blambda\\\\b|=>|->",
      "label": ": {callback_type}",
      "position": "after",
      "paddingLeft": true,
      "description": "Lambda/arrow function type hints"
    },
    {
      "kind": "type",
      "pattern": "\\\\.(\\\\w+)\\\\(\\\\)",
      "label": ": {chain_type}",
      "position": "after",
      "paddingLeft": true,
      "description": "Chained expression type hints"
    },
    {
      "kind": "type",
      "pattern": "\\\\bnew\\\\s+\\\\w+",
      "label": ": {constructor_type}",
      "position": "after",
      "paddingLeft": true,
      "description": "Constructor call type hints"
    },
    {
      "kind": "parameter",
      "pattern": "\\\\b[A-Z][A-Z0-9_]+\\\\b",
      "label": "{enum_member}",
      "position": "before",
      "paddingRight": true,
      "description": "Enum value hints"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "['\"].*['\"]",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\\\d+(\\\\.\\\\d+)?",
      "type": "number"
    },
    "boolean_literal": {
      "pattern": "\\\\b(true|false)\\\\b",
      "type": "boolean"
    },
    "null_literal": {
      "pattern": "\\\\b(null|nil|None|undefined)\\\\b",
      "type": "null"
    },
    "array_literal": {
      "pattern": "\\\\[.*\\\\]",
      "type": "array"
    },
    "object_literal": {
      "pattern": "\\\\{.*\\\\}",
      "type": "object"
    },
    "regex_literal": {
      "pattern": "\\/.*\\/[gimsuy]*",
      "type": "regexp"
    },
    "function_expression": {
      "pattern": "(function|=>|->|lambda|fn|fun)",
      "type": "function"
    },
    "template_string": {
      "pattern": "`[^`]*`",
      "type": "string"
    },
    "tuple_literal": {
      "pattern": "\\\\(.*,.*\\\\)",
      "type": "tuple"
    }
  }
}
