{
  "language": "pascal",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at procedure/function call sites"
    },
    {
      "pattern": "var\\s+(\\w+)\\s*:=",
      "kind": 1,
      "label": ": {type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show inferred types for inline variable declarations"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "'[^']*'",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "Real"
    },
    "boolean_literal": {
      "pattern": "\\b(True|False)\\b",
      "type": "Boolean"
    },
    "null_literal": {
      "pattern": "\\b(nil)\\b",
      "type": "Pointer"
    }
  }
}
