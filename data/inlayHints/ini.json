{
  "language": "ini",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*=\\s*(.+)",
      "kind": 1,
      "label": ": {type}",
      "position": "after_value",
      "paddingLeft": true,
      "description": "Show inferred type of configuration value"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"|'[^']*'",
      "type": "string"
    },
    "number_literal": {
      "pattern": "^\\d+(\\.\\d+)?$",
      "type": "number"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false|yes|no|on|off|1|0)\\b",
      "type": "boolean"
    }
  }
}
