{
  "language": "doctest",
  "inlayHintPatterns": [
    {
      "pattern": ">>>\\s+(.+)",
      "kind": 1,
      "label": "-> {type}",
      "position": "after_expression",
      "paddingLeft": true,
      "description": "Show expected return type for doctest expressions"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "['\"].*['\"]",
      "type": "str"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "number"
    },
    "boolean_literal": {
      "pattern": "\\b(True|False)\\b",
      "type": "bool"
    },
    "null_literal": {
      "pattern": "\\b(None)\\b",
      "type": "NoneType"
    }
  }
}
