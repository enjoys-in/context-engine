{
  "language": "powerquery",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at Power Query function call sites"
    },
    {
      "pattern": "let\\s+(\\w+)\\s*=",
      "kind": 1,
      "label": ": {type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show inferred types for let bindings"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "text"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "number"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "logical"
    },
    "null_literal": {
      "pattern": "\\b(null)\\b",
      "type": "null"
    }
  }
}
