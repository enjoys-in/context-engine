{
  "language": "msdax",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at DAX function call sites"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "String"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "Decimal"
    },
    "boolean_literal": {
      "pattern": "\\b(TRUE|FALSE)\\b",
      "type": "Boolean"
    },
    "null_literal": {
      "pattern": "\\b(BLANK)\\b",
      "type": "Blank"
    }
  }
}
