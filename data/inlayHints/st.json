{
  "language": "st",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s+(\\w+:)",
      "kind": 2,
      "label": "{keyword}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show keyword argument labels at message send sites"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "'[^']*'",
      "type": "String"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "Number"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "Boolean"
    },
    "null_literal": {
      "pattern": "\\b(nil)\\b",
      "type": "UndefinedObject"
    },
    "symbol_literal": {
      "pattern": "#\\w+",
      "type": "Symbol"
    },
    "array_literal": {
      "pattern": "#\\(.*\\)",
      "type": "Array"
    }
  }
}
