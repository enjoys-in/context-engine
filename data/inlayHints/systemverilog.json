{
  "language": "systemverilog",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": ".{port_name}",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show port names at module instantiation sites"
    },
    {
      "pattern": "(\\w+)\\s+(\\w+)\\s*;",
      "kind": 1,
      "label": ": {type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show signal types for variable declarations"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\d+'[hHbBdDoO][0-9a-fA-F_]+|\\d+",
      "type": "logic"
    },
    "boolean_literal": {
      "pattern": "\\b(1'b0|1'b1)\\b",
      "type": "bit"
    }
  }
}
