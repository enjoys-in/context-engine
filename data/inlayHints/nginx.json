{
  "language": "nginx",
  "inlayHintPatterns": [
    {
      "pattern": "(?:set)\\\\s+(\\\\w+)\\\\s*=\\\\s*(.+)",
      "kind": 1,
      "label": ": {inferred_type}",
      "position": "after_capture_1",
      "paddingLeft": true,
      "description": "Show inferred type for variable assignments"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "['\"].*['\"]",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\\\d+(\\\\.\\\\d+)?",
      "type": "number"
    },
    "boolean_literal": {
      "pattern": "\\\\b(true|false)\\\\b",
      "type": "boolean"
    },
    "array_literal": {
      "pattern": "\\\\[.*\\\\]",
      "type": "array"
    },
    "null_literal": {
      "pattern": "\\\\b(null)\\\\b",
      "type": "null"
    }
  }
}
