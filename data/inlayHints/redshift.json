{
  "language": "redshift",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "kind": 2,
      "label": "{param_name}:",
      "position": "before_each_arg",
      "paddingRight": true,
      "description": "Show parameter names at Redshift function call sites"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "'[^']*'",
      "type": "VARCHAR"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "DECIMAL"
    },
    "boolean_literal": {
      "pattern": "\\b(TRUE|FALSE|true|false)\\b",
      "type": "BOOLEAN"
    },
    "null_literal": {
      "pattern": "\\b(NULL)\\b",
      "type": "NULL"
    }
  }
}
