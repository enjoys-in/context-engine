{
  "language": "redis",
  "inlayHintPatterns": [
    {
      "pattern": "(GET|SET|HGET|HSET|LPUSH|RPUSH|SADD|ZADD)\\s+",
      "kind": 2,
      "label": "key:",
      "position": "before_first_arg",
      "paddingRight": true,
      "description": "Show argument role labels for Redis commands"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\d+(\\.\\d+)?",
      "type": "number"
    },
    "null_literal": {
      "pattern": "\\(nil\\)",
      "type": "nil"
    }
  }
}
