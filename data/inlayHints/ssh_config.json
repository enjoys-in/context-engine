{
  "language": "ssh_config",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s+(.+)",
      "kind": 1,
      "label": ": {type}",
      "position": "after_value",
      "paddingLeft": true,
      "description": "Show expected value type for SSH config directives"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\d+",
      "type": "integer"
    },
    "boolean_literal": {
      "pattern": "\\b(yes|no)\\b",
      "type": "boolean"
    },
    "path_literal": {
      "pattern": "~?/[\\w/.-]+",
      "type": "path"
    }
  }
}
