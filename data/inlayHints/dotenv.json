{
  "language": "dotenv",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*=\\s*(.+)",
      "kind": 1,
      "label": ": {type}",
      "position": "after_value",
      "paddingLeft": true,
      "description": "Show inferred type of environment variable value"
    },
    {
      "kind": "parameter",
      "description": "Parameter name hints",
      "pattern": "(\\w+)\\s*\\(([^)]+)\\)",
      "display": "parameterName:",
      "position": "before"
    },
    {
      "kind": "type",
      "description": "Inferred type hints",
      "pattern": "(?:let|var|val|const|auto)\\s+(\\w+)\\s*=",
      "display": ": inferredType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Return type hints",
      "pattern": "(?:function|def|fn|func|fun)\\s+\\w+\\s*\\([^)]*\\)\\s*(?:=>|->|:)?",
      "display": "-> returnType",
      "position": "after"
    },
    {
      "kind": "enum",
      "description": "Enum member value hints",
      "pattern": "(?:enum|const)\\s+\\w+",
      "display": "= value",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Chained method result type",
      "pattern": "\\.(\\w+)\\(",
      "display": ": resultType",
      "position": "after"
    },
    {
      "kind": "type",
      "description": "Destructuring type hints",
      "pattern": "(?:const|let|var)\\s*[{\\[]",
      "display": ": type",
      "position": "inline"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "['\"].*['\"]",
      "type": "string"
    },
    "number_literal": {
      "pattern": "^\\d+$",
      "type": "number"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false|yes|no|1|0)\\b",
      "type": "boolean"
    },
    "url_literal": {
      "pattern": "https?://",
      "type": "url"
    },
    "path_literal": {
      "pattern": "^/[\\w/.-]+",
      "type": "path"
    }
  }
}
