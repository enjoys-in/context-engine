{
  "language": "dotenv",
  "inlayHintPatterns": [
    {
      "pattern": "(\\w+)\\s*=\\s*(.+)",
      "kind": 1,
      "label": ": {type}",
      "position": "after_value",
      "paddingLeft": true,
      "description": "Show inferred type of environment variable value"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "['\"].*['\"]",
      "type": "string"
    },
    "number_literal": {
      "pattern": "^\\d+$",
      "type": "number"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false|yes|no|1|0)\\b",
      "type": "boolean"
    },
    "url_literal": {
      "pattern": "https?://",
      "type": "url"
    },
    "path_literal": {
      "pattern": "^/[\\w/.-]+",
      "type": "path"
    }
  }
}
