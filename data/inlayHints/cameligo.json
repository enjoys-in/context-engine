{
  "language": "cameligo",
  "inlayHintPatterns": [
    {
      "pattern": "let\\s+(\\w+)\\s*=",
      "kind": 1,
      "label": ": {type}",
      "position": "after_variable",
      "paddingLeft": true,
      "description": "Show inferred types for let bindings"
    }
  ],
  "typeInferenceRules": {
    "string_literal": {
      "pattern": "\"[^\"]*\"",
      "type": "string"
    },
    "number_literal": {
      "pattern": "\\d+",
      "type": "int"
    },
    "boolean_literal": {
      "pattern": "\\b(true|false)\\b",
      "type": "bool"
    },
    "null_literal": {
      "pattern": "\\b(unit)\\b",
      "type": "unit"
    }
  }
}
