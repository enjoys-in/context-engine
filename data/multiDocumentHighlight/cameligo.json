{
  "language": "cameligo",
  "selector": {
    "language": "cameligo",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "function",
      "pattern": "\\b(function|func|fn|def|sub|proc|method|void|int|string)\\s+(\\w+)",
      "importPattern": "(import|include|require|use|load)\\s+.*{name}",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Function/procedure across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "type",
      "pattern": "\\b(class|type|struct|record|interface|trait|enum)\\s+(\\w+)",
      "importPattern": "(import|include|require|use)\\s+.*{name}",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Type definition across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "constant",
      "pattern": "\\b(const|final|val|define)\\s+(\\w+)",
      "importPattern": "(import|include|require|use)\\s+",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Constant declaration",
      "crossFileCapable": true
    },
    {
      "symbolKind": "variable",
      "pattern": "\\b(var|let|my|local|dim)\\s+(\\w+)",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Variable reference",
      "crossFileCapable": false
    },
    {
      "symbolKind": "module",
      "pattern": "\\b(module|namespace|package|unit|program)\\s+([\\w.]+)",
      "importPattern": "(import|use|include|require)\\s+{name}",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Module/namespace reference",
      "crossFileCapable": true
    },
    {
      "symbolKind": "macro",
      "pattern": "\\b(macro|define|template)\\s+(\\w+)",
      "importPattern": "(import|include)\\s+",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Macro/define reference",
      "crossFileCapable": true
    },
    {
      "symbolKind": "label",
      "pattern": "\\b(\\w+):",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Label reference",
      "crossFileCapable": false
    },
    {
      "kind": "function",
      "pattern": "(?:function|def|fn|func|sub|proc)\\\\s+(\\\\w+)",
      "description": "Function declarations"
    },
    {
      "kind": "class",
      "pattern": "\\\\bclass\\\\s+([A-Z]\\\\w*)",
      "description": "Class declarations"
    },
    {
      "kind": "variable",
      "pattern": "(?:export|pub)\\\\s+(?:const|let|var)\\\\s+(\\\\w+)",
      "description": "Exported variables"
    },
    {
      "kind": "type",
      "pattern": "\\\\b(type|interface)\\\\s+([A-Z]\\\\w*)",
      "description": "Type/interface declarations"
    },
    {
      "kind": "constant",
      "pattern": "\\\\b(const|final|readonly)\\\\s+([A-Z_]\\\\w*)",
      "description": "Constant declarations"
    },
    {
      "kind": "enum",
      "pattern": "\\\\benum\\\\s+([A-Z]\\\\w*)",
      "description": "Enum declarations"
    },
    {
      "kind": "module",
      "pattern": "(?:module|namespace|package)\\\\s+(\\\\w+)",
      "description": "Module/namespace declarations"
    },
    {
      "kind": "interface",
      "pattern": "\\\\binterface\\\\s+([A-Z]\\\\w*)",
      "description": "Interface declarations"
    },
    {
      "kind": "method",
      "pattern": "\\\\b(public|private|protected)?\\\\s*\\\\w+\\\\s*\\\\(",
      "description": "Method declarations"
    },
    {
      "kind": "import",
      "pattern": "import\\\\s+.*?['\"]([^'\"]+)['\"]",
      "description": "Import statements for cross-file resolution"
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "(import|include|require|use|load)\\s+['\"]?([\\w./]+)['\"]?",
      "(import|include|require|use|load|source)\\s+['\"]?([\\w./\\-]+)['\"]?",
      "from\\s+([\\w./]+)\\s+import",
      "#include\\s+[<\"]([^>\"]+)[>\"]"
    ],
    "exportStatements": [
      "(export|public|pub)\\s+(\\w+)\\s+(\\w+)",
      "(export|public|pub)\\s+(class|struct|function|fn|def|const|var|type)\\s+(\\w+)",
      "module\\.exports\\s*="
    ],
    "reExportStatements": [
      "(export|pub)\\s+(use|import|from)\\s+"
    ]
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\b(global|public)\\s+\\w+\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\b(\\w+)\\s*=",
        "(class|module|namespace)\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [
        "\\b(self|this|me)\\.(\\w+)"
      ],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\b(\\w+)\\s*=",
        "\\b(var|let|const|local)\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\b(\\w+)\\s*="
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    "++",
    "--",
    ".push(",
    ".pop(",
    ".set(",
    ".add(",
    ".remove(",
    ".delete(",
    ".clear("
  ],
  "readOperations": [
    ".length",
    ".size()",
    ".get(",
    ".contains(",
    ".indexOf(",
    ".toString(",
    ".equals(",
    ".compareTo(",
    "typeof",
    "instanceof",
    ".isEmpty()",
    ".count("
  ],
  "declarationPatterns": [
    "\\b(\\w+)\\s*=",
    "\\b(var|let|const|val|def|func|fn)\\s+(\\w+)",
    "\\b(class|struct|type|interface)\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\b(\\w+)\\(",
    "\\b(\\w+)\\.",
    "new\\s+(\\w+)"
  ],
  "specialHighlights": {
    "typeReferences": true,
    "decorators": false,
    "comments": true
  }
}
