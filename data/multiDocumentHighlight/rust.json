{
  "language": "rust",
  "selector": {
    "language": "rust",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "function",
      "pattern": "\\bfn\\s+(\\w+)",
      "importPattern": "use\\s+[\\w:]+::{name}",
      "exportPattern": "pub\\s+fn\\s+{name}",
      "highlightKind": 1,
      "description": "Function across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "struct",
      "pattern": "\\bstruct\\s+(\\w+)",
      "importPattern": "use\\s+[\\w:]+::{name}",
      "exportPattern": "pub\\s+struct\\s+{name}",
      "highlightKind": 1,
      "description": "Struct across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "enum",
      "pattern": "\\benum\\s+(\\w+)",
      "importPattern": "use\\s+[\\w:]+::{name}",
      "exportPattern": "pub\\s+enum\\s+{name}",
      "highlightKind": 1,
      "description": "Enum across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "trait",
      "pattern": "\\btrait\\s+(\\w+)",
      "importPattern": "use\\s+[\\w:]+::{name}",
      "exportPattern": "pub\\s+trait\\s+{name}",
      "highlightKind": 1,
      "description": "Trait across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "module",
      "pattern": "\\bmod\\s+(\\w+)",
      "importPattern": "use\\s+{name}",
      "exportPattern": "pub\\s+mod\\s+{name}",
      "highlightKind": 1,
      "description": "Module across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "macro",
      "pattern": "\\bmacro_rules!\\s+(\\w+)",
      "importPattern": "use\\s+[\\w:]+::{name}",
      "exportPattern": "#\\[macro_export\\]",
      "highlightKind": 1,
      "description": "Macro across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "typeAlias",
      "pattern": "\\btype\\s+(\\w+)",
      "importPattern": "use\\s+[\\w:]+::{name}",
      "exportPattern": "pub\\s+type\\s+{name}",
      "highlightKind": 1,
      "description": "Type alias across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "constant",
      "pattern": "\\bconst\\s+(\\w+)",
      "importPattern": "use\\s+[\\w:]+::{name}",
      "exportPattern": "pub\\s+const\\s+{name}",
      "highlightKind": 1,
      "description": "Constant across files",
      "crossFileCapable": true
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "use\\s+([\\w:]+(?:::\\{[^}]+\\})?)",
      "use\\s+([\\w:]+)\\s+as\\s+(\\w+)",
      "extern\\s+crate\\s+(\\w+)"
    ],
    "exportStatements": [
      "pub(\\(crate\\))?\\s+(fn|struct|enum|trait|type|const|static|mod)\\s+(\\w+)"
    ],
    "reExportStatements": [
      "pub\\s+use\\s+([\\w:]+)"
    ]
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "pub\\s+(static|const)\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\bmod\\s+(\\w+)",
        "pub\\s+(fn|struct|enum|trait)\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [
        "\\bself\\.(\\w+)",
        "\\bSelf::(\\w+)",
        "&self",
        "&mut self"
      ],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\blet\\s+(mut\\s+)?(\\w+)",
        "\\bfor\\s+(\\w+)\\s+in",
        "if\\s+let\\s+.+\\s*=\\s*(\\w+)"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\blet\\s+(mut\\s+)?(\\w+)"
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    "&=",
    "|=",
    "^=",
    "<<=",
    ">>=",
    ".push(",
    ".pop(",
    ".insert(",
    ".remove(",
    ".clear(",
    ".sort(",
    ".drain(",
    ".extend(",
    ".truncate(",
    "std::mem::swap(",
    "std::mem::replace("
  ],
  "readOperations": [
    ".len()",
    ".is_empty()",
    ".contains(",
    ".iter()",
    ".into_iter()",
    ".get(",
    ".unwrap()",
    ".expect(",
    ".as_ref()",
    ".as_mut()",
    ".clone()",
    ".to_string()",
    ".to_owned()",
    ".as_str()",
    "&"
  ],
  "declarationPatterns": [
    "\\blet\\s+(mut\\s+)?(\\w+)",
    "\\bfn\\s+(\\w+)",
    "\\bstruct\\s+(\\w+)",
    "\\benum\\s+(\\w+)",
    "\\btrait\\s+(\\w+)",
    "\\btype\\s+(\\w+)",
    "\\bconst\\s+(\\w+)",
    "\\bstatic\\s+(\\w+)",
    "\\bmod\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\b(\\w+)::",
    "\\b(\\w+)\\(",
    "\\b(\\w+)\\{",
    "\\bimpl\\s+(\\w+)",
    "\\bdyn\\s+(\\w+)",
    "impl\\s+<[^>]*>\\s+(\\w+)"
  ],
  "specialHighlights": {
    "typeReferences": {
      "pattern": ":\\s*(\\w+)",
      "highlightKind": 1
    },
    "decorators": {
      "pattern": "#\\[(\\w+)",
      "highlightKind": 1
    },
    "comments": {
      "pattern": "",
      "highlightKind": 0
    },
    "lifetimes": {
      "pattern": "'(\\w+)",
      "highlightKind": 1
    }
  }
}
