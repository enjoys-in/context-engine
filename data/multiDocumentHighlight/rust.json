{
  "language": "rust",
  "selector": {
    "language": "rust",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "function",
      "pattern": "\\bfn\\s+(\\w+)",
      "importPattern": "use\\s+[\\w:]+::{name}",
      "exportPattern": "pub\\s+fn\\s+{name}",
      "highlightKind": 1,
      "description": "Function across modules",
      "crossFileCapable": true
    },
    {
      "symbolKind": "struct",
      "pattern": "\\bstruct\\s+(\\w+)",
      "importPattern": "use\\s+[\\w:]+::{name}",
      "exportPattern": "pub\\s+struct\\s+{name}",
      "highlightKind": 1,
      "description": "Struct across modules",
      "crossFileCapable": true
    },
    {
      "symbolKind": "enum",
      "pattern": "\\benum\\s+(\\w+)",
      "importPattern": "use\\s+[\\w:]+::{name}",
      "exportPattern": "pub\\s+enum\\s+{name}",
      "highlightKind": 1,
      "description": "Enum across modules",
      "crossFileCapable": true
    },
    {
      "symbolKind": "trait",
      "pattern": "\\btrait\\s+(\\w+)",
      "importPattern": "use\\s+[\\w:]+::{name}",
      "exportPattern": "pub\\s+trait\\s+{name}",
      "highlightKind": 1,
      "description": "Trait across modules",
      "crossFileCapable": true
    },
    {
      "symbolKind": "module",
      "pattern": "\\bmod\\s+(\\w+)",
      "importPattern": "use\\s+{name}::",
      "exportPattern": "pub\\s+mod\\s+{name}",
      "highlightKind": 1,
      "description": "Module declaration",
      "crossFileCapable": true
    },
    {
      "symbolKind": "type",
      "pattern": "\\btype\\s+(\\w+)",
      "importPattern": "use\\s+[\\w:]+::{name}",
      "exportPattern": "pub\\s+type\\s+{name}",
      "highlightKind": 1,
      "description": "Type alias across modules",
      "crossFileCapable": true
    },
    {
      "symbolKind": "macro",
      "pattern": "macro_rules!\\s+(\\w+)",
      "importPattern": "use\\s+[\\w:]+::{name}",
      "exportPattern": "#\\[macro_export\\]",
      "highlightKind": 1,
      "description": "Macro across crates",
      "crossFileCapable": true
    },
    {
      "symbolKind": "constant",
      "pattern": "\\bconst\\s+(\\w+)",
      "importPattern": "use\\s+[\\w:]+::{name}",
      "exportPattern": "pub\\s+const\\s+{name}",
      "highlightKind": 1,
      "description": "Constant across modules",
      "crossFileCapable": true
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "use\\s+([\\w:]+::\\{[^}]+\\})",
      "use\\s+([\\w:]+::\\w+)",
      "use\\s+([\\w:]+::\\*)",
      "extern\\s+crate\\s+(\\w+)",
      "use\\s+(\\w+)\\s+as\\s+(\\w+)"
    ],
    "exportStatements": [
      "pub\\s+(fn|struct|enum|trait|type|const|static|mod|use)\\s+(\\w+)",
      "pub\\(crate\\)\\s+(fn|struct|enum)\\s+(\\w+)",
      "#\\[macro_export\\]"
    ],
    "reExportStatements": [
      "pub\\s+use\\s+([\\w:]+)",
      "pub\\s+use\\s+([\\w:]+::\\*)"
    ]
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\bstatic\\s+(mut\\s+)?(\\w+)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\bpub\\s+(fn|struct|enum|trait)\\s+(\\w+)",
        "\\bmod\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [
        "\\bself\\.(\\w+)",
        "Self::(\\w+)"
      ],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\blet\\s+(mut\\s+)?(\\w+)",
        "\\bfn\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\blet\\s+(mut\\s+)?(\\w+)"
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    "**=",
    "<<=",
    ">>=",
    "&=",
    "^=",
    "|=",
    "&&=",
    "||=",
    "??=",
    "++",
    "--",
    "delete",
    ".push(",
    ".pop(",
    ".shift(",
    ".splice(",
    ".sort(",
    ".reverse(",
    ".fill("
  ],
  "readOperations": [
    ".length",
    ".indexOf(",
    ".includes(",
    ".find(",
    ".filter(",
    ".map(",
    ".reduce(",
    ".some(",
    ".every(",
    ".forEach(",
    ".keys(",
    ".values(",
    ".entries(",
    ".slice(",
    ".concat(",
    ".join(",
    ".toString(",
    ".valueOf(",
    "JSON.stringify(",
    "JSON.parse(",
    "typeof",
    "instanceof",
    "in"
  ],
  "declarationPatterns": [
    "\\blet\\s+(mut\\s+)?(\\w+)",
    "\\bfn\\s+(\\w+)",
    "\\bstruct\\s+(\\w+)",
    "\\benum\\s+(\\w+)",
    "\\btrait\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\b(\\w+)\\(",
    "\\b(\\w+)\\.",
    "new\\s+(\\w+)"
  ],
  "specialHighlights": {
    "typeReferences": true,
    "decorators": true,
    "comments": true
  }
}
