{
  "language": "dart",
  "selector": {
    "language": "dart",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "class",
      "pattern": "\\bclass\\s+(\\w+)",
      "importPattern": "import\\s+['\"][^'\"]+['\"]",
      "exportPattern": "\\bclass\\s+{name}",
      "highlightKind": 1,
      "description": "Class across libraries",
      "crossFileCapable": true
    },
    {
      "symbolKind": "mixin",
      "pattern": "\\bmixin\\s+(\\w+)",
      "importPattern": "import\\s+['\"][^'\"]+['\"]",
      "exportPattern": "\\bmixin\\s+{name}",
      "highlightKind": 1,
      "description": "Mixin across libraries",
      "crossFileCapable": true
    },
    {
      "symbolKind": "extension",
      "pattern": "\\bextension\\s+(\\w+)",
      "importPattern": "import\\s+['\"][^'\"]+['\"]",
      "exportPattern": "\\bextension\\s+{name}",
      "highlightKind": 1,
      "description": "Extension across libraries",
      "crossFileCapable": true
    },
    {
      "symbolKind": "enum",
      "pattern": "\\benum\\s+(\\w+)",
      "importPattern": "import\\s+['\"][^'\"]+['\"]",
      "exportPattern": "\\benum\\s+{name}",
      "highlightKind": 1,
      "description": "Enum across libraries",
      "crossFileCapable": true
    },
    {
      "symbolKind": "typedef",
      "pattern": "\\btypedef\\s+(\\w+)",
      "importPattern": "import\\s+['\"][^'\"]+['\"]",
      "exportPattern": "\\btypedef\\s+{name}",
      "highlightKind": 1,
      "description": "Typedef across libraries",
      "crossFileCapable": true
    },
    {
      "symbolKind": "function",
      "pattern": "\\b(\\w+)\\(",
      "importPattern": "import\\s+['\"][^'\"]+['\"]",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Top-level function",
      "crossFileCapable": true
    },
    {
      "symbolKind": "library",
      "pattern": "library\\s+(\\w+)",
      "importPattern": "import\\s+['\"][^'\"]+['\"]",
      "exportPattern": "library\\s+{name}",
      "highlightKind": 1,
      "description": "Library reference",
      "crossFileCapable": true
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "#include\\s+[<\"]([^>\"]+)[>\"]",
      "import\\s+([\\w.]+)",
      "using\\s+([\\w.]+)",
      "require\\s+([\\w.]+)"
    ],
    "exportStatements": [
      "(public|export)\\s+(class|struct|function|fn|func|def)\\s+(\\w+)",
      "module\\.exports"
    ],
    "reExportStatements": [
      "(export|pub)\\s+(use|import)\\s+"
    ]
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\b(global|public)\\s+\\w+\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\b(\\w+)\\s*=",
        "(class|module|namespace)\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [
        "\\b(self|this|me)\\.(\\w+)"
      ],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\b(\\w+)\\s*=",
        "\\b(var|let|const|local)\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\b(\\w+)\\s*="
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    "**=",
    "<<=",
    ">>=",
    "&=",
    "^=",
    "|=",
    "&&=",
    "||=",
    "??=",
    "++",
    "--",
    "delete",
    ".push(",
    ".pop(",
    ".shift(",
    ".splice(",
    ".sort(",
    ".reverse(",
    ".fill("
  ],
  "readOperations": [
    ".length",
    ".indexOf(",
    ".includes(",
    ".find(",
    ".filter(",
    ".map(",
    ".reduce(",
    ".some(",
    ".every(",
    ".forEach(",
    ".keys(",
    ".values(",
    ".entries(",
    ".slice(",
    ".concat(",
    ".join(",
    ".toString(",
    ".valueOf(",
    "JSON.stringify(",
    "JSON.parse(",
    "typeof",
    "instanceof",
    "in"
  ],
  "declarationPatterns": [
    "\\b(\\w+)\\s*=",
    "\\b(var|let|const|val|def|func|fn)\\s+(\\w+)",
    "\\b(class|struct|type|interface)\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\b(\\w+)\\(",
    "\\b(\\w+)\\.",
    "new\\s+(\\w+)"
  ],
  "specialHighlights": {
    "typeReferences": true,
    "decorators": true,
    "comments": true
  }
}
