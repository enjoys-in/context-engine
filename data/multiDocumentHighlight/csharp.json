{
  "language": "csharp",
  "selector": {
    "language": "csharp",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "class",
      "pattern": "\\bclass\\s+(\\w+)",
      "importPattern": "using\\s+[\\w.]+",
      "exportPattern": "public\\s+(partial\\s+)?class\\s+{name}",
      "highlightKind": 1,
      "description": "Class across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "interface",
      "pattern": "\\binterface\\s+(\\w+)",
      "importPattern": "using\\s+[\\w.]+",
      "exportPattern": "public\\s+interface\\s+{name}",
      "highlightKind": 1,
      "description": "Interface across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "struct",
      "pattern": "\\bstruct\\s+(\\w+)",
      "importPattern": "using\\s+[\\w.]+",
      "exportPattern": "public\\s+(readonly\\s+)?struct\\s+{name}",
      "highlightKind": 1,
      "description": "Struct across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "enum",
      "pattern": "\\benum\\s+(\\w+)",
      "importPattern": "using\\s+[\\w.]+",
      "exportPattern": "public\\s+enum\\s+{name}",
      "highlightKind": 1,
      "description": "Enum across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "record",
      "pattern": "\\brecord\\s+(\\w+)",
      "importPattern": "using\\s+[\\w.]+",
      "exportPattern": "public\\s+record\\s+{name}",
      "highlightKind": 1,
      "description": "Record across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "delegate",
      "pattern": "\\bdelegate\\s+\\w+\\s+(\\w+)",
      "importPattern": "using\\s+[\\w.]+",
      "exportPattern": "public\\s+delegate",
      "highlightKind": 1,
      "description": "Delegate across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "namespace",
      "pattern": "\\bnamespace\\s+([\\w.]+)",
      "importPattern": "using\\s+{name}",
      "exportPattern": "namespace\\s+{name}",
      "highlightKind": 1,
      "description": "Namespace across files",
      "crossFileCapable": true
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "using\\s+([\\w.]+)\\s*;",
      "using\\s+static\\s+([\\w.]+)\\s*;",
      "using\\s+(\\w+)\\s*=\\s*([\\w.]+)\\s*;"
    ],
    "exportStatements": [
      "(public|internal)\\s+(partial\\s+)?(class|interface|struct|enum|record|delegate)\\s+(\\w+)"
    ],
    "reExportStatements": []
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\bstatic\\s+.+\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\bnamespace\\s+([\\w.]+)"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [
        "\\bthis\\.(\\w+)",
        "\\bbase\\.(\\w+)",
        "(private|protected|public|internal)\\s+\\w+\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\b(var|\\w+)\\s+(\\w+)\\s*=",
        "foreach\\s*\\(.+\\s+(\\w+)\\s+in",
        "catch\\s*\\(\\w+\\s+(\\w+)\\)"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\bvar\\s+(\\w+)",
        "using\\s*\\(.+\\s+(\\w+)\\s*="
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    "&=",
    "|=",
    "^=",
    "<<=",
    ">>=",
    "++",
    "--",
    ".Add(",
    ".Remove(",
    ".Clear(",
    ".Insert(",
    ".RemoveAt(",
    ".Sort(",
    ".Reverse(",
    ".AddRange(",
    ".TryAdd("
  ],
  "readOperations": [
    ".Count",
    ".Length",
    ".Contains(",
    ".IndexOf(",
    ".Any(",
    ".All(",
    ".First(",
    ".Last(",
    ".Select(",
    ".Where(",
    ".OrderBy(",
    ".GroupBy(",
    ".ToList(",
    ".ToArray(",
    ".ToDictionary(",
    ".ToString(",
    ".GetType(",
    "is ",
    "as "
  ],
  "declarationPatterns": [
    "\\b(var|\\w+)\\s+(\\w+)\\s*=",
    "\\b\\w+\\s+(\\w+)\\s*;",
    "\\b\\w+\\s+(\\w+)\\s*\\("
  ],
  "referencePatterns": [
    "\\b(\\w+)\\.",
    "\\bnew\\s+(\\w+)",
    "\\b:\\s*(\\w+)",
    "\\bas\\s+(\\w+)",
    "\\bis\\s+(\\w+)",
    "\\[(\\w+)\\]"
  ],
  "specialHighlights": {
    "typeReferences": {
      "pattern": "\\b([A-Z]\\w+)(?:<|\\s|\\.|\\))",
      "highlightKind": 1
    },
    "decorators": {
      "pattern": "\\[(\\w+)(?:\\(|\\])",
      "highlightKind": 1
    },
    "comments": {
      "pattern": "///<\\s*(param|returns|typeparam).*?name=\"(\\w+)\"",
      "highlightKind": 0
    }
  }
}
