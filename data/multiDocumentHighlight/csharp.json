{
  "language": "csharp",
  "selector": {
    "language": "csharp",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "class",
      "pattern": "\\bclass\\s+(\\w+)",
      "importPattern": "using\\s+[\\w.]+;",
      "exportPattern": "public\\s+class\\s+{name}",
      "highlightKind": 1,
      "description": "Class across namespaces",
      "crossFileCapable": true
    },
    {
      "symbolKind": "interface",
      "pattern": "\\binterface\\s+(\\w+)",
      "importPattern": "using\\s+[\\w.]+;",
      "exportPattern": "public\\s+interface\\s+{name}",
      "highlightKind": 1,
      "description": "Interface across namespaces",
      "crossFileCapable": true
    },
    {
      "symbolKind": "struct",
      "pattern": "\\bstruct\\s+(\\w+)",
      "importPattern": "using\\s+[\\w.]+;",
      "exportPattern": "public\\s+struct\\s+{name}",
      "highlightKind": 1,
      "description": "Struct across namespaces",
      "crossFileCapable": true
    },
    {
      "symbolKind": "enum",
      "pattern": "\\benum\\s+(\\w+)",
      "importPattern": "using\\s+[\\w.]+;",
      "exportPattern": "public\\s+enum\\s+{name}",
      "highlightKind": 1,
      "description": "Enum across namespaces",
      "crossFileCapable": true
    },
    {
      "symbolKind": "delegate",
      "pattern": "\\bdelegate\\s+\\S+\\s+(\\w+)",
      "importPattern": "using\\s+[\\w.]+;",
      "exportPattern": "public\\s+delegate",
      "highlightKind": 1,
      "description": "Delegate type across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "namespace",
      "pattern": "\\bnamespace\\s+([\\w.]+)",
      "importPattern": "using\\s+{name};",
      "exportPattern": "namespace\\s+{name}",
      "highlightKind": 1,
      "description": "Namespace reference",
      "crossFileCapable": true
    },
    {
      "symbolKind": "attribute",
      "pattern": "\\[(\\w+)(Attribute)?\\]",
      "importPattern": "using\\s+[\\w.]+;",
      "exportPattern": "public\\s+class\\s+{name}Attribute",
      "highlightKind": 1,
      "description": "Attribute across namespaces",
      "crossFileCapable": true
    },
    {
      "kind": "function",
      "pattern": "(?:public|private|protected)?\\\\s*\\\\w+\\\\s+(\\\\w+)\\\\s*\\\\(",
      "description": "Function declarations"
    },
    {
      "kind": "class",
      "pattern": "\\\\bclass\\\\s+([A-Z]\\\\w*)",
      "description": "Class declarations"
    },
    {
      "kind": "variable",
      "pattern": "(?:export|pub)\\\\s+(?:const|let|var)\\\\s+(\\\\w+)",
      "description": "Exported variables"
    },
    {
      "kind": "type",
      "pattern": "\\\\b(type|interface)\\\\s+([A-Z]\\\\w*)",
      "description": "Type/interface declarations"
    },
    {
      "kind": "constant",
      "pattern": "\\\\b(const|final|readonly)\\\\s+([A-Z_]\\\\w*)",
      "description": "Constant declarations"
    },
    {
      "kind": "enum",
      "pattern": "\\\\benum\\\\s+([A-Z]\\\\w*)",
      "description": "Enum declarations"
    },
    {
      "kind": "module",
      "pattern": "(?:module|namespace|package)\\\\s+(\\\\w+)",
      "description": "Module/namespace declarations"
    },
    {
      "kind": "interface",
      "pattern": "\\\\binterface\\\\s+([A-Z]\\\\w*)",
      "description": "Interface declarations"
    },
    {
      "kind": "method",
      "pattern": "\\\\b(public|private|protected)?\\\\s*\\\\w+\\\\s*\\\\(",
      "description": "Method declarations"
    },
    {
      "kind": "import",
      "pattern": "import\\\\s+.*?['\"]([^'\"]+)['\"]",
      "description": "Import statements for cross-file resolution"
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "using\\s+([\\w.]+);",
      "using\\s+static\\s+([\\w.]+);",
      "using\\s+(\\w+)\\s*=\\s*([\\w.]+);",
      "global\\s+using\\s+([\\w.]+);"
    ],
    "exportStatements": [
      "namespace\\s+([\\w.]+)",
      "public\\s+(class|interface|struct|enum|record|delegate)\\s+(\\w+)"
    ],
    "reExportStatements": []
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\bstatic\\s+.*\\b(\\w+)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\bnamespace\\s+([\\w.]+)",
        "\\bpublic\\s+\\w+\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [
        "\\bthis\\.(\\w+)",
        "\\bbase\\.(\\w+)",
        "\\bstatic\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\b(var|\\w+)\\s+(\\w+)\\s*="
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\b(var|\\w+)\\s+(\\w+)\\s*="
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    "**=",
    "<<=",
    ">>=",
    "&=",
    "^=",
    "|=",
    "&&=",
    "||=",
    "??=",
    "++",
    "--",
    "delete",
    ".push(",
    ".pop(",
    ".shift(",
    ".splice(",
    ".sort(",
    ".reverse(",
    ".fill("
  ],
  "readOperations": [
    ".length",
    ".indexOf(",
    ".includes(",
    ".find(",
    ".filter(",
    ".map(",
    ".reduce(",
    ".some(",
    ".every(",
    ".forEach(",
    ".keys(",
    ".values(",
    ".entries(",
    ".slice(",
    ".concat(",
    ".join(",
    ".toString(",
    ".valueOf(",
    "JSON.stringify(",
    "JSON.parse(",
    "typeof",
    "instanceof",
    "in"
  ],
  "declarationPatterns": [
    "\\b(var|\\w+)\\s+(\\w+)\\s*=",
    "\\bclass\\s+(\\w+)",
    "\\binterface\\s+(\\w+)",
    "\\bstruct\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\b(\\w+)\\(",
    "\\b(\\w+)\\.",
    "new\\s+(\\w+)"
  ],
  "specialHighlights": {
    "typeReferences": true,
    "decorators": true,
    "comments": true
  }
}
