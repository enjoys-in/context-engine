{
  "language": "redshift",
  "selector": {
    "language": "redshift",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "table",
      "pattern": "\\bCREATE\\s+TABLE\\s+(\\w+)",
      "importPattern": "",
      "exportPattern": "CREATE\\s+TABLE\\s+{name}",
      "highlightKind": 1,
      "description": "Table reference across queries",
      "crossFileCapable": true
    },
    {
      "symbolKind": "view",
      "pattern": "\\bCREATE\\s+VIEW\\s+(\\w+)",
      "importPattern": "",
      "exportPattern": "CREATE\\s+VIEW\\s+{name}",
      "highlightKind": 1,
      "description": "View reference",
      "crossFileCapable": true
    },
    {
      "symbolKind": "function",
      "pattern": "\\bCREATE\\s+FUNCTION\\s+(\\w+)",
      "importPattern": "",
      "exportPattern": "CREATE\\s+FUNCTION\\s+{name}",
      "highlightKind": 1,
      "description": "Function reference",
      "crossFileCapable": true
    },
    {
      "symbolKind": "procedure",
      "pattern": "\\bCREATE\\s+PROCEDURE\\s+(\\w+)",
      "importPattern": "",
      "exportPattern": "CREATE\\s+PROCEDURE\\s+{name}",
      "highlightKind": 1,
      "description": "Procedure reference",
      "crossFileCapable": true
    },
    {
      "symbolKind": "trigger",
      "pattern": "\\bCREATE\\s+TRIGGER\\s+(\\w+)",
      "importPattern": "",
      "exportPattern": "CREATE\\s+TRIGGER\\s+{name}",
      "highlightKind": 1,
      "description": "Trigger reference",
      "crossFileCapable": true
    },
    {
      "symbolKind": "index",
      "pattern": "\\bCREATE\\s+INDEX\\s+(\\w+)",
      "importPattern": "",
      "exportPattern": "CREATE\\s+INDEX\\s+{name}",
      "highlightKind": 1,
      "description": "Index reference",
      "crossFileCapable": true
    },
    {
      "symbolKind": "schema",
      "pattern": "\\bCREATE\\s+SCHEMA\\s+(\\w+)",
      "importPattern": "",
      "exportPattern": "CREATE\\s+SCHEMA\\s+{name}",
      "highlightKind": 1,
      "description": "Schema reference",
      "crossFileCapable": true
    },
    {
      "kind": "function",
      "pattern": "(?:function|def|fn|func|sub|proc)\\\\s+(\\\\w+)",
      "description": "Function declarations"
    },
    {
      "kind": "class",
      "pattern": "\\\\bclass\\\\s+([A-Z]\\\\w*)",
      "description": "Class declarations"
    },
    {
      "kind": "variable",
      "pattern": "(?:export|pub)\\\\s+(?:const|let|var)\\\\s+(\\\\w+)",
      "description": "Exported variables"
    },
    {
      "kind": "type",
      "pattern": "\\\\b(type|interface)\\\\s+([A-Z]\\\\w*)",
      "description": "Type/interface declarations"
    },
    {
      "kind": "constant",
      "pattern": "\\\\b(const|final|readonly)\\\\s+([A-Z_]\\\\w*)",
      "description": "Constant declarations"
    },
    {
      "kind": "enum",
      "pattern": "\\\\benum\\\\s+([A-Z]\\\\w*)",
      "description": "Enum declarations"
    },
    {
      "kind": "module",
      "pattern": "(?:module|namespace|package)\\\\s+(\\\\w+)",
      "description": "Module/namespace declarations"
    },
    {
      "kind": "interface",
      "pattern": "\\\\binterface\\\\s+([A-Z]\\\\w*)",
      "description": "Interface declarations"
    },
    {
      "kind": "method",
      "pattern": "\\\\b(public|private|protected)?\\\\s*\\\\w+\\\\s*\\\\(",
      "description": "Method declarations"
    },
    {
      "kind": "import",
      "pattern": "import\\\\s+.*?['\"]([^'\"]+)['\"]",
      "description": "Import statements for cross-file resolution"
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "USE\\s+(\\w+)",
      "FROM\\s+(\\w+)",
      "JOIN\\s+(\\w+)",
      "INTO\\s+(\\w+)",
      "REFERENCES\\s+(\\w+)"
    ],
    "exportStatements": [
      "CREATE\\s+(TABLE|VIEW|FUNCTION|PROCEDURE|TRIGGER|INDEX)\\s+(\\w+)",
      "ALTER\\s+TABLE\\s+(\\w+)"
    ],
    "reExportStatements": []
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\bDECLARE\\s+@(\\w+)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\bCREATE\\s+(TABLE|VIEW|FUNCTION|PROCEDURE)\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\bDECLARE\\s+@?(\\w+)",
        "\\bSET\\s+@?(\\w+)"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\bDECLARE\\s+@?(\\w+)"
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "INSERT",
    "UPDATE",
    "DELETE",
    "ALTER",
    "DROP",
    "TRUNCATE",
    "CREATE",
    "REPLACE",
    "MERGE",
    "SET"
  ],
  "readOperations": [
    "SELECT",
    "COUNT(",
    "SUM(",
    "AVG(",
    "MIN(",
    "MAX(",
    "EXISTS(",
    "IN (",
    "BETWEEN",
    "LIKE",
    "IS NULL",
    "COALESCE(",
    "CASE",
    "CAST(",
    "CONVERT("
  ],
  "declarationPatterns": [
    "\\b(\\w+)\\s*=",
    "\\b(var|let|const|val|def|func|fn)\\s+(\\w+)",
    "\\b(class|struct|type|interface)\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\b(\\w+)\\(",
    "\\b(\\w+)\\.",
    "new\\s+(\\w+)"
  ],
  "specialHighlights": {
    "typeReferences": true,
    "decorators": false,
    "comments": true
  }
}
