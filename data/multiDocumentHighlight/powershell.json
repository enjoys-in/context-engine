{
  "language": "powershell",
  "selector": {
    "language": "powershell",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "function",
      "pattern": "\\b(\\w+)\\s*\\(\\)",
      "importPattern": "source\\s+[\"']?[^\"']+{name}",
      "exportPattern": "(\\w+)\\s*\\(\\)",
      "highlightKind": 1,
      "description": "Function across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "variable",
      "pattern": "\\b(\\w+)=",
      "importPattern": "source\\s+",
      "exportPattern": "export\\s+{name}",
      "highlightKind": 1,
      "description": "Variable across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "alias",
      "pattern": "alias\\s+(\\w+)=",
      "importPattern": "source\\s+",
      "exportPattern": "alias\\s+{name}",
      "highlightKind": 1,
      "description": "Alias across files",
      "crossFileCapable": true
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "source\\s+([^\\s;]+)",
      "\\.\\s+([^\\s;]+)"
    ],
    "exportStatements": [
      "export\\s+(\\w+)",
      "(\\w+)\\s*\\(\\)\\s*\\{"
    ],
    "reExportStatements": []
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "export\\s+(\\w+)",
        "\\b(\\w+)="
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "local\\s+(\\w+)",
        "\\b(\\w+)="
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "export",
    "declare",
    "local",
    "readonly",
    "unset",
    "let",
    "read"
  ],
  "readOperations": [
    "echo",
    "printf",
    "cat",
    "grep",
    "awk",
    "sed",
    "cut",
    "wc",
    "sort",
    "uniq",
    "test",
    "[",
    "[[",
    "expr"
  ],
  "declarationPatterns": [
    "\\b(\\w+)=",
    "\\b(\\w+)\\(\\)",
    "local\\s+(\\w+)",
    "declare\\s+(-\\w+\\s+)?(\\w+)",
    "readonly\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\$(\\w+)",
    "\\$\\{(\\w+)",
    "\\b(\\w+)\\s",
    "\\b(\\w+)\\("
  ],
  "specialHighlights": {
    "typeReferences": {
      "pattern": "",
      "highlightKind": 0
    },
    "decorators": {
      "pattern": "",
      "highlightKind": 0
    },
    "comments": {
      "pattern": "",
      "highlightKind": 0
    }
  }
}
