{
  "language": "shell",
  "selector": {
    "language": "shell",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "function",
      "pattern": "(\\w+)\\s*\\(\\)\\s*\\{|function\\s+(\\w+)",
      "importPattern": "source\\s+.*|\\. \\s+",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Function across scripts",
      "crossFileCapable": true
    },
    {
      "symbolKind": "variable",
      "pattern": "\\b(\\w+)=",
      "importPattern": "source\\s+|\\. ",
      "exportPattern": "export\\s+{name}",
      "highlightKind": 1,
      "description": "Variable across scripts",
      "crossFileCapable": true
    },
    {
      "symbolKind": "alias",
      "pattern": "alias\\s+(\\w+)=",
      "importPattern": "source\\s+",
      "exportPattern": "alias\\s+{name}=",
      "highlightKind": 1,
      "description": "Alias across scripts",
      "crossFileCapable": true
    },
    {
      "symbolKind": "envVar",
      "pattern": "export\\s+(\\w+)",
      "importPattern": "",
      "exportPattern": "export\\s+{name}",
      "highlightKind": 2,
      "description": "Exported environment variable",
      "crossFileCapable": true
    },
    {
      "symbolKind": "command",
      "pattern": "\\b(\\w+)\\b",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Command reference",
      "crossFileCapable": false
    },
    {
      "symbolKind": "parameter",
      "pattern": "\\$\\{?(\\w+)\\}?",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Parameter/variable expansion",
      "crossFileCapable": false
    },
    {
      "symbolKind": "script",
      "pattern": "source\\s+([\\w./]+)|\\. ([\\w./]+)",
      "importPattern": "source\\s+{name}",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Sourced script reference",
      "crossFileCapable": true
    },
    {
      "kind": "function",
      "pattern": "(\\\\w+)\\\\s*\\\\(\\\\)",
      "description": "Function declarations"
    },
    {
      "kind": "class",
      "pattern": "\\\\bclass\\\\s+([A-Z]\\\\w*)",
      "description": "Class declarations"
    },
    {
      "kind": "variable",
      "pattern": "(?:export|pub)\\\\s+(?:const|let|var)\\\\s+(\\\\w+)",
      "description": "Exported variables"
    },
    {
      "kind": "type",
      "pattern": "\\\\b(type|interface)\\\\s+([A-Z]\\\\w*)",
      "description": "Type/interface declarations"
    },
    {
      "kind": "constant",
      "pattern": "\\\\b(const|final|readonly)\\\\s+([A-Z_]\\\\w*)",
      "description": "Constant declarations"
    },
    {
      "kind": "enum",
      "pattern": "\\\\benum\\\\s+([A-Z]\\\\w*)",
      "description": "Enum declarations"
    },
    {
      "kind": "module",
      "pattern": "(?:module|namespace|package)\\\\s+(\\\\w+)",
      "description": "Module/namespace declarations"
    },
    {
      "kind": "interface",
      "pattern": "\\\\binterface\\\\s+([A-Z]\\\\w*)",
      "description": "Interface declarations"
    },
    {
      "kind": "method",
      "pattern": "\\\\b(public|private|protected)?\\\\s*\\\\w+\\\\s*\\\\(",
      "description": "Method declarations"
    },
    {
      "kind": "import",
      "pattern": "import\\\\s+.*?['\"]([^'\"]+)['\"]",
      "description": "Import statements for cross-file resolution"
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "source\\s+([\\w./]+)",
      "\\.\\s+([\\w./]+)",
      "Import-Module\\s+(\\w+)",
      "using\\s+module\\s+(\\w+)"
    ],
    "exportStatements": [
      "export\\s+(\\w+)",
      "(function|filter)\\s+(\\w+)",
      "alias\\s+(\\w+)="
    ],
    "reExportStatements": []
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\bexport\\s+(\\w+)",
        "\\bENV:\\s*(\\w+)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\b(\\w+)=",
        "\\$\\{?(\\w+)\\}?"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\blocal\\s+(\\w+)",
        "\\bmy\\s+\\$(\\w+)"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\b(\\w+)\\s+in\\b"
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "export",
    "unset",
    "declare",
    "readonly",
    "local",
    "typeset",
    "let",
    "read",
    "eval"
  ],
  "readOperations": [
    "echo",
    "printf",
    "cat",
    "grep",
    "awk",
    "sed",
    "wc",
    "head",
    "tail",
    "test",
    "[ ]",
    "[[ ]]",
    "-z",
    "-n",
    "-f",
    "-d",
    "-e"
  ],
  "declarationPatterns": [
    "\\b(\\w+)\\s*=",
    "\\b(var|let|const|val|def|func|fn)\\s+(\\w+)",
    "\\b(class|struct|type|interface)\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\b(\\w+)\\(",
    "\\b(\\w+)\\.",
    "new\\s+(\\w+)"
  ],
  "specialHighlights": {
    "typeReferences": true,
    "decorators": false,
    "comments": true
  }
}
