{
  "language": "elixir",
  "selector": {
    "language": "elixir",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "module",
      "pattern": "\\bdefmodule\\s+([\\w.]+)",
      "importPattern": "alias\\s+{name}|import\\s+{name}|use\\s+{name}",
      "exportPattern": "\\bdefmodule\\s+{name}",
      "highlightKind": 1,
      "description": "Module across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "function",
      "pattern": "\\bdef\\s+(\\w+)",
      "importPattern": "import\\s+\\w+,\\s*only:\\s*\\[.*{name}",
      "exportPattern": "\\bdef\\s+{name}",
      "highlightKind": 1,
      "description": "Public function across modules",
      "crossFileCapable": true
    },
    {
      "symbolKind": "macro",
      "pattern": "\\bdefmacro\\s+(\\w+)",
      "importPattern": "import\\s+\\w+,\\s*only:\\s*\\[.*{name}",
      "exportPattern": "\\bdefmacro\\s+{name}",
      "highlightKind": 1,
      "description": "Macro across modules",
      "crossFileCapable": true
    },
    {
      "symbolKind": "protocol",
      "pattern": "\\bdefprotocol\\s+(\\w+)",
      "importPattern": "alias\\s+{name}",
      "exportPattern": "\\bdefprotocol\\s+{name}",
      "highlightKind": 1,
      "description": "Protocol across modules",
      "crossFileCapable": true
    },
    {
      "symbolKind": "behaviour",
      "pattern": "@behaviour\\s+(\\w+)",
      "importPattern": "alias\\s+{name}",
      "exportPattern": "\\bdefmodule\\s+{name}",
      "highlightKind": 1,
      "description": "Behaviour across modules",
      "crossFileCapable": true
    },
    {
      "symbolKind": "struct",
      "pattern": "\\bdefstruct\\b",
      "importPattern": "alias\\s+{name}",
      "exportPattern": "\\bdefstruct\\b",
      "highlightKind": 1,
      "description": "Struct across modules",
      "crossFileCapable": true
    },
    {
      "symbolKind": "callback",
      "pattern": "@callback\\s+(\\w+)",
      "importPattern": "",
      "exportPattern": "@callback",
      "highlightKind": 1,
      "description": "Callback specification",
      "crossFileCapable": false
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "(import|require|use|include|load|source)\\s+['\"]?([\\w./]+)['\"]?",
      "from\\s+(\\w+)\\s+import",
      "require\\s+(\\w+)"
    ],
    "exportStatements": [
      "(def|function|class|module)\\s+(\\w+)",
      "(export|public)\\s+(\\w+)"
    ],
    "reExportStatements": [
      "from\\s+(\\w+)\\s+import\\s+(.+)"
    ]
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\b(global|public)\\s+\\w+\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\b(\\w+)\\s*=",
        "(class|module|namespace)\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [
        "\\b(self|this|me)\\.(\\w+)"
      ],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\b(\\w+)\\s*=",
        "\\b(var|let|const|local)\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\b(\\w+)\\s*="
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    "++",
    "--",
    ".push(",
    ".pop(",
    ".set(",
    ".add(",
    ".remove(",
    ".delete(",
    ".clear("
  ],
  "readOperations": [
    ".length",
    ".size()",
    ".get(",
    ".contains(",
    ".indexOf(",
    ".toString(",
    ".equals(",
    ".compareTo(",
    "typeof",
    "instanceof",
    ".isEmpty()",
    ".count("
  ],
  "declarationPatterns": [
    "\\b(\\w+)\\s*=",
    "\\b(var|let|const|val|def|func|fn)\\s+(\\w+)",
    "\\b(class|struct|type|interface)\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\b(\\w+)\\(",
    "\\b(\\w+)\\.",
    "new\\s+(\\w+)"
  ],
  "specialHighlights": {
    "typeReferences": true,
    "decorators": true,
    "comments": true
  }
}
