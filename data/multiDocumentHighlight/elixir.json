{
  "language": "elixir",
  "selector": {
    "language": "elixir",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "module",
      "pattern": "\\bdefmodule\\s+(\\w+)",
      "importPattern": "\\balias\\s+{name}",
      "exportPattern": "defmodule\\s+{name}",
      "highlightKind": 1,
      "description": "Module across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "function",
      "pattern": "\\bdef\\s+(\\w+)",
      "importPattern": "import\\s+{module},\\s*only:\\s*\\[.*{name}",
      "exportPattern": "def\\s+{name}",
      "highlightKind": 1,
      "description": "Function across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "macro",
      "pattern": "\\bdefmacro\\s+(\\w+)",
      "importPattern": "import\\s+{module}",
      "exportPattern": "defmacro\\s+{name}",
      "highlightKind": 1,
      "description": "Macro across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "protocol",
      "pattern": "\\bdefprotocol\\s+(\\w+)",
      "importPattern": "\\balias\\s+{name}",
      "exportPattern": "defprotocol\\s+{name}",
      "highlightKind": 1,
      "description": "Protocol across files",
      "crossFileCapable": true
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "alias\\s+([\\w.]+)",
      "import\\s+([\\w.]+)",
      "use\\s+([\\w.]+)",
      "require\\s+([\\w.]+)"
    ],
    "exportStatements": [
      "defmodule\\s+(\\w+)",
      "def\\s+(\\w+)",
      "defmacro\\s+(\\w+)"
    ],
    "reExportStatements": [
      "defdelegate\\s+(\\w+)"
    ]
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "@(\\w+)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\bdef\\s+(\\w+)",
        "\\bdefp\\s+(\\w+)",
        "@(\\w+)"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\b(\\w+)\\s*=",
        "fn\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\b(\\w+)\\s*<-",
        "\\b(\\w+)\\s*="
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "|>",
    "put_in(",
    "Map.put(",
    "Map.delete(",
    "List.delete(",
    "List.insert_at(",
    "Keyword.put(",
    "Agent.update(",
    "GenServer.cast("
  ],
  "readOperations": [
    "Enum.",
    "Stream.",
    "Map.get(",
    "Map.fetch(",
    "Keyword.get(",
    "List.first(",
    "List.last(",
    "length(",
    "is_",
    "Enum.count(",
    "Enum.find(",
    "Enum.filter(",
    "Enum.map(",
    "Enum.reduce("
  ],
  "declarationPatterns": [
    "\\bdef\\s+(\\w+)",
    "\\bdefp\\s+(\\w+)",
    "\\bdefmodule\\s+(\\w+)",
    "\\bdefmacro\\s+(\\w+)",
    "\\b(\\w+)\\s*="
  ],
  "referencePatterns": [
    "\\b(\\w+)\\.",
    "\\b(\\w+)\\(",
    "\\b(\\w+)/\\d+",
    "&(\\w+)/\\d+"
  ],
  "specialHighlights": {
    "typeReferences": {
      "pattern": "@spec\\s+\\w+\\(([^)]+)\\)",
      "highlightKind": 1
    },
    "decorators": {
      "pattern": "@(\\w+)",
      "highlightKind": 1
    },
    "comments": {
      "pattern": "@(doc|moduledoc|typedoc)",
      "highlightKind": 0
    }
  }
}
