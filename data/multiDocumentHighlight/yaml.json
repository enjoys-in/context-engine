{
  "language": "yaml",
  "selector": {
    "language": "yaml",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "key",
      "pattern": "\\b(\\w+)\\s*[=:]",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Configuration key reference",
      "crossFileCapable": false
    },
    {
      "symbolKind": "section",
      "pattern": "\\[([\\w.]+)\\]",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Configuration section",
      "crossFileCapable": false
    },
    {
      "symbolKind": "variable",
      "pattern": "\\$\\{?(\\w+)\\}?|\\{\\{\\s*(\\w+)\\s*\\}\\}",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Variable/template reference",
      "crossFileCapable": true
    },
    {
      "symbolKind": "anchor",
      "pattern": "&(\\w+)",
      "importPattern": "\\*{name}",
      "exportPattern": "&{name}",
      "highlightKind": 1,
      "description": "YAML anchor/alias",
      "crossFileCapable": false
    },
    {
      "symbolKind": "include",
      "pattern": "(include|import|extends|source)\\s+([\\w./]+)",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Include/import reference",
      "crossFileCapable": true
    },
    {
      "symbolKind": "service",
      "pattern": "\\b(\\w+):\\s*$",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Service/block definition",
      "crossFileCapable": false
    },
    {
      "symbolKind": "reference",
      "pattern": "\\$\\w+|\\{\\{.*?\\}\\}",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Value reference",
      "crossFileCapable": false
    },
    {
      "kind": "function",
      "pattern": "(?:function|def|fn|func|sub|proc)\\\\s+(\\\\w+)",
      "description": "Function declarations"
    },
    {
      "kind": "class",
      "pattern": "\\\\bclass\\\\s+([A-Z]\\\\w*)",
      "description": "Class declarations"
    },
    {
      "kind": "variable",
      "pattern": "(?:export|pub)\\\\s+(?:const|let|var)\\\\s+(\\\\w+)",
      "description": "Exported variables"
    },
    {
      "kind": "type",
      "pattern": "\\\\b(type|interface)\\\\s+([A-Z]\\\\w*)",
      "description": "Type/interface declarations"
    },
    {
      "kind": "constant",
      "pattern": "\\\\b(const|final|readonly)\\\\s+([A-Z_]\\\\w*)",
      "description": "Constant declarations"
    },
    {
      "kind": "enum",
      "pattern": "\\\\benum\\\\s+([A-Z]\\\\w*)",
      "description": "Enum declarations"
    },
    {
      "kind": "module",
      "pattern": "(?:module|namespace|package)\\\\s+(\\\\w+)",
      "description": "Module/namespace declarations"
    },
    {
      "kind": "interface",
      "pattern": "\\\\binterface\\\\s+([A-Z]\\\\w*)",
      "description": "Interface declarations"
    },
    {
      "kind": "method",
      "pattern": "\\\\b(public|private|protected)?\\\\s*\\\\w+\\\\s*\\\\(",
      "description": "Method declarations"
    },
    {
      "kind": "import",
      "pattern": "import\\\\s+.*?['\"]([^'\"]+)['\"]",
      "description": "Import statements for cross-file resolution"
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "(import|include|require|use|load)\\s+['\"]?([\\w./]+)['\"]?",
      "(import|include|require|use|load|source)\\s+['\"]?([\\w./\\-]+)['\"]?",
      "from\\s+([\\w./]+)\\s+import",
      "#include\\s+[<\"]([^>\"]+)[>\"]"
    ],
    "exportStatements": [
      "(export|public|pub)\\s+(\\w+)\\s+(\\w+)",
      "(export|public|pub)\\s+(class|struct|function|fn|def|const|var|type)\\s+(\\w+)",
      "module\\.exports\\s*="
    ],
    "reExportStatements": [
      "(export|pub)\\s+(use|import|from)\\s+"
    ]
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\b(\\w+)\\s*[=:]"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\[[\\w.]+\\]",
        "\\b(\\w+)\\s*:"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [
        "\\b(class|struct|type|interface)\\s+(\\w+)",
        "\\b(self|this|me)\\.(\\w+)"
      ],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\b(var|let|const|local|my|dim)\\s+(\\w+)",
        "\\b(def|function|fn|func|proc|sub)\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\b(\\w+)\\s*=(?!=)"
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    "++",
    "--",
    ".push(",
    ".pop(",
    ".set(",
    ".add(",
    ".remove(",
    ".delete(",
    ".clear("
  ],
  "readOperations": [
    ".length",
    ".size()",
    ".get(",
    ".contains(",
    ".indexOf(",
    ".toString(",
    ".equals(",
    ".compareTo(",
    "typeof",
    "instanceof",
    ".isEmpty()",
    ".count("
  ],
  "declarationPatterns": [
    "\\b(\\w+)\\s*=",
    "\\b(var|let|const|val|def|func|fn)\\s+(\\w+)",
    "\\b(class|struct|type|interface)\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\b(\\w+)\\(",
    "\\b(\\w+)\\.",
    "new\\s+(\\w+)"
  ],
  "specialHighlights": {
    "typeReferences": true,
    "decorators": false,
    "comments": true
  }
}
