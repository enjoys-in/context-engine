{
  "language": "cpp",
  "selector": {
    "language": "cpp",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "function",
      "pattern": "\\b(function|func|fn|def|void|int|char|bool|float|double|string|auto)\\s+(\\w+)\\s*\\(",
      "importPattern": "#include\\s+[<\"][^>\"]*{name}",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Function declaration across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "class",
      "pattern": "\\b(class|struct)\\s+(\\w+)",
      "importPattern": "#include\\s+[<\"][^>\"]*{name}",
      "exportPattern": "\\bclass\\s+{name}",
      "highlightKind": 1,
      "description": "Class/struct across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "enum",
      "pattern": "\\benum\\s+(class\\s+)?(\\w+)",
      "importPattern": "#include\\s+[<\"]",
      "exportPattern": "\\benum\\s+{name}",
      "highlightKind": 1,
      "description": "Enum across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "interface",
      "pattern": "\\binterface\\s+(\\w+)",
      "importPattern": "",
      "exportPattern": "\\binterface\\s+{name}",
      "highlightKind": 1,
      "description": "Interface across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "constant",
      "pattern": "\\b(const|#define|static\\s+final)\\s+(\\w+)",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Constant declaration",
      "crossFileCapable": false
    },
    {
      "symbolKind": "typedef",
      "pattern": "\\b(typedef|type|typealias)\\s+",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Type definition",
      "crossFileCapable": false
    },
    {
      "symbolKind": "namespace",
      "pattern": "\\b(namespace|package|module)\\s+([\\w.]+)",
      "importPattern": "(import|using|use)\\s+",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Namespace/package reference",
      "crossFileCapable": true
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "#include\\s+[<\"]([^>\"]+)[>\"]",
      "import\\s+([\\w.]+)",
      "using\\s+([\\w.]+)",
      "require\\s+([\\w.]+)"
    ],
    "exportStatements": [
      "(public|export)\\s+(class|struct|function|fn|func|def)\\s+(\\w+)",
      "module\\.exports"
    ],
    "reExportStatements": [
      "(export|pub)\\s+(use|import)\\s+"
    ]
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\b(global|public)\\s+\\w+\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\b(\\w+)\\s*=",
        "(class|module|namespace)\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [
        "\\b(self|this|me)\\.(\\w+)"
      ],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\b(\\w+)\\s*=",
        "\\b(var|let|const|local)\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\b(\\w+)\\s*="
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    "**=",
    "<<=",
    ">>=",
    "&=",
    "^=",
    "|=",
    "&&=",
    "||=",
    "??=",
    "++",
    "--",
    "delete",
    ".push(",
    ".pop(",
    ".shift(",
    ".splice(",
    ".sort(",
    ".reverse(",
    ".fill("
  ],
  "readOperations": [
    ".length",
    ".indexOf(",
    ".includes(",
    ".find(",
    ".filter(",
    ".map(",
    ".reduce(",
    ".some(",
    ".every(",
    ".forEach(",
    ".keys(",
    ".values(",
    ".entries(",
    ".slice(",
    ".concat(",
    ".join(",
    ".toString(",
    ".valueOf(",
    "JSON.stringify(",
    "JSON.parse(",
    "typeof",
    "instanceof",
    "in"
  ],
  "declarationPatterns": [
    "\\b(\\w+)\\s*=",
    "\\b(var|let|const|val|def|func|fn)\\s+(\\w+)",
    "\\b(class|struct|type|interface)\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\b(\\w+)\\(",
    "\\b(\\w+)\\.",
    "new\\s+(\\w+)"
  ],
  "specialHighlights": {
    "typeReferences": true,
    "decorators": true,
    "comments": true
  }
}
