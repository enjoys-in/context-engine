{
  "language": "java",
  "selector": {
    "language": "java",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "class",
      "pattern": "\\bclass\\s+(\\w+)",
      "importPattern": "import\\s+[\\w.]+\\.{name};",
      "exportPattern": "public\\s+class\\s+{name}",
      "highlightKind": 1,
      "description": "Class across packages",
      "crossFileCapable": true
    },
    {
      "symbolKind": "interface",
      "pattern": "\\binterface\\s+(\\w+)",
      "importPattern": "import\\s+[\\w.]+\\.{name};",
      "exportPattern": "public\\s+interface\\s+{name}",
      "highlightKind": 1,
      "description": "Interface across packages",
      "crossFileCapable": true
    },
    {
      "symbolKind": "enum",
      "pattern": "\\benum\\s+(\\w+)",
      "importPattern": "import\\s+[\\w.]+\\.{name};",
      "exportPattern": "public\\s+enum\\s+{name}",
      "highlightKind": 1,
      "description": "Enum across packages",
      "crossFileCapable": true
    },
    {
      "symbolKind": "annotation",
      "pattern": "@(\\w+)",
      "importPattern": "import\\s+[\\w.]+\\.{name};",
      "exportPattern": "public\\s+@interface\\s+{name}",
      "highlightKind": 1,
      "description": "Annotation across packages",
      "crossFileCapable": true
    },
    {
      "symbolKind": "method",
      "pattern": "\\b(public|private|protected)\\s+\\S+\\s+(\\w+)\\(",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Method declaration",
      "crossFileCapable": false
    },
    {
      "symbolKind": "constant",
      "pattern": "\\bstatic\\s+final\\s+\\S+\\s+(\\w+)",
      "importPattern": "import\\s+static\\s+[\\w.]+\\.{name};",
      "exportPattern": "public\\s+static\\s+final",
      "highlightKind": 1,
      "description": "Static constant",
      "crossFileCapable": true
    },
    {
      "symbolKind": "package",
      "pattern": "package\\s+([\\w.]+)",
      "importPattern": "import\\s+{name}\\.",
      "exportPattern": "package\\s+{name}",
      "highlightKind": 1,
      "description": "Package reference",
      "crossFileCapable": true
    },
    {
      "kind": "function",
      "pattern": "(?:public|private|protected)?\\\\s*\\\\w+\\\\s+(\\\\w+)\\\\s*\\\\(",
      "description": "Function declarations"
    },
    {
      "kind": "class",
      "pattern": "\\\\bclass\\\\s+([A-Z]\\\\w*)",
      "description": "Class declarations"
    },
    {
      "kind": "variable",
      "pattern": "(?:export|pub)\\\\s+(?:const|let|var)\\\\s+(\\\\w+)",
      "description": "Exported variables"
    },
    {
      "kind": "type",
      "pattern": "\\\\b(type|interface)\\\\s+([A-Z]\\\\w*)",
      "description": "Type/interface declarations"
    },
    {
      "kind": "constant",
      "pattern": "\\\\b(const|final|readonly)\\\\s+([A-Z_]\\\\w*)",
      "description": "Constant declarations"
    },
    {
      "kind": "enum",
      "pattern": "\\\\benum\\\\s+([A-Z]\\\\w*)",
      "description": "Enum declarations"
    },
    {
      "kind": "module",
      "pattern": "(?:module|namespace|package)\\\\s+(\\\\w+)",
      "description": "Module/namespace declarations"
    },
    {
      "kind": "interface",
      "pattern": "\\\\binterface\\\\s+([A-Z]\\\\w*)",
      "description": "Interface declarations"
    },
    {
      "kind": "method",
      "pattern": "\\\\b(public|private|protected)?\\\\s*\\\\w+\\\\s*\\\\(",
      "description": "Method declarations"
    },
    {
      "kind": "import",
      "pattern": "import\\\\s+.*?['\"]([^'\"]+)['\"]",
      "description": "Import statements for cross-file resolution"
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "import\\s+([\\w.]+);",
      "import\\s+static\\s+([\\w.]+);",
      "import\\s+([\\w.]+)\\.\\*;"
    ],
    "exportStatements": [
      "public\\s+(class|interface|enum|@interface|record)\\s+(\\w+)",
      "public\\s+static\\s+(\\w+)\\s+(\\w+)",
      "package\\s+([\\w.]+);"
    ],
    "reExportStatements": []
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\bstatic\\s+.*\\b(\\w+)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\bpackage\\s+([\\w.]+)",
        "\\b(public|protected|private)\\s+\\w+\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [
        "\\bthis\\.(\\w+)",
        "\\bstatic\\s+(\\w+)",
        "\\bsuper\\.(\\w+)"
      ],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\b(\\w+)\\s+(\\w+)\\s*=",
        "\\b(\\w+)\\s+(\\w+)\\s*;"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\b(final\\s+)?\\w+\\s+(\\w+)\\s*="
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    "**=",
    "<<=",
    ">>=",
    "&=",
    "^=",
    "|=",
    "&&=",
    "||=",
    "??=",
    "++",
    "--",
    "delete",
    ".push(",
    ".pop(",
    ".shift(",
    ".splice(",
    ".sort(",
    ".reverse(",
    ".fill("
  ],
  "readOperations": [
    ".length",
    ".indexOf(",
    ".includes(",
    ".find(",
    ".filter(",
    ".map(",
    ".reduce(",
    ".some(",
    ".every(",
    ".forEach(",
    ".keys(",
    ".values(",
    ".entries(",
    ".slice(",
    ".concat(",
    ".join(",
    ".toString(",
    ".valueOf(",
    "JSON.stringify(",
    "JSON.parse(",
    "typeof",
    "instanceof",
    "in"
  ],
  "declarationPatterns": [
    "(public|private|protected)\\s+.*\\s+(\\w+)\\s*[=(;]",
    "\\bclass\\s+(\\w+)",
    "\\binterface\\s+(\\w+)",
    "\\benum\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\b(\\w+)\\(",
    "new\\s+(\\w+)",
    "extends\\s+(\\w+)",
    "implements\\s+(\\w+)",
    "@(\\w+)"
  ],
  "specialHighlights": {
    "typeReferences": true,
    "decorators": true,
    "comments": true
  }
}
