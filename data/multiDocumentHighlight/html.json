{
  "language": "html",
  "selector": {
    "language": "html",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "element",
      "pattern": "<([a-zA-Z][\\w-]*)",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Element tag reference",
      "crossFileCapable": false
    },
    {
      "symbolKind": "id",
      "pattern": "id=[\"']([\\w-]+)[\"']",
      "importPattern": "#\\{name\\}",
      "exportPattern": "id=",
      "highlightKind": 1,
      "description": "ID reference across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "class",
      "pattern": "class=[\"']([\\w\\s-]+)[\"']",
      "importPattern": "\\.{name}",
      "exportPattern": "class=",
      "highlightKind": 1,
      "description": "CSS class reference",
      "crossFileCapable": true
    },
    {
      "symbolKind": "component",
      "pattern": "<([A-Z][\\w]*)",
      "importPattern": "(import|require)\\s+.*{name}",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Component reference",
      "crossFileCapable": true
    },
    {
      "symbolKind": "link",
      "pattern": "(href|src)=[\"']([^\"']+)[\"']",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Link/source reference",
      "crossFileCapable": true
    },
    {
      "symbolKind": "template",
      "pattern": "\\{\\{\\s*(\\w+)\\s*\\}\\}",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Template variable",
      "crossFileCapable": false
    },
    {
      "symbolKind": "slot",
      "pattern": "slot=[\"']([\\w-]+)[\"']|<slot\\s+name=[\"']([\\w-]+)[\"']",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Slot reference",
      "crossFileCapable": true
    },
    {
      "kind": "function",
      "pattern": "(?:function|def|fn|func|sub|proc)\\\\s+(\\\\w+)",
      "description": "Function declarations"
    },
    {
      "kind": "class",
      "pattern": "\\\\bclass\\\\s+([A-Z]\\\\w*)",
      "description": "Class declarations"
    },
    {
      "kind": "variable",
      "pattern": "(?:export|pub)\\\\s+(?:const|let|var)\\\\s+(\\\\w+)",
      "description": "Exported variables"
    },
    {
      "kind": "type",
      "pattern": "\\\\b(type|interface)\\\\s+([A-Z]\\\\w*)",
      "description": "Type/interface declarations"
    },
    {
      "kind": "constant",
      "pattern": "\\\\b(const|final|readonly)\\\\s+([A-Z_]\\\\w*)",
      "description": "Constant declarations"
    },
    {
      "kind": "enum",
      "pattern": "\\\\benum\\\\s+([A-Z]\\\\w*)",
      "description": "Enum declarations"
    },
    {
      "kind": "module",
      "pattern": "(?:module|namespace|package)\\\\s+(\\\\w+)",
      "description": "Module/namespace declarations"
    },
    {
      "kind": "interface",
      "pattern": "\\\\binterface\\\\s+([A-Z]\\\\w*)",
      "description": "Interface declarations"
    },
    {
      "kind": "method",
      "pattern": "\\\\b(public|private|protected)?\\\\s*\\\\w+\\\\s*\\\\(",
      "description": "Method declarations"
    },
    {
      "kind": "import",
      "pattern": "import\\\\s+.*?['\"]([^'\"]+)['\"]",
      "description": "Import statements for cross-file resolution"
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "(import|include|require|use|load)\\s+['\"]?([\\w./]+)['\"]?",
      "(import|include|require|use|load|source)\\s+['\"]?([\\w./\\-]+)['\"]?",
      "from\\s+([\\w./]+)\\s+import",
      "#include\\s+[<\"]([^>\"]+)[>\"]"
    ],
    "exportStatements": [
      "(export|public|pub)\\s+(\\w+)\\s+(\\w+)",
      "(export|public|pub)\\s+(class|struct|function|fn|def|const|var|type)\\s+(\\w+)",
      "module\\.exports\\s*="
    ],
    "reExportStatements": [
      "(export|pub)\\s+(use|import|from)\\s+"
    ]
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\bwindow\\.(\\w+)",
        "\\bglobalThis\\.(\\w+)",
        "\\bglobal\\.(\\w+)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\bexport\\s+(const|let|var|function|class)\\s+(\\w+)",
        "module\\.exports"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [
        "\\bthis\\.(\\w+)",
        "\\bstatic\\s+(\\w+)",
        "#(\\w+)"
      ],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\b(const|let|var)\\s+(\\w+)",
        "\\bfunction\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\b(const|let)\\s+(\\w+)"
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    "**=",
    "<<=",
    ">>=",
    "&=",
    "^=",
    "|=",
    "&&=",
    "||=",
    "??=",
    "++",
    "--",
    "delete",
    ".push(",
    ".pop(",
    ".shift(",
    ".splice(",
    ".sort(",
    ".reverse(",
    ".fill("
  ],
  "readOperations": [
    ".length",
    ".indexOf(",
    ".includes(",
    ".find(",
    ".filter(",
    ".map(",
    ".reduce(",
    ".some(",
    ".every(",
    ".forEach(",
    ".keys(",
    ".values(",
    ".entries(",
    ".slice(",
    ".concat(",
    ".join(",
    ".toString(",
    ".valueOf(",
    "JSON.stringify(",
    "JSON.parse(",
    "typeof",
    "instanceof",
    "in"
  ],
  "declarationPatterns": [
    "\\b(const|let|var)\\s+(\\w+)",
    "\\bfunction\\s+(\\w+)",
    "\\bclass\\s+(\\w+)",
    "interface\\s+(\\w+)",
    "type\\s+(\\w+)",
    "enum\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\b(\\w+)\\(",
    "\\b(\\w+)\\s*\\.",
    "new\\s+(\\w+)",
    "extends\\s+(\\w+)",
    "implements\\s+(\\w+)"
  ],
  "specialHighlights": {
    "typeReferences": true,
    "decorators": true,
    "comments": true
  }
}
