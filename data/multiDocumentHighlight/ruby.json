{
  "language": "ruby",
  "selector": {
    "language": "ruby",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "class",
      "pattern": "\\bclass\\s+(\\w+)",
      "importPattern": "require\\s+['\"][^'\"]*{name}",
      "exportPattern": "\\bclass\\s+{name}",
      "highlightKind": 1,
      "description": "Class across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "module",
      "pattern": "\\bmodule\\s+(\\w+)",
      "importPattern": "require\\s+['\"][^'\"]*{name}",
      "exportPattern": "\\bmodule\\s+{name}",
      "highlightKind": 1,
      "description": "Module across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "method",
      "pattern": "\\bdef\\s+(\\w+[!?]?)",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Method definition",
      "crossFileCapable": false
    },
    {
      "symbolKind": "constant",
      "pattern": "\\b([A-Z][A-Z0-9_]+)\\s*=",
      "importPattern": "require\\s+",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Constant reference",
      "crossFileCapable": true
    },
    {
      "symbolKind": "symbol",
      "pattern": ":(\\w+)",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Symbol reference",
      "crossFileCapable": false
    },
    {
      "symbolKind": "attribute",
      "pattern": "attr_(reader|writer|accessor)\\s+:(\\w+)",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Attribute accessor",
      "crossFileCapable": false
    },
    {
      "symbolKind": "mixin",
      "pattern": "(include|extend|prepend)\\s+(\\w+)",
      "importPattern": "require\\s+",
      "exportPattern": "\\bmodule\\s+{name}",
      "highlightKind": 1,
      "description": "Mixin across files",
      "crossFileCapable": true
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "require\\s+['\"]([^'\"]+)['\"]",
      "require_relative\\s+['\"]([^'\"]+)['\"]",
      "load\\s+['\"]([^'\"]+)['\"]",
      "autoload\\s+:(\\w+)",
      "include\\s+(\\w+)",
      "extend\\s+(\\w+)"
    ],
    "exportStatements": [
      "\\b(class|module)\\s+(\\w+)",
      "attr_(reader|writer|accessor)\\s+:(\\w+)"
    ],
    "reExportStatements": []
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\$\\w+"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\b(class|module)\\s+(\\w+)",
        "attr_(reader|writer|accessor)\\s+"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [
        "@\\w+",
        "@@\\w+"
      ],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\b(\\w+)\\s*="
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\|([\\w,\\s]+)\\|"
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    "**=",
    "||=",
    "&&=",
    "<<=",
    ".push(",
    ".pop(",
    ".shift(",
    ".unshift(",
    ".delete(",
    ".clear",
    ".sort!",
    ".reverse!",
    ".map!",
    ".select!",
    ".reject!",
    ".compact!",
    ".flatten!",
    ".uniq!"
  ],
  "readOperations": [
    ".length",
    ".size",
    ".count",
    ".include?(",
    ".index(",
    ".find(",
    ".select(",
    ".reject(",
    ".map(",
    ".each(",
    ".reduce(",
    ".any?(",
    ".all?(",
    ".none?(",
    ".min",
    ".max",
    ".sum",
    ".sort",
    ".reverse",
    ".flatten",
    ".compact",
    ".uniq",
    ".first"
  ],
  "declarationPatterns": [
    "\\b(\\w+)\\s*=",
    "\\b(var|let|const|val|def|func|fn)\\s+(\\w+)",
    "\\b(class|struct|type|interface)\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\b(\\w+)\\(",
    "\\b(\\w+)\\.",
    "new\\s+(\\w+)"
  ],
  "specialHighlights": {
    "typeReferences": true,
    "decorators": true,
    "comments": true
  }
}
