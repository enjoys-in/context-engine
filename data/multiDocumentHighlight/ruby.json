{
  "language": "ruby",
  "selector": {
    "language": "ruby",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "class",
      "pattern": "\\bclass\\s+(\\w+)",
      "importPattern": "require(_relative)?\\s+['\"][^'\"]*{name}",
      "exportPattern": "class\\s+{name}",
      "highlightKind": 1,
      "description": "Class across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "module",
      "pattern": "\\bmodule\\s+(\\w+)",
      "importPattern": "require\\s+['\"][^'\"]*{name}",
      "exportPattern": "module\\s+{name}",
      "highlightKind": 1,
      "description": "Module across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "method",
      "pattern": "\\bdef\\s+(\\w+)",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Method reference across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "constant",
      "pattern": "\\b([A-Z][A-Z0-9_]+)\\s*=",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Constant across files",
      "crossFileCapable": true
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "require\\s+['\"]([^'\"]+)['\"]",
      "require_relative\\s+['\"]([^'\"]+)['\"]",
      "include\\s+(\\w+)",
      "extend\\s+(\\w+)",
      "prepend\\s+(\\w+)",
      "autoload\\s+:(\\w+)\\s*,\\s*['\"]([^'\"]+)['\"]"
    ],
    "exportStatements": [
      "\\bclass\\s+(\\w+)",
      "\\bmodule\\s+(\\w+)",
      "\\bdef\\s+(\\w+)",
      "\\b([A-Z][A-Z_]+)\\s*="
    ],
    "reExportStatements": []
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\$\\w+"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\bmodule\\s+(\\w+)",
        "\\bclass\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [
        "@\\w+",
        "@@\\w+",
        "\\bself\\.(\\w+)"
      ],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\b(\\w+)\\s*=",
        "\\|([^|]+)\\|"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\|([^|]+)\\|",
        "\\bdo\\b"
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    "**=",
    "&=",
    "|=",
    "^=",
    "<<=",
    ">>=",
    "||=",
    "&&=",
    ".push(",
    ".pop",
    ".shift",
    ".unshift",
    ".delete(",
    ".clear",
    ".sort!",
    ".reverse!",
    ".map!",
    ".select!",
    ".reject!",
    ".compact!",
    ".flatten!",
    ".uniq!"
  ],
  "readOperations": [
    ".length",
    ".size",
    ".count",
    ".include?(",
    ".empty?",
    ".nil?",
    ".any?",
    ".all?",
    ".each",
    ".map",
    ".select",
    ".find",
    ".first",
    ".last",
    ".index(",
    ".key?(",
    ".value?(",
    ".to_s",
    ".to_i",
    ".to_f",
    ".class",
    ".is_a?(",
    ".respond_to?(",
    ".frozen?"
  ],
  "declarationPatterns": [
    "\\bdef\\s+(\\w+)",
    "\\bclass\\s+(\\w+)",
    "\\bmodule\\s+(\\w+)",
    "\\b(\\w+)\\s*=",
    "@(\\w+)",
    "@@(\\w+)",
    "\\$(\\w+)"
  ],
  "referencePatterns": [
    "\\b(\\w+)\\.",
    "\\b(\\w+)\\s*\\(",
    "\\b(\\w+)::",
    ":(\\w+)"
  ],
  "specialHighlights": {
    "typeReferences": {
      "pattern": "\\b([A-Z]\\w+)",
      "highlightKind": 1
    },
    "decorators": {
      "pattern": "",
      "highlightKind": 0
    },
    "comments": {
      "pattern": "@(param|return|type)\\s+(\\w+)",
      "highlightKind": 0
    }
  }
}
