{
  "language": "ecl",
  "selector": {
    "language": "ecl",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "type",
      "pattern": "\\b(class|struct|type|interface|module)\\s+(\\w+)",
      "importPattern": "(import|use|require|include)\\s+.*{name}",
      "exportPattern": "(export|public|pub)\\s+",
      "highlightKind": 1,
      "description": "Type across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "function",
      "pattern": "\\b(function|func|def|fn|sub|proc)\\s+(\\w+)",
      "importPattern": "(import|use|require|include)\\s+",
      "exportPattern": "(export|public|pub)\\s+",
      "highlightKind": 1,
      "description": "Function across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "variable",
      "pattern": "\\b(var|let|const|val|my|local)\\s+(\\w+)",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Variable reference",
      "crossFileCapable": false
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "(import|use|require|include|from)\\s+([\\w./]+)"
    ],
    "exportStatements": [
      "(export|public|pub)\\s+(\\w+)\\s+(\\w+)"
    ],
    "reExportStatements": []
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\b(global|public)\\s+\\w+\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\b(\\w+)\\s*="
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\b(\\w+)\\s*="
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/="
  ],
  "readOperations": [
    ".",
    "("
  ],
  "declarationPatterns": [
    "\\b(\\w+)\\s*=",
    "\\b(class|struct|type|function|def|fn|sub)\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\b(\\w+)\\.",
    "\\b(\\w+)\\("
  ],
  "specialHighlights": {
    "typeReferences": {
      "pattern": "",
      "highlightKind": 1
    },
    "decorators": {
      "pattern": "",
      "highlightKind": 0
    },
    "comments": {
      "pattern": "",
      "highlightKind": 0
    }
  }
}
