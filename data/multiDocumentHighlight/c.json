{
  "language": "c",
  "selector": {
    "language": "c",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "function",
      "pattern": "\\b(\\w+)\\s*\\([^)]*\\)\\s*\\{",
      "importPattern": "#include\\s+[<\"]([^>\"]+)[>\"]",
      "exportPattern": "extern\\s+\\w+\\s+{name}",
      "highlightKind": 1,
      "description": "Function across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "struct",
      "pattern": "\\bstruct\\s+(\\w+)",
      "importPattern": "#include\\s+[<\"]([^>\"]+)[>\"]",
      "exportPattern": "struct\\s+{name}",
      "highlightKind": 1,
      "description": "Struct across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "typedef",
      "pattern": "\\btypedef\\s+.+\\s+(\\w+)\\s*;",
      "importPattern": "#include\\s+[<\"]([^>\"]+)[>\"]",
      "exportPattern": "typedef\\s+",
      "highlightKind": 1,
      "description": "Typedef across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "macro",
      "pattern": "#define\\s+(\\w+)",
      "importPattern": "#include\\s+[<\"]([^>\"]+)[>\"]",
      "exportPattern": "#define\\s+{name}",
      "highlightKind": 1,
      "description": "Macro across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "enum",
      "pattern": "\\benum\\s+(\\w+)",
      "importPattern": "#include\\s+[<\"]([^>\"]+)[>\"]",
      "exportPattern": "enum\\s+{name}",
      "highlightKind": 1,
      "description": "Enum across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "externVariable",
      "pattern": "\\bextern\\s+\\w+\\s+(\\w+)",
      "importPattern": "#include\\s+[<\"]([^>\"]+)[>\"]",
      "exportPattern": "extern\\s+",
      "highlightKind": 1,
      "description": "Extern variable across files",
      "crossFileCapable": true
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "#include\\s+<([^>]+)>",
      "#include\\s+\"([^\"]+)\""
    ],
    "exportStatements": [
      "extern\\s+\\w+\\s+(\\w+)",
      "#define\\s+(\\w+)",
      "typedef\\s+.+\\s+(\\w+)"
    ],
    "reExportStatements": []
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\bextern\\s+\\w+\\s+(\\w+)",
        "#define\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\bstatic\\s+\\w+\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\b\\w+\\s+(\\w+)\\s*=",
        "\\bfor\\s*\\(\\w+\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\b\\w+\\s+(\\w+)\\s*="
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    "&=",
    "|=",
    "^=",
    "<<=",
    ">>=",
    "++",
    "--",
    "malloc(",
    "calloc(",
    "realloc(",
    "free(",
    "memcpy(",
    "memmove(",
    "memset(",
    "strcpy(",
    "strncpy(",
    "strcat("
  ],
  "readOperations": [
    "sizeof(",
    "strlen(",
    "strcmp(",
    "strncmp(",
    "memcmp(",
    "printf(",
    "fprintf(",
    "sprintf(",
    "scanf(",
    "fread(",
    "fwrite(",
    "fopen(",
    "fclose("
  ],
  "declarationPatterns": [
    "\\b\\w+\\s+(\\w+)\\s*=",
    "\\b\\w+\\s+(\\w+)\\s*;",
    "\\b\\w+\\s+(\\w+)\\s*\\(",
    "struct\\s+(\\w+)",
    "enum\\s+(\\w+)",
    "union\\s+(\\w+)",
    "typedef\\s+.+\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\b(\\w+)\\(",
    "\\b(\\w+)\\.",
    "\\b(\\w+)->"
  ],
  "specialHighlights": {
    "typeReferences": {
      "pattern": "\\b(\\w+)\\s+\\w+\\s*[=;(]",
      "highlightKind": 1
    },
    "decorators": {
      "pattern": "",
      "highlightKind": 0
    },
    "comments": {
      "pattern": "@(param|return|brief)\\s+(\\w+)",
      "highlightKind": 0
    }
  }
}
