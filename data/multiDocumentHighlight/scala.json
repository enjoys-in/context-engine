{
  "language": "scala",
  "selector": {
    "language": "scala",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "class",
      "pattern": "\\bclass\\s+(\\w+)",
      "importPattern": "import\\s+[\\w.]+\\.{name}",
      "exportPattern": "public\\s+class\\s+{name}",
      "highlightKind": 1,
      "description": "Class across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "interface",
      "pattern": "\\binterface\\s+(\\w+)",
      "importPattern": "import\\s+[\\w.]+\\.{name}",
      "exportPattern": "public\\s+interface\\s+{name}",
      "highlightKind": 1,
      "description": "Interface across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "enum",
      "pattern": "\\benum\\s+(\\w+)",
      "importPattern": "import\\s+[\\w.]+\\.{name}",
      "exportPattern": "public\\s+enum\\s+{name}",
      "highlightKind": 1,
      "description": "Enum across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "annotation",
      "pattern": "@interface\\s+(\\w+)",
      "importPattern": "import\\s+[\\w.]+\\.{name}",
      "exportPattern": "public\\s+@interface\\s+{name}",
      "highlightKind": 1,
      "description": "Annotation across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "method",
      "pattern": "\\b(public|protected|private)?\\s*\\w+\\s+(\\w+)\\s*\\(",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Method reference across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "staticImport",
      "pattern": "import\\s+static\\s+([\\w.]+)",
      "importPattern": "import\\s+static\\s+{name}",
      "exportPattern": "public\\s+static",
      "highlightKind": 1,
      "description": "Static import across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "object",
      "pattern": "\\bobject\\s+(\\w+)",
      "importPattern": "import\\s+[\\w.]+\\.{name}",
      "exportPattern": "object\\s+{name}",
      "highlightKind": 1,
      "description": "Object across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "trait",
      "pattern": "\\btrait\\s+(\\w+)",
      "importPattern": "import\\s+[\\w.]+\\.{name}",
      "exportPattern": "trait\\s+{name}",
      "highlightKind": 1,
      "description": "Trait across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "caseClass",
      "pattern": "\\bcase\\s+class\\s+(\\w+)",
      "importPattern": "import\\s+[\\w.]+\\.{name}",
      "exportPattern": "case\\s+class\\s+{name}",
      "highlightKind": 1,
      "description": "Case class across files",
      "crossFileCapable": true
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "import\\s+([\\w.*]+)",
      "import\\s+static\\s+([\\w.*]+)"
    ],
    "exportStatements": [
      "public\\s+(class|interface|enum|@interface|record)\\s+(\\w+)"
    ],
    "reExportStatements": []
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "public\\s+static\\s+.+\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "package\\s+([\\w.]+)"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [
        "\\bthis\\.(\\w+)",
        "\\bsuper\\.(\\w+)",
        "(private|protected|public)\\s+\\w+\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\b(\\w+)\\s+(\\w+)\\s*=",
        "\\bfor\\s*\\(\\w+\\s+(\\w+)",
        "catch\\s*\\(\\w+\\s+(\\w+)\\)"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\bvar\\s+(\\w+)",
        "\\bfinal\\s+\\w+\\s+(\\w+)"
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    "&=",
    "|=",
    "^=",
    "<<=",
    ">>=",
    ">>>=",
    "++",
    "--",
    ".set(",
    ".put(",
    ".add(",
    ".remove(",
    ".clear(",
    ".sort(",
    ".addAll(",
    ".removeAll(",
    ".replaceAll("
  ],
  "readOperations": [
    ".get(",
    ".size(",
    ".isEmpty(",
    ".contains(",
    ".indexOf(",
    ".containsKey(",
    ".containsValue(",
    ".keySet(",
    ".values(",
    ".entrySet(",
    ".stream(",
    ".iterator(",
    ".toString(",
    ".hashCode(",
    ".equals(",
    "instanceof"
  ],
  "declarationPatterns": [
    "\\b(\\w+)\\s+(\\w+)\\s*=",
    "\\b(\\w+)\\s+(\\w+)\\s*;",
    "\\b(\\w+)\\s+(\\w+)\\s*\\("
  ],
  "referencePatterns": [
    "\\b(\\w+)\\.",
    "\\bnew\\s+(\\w+)",
    "\\bextends\\s+(\\w+)",
    "\\bimplements\\s+(\\w+)",
    "\\bthrows\\s+(\\w+)",
    "@(\\w+)"
  ],
  "specialHighlights": {
    "typeReferences": {
      "pattern": "\\b([A-Z]\\w+)(?:<|\\s)",
      "highlightKind": 1
    },
    "decorators": {
      "pattern": "@(\\w+)",
      "highlightKind": 1
    },
    "comments": {
      "pattern": "@(param|return|throws)\\s+(\\w+)",
      "highlightKind": 0
    }
  }
}
