{
  "language": "scala",
  "selector": {
    "language": "scala",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "class",
      "pattern": "\\bclass\\s+(\\w+)",
      "importPattern": "import\\s+[\\w.]+\\.{name}",
      "exportPattern": "\\bclass\\s+{name}",
      "highlightKind": 1,
      "description": "Class across packages",
      "crossFileCapable": true
    },
    {
      "symbolKind": "object",
      "pattern": "\\bobject\\s+(\\w+)",
      "importPattern": "import\\s+[\\w.]+\\.{name}",
      "exportPattern": "\\bobject\\s+{name}",
      "highlightKind": 1,
      "description": "Object across packages",
      "crossFileCapable": true
    },
    {
      "symbolKind": "trait",
      "pattern": "\\btrait\\s+(\\w+)",
      "importPattern": "import\\s+[\\w.]+\\.{name}",
      "exportPattern": "\\btrait\\s+{name}",
      "highlightKind": 1,
      "description": "Trait across packages",
      "crossFileCapable": true
    },
    {
      "symbolKind": "function",
      "pattern": "\\bdef\\s+(\\w+)",
      "importPattern": "import\\s+[\\w.]+\\.{name}",
      "exportPattern": "\\bdef\\s+{name}",
      "highlightKind": 1,
      "description": "Method across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "type",
      "pattern": "\\btype\\s+(\\w+)",
      "importPattern": "import\\s+[\\w.]+\\.{name}",
      "exportPattern": "\\btype\\s+{name}",
      "highlightKind": 1,
      "description": "Type member across packages",
      "crossFileCapable": true
    },
    {
      "symbolKind": "enum",
      "pattern": "\\benum\\s+(\\w+)",
      "importPattern": "import\\s+[\\w.]+\\.{name}",
      "exportPattern": "\\benum\\s+{name}",
      "highlightKind": 1,
      "description": "Enum across packages",
      "crossFileCapable": true
    },
    {
      "symbolKind": "given",
      "pattern": "\\bgiven\\s+(\\w+)",
      "importPattern": "import\\s+[\\w.]+\\.{name}",
      "exportPattern": "\\bgiven\\s+{name}",
      "highlightKind": 1,
      "description": "Given instance across packages",
      "crossFileCapable": true
    },
    {
      "kind": "function",
      "pattern": "(?:function|def|fn|func|sub|proc)\\\\s+(\\\\w+)",
      "description": "Function declarations"
    },
    {
      "kind": "class",
      "pattern": "\\\\bclass\\\\s+([A-Z]\\\\w*)",
      "description": "Class declarations"
    },
    {
      "kind": "variable",
      "pattern": "(?:export|pub)\\\\s+(?:const|let|var)\\\\s+(\\\\w+)",
      "description": "Exported variables"
    },
    {
      "kind": "type",
      "pattern": "\\\\b(type|interface)\\\\s+([A-Z]\\\\w*)",
      "description": "Type/interface declarations"
    },
    {
      "kind": "constant",
      "pattern": "\\\\b(const|final|readonly)\\\\s+([A-Z_]\\\\w*)",
      "description": "Constant declarations"
    },
    {
      "kind": "enum",
      "pattern": "\\\\benum\\\\s+([A-Z]\\\\w*)",
      "description": "Enum declarations"
    },
    {
      "kind": "module",
      "pattern": "(?:module|namespace|package)\\\\s+(\\\\w+)",
      "description": "Module/namespace declarations"
    },
    {
      "kind": "interface",
      "pattern": "\\\\binterface\\\\s+([A-Z]\\\\w*)",
      "description": "Interface declarations"
    },
    {
      "kind": "method",
      "pattern": "\\\\b(public|private|protected)?\\\\s*\\\\w+\\\\s*\\\\(",
      "description": "Method declarations"
    },
    {
      "kind": "import",
      "pattern": "import\\\\s+.*?['\"]([^'\"]+)['\"]",
      "description": "Import statements for cross-file resolution"
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "#include\\s+[<\"]([^>\"]+)[>\"]",
      "import\\s+([\\w.]+)",
      "using\\s+([\\w.]+)",
      "require\\s+([\\w.]+)"
    ],
    "exportStatements": [
      "(public|export)\\s+(class|struct|function|fn|func|def)\\s+(\\w+)",
      "module\\.exports"
    ],
    "reExportStatements": [
      "(export|pub)\\s+(use|import)\\s+"
    ]
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\b(global|public)\\s+\\w+\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\b(\\w+)\\s*=",
        "(class|module|namespace)\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [
        "\\b(self|this|me)\\.(\\w+)"
      ],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\b(\\w+)\\s*=",
        "\\b(var|let|const|local)\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\b(\\w+)\\s*="
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    "**=",
    "<<=",
    ">>=",
    "&=",
    "^=",
    "|=",
    "&&=",
    "||=",
    "??=",
    "++",
    "--",
    "delete",
    ".push(",
    ".pop(",
    ".shift(",
    ".splice(",
    ".sort(",
    ".reverse(",
    ".fill("
  ],
  "readOperations": [
    ".length",
    ".indexOf(",
    ".includes(",
    ".find(",
    ".filter(",
    ".map(",
    ".reduce(",
    ".some(",
    ".every(",
    ".forEach(",
    ".keys(",
    ".values(",
    ".entries(",
    ".slice(",
    ".concat(",
    ".join(",
    ".toString(",
    ".valueOf(",
    "JSON.stringify(",
    "JSON.parse(",
    "typeof",
    "instanceof",
    "in"
  ],
  "declarationPatterns": [
    "\\b(\\w+)\\s*=",
    "\\b(var|let|const|val|def|func|fn)\\s+(\\w+)",
    "\\b(class|struct|type|interface)\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\b(\\w+)\\(",
    "\\b(\\w+)\\.",
    "new\\s+(\\w+)"
  ],
  "specialHighlights": {
    "typeReferences": true,
    "decorators": true,
    "comments": true
  }
}
