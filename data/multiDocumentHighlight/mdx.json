{
  "language": "mdx",
  "selector": {
    "language": "mdx",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "element",
      "pattern": "<([a-zA-Z][\\w-]*)",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Element tag reference",
      "crossFileCapable": false
    },
    {
      "symbolKind": "id",
      "pattern": "id=[\"']([\\w-]+)[\"']",
      "importPattern": "#\\{name\\}",
      "exportPattern": "id=",
      "highlightKind": 1,
      "description": "ID reference across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "class",
      "pattern": "class=[\"']([\\w\\s-]+)[\"']",
      "importPattern": "\\.{name}",
      "exportPattern": "class=",
      "highlightKind": 1,
      "description": "CSS class reference",
      "crossFileCapable": true
    },
    {
      "symbolKind": "component",
      "pattern": "<([A-Z][\\w]*)",
      "importPattern": "(import|require)\\s+.*{name}",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Component reference",
      "crossFileCapable": true
    },
    {
      "symbolKind": "link",
      "pattern": "(href|src)=[\"']([^\"']+)[\"']",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Link/source reference",
      "crossFileCapable": true
    },
    {
      "symbolKind": "template",
      "pattern": "\\{\\{\\s*(\\w+)\\s*\\}\\}",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Template variable",
      "crossFileCapable": false
    },
    {
      "symbolKind": "slot",
      "pattern": "slot=[\"']([\\w-]+)[\"']|<slot\\s+name=[\"']([\\w-]+)[\"']",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Slot reference",
      "crossFileCapable": true
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "(import|include|require|use|load)\\s+['\"]?([\\w./]+)['\"]?",
      "(import|include|require|use|load|source)\\s+['\"]?([\\w./\\-]+)['\"]?",
      "from\\s+([\\w./]+)\\s+import",
      "#include\\s+[<\"]([^>\"]+)[>\"]"
    ],
    "exportStatements": [
      "(export|public|pub)\\s+(\\w+)\\s+(\\w+)",
      "(export|public|pub)\\s+(class|struct|function|fn|def|const|var|type)\\s+(\\w+)",
      "module\\.exports\\s*="
    ],
    "reExportStatements": [
      "(export|pub)\\s+(use|import|from)\\s+"
    ]
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\b(global|public)\\s+\\w+\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\b(\\w+)\\s*=",
        "(class|module|namespace)\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [
        "\\b(self|this|me)\\.(\\w+)"
      ],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\b(\\w+)\\s*=",
        "\\b(var|let|const|local)\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\b(\\w+)\\s*="
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    "++",
    "--",
    ".push(",
    ".pop(",
    ".set(",
    ".add(",
    ".remove(",
    ".delete(",
    ".clear("
  ],
  "readOperations": [
    ".length",
    ".size()",
    ".get(",
    ".contains(",
    ".indexOf(",
    ".toString(",
    ".equals(",
    ".compareTo(",
    "typeof",
    "instanceof",
    ".isEmpty()",
    ".count("
  ],
  "declarationPatterns": [
    "\\b(\\w+)\\s*=",
    "\\b(var|let|const|val|def|func|fn)\\s+(\\w+)",
    "\\b(class|struct|type|interface)\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\b(\\w+)\\(",
    "\\b(\\w+)\\.",
    "new\\s+(\\w+)"
  ],
  "specialHighlights": {
    "typeReferences": true,
    "decorators": false,
    "comments": true
  }
}
