{
  "language": "javascript",
  "selector": {
    "language": "javascript",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "function",
      "pattern": "\\bfunction\\s+(\\w+)",
      "importPattern": "import\\s*\\{[^}]*\\b{name}\\b[^}]*\\}",
      "exportPattern": "export\\s+(function|const|let|var|default)\\s+{name}",
      "highlightKind": 1,
      "description": "Function declaration/usage across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "class",
      "pattern": "\\bclass\\s+(\\w+)",
      "importPattern": "import\\s*\\{[^}]*\\b{name}\\b[^}]*\\}",
      "exportPattern": "export\\s+(class|default\\s+class)\\s+{name}",
      "highlightKind": 1,
      "description": "Class declaration/usage across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "variable",
      "pattern": "\\b(const|let|var)\\s+(\\w+)",
      "importPattern": "import\\s*\\{[^}]*\\b{name}\\b[^}]*\\}",
      "exportPattern": "export\\s+(const|let|var)\\s+{name}",
      "highlightKind": 1,
      "description": "Variable declaration/usage across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "defaultExport",
      "pattern": "export\\s+default\\s+(\\w+)",
      "importPattern": "import\\s+(\\w+)\\s+from",
      "exportPattern": "export\\s+default",
      "highlightKind": 1,
      "description": "Default export across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "namespaceImport",
      "pattern": "import\\s+\\*\\s+as\\s+(\\w+)",
      "importPattern": "import\\s+\\*\\s+as\\s+{name}",
      "exportPattern": "export\\s+\\*",
      "highlightKind": 1,
      "description": "Namespace import across files",
      "crossFileCapable": true
    },
    {
      "kind": "function",
      "pattern": "function\\\\s+(\\\\w+)",
      "description": "Function declarations"
    },
    {
      "kind": "class",
      "pattern": "\\\\bclass\\\\s+([A-Z]\\\\w*)",
      "description": "Class declarations"
    },
    {
      "kind": "variable",
      "pattern": "(?:export|pub)\\\\s+(?:const|let|var)\\\\s+(\\\\w+)",
      "description": "Exported variables"
    },
    {
      "kind": "type",
      "pattern": "\\\\b(type|interface)\\\\s+([A-Z]\\\\w*)",
      "description": "Type/interface declarations"
    },
    {
      "kind": "constant",
      "pattern": "\\\\b(const|final|readonly)\\\\s+([A-Z_]\\\\w*)",
      "description": "Constant declarations"
    },
    {
      "kind": "enum",
      "pattern": "\\\\benum\\\\s+([A-Z]\\\\w*)",
      "description": "Enum declarations"
    },
    {
      "kind": "module",
      "pattern": "(?:module|namespace|package)\\\\s+(\\\\w+)",
      "description": "Module/namespace declarations"
    },
    {
      "kind": "interface",
      "pattern": "\\\\binterface\\\\s+([A-Z]\\\\w*)",
      "description": "Interface declarations"
    },
    {
      "kind": "method",
      "pattern": "\\\\b(public|private|protected)?\\\\s*\\\\w+\\\\s*\\\\(",
      "description": "Method declarations"
    },
    {
      "kind": "import",
      "pattern": "import\\\\s+.*?['\"]([^'\"]+)['\"]",
      "description": "Import statements for cross-file resolution"
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "import\\s+{\\s*([^}]+)\\s*}\\s+from\\s+['\"]([^'\"]+)['\"]",
      "import\\s+(\\w+)\\s+from\\s+['\"]([^'\"]+)['\"]",
      "import\\s+\\*\\s+as\\s+(\\w+)\\s+from\\s+['\"]([^'\"]+)['\"]",
      "import\\s+type\\s+{\\s*([^}]+)\\s*}\\s+from\\s+['\"]([^'\"]+)['\"]",
      "require\\(['\"]([^'\"]+)['\"]\\)",
      "import\\(['\"]([^'\"]+)['\"]\\)"
    ],
    "exportStatements": [
      "export\\s+(const|let|var|function|class|type|interface|enum|default)\\s+(\\w+)",
      "export\\s+{\\s*([^}]+)\\s*}",
      "export\\s+default\\s+(\\w+|function|class)"
    ],
    "reExportStatements": [
      "export\\s+{\\s*([^}]+)\\s*}\\s+from\\s+['\"]([^'\"]+)['\"]",
      "export\\s+\\*\\s+from\\s+['\"]([^'\"]+)['\"]",
      "export\\s+\\*\\s+as\\s+(\\w+)\\s+from\\s+['\"]([^'\"]+)['\"]"
    ]
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\bwindow\\.(\\w+)",
        "\\bglobalThis\\.(\\w+)",
        "\\bglobal\\.(\\w+)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\bexport\\s+(const|let|var|function|class)\\s+(\\w+)",
        "module\\.exports"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [
        "\\bthis\\.(\\w+)",
        "\\bstatic\\s+(\\w+)",
        "#(\\w+)"
      ],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\b(const|let|var)\\s+(\\w+)",
        "\\bfunction\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\b(const|let)\\s+(\\w+)"
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    "**=",
    "<<=",
    ">>=",
    "&=",
    "^=",
    "|=",
    "&&=",
    "||=",
    "??=",
    "++",
    "--",
    "delete",
    ".push(",
    ".pop(",
    ".shift(",
    ".splice(",
    ".sort(",
    ".reverse(",
    ".fill("
  ],
  "readOperations": [
    ".length",
    ".indexOf(",
    ".includes(",
    ".find(",
    ".filter(",
    ".map(",
    ".reduce(",
    ".some(",
    ".every(",
    ".forEach(",
    ".keys(",
    ".values(",
    ".entries(",
    ".slice(",
    ".concat(",
    ".join(",
    ".toString(",
    ".valueOf(",
    "JSON.stringify(",
    "JSON.parse(",
    "typeof",
    "instanceof",
    "in"
  ],
  "declarationPatterns": [
    "\\b(const|let|var)\\s+(\\w+)",
    "\\bfunction\\s+(\\w+)",
    "\\bclass\\s+(\\w+)",
    "interface\\s+(\\w+)",
    "type\\s+(\\w+)",
    "enum\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\b(\\w+)\\(",
    "\\b(\\w+)\\s*\\.",
    "new\\s+(\\w+)",
    "extends\\s+(\\w+)",
    "implements\\s+(\\w+)"
  ],
  "specialHighlights": {
    "typeReferences": true,
    "decorators": true,
    "comments": true
  }
}
