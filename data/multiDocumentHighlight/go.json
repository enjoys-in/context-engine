{
  "language": "go",
  "selector": {
    "language": "go",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "function",
      "pattern": "\\bfunc\\s+(\\w+)",
      "importPattern": "\"[\\w./]+\"",
      "exportPattern": "\\bfunc\\s+{name}",
      "highlightKind": 1,
      "description": "Exported function across packages",
      "crossFileCapable": true
    },
    {
      "symbolKind": "type",
      "pattern": "\\btype\\s+(\\w+)\\s+struct",
      "importPattern": "\"[\\w./]+\"",
      "exportPattern": "\\btype\\s+{name}\\s+struct",
      "highlightKind": 1,
      "description": "Struct type across packages",
      "crossFileCapable": true
    },
    {
      "symbolKind": "interface",
      "pattern": "\\btype\\s+(\\w+)\\s+interface",
      "importPattern": "\"[\\w./]+\"",
      "exportPattern": "\\btype\\s+{name}\\s+interface",
      "highlightKind": 1,
      "description": "Interface type across packages",
      "crossFileCapable": true
    },
    {
      "symbolKind": "constant",
      "pattern": "\\bconst\\s+(\\w+)",
      "importPattern": "\"[\\w./]+\"",
      "exportPattern": "\\bconst\\s+{name}",
      "highlightKind": 1,
      "description": "Package-level constant",
      "crossFileCapable": true
    },
    {
      "symbolKind": "variable",
      "pattern": "\\bvar\\s+(\\w+)",
      "importPattern": "\"[\\w./]+\"",
      "exportPattern": "\\bvar\\s+{name}",
      "highlightKind": 1,
      "description": "Package-level variable",
      "crossFileCapable": true
    },
    {
      "symbolKind": "method",
      "pattern": "\\bfunc\\s+\\(\\w+\\s+\\*?\\w+\\)\\s+(\\w+)",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Method on type",
      "crossFileCapable": false
    },
    {
      "symbolKind": "package",
      "pattern": "package\\s+(\\w+)",
      "importPattern": "\"[\\w./]+\"",
      "exportPattern": "package\\s+{name}",
      "highlightKind": 1,
      "description": "Package reference",
      "crossFileCapable": true
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "\"([\\w./]+)\"",
      "(\\w+)\\s+\"([\\w./]+)\"",
      "_\\s+\"([\\w./]+)\"",
      "\\.\\s+\"([\\w./]+)\""
    ],
    "exportStatements": [
      "\\bfunc\\s+([A-Z]\\w*)",
      "\\btype\\s+([A-Z]\\w*)\\s+struct",
      "\\btype\\s+([A-Z]\\w*)\\s+interface",
      "\\bvar\\s+([A-Z]\\w*)",
      "\\bconst\\s+([A-Z]\\w*)"
    ],
    "reExportStatements": []
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\bvar\\s+([A-Z]\\w*)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\bpackage\\s+(\\w+)",
        "\\bfunc\\s+([A-Z]\\w*)"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [
        "(\\w+)\\.(\\w+)"
      ],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\b(\\w+)\\s*:=",
        "\\bvar\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\b(\\w+)\\s*:="
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    "**=",
    "<<=",
    ">>=",
    "&=",
    "^=",
    "|=",
    "&&=",
    "||=",
    "??=",
    "++",
    "--",
    "delete",
    ".push(",
    ".pop(",
    ".shift(",
    ".splice(",
    ".sort(",
    ".reverse(",
    ".fill("
  ],
  "readOperations": [
    ".length",
    ".indexOf(",
    ".includes(",
    ".find(",
    ".filter(",
    ".map(",
    ".reduce(",
    ".some(",
    ".every(",
    ".forEach(",
    ".keys(",
    ".values(",
    ".entries(",
    ".slice(",
    ".concat(",
    ".join(",
    ".toString(",
    ".valueOf(",
    "JSON.stringify(",
    "JSON.parse(",
    "typeof",
    "instanceof",
    "in"
  ],
  "declarationPatterns": [
    "\\b(var|const)\\s+(\\w+)",
    "\\btype\\s+(\\w+)",
    "\\bfunc\\s+(\\w+)",
    "(\\w+)\\s*:="
  ],
  "referencePatterns": [
    "\\b(\\w+)\\(",
    "\\b(\\w+)\\.",
    "new\\s+(\\w+)"
  ],
  "specialHighlights": {
    "typeReferences": true,
    "decorators": true,
    "comments": true
  }
}
