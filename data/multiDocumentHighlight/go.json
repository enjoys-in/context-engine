{
  "language": "go",
  "selector": {
    "language": "go",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "function",
      "pattern": "\\bfunc\\s+(\\w+)",
      "importPattern": "\\b{package}\\.{name}",
      "exportPattern": "func\\s+{name}",
      "highlightKind": 1,
      "description": "Exported function across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "type",
      "pattern": "\\btype\\s+(\\w+)",
      "importPattern": "\\b{package}\\.{name}",
      "exportPattern": "type\\s+{name}",
      "highlightKind": 1,
      "description": "Type across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "interface",
      "pattern": "\\btype\\s+(\\w+)\\s+interface",
      "importPattern": "\\b{package}\\.{name}",
      "exportPattern": "type\\s+{name}\\s+interface",
      "highlightKind": 1,
      "description": "Interface across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "variable",
      "pattern": "\\bvar\\s+(\\w+)",
      "importPattern": "\\b{package}\\.{name}",
      "exportPattern": "var\\s+{name}",
      "highlightKind": 1,
      "description": "Package variable across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "constant",
      "pattern": "\\bconst\\s+(\\w+)",
      "importPattern": "\\b{package}\\.{name}",
      "exportPattern": "const\\s+{name}",
      "highlightKind": 1,
      "description": "Constant across files",
      "crossFileCapable": true
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "import\\s+\"([^\"]+)\"",
      "import\\s+\\(([^)]+)\\)",
      "import\\s+(\\w+)\\s+\"([^\"]+)\""
    ],
    "exportStatements": [
      "func\\s+([A-Z]\\w*)\\s*\\(",
      "type\\s+([A-Z]\\w*)",
      "var\\s+([A-Z]\\w*)",
      "const\\s+([A-Z]\\w*)"
    ],
    "reExportStatements": []
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\bvar\\s+([A-Z]\\w+)",
        "\\bconst\\s+([A-Z]\\w+)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\bpackage\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [
        "\\bfunc\\s*\\((\\w+)\\s+\\*?\\w+\\)",
        "\\b(\\w+)\\.(\\w+)"
      ],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\b(\\w+)\\s*:=",
        "\\bvar\\s+(\\w+)",
        "\\bfor\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\b(\\w+)\\s*:=",
        "if\\s+(\\w+)\\s*:="
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    ":=",
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    "&=",
    "|=",
    "^=",
    "<<=",
    ">>=",
    "&^=",
    "++",
    "--",
    "append(",
    "delete(",
    "close("
  ],
  "readOperations": [
    "len(",
    "cap(",
    "make(",
    "new(",
    "range ",
    "fmt.Sprint",
    "fmt.Print",
    "strings.",
    "strconv.",
    "sort.",
    "reflect."
  ],
  "declarationPatterns": [
    "\\b(\\w+)\\s*:=",
    "\\bvar\\s+(\\w+)",
    "\\bconst\\s+(\\w+)",
    "\\bfunc\\s+(\\w+)",
    "\\btype\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\b(\\w+)\\.",
    "\\b(\\w+)\\(",
    "\\b(\\w+)\\{"
  ],
  "specialHighlights": {
    "typeReferences": {
      "pattern": "\\b([A-Z]\\w+)(?:\\{|\\(|\\))",
      "highlightKind": 1
    },
    "decorators": {
      "pattern": "",
      "highlightKind": 0
    },
    "comments": {
      "pattern": "",
      "highlightKind": 0
    }
  }
}
