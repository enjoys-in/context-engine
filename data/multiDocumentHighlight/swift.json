{
  "language": "swift",
  "selector": {
    "language": "swift",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "class",
      "pattern": "\\bclass\\s+(\\w+)",
      "importPattern": "import\\s+\\w+",
      "exportPattern": "(public|open)\\s+class\\s+{name}",
      "highlightKind": 1,
      "description": "Class across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "struct",
      "pattern": "\\bstruct\\s+(\\w+)",
      "importPattern": "import\\s+\\w+",
      "exportPattern": "public\\s+struct\\s+{name}",
      "highlightKind": 1,
      "description": "Struct across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "protocol",
      "pattern": "\\bprotocol\\s+(\\w+)",
      "importPattern": "import\\s+\\w+",
      "exportPattern": "public\\s+protocol\\s+{name}",
      "highlightKind": 1,
      "description": "Protocol across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "enum",
      "pattern": "\\benum\\s+(\\w+)",
      "importPattern": "import\\s+\\w+",
      "exportPattern": "public\\s+enum\\s+{name}",
      "highlightKind": 1,
      "description": "Enum across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "actor",
      "pattern": "\\bactor\\s+(\\w+)",
      "importPattern": "import\\s+\\w+",
      "exportPattern": "public\\s+actor\\s+{name}",
      "highlightKind": 1,
      "description": "Actor across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "function",
      "pattern": "\\bfunc\\s+(\\w+)",
      "importPattern": "",
      "exportPattern": "public\\s+func\\s+{name}",
      "highlightKind": 1,
      "description": "Function across files",
      "crossFileCapable": true
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "import\\s+(\\w+)",
      "@testable\\s+import\\s+(\\w+)"
    ],
    "exportStatements": [
      "(public|open)\\s+(class|struct|protocol|enum|actor|func|var|let|typealias)\\s+(\\w+)"
    ],
    "reExportStatements": [
      "@_exported\\s+import\\s+(\\w+)"
    ]
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "(public|open)\\s+(var|let|func)\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "(internal)\\s+(class|struct|func)\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [
        "\\bself\\.(\\w+)",
        "\\bSelf\\.(\\w+)",
        "(private|fileprivate)\\s+(var|let|func)\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\b(let|var)\\s+(\\w+)",
        "\\bguard\\s+let\\s+(\\w+)",
        "\\bfor\\s+(\\w+)\\s+in"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\b(let|var)\\s+(\\w+)",
        "if\\s+let\\s+(\\w+)"
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    "&=",
    "|=",
    "^=",
    "<<=",
    ">>=",
    ".append(",
    ".insert(",
    ".remove(",
    ".removeAll(",
    ".sort(",
    ".reverse(",
    ".swapAt("
  ],
  "readOperations": [
    ".count",
    ".isEmpty",
    ".contains(",
    ".first",
    ".last",
    ".map(",
    ".filter(",
    ".reduce(",
    ".compactMap(",
    ".flatMap(",
    ".forEach(",
    ".enumerated(",
    ".sorted(",
    ".reversed(",
    "type(of"
  ],
  "declarationPatterns": [
    "\\b(let|var)\\s+(\\w+)",
    "\\bfunc\\s+(\\w+)",
    "\\bclass\\s+(\\w+)",
    "\\bstruct\\s+(\\w+)",
    "\\bprotocol\\s+(\\w+)",
    "\\benum\\s+(\\w+)",
    "\\bactor\\s+(\\w+)",
    "\\btypealias\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\b(\\w+)\\.",
    "\\b(\\w+)\\(",
    ":\\s+(\\w+)",
    "\\bextension\\s+(\\w+)"
  ],
  "specialHighlights": {
    "typeReferences": {
      "pattern": ":\\s*(\\w+)",
      "highlightKind": 1
    },
    "decorators": {
      "pattern": "@(\\w+)",
      "highlightKind": 1
    },
    "comments": {
      "pattern": "- (Parameter|Returns|Throws)\\s+(\\w+)",
      "highlightKind": 0
    }
  }
}
