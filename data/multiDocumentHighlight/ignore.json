{
  "language": "ignore",
  "selector": {
    "language": "ignore",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "kind": "function",
      "pattern": "(?:function|def|fn|func|sub|proc)\\\\s+(\\\\w+)",
      "description": "Function declarations"
    },
    {
      "kind": "class",
      "pattern": "\\\\bclass\\\\s+([A-Z]\\\\w*)",
      "description": "Class declarations"
    },
    {
      "kind": "variable",
      "pattern": "(?:export|pub)\\\\s+(?:const|let|var)\\\\s+(\\\\w+)",
      "description": "Exported variables"
    },
    {
      "kind": "type",
      "pattern": "\\\\b(type|interface)\\\\s+([A-Z]\\\\w*)",
      "description": "Type/interface declarations"
    },
    {
      "kind": "constant",
      "pattern": "\\\\b(const|final|readonly)\\\\s+([A-Z_]\\\\w*)",
      "description": "Constant declarations"
    },
    {
      "kind": "enum",
      "pattern": "\\\\benum\\\\s+([A-Z]\\\\w*)",
      "description": "Enum declarations"
    },
    {
      "kind": "module",
      "pattern": "(?:module|namespace|package)\\\\s+(\\\\w+)",
      "description": "Module/namespace declarations"
    },
    {
      "kind": "interface",
      "pattern": "\\\\binterface\\\\s+([A-Z]\\\\w*)",
      "description": "Interface declarations"
    },
    {
      "kind": "method",
      "pattern": "\\\\b(public|private|protected)?\\\\s*\\\\w+\\\\s*\\\\(",
      "description": "Method declarations"
    },
    {
      "kind": "import",
      "pattern": "import\\\\s+.*?['\"]([^'\"]+)['\"]",
      "description": "Import statements for cross-file resolution"
    }
  ],
  "importExportPatterns": {
    "import": "import\\\\s+|require\\\\s*\\\\(|from\\\\s+",
    "export": "export\\\\s+|module\\\\.exports"
  },
  "scopeRules": [
    {
      "scope": "global",
      "description": "Top-level declarations visible across files"
    },
    {
      "scope": "module",
      "description": "Module-scoped declarations accessible via import"
    },
    {
      "scope": "function",
      "description": "Function-local scope"
    },
    {
      "scope": "block",
      "description": "Block-scoped (within if/for/while etc.)"
    },
    {
      "scope": "class",
      "description": "Class-member scope"
    }
  ],
  "writeOperations": [
    {
      "pattern": "=(?!=)",
      "kind": "write",
      "description": "Assignment"
    },
    {
      "pattern": "[+\\\\-*/]?=",
      "kind": "write",
      "description": "Compound assignment"
    },
    {
      "pattern": "\\\\+\\\\+|--",
      "kind": "write",
      "description": "Increment/decrement"
    }
  ],
  "readOperations": [
    {
      "pattern": "\\\\b\\\\w+\\\\s*[^=]",
      "kind": "read",
      "description": "Variable read in expression"
    },
    {
      "pattern": "\\\\b\\\\w+\\\\.\\\\w+",
      "kind": "read",
      "description": "Property access read"
    },
    {
      "pattern": "\\\\b\\\\w+\\\\[",
      "kind": "read",
      "description": "Index access read"
    }
  ],
  "declarationPatterns": [
    {
      "pattern": "(?:const|let|var|val|dim)\\\\s+(\\\\w+)",
      "kind": "variable",
      "description": "Variable declaration"
    },
    {
      "pattern": "(?:function|def|fn|func|sub|proc)\\\\s+(\\\\w+)",
      "kind": "function",
      "description": "Function declaration"
    },
    {
      "pattern": "\\\\bclass\\\\s+(\\\\w+)",
      "kind": "class",
      "description": "Class declaration"
    }
  ],
  "referencePatterns": [
    {
      "pattern": "\\\\b(\\\\w+)\\\\s*\\\\(",
      "kind": "call",
      "description": "Function call reference"
    },
    {
      "pattern": "\\\\b(\\\\w+)\\\\s*\\\\.",
      "kind": "member-access",
      "description": "Member access reference"
    },
    {
      "pattern": ":\\\\s*(\\\\w+)",
      "kind": "type-reference",
      "description": "Type annotation reference"
    }
  ],
  "specialHighlights": [
    {
      "pattern": "\\\\bsuper\\\\b",
      "kind": "read",
      "description": "Super/parent class reference"
    },
    {
      "pattern": "\\\\bthis\\\\b|\\\\bself\\\\b",
      "kind": "read",
      "description": "Self/this reference"
    }
  ]
}
