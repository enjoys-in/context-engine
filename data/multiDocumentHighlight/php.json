{
  "language": "php",
  "selector": {
    "language": "php",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "class",
      "pattern": "\\bclass\\s+(\\w+)",
      "importPattern": "use\\s+[\\w\\\\]+\\\\{name}",
      "exportPattern": "class\\s+{name}",
      "highlightKind": 1,
      "description": "Class across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "interface",
      "pattern": "\\binterface\\s+(\\w+)",
      "importPattern": "use\\s+[\\w\\\\]+\\\\{name}",
      "exportPattern": "interface\\s+{name}",
      "highlightKind": 1,
      "description": "Interface across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "trait",
      "pattern": "\\btrait\\s+(\\w+)",
      "importPattern": "use\\s+[\\w\\\\]+\\\\{name}",
      "exportPattern": "trait\\s+{name}",
      "highlightKind": 1,
      "description": "Trait across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "function",
      "pattern": "\\bfunction\\s+(\\w+)",
      "importPattern": "use\\s+function\\s+[\\w\\\\]+\\\\{name}",
      "exportPattern": "function\\s+{name}",
      "highlightKind": 1,
      "description": "Function across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "constant",
      "pattern": "\\bconst\\s+(\\w+)",
      "importPattern": "use\\s+const\\s+[\\w\\\\]+\\\\{name}",
      "exportPattern": "const\\s+{name}",
      "highlightKind": 1,
      "description": "Constant across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "namespace",
      "pattern": "\\bnamespace\\s+([\\w\\\\]+)",
      "importPattern": "use\\s+{name}",
      "exportPattern": "namespace\\s+{name}",
      "highlightKind": 1,
      "description": "Namespace across files",
      "crossFileCapable": true
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "use\\s+([\\w\\\\]+)",
      "use\\s+([\\w\\\\]+)\\s+as\\s+(\\w+)",
      "include(_once)?\\s+['\"]([^'\"]+)['\"]",
      "require(_once)?\\s+['\"]([^'\"]+)['\"]"
    ],
    "exportStatements": [
      "(class|interface|trait|enum)\\s+(\\w+)",
      "function\\s+(\\w+)",
      "const\\s+(\\w+)"
    ],
    "reExportStatements": []
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\$GLOBALS\\[",
        "\\bglobal\\s+\\$(\\w+)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\bnamespace\\s+([\\w\\\\]+)"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [
        "\\$this->(\\w+)",
        "\\bself::(\\w+)",
        "\\bstatic::(\\w+)",
        "\\bparent::(\\w+)"
      ],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\$(\\w+)\\s*=",
        "foreach\\s*\\(.+as\\s*\\$(\\w+)"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\$(\\w+)\\s*=",
        "catch\\s*\\(\\w+\\s+\\$(\\w+)\\)"
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    ".=",
    "&=",
    "|=",
    "^=",
    "<<=",
    ">>=",
    "**=",
    "??=",
    "++",
    "--",
    "[]",
    "array_push(",
    "array_pop(",
    "array_shift(",
    "array_unshift(",
    "array_splice(",
    "unset("
  ],
  "readOperations": [
    "count(",
    "strlen(",
    "sizeof(",
    "isset(",
    "empty(",
    "is_array(",
    "is_string(",
    "is_int(",
    "is_null(",
    "array_key_exists(",
    "in_array(",
    "array_search(",
    "array_map(",
    "array_filter(",
    "array_reduce(",
    "get_class(",
    "instanceof"
  ],
  "declarationPatterns": [
    "\\$(\\w+)\\s*=",
    "function\\s+(\\w+)",
    "class\\s+(\\w+)",
    "interface\\s+(\\w+)",
    "trait\\s+(\\w+)",
    "const\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\$(\\w+)",
    "\\b(\\w+)::",
    "\\b(\\w+)->",
    "\\bnew\\s+(\\w+)",
    "\\b(\\w+)\\("
  ],
  "specialHighlights": {
    "typeReferences": {
      "pattern": "(?::\\s*|instanceof\\s+)(\\w+)",
      "highlightKind": 1
    },
    "decorators": {
      "pattern": "#\\[(\\w+)",
      "highlightKind": 1
    },
    "comments": {
      "pattern": "@(param|return|var|throws)\\s+(\\w+)",
      "highlightKind": 0
    }
  }
}
