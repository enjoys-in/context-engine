{
  "language": "php",
  "selector": {
    "language": "php",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "class",
      "pattern": "\\bclass\\s+(\\w+)",
      "importPattern": "use\\s+[\\\\\\w]+\\\\{name}",
      "exportPattern": "\\bclass\\s+{name}",
      "highlightKind": 1,
      "description": "Class across namespaces",
      "crossFileCapable": true
    },
    {
      "symbolKind": "interface",
      "pattern": "\\binterface\\s+(\\w+)",
      "importPattern": "use\\s+[\\\\\\w]+\\\\{name}",
      "exportPattern": "\\binterface\\s+{name}",
      "highlightKind": 1,
      "description": "Interface across namespaces",
      "crossFileCapable": true
    },
    {
      "symbolKind": "trait",
      "pattern": "\\btrait\\s+(\\w+)",
      "importPattern": "use\\s+[\\\\\\w]+\\\\{name}",
      "exportPattern": "\\btrait\\s+{name}",
      "highlightKind": 1,
      "description": "Trait across namespaces",
      "crossFileCapable": true
    },
    {
      "symbolKind": "function",
      "pattern": "\\bfunction\\s+(\\w+)",
      "importPattern": "use\\s+function\\s+[\\\\\\w]+\\\\{name}",
      "exportPattern": "\\bfunction\\s+{name}",
      "highlightKind": 1,
      "description": "Function across namespaces",
      "crossFileCapable": true
    },
    {
      "symbolKind": "constant",
      "pattern": "\\bconst\\s+(\\w+)",
      "importPattern": "use\\s+const\\s+[\\\\\\w]+\\\\{name}",
      "exportPattern": "\\bconst\\s+{name}",
      "highlightKind": 1,
      "description": "Constant across namespaces",
      "crossFileCapable": true
    },
    {
      "symbolKind": "namespace",
      "pattern": "\\bnamespace\\s+([\\w\\\\]+)",
      "importPattern": "use\\s+{name}",
      "exportPattern": "namespace\\s+{name}",
      "highlightKind": 1,
      "description": "Namespace reference",
      "crossFileCapable": true
    },
    {
      "symbolKind": "enum",
      "pattern": "\\benum\\s+(\\w+)",
      "importPattern": "use\\s+[\\\\\\w]+\\\\{name}",
      "exportPattern": "\\benum\\s+{name}",
      "highlightKind": 1,
      "description": "Enum across namespaces",
      "crossFileCapable": true
    },
    {
      "kind": "function",
      "pattern": "function\\\\s+(\\\\w+)",
      "description": "Function declarations"
    },
    {
      "kind": "class",
      "pattern": "\\\\bclass\\\\s+([A-Z]\\\\w*)",
      "description": "Class declarations"
    },
    {
      "kind": "variable",
      "pattern": "(?:export|pub)\\\\s+(?:const|let|var)\\\\s+(\\\\w+)",
      "description": "Exported variables"
    },
    {
      "kind": "type",
      "pattern": "\\\\b(type|interface)\\\\s+([A-Z]\\\\w*)",
      "description": "Type/interface declarations"
    },
    {
      "kind": "constant",
      "pattern": "\\\\b(const|final|readonly)\\\\s+([A-Z_]\\\\w*)",
      "description": "Constant declarations"
    },
    {
      "kind": "enum",
      "pattern": "\\\\benum\\\\s+([A-Z]\\\\w*)",
      "description": "Enum declarations"
    },
    {
      "kind": "module",
      "pattern": "(?:module|namespace|package)\\\\s+(\\\\w+)",
      "description": "Module/namespace declarations"
    },
    {
      "kind": "interface",
      "pattern": "\\\\binterface\\\\s+([A-Z]\\\\w*)",
      "description": "Interface declarations"
    },
    {
      "kind": "method",
      "pattern": "\\\\b(public|private|protected)?\\\\s*\\\\w+\\\\s*\\\\(",
      "description": "Method declarations"
    },
    {
      "kind": "import",
      "pattern": "import\\\\s+.*?['\"]([^'\"]+)['\"]",
      "description": "Import statements for cross-file resolution"
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "use\\s+([\\\\\\w]+)\\s*;",
      "use\\s+([\\\\\\w]+)\\s+as\\s+(\\w+)",
      "use\\s+function\\s+([\\\\\\w]+)",
      "use\\s+const\\s+([\\\\\\w]+)",
      "require(_once)?\\s+['\"]([^'\"]+)['\"]",
      "include(_once)?\\s+['\"]([^'\"]+)['\"]"
    ],
    "exportStatements": [
      "namespace\\s+([\\w\\\\]+)",
      "(public|protected|private)\\s+(function|static|const)\\s+(\\w+)"
    ],
    "reExportStatements": []
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\bwindow\\.(\\w+)",
        "\\bglobalThis\\.(\\w+)",
        "\\bglobal\\.(\\w+)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\bexport\\s+(const|let|var|function|class)\\s+(\\w+)",
        "module\\.exports"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [
        "\\bthis\\.(\\w+)",
        "\\bstatic\\s+(\\w+)",
        "#(\\w+)"
      ],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\b(const|let|var)\\s+(\\w+)",
        "\\bfunction\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\b(const|let)\\s+(\\w+)"
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    "**=",
    "<<=",
    ">>=",
    "&=",
    "^=",
    "|=",
    "&&=",
    "||=",
    "??=",
    "++",
    "--",
    "delete",
    ".push(",
    ".pop(",
    ".shift(",
    ".splice(",
    ".sort(",
    ".reverse(",
    ".fill("
  ],
  "readOperations": [
    ".length",
    ".indexOf(",
    ".includes(",
    ".find(",
    ".filter(",
    ".map(",
    ".reduce(",
    ".some(",
    ".every(",
    ".forEach(",
    ".keys(",
    ".values(",
    ".entries(",
    ".slice(",
    ".concat(",
    ".join(",
    ".toString(",
    ".valueOf(",
    "JSON.stringify(",
    "JSON.parse(",
    "typeof",
    "instanceof",
    "in"
  ],
  "declarationPatterns": [
    "\\b(const|let|var)\\s+(\\w+)",
    "\\bfunction\\s+(\\w+)",
    "\\bclass\\s+(\\w+)",
    "interface\\s+(\\w+)",
    "type\\s+(\\w+)",
    "enum\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\b(\\w+)\\(",
    "\\b(\\w+)\\s*\\.",
    "new\\s+(\\w+)",
    "extends\\s+(\\w+)",
    "implements\\s+(\\w+)"
  ],
  "specialHighlights": {
    "typeReferences": true,
    "decorators": true,
    "comments": true
  }
}
