{
  "language": "r",
  "selector": {
    "language": "r",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "function",
      "pattern": "\\b(def|function|fn|sub|proc)\\s+(\\w+)",
      "importPattern": "(import|require|use|load|include|source)\\s+.*{name}",
      "exportPattern": "\\b(def|function)\\s+{name}",
      "highlightKind": 1,
      "description": "Function across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "class",
      "pattern": "\\b(class|module|package)\\s+(\\w+)",
      "importPattern": "(import|require|use|load|include)\\s+.*{name}",
      "exportPattern": "\\b(class|module)\\s+{name}",
      "highlightKind": 1,
      "description": "Class/module across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "variable",
      "pattern": "\\b(\\w+)\\s*=",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Variable reference",
      "crossFileCapable": false
    },
    {
      "symbolKind": "constant",
      "pattern": "\\b([A-Z_][A-Z0-9_]+)\\s*=",
      "importPattern": "(import|require|use)\\s+",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Constant reference",
      "crossFileCapable": true
    },
    {
      "symbolKind": "method",
      "pattern": "\\b(def|function)\\s+",
      "importPattern": "",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Method definition",
      "crossFileCapable": false
    },
    {
      "symbolKind": "type",
      "pattern": "\\b(type|alias|typedef|class)\\s+(\\w+)",
      "importPattern": "(import|require|use)\\s+",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Type definition",
      "crossFileCapable": true
    },
    {
      "symbolKind": "module",
      "pattern": "(import|require|use|include)\\s+([\\w./]+)",
      "importPattern": "(import|require|use)\\s+{name}",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Module import",
      "crossFileCapable": true
    },
    {
      "kind": "function",
      "pattern": "(?:function|def|fn|func|sub|proc)\\\\s+(\\\\w+)",
      "description": "Function declarations"
    },
    {
      "kind": "class",
      "pattern": "\\\\bclass\\\\s+([A-Z]\\\\w*)",
      "description": "Class declarations"
    },
    {
      "kind": "variable",
      "pattern": "(?:export|pub)\\\\s+(?:const|let|var)\\\\s+(\\\\w+)",
      "description": "Exported variables"
    },
    {
      "kind": "type",
      "pattern": "\\\\b(type|interface)\\\\s+([A-Z]\\\\w*)",
      "description": "Type/interface declarations"
    },
    {
      "kind": "constant",
      "pattern": "\\\\b(const|final|readonly)\\\\s+([A-Z_]\\\\w*)",
      "description": "Constant declarations"
    },
    {
      "kind": "enum",
      "pattern": "\\\\benum\\\\s+([A-Z]\\\\w*)",
      "description": "Enum declarations"
    },
    {
      "kind": "module",
      "pattern": "(?:module|namespace|package)\\\\s+(\\\\w+)",
      "description": "Module/namespace declarations"
    },
    {
      "kind": "interface",
      "pattern": "\\\\binterface\\\\s+([A-Z]\\\\w*)",
      "description": "Interface declarations"
    },
    {
      "kind": "method",
      "pattern": "\\\\b(public|private|protected)?\\\\s*\\\\w+\\\\s*\\\\(",
      "description": "Method declarations"
    },
    {
      "kind": "import",
      "pattern": "import\\\\s+.*?['\"]([^'\"]+)['\"]",
      "description": "Import statements for cross-file resolution"
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "(import|require|use|include|load|source)\\s+['\"]?([\\w./]+)['\"]?",
      "from\\s+(\\w+)\\s+import",
      "require\\s+(\\w+)"
    ],
    "exportStatements": [
      "(def|function|class|module)\\s+(\\w+)",
      "(export|public)\\s+(\\w+)"
    ],
    "reExportStatements": [
      "from\\s+(\\w+)\\s+import\\s+(.+)"
    ]
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\b(global|public)\\s+\\w+\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\b(\\w+)\\s*=",
        "(class|module|namespace)\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [
        "\\b(self|this|me)\\.(\\w+)"
      ],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\b(\\w+)\\s*=",
        "\\b(var|let|const|local)\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\b(\\w+)\\s*="
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "%=",
    "++",
    "--",
    ".push(",
    ".pop(",
    ".set(",
    ".add(",
    ".remove(",
    ".delete(",
    ".clear("
  ],
  "readOperations": [
    ".length",
    ".size()",
    ".get(",
    ".contains(",
    ".indexOf(",
    ".toString(",
    ".equals(",
    ".compareTo(",
    "typeof",
    "instanceof",
    ".isEmpty()",
    ".count("
  ],
  "declarationPatterns": [
    "\\b(\\w+)\\s*=",
    "\\b(var|let|const|val|def|func|fn)\\s+(\\w+)",
    "\\b(class|struct|type|interface)\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\b(\\w+)\\(",
    "\\b(\\w+)\\.",
    "new\\s+(\\w+)"
  ],
  "specialHighlights": {
    "typeReferences": true,
    "decorators": true,
    "comments": true
  }
}
