{
  "language": "python",
  "selector": {
    "language": "python",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "function",
      "pattern": "\\bdef\\s+(\\w+)",
      "importPattern": "from\\s+\\S+\\s+import\\s+.*\\b{name}\\b",
      "exportPattern": "__all__\\s*=.*\\b{name}\\b",
      "highlightKind": 1,
      "description": "Function across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "class",
      "pattern": "\\bclass\\s+(\\w+)",
      "importPattern": "from\\s+\\S+\\s+import\\s+.*\\b{name}\\b",
      "exportPattern": "__all__\\s*=.*\\b{name}\\b",
      "highlightKind": 1,
      "description": "Class across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "variable",
      "pattern": "^(\\w+)\\s*=",
      "importPattern": "from\\s+\\S+\\s+import\\s+.*\\b{name}\\b",
      "exportPattern": "__all__\\s*=.*\\b{name}\\b",
      "highlightKind": 1,
      "description": "Module variable across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "module",
      "pattern": "import\\s+(\\w+)",
      "importPattern": "import\\s+{name}",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Module import across files",
      "crossFileCapable": true
    },
    {
      "symbolKind": "decorator",
      "pattern": "@(\\w+)",
      "importPattern": "from\\s+\\S+\\s+import\\s+.*\\b{name}\\b",
      "exportPattern": "def\\s+{name}",
      "highlightKind": 1,
      "description": "Decorator across files",
      "crossFileCapable": true
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "from\\s+(\\S+)\\s+import\\s+(.+)",
      "import\\s+(\\S+)(?:\\s+as\\s+(\\w+))?",
      "from\\s+(\\S+)\\s+import\\s+\\(([^)]+)\\)"
    ],
    "exportStatements": [
      "__all__\\s*=\\s*\\[([^\\]]+)\\]",
      "\\bdef\\s+(\\w+)",
      "\\bclass\\s+(\\w+)"
    ],
    "reExportStatements": [
      "from\\s+(\\S+)\\s+import\\s+\\*"
    ]
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\bglobal\\s+(\\w+)"
      ],
      "highlightKind": 2
    },
    "moduleScope": {
      "patterns": [
        "^(\\w+)\\s*=",
        "\\bdef\\s+(\\w+)",
        "\\bclass\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [
        "\\bself\\.(\\w+)",
        "\\bcls\\.(\\w+)",
        "@classmethod",
        "@staticmethod",
        "@property"
      ],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\b(\\w+)\\s*=",
        "\\bfor\\s+(\\w+)\\s+in",
        "\\bwith\\s+.+\\s+as\\s+(\\w+)",
        "\\bexcept\\s+\\w+\\s+as\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\bnonlocal\\s+(\\w+)"
      ],
      "highlightKind": 2
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "//=",
    "%=",
    "**=",
    "&=",
    "|=",
    "^=",
    ">>=",
    "<<=",
    ":=",
    ".append(",
    ".extend(",
    ".insert(",
    ".remove(",
    ".pop(",
    ".clear(",
    ".sort(",
    ".reverse(",
    ".update(",
    ".add(",
    ".discard(",
    "del "
  ],
  "readOperations": [
    "len(",
    "type(",
    "isinstance(",
    "hasattr(",
    "getattr(",
    "dir(",
    "vars(",
    ".index(",
    ".count(",
    ".find(",
    ".keys(",
    ".values(",
    ".items(",
    ".get(",
    "in ",
    "not in",
    ".startswith(",
    ".endswith(",
    ".strip(",
    ".split(",
    ".join("
  ],
  "declarationPatterns": [
    "\\bdef\\s+(\\w+)",
    "\\bclass\\s+(\\w+)",
    "\\b(\\w+)\\s*=",
    "\\b(\\w+)\\s*:",
    "for\\s+(\\w+)",
    "as\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\b(\\w+)\\(",
    "\\b(\\w+)\\.",
    "\\bfrom\\s+(\\w+)",
    "\\bimport\\s+(\\w+)"
  ],
  "specialHighlights": {
    "typeReferences": {
      "pattern": ":\\s*(\\w+)",
      "highlightKind": 1
    },
    "decorators": {
      "pattern": "@(\\w+)",
      "highlightKind": 1
    },
    "comments": {
      "pattern": ":param\\s+(\\w+)",
      "highlightKind": 0
    }
  }
}
