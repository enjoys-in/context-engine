{
  "language": "python",
  "selector": {
    "language": "python",
    "scheme": "file"
  },
  "highlightKinds": {
    "text": 0,
    "read": 1,
    "write": 2
  },
  "crossFileSymbols": [
    {
      "symbolKind": "function",
      "pattern": "\\bdef\\s+(\\w+)",
      "importPattern": "from\\s+\\S+\\s+import\\s+.*\\b{name}\\b",
      "exportPattern": "\\bdef\\s+{name}\\b",
      "highlightKind": 1,
      "description": "Function definition across modules",
      "crossFileCapable": true
    },
    {
      "symbolKind": "class",
      "pattern": "\\bclass\\s+(\\w+)",
      "importPattern": "from\\s+\\S+\\s+import\\s+.*\\b{name}\\b",
      "exportPattern": "\\bclass\\s+{name}\\b",
      "highlightKind": 1,
      "description": "Class definition across modules",
      "crossFileCapable": true
    },
    {
      "symbolKind": "variable",
      "pattern": "\\b(\\w+)\\s*=",
      "importPattern": "from\\s+\\S+\\s+import\\s+.*\\b{name}\\b",
      "exportPattern": "__all__\\s*=.*\\b{name}\\b",
      "highlightKind": 1,
      "description": "Module-level variable",
      "crossFileCapable": true
    },
    {
      "symbolKind": "constant",
      "pattern": "\\b([A-Z_][A-Z0-9_]+)\\s*=",
      "importPattern": "from\\s+\\S+\\s+import\\s+.*\\b{name}\\b",
      "exportPattern": "__all__\\s*=.*\\b{name}\\b",
      "highlightKind": 1,
      "description": "Constant across modules",
      "crossFileCapable": true
    },
    {
      "symbolKind": "decorator",
      "pattern": "@(\\w+)",
      "importPattern": "from\\s+\\S+\\s+import\\s+.*\\b{name}\\b",
      "exportPattern": "\\bdef\\s+{name}\\b",
      "highlightKind": 1,
      "description": "Decorator across modules",
      "crossFileCapable": true
    },
    {
      "symbolKind": "module",
      "pattern": "import\\s+(\\w+)",
      "importPattern": "import\\s+{name}",
      "exportPattern": "",
      "highlightKind": 1,
      "description": "Module import",
      "crossFileCapable": true
    },
    {
      "symbolKind": "exception",
      "pattern": "\\bclass\\s+(\\w+Error|\\w+Exception)",
      "importPattern": "from\\s+\\S+\\s+import\\s+.*\\b{name}\\b",
      "exportPattern": "\\bclass\\s+{name}\\b",
      "highlightKind": 1,
      "description": "Exception class across modules",
      "crossFileCapable": true
    },
    {
      "kind": "function",
      "pattern": "def\\\\s+(\\\\w+)",
      "description": "Function declarations"
    },
    {
      "kind": "class",
      "pattern": "\\\\bclass\\\\s+([A-Z]\\\\w*)",
      "description": "Class declarations"
    },
    {
      "kind": "variable",
      "pattern": "(?:export|pub)\\\\s+(?:const|let|var)\\\\s+(\\\\w+)",
      "description": "Exported variables"
    },
    {
      "kind": "type",
      "pattern": "\\\\b(type|interface)\\\\s+([A-Z]\\\\w*)",
      "description": "Type/interface declarations"
    },
    {
      "kind": "constant",
      "pattern": "\\\\b(const|final|readonly)\\\\s+([A-Z_]\\\\w*)",
      "description": "Constant declarations"
    },
    {
      "kind": "enum",
      "pattern": "\\\\benum\\\\s+([A-Z]\\\\w*)",
      "description": "Enum declarations"
    },
    {
      "kind": "module",
      "pattern": "import\\\\s+(\\\\w+)",
      "description": "Module/namespace declarations"
    },
    {
      "kind": "interface",
      "pattern": "\\\\binterface\\\\s+([A-Z]\\\\w*)",
      "description": "Interface declarations"
    },
    {
      "kind": "method",
      "pattern": "\\\\b(public|private|protected)?\\\\s*\\\\w+\\\\s*\\\\(",
      "description": "Method declarations"
    },
    {
      "kind": "import",
      "pattern": "import\\\\s+(\\\\w+)",
      "description": "Import statements for cross-file resolution"
    }
  ],
  "importExportPatterns": {
    "importStatements": [
      "import\\s+(\\w+)",
      "from\\s+(\\w+)\\s+import\\s+(.+)",
      "from\\s+\\.(\\w*)\\s+import",
      "import\\s+(\\w+)\\s+as\\s+(\\w+)",
      "from\\s+(\\w+)\\s+import\\s+\\*",
      "__import__\\(['\"]([\\w.]+)['\"]\\)"
    ],
    "exportStatements": [
      "__all__\\s*=\\s*\\[([^\\]]+)\\]",
      "\\bdef\\s+(\\w+)",
      "\\bclass\\s+(\\w+)"
    ],
    "reExportStatements": [
      "from\\s+(\\w+)\\s+import\\s+(.+)"
    ]
  },
  "scopeRules": {
    "globalScope": {
      "patterns": [
        "\\b(\\w+)\\s*=\\s*",
        "\\bglobal\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "moduleScope": {
      "patterns": [
        "\\b(\\w+)\\s*=",
        "def\\s+(\\w+)",
        "class\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "classScope": {
      "patterns": [
        "\\bself\\.(\\w+)",
        "\\bcls\\.(\\w+)",
        "@classmethod"
      ],
      "highlightKind": 1
    },
    "functionScope": {
      "patterns": [
        "\\b(\\w+)\\s*=",
        "\\bdef\\s+(\\w+)"
      ],
      "highlightKind": 1
    },
    "blockScope": {
      "patterns": [
        "\\bfor\\s+(\\w+)\\s+in",
        "\\bwith\\s+.*\\bas\\s+(\\w+)"
      ],
      "highlightKind": 1
    }
  },
  "writeOperations": [
    "=",
    "+=",
    "-=",
    "*=",
    "/=",
    "//=",
    "**=",
    "%=",
    "&=",
    "|=",
    "^=",
    "<<=",
    ">>=",
    ".append(",
    ".extend(",
    ".insert(",
    ".remove(",
    ".pop(",
    ".clear(",
    ".sort(",
    ".reverse(",
    "del ",
    ".update(",
    ".add("
  ],
  "readOperations": [
    "len(",
    ".index(",
    ".count(",
    ".find(",
    ".startswith(",
    ".endswith(",
    "isinstance(",
    "type(",
    "getattr(",
    "hasattr(",
    "dir(",
    "vars(",
    ".items(",
    ".keys(",
    ".values(",
    "str(",
    "int(",
    "float(",
    "list(",
    "tuple(",
    "dict(",
    "set(",
    "sorted("
  ],
  "declarationPatterns": [
    "\\bdef\\s+(\\w+)",
    "\\bclass\\s+(\\w+)",
    "\\b(\\w+)\\s*=",
    "\\b(\\w+)\\s*:",
    "import\\s+(\\w+)"
  ],
  "referencePatterns": [
    "\\b(\\w+)\\(",
    "\\b(\\w+)\\s*\\.",
    "(\\w+)\\s*:",
    "isinstance\\(.*,\\s*(\\w+)\\)"
  ],
  "specialHighlights": {
    "typeReferences": true,
    "decorators": true,
    "comments": true
  }
}
