{
  "language": "nextjs",
  "linkPatterns": [
    {
      "pattern": "from\\s+['\"]next/image['\"]",
      "captureGroup": 0,
      "tooltip": "Next.js Image Optimization component",
      "urlTemplate": "https://nextjs.org/docs/app/api-reference/components/image"
    },
    {
      "pattern": "from\\s+['\"]next/link['\"]",
      "captureGroup": 0,
      "tooltip": "Next.js Link component for client-side navigation",
      "urlTemplate": "https://nextjs.org/docs/app/api-reference/components/link"
    },
    {
      "pattern": "from\\s+['\"]next/navigation['\"]",
      "captureGroup": 0,
      "tooltip": "Next.js navigation hooks and utilities (App Router)",
      "urlTemplate": "https://nextjs.org/docs/app/api-reference/functions"
    },
    {
      "pattern": "from\\s+['\"]next/font/google['\"]",
      "captureGroup": 0,
      "tooltip": "Next.js Google Font optimization",
      "urlTemplate": "https://nextjs.org/docs/app/building-your-application/optimizing/fonts"
    },
    {
      "pattern": "from\\s+['\"]next/font/local['\"]",
      "captureGroup": 0,
      "tooltip": "Next.js local font optimization",
      "urlTemplate": "https://nextjs.org/docs/app/building-your-application/optimizing/fonts"
    },
    {
      "pattern": "from\\s+['\"]next/script['\"]",
      "captureGroup": 0,
      "tooltip": "Next.js Script component for third-party scripts",
      "urlTemplate": "https://nextjs.org/docs/app/api-reference/components/script"
    },
    {
      "pattern": "from\\s+['\"]next/headers['\"]",
      "captureGroup": 0,
      "tooltip": "Next.js headers and cookies access (Server Components)",
      "urlTemplate": "https://nextjs.org/docs/app/api-reference/functions/headers"
    },
    {
      "pattern": "from\\s+['\"]next/server['\"]",
      "captureGroup": 0,
      "tooltip": "Next.js server utilities (NextRequest, NextResponse)",
      "urlTemplate": "https://nextjs.org/docs/app/api-reference/functions/next-request"
    },
    {
      "pattern": "from\\s+['\"]next/dynamic['\"]",
      "captureGroup": 0,
      "tooltip": "Next.js dynamic import with lazy loading",
      "urlTemplate": "https://nextjs.org/docs/app/building-your-application/optimizing/lazy-loading"
    },
    {
      "pattern": "from\\s+['\"]next/cache['\"]",
      "captureGroup": 0,
      "tooltip": "Next.js caching utilities (revalidatePath, revalidateTag, unstable_cache)",
      "urlTemplate": "https://nextjs.org/docs/app/api-reference/functions/revalidatePath"
    },
    {
      "pattern": "from\\s+['\"](\\.\\.?/[^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Relative module import"
    },
    {
      "pattern": "from\\s+['\"](@/[^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Aliased module import (@ = project root)"
    },
    {
      "pattern": "from\\s+['\"]([a-z@][a-z0-9/_.-]*)['\"]",
      "captureGroup": 1,
      "tooltip": "Package import from node_modules"
    },
    {
      "pattern": "(?:href|src)\\s*=\\s*['\"]((https?://)[^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "External URL"
    },
    {
      "pattern": "(?:next\\.config\\.(?:js|mjs|ts))",
      "captureGroup": 0,
      "tooltip": "Next.js configuration file",
      "urlTemplate": "https://nextjs.org/docs/app/api-reference/next-config-js"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    },
    {
      "pattern": "['\"](\\.{0,2}/[\\w./-]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open file path"
    },
    {
      "pattern": "(?:require|include|import|source|load)\\s*[('\"]+([\\w./-]+)",
      "captureGroup": 1,
      "tooltip": "Open relative path"
    },
    {
      "pattern": "(?:href|src|url)\\s*[=(]\\s*['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open stylesheet",
      "linkKind": "asset"
    },
    {
      "pattern": "(?:from|import)\\s+['\"]([./][^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open component",
      "linkKind": "module"
    }
  ]
}
