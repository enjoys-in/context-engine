{
  "language": "abap",
  "linkPatterns": [
    {
      "pattern": "INCLUDE\\s+(\\w+)",
      "captureGroup": 1,
      "tooltip": "Open INCLUDE program"
    },
    {
      "pattern": "REPORT\\s+(\\w+)",
      "captureGroup": 1,
      "tooltip": "Open REPORT program"
    },
    {
      "pattern": "TYPE-POOL\\s+(\\w+)",
      "captureGroup": 1,
      "tooltip": "Open TYPE-POOL"
    },
    {
      "pattern": "CLASS\\s+(\\w+)",
      "captureGroup": 1,
      "tooltip": "Go to class definition"
    },
    {
      "pattern": "INTERFACE\\s+(\\w+)",
      "captureGroup": 1,
      "tooltip": "Go to interface definition"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    },
    {
      "pattern": "['\"](\\.{0,2}/[\\w./-]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open file path"
    },
    {
      "pattern": "(?:require|include|import|source|load)\\s*[('\"]+([\\w./-]+)",
      "captureGroup": 1,
      "tooltip": "Open relative path"
    },
    {
      "pattern": "https?://[^\\s<>\"'\\)]+",
      "captureGroup": 0,
      "tooltip": "HTTP/HTTPS URL"
    },
    {
      "pattern": "(?:\\./|\\.\\./)\\S+",
      "captureGroup": 0,
      "tooltip": "Relative file path"
    },
    {
      "pattern": "/[\\w./\\-]+\\.\\w+",
      "captureGroup": 0,
      "tooltip": "Absolute file path"
    },
    {
      "pattern": "\\b[\\w.]+@[\\w.]+\\.[a-z]{2,}\\b",
      "captureGroup": 0,
      "tooltip": "Email address"
    },
    {
      "pattern": "file://[^\\s]+",
      "captureGroup": 0,
      "tooltip": "File URI"
    },
    {
      "pattern": "(?:ftp|ftps)://[^\\s]+",
      "captureGroup": 0,
      "tooltip": "FTP/FTPS URL"
    },
    {
      "pattern": "#\\w[\\w-]*",
      "captureGroup": 0,
      "tooltip": "Document anchor/fragment reference"
    }
  ]
}
