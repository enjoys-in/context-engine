{
  "language": "less",
  "linkPatterns": [
    {
      "pattern": "@import\\s+(?:\\([^)]*\\)\\s+)?\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open imported file"
    },
    {
      "pattern": "@import\\s+(?:\\([^)]*\\)\\s+)?'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open imported file"
    },
    {
      "pattern": "url\\(\"([^\"]+)\"\\)",
      "captureGroup": 1,
      "tooltip": "Open referenced resource"
    },
    {
      "pattern": "url\\('([^']+)'\\)",
      "captureGroup": 1,
      "tooltip": "Open referenced resource"
    },
    {
      "pattern": "url\\(([^)\"'\\s]+)\\)",
      "captureGroup": 1,
      "tooltip": "Open referenced resource"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    },
    {
      "pattern": "['\"](\\.{0,2}/[\\w./-]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open file path"
    },
    {
      "pattern": "(?:require|include|import|source|load)\\s*[('\"]+([\\w./-]+)",
      "captureGroup": 1,
      "tooltip": "Open relative path"
    },
    {
      "pattern": "(?:href|src|url)\\s*[=(]\\s*['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open stylesheet",
      "linkKind": "asset"
    },
    {
      "pattern": "(?:from|import)\\s+['\"]([./][^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open component",
      "linkKind": "module"
    },
    {
      "pattern": "https?://[^\\s<>\"'\\)]+",
      "captureGroup": 0,
      "tooltip": "HTTP/HTTPS URL"
    },
    {
      "pattern": "(?:\\./|\\.\\./)\\S+",
      "captureGroup": 0,
      "tooltip": "Relative file path"
    },
    {
      "pattern": "/[\\w./\\-]+\\.\\w+",
      "captureGroup": 0,
      "tooltip": "Absolute file path"
    },
    {
      "pattern": "\\b[\\w.]+@[\\w.]+\\.[a-z]{2,}\\b",
      "captureGroup": 0,
      "tooltip": "Email address"
    },
    {
      "pattern": "file://[^\\s]+",
      "captureGroup": 0,
      "tooltip": "File URI"
    }
  ]
}
