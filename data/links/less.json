{
  "language": "less",
  "linkPatterns": [
    {
      "pattern": "@import\\s+(?:\\([^)]*\\)\\s+)?\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open imported file"
    },
    {
      "pattern": "@import\\s+(?:\\([^)]*\\)\\s+)?'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open imported file"
    },
    {
      "pattern": "url\\(\"([^\"]+)\"\\)",
      "captureGroup": 1,
      "tooltip": "Open referenced resource"
    },
    {
      "pattern": "url\\('([^']+)'\\)",
      "captureGroup": 1,
      "tooltip": "Open referenced resource"
    },
    {
      "pattern": "url\\(([^)\"'\\s]+)\\)",
      "captureGroup": 1,
      "tooltip": "Open referenced resource"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
