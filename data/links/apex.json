{
  "language": "apex",
  "linkPatterns": [
    {
      "pattern": "import\\s+([\\w.]+);",
      "captureGroup": 1,
      "tooltip": "Open imported class"
    },
    {
      "pattern": "extends\\s+(\\w+)",
      "captureGroup": 1,
      "tooltip": "Go to parent class"
    },
    {
      "pattern": "implements\\s+(\\w+)",
      "captureGroup": 1,
      "tooltip": "Go to interface"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
