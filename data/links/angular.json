{
  "language": "angular",
  "linkPatterns": [
    {
      "pattern": "from\\s+['\"](@angular\\/core)['\"]",
      "captureGroup": 1,
      "tooltip": "Open Angular Core API docs",
      "urlTemplate": "https://angular.dev/api/core"
    },
    {
      "pattern": "from\\s+['\"](@angular\\/common)['\"]",
      "captureGroup": 1,
      "tooltip": "Open Angular Common API docs",
      "urlTemplate": "https://angular.dev/api/common"
    },
    {
      "pattern": "from\\s+['\"](@angular\\/common\\/http)['\"]",
      "captureGroup": 1,
      "tooltip": "Open Angular HTTP Client API docs",
      "urlTemplate": "https://angular.dev/api/common/http"
    },
    {
      "pattern": "from\\s+['\"](@angular\\/router)['\"]",
      "captureGroup": 1,
      "tooltip": "Open Angular Router API docs",
      "urlTemplate": "https://angular.dev/api/router"
    },
    {
      "pattern": "from\\s+['\"](@angular\\/forms)['\"]",
      "captureGroup": 1,
      "tooltip": "Open Angular Forms API docs",
      "urlTemplate": "https://angular.dev/api/forms"
    },
    {
      "pattern": "from\\s+['\"](@angular\\/platform-browser)['\"]",
      "captureGroup": 1,
      "tooltip": "Open Angular Platform Browser API docs",
      "urlTemplate": "https://angular.dev/api/platform-browser"
    },
    {
      "pattern": "from\\s+['\"](@angular\\/animations)['\"]",
      "captureGroup": 1,
      "tooltip": "Open Angular Animations API docs",
      "urlTemplate": "https://angular.dev/api/animations"
    },
    {
      "pattern": "from\\s+['\"](@angular\\/core\\/rxjs-interop)['\"]",
      "captureGroup": 1,
      "tooltip": "Open Angular RxJS Interop API docs",
      "urlTemplate": "https://angular.dev/api/core/rxjs-interop"
    },
    {
      "pattern": "templateUrl\\s*:\\s*['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open template file"
    },
    {
      "pattern": "styleUrls?\\s*:\\s*\\[?\\s*['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open stylesheet file"
    },
    {
      "pattern": "loadComponent\\s*:\\s*\\(\\)\\s*=>\\s*import\\(['\"]([^'\"]+)['\"]\\)",
      "captureGroup": 1,
      "tooltip": "Open lazy-loaded component module"
    },
    {
      "pattern": "loadChildren\\s*:\\s*\\(\\)\\s*=>\\s*import\\(['\"]([^'\"]+)['\"]\\)",
      "captureGroup": 1,
      "tooltip": "Open lazy-loaded child routes module"
    },
    {
      "pattern": "(?:from|import)\\s+['\"](\\.{1,2}\\/[^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open relative import"
    },
    {
      "pattern": "from\\s+['\"](@angular\\/[\\w\\-\\/]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open Angular package docs",
      "urlTemplate": "https://angular.dev/api/{1}"
    },
    {
      "pattern": "from\\s+['\"](rxjs(?:\\/operators)?)['\"]",
      "captureGroup": 1,
      "tooltip": "Open RxJS documentation",
      "urlTemplate": "https://rxjs.dev/api/{1}"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    },
    {
      "pattern": "['\"](\\.{0,2}/[\\w./-]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open file path"
    },
    {
      "pattern": "(?:require|include|import|source|load)\\s*[('\"]+([\\w./-]+)",
      "captureGroup": 1,
      "tooltip": "Open relative path"
    },
    {
      "pattern": "(?:href|src|url)\\s*[=(]\\s*['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open stylesheet",
      "linkKind": "asset"
    },
    {
      "pattern": "(?:from|import)\\s+['\"]([./][^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open component",
      "linkKind": "module"
    }
  ]
}
