{
  "language": "mdx",
  "linkPatterns": [
    {
      "pattern": "import\\s+(?:\\w+|\\{[^}]+\\})\\s+from\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open imported module"
    },
    {
      "pattern": "import\\s+(?:\\w+|\\{[^}]+\\})\\s+from\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open imported module"
    },
    {
      "pattern": "!\\[[^\\]]*\\]\\(([^)]+)\\)",
      "captureGroup": 1,
      "tooltip": "Open image"
    },
    {
      "pattern": "\\[[^\\]]*\\]\\(([^)]+)\\)",
      "captureGroup": 1,
      "tooltip": "Open link target"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    },
    {
      "pattern": "['\"](\\.{0,2}/[\\w./-]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open file path"
    },
    {
      "pattern": "(?:require|include|import|source|load)\\s*[('\"]+([\\w./-]+)",
      "captureGroup": 1,
      "tooltip": "Open relative path"
    },
    {
      "pattern": "(?:href|src|url)\\s*[=(]\\s*['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open stylesheet",
      "linkKind": "asset"
    },
    {
      "pattern": "(?:from|import)\\s+['\"]([./][^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open component",
      "linkKind": "module"
    },
    {
      "pattern": "https?://[^\\s<>\"'\\)]+",
      "kind": "url",
      "description": "HTTP/HTTPS URL"
    },
    {
      "pattern": "(?:\\./|\\.\\./)\\S+",
      "kind": "relative",
      "description": "Relative file path"
    },
    {
      "pattern": "/[\\w./\\-]+\\.\\w+",
      "kind": "absolute",
      "description": "Absolute file path"
    },
    {
      "pattern": "\\b[\\w.]+@[\\w.]+\\.[a-z]{2,}\\b",
      "kind": "email",
      "description": "Email address"
    },
    {
      "pattern": "file://[^\\s]+",
      "kind": "file-uri",
      "description": "File URI"
    },
    {
      "pattern": "(?:ftp|ftps)://[^\\s]+",
      "kind": "ftp",
      "description": "FTP/FTPS URL"
    }
  ]
}
