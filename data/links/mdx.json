{
  "language": "mdx",
  "linkPatterns": [
    {
      "pattern": "import\\s+(?:\\w+|\\{[^}]+\\})\\s+from\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open imported module"
    },
    {
      "pattern": "import\\s+(?:\\w+|\\{[^}]+\\})\\s+from\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open imported module"
    },
    {
      "pattern": "!\\[[^\\]]*\\]\\(([^)]+)\\)",
      "captureGroup": 1,
      "tooltip": "Open image"
    },
    {
      "pattern": "\\[[^\\]]*\\]\\(([^)]+)\\)",
      "captureGroup": 1,
      "tooltip": "Open link target"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
