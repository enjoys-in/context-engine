{
  "language": "cypher",
  "linkPatterns": [
    {
      "pattern": "LOAD\\s+CSV\\s+(?:WITH\\s+HEADERS\\s+)?FROM\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open CSV source"
    },
    {
      "pattern": "LOAD\\s+CSV\\s+(?:WITH\\s+HEADERS\\s+)?FROM\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open CSV source"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
