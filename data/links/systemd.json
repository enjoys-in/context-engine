{
  "language": "systemd",
  "linkPatterns": [
    {
      "pattern": "=\\s*(/[\\w./-]+)",
      "captureGroup": 1,
      "tooltip": "Open referenced path"
    },
    {
      "pattern": "\\.include\\s+([^\\s]+)",
      "captureGroup": 1,
      "tooltip": "Open included unit file"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
