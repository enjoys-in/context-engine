{
  "language": "scala",
  "linkPatterns": [
    {
      "pattern": "import\\s+([\\w.]+)\\.\\{",
      "captureGroup": 1,
      "tooltip": "Open Scala package documentation"
    },
    {
      "pattern": "import\\s+([\\w.]+)",
      "captureGroup": 1,
      "tooltip": "Open imported package/class"
    },
    {
      "pattern": "import\\s+([\\w.]+)\\.\\*",
      "captureGroup": 1,
      "tooltip": "Open wildcard import package"
    },
    {
      "pattern": "\"(https?://[^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open URL"
    },
    {
      "pattern": "s\"[^\"]*\\$(\\{[^}]+\\}|\\w+)",
      "captureGroup": 0,
      "tooltip": "String interpolation expression"
    },
    {
      "pattern": "//\\s*TODO.*?(https?://\\S+)",
      "captureGroup": 1,
      "tooltip": "Open linked URL"
    },
    {
      "pattern": "//\\s*see\\s+(https?://\\S+)",
      "captureGroup": 1,
      "tooltip": "Open documentation link"
    },
    {
      "pattern": "\"([\\w.-]+)\"\\s*%%?\\s*\"([\\w.-]+)\"\\s*%\\s*\"([\\w.-]+)\"",
      "captureGroup": 2,
      "tooltip": "Open sbt dependency on Maven Central",
      "urlTemplate": "https://mvnrepository.com/artifact/{capture}"
    },
    {
      "pattern": "libraryDependencies\\s*\\+=\\s*\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open library on Maven Central",
      "urlTemplate": "https://mvnrepository.com/artifact/{capture}"
    },
    {
      "pattern": "ivy\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open Mill dependency"
    },
    {
      "pattern": "//> using dep\\s+(\\S+)",
      "captureGroup": 1,
      "tooltip": "Open scala-cli dependency"
    },
    {
      "pattern": "@\\w+\\s*\\(\\s*\"(https?://\\S+)\"",
      "captureGroup": 1,
      "tooltip": "Open annotation URL"
    },
    {
      "pattern": "['\"](\\.{0,2}/[\\w./-]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open file path"
    },
    {
      "pattern": "(?:require|include|import|source|load)\\s*[('\"]+([\\w./-]+)",
      "captureGroup": 1,
      "tooltip": "Open relative path"
    },
    {
      "pattern": "(?:#include|import|use|using|package)\\s+[<\"]([^>\"]+)[>\"]",
      "captureGroup": 1,
      "tooltip": "Open header/module",
      "linkKind": "dependency"
    }
  ]
}
