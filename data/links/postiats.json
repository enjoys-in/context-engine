{
  "language": "postiats",
  "linkPatterns": [
    {
      "pattern": "#include\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open included file"
    },
    {
      "pattern": "staload\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open statically loaded file"
    },
    {
      "pattern": "dynload\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open dynamically loaded file"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
