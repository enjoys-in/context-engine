{
  "language": "qsharp",
  "linkPatterns": [
    {
      "pattern": "open\\s+([\\w.]+)",
      "captureGroup": 1,
      "tooltip": "Open Q# namespace"
    },
    {
      "pattern": "import\\s+([\\w.]+)",
      "captureGroup": 1,
      "tooltip": "Open imported namespace"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
