{
  "language": "freemarker2",
  "linkPatterns": [
    {
      "pattern": "<#import\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open imported template"
    },
    {
      "pattern": "<#include\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open included template"
    },
    {
      "pattern": "<#import\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open imported template"
    },
    {
      "pattern": "<#include\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open included template"
    },
    {
      "pattern": "\"(https?://[^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open URL"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
