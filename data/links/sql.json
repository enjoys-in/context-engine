{
  "language": "sql",
  "linkPatterns": [
    {
      "pattern": "@([^\\s;]+\\.sql)",
      "captureGroup": 1,
      "tooltip": "Open referenced SQL script"
    },
    {
      "pattern": "USE\\s+(\\w+)",
      "captureGroup": 1,
      "tooltip": "Go to database"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
