{
  "language": "docker-compose",
  "linkPatterns": [
    {
      "pattern": "image:\\s+([\\w.\\-/]+:[\\w.\\-]+)",
      "captureGroup": 1,
      "tooltip": "Open Docker Hub image",
      "urlTemplate": "https://hub.docker.com/_/{capture}"
    },
    {
      "pattern": "image:\\s+([\\w.\\-]+/[\\w.\\-]+:[\\w.\\-]+)",
      "captureGroup": 1,
      "tooltip": "Open Docker Hub image",
      "urlTemplate": "https://hub.docker.com/r/{capture}"
    },
    {
      "pattern": "env_file:\\s*-?\\s*['\"]?([\\w.\\-/]+\\.env[\\w.]*)['\"]?",
      "captureGroup": 1,
      "tooltip": "Open environment file"
    },
    {
      "pattern": "file:\\s*['\"]?([\\w.\\-/]+)['\"]?",
      "captureGroup": 1,
      "tooltip": "Open referenced file"
    },
    {
      "pattern": "context:\\s*['\"]?(\\.?[\\w.\\-/]+)['\"]?",
      "captureGroup": 1,
      "tooltip": "Open build context directory"
    },
    {
      "pattern": "dockerfile:\\s*['\"]?([\\w.\\-/]+)['\"]?",
      "captureGroup": 1,
      "tooltip": "Open Dockerfile"
    },
    {
      "pattern": "path:\\s*['\"]?(\\.?[\\w.\\-/]+)['\"]?",
      "captureGroup": 1,
      "tooltip": "Open referenced path"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    },
    {
      "pattern": "['\"](\\.{0,2}/[\\w./-]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open file path"
    },
    {
      "pattern": "(?:require|include|import|source|load)\\s*[('\"]+([\\w./-]+)",
      "captureGroup": 1,
      "tooltip": "Open relative path"
    },
    {
      "pattern": "[=:]\\s*['\"]?([./][\\w./-]+\\.[\\w]+)",
      "captureGroup": 1,
      "tooltip": "Open config reference",
      "linkKind": "file"
    },
    {
      "pattern": "https?://[^\\s<>\"'\\)]+",
      "captureGroup": 0,
      "tooltip": "HTTP/HTTPS URL"
    },
    {
      "pattern": "(?:\\./|\\.\\./)\\S+",
      "captureGroup": 0,
      "tooltip": "Relative file path"
    },
    {
      "pattern": "/[\\w./\\-]+\\.\\w+",
      "captureGroup": 0,
      "tooltip": "Absolute file path"
    },
    {
      "pattern": "\\b[\\w.]+@[\\w.]+\\.[a-z]{2,}\\b",
      "captureGroup": 0,
      "tooltip": "Email address"
    }
  ]
}
