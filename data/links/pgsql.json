{
  "language": "pgsql",
  "linkPatterns": [
    {
      "pattern": "\\\\i\\s+([^\\s;]+)",
      "captureGroup": 1,
      "tooltip": "Open included script"
    },
    {
      "pattern": "\\\\include\\s+([^\\s;]+)",
      "captureGroup": 1,
      "tooltip": "Open included script"
    },
    {
      "pattern": "\\\\ir\\s+([^\\s;]+)",
      "captureGroup": 1,
      "tooltip": "Open included script (relative)"
    },
    {
      "pattern": "\\\\include_relative\\s+([^\\s;]+)",
      "captureGroup": 1,
      "tooltip": "Open included script (relative)"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    },
    {
      "pattern": "['\"](\\.{0,2}/[\\w./-]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open file path"
    },
    {
      "pattern": "(?:require|include|import|source|load)\\s*[('\"]+([\\w./-]+)",
      "captureGroup": 1,
      "tooltip": "Open relative path"
    },
    {
      "pattern": "(?:FROM|JOIN|TABLE|SCHEMA|INDEX)\\s+[`'\"]?([\\w.]+)",
      "captureGroup": 1,
      "tooltip": "Open schema reference",
      "linkKind": "schema"
    },
    {
      "pattern": "https?://[^\\s<>\"'\\)]+",
      "kind": "url",
      "description": "HTTP/HTTPS URL"
    },
    {
      "pattern": "(?:\\./|\\.\\./)\\S+",
      "kind": "relative",
      "description": "Relative file path"
    },
    {
      "pattern": "/[\\w./\\-]+\\.\\w+",
      "kind": "absolute",
      "description": "Absolute file path"
    },
    {
      "pattern": "\\b[\\w.]+@[\\w.]+\\.[a-z]{2,}\\b",
      "kind": "email",
      "description": "Email address"
    },
    {
      "pattern": "file://[^\\s]+",
      "kind": "file-uri",
      "description": "File URI"
    },
    {
      "pattern": "(?:ftp|ftps)://[^\\s]+",
      "kind": "ftp",
      "description": "FTP/FTPS URL"
    },
    {
      "pattern": "#\\w[\\w-]*",
      "kind": "anchor",
      "description": "Document anchor/fragment reference"
    }
  ]
}
