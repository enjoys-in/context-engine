{
  "language": "pgsql",
  "linkPatterns": [
    {
      "pattern": "\\\\i\\s+([^\\s;]+)",
      "captureGroup": 1,
      "tooltip": "Open included script"
    },
    {
      "pattern": "\\\\include\\s+([^\\s;]+)",
      "captureGroup": 1,
      "tooltip": "Open included script"
    },
    {
      "pattern": "\\\\ir\\s+([^\\s;]+)",
      "captureGroup": 1,
      "tooltip": "Open included script (relative)"
    },
    {
      "pattern": "\\\\include_relative\\s+([^\\s;]+)",
      "captureGroup": 1,
      "tooltip": "Open included script (relative)"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
