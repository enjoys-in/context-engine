{
  "language": "yaml",
  "linkPatterns": [
    {
      "pattern": "\\$ref:\\s+['\"]?([^'\"\\s]+)",
      "captureGroup": 1,
      "tooltip": "Open $ref target"
    },
    {
      "pattern": "!include\\s+([^\\s]+)",
      "captureGroup": 1,
      "tooltip": "Open included file"
    },
    {
      "pattern": "file://([^\\s'\"]+)",
      "captureGroup": 1,
      "tooltip": "Open referenced file"
    },
    {
      "pattern": "\"(https?://[^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open URL"
    },
    {
      "pattern": "'(https?://[^']+)'",
      "captureGroup": 1,
      "tooltip": "Open URL"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
