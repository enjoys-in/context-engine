{
  "language": "systemverilog",
  "linkPatterns": [
    {
      "pattern": "`include\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open included file"
    },
    {
      "pattern": "import\\s+([\\w:]+)::",
      "captureGroup": 1,
      "tooltip": "Go to imported package"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
