{
  "language": "objective-c",
  "linkPatterns": [
    {
      "pattern": "#import\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open imported header"
    },
    {
      "pattern": "#import\\s+<([^>]+)>",
      "captureGroup": 1,
      "tooltip": "Open system header"
    },
    {
      "pattern": "#include\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open included header"
    },
    {
      "pattern": "#include\\s+<([^>]+)>",
      "captureGroup": 1,
      "tooltip": "Open system header"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
