{
  "language": "liquid",
  "linkPatterns": [
    {
      "pattern": "\\{%[-\\s]*include\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open included template"
    },
    {
      "pattern": "\\{%[-\\s]*include\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open included template"
    },
    {
      "pattern": "\\{%[-\\s]*render\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open rendered template"
    },
    {
      "pattern": "\\{%[-\\s]*render\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open rendered template"
    },
    {
      "pattern": "\\{%[-\\s]*layout\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open layout template"
    },
    {
      "pattern": "\\{%[-\\s]*section\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open section"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    },
    {
      "pattern": "['\"](\\.{0,2}/[\\w./-]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open file path"
    },
    {
      "pattern": "(?:require|include|import|source|load)\\s*[('\"]+([\\w./-]+)",
      "captureGroup": 1,
      "tooltip": "Open relative path"
    },
    {
      "pattern": "(?:href|src|url)\\s*[=(]\\s*['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open stylesheet",
      "linkKind": "asset"
    },
    {
      "pattern": "(?:from|import)\\s+['\"]([./][^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open component",
      "linkKind": "module"
    },
    {
      "pattern": "https?://[^\\s<>\"'\\)]+",
      "kind": "url",
      "description": "HTTP/HTTPS URL"
    },
    {
      "pattern": "(?:\\./|\\.\\./)\\S+",
      "kind": "relative",
      "description": "Relative file path"
    },
    {
      "pattern": "/[\\w./\\-]+\\.\\w+",
      "kind": "absolute",
      "description": "Absolute file path"
    },
    {
      "pattern": "\\b[\\w.]+@[\\w.]+\\.[a-z]{2,}\\b",
      "kind": "email",
      "description": "Email address"
    }
  ]
}
