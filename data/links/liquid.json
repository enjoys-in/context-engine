{
  "language": "liquid",
  "linkPatterns": [
    {
      "pattern": "\\{%[-\\s]*include\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open included template"
    },
    {
      "pattern": "\\{%[-\\s]*include\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open included template"
    },
    {
      "pattern": "\\{%[-\\s]*render\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open rendered template"
    },
    {
      "pattern": "\\{%[-\\s]*render\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open rendered template"
    },
    {
      "pattern": "\\{%[-\\s]*layout\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open layout template"
    },
    {
      "pattern": "\\{%[-\\s]*section\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open section"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
