{
  "language": "bash",
  "linkPatterns": [
    {
      "pattern": "(?:source|\\.)\\s+['\"]?([^'\"\\s]+)['\"]?",
      "captureGroup": 1,
      "tooltip": "Open sourced file"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    },
    {
      "pattern": "(?:cat|less|more|head|tail|wc|sort|grep|awk|sed|source|\\.)\\s+['\"]?(/[^'\"\\s]+)['\"]?",
      "captureGroup": 1,
      "tooltip": "Open file path"
    },
    {
      "pattern": "\\b(?:chmod|chown|chgrp|rm|cp|mv|mkdir|touch)\\s+(?:-[\\w]+\\s+)*['\"]?(/[^'\"\\s]+)['\"]?",
      "captureGroup": 1,
      "tooltip": "Open file path"
    },
    {
      "pattern": "['\"]?(~/[^'\"\\s]+)['\"]?",
      "captureGroup": 1,
      "tooltip": "Open home-relative path"
    },
    {
      "pattern": "\\$\\{?(?:BASH_SOURCE|0)\\}?",
      "captureGroup": 0,
      "tooltip": "Current script reference"
    },
    {
      "pattern": "(?:>|>>|<|2>|2>>|&>)\\s*['\"]?([^'\"\\s&;|]+)['\"]?",
      "captureGroup": 1,
      "tooltip": "Open redirected file"
    },
    {
      "pattern": "/(?:etc|usr|var|opt|tmp|home|dev|proc|sys)/[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open system path"
    },
    {
      "pattern": "\\bman\\s+(\\w[\\w.-]*)",
      "captureGroup": 1,
      "tooltip": "View man page",
      "urlTemplate": "https://man7.org/linux/man-pages/man1/{capture}.1.html"
    },
    {
      "pattern": "#\\s*(?:see|ref|link|docs?):\\s*(https?://[^\\s]+)",
      "captureGroup": 1,
      "tooltip": "Open reference link"
    }
  ]
}
