{
  "language": "coffee",
  "linkPatterns": [
    {
      "pattern": "require\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open required module"
    },
    {
      "pattern": "require\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open required module"
    },
    {
      "pattern": "require\\(\\s*'([^']+)'\\s*\\)",
      "captureGroup": 1,
      "tooltip": "Open required module"
    },
    {
      "pattern": "require\\(\\s*\"([^\"]+)\"\\s*\\)",
      "captureGroup": 1,
      "tooltip": "Open required module"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
