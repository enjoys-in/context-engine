{
  "language": "doctest",
  "linkPatterns": [
    {
      "pattern": ">>>\\s+import\\s+([\\w.]+)",
      "captureGroup": 1,
      "tooltip": "Open imported module"
    },
    {
      "pattern": ">>>\\s+from\\s+([\\w.]+)\\s+import",
      "captureGroup": 1,
      "tooltip": "Open imported module"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
