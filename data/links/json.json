{
  "language": "json",
  "linkPatterns": [
    {
      "pattern": "\"\\$ref\"\\s*:\\s*\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open $ref target"
    },
    {
      "pattern": "\"\\$schema\"\\s*:\\s*\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open JSON schema"
    },
    {
      "pattern": "\"(https?://[^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open URL"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
