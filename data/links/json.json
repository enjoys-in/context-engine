{
  "language": "json",
  "linkPatterns": [
    {
      "pattern": "\"\\$ref\"\\s*:\\s*\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open $ref target"
    },
    {
      "pattern": "\"\\$schema\"\\s*:\\s*\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open JSON schema"
    },
    {
      "pattern": "\"(https?://[^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open URL"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    },
    {
      "pattern": "['\"](\\.{0,2}/[\\w./-]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open file path"
    },
    {
      "pattern": "(?:require|include|import|source|load)\\s*[('\"]+([\\w./-]+)",
      "captureGroup": 1,
      "tooltip": "Open relative path"
    },
    {
      "pattern": "[=:]\\s*['\"]?([./][\\w./-]+\\.[\\w]+)",
      "captureGroup": 1,
      "tooltip": "Open config reference",
      "linkKind": "file"
    },
    {
      "pattern": "https?://[^\\s<>\"'\\)]+",
      "kind": "url",
      "description": "HTTP/HTTPS URL"
    },
    {
      "pattern": "(?:\\./|\\.\\./)\\S+",
      "kind": "relative",
      "description": "Relative file path"
    },
    {
      "pattern": "/[\\w./\\-]+\\.\\w+",
      "kind": "absolute",
      "description": "Absolute file path"
    },
    {
      "pattern": "\\b[\\w.]+@[\\w.]+\\.[a-z]{2,}\\b",
      "kind": "email",
      "description": "Email address"
    },
    {
      "pattern": "file://[^\\s]+",
      "kind": "file-uri",
      "description": "File URI"
    },
    {
      "pattern": "(?:ftp|ftps)://[^\\s]+",
      "kind": "ftp",
      "description": "FTP/FTPS URL"
    },
    {
      "pattern": "#\\w[\\w-]*",
      "kind": "anchor",
      "description": "Document anchor/fragment reference"
    },
    {
      "pattern": "\\bREADME(?:\\.md)?\\b",
      "kind": "readme",
      "description": "README file reference"
    }
  ]
}
