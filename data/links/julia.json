{
  "language": "julia",
  "linkPatterns": [
    {
      "pattern": "using\\s+([\\w.]+)",
      "captureGroup": 1,
      "tooltip": "Open used package"
    },
    {
      "pattern": "import\\s+([\\w.]+)",
      "captureGroup": 1,
      "tooltip": "Open imported module"
    },
    {
      "pattern": "include\\(\"([^\"]+)\"\\)",
      "captureGroup": 1,
      "tooltip": "Open included file"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
