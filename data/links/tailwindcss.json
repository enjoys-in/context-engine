{
  "language": "tailwindcss",
  "linkPatterns": [
    {
      "pattern": "@config\\s+['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open Tailwind configuration file: ${1}"
    },
    {
      "pattern": "@import\\s+['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open imported CSS file: ${1}"
    },
    {
      "pattern": "url\\(['\"]?([^)'\"]+)['\"]?\\)",
      "captureGroup": 1,
      "tooltip": "Open linked resource: ${1}"
    },
    {
      "pattern": "theme\\(['\"]([^'\"]+)['\"]\\)",
      "captureGroup": 1,
      "tooltip": "Resolve theme value from tailwind.config.js: ${1}"
    },
    {
      "pattern": "screen\\(['\"]([^'\"]+)['\"]\\)",
      "captureGroup": 1,
      "tooltip": "Resolve breakpoint from tailwind.config.js: ${1}"
    },
    {
      "pattern": "require\\(['\"]([^'\"]+)['\"]\\)",
      "captureGroup": 1,
      "tooltip": "Open required module: ${1}"
    },
    {
      "pattern": "content:\\s*\\[([^\\]]+)\\]",
      "captureGroup": 1,
      "tooltip": "Content paths for Tailwind class scanning"
    },
    {
      "pattern": "@source\\s+['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open source content path: ${1}"
    },
    {
      "pattern": "@plugin\\s+['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open Tailwind plugin: ${1}"
    },
    {
      "pattern": "from\\s+['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open imported module: ${1}"
    },
    {
      "pattern": "presets:\\s*\\[\\s*require\\(['\"]([^'\"]+)['\"]\\)",
      "captureGroup": 1,
      "tooltip": "Open Tailwind preset package: ${1}"
    },
    {
      "pattern": "plugins:\\s*\\[.*require\\(['\"]([^'\"]+)['\"]\\)",
      "captureGroup": 1,
      "tooltip": "Open Tailwind plugin package: ${1}"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    },
    {
      "pattern": "['\"](\\.{0,2}/[\\w./-]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open file path"
    },
    {
      "pattern": "(?:require|include|import|source|load)\\s*[('\"]+([\\w./-]+)",
      "captureGroup": 1,
      "tooltip": "Open relative path"
    },
    {
      "pattern": "(?:href|src|url)\\s*[=(]\\s*['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open stylesheet",
      "linkKind": "asset"
    },
    {
      "pattern": "(?:from|import)\\s+['\"]([./][^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open component",
      "linkKind": "module"
    }
  ]
}
