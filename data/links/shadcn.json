{
  "language": "shadcn",
  "linkPatterns": [
    {
      "pattern": "from\\s+['\"]@/components/ui/(\\w[\\w-]*)['\"]",
      "captureGroup": 1,
      "tooltip": "Open shadcn/ui component documentation",
      "urlTemplate": "https://ui.shadcn.com/docs/components/${1}"
    },
    {
      "pattern": "from\\s+['\"]@radix-ui/react-(\\w[\\w-]*)['\"]",
      "captureGroup": 1,
      "tooltip": "Open Radix UI primitive documentation",
      "urlTemplate": "https://www.radix-ui.com/primitives/docs/components/${1}"
    },
    {
      "pattern": "from\\s+['\"]class-variance-authority['\"]",
      "captureGroup": 0,
      "tooltip": "Open class-variance-authority (CVA) documentation",
      "urlTemplate": "https://cva.style/docs"
    },
    {
      "pattern": "from\\s+['\"]zod['\"]",
      "captureGroup": 0,
      "tooltip": "Open Zod schema validation documentation",
      "urlTemplate": "https://zod.dev"
    },
    {
      "pattern": "from\\s+['\"]react-hook-form['\"]",
      "captureGroup": 0,
      "tooltip": "Open React Hook Form documentation",
      "urlTemplate": "https://react-hook-form.com"
    },
    {
      "pattern": "from\\s+['\"]@hookform/resolvers/zod['\"]",
      "captureGroup": 0,
      "tooltip": "Open hookform/resolvers documentation",
      "urlTemplate": "https://github.com/react-hook-form/resolvers"
    },
    {
      "pattern": "from\\s+['\"]@/lib/utils['\"]",
      "captureGroup": 0,
      "tooltip": "Open local utils module (cn() utility)"
    },
    {
      "pattern": "from\\s+['\"]@tanstack/react-table['\"]",
      "captureGroup": 0,
      "tooltip": "Open TanStack Table documentation",
      "urlTemplate": "https://tanstack.com/table/latest"
    },
    {
      "pattern": "from\\s+['\"]clsx['\"]",
      "captureGroup": 0,
      "tooltip": "Open clsx documentation",
      "urlTemplate": "https://github.com/lukeed/clsx"
    },
    {
      "pattern": "from\\s+['\"]tailwind-merge['\"]",
      "captureGroup": 0,
      "tooltip": "Open tailwind-merge documentation",
      "urlTemplate": "https://github.com/dcastil/tailwind-merge"
    },
    {
      "pattern": "from\\s+['\"]cmdk['\"]",
      "captureGroup": 0,
      "tooltip": "Open cmdk command menu documentation",
      "urlTemplate": "https://cmdk.paco.me"
    },
    {
      "pattern": "from\\s+['\"]vaul['\"]",
      "captureGroup": 0,
      "tooltip": "Open vaul drawer documentation",
      "urlTemplate": "https://vaul.emilkowal.ski"
    },
    {
      "pattern": "from\\s+['\"]react-day-picker['\"]",
      "captureGroup": 0,
      "tooltip": "Open react-day-picker documentation",
      "urlTemplate": "https://react-day-picker.js.org"
    },
    {
      "pattern": "from\\s+['\"]embla-carousel-react['\"]",
      "captureGroup": 0,
      "tooltip": "Open Embla Carousel documentation",
      "urlTemplate": "https://www.embla-carousel.com"
    },
    {
      "pattern": "(?:from|import)\\s+['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open module/dependency"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}