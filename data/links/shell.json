{
  "language": "shell",
  "linkPatterns": [
    {
      "pattern": "source\\s+([^\\s;|&]+)",
      "captureGroup": 1,
      "tooltip": "Open sourced file"
    },
    {
      "pattern": "\\.\\s+([^\\s;|&]+)",
      "captureGroup": 1,
      "tooltip": "Open sourced file"
    },
    {
      "pattern": "\\$\\{?([A-Z_][A-Z0-9_]*)\\}?",
      "captureGroup": 1,
      "tooltip": "Go to environment variable"
    },
    {
      "pattern": "(?:^|\\s)(/[\\w./-]+)",
      "captureGroup": 1,
      "tooltip": "Open file path"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
