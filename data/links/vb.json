{
  "language": "vb",
  "linkPatterns": [
    {
      "pattern": "Imports\\s+([\\w.]+)",
      "captureGroup": 1,
      "tooltip": "Open imported namespace"
    },
    {
      "pattern": "Inherits\\s+([\\w.]+)",
      "captureGroup": 1,
      "tooltip": "Go to base class"
    },
    {
      "pattern": "Implements\\s+([\\w.]+)",
      "captureGroup": 1,
      "tooltip": "Go to interface"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
