{
  "language": "vb",
  "linkPatterns": [
    {
      "pattern": "Imports\\s+([\\w.]+)",
      "captureGroup": 1,
      "tooltip": "Open imported namespace"
    },
    {
      "pattern": "Inherits\\s+([\\w.]+)",
      "captureGroup": 1,
      "tooltip": "Go to base class"
    },
    {
      "pattern": "Implements\\s+([\\w.]+)",
      "captureGroup": 1,
      "tooltip": "Go to interface"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    },
    {
      "pattern": "['\"](\\.{0,2}/[\\w./-]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open file path"
    },
    {
      "pattern": "(?:require|include|import|source|load)\\s*[('\"]+([\\w./-]+)",
      "captureGroup": 1,
      "tooltip": "Open relative path"
    },
    {
      "pattern": "(?:#include|import|use|using|package)\\s+[<\"]([^>\"]+)[>\"]",
      "captureGroup": 1,
      "tooltip": "Open header/module",
      "linkKind": "dependency"
    },
    {
      "pattern": "https?://[^\\s<>\"'\\)]+",
      "captureGroup": 0,
      "tooltip": "HTTP/HTTPS URL"
    },
    {
      "pattern": "(?:\\./|\\.\\./)\\S+",
      "captureGroup": 0,
      "tooltip": "Relative file path"
    },
    {
      "pattern": "/[\\w./\\-]+\\.\\w+",
      "captureGroup": 0,
      "tooltip": "Absolute file path"
    },
    {
      "pattern": "\\b[\\w.]+@[\\w.]+\\.[a-z]{2,}\\b",
      "captureGroup": 0,
      "tooltip": "Email address"
    },
    {
      "pattern": "file://[^\\s]+",
      "captureGroup": 0,
      "tooltip": "File URI"
    },
    {
      "pattern": "(?:ftp|ftps)://[^\\s]+",
      "captureGroup": 0,
      "tooltip": "FTP/FTPS URL"
    },
    {
      "pattern": "#\\w[\\w-]*",
      "captureGroup": 0,
      "tooltip": "Document anchor/fragment reference"
    },
    {
      "pattern": "\\bREADME(?:\\.md)?\\b",
      "captureGroup": 0,
      "tooltip": "README file reference"
    }
  ]
}
