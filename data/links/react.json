{
  "language": "react",
  "linkPatterns": [
    {
      "pattern": "import\\s+(?:(?:\\{[^}]*\\}|\\*\\s+as\\s+\\w+|\\w+)\\s*,?\\s*)*\\s*from\\s+['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Navigate to module: ${1}"
    },
    {
      "pattern": "require\\s*\\(\\s*['\"]([^'\"]+)['\"]\\s*\\)",
      "captureGroup": 1,
      "tooltip": "Navigate to required module: ${1}"
    },
    {
      "pattern": "(?:React\\.)?lazy\\s*\\(\\s*\\(\\)\\s*=>\\s*import\\s*\\(\\s*['\"]([^'\"]+)['\"]\\s*\\)",
      "captureGroup": 1,
      "tooltip": "Navigate to lazy-loaded component: ${1}"
    },
    {
      "pattern": "import\\s*\\(\\s*['\"]([^'\"]+)['\"]\\s*\\)",
      "captureGroup": 1,
      "tooltip": "Navigate to dynamically imported module: ${1}"
    },
    {
      "pattern": "from\\s+['\"](\\.{1,2}/[^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Navigate to relative file: ${1}"
    },
    {
      "pattern": "import\\s+['\"]([^'\"]+\\.css)['\"]",
      "captureGroup": 1,
      "tooltip": "Navigate to CSS file: ${1}"
    },
    {
      "pattern": "import\\s+\\w+\\s+from\\s+['\"]([^'\"]+\\.module\\.(?:css|scss|less))['\"]",
      "captureGroup": 1,
      "tooltip": "Navigate to CSS Module: ${1}"
    },
    {
      "pattern": "import\\s+\\w+\\s+from\\s+['\"]([^'\"]+\\.(?:png|jpg|jpeg|gif|svg|webp|ico))['\"]",
      "captureGroup": 1,
      "tooltip": "Navigate to image asset: ${1}"
    },
    {
      "pattern": "https?://react\\.dev/reference/[^\\s'\"`)]+",
      "captureGroup": 0,
      "tooltip": "Open React documentation"
    },
    {
      "pattern": "https?://(?:www\\.)?npmjs\\.com/package/[^\\s'\"`)]+",
      "captureGroup": 0,
      "tooltip": "Open npm package page"
    },
    {
      "pattern": "https?://github\\.com/[^\\s'\"`)]+",
      "captureGroup": 0,
      "tooltip": "Open GitHub repository"
    },
    {
      "pattern": "import\\s+['\"]([^'\"]+\\.(?:scss|sass|less))['\"]",
      "captureGroup": 1,
      "tooltip": "Navigate to stylesheet: ${1}"
    },
    {
      "pattern": "import\\s+\\w+\\s+from\\s+['\"]([^'\"]+\\.json)['\"]",
      "captureGroup": 1,
      "tooltip": "Navigate to JSON file: ${1}"
    },
    {
      "pattern": "/// <reference\\s+path=['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Navigate to TypeScript reference: ${1}"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    },
    {
      "pattern": "['\"](\\.{0,2}/[\\w./-]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open file path"
    },
    {
      "pattern": "(?:require|include|import|source|load)\\s*[('\"]+([\\w./-]+)",
      "captureGroup": 1,
      "tooltip": "Open relative path"
    },
    {
      "pattern": "(?:href|src|url)\\s*[=(]\\s*['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open stylesheet",
      "linkKind": "asset"
    },
    {
      "pattern": "(?:from|import)\\s+['\"]([./][^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open component",
      "linkKind": "module"
    }
  ]
}
