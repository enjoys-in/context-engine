{
  "language": "elixir",
  "linkPatterns": [
    {
      "pattern": "import\\s+([A-Z][\\w.]*)",
      "captureGroup": 1,
      "tooltip": "Open imported module"
    },
    {
      "pattern": "alias\\s+([A-Z][\\w.]*)",
      "captureGroup": 1,
      "tooltip": "Open aliased module"
    },
    {
      "pattern": "require\\s+([A-Z][\\w.]*)",
      "captureGroup": 1,
      "tooltip": "Open required module"
    },
    {
      "pattern": "use\\s+([A-Z][\\w.]*)",
      "captureGroup": 1,
      "tooltip": "Open used module"
    },
    {
      "pattern": "@external_resource\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open external resource"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
