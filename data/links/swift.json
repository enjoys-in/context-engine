{
  "language": "swift",
  "linkPatterns": [
    {
      "pattern": "import\\s+(\\w+)",
      "captureGroup": 1,
      "tooltip": "Open Apple documentation",
      "urlTemplate": "https://developer.apple.com/documentation/{capture}"
    },
    {
      "pattern": "\"(https?://[^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open URL"
    },
    {
      "pattern": "\\.package\\s*\\(\\s*url:\\s*\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open package repository URL"
    },
    {
      "pattern": "\\.package\\s*\\(\\s*name:\\s*\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Search package on Swift Package Index",
      "urlTemplate": "https://swiftpackageindex.com/search?query={capture}"
    },
    {
      "pattern": "///\\s*.*?(https?://\\S+)",
      "captureGroup": 1,
      "tooltip": "Open linked URL in doc comment"
    },
    {
      "pattern": "//\\s*TODO.*?(https?://\\S+)",
      "captureGroup": 1,
      "tooltip": "Open linked URL"
    },
    {
      "pattern": "//\\s*FIXME.*?(https?://\\S+)",
      "captureGroup": 1,
      "tooltip": "Open linked URL"
    },
    {
      "pattern": "@available\\(.*?(https?://\\S+)",
      "captureGroup": 1,
      "tooltip": "Open availability URL"
    },
    {
      "pattern": "['\"](\\.{0,2}/[\\w./-]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open file path"
    },
    {
      "pattern": "(?:require|include|import|source|load)\\s*[('\"]+([\\w./-]+)",
      "captureGroup": 1,
      "tooltip": "Open relative path"
    },
    {
      "pattern": "(?:#include|import|use|using|package)\\s+[<\"]([^>\"]+)[>\"]",
      "captureGroup": 1,
      "tooltip": "Open header/module",
      "linkKind": "dependency"
    },
    {
      "pattern": "https?://[^\\s<>\"'\\)]+",
      "captureGroup": 0,
      "tooltip": "HTTP/HTTPS URL"
    },
    {
      "pattern": "(?:\\./|\\.\\./)\\S+",
      "captureGroup": 0,
      "tooltip": "Relative file path"
    },
    {
      "pattern": "/[\\w./\\-]+\\.\\w+",
      "captureGroup": 0,
      "tooltip": "Absolute file path"
    },
    {
      "pattern": "\\b[\\w.]+@[\\w.]+\\.[a-z]{2,}\\b",
      "captureGroup": 0,
      "tooltip": "Email address"
    }
  ]
}
