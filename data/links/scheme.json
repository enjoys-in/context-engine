{
  "language": "scheme",
  "linkPatterns": [
    {
      "pattern": "\\(import\\s+\\(?([\\w./-]+)",
      "captureGroup": 1,
      "tooltip": "Open imported library"
    },
    {
      "pattern": "\\(require\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open required file"
    },
    {
      "pattern": "\\(require\\s+'([\\w./-]+)",
      "captureGroup": 1,
      "tooltip": "Open required module"
    },
    {
      "pattern": "\\(load\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open loaded file"
    },
    {
      "pattern": "\\(include\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open included file"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
