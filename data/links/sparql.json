{
  "language": "sparql",
  "linkPatterns": [
    {
      "pattern": "PREFIX\\s+\\w*:\\s*<([^>]+)>",
      "captureGroup": 1,
      "tooltip": "Open namespace URI"
    },
    {
      "pattern": "<(https?://[^>]+)>",
      "captureGroup": 1,
      "tooltip": "Open IRI"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
