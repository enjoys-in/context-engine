{
  "language": "powershell",
  "linkPatterns": [
    {
      "pattern": "(?:Import-Module|using\\\\s+module)\\\\s+([\\\\w.-]+)",
      "captureGroup": 1,
      "tooltip": "Open module/dependency"
    },
    {
      "pattern": "https?://[^\\\\s'\"`,;)\\\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
