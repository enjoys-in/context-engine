{
  "language": "pascal",
  "linkPatterns": [
    {
      "pattern": "uses\\s+([\\w,\\s]+);",
      "captureGroup": 1,
      "tooltip": "Open used unit"
    },
    {
      "pattern": "\\{\\$I\\s+([^}]+)\\}",
      "captureGroup": 1,
      "tooltip": "Open include file"
    },
    {
      "pattern": "\\{\\$INCLUDE\\s+([^}]+)\\}",
      "captureGroup": 1,
      "tooltip": "Open include file"
    },
    {
      "pattern": "\\{\\$R\\s+([^}]+)\\}",
      "captureGroup": 1,
      "tooltip": "Open resource file"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
