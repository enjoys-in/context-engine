{
  "language": "clojure",
  "linkPatterns": [
    {
      "pattern": "\\(require\\s+'\\[?([\\w.-]+)",
      "captureGroup": 1,
      "tooltip": "Open required namespace"
    },
    {
      "pattern": "\\(use\\s+'\\[?([\\w.-]+)",
      "captureGroup": 1,
      "tooltip": "Open used namespace"
    },
    {
      "pattern": ":require\\s+\\[([\\w.-]+)",
      "captureGroup": 1,
      "tooltip": "Open required namespace"
    },
    {
      "pattern": ":import\\s+\\[?([\\w.-]+)",
      "captureGroup": 1,
      "tooltip": "Open imported class"
    },
    {
      "pattern": "\\(load\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open loaded file"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
