{
  "language": "powerquery",
  "linkPatterns": [
    {
      "pattern": "#\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Go to step reference"
    },
    {
      "pattern": "=\\s+([A-Z]\\w+)\\.([A-Z]\\w+)",
      "captureGroup": 0,
      "tooltip": "Go to data source function"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
