{
  "language": "r",
  "linkPatterns": [
    {
      "pattern": "(?:library|require)\\\\s*\\\\(\\\\s*[\"']?([\\\\w.]+)[\"']?\\\\s*\\\\)",
      "captureGroup": 1,
      "tooltip": "Open package documentation"
    },
    {
      "pattern": "source\\\\s*\\\\(\\\\s*[\"']([^\"']+)[\"']\\\\s*\\\\)",
      "captureGroup": 1,
      "tooltip": "Open sourced R file"
    },
    {
      "pattern": "https?://[^\\\\s'\"`,;)\\\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    },
    {
      "pattern": "['\"](\\.{0,2}/[\\w./-]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open file path"
    },
    {
      "pattern": "(?:require|include|import|source|load)\\s*[('\"]+([\\w./-]+)",
      "captureGroup": 1,
      "tooltip": "Open relative path"
    },
    {
      "pattern": "(?:require|import|use|load|include|source)\\s+['\"]?([\\w./-]+)",
      "captureGroup": 1,
      "tooltip": "Open module",
      "linkKind": "module"
    },
    {
      "pattern": "https?://[^\\s<>\"'\\)]+",
      "kind": "url",
      "description": "HTTP/HTTPS URL"
    },
    {
      "pattern": "(?:\\./|\\.\\./)\\S+",
      "kind": "relative",
      "description": "Relative file path"
    },
    {
      "pattern": "/[\\w./\\-]+\\.\\w+",
      "kind": "absolute",
      "description": "Absolute file path"
    },
    {
      "pattern": "\\b[\\w.]+@[\\w.]+\\.[a-z]{2,}\\b",
      "kind": "email",
      "description": "Email address"
    },
    {
      "pattern": "file://[^\\s]+",
      "kind": "file-uri",
      "description": "File URI"
    },
    {
      "pattern": "(?:ftp|ftps)://[^\\s]+",
      "kind": "ftp",
      "description": "FTP/FTPS URL"
    },
    {
      "pattern": "#\\w[\\w-]*",
      "kind": "anchor",
      "description": "Document anchor/fragment reference"
    },
    {
      "pattern": "\\bREADME(?:\\.md)?\\b",
      "kind": "readme",
      "description": "README file reference"
    },
    {
      "pattern": "\\bLICENSE\\b",
      "kind": "license",
      "description": "LICENSE file reference"
    }
  ]
}
