{
  "language": "restructuredtext",
  "linkPatterns": [
    {
      "pattern": "\\.\\.\\s+include::\\s+([^\\s]+)",
      "captureGroup": 1,
      "tooltip": "Open included file"
    },
    {
      "pattern": "\\.\\.\\s+image::\\s+([^\\s]+)",
      "captureGroup": 1,
      "tooltip": "Open image file"
    },
    {
      "pattern": "\\.\\.\\s+figure::\\s+([^\\s]+)",
      "captureGroup": 1,
      "tooltip": "Open figure file"
    },
    {
      "pattern": ":doc:`([^`]+)`",
      "captureGroup": 1,
      "tooltip": "Open referenced document"
    },
    {
      "pattern": ":ref:`([^`]+)`",
      "captureGroup": 1,
      "tooltip": "Go to reference target"
    },
    {
      "pattern": ":download:`([^`]+)`",
      "captureGroup": 1,
      "tooltip": "Open download target"
    },
    {
      "pattern": "`([^`]+)`_",
      "captureGroup": 1,
      "tooltip": "Go to link target"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    },
    {
      "pattern": "['\"](\\.{0,2}/[\\w./-]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open file path"
    },
    {
      "pattern": "(?:require|include|import|source|load)\\s*[('\"]+([\\w./-]+)",
      "captureGroup": 1,
      "tooltip": "Open relative path"
    },
    {
      "pattern": "https?://[^\\s<>\"'\\)]+",
      "captureGroup": 0,
      "tooltip": "HTTP/HTTPS URL"
    },
    {
      "pattern": "(?:\\./|\\.\\./)\\S+",
      "captureGroup": 0,
      "tooltip": "Relative file path"
    },
    {
      "pattern": "/[\\w./\\-]+\\.\\w+",
      "captureGroup": 0,
      "tooltip": "Absolute file path"
    },
    {
      "pattern": "\\b[\\w.]+@[\\w.]+\\.[a-z]{2,}\\b",
      "captureGroup": 0,
      "tooltip": "Email address"
    },
    {
      "pattern": "file://[^\\s]+",
      "captureGroup": 0,
      "tooltip": "File URI"
    }
  ]
}
