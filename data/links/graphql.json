{
  "language": "graphql",
  "linkPatterns": [
    {
      "pattern": "#import\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open imported schema"
    },
    {
      "pattern": "#import\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open imported schema"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
