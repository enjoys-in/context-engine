{
  "language": "scss",
  "linkPatterns": [
    {
      "pattern": "@import\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open imported file"
    },
    {
      "pattern": "@import\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open imported file"
    },
    {
      "pattern": "@use\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open used module"
    },
    {
      "pattern": "@use\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open used module"
    },
    {
      "pattern": "@forward\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open forwarded module"
    },
    {
      "pattern": "@forward\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open forwarded module"
    },
    {
      "pattern": "url\\(\"([^\"]+)\"\\)",
      "captureGroup": 1,
      "tooltip": "Open referenced resource"
    },
    {
      "pattern": "url\\('([^']+)'\\)",
      "captureGroup": 1,
      "tooltip": "Open referenced resource"
    },
    {
      "pattern": "url\\(([^)\"'\\s]+)\\)",
      "captureGroup": 1,
      "tooltip": "Open referenced resource"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    },
    {
      "pattern": "['\"](\\.{0,2}/[\\w./-]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open file path"
    },
    {
      "pattern": "(?:require|include|import|source|load)\\s*[('\"]+([\\w./-]+)",
      "captureGroup": 1,
      "tooltip": "Open relative path"
    },
    {
      "pattern": "(?:href|src|url)\\s*[=(]\\s*['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open stylesheet",
      "linkKind": "asset"
    },
    {
      "pattern": "(?:from|import)\\s+['\"]([./][^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open component",
      "linkKind": "module"
    },
    {
      "pattern": "https?://[^\\s<>\"'\\)]+",
      "captureGroup": 0,
      "tooltip": "HTTP/HTTPS URL"
    }
  ]
}
