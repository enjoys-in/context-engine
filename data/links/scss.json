{
  "language": "scss",
  "linkPatterns": [
    {
      "pattern": "@import\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open imported file"
    },
    {
      "pattern": "@import\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open imported file"
    },
    {
      "pattern": "@use\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open used module"
    },
    {
      "pattern": "@use\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open used module"
    },
    {
      "pattern": "@forward\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open forwarded module"
    },
    {
      "pattern": "@forward\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open forwarded module"
    },
    {
      "pattern": "url\\(\"([^\"]+)\"\\)",
      "captureGroup": 1,
      "tooltip": "Open referenced resource"
    },
    {
      "pattern": "url\\('([^']+)'\\)",
      "captureGroup": 1,
      "tooltip": "Open referenced resource"
    },
    {
      "pattern": "url\\(([^)\"'\\s]+)\\)",
      "captureGroup": 1,
      "tooltip": "Open referenced resource"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
