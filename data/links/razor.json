{
  "language": "razor",
  "linkPatterns": [
    {
      "pattern": "@using\\s+([\\w.]+)",
      "captureGroup": 1,
      "tooltip": "Open imported namespace"
    },
    {
      "pattern": "@model\\s+([\\w.]+)",
      "captureGroup": 1,
      "tooltip": "Go to model type"
    },
    {
      "pattern": "@inject\\s+([\\w.]+)",
      "captureGroup": 1,
      "tooltip": "Go to injected service"
    },
    {
      "pattern": "@addTagHelper\\s+\\*,\\s+([\\w.]+)",
      "captureGroup": 1,
      "tooltip": "Go to Tag Helper assembly"
    },
    {
      "pattern": "src=\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open referenced resource"
    },
    {
      "pattern": "href=\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open referenced resource"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
