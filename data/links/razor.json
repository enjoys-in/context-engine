{
  "language": "razor",
  "linkPatterns": [
    {
      "pattern": "@using\\s+([\\w.]+)",
      "captureGroup": 1,
      "tooltip": "Open imported namespace"
    },
    {
      "pattern": "@model\\s+([\\w.]+)",
      "captureGroup": 1,
      "tooltip": "Go to model type"
    },
    {
      "pattern": "@inject\\s+([\\w.]+)",
      "captureGroup": 1,
      "tooltip": "Go to injected service"
    },
    {
      "pattern": "@addTagHelper\\s+\\*,\\s+([\\w.]+)",
      "captureGroup": 1,
      "tooltip": "Go to Tag Helper assembly"
    },
    {
      "pattern": "src=\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open referenced resource"
    },
    {
      "pattern": "href=\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open referenced resource"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    },
    {
      "pattern": "['\"](\\.{0,2}/[\\w./-]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open file path"
    },
    {
      "pattern": "(?:require|include|import|source|load)\\s*[('\"]+([\\w./-]+)",
      "captureGroup": 1,
      "tooltip": "Open relative path"
    },
    {
      "pattern": "(?:href|src|url)\\s*[=(]\\s*['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open stylesheet",
      "linkKind": "asset"
    },
    {
      "pattern": "(?:from|import)\\s+['\"]([./][^'\"]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open component",
      "linkKind": "module"
    },
    {
      "pattern": "https?://[^\\s<>\"'\\)]+",
      "captureGroup": 0,
      "tooltip": "HTTP/HTTPS URL"
    },
    {
      "pattern": "(?:\\./|\\.\\./)\\S+",
      "captureGroup": 0,
      "tooltip": "Relative file path"
    },
    {
      "pattern": "/[\\w./\\-]+\\.\\w+",
      "captureGroup": 0,
      "tooltip": "Absolute file path"
    },
    {
      "pattern": "\\b[\\w.]+@[\\w.]+\\.[a-z]{2,}\\b",
      "captureGroup": 0,
      "tooltip": "Email address"
    }
  ]
}
