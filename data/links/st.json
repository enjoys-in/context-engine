{
  "language": "st",
  "linkPatterns": [
    {
      "pattern": "'([A-Z][\\w]+)'",
      "captureGroup": 1,
      "tooltip": "Go to referenced class/symbol"
    },
    {
      "pattern": "fileIn:\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open filed-in file"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
