{
  "language": "azcli",
  "linkPatterns": [
    {
      "pattern": "--([a-z-]+)",
      "captureGroup": 1,
      "tooltip": "Go to parameter definition"
    },
    {
      "pattern": "az\\s+([a-z][a-z-]*(?:\\s+[a-z][a-z-]*){0,2})",
      "captureGroup": 1,
      "tooltip": "Look up az CLI command"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    },
    {
      "pattern": "['\"](\\.{0,2}/[\\w./-]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open file path"
    },
    {
      "pattern": "(?:require|include|import|source|load)\\s*[('\"]+([\\w./-]+)",
      "captureGroup": 1,
      "tooltip": "Open relative path"
    },
    {
      "pattern": "https?://[^\\s<>\"'\\)]+",
      "kind": "url",
      "description": "HTTP/HTTPS URL"
    },
    {
      "pattern": "(?:\\./|\\.\\./)\\S+",
      "kind": "relative",
      "description": "Relative file path"
    },
    {
      "pattern": "/[\\w./\\-]+\\.\\w+",
      "kind": "absolute",
      "description": "Absolute file path"
    },
    {
      "pattern": "\\b[\\w.]+@[\\w.]+\\.[a-z]{2,}\\b",
      "kind": "email",
      "description": "Email address"
    },
    {
      "pattern": "file://[^\\s]+",
      "kind": "file-uri",
      "description": "File URI"
    },
    {
      "pattern": "(?:ftp|ftps)://[^\\s]+",
      "kind": "ftp",
      "description": "FTP/FTPS URL"
    },
    {
      "pattern": "#\\w[\\w-]*",
      "kind": "anchor",
      "description": "Document anchor/fragment reference"
    },
    {
      "pattern": "\\bREADME(?:\\.md)?\\b",
      "kind": "readme",
      "description": "README file reference"
    },
    {
      "pattern": "\\bLICENSE\\b",
      "kind": "license",
      "description": "LICENSE file reference"
    },
    {
      "pattern": "\\bpackage\\.json\\b",
      "kind": "package",
      "description": "Package manifest reference"
    }
  ]
}
