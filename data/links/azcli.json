{
  "language": "azcli",
  "linkPatterns": [
    {
      "pattern": "--([a-z-]+)",
      "captureGroup": 1,
      "tooltip": "Go to parameter definition"
    },
    {
      "pattern": "az\\s+([a-z][a-z-]*(?:\\s+[a-z][a-z-]*){0,2})",
      "captureGroup": 1,
      "tooltip": "Look up az CLI command"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
