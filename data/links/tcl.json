{
  "language": "tcl",
  "linkPatterns": [
    {
      "pattern": "package\\s+require\\s+([\\w:]+)",
      "captureGroup": 1,
      "tooltip": "Open required package"
    },
    {
      "pattern": "source\\s+([^\\s;]+)",
      "captureGroup": 1,
      "tooltip": "Open sourced file"
    },
    {
      "pattern": "package\\s+require\\s+-exact\\s+([\\w:]+)",
      "captureGroup": 1,
      "tooltip": "Open required package"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
