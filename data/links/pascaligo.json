{
  "language": "pascaligo",
  "linkPatterns": [
    {
      "pattern": "#include\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open included file"
    },
    {
      "pattern": "#import\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open imported file"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
