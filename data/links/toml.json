{
  "language": "toml",
  "linkPatterns": [
    {
      "pattern": "=\\s*\"([\\w./][\\w./-]+\\.[\\w]+)\"",
      "captureGroup": 1,
      "tooltip": "Open referenced file"
    },
    {
      "pattern": "=\\s*'([\\w./][\\w./-]+\\.[\\w]+)'",
      "captureGroup": 1,
      "tooltip": "Open referenced file"
    },
    {
      "pattern": "\"(https?://[^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open URL"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
