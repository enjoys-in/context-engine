{
  "language": "bicep",
  "linkPatterns": [
    {
      "pattern": "import\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open imported module"
    },
    {
      "pattern": "module\\s+\\w+\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open Bicep module file"
    },
    {
      "pattern": "loadTextContent\\('([^']+)'\\)",
      "captureGroup": 1,
      "tooltip": "Open referenced file"
    },
    {
      "pattern": "loadJsonContent\\('([^']+)'\\)",
      "captureGroup": 1,
      "tooltip": "Open referenced JSON file"
    },
    {
      "pattern": "'(https?://[^']+)'",
      "captureGroup": 1,
      "tooltip": "Open URL"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    },
    {
      "pattern": "['\"](\\.{0,2}/[\\w./-]+)['\"]",
      "captureGroup": 1,
      "tooltip": "Open file path"
    },
    {
      "pattern": "(?:require|include|import|source|load)\\s*[('\"]+([\\w./-]+)",
      "captureGroup": 1,
      "tooltip": "Open relative path"
    },
    {
      "pattern": "[=:]\\s*['\"]?([./][\\w./-]+\\.[\\w]+)",
      "captureGroup": 1,
      "tooltip": "Open config reference",
      "linkKind": "file"
    },
    {
      "pattern": "https?://[^\\s<>\"'\\)]+",
      "kind": "url",
      "description": "HTTP/HTTPS URL"
    },
    {
      "pattern": "(?:\\./|\\.\\./)\\S+",
      "kind": "relative",
      "description": "Relative file path"
    },
    {
      "pattern": "/[\\w./\\-]+\\.\\w+",
      "kind": "absolute",
      "description": "Absolute file path"
    },
    {
      "pattern": "\\b[\\w.]+@[\\w.]+\\.[a-z]{2,}\\b",
      "kind": "email",
      "description": "Email address"
    },
    {
      "pattern": "file://[^\\s]+",
      "kind": "file-uri",
      "description": "File URI"
    },
    {
      "pattern": "(?:ftp|ftps)://[^\\s]+",
      "kind": "ftp",
      "description": "FTP/FTPS URL"
    }
  ]
}
