{
  "language": "bicep",
  "linkPatterns": [
    {
      "pattern": "import\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open imported module"
    },
    {
      "pattern": "module\\s+\\w+\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open Bicep module file"
    },
    {
      "pattern": "loadTextContent\\('([^']+)'\\)",
      "captureGroup": 1,
      "tooltip": "Open referenced file"
    },
    {
      "pattern": "loadJsonContent\\('([^']+)'\\)",
      "captureGroup": 1,
      "tooltip": "Open referenced JSON file"
    },
    {
      "pattern": "'(https?://[^']+)'",
      "captureGroup": 1,
      "tooltip": "Open URL"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
