{
  "language": "mysql",
  "linkPatterns": [
    {
      "pattern": "SOURCE\\s+([^\\s;]+)",
      "captureGroup": 1,
      "tooltip": "Open sourced script"
    },
    {
      "pattern": "\\\\\\.\\s+([^\\s;]+)",
      "captureGroup": 1,
      "tooltip": "Open sourced script"
    },
    {
      "pattern": "USE\\s+(\\w+)",
      "captureGroup": 1,
      "tooltip": "Go to database"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
