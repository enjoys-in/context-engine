{
  "language": "awk",
  "linkPatterns": [
    {
      "pattern": "@include\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open included file"
    },
    {
      "pattern": "@load\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open loaded extension"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
