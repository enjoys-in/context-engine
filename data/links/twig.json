{
  "language": "twig",
  "linkPatterns": [
    {
      "pattern": "\\{%[-\\s]*include\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open included template"
    },
    {
      "pattern": "\\{%[-\\s]*include\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open included template"
    },
    {
      "pattern": "\\{%[-\\s]*extends\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open parent template"
    },
    {
      "pattern": "\\{%[-\\s]*extends\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open parent template"
    },
    {
      "pattern": "\\{%[-\\s]*import\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open imported template"
    },
    {
      "pattern": "\\{%[-\\s]*import\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open imported template"
    },
    {
      "pattern": "\\{%[-\\s]*embed\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open embedded template"
    },
    {
      "pattern": "\\{%[-\\s]*embed\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open embedded template"
    },
    {
      "pattern": "\\{%[-\\s]*from\\s+'([^']+)'",
      "captureGroup": 1,
      "tooltip": "Open source template"
    },
    {
      "pattern": "\\{%[-\\s]*from\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "tooltip": "Open source template"
    },
    {
      "pattern": "https?://[^\\s'\"`,;)\\]>]+",
      "captureGroup": 0,
      "tooltip": "Open URL"
    }
  ]
}
