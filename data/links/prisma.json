{
  "language": "prisma",
  "linkPatterns": [
    {
      "pattern": "///.*?(https?://[^\\s]+)",
      "captureGroup": 1,
      "tooltip": "Open URL"
    },
    {
      "pattern": "//.*?(https?://[^\\s]+)",
      "captureGroup": 1,
      "tooltip": "Open URL"
    },
    {
      "pattern": "provider\\s*=\\s*\"(prisma-client-js)\"",
      "captureGroup": 1,
      "tooltip": "Prisma Client documentation",
      "urlTemplate": "https://www.prisma.io/docs/orm/prisma-client"
    }
  ]
}