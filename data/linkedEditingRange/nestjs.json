{
  "language": "nestjs",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "linkedEditingPatterns": [
    {
      "description": "Generic type parameter pairs",
      "openPattern": "<(\\w+)>",
      "closePattern": "<(\\w+)>",
      "captureGroup": 1
    },
    {
      "description": "Template literal variable",
      "pattern": "\\$\\{(\\w+)\\}",
      "captureGroup": 1
    }
  ],
  "supported": true
}
