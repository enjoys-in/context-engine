{
  "language": "nestjs",
  "linkedEditingRanges": {
    "patterns": [
      { "description": "Generic type parameter pairs", "openPattern": "<(\\w+)>", "closePattern": "<(\\w+)>", "captureGroup": 1 },
      { "description": "Template literal variable", "pattern": "\\$\\{(\\w+)\\}", "captureGroup": 1 }
    ],
    "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*"
  }
}