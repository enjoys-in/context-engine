{
  "language": "ruby",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*[!?]?",
  "linkedEditingPatterns": [
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Matching curly brace pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Matching square bracket pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Matching parenthesis pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Parenthesis pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Square bracket pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Block brace pair (hash/block)"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bdef\\s+(\\w+)",
      "closePattern": "\\bend\\b",
      "description": "Method def/end pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bclass\\s+(\\w+)",
      "closePattern": "\\bend\\b",
      "description": "Class def/end pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bmodule\\s+(\\w+)",
      "closePattern": "\\bend\\b",
      "description": "Module def/end pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bdo\\b",
      "closePattern": "\\bend\\b",
      "description": "Do/end block pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bif\\b",
      "closePattern": "\\bend\\b",
      "description": "If/end pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bunless\\b",
      "closePattern": "\\bend\\b",
      "description": "Unless/end pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bwhile\\b",
      "closePattern": "\\bend\\b",
      "description": "While/end pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\buntil\\b",
      "closePattern": "\\bend\\b",
      "description": "Until/end pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bcase\\b",
      "closePattern": "\\bend\\b",
      "description": "Case/end pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bbegin\\b",
      "closePattern": "\\bend\\b",
      "description": "Begin/rescue/end pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bfor\\b",
      "closePattern": "\\bend\\b",
      "description": "For/end pair"
    },
    {
      "type": "string_pair",
      "openPattern": "%q\\[",
      "closePattern": "\\]",
      "description": "Percent string literal pair"
    },
    {
      "type": "comment_pair",
      "openPattern": "=begin",
      "closePattern": "=end",
      "description": "Multi-line comment pair"
    },
    {
      "type": "string_pair",
      "openPattern": "<<~?(\\w+)",
      "closePattern": "\\1",
      "description": "Heredoc delimiter pair"
    }
  ],
  "supported": true
}
