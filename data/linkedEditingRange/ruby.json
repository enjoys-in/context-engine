{
  "language": "ruby",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_!?]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "\\b(def|class|module|do|if|unless|while|until|case|begin|for)\\b",
      "closePattern": "\\bend\\b",
      "description": "Ruby block keyword/end pair synchronization"
    },
    {
      "kind": "tag",
      "pattern": "<(\\w+)[^>]*>.*?</\\1>",
      "description": "Linked editing for matching HTML/XML tags"
    },
    {
      "kind": "variable",
      "pattern": "\\b(\\w+)\\b",
      "description": "Linked editing for variable references"
    }
  ],
  "supported": true
}
