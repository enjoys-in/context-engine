{
  "language": "shadcn",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "<([a-zA-Z][a-zA-Z0-9.]*)(?:\\s[^>]*)?>",
      "closePattern": "</([a-zA-Z][a-zA-Z0-9.]*)\\s*>",
      "description": "JSX/TSX tag pair synchronization"
    },
    {
      "type": "tag_pair",
      "openPattern": "<([A-Z][a-zA-Z0-9.]*)(?:\\s[^>]*)?>",
      "closePattern": "</([A-Z][a-zA-Z0-9.]*)\\s*>",
      "description": "Component tag pair synchronization"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Matching curly brace pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Matching square bracket pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Matching parenthesis pairs"
    },
    {
      "type": "string_pair",
      "openPattern": "\"",
      "closePattern": "\"",
      "description": "Double-quoted string pair"
    },
    {
      "type": "string_pair",
      "openPattern": "'",
      "closePattern": "'",
      "description": "Single-quoted string pair"
    }
  ],
  "supported": true
}
