{
  "language": "java",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "linkedEditingPatterns": [
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Matching curly brace pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Matching square bracket pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Matching parenthesis pairs"
    },
    {
      "type": "scope_pair",
      "openPattern": "class\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Class declaration scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "interface\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Interface declaration scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "enum\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Enum declaration scope"
    },
    {
      "type": "type_pair",
      "openPattern": "<",
      "closePattern": ">",
      "description": "Generic type parameters"
    },
    {
      "type": "annotation_pair",
      "openPattern": "@(\\w+)\\(",
      "closePattern": "\\)",
      "description": "Annotation with arguments"
    },
    {
      "type": "string_pair",
      "openPattern": "\"\"\"",
      "closePattern": "\"\"\"",
      "description": "Text block delimiters"
    },
    {
      "type": "comment_pair",
      "openPattern": "/\\*\\*",
      "closePattern": "\\*/",
      "description": "Javadoc comment pair"
    },
    {
      "type": "comment_pair",
      "openPattern": "/\\*",
      "closePattern": "\\*/",
      "description": "Block comment pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "try\\s*\\{",
      "closePattern": "catch|finally",
      "description": "Try/catch/finally block"
    },
    {
      "type": "scope_pair",
      "openPattern": "switch\\s*\\(",
      "closePattern": "\\}",
      "description": "Switch statement scope"
    }
  ],
  "supported": true
}
