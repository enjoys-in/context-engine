{
  "language": "razor",
  "wordPattern": "[a-zA-Z][a-zA-Z0-9-]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "<([a-zA-Z][a-zA-Z0-9-]*)(?:\\s[^>]*)?>",
      "closePattern": "</([a-zA-Z][a-zA-Z0-9-]*)\\s*>",
      "description": "Razor/HTML open/close tag name synchronization"
    },
    {
      "type": "tag_pair",
      "openPattern": "<([A-Z][a-zA-Z0-9]*)(?:\\s[^>]*)?>",
      "closePattern": "</([A-Z][a-zA-Z0-9]*)\\s*>",
      "description": "Blazor component tag name synchronization"
    },
    {
      "kind": "tag",
      "pattern": "<(\\w+)[^>]*>.*?</\\1>",
      "description": "Linked editing for matching HTML/XML tags"
    }
  ],
  "supported": true
}
