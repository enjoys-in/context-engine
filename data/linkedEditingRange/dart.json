{
  "language": "dart",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "linkedEditingPatterns": [
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Matching curly brace pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Matching square bracket pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Matching parenthesis pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Parenthesis pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Square bracket pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Block brace pair"
    },
    {
      "type": "type_pair",
      "openPattern": "<",
      "closePattern": ">",
      "description": "Generic type parameters"
    },
    {
      "type": "scope_pair",
      "openPattern": "class\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Class scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "mixin\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Mixin scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "extension\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Extension scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "enum\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Enum scope"
    },
    {
      "type": "string_pair",
      "openPattern": "'''",
      "closePattern": "'''",
      "description": "Triple single-quoted string pair"
    },
    {
      "type": "string_pair",
      "openPattern": "\"\"\"",
      "closePattern": "\"\"\"",
      "description": "Triple double-quoted string pair"
    },
    {
      "type": "annotation_pair",
      "openPattern": "@(\\w+)\\(",
      "closePattern": "\\)",
      "description": "Annotation argument pair"
    },
    {
      "type": "comment_pair",
      "openPattern": "/\\*",
      "closePattern": "\\*/",
      "description": "Block comment pair"
    }
  ],
  "supported": true
}
