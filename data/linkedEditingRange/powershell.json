{
  "language": "powershell",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$-]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Matching curly brace pairs"
    },
    {
      "type": "tag_pair",
      "openPattern": "#region\\s+(.*)",
      "closePattern": "#endregion",
      "description": "PowerShell #region/#endregion pair"
    },
    {
      "kind": "tag",
      "pattern": "<(\\w+)[^>]*>.*?</\\1>",
      "description": "Linked editing for matching HTML/XML tags"
    }
  ],
  "supported": true
}
