{
  "language": "powershell",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_-]*",
  "linkedEditingPatterns": [
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Parenthesis pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Square bracket pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "ScriptBlock brace pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bfunction\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Function scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bif\\s*\\(",
      "closePattern": "\\}",
      "description": "If block scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bforeach\\s*\\(",
      "closePattern": "\\}",
      "description": "Foreach scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bfor\\s*\\(",
      "closePattern": "\\}",
      "description": "For scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bwhile\\s*\\(",
      "closePattern": "\\}",
      "description": "While scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bswitch\\s*\\(",
      "closePattern": "\\}",
      "description": "Switch scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\btry\\s*\\{",
      "closePattern": "\\}",
      "description": "Try block scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bclass\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Class scope"
    },
    {
      "type": "string_pair",
      "openPattern": "@\"",
      "closePattern": "\"@",
      "description": "Here-string double pair"
    },
    {
      "type": "string_pair",
      "openPattern": "@'",
      "closePattern": "'@",
      "description": "Here-string single pair"
    },
    {
      "type": "comment_pair",
      "openPattern": "<#",
      "closePattern": "#>",
      "description": "Block comment pair"
    },
    {
      "type": "variable_pair",
      "openPattern": "\\$\\(",
      "closePattern": "\\)",
      "description": "Subexpression pair"
    }
  ],
  "supported": true
}
