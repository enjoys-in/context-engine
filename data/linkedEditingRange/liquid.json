{
  "language": "liquid",
  "wordPattern": "[a-zA-Z][a-zA-Z0-9_-]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "<([a-zA-Z][a-zA-Z0-9-]*)(?:\\s[^>]*)?>",
      "closePattern": "</([a-zA-Z][a-zA-Z0-9-]*)\\s*>",
      "description": "HTML open/close tag name synchronization in Liquid templates"
    },
    {
      "type": "tag_pair",
      "openPattern": "\\{%[-\\s]*([a-zA-Z_]+)\\b",
      "closePattern": "\\{%[-\\s]*end([a-zA-Z_]+)\\s*-?%\\}",
      "description": "Liquid block tag pairs ({% if %}...{% endif %})"
    }
  ],
  "supported": true
}
