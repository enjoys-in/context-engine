{
  "language": "coffee",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "\\b(if|for|while|switch|class|try)\\b",
      "closePattern": "\\b(else|catch|finally)\\b",
      "description": "CoffeeScript block keyword pair synchronization"
    }
  ],
  "supported": true
}
