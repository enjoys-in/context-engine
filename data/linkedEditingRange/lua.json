{
  "language": "lua",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "\\b(function|if|for|while|do|repeat)\\b",
      "closePattern": "\\b(end|until)\\b",
      "description": "Lua block keyword/end pair synchronization"
    }
  ],
  "supported": true
}
