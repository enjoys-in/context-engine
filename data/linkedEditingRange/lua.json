{
  "language": "lua",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "linkedEditingPatterns": [
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Matching curly brace pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Matching square bracket pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Matching parenthesis pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Parenthesis pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Square bracket pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Table brace pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bfunction\\b",
      "closePattern": "\\bend\\b",
      "description": "Function/end pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bif\\b",
      "closePattern": "\\bend\\b",
      "description": "If/end pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bfor\\b",
      "closePattern": "\\bend\\b",
      "description": "For/end pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bwhile\\b",
      "closePattern": "\\bend\\b",
      "description": "While/end pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\brepeat\\b",
      "closePattern": "\\buntil\\b",
      "description": "Repeat/until pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bdo\\b",
      "closePattern": "\\bend\\b",
      "description": "Do/end pair"
    },
    {
      "type": "string_pair",
      "openPattern": "\\[=*\\[",
      "closePattern": "\\]=*\\]",
      "description": "Long string bracket pair"
    },
    {
      "type": "comment_pair",
      "openPattern": "--\\[=*\\[",
      "closePattern": "\\]=*\\]",
      "description": "Long comment bracket pair"
    }
  ],
  "supported": true
}
