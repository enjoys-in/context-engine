{
  "language": "docker-compose",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_.-]*",
  "linkedEditingPatterns": [
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Block brace pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Section bracket pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Parenthesis pair"
    },
    {
      "type": "string_pair",
      "openPattern": "\"",
      "closePattern": "\"",
      "description": "Double-quoted string pair"
    },
    {
      "type": "string_pair",
      "openPattern": "'",
      "closePattern": "'",
      "description": "Single-quoted string pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\w+:",
      "closePattern": "(?=^\\S)",
      "description": "YAML mapping scope"
    },
    {
      "type": "string_pair",
      "openPattern": "\\|",
      "closePattern": "(?=^\\S)",
      "description": "YAML block scalar pair"
    },
    {
      "type": "string_pair",
      "openPattern": ">",
      "closePattern": "(?=^\\S)",
      "description": "YAML folded scalar pair"
    }
  ],
  "supported": true
}
