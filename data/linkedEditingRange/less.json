{
  "language": "less",
  "wordPattern": "[a-zA-Z_@][a-zA-Z0-9_-]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "([.#&][a-zA-Z_-][a-zA-Z0-9_-]*)\\s*\\{",
      "closePattern": "\\}",
      "description": "Less nested selector and closing brace pair"
    },
    {
      "type": "tag_pair",
      "openPattern": "\\.([a-zA-Z_-][a-zA-Z0-9_-]*)\\s*\\(",
      "closePattern": "\\.([a-zA-Z_-][a-zA-Z0-9_-]*)\\s*;",
      "description": "Less mixin definition and usage name synchronization"
    },
    {
      "kind": "tag",
      "pattern": "<(\\w+)[^>]*>.*?</\\1>",
      "description": "Linked editing for matching HTML/XML tags"
    }
  ],
  "supported": true
}
