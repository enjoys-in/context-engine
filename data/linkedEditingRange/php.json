{
  "language": "php",
  "wordPattern": "\\$?[a-zA-Z_\\x80-\\xff][a-zA-Z0-9_\\x80-\\xff]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "<([a-zA-Z][a-zA-Z0-9:-]*)(?:\\s[^>]*)?>",
      "closePattern": "</([a-zA-Z][a-zA-Z0-9:-]*)\\s*>",
      "description": "HTML/XML tag pair synchronization"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Matching curly brace pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Matching square bracket pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Matching parenthesis pairs"
    },
    {
      "type": "tag_pair",
      "openPattern": "<([a-zA-Z][a-zA-Z0-9:-]*)(?:\\s[^>]*)?>",
      "closePattern": "</([a-zA-Z][a-zA-Z0-9:-]*)\\s*>",
      "description": "HTML tag pair in PHP templates"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Parenthesis pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Array bracket pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Block brace pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "class\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Class scope pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "interface\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Interface scope pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "trait\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Trait scope pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "function\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Function scope pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "if\\s*\\(",
      "closePattern": "endif;?|\\}",
      "description": "If block scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "foreach\\s*\\(",
      "closePattern": "endforeach;?|\\}",
      "description": "Foreach scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "while\\s*\\(",
      "closePattern": "endwhile;?|\\}",
      "description": "While scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "switch\\s*\\(",
      "closePattern": "endswitch;?|\\}",
      "description": "Switch scope"
    },
    {
      "type": "string_pair",
      "openPattern": "<<<['\"]?(\\w+)['\"]?",
      "closePattern": "\\1;?",
      "description": "Heredoc/nowdoc delimiter pair"
    },
    {
      "type": "attribute_pair",
      "openPattern": "#\\[",
      "closePattern": "\\]",
      "description": "PHP 8 attribute pair"
    },
    {
      "type": "comment_pair",
      "openPattern": "/\\*",
      "closePattern": "\\*/",
      "description": "Block comment pair"
    }
  ],
  "supported": true
}
