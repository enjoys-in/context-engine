{
  "language": "php",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_-]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "<([a-zA-Z][a-zA-Z0-9-]*)(?:\\s[^>]*)?>",
      "closePattern": "</([a-zA-Z][a-zA-Z0-9-]*)\\s*>",
      "description": "HTML open/close tag name synchronization in PHP"
    },
    {
      "type": "tag_pair",
      "openPattern": "<\\?php\\s.*?\\bif\\b",
      "closePattern": "<\\?php\\s.*?\\bendif\\b",
      "description": "PHP alternative syntax block pairs (if/endif)"
    }
  ],
  "supported": true
}
