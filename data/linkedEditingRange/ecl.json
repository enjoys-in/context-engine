{
  "language": "ecl",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "\\b(FUNCTION|MODULE|RECORD|BEGINC\\+\\+|TRANSFORM|MACRO)\\b",
      "closePattern": "\\b(END|ENDC\\+\\+|ENDMACRO)\\b",
      "description": "ECL block keyword open/close pair"
    }
  ],
  "supported": true
}
