{
  "language": "pgsql",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "\\bBEGIN\\b",
      "closePattern": "\\bEND\\b",
      "description": "PostgreSQL BEGIN/END block pair"
    },
    {
      "type": "tag_pair",
      "openPattern": "\\$([a-zA-Z_]*)\\$",
      "closePattern": "\\$([a-zA-Z_]*)\\$",
      "description": "PostgreSQL dollar-quoted string tag synchronization"
    },
    {
      "kind": "tag",
      "pattern": "<(\\w+)[^>]*>.*?</\\1>",
      "description": "Linked editing for matching HTML/XML tags"
    }
  ],
  "supported": true
}
