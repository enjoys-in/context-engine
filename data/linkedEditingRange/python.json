{
  "language": "python",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "\\bdef\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "closePattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "description": "Function definition and call name synchronization"
    },
    {
      "kind": "tag",
      "pattern": "<(\\w+)[^>]*>.*?</\\1>",
      "description": "Linked editing for matching HTML/XML tags"
    },
    {
      "kind": "variable",
      "pattern": "\\b(\\w+)\\b",
      "description": "Linked editing for variable references"
    }
  ],
  "supported": true
}
