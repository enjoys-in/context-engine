{
  "language": "python",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "linkedEditingPatterns": [
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Parenthesis pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Square bracket pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Curly brace pair (dict/set)"
    },
    {
      "type": "string_pair",
      "openPattern": "\"\"\"",
      "closePattern": "\"\"\"",
      "description": "Triple-quoted string pair (double)"
    },
    {
      "type": "string_pair",
      "openPattern": "'''",
      "closePattern": "'''",
      "description": "Triple-quoted string pair (single)"
    },
    {
      "type": "scope_pair",
      "openPattern": "def\\s+(\\w+)\\s*\\(",
      "closePattern": "\\):",
      "description": "Function definition signature"
    },
    {
      "type": "scope_pair",
      "openPattern": "class\\s+(\\w+)",
      "closePattern": ":",
      "description": "Class definition header"
    },
    {
      "type": "scope_pair",
      "openPattern": "if\\s+",
      "closePattern": ":",
      "description": "If statement header"
    },
    {
      "type": "scope_pair",
      "openPattern": "for\\s+",
      "closePattern": ":",
      "description": "For loop header"
    },
    {
      "type": "scope_pair",
      "openPattern": "with\\s+",
      "closePattern": ":",
      "description": "With statement header"
    },
    {
      "type": "scope_pair",
      "openPattern": "try:",
      "closePattern": "except|finally",
      "description": "Try/except/finally block"
    },
    {
      "type": "decorator_pair",
      "openPattern": "@(\\w+)",
      "closePattern": "def\\s+",
      "description": "Decorator and decorated function"
    }
  ],
  "supported": true
}
