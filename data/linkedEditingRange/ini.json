{
  "language": "ini",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "linkedEditingPatterns": [
    {
      "type": "section_reference",
      "openPattern": "\\[([\\w.-]+)\\]",
      "closePattern": "\\b([\\w.-]+)\\b",
      "description": "Linked editing for INI section names"
    },
    {
      "kind": "tag",
      "pattern": "<(\\w+)[^>]*>.*?</\\1>",
      "description": "Linked editing for matching HTML/XML tags"
    },
    {
      "kind": "variable",
      "pattern": "\\b(\\w+)\\b",
      "description": "Linked editing for variable references"
    }
  ],
  "supported": false
}
