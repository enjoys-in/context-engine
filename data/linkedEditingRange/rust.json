{
  "language": "rust",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*'?",
  "linkedEditingPatterns": [
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Matching curly brace pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Matching square bracket pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Matching parenthesis pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Parenthesis pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Square bracket pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Block brace pair"
    },
    {
      "type": "type_pair",
      "openPattern": "<",
      "closePattern": ">",
      "description": "Generic/lifetime angle brackets"
    },
    {
      "type": "scope_pair",
      "openPattern": "fn\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Function scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "struct\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Struct scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "enum\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Enum scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "impl\\s+",
      "closePattern": "\\}",
      "description": "Impl block scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "trait\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Trait scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "mod\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Module scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "match\\s+",
      "closePattern": "\\}",
      "description": "Match expression scope"
    },
    {
      "type": "attribute_pair",
      "openPattern": "#\\[",
      "closePattern": "\\]",
      "description": "Attribute bracket pair"
    },
    {
      "type": "attribute_pair",
      "openPattern": "#!\\[",
      "closePattern": "\\]",
      "description": "Inner attribute bracket pair"
    },
    {
      "type": "string_pair",
      "openPattern": "r#*\"",
      "closePattern": "\"#*",
      "description": "Raw string literal pair"
    },
    {
      "type": "comment_pair",
      "openPattern": "/\\*",
      "closePattern": "\\*/",
      "description": "Block comment pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "unsafe\\s*\\{",
      "closePattern": "\\}",
      "description": "Unsafe block scope"
    }
  ],
  "supported": true
}
