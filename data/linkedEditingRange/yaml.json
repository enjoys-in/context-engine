{
  "language": "yaml",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_-]*",
  "linkedEditingPatterns": [
    {
      "type": "key_value",
      "openPattern": "([\\w.-]+):\\s",
      "closePattern": "\\b([\\w.-]+)\\b",
      "description": "Linked editing for YAML keys"
    },
    {
      "kind": "tag",
      "pattern": "<(\\w+)[^>]*>.*?</\\1>",
      "description": "Linked editing for matching HTML/XML tags"
    },
    {
      "kind": "variable",
      "pattern": "\\b(\\w+)\\b",
      "description": "Linked editing for variable references"
    }
  ],
  "supported": false
}
