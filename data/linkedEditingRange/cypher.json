{
  "language": "cypher",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "linkedEditingPatterns": [
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Parenthesis pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Block brace pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Square bracket pair"
    },
    {
      "type": "string_pair",
      "openPattern": "\"",
      "closePattern": "\"",
      "description": "Double-quoted string pair"
    },
    {
      "type": "string_pair",
      "openPattern": "'",
      "closePattern": "'",
      "description": "Single-quoted string pair"
    }
  ],
  "supported": true
}
