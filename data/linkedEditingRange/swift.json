{
  "language": "swift",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "linkedEditingPatterns": [
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Matching curly brace pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Matching square bracket pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Matching parenthesis pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Parenthesis pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Array/dict bracket pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Block brace pair"
    },
    {
      "type": "type_pair",
      "openPattern": "<",
      "closePattern": ">",
      "description": "Generic type parameters"
    },
    {
      "type": "scope_pair",
      "openPattern": "func\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Function scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "class\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Class scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "struct\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Struct scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "enum\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Enum scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "protocol\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Protocol scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "extension\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Extension scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "actor\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Actor scope"
    },
    {
      "type": "string_pair",
      "openPattern": "\"\"\"",
      "closePattern": "\"\"\"",
      "description": "Multiline string pair"
    },
    {
      "type": "preprocessor_pair",
      "openPattern": "#if\\b",
      "closePattern": "#endif",
      "description": "Conditional compilation pair"
    },
    {
      "type": "comment_pair",
      "openPattern": "/\\*",
      "closePattern": "\\*/",
      "description": "Block comment pair"
    }
  ],
  "supported": true
}
