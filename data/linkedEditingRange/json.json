{
  "language": "json",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "linkedEditingPatterns": [
    {
      "type": "key_reference",
      "openPattern": "\"([^\"]+)\"\\s*:",
      "closePattern": "\"([^\"]+)\"",
      "description": "Linked editing for JSON key references"
    },
    {
      "kind": "tag",
      "pattern": "<(\\w+)[^>]*>.*?</\\1>",
      "description": "Linked editing for matching HTML/XML tags"
    },
    {
      "kind": "variable",
      "pattern": "\\b(\\w+)\\b",
      "description": "Linked editing for variable references"
    }
  ],
  "supported": false
}
