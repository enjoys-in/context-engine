{
  "language": "cpp",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Matching curly brace pairs"
    },
    {
      "type": "tag_pair",
      "openPattern": "#ifdef\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "closePattern": "#endif",
      "description": "Preprocessor #ifdef/#endif pair"
    },
    {
      "kind": "tag",
      "pattern": "<(\\w+)[^>]*>.*?</\\1>",
      "description": "Linked editing for matching HTML/XML tags"
    }
  ],
  "supported": true
}
