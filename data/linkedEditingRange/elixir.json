{
  "language": "elixir",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*[!?]?",
  "linkedEditingPatterns": [
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Matching curly brace pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Matching square bracket pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Matching parenthesis pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Parenthesis pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "List bracket pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Tuple/map brace pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bdo\\b",
      "closePattern": "\\bend\\b",
      "description": "Do/end block pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bdef\\s+(\\w+)",
      "closePattern": "\\bend\\b",
      "description": "Function def/end pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bdefp\\s+(\\w+)",
      "closePattern": "\\bend\\b",
      "description": "Private function def/end pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bdefmodule\\s+(\\w+)",
      "closePattern": "\\bend\\b",
      "description": "Module def/end pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bdefmacro\\s+(\\w+)",
      "closePattern": "\\bend\\b",
      "description": "Macro def/end pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bcase\\b",
      "closePattern": "\\bend\\b",
      "description": "Case/end pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bcond\\b",
      "closePattern": "\\bend\\b",
      "description": "Cond/end pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bif\\b",
      "closePattern": "\\bend\\b",
      "description": "If/end pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bunless\\b",
      "closePattern": "\\bend\\b",
      "description": "Unless/end pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\breceive\\b",
      "closePattern": "\\bend\\b",
      "description": "Receive/end pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\btry\\b",
      "closePattern": "\\bend\\b",
      "description": "Try/end pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bwith\\b",
      "closePattern": "\\bend\\b",
      "description": "With/end pair"
    },
    {
      "type": "string_pair",
      "openPattern": "\"\"\"",
      "closePattern": "\"\"\"",
      "description": "Heredoc string pair"
    },
    {
      "type": "sigil_pair",
      "openPattern": "~[a-zA-Z]\\(",
      "closePattern": "\\)",
      "description": "Sigil parenthesis pair"
    }
  ],
  "supported": true
}
