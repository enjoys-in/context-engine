{
  "language": "elixir",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_!?]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "\\b(do)\\b",
      "closePattern": "\\bend\\b",
      "description": "Elixir do/end block pair synchronization"
    },
    {
      "type": "tag_pair",
      "openPattern": "<%=?\\s",
      "closePattern": "\\s%>",
      "description": "EEx template tag pairs"
    },
    {
      "kind": "tag",
      "pattern": "<(\\w+)[^>]*>.*?</\\1>",
      "description": "Linked editing for matching HTML/XML tags"
    }
  ],
  "supported": true
}
