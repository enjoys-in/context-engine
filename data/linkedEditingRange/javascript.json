{
  "language": "javascript",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "<([a-zA-Z][a-zA-Z0-9.]*)(?:\\s[^>]*)?>",
      "closePattern": "</([a-zA-Z][a-zA-Z0-9.]*)\\s*>",
      "description": "JSX/TSX tag pair synchronization"
    },
    {
      "type": "tag_pair",
      "openPattern": "<([A-Z][a-zA-Z0-9.]*)(?:\\s[^>]*)?>",
      "closePattern": "</([A-Z][a-zA-Z0-9.]*)\\s*>",
      "description": "Component tag pair synchronization"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Matching curly brace pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Matching square bracket pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Matching parenthesis pairs"
    },
    {
      "type": "string_pair",
      "openPattern": "`",
      "closePattern": "`",
      "description": "Template literal backtick pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "function\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Function name and closing brace"
    },
    {
      "type": "scope_pair",
      "openPattern": "class\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Class declaration scope pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "if\\s*\\(",
      "closePattern": "\\)",
      "description": "If condition parentheses pair"
    },
    {
      "type": "comment_pair",
      "openPattern": "/\\*",
      "closePattern": "\\*/",
      "description": "Block comment delimiters"
    }
  ],
  "supported": true
}
