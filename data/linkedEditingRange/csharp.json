{
  "language": "csharp",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "linkedEditingPatterns": [
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Matching curly brace pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Matching square bracket pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Matching parenthesis pairs"
    },
    {
      "type": "scope_pair",
      "openPattern": "class\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Class declaration scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "interface\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Interface declaration scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "struct\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Struct declaration scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "namespace\\s+[\\w.]+",
      "closePattern": "\\}",
      "description": "Namespace scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "enum\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Enum scope"
    },
    {
      "type": "type_pair",
      "openPattern": "<",
      "closePattern": ">",
      "description": "Generic type parameters"
    },
    {
      "type": "string_pair",
      "openPattern": "@\"",
      "closePattern": "\"",
      "description": "Verbatim string pair"
    },
    {
      "type": "string_pair",
      "openPattern": "\\$\"",
      "closePattern": "\"",
      "description": "Interpolated string pair"
    },
    {
      "type": "preprocessor_pair",
      "openPattern": "#region",
      "closePattern": "#endregion",
      "description": "Region directive pair"
    },
    {
      "type": "preprocessor_pair",
      "openPattern": "#if",
      "closePattern": "#endif",
      "description": "Preprocessor conditional pair"
    },
    {
      "type": "comment_pair",
      "openPattern": "/\\*",
      "closePattern": "\\*/",
      "description": "Block comment pair"
    },
    {
      "type": "attribute_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Attribute bracket pair"
    }
  ],
  "supported": true
}
