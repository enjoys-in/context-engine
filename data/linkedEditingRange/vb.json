{
  "language": "vb",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "#Region\\s+\"(.*)\"",
      "closePattern": "#End Region",
      "description": "VB.NET #Region/#End Region directive pair"
    },
    {
      "type": "tag_pair",
      "openPattern": "\\b(Sub|Function|Class|Module|Namespace|If|For|While|Do|Select|Try|Using|With|SyncLock)\\b",
      "closePattern": "\\bEnd\\s+(Sub|Function|Class|Module|Namespace|If|For|While|Do|Select|Try|Using|With|SyncLock)\\b",
      "description": "VB.NET block statement open/End pairs"
    },
    {
      "kind": "tag",
      "pattern": "<(\\w+)[^>]*>.*?</\\1>",
      "description": "Linked editing for matching HTML/XML tags"
    }
  ],
  "supported": true
}
