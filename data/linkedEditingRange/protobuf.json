{
  "language": "protobuf",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_.]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Matching curly brace pairs in protobuf message/service definitions"
    },
    {
      "kind": "tag",
      "pattern": "<(\\w+)[^>]*>.*?</\\1>",
      "description": "Linked editing for matching HTML/XML tags"
    },
    {
      "kind": "variable",
      "pattern": "\\b(\\w+)\\b",
      "description": "Linked editing for variable references"
    }
  ],
  "supported": true
}
