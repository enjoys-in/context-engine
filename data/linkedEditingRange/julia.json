{
  "language": "julia",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_!]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "\\b(function|if|for|while|do|begin|let|struct|module|macro|quote|try)\\b",
      "closePattern": "\\bend\\b",
      "description": "Julia block keyword/end pair synchronization"
    },
    {
      "kind": "tag",
      "pattern": "<(\\w+)[^>]*>.*?</\\1>",
      "description": "Linked editing for matching HTML/XML tags"
    },
    {
      "kind": "variable",
      "pattern": "\\b(\\w+)\\b",
      "description": "Linked editing for variable references"
    }
  ],
  "supported": true
}
