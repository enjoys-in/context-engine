{
  "language": "shell",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_-]*",
  "linkedEditingPatterns": [
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Subshell parenthesis pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Command group brace pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[\\[",
      "closePattern": "\\]\\]",
      "description": "Test bracket pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Test bracket pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bif\\b",
      "closePattern": "\\bfi\\b",
      "description": "If/fi pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bfor\\b",
      "closePattern": "\\bdone\\b",
      "description": "For/done pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bwhile\\b",
      "closePattern": "\\bdone\\b",
      "description": "While/done pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\buntil\\b",
      "closePattern": "\\bdone\\b",
      "description": "Until/done pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bcase\\b",
      "closePattern": "\\besac\\b",
      "description": "Case/esac pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bdo\\b",
      "closePattern": "\\bdone\\b",
      "description": "Do/done pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bselect\\b",
      "closePattern": "\\bdone\\b",
      "description": "Select/done pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "(\\w+)\\s*\\(\\)",
      "closePattern": "\\}",
      "description": "Function scope pair"
    },
    {
      "type": "string_pair",
      "openPattern": "<<[-']?(\\w+)",
      "closePattern": "\\1",
      "description": "Here-document delimiter pair"
    },
    {
      "type": "string_pair",
      "openPattern": "\\$\\(",
      "closePattern": "\\)",
      "description": "Command substitution pair"
    },
    {
      "type": "variable_pair",
      "openPattern": "\\$\\{",
      "closePattern": "\\}",
      "description": "Variable expansion pair"
    }
  ],
  "supported": true
}
