{
  "language": "dotenv",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "linkedEditingPatterns": [
    {
      "type": "variable_reference",
      "openPattern": "([A-Z_][A-Z0-9_]*)=",
      "closePattern": "\\$\\{?([A-Z_][A-Z0-9_]*)\\}?",
      "description": "Linked editing for environment variable references"
    }
  ],
  "supported": false
}