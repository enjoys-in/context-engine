{
  "language": "dotenv",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "linkedEditingPatterns": [
    {
      "type": "variable_reference",
      "openPattern": "([A-Z_][A-Z0-9_]*)=",
      "closePattern": "\\$\\{?([A-Z_][A-Z0-9_]*)\\}?",
      "description": "Linked editing for environment variable references"
    },
    {
      "kind": "tag",
      "pattern": "<(\\w+)[^>]*>.*?</\\1>",
      "description": "Linked editing for matching HTML/XML tags"
    },
    {
      "kind": "variable",
      "pattern": "\\b(\\w+)\\b",
      "description": "Linked editing for variable references"
    }
  ],
  "supported": false
}
