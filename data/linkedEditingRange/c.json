{
  "language": "c",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "linkedEditingPatterns": [
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Matching curly brace pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Matching square bracket pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Matching parenthesis pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Parenthesis pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Array bracket pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Block brace pair"
    },
    {
      "type": "preprocessor_pair",
      "openPattern": "#ifdef\\s+(\\w+)",
      "closePattern": "#endif",
      "description": "Preprocessor #ifdef/#endif pair"
    },
    {
      "type": "preprocessor_pair",
      "openPattern": "#ifndef\\s+(\\w+)",
      "closePattern": "#endif",
      "description": "Preprocessor #ifndef/#endif pair"
    },
    {
      "type": "preprocessor_pair",
      "openPattern": "#if\\b",
      "closePattern": "#endif",
      "description": "Preprocessor #if/#endif pair"
    },
    {
      "type": "comment_pair",
      "openPattern": "/\\*",
      "closePattern": "\\*/",
      "description": "Block comment pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "struct\\s+(\\w+)\\s*\\{",
      "closePattern": "\\};",
      "description": "Struct scope pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "enum\\s+(\\w+)\\s*\\{",
      "closePattern": "\\};",
      "description": "Enum scope pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "union\\s+(\\w+)\\s*\\{",
      "closePattern": "\\};",
      "description": "Union scope pair"
    }
  ],
  "supported": true
}
