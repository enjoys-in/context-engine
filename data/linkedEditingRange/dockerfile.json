{
  "language": "dockerfile",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_-]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "\\bAS\\s+([a-zA-Z_][a-zA-Z0-9_-]*)",
      "closePattern": "--from=([a-zA-Z_][a-zA-Z0-9_-]*)",
      "description": "Multi-stage build alias synchronization"
    },
    {
      "kind": "tag",
      "pattern": "<(\\w+)[^>]*>.*?</\\1>",
      "description": "Linked editing for matching HTML/XML tags"
    },
    {
      "kind": "variable",
      "pattern": "\\b(\\w+)\\b",
      "description": "Linked editing for variable references"
    }
  ],
  "supported": true
}
