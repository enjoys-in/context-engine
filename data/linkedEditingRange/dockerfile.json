{
  "language": "dockerfile",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_.-]*",
  "linkedEditingPatterns": [
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Block brace pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Section bracket pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Parenthesis pair"
    },
    {
      "type": "string_pair",
      "openPattern": "\"",
      "closePattern": "\"",
      "description": "Double-quoted string pair"
    },
    {
      "type": "string_pair",
      "openPattern": "'",
      "closePattern": "'",
      "description": "Single-quoted string pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "FROM\\b",
      "closePattern": "(?=^FROM|$)",
      "description": "Build stage scope"
    },
    {
      "type": "continuation_pair",
      "openPattern": "\\\\$",
      "closePattern": "^[^\\\\]",
      "description": "Line continuation pair"
    }
  ],
  "supported": true
}
