{
  "language": "xml",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_.:-]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "<([a-zA-Z_][a-zA-Z0-9_.:-]*)(?:\\s[^>]*)?>",
      "closePattern": "</([a-zA-Z_][a-zA-Z0-9_.:-]*)\\s*>",
      "description": "XML open/close tag name synchronization"
    }
  ],
  "supported": true
}