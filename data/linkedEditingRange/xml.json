{
  "language": "xml",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_.:-]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "<([a-zA-Z_][a-zA-Z0-9_.:-]*)(?:\\s[^>]*)?>",
      "closePattern": "</([a-zA-Z_][a-zA-Z0-9_.:-]*)\\s*>",
      "description": "XML open/close tag name synchronization"
    },
    {
      "kind": "tag",
      "pattern": "<(\\w+)[^>]*>.*?</\\1>",
      "description": "Linked editing for matching HTML/XML tags"
    },
    {
      "kind": "variable",
      "pattern": "\\b(\\w+)\\b",
      "description": "Linked editing for variable references"
    }
  ],
  "supported": true
}
