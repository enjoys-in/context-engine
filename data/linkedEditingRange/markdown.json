{
  "language": "markdown",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_-]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "<([a-zA-Z][a-zA-Z0-9-]*)(?:\\s[^>]*)?>",
      "closePattern": "</([a-zA-Z][a-zA-Z0-9-]*)\\s*>",
      "description": "HTML tag pairs embedded in Markdown"
    }
  ],
  "supported": true
}
