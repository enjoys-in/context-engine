{
  "language": "kotlin",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "linkedEditingPatterns": [
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Matching curly brace pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Matching square bracket pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Matching parenthesis pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Parenthesis pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Square bracket pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Block brace pair"
    },
    {
      "type": "type_pair",
      "openPattern": "<",
      "closePattern": ">",
      "description": "Generic type parameters"
    },
    {
      "type": "scope_pair",
      "openPattern": "fun\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Function scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "class\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Class scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "interface\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Interface scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "object\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Object scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "when\\s*\\(",
      "closePattern": "\\}",
      "description": "When expression scope"
    },
    {
      "type": "string_pair",
      "openPattern": "\"\"\"",
      "closePattern": "\"\"\"",
      "description": "Multiline string pair"
    },
    {
      "type": "annotation_pair",
      "openPattern": "@(\\w+)\\(",
      "closePattern": "\\)",
      "description": "Annotation argument pair"
    },
    {
      "type": "comment_pair",
      "openPattern": "/\\*",
      "closePattern": "\\*/",
      "description": "Block comment pair"
    }
  ],
  "supported": true
}
