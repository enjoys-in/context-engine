{
  "language": "sb",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "\\b(Sub|For|While|If)\\b",
      "closePattern": "\\b(EndSub|EndFor|EndWhile|EndIf)\\b",
      "description": "Small Basic block keyword pairs"
    },
    {
      "kind": "tag",
      "pattern": "<(\\w+)[^>]*>.*?</\\1>",
      "description": "Linked editing for matching HTML/XML tags"
    },
    {
      "kind": "variable",
      "pattern": "\\b(\\w+)\\b",
      "description": "Linked editing for variable references"
    }
  ],
  "supported": true
}
