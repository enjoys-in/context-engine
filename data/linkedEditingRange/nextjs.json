{
  "language": "nextjs",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$.]*",
  "linkedEditingPatterns": [
    {
      "description": "JSX tag pairs",
      "openPattern": "<([A-Z][a-zA-Z0-9.]*)",
      "closePattern": "<\\/([A-Z][a-zA-Z0-9.]*)",
      "captureGroup": 1
    },
    {
      "description": "HTML tag pairs",
      "openPattern": "<([a-z][a-z0-9]*)",
      "closePattern": "<\\/([a-z][a-z0-9]*)",
      "captureGroup": 1
    },
    {
      "description": "Template literal variable",
      "pattern": "\\$\\{(\\w+)\\}",
      "captureGroup": 1
    }
  ],
  "supported": true
}
