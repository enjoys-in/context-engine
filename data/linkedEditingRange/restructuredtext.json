{
  "language": "restructuredtext",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_-]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "\\.\\.\\s+\\|([a-zA-Z_][a-zA-Z0-9_-]*)\\|",
      "closePattern": "\\|([a-zA-Z_][a-zA-Z0-9_-]*)\\|",
      "description": "reStructuredText substitution definition and reference pair"
    },
    {
      "kind": "tag",
      "pattern": "<(\\w+)[^>]*>.*?</\\1>",
      "description": "Linked editing for matching HTML/XML tags"
    },
    {
      "kind": "variable",
      "pattern": "\\b(\\w+)\\b",
      "description": "Linked editing for variable references"
    }
  ],
  "supported": true
}
