{
  "language": "restructuredtext",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "<([a-zA-Z][a-zA-Z0-9:-]*)(?:\\s[^>]*)?>",
      "closePattern": "</([a-zA-Z][a-zA-Z0-9:-]*)\\s*>",
      "description": "HTML/XML tag pair synchronization"
    },
    {
      "type": "comment_pair",
      "openPattern": "<!--",
      "closePattern": "-->",
      "description": "HTML comment pair"
    },
    {
      "type": "string_pair",
      "openPattern": "```",
      "closePattern": "```",
      "description": "Fenced code block pair"
    },
    {
      "type": "emphasis_pair",
      "openPattern": "\\*\\*",
      "closePattern": "\\*\\*",
      "description": "Bold emphasis pair"
    },
    {
      "type": "emphasis_pair",
      "openPattern": "\\*",
      "closePattern": "\\*",
      "description": "Italic emphasis pair"
    },
    {
      "type": "emphasis_pair",
      "openPattern": "~~",
      "closePattern": "~~",
      "description": "Strikethrough pair"
    }
  ],
  "supported": true
}
