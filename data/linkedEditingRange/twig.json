{
  "language": "twig",
  "wordPattern": "[a-zA-Z][a-zA-Z0-9_-]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "<([a-zA-Z][a-zA-Z0-9-]*)(?:\\s[^>]*)?>",
      "closePattern": "</([a-zA-Z][a-zA-Z0-9-]*)\\s*>",
      "description": "HTML open/close tag name synchronization in Twig templates"
    },
    {
      "type": "tag_pair",
      "openPattern": "\\{%[-\\s]*([a-zA-Z_]+)\\b",
      "closePattern": "\\{%[-\\s]*end([a-zA-Z_]+)\\s*-?%\\}",
      "description": "Twig block tag pairs ({% block %}...{% endblock %})"
    },
    {
      "kind": "tag",
      "pattern": "<(\\w+)[^>]*>.*?</\\1>",
      "description": "Linked editing for matching HTML/XML tags"
    }
  ],
  "supported": true
}
