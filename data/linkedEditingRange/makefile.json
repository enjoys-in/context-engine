{
  "language": "makefile",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_.-]*",
  "linkedEditingPatterns": [
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Block brace pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Section bracket pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Parenthesis pair"
    },
    {
      "type": "string_pair",
      "openPattern": "\"",
      "closePattern": "\"",
      "description": "Double-quoted string pair"
    },
    {
      "type": "string_pair",
      "openPattern": "'",
      "closePattern": "'",
      "description": "Single-quoted string pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bdefine\\b",
      "closePattern": "\\bendef\\b",
      "description": "Define/endef block pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\bifn?eq\\b",
      "closePattern": "\\bendif\\b",
      "description": "Conditional/endif pair"
    },
    {
      "type": "variable_pair",
      "openPattern": "\\$\\(",
      "closePattern": "\\)",
      "description": "Variable reference pair"
    },
    {
      "type": "variable_pair",
      "openPattern": "\\$\\{",
      "closePattern": "\\}",
      "description": "Variable reference pair (braces)"
    }
  ],
  "supported": true
}
