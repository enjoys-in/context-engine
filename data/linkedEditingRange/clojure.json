{
  "language": "clojure",
  "wordPattern": "[a-zA-Z_+\\-*/<>=!?][a-zA-Z0-9_+\\-*/<>=!?.]*",
  "linkedEditingPatterns": [
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Matching curly brace pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Matching square bracket pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Matching parenthesis pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "S-expression parenthesis pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Vector bracket pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Map brace pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "#\\{",
      "closePattern": "\\}",
      "description": "Set literal pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "#\\(",
      "closePattern": "\\)",
      "description": "Anonymous function pair"
    },
    {
      "type": "string_pair",
      "openPattern": "#\"",
      "closePattern": "\"",
      "description": "Regex literal pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\(defn\\s+",
      "closePattern": "\\)",
      "description": "Defn form scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\(let\\s+\\[",
      "closePattern": "\\)",
      "description": "Let binding scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\(fn\\s+",
      "closePattern": "\\)",
      "description": "Anonymous fn scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\(ns\\s+",
      "closePattern": "\\)",
      "description": "Namespace form scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "\\(do\\b",
      "closePattern": "\\)",
      "description": "Do form scope"
    }
  ],
  "supported": true
}
