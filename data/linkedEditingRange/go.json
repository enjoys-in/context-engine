{
  "language": "go",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "linkedEditingPatterns": [
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Matching curly brace pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Matching square bracket pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Matching parenthesis pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Parenthesis pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Square bracket pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Block brace pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "func\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Function scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "type\\s+(\\w+)\\s+struct",
      "closePattern": "\\}",
      "description": "Struct scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "type\\s+(\\w+)\\s+interface",
      "closePattern": "\\}",
      "description": "Interface scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "if\\s+",
      "closePattern": "\\}",
      "description": "If block scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "for\\s+",
      "closePattern": "\\}",
      "description": "For loop scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "switch\\s+",
      "closePattern": "\\}",
      "description": "Switch scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "select\\s*\\{",
      "closePattern": "\\}",
      "description": "Select scope"
    },
    {
      "type": "string_pair",
      "openPattern": "`",
      "closePattern": "`",
      "description": "Raw string literal pair"
    },
    {
      "type": "comment_pair",
      "openPattern": "/\\*",
      "closePattern": "\\*/",
      "description": "Block comment pair"
    }
  ],
  "supported": true
}
