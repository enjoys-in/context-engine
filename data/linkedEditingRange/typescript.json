{
  "language": "typescript",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$.-]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "<([a-zA-Z][a-zA-Z0-9.]*)(?:\\s[^>]*)?>",
      "closePattern": "</([a-zA-Z][a-zA-Z0-9.]*)\\s*>",
      "description": "TSX open/close tag name synchronization"
    },
    {
      "type": "tag_pair",
      "openPattern": "<([A-Z][a-zA-Z0-9.]*)(?:\\s[^>]*)?>",
      "closePattern": "</([A-Z][a-zA-Z0-9.]*)\\s*>",
      "description": "TSX component tag name synchronization"
    }
  ],
  "supported": true
}
