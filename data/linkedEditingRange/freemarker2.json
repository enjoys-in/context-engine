{
  "language": "freemarker2",
  "wordPattern": "[a-zA-Z][a-zA-Z0-9_]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "<([a-zA-Z][a-zA-Z0-9-]*)(?:\\s[^>]*)?>",
      "closePattern": "</([a-zA-Z][a-zA-Z0-9-]*)\\s*>",
      "description": "HTML open/close tag name synchronization in FreeMarker templates"
    },
    {
      "type": "tag_pair",
      "openPattern": "<#([a-zA-Z_]+)\\b",
      "closePattern": "</#([a-zA-Z_]+)\\s*>",
      "description": "FreeMarker directive tag pairs (<#if>...</#if>)"
    },
    {
      "type": "tag_pair",
      "openPattern": "<@([a-zA-Z_][a-zA-Z0-9_.]*)\\b",
      "closePattern": "</@([a-zA-Z_][a-zA-Z0-9_.]*)\\s*>",
      "description": "FreeMarker user-defined directive pairs (<@macro>...</@macro>)"
    }
  ],
  "supported": true
}
