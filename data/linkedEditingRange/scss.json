{
  "language": "scss",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$-]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "([.#&][a-zA-Z_-][a-zA-Z0-9_-]*)\\s*\\{",
      "closePattern": "\\}",
      "description": "SCSS nested selector and closing brace pair"
    },
    {
      "type": "tag_pair",
      "openPattern": "@mixin\\s+([a-zA-Z_-][a-zA-Z0-9_-]*)",
      "closePattern": "@include\\s+([a-zA-Z_-][a-zA-Z0-9_-]*)",
      "description": "SCSS mixin definition and include name synchronization"
    }
  ],
  "supported": true
}
