{
  "language": "perl",
  "wordPattern": "[$@%&*][a-zA-Z_][a-zA-Z0-9_]*|[a-zA-Z_][a-zA-Z0-9_]*",
  "linkedEditingPatterns": [
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Matching curly brace pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Matching square bracket pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Matching parenthesis pairs"
    },
    {
      "type": "string_pair",
      "openPattern": "\"",
      "closePattern": "\"",
      "description": "Double-quoted string pair"
    },
    {
      "type": "string_pair",
      "openPattern": "'",
      "closePattern": "'",
      "description": "Single-quoted string pair"
    }
  ],
  "supported": true
}
