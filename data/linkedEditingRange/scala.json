{
  "language": "scala",
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*",
  "linkedEditingPatterns": [
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Matching curly brace pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Matching square bracket pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Matching parenthesis pairs"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Parenthesis pair"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Type parameter brackets"
    },
    {
      "type": "bracket_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Block brace pair"
    },
    {
      "type": "scope_pair",
      "openPattern": "def\\s+(\\w+)",
      "closePattern": "\\}|$",
      "description": "Method scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "class\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Class scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "object\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Object scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "trait\\s+(\\w+)",
      "closePattern": "\\}",
      "description": "Trait scope"
    },
    {
      "type": "scope_pair",
      "openPattern": "match\\s*\\{",
      "closePattern": "\\}",
      "description": "Match expression scope"
    },
    {
      "type": "string_pair",
      "openPattern": "\"\"\"",
      "closePattern": "\"\"\"",
      "description": "Triple-quoted string pair"
    },
    {
      "type": "comment_pair",
      "openPattern": "/\\*",
      "closePattern": "\\*/",
      "description": "Block comment pair"
    },
    {
      "type": "annotation_pair",
      "openPattern": "@(\\w+)\\(",
      "closePattern": "\\)",
      "description": "Annotation argument pair"
    }
  ],
  "supported": true
}
