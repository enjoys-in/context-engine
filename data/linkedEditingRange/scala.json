{
  "language": "scala",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "\\{",
      "closePattern": "\\}",
      "description": "Matching curly brace pairs"
    },
    {
      "type": "tag_pair",
      "openPattern": "<([a-zA-Z][a-zA-Z0-9.]*)(?:\\s[^>]*)?>",
      "closePattern": "</([a-zA-Z][a-zA-Z0-9.]*)\\s*>",
      "description": "Scala XML literal tag synchronization"
    },
    {
      "kind": "tag",
      "pattern": "<(\\w+)[^>]*>.*?</\\1>",
      "description": "Linked editing for matching HTML/XML tags"
    }
  ],
  "supported": true
}
