{
  "language": "scheme",
  "wordPattern": "[a-zA-Z!$%&*+./:<=>?@^_~-][a-zA-Z0-9!$%&*+./:<=>?@^_~-]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "\\(",
      "closePattern": "\\)",
      "description": "Matching parenthesis pairs"
    },
    {
      "type": "tag_pair",
      "openPattern": "\\[",
      "closePattern": "\\]",
      "description": "Matching bracket pairs"
    },
    {
      "kind": "tag",
      "pattern": "<(\\w+)[^>]*>.*?</\\1>",
      "description": "Linked editing for matching HTML/XML tags"
    }
  ],
  "supported": true
}
