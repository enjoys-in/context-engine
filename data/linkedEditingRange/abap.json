{
  "language": "abap",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "\\b(IF|LOOP|DO|WHILE|CASE|TRY|METHOD|FORM|FUNCTION|CLASS|INTERFACE)\\b",
      "closePattern": "\\b(ENDIF|ENDLOOP|ENDDO|ENDWHILE|ENDCASE|ENDTRY|ENDMETHOD|ENDFORM|ENDFUNCTION|ENDCLASS|ENDINTERFACE)\\b",
      "description": "ABAP block keyword open/close pair synchronization"
    }
  ],
  "supported": true
}
