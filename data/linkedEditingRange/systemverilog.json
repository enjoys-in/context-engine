{
  "language": "systemverilog",
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_$]*",
  "linkedEditingPatterns": [
    {
      "type": "tag_pair",
      "openPattern": "\\b(module|begin|function|task|class|interface|package|generate|fork)\\b",
      "closePattern": "\\b(endmodule|end|endfunction|endtask|endclass|endinterface|endpackage|endgenerate|join)\\b",
      "description": "SystemVerilog block keyword open/close pair synchronization"
    }
  ],
  "supported": true
}
