{
  "language": "lexon",
  "legend": {
    "tokenTypes": [
      "type",
      "variable",
      "property",
      "function",
      "keyword",
      "comment",
      "string",
      "number",
      "operator",
      "namespace",
      "modifier",
      "enum",
      "parameter"
    ],
    "tokenModifiers": [
      "declaration",
      "definition",
      "readonly",
      "documentation"
    ]
  },
  "semanticRules": [
    {
      "tokenType": "keyword",
      "pattern": "\\b(LEX|CLAUSE|TERMS|ARTICLE|SECTION|PARAGRAPH|RECITALS|COVENANTS|SCHEDULE|APPENDIX|EXHIBIT|PREAMBLE|DEFINITIONS)\\b",
      "tokenModifiers": [],
      "description": "Lexon structural document keywords for contract organization"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(WHEREAS|THEREFORE|PROVIDED THAT|WITNESSETH|HEREBY|HEREIN|HEREOF|HERETO|HEREUNDER|THEREIN|THEREOF|THERETO|THEREUNDER|NOTWITHSTANDING)\\b",
      "tokenModifiers": [],
      "description": "Legal boilerplate and recital keywords"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(IF|THEN|ELSE|WHEN|UNLESS|PROVIDED THAT|IN CASE|OTHERWISE|WHERE|SUCH THAT)\\b",
      "tokenModifiers": [],
      "description": "Conditional and branching keywords"
    },
    {
      "tokenType": "modifier",
      "pattern": "\\b(SHALL|MAY|MUST|WILL|SHOULD|OUGHT TO|IS REQUIRED TO|IS ENTITLED TO|AGREES TO|WARRANTS|REPRESENTS|COVENANTS)\\b",
      "tokenModifiers": [],
      "description": "Legal obligation and permission modifiers (deontic modality)"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(pay|send|transfer|return|deliver|remit|disburse|allocate|distribute|refund)\\b",
      "tokenModifiers": [],
      "description": "Financial and transfer action verbs"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(notify|declare|certify|register|terminate|execute|amend|revoke|cancel|suspend|reinstate|renew|extend|waive|assign|delegate|appoint|authorize|confirm|acknowledge|accept|reject|approve|dispute|resolve|enforce|forfeit|indemnify|compensate|remedy)\\b",
      "tokenModifiers": [],
      "description": "Legal and administrative action verbs"
    },
    {
      "tokenType": "type",
      "pattern": "\\b(amount|person|text|time|binary|number|date|boolean|percentage|currency|duration|address|account|identifier)\\b",
      "tokenModifiers": [],
      "description": "Lexon primitive value types"
    },
    {
      "tokenType": "namespace",
      "pattern": "\\b(contract|agreement|deed|license|memorandum|charter|covenant|instrument|indenture)\\b",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Top-level contract document type declarations"
    },
    {
      "tokenType": "property",
      "pattern": "\\b(party|parties|obligation|right|duty|liability|warranty|representation|condition|term|consideration|benefit|interest|claim|consent|notice|default|breach|remedy|damages|penalty|force majeure|indemnity|confidentiality|jurisdiction|governing law|severability|entirety|waiver|assignment)\\b",
      "tokenModifiers": [],
      "description": "Legal construct and contract property terms"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(before|after|within|upon|during|until|from|through|commencing|expiring|effective|retroactive)\\b",
      "tokenModifiers": [],
      "description": "Temporal prepositions and time-reference keywords"
    },
    {
      "tokenType": "type",
      "pattern": "\\b(days|months|years|weeks|hours|minutes|business days|calendar days|working days)\\b",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Time duration unit types"
    },
    {
      "tokenType": "variable",
      "pattern": "(?<=CLAUSE\\s+)\\w[\\w\\s]*(?=\\.)",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Clause name declarations"
    },
    {
      "tokenType": "variable",
      "pattern": "(?<=ARTICLE\\s+)\\w[\\w\\s]*(?=\\.)",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Article name declarations"
    },
    {
      "tokenType": "variable",
      "pattern": "\"[^\"]+\"(?=\\s+(?:is|means|be|shall mean|refers to|denotes))",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Defined term names in the definitions section"
    },
    {
      "tokenType": "parameter",
      "pattern": "(?<=\\b(?:pay|send|transfer|deliver|remit|notify)\\s+)\\w+(?=\\s+to\\b)",
      "tokenModifiers": [],
      "description": "Direct object parameters of action verbs"
    },
    {
      "tokenType": "enum",
      "pattern": "\\b(USD|EUR|GBP|JPY|CHF|ETH|BTC|WEI|GWEI|FINNEY)\\b",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Currency and cryptocurrency denomination constants"
    },
    {
      "tokenType": "operator",
      "pattern": "\\b(AND|OR|NOT|NOR|XOR)\\b",
      "tokenModifiers": [],
      "description": "Logical connective operators"
    },
    {
      "tokenType": "operator",
      "pattern": "\\b(equals|greater than|less than|at least|at most|no more than|no less than|exceeds|between|is equal to|is not equal to|is greater than|is less than)\\b",
      "tokenModifiers": [],
      "description": "Natural-language comparison operators"
    },
    {
      "tokenType": "operator",
      "pattern": "\\b(plus|minus|times|divided by|multiplied by|per|of)\\b",
      "tokenModifiers": [],
      "description": "Natural-language arithmetic operators"
    },
    {
      "tokenType": "number",
      "pattern": "\\b\\d{1,3}(,\\d{3})*(\\.\\d+)?\\b",
      "tokenModifiers": [],
      "description": "Numeric literals with optional comma-separated thousands and decimals"
    },
    {
      "tokenType": "number",
      "pattern": "\\b\\d+(\\.\\d+)?%",
      "tokenModifiers": [],
      "description": "Percentage literals"
    },
    {
      "tokenType": "string",
      "pattern": "\"(?:[^\"\\\\]|\\\\.)*\"",
      "tokenModifiers": [],
      "description": "Double-quoted string literals for names and identifiers"
    },
    {
      "tokenType": "string",
      "pattern": "'(?:[^'\\\\]|\\\\.)*'",
      "tokenModifiers": [],
      "description": "Single-quoted string literals"
    },
    {
      "tokenType": "comment",
      "pattern": "//[^\\n]*",
      "tokenModifiers": [
        "documentation"
      ],
      "description": "Single-line comments"
    },
    {
      "tokenType": "comment",
      "pattern": "/\\*[\\s\\S]*?\\*/",
      "tokenModifiers": [
        "documentation"
      ],
      "description": "Multi-line block comments"
    },
    {
      "tokenType": "variable",
      "pattern": "\\\\bthis\\\\b|\\\\bself\\\\b",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Self/this keyword semantic token"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\\\b(async|await|yield)\\\\b",
      "tokenModifiers": [
        "async"
      ],
      "description": "Async/concurrent keywords"
    },
    {
      "tokenType": "type",
      "pattern": "\\\\b(Promise|Future|Task|Observable)\\\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Concurrent/async types"
    },
    {
      "tokenType": "function",
      "pattern": "\\\\b(get|set)\\\\s+\\\\w+\\\\s*\\\\(",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Getter/setter declarations"
    },
    {
      "tokenType": "variable",
      "pattern": "\\\\b_\\\\w+\\\\b",
      "tokenModifiers": [],
      "description": "Private/underscore-prefixed identifiers"
    },
    {
      "tokenType": "type",
      "pattern": "\\\\b(Array|List|Map|Set|Dict|Vector|HashMap|TreeMap)\\\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Collection types"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\\\b(abstract|virtual|override|final|sealed)\\\\b",
      "tokenModifiers": [],
      "description": "OOP modifier keywords"
    },
    {
      "tokenType": "property",
      "pattern": "\\\\b(length|size|count|isEmpty|isNotEmpty)\\\\b",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Common read-only properties"
    },
    {
      "tokenType": "function",
      "pattern": "\\\\b(map|filter|reduce|forEach|find|some|every)\\\\b",
      "tokenModifiers": [],
      "description": "Iteration/functional methods"
    },
    {
      "tokenType": "modifier",
      "pattern": "\\\\b(override|static|readonly|const|final|volatile)\\\\b",
      "tokenModifiers": [],
      "description": "Member modifiers"
    },
    {
      "tokenType": "namespace",
      "pattern": "\\\\b(std|System|java|kotlin|swift|Foundation)\\\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Standard library namespaces"
    },
    {
      "tokenType": "decorator",
      "pattern": "@[A-Z]\\\\w+",
      "tokenModifiers": [],
      "description": "Class/method annotations (PascalCase)"
    },
    {
      "tokenType": "typeParameter",
      "pattern": "<[A-Z](\\\\w*)>",
      "tokenModifiers": [],
      "description": "Single-letter and named type parameters"
    },
    {
      "tokenType": "event",
      "pattern": "\\\\b(onClick|onChange|onSubmit|onLoad|onError)\\\\b",
      "tokenModifiers": [],
      "description": "Common event handler names"
    },
    {
      "tokenType": "enumMember",
      "pattern": "\\\\b[A-Z][a-z]+[A-Z]\\\\w*\\\\b",
      "tokenModifiers": [],
      "description": "CamelCase identifiers (often enum values)"
    }
  ]
}
