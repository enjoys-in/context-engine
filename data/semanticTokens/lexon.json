{
  "language": "lexon",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["type", "variable", "property", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly"]
  },
  "semanticRules": [
    {
      "type": "keyword",
      "pattern": "\\b(LEX|CLAUSE|TERMS|RECITALS|COVENANTS|WHEREAS|THEREFORE|PROVIDED THAT|IF|THEN|ELSE|AND|OR|SHALL|MAY|MUST)\\b",
      "modifiers": [],
      "description": "Lexon structural and legal keywords"
    },
    {
      "type": "type",
      "pattern": "(?<=CLAUSE\\s+)\\w+",
      "modifiers": ["declaration"],
      "description": "Clause name declarations"
    },
    {
      "type": "variable",
      "pattern": "(?<=TERMS\\.\\s*)\\w+|\"[^\"]+\"(?=\\s+(?:is|means|be))",
      "modifiers": ["declaration"],
      "description": "Term definitions in the contract"
    },
    {
      "type": "property",
      "pattern": "(?<=RECITALS\\.\\s*)\\w+",
      "modifiers": ["definition"],
      "description": "Recital declarations and references"
    },
    {
      "type": "function",
      "pattern": "\\b(pay|transfer|send|notify|certify|register|terminate|declare|appoint|authorize|assign|deliver|execute)\\b",
      "modifiers": [],
      "description": "Action verbs for contract operations"
    },
    {
      "type": "keyword",
      "pattern": "\\b(amount|percent|date|time|party|person|address|account)\\b",
      "modifiers": [],
      "description": "Condition and value type keywords"
    },
    {
      "type": "number",
      "pattern": "\\b\\d+\\.?\\d*\\b",
      "modifiers": [],
      "description": "Numeric values for amounts and percentages"
    },
    {
      "type": "string",
      "pattern": "\"(?:[^\"\\\\]|\\\\.)*\"",
      "modifiers": [],
      "description": "Quoted string literals for names and identifiers"
    },
    {
      "type": "comment",
      "pattern": "//.*$",
      "modifiers": ["documentation"],
      "description": "Single-line comments"
    }
  ]
}
