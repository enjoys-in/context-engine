{
  "language": "ruby",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "class", "variable", "property", "function", "method", "keyword", "modifier", "comment", "string", "number", "regexp", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "method",
      "pattern": "\\bdef\\s+(self\\.)?\\w+[!?=]?",
      "modifiers": ["declaration"],
      "description": "Method definitions including class methods (self.) and bang/query methods"
    },
    {
      "type": "class",
      "pattern": "\\bclass\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Class definitions"
    },
    {
      "type": "namespace",
      "pattern": "\\bmodule\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Module definitions"
    },
    {
      "type": "method",
      "pattern": "\\b(attr_accessor|attr_reader|attr_writer)\\s+",
      "modifiers": ["declaration"],
      "description": "Attribute accessor macros for generating getter/setter methods"
    },
    {
      "type": "keyword",
      "pattern": "\\b(do|end|begin|rescue|ensure|raise|yield|return|break|next|redo|retry|if|unless|elsif|else|case|when|in|while|until|for|loop|then|super|self|nil|true|false|and|or|not|defined\\?|__FILE__|__LINE__|__method__|__dir__|__ENCODING__|BEGIN|END|require|require_relative|include|extend|prepend|alias|undef)\\b",
      "modifiers": [],
      "description": "Ruby keywords and control flow statements"
    },
    {
      "type": "variable",
      "pattern": "@[a-zA-Z_]\\w*",
      "modifiers": [],
      "description": "Instance variables prefixed with @"
    },
    {
      "type": "variable",
      "pattern": "@@[a-zA-Z_]\\w*",
      "modifiers": ["static"],
      "description": "Class variables prefixed with @@"
    },
    {
      "type": "variable",
      "pattern": "\\$[a-zA-Z_!@&+`'~=/\\\\,;.<>*$?:\"0-9]\\w*",
      "modifiers": [],
      "description": "Global variables prefixed with $ including special globals"
    },
    {
      "type": "property",
      "pattern": ":[a-zA-Z_]\\w*[!?]?",
      "modifiers": ["readonly"],
      "description": "Symbols prefixed with :"
    },
    {
      "type": "keyword",
      "pattern": "\\bdo\\b|\\{(?=\\s*\\|)|\\b(end)\\b",
      "modifiers": [],
      "description": "Block delimiters do/end and { } with block parameters"
    },
    {
      "type": "comment",
      "pattern": "#[^\\n]*|^=begin[\\s\\S]*?^=end",
      "modifiers": [],
      "description": "Single-line # comments and multi-line =begin/=end blocks"
    },
    {
      "type": "regexp",
      "pattern": "/([^/\\\\]|\\\\.)*?/[imxo]*",
      "modifiers": [],
      "description": "Regular expression literals with optional flags"
    }
  ]
}
