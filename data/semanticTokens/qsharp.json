{
  "language": "qsharp",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "typeParameter", "parameter", "variable", "function", "method", "keyword", "modifier", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "function",
      "pattern": "\\b(operation)\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Quantum operation declarations"
    },
    {
      "type": "function",
      "pattern": "\\b(function)\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Classical function declarations"
    },
    {
      "type": "type",
      "pattern": "\\b(Qubit|Result|Bool|Int|BigInt|Double|String|Unit|Pauli|Range|Array)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Q# built-in types including quantum types"
    },
    {
      "type": "function",
      "pattern": "\\b(H|X|Y|Z|CNOT|CCNOT|SWAP|S|T|Rx|Ry|Rz|R1|Measure|M|MResetZ|MResetX|Reset|ResetAll|Adjoint|Controlled)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Quantum gates and measurement operations"
    },
    {
      "type": "namespace",
      "pattern": "\\b(namespace)\\s+([\\w.]+)",
      "modifiers": ["declaration"],
      "description": "Namespace declarations"
    },
    {
      "type": "keyword",
      "pattern": "\\b(open)\\s+([\\w.]+)",
      "modifiers": ["definition"],
      "description": "Open statements for importing namespaces"
    },
    {
      "type": "keyword",
      "pattern": "\\b(let|mutable|set|use|borrow|if|elif|else|for|in|while|repeat|until|fixup|return|fail|within|apply|using|borrowing|newtype|internal|body|adjoint|controlled|auto|self|distribute|invert|intrinsic)\\b",
      "modifiers": [],
      "description": "Q# keywords for bindings, control flow, and functors"
    },
    {
      "type": "variable",
      "pattern": "\\b(use|borrow)\\s+(\\w+)\\s*=\\s*Qubit",
      "modifiers": ["declaration"],
      "description": "Qubit allocation with use and borrow statements"
    },
    {
      "type": "type",
      "pattern": "\\b(Zero|One|PauliX|PauliY|PauliZ|PauliI)\\b",
      "modifiers": ["readonly", "defaultLibrary"],
      "description": "Result and Pauli enum values"
    },
    {
      "type": "comment",
      "pattern": "//[^\\n]*|///[^\\n]*",
      "modifiers": ["documentation"],
      "description": "Line comments and documentation comments"
    },
    {
      "type": "string",
      "pattern": "\"([^\"\\\\]|\\\\.)*\"",
      "modifiers": [],
      "description": "String literals in double quotes"
    },
    {
      "type": "number",
      "pattern": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?L?\\b|0[xXoObB][0-9a-fA-F]+\\b",
      "modifiers": [],
      "description": "Integer, floating-point, BigInt (L suffix), and hex/octal/binary literals"
    }
  ]
}
