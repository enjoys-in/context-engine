{
  "language": "hcl",
  "legend": {
    "tokenTypes": [
      "keyword",
      "variable",
      "type",
      "property",
      "function",
      "namespace",
      "string",
      "operator",
      "comment"
    ],
    "tokenModifiers": [
      "declaration",
      "definition",
      "readonly",
      "defaultLibrary",
      "documentation"
    ]
  },
  "semanticRules": [
    {
      "tokenType": "keyword",
      "pattern": "\\b(resource|data|variable|output|locals|module|provider|terraform|backend)\\b",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Top-level HCL/Terraform block type keywords"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(provisioner|connection|lifecycle|dynamic|content|moved|import|check|removed)\\b",
      "tokenModifiers": [],
      "description": "Nested block and meta-block keywords"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(for_each|count|depends_on)\\b",
      "tokenModifiers": [],
      "description": "Meta-arguments for resource iteration and dependency"
    },
    {
      "tokenType": "type",
      "pattern": "(?<=resource\\s+\")[a-z_]+(?=\")",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Resource type names (e.g., aws_instance, azurerm_resource_group)"
    },
    {
      "tokenType": "type",
      "pattern": "(?<=data\\s+\")[a-z_]+(?=\")",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Data source type names"
    },
    {
      "tokenType": "type",
      "pattern": "(?<=provider\\s+\")[a-z_]+(?=\")",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Provider type names"
    },
    {
      "tokenType": "type",
      "pattern": "\\b(string|number|bool|list|map|set|object|tuple|any|optional)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "HCL type constraint keywords"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(for|in|if|true|false|null)\\b",
      "tokenModifiers": [],
      "description": "Expression-level keywords and literal values"
    },
    {
      "tokenType": "namespace",
      "pattern": "\\bvar\\.([a-zA-Z_][a-zA-Z0-9_]*)",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Variable references (var.name)"
    },
    {
      "tokenType": "namespace",
      "pattern": "\\blocal\\.([a-zA-Z_][a-zA-Z0-9_]*)",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Local value references (local.name)"
    },
    {
      "tokenType": "namespace",
      "pattern": "\\bmodule\\.([a-zA-Z_][a-zA-Z0-9_]*)",
      "tokenModifiers": [],
      "description": "Module output references (module.name)"
    },
    {
      "tokenType": "namespace",
      "pattern": "\\bdata\\.([a-z_]+)\\.([a-zA-Z_][a-zA-Z0-9_]*)",
      "tokenModifiers": [],
      "description": "Data source references (data.type.name)"
    },
    {
      "tokenType": "variable",
      "pattern": "\\b(each\\.key|each\\.value|count\\.index)\\b",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Iteration meta-argument references"
    },
    {
      "tokenType": "variable",
      "pattern": "\\b(self|path\\.module|path\\.root|path\\.cwd|terraform\\.workspace)\\b",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Special built-in references (self, path.*, terraform.workspace)"
    },
    {
      "tokenType": "variable",
      "pattern": "\\$\\{[^}]+\\}",
      "tokenModifiers": [],
      "description": "String template interpolation expressions ${...}"
    },
    {
      "tokenType": "variable",
      "pattern": "%\\{\\s*(if|for|endif|endfor)\\b[^}]*\\}",
      "tokenModifiers": [],
      "description": "Template directives %{if}, %{for}, %{endif}, %{endfor}"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(file|templatefile|fileexists|fileset|filebase64|abspath|basename|dirname|pathexpand)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Filesystem functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(jsonencode|jsondecode|yamlencode|yamldecode|csvdecode|urlencode|base64encode|base64decode|textencodebase64|textdecodebase64|base64gzip)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Encoding and serialization functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(length|lookup|element|flatten|distinct|compact|concat|contains|merge|keys|values|zipmap|range|reverse|sort|setproduct|setintersection|setunion|setsubtract|matchkeys|one|coalesce|coalescelist|index|chunklist)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Collection manipulation functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(format|formatlist|join|split|replace|substr|lower|upper|title|trim|trimprefix|trimsuffix|trimspace|chomp|indent|regex|regexall|regexreplace|startswith|endswith|strrev)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "String manipulation and regex functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(abs|ceil|floor|log|pow|signum|parseint|min|max|sum)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Numeric and math functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(tostring|tonumber|tobool|tolist|tomap|toset|type|try|can|nonsensitive|sensitive)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Type conversion and introspection functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(md5|sha1|sha256|sha512|bcrypt|rsadecrypt|base64sha256|base64sha512|filebase64sha256|filemd5|filesha1|filesha256|filesha512|uuid|uuidv5)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Hash, crypto, and UUID functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(cidrhost|cidrnetmask|cidrsubnet|cidrsubnets)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "IP network and CIDR calculation functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(timestamp|plantimestamp|timeadd|timecmp|formatdate)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Date and time functions"
    },
    {
      "tokenType": "property",
      "pattern": "^\\s*([a-z_][a-zA-Z0-9_]*)\\s*=",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Attribute assignments in block bodies"
    },
    {
      "tokenType": "property",
      "pattern": "\\blifecycle\\s*\\{[^}]*\\b(create_before_destroy|prevent_destroy|ignore_changes|replace_triggered_by|precondition|postcondition)\\b",
      "tokenModifiers": [],
      "description": "Lifecycle block meta-arguments"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\bdynamic\\s+\"([a-z_]+)\"\\s*\\{",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Dynamic blocks for generating repeated nested blocks"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\bprovisioner\\s+\"(local-exec|remote-exec|file)\"\\s*\\{",
      "tokenModifiers": [],
      "description": "Provisioner blocks with provisioner type"
    },
    {
      "tokenType": "operator",
      "pattern": "\\[\\s*for\\s+[a-z_][a-z0-9_]*(?:\\s*,\\s*[a-z_][a-z0-9_]*)?\\s+in\\s+",
      "tokenModifiers": [],
      "description": "For expressions in list/map comprehensions"
    },
    {
      "tokenType": "operator",
      "pattern": "\\.[*]",
      "tokenModifiers": [],
      "description": "Splat expression for attribute access across collections"
    },
    {
      "tokenType": "operator",
      "pattern": "[^?]\\?[^?]",
      "tokenModifiers": [],
      "description": "Conditional ternary expression operator"
    },
    {
      "tokenType": "string",
      "pattern": "<<-?\\s*[A-Z_]+\\b",
      "tokenModifiers": [],
      "description": "Heredoc string opening delimiters (<<EOF, <<-EOF)"
    },
    {
      "tokenType": "string",
      "pattern": "\\bsource\\s*=\\s*\"[^\"]+\"",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Module source path strings (registry, git, local)"
    },
    {
      "tokenType": "comment",
      "pattern": "#[^\\n]*|//[^\\n]*|/\\*[\\s\\S]*?\\*/",
      "tokenModifiers": [
        "documentation"
      ],
      "description": "Hash, double-slash, and block comments"
    }
  ]
}
