{
  "language": "pascal",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "enum", "interface", "variable", "property", "function", "method", "keyword", "modifier", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "function",
      "pattern": "\\b(procedure|function)\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Procedure and function declarations"
    },
    {
      "type": "type",
      "pattern": "\\b(type)\\s+(\\w+)\\s*=\\s*(record|class|object|interface|enum)",
      "modifiers": ["declaration"],
      "description": "Type declarations for record, class, object, interface"
    },
    {
      "type": "keyword",
      "pattern": "\\b(begin|end|program|unit|library|uses|interface|implementation|initialization|finalization|var|const|type|array|of|set|file|packed|with|do|while|for|to|downto|repeat|until|if|then|else|case|try|except|finally|raise|inherited|self)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Pascal structural and control keywords"
    },
    {
      "type": "namespace",
      "pattern": "\\b(uses)\\s+([\\w,\\s]+);",
      "modifiers": ["definition"],
      "description": "Uses clause for unit imports"
    },
    {
      "type": "namespace",
      "pattern": "\\b(unit|program|library)\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Unit, program, and library declarations"
    },
    {
      "type": "type",
      "pattern": "\\b(Integer|String|Boolean|Real|Double|Extended|Char|Byte|Word|LongInt|Cardinal|Pointer|TObject|TComponent|TForm|TStringList|Variant)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in and commonly used types"
    },
    {
      "type": "modifier",
      "pattern": "\\b(virtual|override|abstract|dynamic|reintroduce|overload|cdecl|stdcall|register|safecall|external|forward|inline)\\b",
      "modifiers": [],
      "description": "Method and calling convention modifiers"
    },
    {
      "type": "property",
      "pattern": "\\b(property)\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Property declarations in classes"
    },
    {
      "type": "comment",
      "pattern": "\\{[\\s\\S]*?\\}|\\(\\*[\\s\\S]*?\\*\\)|//[^\\n]*",
      "modifiers": [],
      "description": "Block comments {}, (*...*), and line comments //"
    },
    {
      "type": "string",
      "pattern": "'([^']*)'",
      "modifiers": [],
      "description": "String literals in single quotes"
    },
    {
      "type": "number",
      "pattern": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b|\\$[0-9a-fA-F]+\\b",
      "modifiers": [],
      "description": "Decimal, floating-point, and hexadecimal ($) literals"
    }
  ]
}
