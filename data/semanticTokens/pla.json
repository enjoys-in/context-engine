{
  "language": "pla",
  "legend": {
    "tokenTypes": [
      "keyword",
      "variable",
      "property",
      "type",
      "number",
      "string",
      "comment",
      "operator",
      "namespace",
      "enumMember"
    ],
    "tokenModifiers": [
      "declaration",
      "definition",
      "readonly",
      "defaultLibrary"
    ]
  },
  "semanticRules": [
    {
      "tokenType": "keyword",
      "pattern": "^\\.i\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Input count directive (.i) specifying the number of input variables"
    },
    {
      "tokenType": "keyword",
      "pattern": "^\\.o\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Output count directive (.o) specifying the number of output variables"
    },
    {
      "tokenType": "keyword",
      "pattern": "^\\.p\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Product term count directive (.p) specifying number of product terms"
    },
    {
      "tokenType": "keyword",
      "pattern": "^\\.e\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "End-of-file directive (.e) marking the end of the PLA description"
    },
    {
      "tokenType": "keyword",
      "pattern": "^\\.ilb\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Input label directive (.ilb) declaring symbolic names for input variables"
    },
    {
      "tokenType": "keyword",
      "pattern": "^\\.ob\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Output label directive (.ob) declaring symbolic names for output variables"
    },
    {
      "tokenType": "keyword",
      "pattern": "^\\.type\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Type directive (.type) specifying PLA representation format"
    },
    {
      "tokenType": "keyword",
      "pattern": "^\\.phase\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Phase directive (.phase) specifying output polarity for each output"
    },
    {
      "tokenType": "keyword",
      "pattern": "^\\.(mv|label|pair|symbolic|symbolic-output|kiss)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Extended Berkeley PLA directives: .mv (multi-valued), .label, .pair, .symbolic, .kiss"
    },
    {
      "tokenType": "keyword",
      "pattern": "^\\.(na|exdc|sp|ov)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Additional PLA directives: .na (name), .exdc (external DC-set), .sp/.ov (sparse)"
    },
    {
      "tokenType": "enumMember",
      "pattern": "(?<=\\.type\\s+)(f|r|d|fd|fr|dr|fdr)\\b",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "PLA type values: f(ON-set), r(OFF-set), d(DC-set) and combinations fd, fr, dr, fdr"
    },
    {
      "tokenType": "number",
      "pattern": "(?<=\\.(i|o|p)\\s+)\\d+",
      "tokenModifiers": [],
      "description": "Numeric count values following .i, .o, or .p directives"
    },
    {
      "tokenType": "property",
      "pattern": "(?<=\\.ilb\\s+)[a-zA-Z_][a-zA-Z0-9_]*",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Individual input variable label names after .ilb directive"
    },
    {
      "tokenType": "property",
      "pattern": "(?<=\\.ob\\s+)[a-zA-Z_][a-zA-Z0-9_]*",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Individual output variable label names after .ob directive"
    },
    {
      "tokenType": "variable",
      "pattern": "^[01-]+(?=\\s+[01-~]+)",
      "tokenModifiers": [],
      "description": "Input column of a product term row (binary string with 0, 1, and don't-care -)"
    },
    {
      "tokenType": "variable",
      "pattern": "(?<=\\s)[01-~]+$",
      "tokenModifiers": [],
      "description": "Output column of a product term row (binary string with 0, 1, -, ~)"
    },
    {
      "tokenType": "operator",
      "pattern": "(?<=[01])\\-(?=[01])",
      "tokenModifiers": [],
      "description": "Don't-care literal (-) within product term input or output columns"
    },
    {
      "tokenType": "operator",
      "pattern": "~",
      "tokenModifiers": [],
      "description": "Complement operator (~) in output column entries"
    },
    {
      "tokenType": "comment",
      "pattern": "^\\s*#[^\\n]*",
      "tokenModifiers": [],
      "description": "Full-line comments beginning with # character"
    },
    {
      "tokenType": "comment",
      "pattern": "\\s+#[^\\n]*$",
      "tokenModifiers": [],
      "description": "Inline trailing comments after data, beginning with #"
    },
    {
      "tokenType": "type",
      "pattern": "(?<=\\.phase\\s+)[01]+",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Output polarity bit string after .phase (0=complemented, 1=true form)"
    },
    {
      "tokenType": "number",
      "pattern": "(?<=\\.mv\\s+)\\d+(\\s+\\d+)*",
      "tokenModifiers": [],
      "description": "Multi-valued variable domain sizes following .mv directive"
    },
    {
      "tokenType": "string",
      "pattern": "(?<=\\.na\\s+)[^\\n]+",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "PLA network name string following .na directive"
    },
    {
      "tokenType": "namespace",
      "pattern": "(?<=\\.exdc)\\b",
      "tokenModifiers": [],
      "description": "External don't-care set section marker (.exdc) beginning a DC-set block"
    },
    {
      "tokenType": "variable",
      "pattern": "^[01-]{2,}$",
      "tokenModifiers": [],
      "description": "Standalone binary pattern line (input-only or compressed truth table row)"
    },
    {
      "tokenType": "variable",
      "pattern": "\\\\bthis\\\\b|\\\\bself\\\\b",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Self/this keyword semantic token"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\\\b(async|await|yield)\\\\b",
      "tokenModifiers": [
        "async"
      ],
      "description": "Async/concurrent keywords"
    },
    {
      "tokenType": "type",
      "pattern": "\\\\b(Promise|Future|Task|Observable)\\\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Concurrent/async types"
    },
    {
      "tokenType": "function",
      "pattern": "\\\\b(get|set)\\\\s+\\\\w+\\\\s*\\\\(",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Getter/setter declarations"
    },
    {
      "tokenType": "variable",
      "pattern": "\\\\b_\\\\w+\\\\b",
      "tokenModifiers": [],
      "description": "Private/underscore-prefixed identifiers"
    },
    {
      "tokenType": "type",
      "pattern": "\\\\b(Array|List|Map|Set|Dict|Vector|HashMap|TreeMap)\\\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Collection types"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\\\b(abstract|virtual|override|final|sealed)\\\\b",
      "tokenModifiers": [],
      "description": "OOP modifier keywords"
    },
    {
      "tokenType": "property",
      "pattern": "\\\\b(length|size|count|isEmpty|isNotEmpty)\\\\b",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Common read-only properties"
    },
    {
      "tokenType": "function",
      "pattern": "\\\\b(map|filter|reduce|forEach|find|some|every)\\\\b",
      "tokenModifiers": [],
      "description": "Iteration/functional methods"
    },
    {
      "tokenType": "modifier",
      "pattern": "\\\\b(override|static|readonly|const|final|volatile)\\\\b",
      "tokenModifiers": [],
      "description": "Member modifiers"
    },
    {
      "tokenType": "namespace",
      "pattern": "\\\\b(std|System|java|kotlin|swift|Foundation)\\\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Standard library namespaces"
    },
    {
      "tokenType": "decorator",
      "pattern": "@[A-Z]\\\\w+",
      "tokenModifiers": [],
      "description": "Class/method annotations (PascalCase)"
    },
    {
      "tokenType": "typeParameter",
      "pattern": "<[A-Z](\\\\w*)>",
      "tokenModifiers": [],
      "description": "Single-letter and named type parameters"
    },
    {
      "tokenType": "event",
      "pattern": "\\\\b(onClick|onChange|onSubmit|onLoad|onError)\\\\b",
      "tokenModifiers": [],
      "description": "Common event handler names"
    },
    {
      "tokenType": "enumMember",
      "pattern": "\\\\b[A-Z][a-z]+[A-Z]\\\\w*\\\\b",
      "tokenModifiers": [],
      "description": "CamelCase identifiers (often enum values)"
    }
  ]
}
