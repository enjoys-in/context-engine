{
  "language": "typescript",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "enum", "interface", "typeParameter", "parameter", "variable", "property", "enumMember", "function", "method", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "documentation", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "class",
      "pattern": "\\bclass\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Class declarations"
    },
    {
      "type": "interface",
      "pattern": "\\binterface\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Interface declarations"
    },
    {
      "type": "type",
      "pattern": "\\btype\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Type alias declarations"
    },
    {
      "type": "enum",
      "pattern": "\\benum\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Enum declarations"
    },
    {
      "type": "typeParameter",
      "pattern": "<([A-Z][a-zA-Z0-9_]*(?:\\s+extends\\s+[a-zA-Z0-9_<>]+)?)>",
      "modifiers": [],
      "description": "Generic type parameters with optional constraints"
    },
    {
      "type": "decorator",
      "pattern": "@([a-zA-Z_][a-zA-Z0-9_.]*)",
      "modifiers": [],
      "description": "Decorator annotations"
    },
    {
      "type": "function",
      "pattern": "\\b(async\\s+)?function\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Function declarations including async"
    },
    {
      "type": "keyword",
      "pattern": "\\b(abstract|as|asserts|await|declare|export|from|implements|import|in|infer|instanceof|is|keyof|namespace|never|readonly|satisfies|typeof|undefined|unique|unknown|using)\\b",
      "modifiers": [],
      "description": "TypeScript-specific keywords"
    },
    {
      "type": "variable",
      "pattern": "\\b(const|let|var)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Variable declarations with const/let/var"
    },
    {
      "type": "method",
      "pattern": "\\b(async\\s+)?([a-zA-Z_][a-zA-Z0-9_]*)\\s*(<[^>]*>)?\\s*\\([^)]*\\)\\s*(?::\\s*[a-zA-Z<>|&\\[\\]]+)?\\s*(?:=>|\\{)",
      "modifiers": ["declaration"],
      "description": "Method declarations and arrow functions"
    },
    {
      "type": "keyword",
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s+is\\s+[A-Z][a-zA-Z0-9_]*\\b",
      "modifiers": [],
      "description": "Type guard expressions using 'is'"
    },
    {
      "type": "type",
      "pattern": "\\b(string|number|boolean|symbol|bigint|void|null|undefined|never|any|unknown|object|Promise|Array|Map|Set|Record|Partial|Required|Readonly|Pick|Omit|Exclude|Extract|NonNullable|ReturnType|Parameters|Awaited)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in types and utility types"
    }
  ]
}
