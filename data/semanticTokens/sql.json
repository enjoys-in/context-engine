{
  "language": "sql",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "variable", "property", "function", "keyword", "modifier", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "keyword",
      "pattern": "\\b(SELECT|INSERT|UPDATE|DELETE|FROM|WHERE|SET|INTO|VALUES|HAVING|GROUP\\s+BY|ORDER\\s+BY|LIMIT|OFFSET|DISTINCT|ALL|AS|ON|USING|UNION|INTERSECT|EXCEPT)\\b",
      "modifiers": [],
      "description": "DML and query clause keywords"
    },
    {
      "type": "keyword",
      "pattern": "\\b(CREATE|ALTER|DROP|TRUNCATE|TABLE|VIEW|INDEX|SCHEMA|DATABASE|TRIGGER|PROCEDURE|FUNCTION|SEQUENCE|CONSTRAINT|PRIMARY\\s+KEY|FOREIGN\\s+KEY|REFERENCES|UNIQUE|CHECK|DEFAULT)\\b",
      "modifiers": [],
      "description": "DDL and schema definition keywords"
    },
    {
      "type": "keyword",
      "pattern": "\\b(INNER|LEFT|RIGHT|FULL|CROSS|NATURAL)?\\s*(JOIN)\\b",
      "modifiers": [],
      "description": "JOIN types and keyword"
    },
    {
      "type": "function",
      "pattern": "\\b(CREATE\\s+(OR\\s+REPLACE\\s+)?(PROCEDURE|FUNCTION))\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Stored procedure and function declarations"
    },
    {
      "type": "type",
      "pattern": "\\b(INT|INTEGER|BIGINT|SMALLINT|TINYINT|DECIMAL|NUMERIC|FLOAT|REAL|DOUBLE|CHAR|VARCHAR|TEXT|NVARCHAR|NCHAR|DATE|TIME|DATETIME|TIMESTAMP|BOOLEAN|BLOB|CLOB|BINARY|VARBINARY|JSON|XML|UUID|SERIAL)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "SQL data types"
    },
    {
      "type": "function",
      "pattern": "\\b(COUNT|SUM|AVG|MIN|MAX|COALESCE|NULLIF|CAST|CONVERT|CONCAT|SUBSTRING|TRIM|UPPER|LOWER|LENGTH|REPLACE|ROUND|CEIL|FLOOR|ABS|NOW|CURRENT_TIMESTAMP|CURRENT_DATE|CURRENT_TIME|EXTRACT|DATE_FORMAT|ROW_NUMBER|RANK|DENSE_RANK|LAG|LEAD|FIRST_VALUE|LAST_VALUE)\\s*\\(",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in SQL functions and window functions"
    },
    {
      "type": "keyword",
      "pattern": "\\b(BEGIN|END|DECLARE|IF|ELSE|ELSEIF|THEN|WHILE|LOOP|RETURN|CURSOR|OPEN|FETCH|CLOSE|COMMIT|ROLLBACK|SAVEPOINT|GRANT|REVOKE|CASE|WHEN|BETWEEN|IN|EXISTS|LIKE|IS\\s+NULL|IS\\s+NOT\\s+NULL|AND|OR|NOT)\\b",
      "modifiers": [],
      "description": "Control flow, transaction, and conditional keywords"
    },
    {
      "type": "variable",
      "pattern": "@([a-zA-Z_][a-zA-Z0-9_]*)",
      "modifiers": [],
      "description": "User-defined variables with @ prefix"
    },
    {
      "type": "comment",
      "pattern": "--[^\\n]*",
      "modifiers": [],
      "description": "Single-line comments with --"
    }
  ]
}
