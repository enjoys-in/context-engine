{
  "language": "sql",
  "legend": {
    "tokenTypes": [
      "namespace",
      "type",
      "variable",
      "property",
      "function",
      "keyword",
      "modifier",
      "comment",
      "string",
      "number",
      "operator"
    ],
    "tokenModifiers": [
      "declaration",
      "definition",
      "defaultLibrary"
    ]
  },
  "semanticRules": [
    {
      "tokenType": "keyword",
      "pattern": "\\b(SELECT|INSERT\\s+INTO|INSERT|UPDATE|DELETE\\s+FROM|DELETE|FROM|WHERE|SET|INTO|VALUES|AS|ON|USING|ALL|DISTINCT|TOP)\\b",
      "tokenModifiers": [],
      "description": "Core DML and query clause keywords"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(CREATE(\\s+OR\\s+REPLACE)?\\s+(TABLE|TEMP(ORARY)?\\s+TABLE|VIEW|INDEX|UNIQUE\\s+INDEX|SCHEMA|DATABASE|SEQUENCE|TRIGGER|PROCEDURE|FUNCTION|TYPE|MATERIALIZED\\s+VIEW)|ALTER\\s+(TABLE|COLUMN|INDEX|SCHEMA|DATABASE|SEQUENCE|VIEW)|DROP\\s+(TABLE|VIEW|INDEX|SCHEMA|DATABASE|SEQUENCE|TRIGGER|PROCEDURE|FUNCTION|TYPE)|TRUNCATE(\\s+TABLE)?)\\b",
      "tokenModifiers": [],
      "description": "DDL statements for tables, views, indexes, schemas, triggers, procedures, and functions"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(INNER\\s+JOIN|LEFT(\\s+OUTER)?\\s+JOIN|RIGHT(\\s+OUTER)?\\s+JOIN|FULL(\\s+OUTER)?\\s+JOIN|CROSS\\s+JOIN|NATURAL\\s+JOIN|LATERAL\\s+JOIN|JOIN)\\b",
      "tokenModifiers": [],
      "description": "JOIN types including INNER, LEFT, RIGHT, FULL OUTER, CROSS, NATURAL, LATERAL"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(GROUP\\s+BY|ORDER\\s+BY|HAVING|LIMIT|OFFSET|FETCH\\s+FIRST|FETCH\\s+NEXT|ROWS\\s+ONLY)\\b",
      "tokenModifiers": [],
      "description": "Grouping, ordering, and result-limiting clauses"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(UNION(\\s+ALL)?|INTERSECT(\\s+ALL)?|EXCEPT(\\s+ALL)?)\\b",
      "tokenModifiers": [],
      "description": "Set operation keywords"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(WITH(\\s+RECURSIVE)?)\\b\\s+[a-zA-Z_]",
      "tokenModifiers": [],
      "description": "Common Table Expression (CTE) WITH and WITH RECURSIVE"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(CASE|WHEN|THEN|ELSE|END)\\b",
      "tokenModifiers": [],
      "description": "CASE conditional expression keywords"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(EXISTS|NOT\\s+EXISTS|IN|NOT\\s+IN|BETWEEN|LIKE|NOT\\s+LIKE|SIMILAR\\s+TO|IS\\s+(NOT\\s+)?NULL|IS\\s+(NOT\\s+)?DISTINCT\\s+FROM|ANY|SOME)\\b",
      "tokenModifiers": [],
      "description": "Predicate and subquery operators"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(AND|OR|NOT|ASC|DESC|NULLS\\s+(FIRST|LAST))\\b",
      "tokenModifiers": [],
      "description": "Logical operators and sort direction keywords"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(PRIMARY\\s+KEY|FOREIGN\\s+KEY|UNIQUE|CHECK|NOT\\s+NULL|DEFAULT|REFERENCES|ON\\s+DELETE\\s+(CASCADE|SET\\s+NULL|SET\\s+DEFAULT|RESTRICT|NO\\s+ACTION)|ON\\s+UPDATE\\s+(CASCADE|SET\\s+NULL|SET\\s+DEFAULT|RESTRICT|NO\\s+ACTION)|CONSTRAINT|ADD\\s+CONSTRAINT)\\b",
      "tokenModifiers": [],
      "description": "Table constraint and referential integrity keywords"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(BEGIN(\\s+TRANSACTION)?|START\\s+TRANSACTION|COMMIT|ROLLBACK|SAVEPOINT|RELEASE\\s+SAVEPOINT|ROLLBACK\\s+TO\\s+SAVEPOINT|SET\\s+TRANSACTION|ISOLATION\\s+LEVEL|READ\\s+(COMMITTED|UNCOMMITTED)|REPEATABLE\\s+READ|SERIALIZABLE)\\b",
      "tokenModifiers": [],
      "description": "Transaction control and isolation level keywords"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(GRANT|REVOKE|ALL\\s+PRIVILEGES|EXECUTE|USAGE)\\b",
      "tokenModifiers": [],
      "description": "DCL privilege control keywords"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(DECLARE|CURSOR|OPEN|FETCH|CLOSE|DEALLOCATE|IF|ELSEIF|ELSE|THEN|WHILE|LOOP|FOR|RETURN|RETURNS|LANGUAGE|BEGIN|END|CALL|EXECUTE|PREPARE)\\b",
      "tokenModifiers": [],
      "description": "Procedural, cursor, and control flow keywords"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(MERGE\\s+INTO|MERGE|MATCHED|NOT\\s+MATCHED|WHEN\\s+MATCHED|WHEN\\s+NOT\\s+MATCHED|UPSERT|ON\\s+CONFLICT|DO\\s+UPDATE|DO\\s+NOTHING)\\b",
      "tokenModifiers": [],
      "description": "MERGE and UPSERT/ON CONFLICT keywords"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(EXPLAIN(\\s+ANALYZE)?|EXPLAIN\\s+PLAN)\\b",
      "tokenModifiers": [],
      "description": "EXPLAIN and query plan analysis keywords"
    },
    {
      "tokenType": "type",
      "pattern": "\\b(SMALLINT|INTEGER|INT|BIGINT|TINYINT|MEDIUMINT|DECIMAL|NUMERIC|FLOAT|REAL|DOUBLE(\\s+PRECISION)?|CHAR|VARCHAR|NCHAR|NVARCHAR|TEXT|CLOB|BLOB|BINARY|VARBINARY|DATE|TIME|DATETIME|TIMESTAMP(\\s+WITH(OUT)?\\s+TIME\\s+ZONE)?|BOOLEAN|BOOL|JSON|JSONB|XML|UUID|SERIAL|BIGSERIAL|SMALLSERIAL|INTERVAL|MONEY|ARRAY|BIT)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "SQL data types including standard and extended types"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(COUNT|SUM|AVG|MIN|MAX|GROUP_CONCAT|STRING_AGG|ARRAY_AGG|LISTAGG|EVERY|BOOL_AND|BOOL_OR)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Aggregate functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(ROW_NUMBER|RANK|DENSE_RANK|NTILE|LAG|LEAD|FIRST_VALUE|LAST_VALUE|NTH_VALUE|CUME_DIST|PERCENT_RANK)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Window/analytic functions"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(OVER)\\s*\\(|\\bPARTITION\\s+BY\\b|\\b(ROWS|RANGE|GROUPS)\\s+BETWEEN\\b|\\bUNBOUNDED\\s+(PRECEDING|FOLLOWING)\\b|\\bCURRENT\\s+ROW\\b",
      "tokenModifiers": [],
      "description": "Window frame specification and OVER clause keywords"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(CAST|CONVERT|COALESCE|NULLIF|GREATEST|LEAST|IIF|IFNULL|NVL|DECODE)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Conditional and conversion scalar functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(CONCAT|SUBSTRING|SUBSTR|TRIM|LTRIM|RTRIM|UPPER|LOWER|UCASE|LCASE|LENGTH|CHAR_LENGTH|CHARACTER_LENGTH|REPLACE|POSITION|LOCATE|INSTR|LEFT|RIGHT|LPAD|RPAD|REVERSE|REPEAT|TRANSLATE|INITCAP|CHARINDEX|STUFF|QUOTENAME|FORMAT|SPACE|SOUNDEX)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "String manipulation functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(NOW|CURRENT_TIMESTAMP|CURRENT_DATE|CURRENT_TIME|GETDATE|GETUTCDATE|SYSDATETIME|SYSUTCDATETIME|DATE_FORMAT|DATE_ADD|DATE_SUB|DATEADD|DATEDIFF|DATE_TRUNC|EXTRACT|YEAR|MONTH|DAY|HOUR|MINUTE|SECOND|TIMESTAMPADD|TIMESTAMPDIFF|TO_DATE|TO_CHAR|TO_TIMESTAMP|STRFTIME|DATE_PART|AGE|INTERVAL)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Date/time functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(ABS|CEIL|CEILING|FLOOR|ROUND|TRUNC|TRUNCATE|MOD|POWER|SQRT|LOG|LOG2|LOG10|LN|EXP|SIGN|RAND|RANDOM|PI|DEGREES|RADIANS|SIN|COS|TAN|ASIN|ACOS|ATAN|ATAN2|COT)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Mathematical functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(CREATE(\\s+OR\\s+REPLACE)?\\s+(FUNCTION|PROCEDURE))\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "User-defined function and procedure declarations"
    },
    {
      "tokenType": "operator",
      "pattern": "(=|<>|!=|<=|>=|<|>|\\+|-|\\*|/|%|\\|\\||&&|::)",
      "tokenModifiers": [],
      "description": "Comparison, arithmetic, concatenation, and type cast operators"
    },
    {
      "tokenType": "variable",
      "pattern": "@[a-zA-Z_][a-zA-Z0-9_]*|:[a-zA-Z_][a-zA-Z0-9_]*|\\$[0-9]+",
      "tokenModifiers": [],
      "description": "User variables (@var), named parameters (:param), and positional parameters ($1)"
    },
    {
      "tokenType": "namespace",
      "pattern": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\.[a-zA-Z_][a-zA-Z0-9_]*\\.[a-zA-Z_][a-zA-Z0-9_]*\\b",
      "tokenModifiers": [],
      "description": "Fully qualified schema.table.column references"
    },
    {
      "tokenType": "modifier",
      "pattern": "\\b(IF\\s+NOT\\s+EXISTS|IF\\s+EXISTS|CASCADE|RESTRICT|CONCURRENTLY|TEMPORARY|TEMP|UNLOGGED|LOCAL|GLOBAL)\\b",
      "tokenModifiers": [],
      "description": "DDL modifiers and conditional existence checks"
    },
    {
      "tokenType": "property",
      "pattern": "\\b(AUTO_INCREMENT|AUTOINCREMENT|GENERATED\\s+(ALWAYS|BY\\s+DEFAULT)\\s+AS\\s+IDENTITY|NEXTVAL|CURRVAL|SETVAL)\\b",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Auto-increment and sequence identity column properties"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(RETURNING|OUTPUT|INSERTED|DELETED|NEW|OLD)\\b",
      "tokenModifiers": [],
      "description": "DML output and row reference keywords"
    },
    {
      "tokenType": "comment",
      "pattern": "--[^\\n]*|/\\*[\\s\\S]*?\\*/",
      "tokenModifiers": [],
      "description": "Single-line (--) and multi-line (/* */) SQL comments"
    },
    {
      "tokenType": "string",
      "pattern": "'([^'\\\\]|\\\\.)*'|N'([^'\\\\]|\\\\.)*'",
      "tokenModifiers": [],
      "description": "String literals and Unicode string literals (N'...')"
    },
    {
      "tokenType": "number",
      "pattern": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b",
      "tokenModifiers": [],
      "description": "Numeric literals including decimal and scientific notation"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(PARTITION\\s+BY\\s+(RANGE|LIST|HASH)|TABLESPACE|STORAGE|FILLFACTOR|CLUSTER|COMMENT\\s+ON|ANALYZE|VACUUM|REINDEX|REFRESH)\\b",
      "tokenModifiers": [],
      "description": "Table partitioning, storage, and maintenance keywords"
    }
  ]
}
