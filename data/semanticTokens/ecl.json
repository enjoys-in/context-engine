{
  "language": "ecl",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["type", "variable", "function", "keyword", "macro", "namespace", "property", "parameter"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "type",
      "pattern": "\\bRECORD\\b",
      "modifiers": ["definition"],
      "description": "RECORD structure definitions"
    },
    {
      "type": "variable",
      "pattern": "\\bDATASET\\s*\\([^)]+\\)",
      "modifiers": ["declaration"],
      "description": "DATASET declarations"
    },
    {
      "type": "namespace",
      "pattern": "\\bMODULE\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "MODULE definitions"
    },
    {
      "type": "function",
      "pattern": "\\b(OUTPUT|SEQUENTIAL|PARALLEL|APPLY|IF|CASE|MAP|CHOOSE)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in action keywords"
    },
    {
      "type": "macro",
      "pattern": "\\bMACRO\\b",
      "modifiers": ["definition"],
      "description": "MACRO definitions"
    },
    {
      "type": "variable",
      "pattern": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*:=",
      "modifiers": ["definition"],
      "description": "Attribute/value definitions using :="
    },
    {
      "type": "keyword",
      "pattern": "\\b(EXPORT|SHARED|LOCAL)\\b",
      "modifiers": [],
      "description": "Scope/visibility keywords"
    },
    {
      "type": "type",
      "pattern": "\\b(STRING|INTEGER|REAL|BOOLEAN|UNSIGNED|DATA|DECIMAL|SET\\s+OF|UNICODE|VARSTRING)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in ECL data types"
    },
    {
      "type": "function",
      "pattern": "\\b(SORT|DEDUP|JOIN|TABLE|COUNT|SUM|AVE|MIN|MAX|ROLLUP|DISTRIBUTE|PROJECT|NORMALIZE|DENORMALIZE)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in transformation functions"
    },
    {
      "type": "keyword",
      "pattern": "\\b(TRANSFORM|SELF|LEFT|RIGHT|ROWS|COUNTER)\\b",
      "modifiers": [],
      "description": "Transform and special reference keywords"
    }
  ]
}
