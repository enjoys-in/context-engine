{
  "language": "nestjs",
  "semanticTokens": {
    "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "async", "modification", "documentation", "defaultLibrary", "abstract"],
    "tokenLegend": {
      "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
      "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "async", "modification", "documentation", "defaultLibrary", "abstract"]
    },
    "tokenRules": [
      { "pattern": "\\b(import|export|from|default|as|const|let|var|function|return|if|else|for|while|do|switch|case|break|continue|throw|try|catch|finally|new|delete|typeof|instanceof|in|of|void|yield|await|async|class|extends|super|this|static|get|set|implements|abstract|private|protected|public|readonly)\\b", "tokenType": "keyword", "tokenModifiers": [], "description": "Language keywords" },
      { "pattern": "@(Controller|Injectable|Module|Inject|Optional|Global|Catch|UseGuards|UseInterceptors|UsePipes|UseFilters|SetMetadata|Get|Post|Put|Patch|Delete|Head|Options|All|Body|Param|Query|Headers|Req|Res|HttpCode|Header|Redirect|Render|Sse|WebSocketGateway|SubscribeMessage|ConnectedSocket|WebSocketServer|Cron|Interval|Timeout|EventPattern|MessagePattern)\\b", "tokenType": "decorator", "tokenModifiers": ["defaultLibrary"], "description": "NestJS decorators" },
      { "pattern": "@(ApiTags|ApiOperation|ApiResponse|ApiProperty|ApiBody|ApiBearerAuth|ApiQuery|ApiParam|ApiHeader|ApiExcludeEndpoint|ApiProduces|ApiConsumes)\\b", "tokenType": "decorator", "tokenModifiers": ["defaultLibrary"], "description": "Swagger decorators" },
      { "pattern": "@(Entity|Column|PrimaryGeneratedColumn|PrimaryColumn|CreateDateColumn|UpdateDateColumn|DeleteDateColumn|ManyToOne|OneToMany|ManyToMany|OneToOne|JoinColumn|JoinTable|Index|Unique|BeforeInsert|AfterInsert|BeforeUpdate|AfterUpdate)\\b", "tokenType": "decorator", "tokenModifiers": ["defaultLibrary"], "description": "TypeORM decorators" },
      { "pattern": "@(IsString|IsNumber|IsBoolean|IsEmail|IsNotEmpty|IsOptional|IsArray|IsEnum|IsDate|IsUUID|MinLength|MaxLength|Min|Max|Matches|ValidateNested|Type|Transform)\\b", "tokenType": "decorator", "tokenModifiers": ["defaultLibrary"], "description": "class-validator decorators" },
      { "pattern": "\\b(NestFactory|ModuleRef|Reflector|DiscoveryService|LazyModuleLoader)\\b", "tokenType": "class", "tokenModifiers": ["defaultLibrary"], "description": "NestJS core classes" },
      { "pattern": "\\b(ConfigModule|TypeOrmModule|MongooseModule|JwtModule|PassportModule|ThrottlerModule|CacheModule|ScheduleModule|BullModule|EventEmitterModule|ServeStaticModule|GraphQLModule)\\b", "tokenType": "class", "tokenModifiers": ["defaultLibrary"], "description": "NestJS modules" },
      { "pattern": "\\b(ValidationPipe|ParseIntPipe|ParseBoolPipe|ParseArrayPipe|ParseUUIDPipe|ParseEnumPipe|ParseFloatPipe|DefaultValuePipe)\\b", "tokenType": "class", "tokenModifiers": ["defaultLibrary"], "description": "NestJS pipes" },
      { "pattern": "\\b(HttpException|BadRequestException|UnauthorizedException|ForbiddenException|NotFoundException|ConflictException|InternalServerErrorException|NotImplementedException|BadGatewayException|ServiceUnavailableException|GatewayTimeoutException|UnprocessableEntityException)\\b", "tokenType": "class", "tokenModifiers": ["defaultLibrary"], "description": "NestJS exceptions" },
      { "pattern": "\\b(INestApplication|INestMicroservice|DynamicModule|ModuleMetadata|CanActivate|PipeTransform|NestInterceptor|ExceptionFilter|NestMiddleware|ExecutionContext|ArgumentsHost|CallHandler|OnModuleInit|OnModuleDestroy|OnApplicationBootstrap|OnApplicationShutdown)\\b", "tokenType": "interface", "tokenModifiers": ["defaultLibrary"], "description": "NestJS interfaces" },
      { "pattern": "\\bclass\\s+(\\w+)", "tokenType": "class", "tokenModifiers": ["declaration"], "description": "Class declarations" },
      { "pattern": "\\binterface\\s+(\\w+)", "tokenType": "interface", "tokenModifiers": ["declaration"], "description": "Interface declarations" },
      { "pattern": "\\benum\\s+(\\w+)", "tokenType": "enum", "tokenModifiers": ["declaration"], "description": "Enum declarations" },
      { "pattern": "\\btype\\s+(\\w+)\\s*=", "tokenType": "type", "tokenModifiers": ["declaration"], "description": "Type aliases" },
      { "pattern": "(?:async\\s+)?(\\w+)\\s*\\([^)]*\\)\\s*(?::\\s*[^{]+)?\\s*\\{", "tokenType": "method", "tokenModifiers": [], "description": "Method definitions" },
      { "pattern": "constructor\\s*\\(", "tokenType": "method", "tokenModifiers": ["declaration"], "description": "Constructor" },
      { "pattern": "(?:'[^']*'|\"[^\"]*\"|`[^`]*`)", "tokenType": "string", "tokenModifiers": [], "description": "String literals" },
      { "pattern": "\\b\\d+(\\.\\d+)?\\b", "tokenType": "number", "tokenModifiers": [], "description": "Numeric literals" },
      { "pattern": "\\/(?!\\/|\\*)[^\\/\\n]+\\/[gimsuy]*", "tokenType": "regexp", "tokenModifiers": [], "description": "Regular expressions" },
      { "pattern": "(?:^|\\s)(?:\\/\\/.*|\\/\\*[\\s\\S]*?\\*\\/)", "tokenType": "comment", "tokenModifiers": [], "description": "Comments" },
      { "pattern": "\\b(describe|it|expect|beforeEach|afterEach|beforeAll|afterAll|jest|Test|TestingModule)\\b", "tokenType": "function", "tokenModifiers": ["defaultLibrary"], "description": "Testing functions" },
      { "pattern": "\\bprocess\\.env\\.(\\w+)", "tokenType": "variable", "tokenModifiers": ["readonly"], "description": "Environment variables" }
    ]
  }
}