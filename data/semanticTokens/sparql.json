{
  "language": "sparql",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "variable", "property", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "keyword",
      "pattern": "\\b(SELECT|CONSTRUCT|ASK|DESCRIBE|WHERE|FROM|NAMED|BASE|PREFIX|DISTINCT|REDUCED|ORDER\\s+BY|LIMIT|OFFSET|GROUP\\s+BY|HAVING|UNION)\\b",
      "modifiers": [],
      "description": "SPARQL query form and clause keywords"
    },
    {
      "type": "keyword",
      "pattern": "\\b(FILTER|OPTIONAL|BIND|VALUES|GRAPH|SERVICE|MINUS|EXISTS|NOT\\s+EXISTS)\\b",
      "modifiers": [],
      "description": "SPARQL pattern and filter keywords"
    },
    {
      "type": "variable",
      "pattern": "\\?([a-zA-Z_][a-zA-Z0-9_]*)",
      "modifiers": [],
      "description": "SPARQL query variables with ? prefix"
    },
    {
      "type": "variable",
      "pattern": "\\$([a-zA-Z_][a-zA-Z0-9_]*)",
      "modifiers": [],
      "description": "SPARQL query variables with $ prefix"
    },
    {
      "type": "namespace",
      "pattern": "PREFIX\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*:",
      "modifiers": ["declaration"],
      "description": "PREFIX namespace declarations"
    },
    {
      "type": "function",
      "pattern": "\\b(STR|LANG|LANGMATCHES|DATATYPE|BOUND|IRI|URI|BNODE|RAND|ABS|CEIL|FLOOR|ROUND|CONCAT|STRLEN|UCASE|LCASE|ENCODE_FOR_URI|CONTAINS|STRSTARTS|STRENDS|STRBEFORE|STRAFTER|YEAR|MONTH|DAY|HOURS|MINUTES|SECONDS|TIMEZONE|NOW|UUID|STRUUID|MD5|SHA1|SHA256|SHA384|SHA512|COALESCE|IF|STRLANG|STRDT|sameTerm|isIRI|isURI|isBLANK|isLITERAL|isNUMERIC|REGEX|REPLACE|SUBSTR)\\s*\\(",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in SPARQL functions"
    },
    {
      "type": "function",
      "pattern": "\\b(COUNT|SUM|MIN|MAX|AVG|GROUP_CONCAT|SAMPLE)\\s*\\(",
      "modifiers": ["defaultLibrary"],
      "description": "SPARQL aggregate functions"
    },
    {
      "type": "property",
      "pattern": "([a-zA-Z_][a-zA-Z0-9_]*):[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": [],
      "description": "Prefixed name property references"
    },
    {
      "type": "comment",
      "pattern": "#[^\\n]*",
      "modifiers": [],
      "description": "Line comments starting with #"
    }
  ]
}
