{
  "language": "perl",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "variable", "function", "method", "keyword", "comment", "string", "number", "regexp", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "function",
      "pattern": "\\bsub\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Subroutine declarations with sub keyword"
    },
    {
      "type": "variable",
      "pattern": "\\$_|\\$\\d+|\\$[!@\\$%^&*]|\\$\\w+",
      "modifiers": [],
      "description": "Scalar variables including special variables like $_, $!, $1"
    },
    {
      "type": "variable",
      "pattern": "@_|@\\w+|@ARGV|@INC|@ISA",
      "modifiers": [],
      "description": "Array variables including special arrays @_, @ARGV, @INC"
    },
    {
      "type": "variable",
      "pattern": "%ENV|%SIG|%INC|%\\w+",
      "modifiers": [],
      "description": "Hash variables including special hashes %ENV, %SIG"
    },
    {
      "type": "namespace",
      "pattern": "\\b(package)\\s+([\\w:]+)",
      "modifiers": ["declaration"],
      "description": "Package/namespace declarations"
    },
    {
      "type": "keyword",
      "pattern": "\\b(use|require|no|package|my|our|local|sub|if|elsif|else|unless|while|until|for|foreach|do|last|next|redo|return|die|warn|print|say|chomp|chop|push|pop|shift|unshift|splice|grep|map|sort|keys|values|exists|delete|defined|undef|bless|ref|tie|untie|BEGIN|END|INIT|DESTROY|new)\\b",
      "modifiers": [],
      "description": "Perl keywords and built-in functions"
    },
    {
      "type": "regexp",
      "pattern": "(?:m|qr)?/[^/\\n]*/[gimsxce]*|s/[^/\\n]*/[^/\\n]*/[gimsxce]*|tr/[^/\\n]*/[^/\\n]*/[cds]*",
      "modifiers": [],
      "description": "Regular expressions, substitutions, and transliterations"
    },
    {
      "type": "namespace",
      "pattern": "\\b(use|require)\\s+([\\w:]+)",
      "modifiers": ["definition"],
      "description": "Module imports with use and require"
    },
    {
      "type": "method",
      "pattern": "->\\s*(\\w+)",
      "modifiers": [],
      "description": "Method calls via arrow operator"
    },
    {
      "type": "comment",
      "pattern": "#[^\\n]*|^=\\w+[\\s\\S]*?^=cut",
      "modifiers": [],
      "description": "Line comments and POD documentation blocks"
    },
    {
      "type": "string",
      "pattern": "\"([^\"\\\\]|\\\\.)*\"|'([^'\\\\]|\\\\.)*'|qq?\\{[^}]*\\}|qq?\\([^)]*\\)|qq?\\[[^\\]]*\\]",
      "modifiers": [],
      "description": "String literals with various quoting mechanisms"
    }
  ]
}
