{
  "language": "azcli",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["keyword", "function", "parameter", "variable", "property", "string", "namespace"],
    "tokenModifiers": ["declaration", "readonly", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "keyword",
      "pattern": "^az\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Root az command"
    },
    {
      "type": "function",
      "pattern": "\\baz\\s+(group|account|vm|storage|network|webapp|aks|acr|ad|keyvault|monitor|sql|cosmosdb|functionapp)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Top-level az command groups"
    },
    {
      "type": "parameter",
      "pattern": "--([a-z][a-z0-9-]*)",
      "modifiers": [],
      "description": "Long parameter flags (--parameter)"
    },
    {
      "type": "parameter",
      "pattern": "\\s-([a-zA-Z])\\s",
      "modifiers": [],
      "description": "Short parameter flags (-p)"
    },
    {
      "type": "variable",
      "pattern": "\\$\\{?[a-zA-Z_][a-zA-Z0-9_]*\\}?",
      "modifiers": [],
      "description": "Shell variable references"
    },
    {
      "type": "property",
      "pattern": "--resource-group\\s+([a-zA-Z0-9_-]+)",
      "modifiers": [],
      "description": "Resource group name references"
    },
    {
      "type": "string",
      "pattern": "--subscription\\s+(['\"]?[a-zA-Z0-9-]+['\"]?)",
      "modifiers": ["readonly"],
      "description": "Subscription references"
    },
    {
      "type": "namespace",
      "pattern": "/subscriptions/[a-f0-9-]+/resourceGroups/[a-zA-Z0-9_-]+",
      "modifiers": ["readonly"],
      "description": "Azure resource ID paths"
    },
    {
      "type": "keyword",
      "pattern": "\\b(create|delete|list|show|update|set|get|start|stop|restart)\\b",
      "modifiers": [],
      "description": "Common action subcommands"
    },
    {
      "type": "parameter",
      "pattern": "--output\\s+(json|table|tsv|jsonc|yaml|yamlc|none)",
      "modifiers": [],
      "description": "Output format parameter values"
    }
  ]
}
