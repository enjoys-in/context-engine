{
  "language": "sb",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "property", "function", "method", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "keyword",
      "pattern": "\\b(Sub|EndSub|If|Then|Else|ElseIf|EndIf|For|To|Step|EndFor|While|EndWhile|Goto)\\b",
      "modifiers": [],
      "description": "Small Basic control flow and structure keywords"
    },
    {
      "type": "function",
      "pattern": "\\bSub\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Subroutine declarations"
    },
    {
      "type": "variable",
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*=",
      "modifiers": ["declaration"],
      "description": "Variable assignments"
    },
    {
      "type": "property",
      "pattern": "\\b(TextWindow|GraphicsWindow|Math|Clock|Desktop|File|Network|Program|Sound|Stack|Array|Turtle|Shapes|Timer|Mouse|Flickr|ImageList)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in Small Basic objects"
    },
    {
      "type": "method",
      "pattern": "\\.(WriteLine|ReadLine|Show|DrawRectangle|DrawEllipse|FillRectangle|GetRandomNumber|Clear|Pause|Read|Write|GetContent|AddLine|InsertLine)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in object methods"
    },
    {
      "type": "string",
      "pattern": "\"[^\"]*\"",
      "modifiers": [],
      "description": "String literals in double quotes"
    },
    {
      "type": "comment",
      "pattern": "'[^\\n]*",
      "modifiers": [],
      "description": "Single-line comments starting with apostrophe"
    }
  ]
}
