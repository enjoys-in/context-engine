{
  "language": "rust",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "enum", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "async", "documentation", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "function",
      "pattern": "\\bfn\\s+([a-z_][a-z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Function declarations with fn keyword"
    },
    {
      "type": "struct",
      "pattern": "\\bstruct\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Struct type declarations"
    },
    {
      "type": "enum",
      "pattern": "\\benum\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Enum type declarations"
    },
    {
      "type": "typeParameter",
      "pattern": "'([a-z][a-z0-9_]*)",
      "modifiers": [],
      "description": "Lifetime annotations like 'a, 'static"
    },
    {
      "type": "macro",
      "pattern": "\\b([a-z_][a-z0-9_]*)\\s*!",
      "modifiers": [],
      "description": "Macro invocations like println!, vec!"
    },
    {
      "type": "keyword",
      "pattern": "\\b(async|await|unsafe|pub|mod|use|impl|trait|where|dyn|move|ref|mut|self|super|crate)\\b",
      "modifiers": [],
      "description": "Rust-specific keywords including async/await and ownership"
    },
    {
      "type": "decorator",
      "pattern": "#\\[derive\\(([^)]+)\\)\\]",
      "modifiers": [],
      "description": "Derive attribute macros"
    },
    {
      "type": "decorator",
      "pattern": "#\\[([a-z_][a-z0-9_:]*)\\]",
      "modifiers": [],
      "description": "Attribute annotations like #[test], #[cfg]"
    },
    {
      "type": "type",
      "pattern": "\\b(i8|i16|i32|i64|i128|u8|u16|u32|u64|u128|f32|f64|bool|char|str|usize|isize|String|Vec|Option|Result|Box)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in and common standard library types"
    },
    {
      "type": "variable",
      "pattern": "\\blet\\s+(mut\\s+)?([a-z_][a-z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Variable bindings with let/let mut"
    }
  ]
}
