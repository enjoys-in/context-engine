{
  "language": "liquid",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "property", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "keyword",
      "pattern": "\\{%[-\\s]*(if|elsif|else|endif|unless|endunless|for|endfor|case|when|endcase|capture|endcapture|assign|include|render|layout|block|endblock|comment|endcomment|raw|endraw|tablerow|endtablerow|increment|decrement|break|continue|cycle|paginate|endpaginate|schema|endschema|style|endstyle|section|javascript|stylesheet)[-\\s]*%\\}",
      "modifiers": [],
      "description": "Liquid tag keywords in {% %} blocks"
    },
    {
      "type": "variable",
      "pattern": "\\{\\{\\s*[a-zA-Z_][a-zA-Z0-9_.\\[\\]]*\\s*(?:\\|[^}]+)?\\}\\}",
      "modifiers": [],
      "description": "Output expressions in {{ }} with optional filters"
    },
    {
      "type": "function",
      "pattern": "\\|\\s*[a-z_][a-z0-9_]*",
      "modifiers": ["defaultLibrary"],
      "description": "Filter functions after pipe operator"
    },
    {
      "type": "property",
      "pattern": "(?<=\\.)[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": [],
      "description": "Object property access via dot notation"
    },
    {
      "type": "variable",
      "pattern": "(?<=assign\\s+)[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Variable assignments with assign tag"
    },
    {
      "type": "keyword",
      "pattern": "\\b(in|and|or|not|contains|blank|empty|nil|true|false|limit|offset|reversed|cols)\\b",
      "modifiers": [],
      "description": "Liquid expression keywords and loop parameters"
    },
    {
      "type": "variable",
      "pattern": "\\b(forloop|tablerowloop|product|collection|cart|customer|shop|page|article|blog|section|block|template|content_for_header|content_for_layout)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in Liquid objects"
    },
    {
      "type": "string",
      "pattern": "\"(?:[^\"\\\\]|\\\\.)*\"|'(?:[^'\\\\]|\\\\.)*'",
      "modifiers": [],
      "description": "String literals in single or double quotes"
    },
    {
      "type": "comment",
      "pattern": "\\{%\\s*comment\\s*%\\}[\\s\\S]*?\\{%\\s*endcomment\\s*%\\}",
      "modifiers": ["documentation"],
      "description": "Liquid comment blocks"
    },
    {
      "type": "number",
      "pattern": "-?\\d+\\.?\\d*",
      "modifiers": [],
      "description": "Numeric literal values"
    }
  ]
}
