{
  "language": "protobuf",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "enum", "interface", "property", "enumMember", "function", "method", "keyword", "modifier", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "deprecated"]
  },
  "semanticRules": [
    {
      "type": "class",
      "pattern": "\\b(message)\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Message type declarations"
    },
    {
      "type": "enum",
      "pattern": "\\b(enum)\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Enum type declarations"
    },
    {
      "type": "interface",
      "pattern": "\\b(service)\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Service declarations for gRPC services"
    },
    {
      "type": "method",
      "pattern": "\\b(rpc)\\s+(\\w+)\\s*\\(",
      "modifiers": ["declaration"],
      "description": "RPC method definitions within services"
    },
    {
      "type": "type",
      "pattern": "\\b(double|float|int32|int64|uint32|uint64|sint32|sint64|fixed32|fixed64|sfixed32|sfixed64|bool|string|bytes|map|repeated|optional|required|oneof|Any|Timestamp|Duration|Empty|Struct|Value|FieldMask)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Protobuf scalar types, field rules, and well-known types"
    },
    {
      "type": "namespace",
      "pattern": "\\b(package)\\s+([\\w.]+)",
      "modifiers": ["declaration"],
      "description": "Package declarations for namespace scoping"
    },
    {
      "type": "keyword",
      "pattern": "\\b(import|package|option|syntax|extend|extensions|reserved|returns|stream|weak|public)\\b",
      "modifiers": [],
      "description": "Protobuf keywords for imports, options, and structure"
    },
    {
      "type": "property",
      "pattern": "\\b(option)\\s+([\\w.()]+)\\s*=",
      "modifiers": ["definition"],
      "description": "Option definitions for files, messages, fields, and services"
    },
    {
      "type": "number",
      "pattern": "\\b\\d+\\b",
      "modifiers": [],
      "description": "Field numbers and numeric values"
    },
    {
      "type": "comment",
      "pattern": "//[^\\n]*|/\\*[\\s\\S]*?\\*/",
      "modifiers": [],
      "description": "Single-line and multi-line comments"
    },
    {
      "type": "string",
      "pattern": "\"([^\"\\\\]|\\\\.)*\"",
      "modifiers": [],
      "description": "String literals in double quotes"
    }
  ]
}
