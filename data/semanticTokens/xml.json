{
  "language": "xml",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "property", "keyword", "comment", "string", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly"]
  },
  "semanticRules": [
    {
      "type": "type",
      "pattern": "</?([a-zA-Z_][a-zA-Z0-9_:.\\-]*)",
      "modifiers": [],
      "description": "Element tag names in opening and closing tags"
    },
    {
      "type": "property",
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_:.\\-]*)\\s*=",
      "modifiers": [],
      "description": "Attribute names in elements"
    },
    {
      "type": "namespace",
      "pattern": "xmlns(?::([a-zA-Z_][a-zA-Z0-9_]*))?\\s*=",
      "modifiers": ["declaration"],
      "description": "Namespace declarations with xmlns"
    },
    {
      "type": "namespace",
      "pattern": "([a-zA-Z_][a-zA-Z0-9_]*):[a-zA-Z_][a-zA-Z0-9_:.\\-]*",
      "modifiers": [],
      "description": "Namespace prefixes on elements and attributes"
    },
    {
      "type": "keyword",
      "pattern": "<!\\[CDATA\\[[\\s\\S]*?\\]\\]>",
      "modifiers": [],
      "description": "CDATA sections"
    },
    {
      "type": "keyword",
      "pattern": "<\\?([a-zA-Z_][a-zA-Z0-9_\\-]*)\\b",
      "modifiers": [],
      "description": "Processing instructions like <?xml ?>"
    },
    {
      "type": "comment",
      "pattern": "<!--[\\s\\S]*?-->",
      "modifiers": [],
      "description": "XML comments"
    },
    {
      "type": "keyword",
      "pattern": "<!DOCTYPE\\b[^>]*>",
      "modifiers": [],
      "description": "DOCTYPE declarations"
    },
    {
      "type": "string",
      "pattern": "&([a-zA-Z_][a-zA-Z0-9_]*|#[0-9]+|#x[0-9a-fA-F]+);",
      "modifiers": [],
      "description": "Entity references and character references"
    }
  ]
}
