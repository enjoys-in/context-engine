{
  "language": "coffee",
  "legend": {
    "tokenTypes": [
      "class",
      "variable",
      "property",
      "parameter",
      "function",
      "method",
      "keyword",
      "string",
      "number",
      "regexp",
      "operator"
    ],
    "tokenModifiers": [
      "declaration",
      "definition",
      "readonly",
      "static"
    ]
  },
  "semanticRules": [
    {
      "tokenType": "class",
      "pattern": "\\bclass\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Class declarations"
    },
    {
      "tokenType": "class",
      "pattern": "\\bclass\\s+[A-Z][a-zA-Z0-9_]*\\s+extends\\s+([A-Z][a-zA-Z0-9_.]*)\\b",
      "tokenModifiers": [],
      "description": "Superclass reference in class inheritance (extends)"
    },
    {
      "tokenType": "function",
      "pattern": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*[:=]\\s*\\([^)]*\\)\\s*->",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Thin arrow function definitions (bound-free ->)"
    },
    {
      "tokenType": "function",
      "pattern": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*[:=]\\s*\\([^)]*\\)\\s*=>",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Fat arrow function definitions (bound =>)"
    },
    {
      "tokenType": "method",
      "pattern": "^\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*:\\s*\\([^)]*\\)\\s*[-=]>",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Class method definitions inside class body"
    },
    {
      "tokenType": "method",
      "pattern": "\\bconstructor\\s*:\\s*\\([^)]*\\)\\s*->",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Constructor method definition in class"
    },
    {
      "tokenType": "property",
      "pattern": "@([a-zA-Z_][a-zA-Z0-9_]*)",
      "tokenModifiers": [],
      "description": "Instance property shorthand (@prop as this.prop)"
    },
    {
      "tokenType": "property",
      "pattern": "@([a-zA-Z_][a-zA-Z0-9_]*)\\s*[:=]",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Instance property assignment in constructor (@prop = value)"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(if|then|else|unless|while|until|for|loop|break|continue|return|throw|yield)\\b",
      "tokenModifiers": [],
      "description": "Control flow keywords"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(switch|when|try|catch|finally)\\b",
      "tokenModifiers": [],
      "description": "Switch/when pattern matching and exception handling"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(extends|super|constructor|this|do|by|own|new|delete|typeof|instanceof)\\b",
      "tokenModifiers": [],
      "description": "Class-related, iteration, and type-checking keywords"
    },
    {
      "tokenType": "operator",
      "pattern": "\\b(is|isnt|not|and|or|in|of)\\b",
      "tokenModifiers": [],
      "description": "CoffeeScript English-style boolean and membership operators"
    },
    {
      "tokenType": "operator",
      "pattern": "\\?(?!\\.|\\s*[:=])",
      "tokenModifiers": [],
      "description": "Existential operator (?) for null/undefined checks"
    },
    {
      "tokenType": "operator",
      "pattern": "\\?\\.(?=[a-zA-Z_])",
      "tokenModifiers": [],
      "description": "Soak accessor (?.) for safe property access on nullable objects"
    },
    {
      "tokenType": "operator",
      "pattern": "\\?\\(",
      "tokenModifiers": [],
      "description": "Existential function call (?()) for safe invocation"
    },
    {
      "tokenType": "operator",
      "pattern": "\\.\\.\\.",
      "tokenModifiers": [],
      "description": "Splat operator (...) for variadic arguments and array expansion"
    },
    {
      "tokenType": "parameter",
      "pattern": "\\(([a-zA-Z_][a-zA-Z0-9_]*(?:\\s*,\\s*[a-zA-Z_][a-zA-Z0-9_]*)*)\\s*\\.\\.\\.\\)\\s*[-=]>",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Splat parameters in function signatures (args...)"
    },
    {
      "tokenType": "variable",
      "pattern": "\\[([a-zA-Z_][a-zA-Z0-9_]*(?:\\s*,\\s*[a-zA-Z_][a-zA-Z0-9_]*)*)\\]\\s*=",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Array destructuring assignments"
    },
    {
      "tokenType": "variable",
      "pattern": "\\{([a-zA-Z_][a-zA-Z0-9_]*(?:\\s*,\\s*[a-zA-Z_][a-zA-Z0-9_]*)*)\\}\\s*=",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Object destructuring assignments"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\bfor\\s+(?:own\\s+)?\\w+(?:\\s*,\\s*\\w+)?\\s+(?:in|of)\\b",
      "tokenModifiers": [],
      "description": "For comprehension headers (for x in/of collection)"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\bwhen\\s+(?=[a-zA-Z_@!])",
      "tokenModifiers": [],
      "description": "Comprehension guard clause (when condition)"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\bby\\s+(?=\\d|[a-zA-Z_])",
      "tokenModifiers": [],
      "description": "Step modifier in for comprehensions (by step)"
    },
    {
      "tokenType": "number",
      "pattern": "\\[\\s*\\d+\\s*\\.\\.\\s*\\d+\\s*\\]",
      "tokenModifiers": [],
      "description": "Inclusive range literal [start..end]"
    },
    {
      "tokenType": "number",
      "pattern": "\\[\\s*\\d+\\s*\\.\\.\\.\\s*\\d+\\s*\\]",
      "tokenModifiers": [],
      "description": "Exclusive range literal [start...end]"
    },
    {
      "tokenType": "string",
      "pattern": "\"\"\"[\\s\\S]*?\"\"\"",
      "tokenModifiers": [],
      "description": "Block string (heredoc) with double quotes and interpolation"
    },
    {
      "tokenType": "string",
      "pattern": "'''[\\s\\S]*?'''",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Block string (heredoc) with single quotes (no interpolation)"
    },
    {
      "tokenType": "string",
      "pattern": "#\\{[^}]*\\}",
      "tokenModifiers": [],
      "description": "String interpolation expression #{...} in double-quoted strings"
    },
    {
      "tokenType": "regexp",
      "pattern": "///[\\s\\S]*?///[gimy]*",
      "tokenModifiers": [],
      "description": "Block regex (heregex) with ///.../// delimiters"
    },
    {
      "tokenType": "regexp",
      "pattern": "/(?![\\s=])[^/\\n]+/[gimy]*",
      "tokenModifiers": [],
      "description": "Inline regex literal /pattern/flags"
    },
    {
      "tokenType": "operator",
      "pattern": "\\b\\w+\\s*(<|>|<=|>=)\\s*\\w+\\s*(<=?|>=?)\\s*\\w+",
      "tokenModifiers": [],
      "description": "Chained comparisons (e.g., a < b < c)"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\bdo\\s*\\(",
      "tokenModifiers": [],
      "description": "do keyword for immediate function invocation with closure"
    },
    {
      "tokenType": "variable",
      "pattern": "\\b(true|false|yes|no|on|off|null|undefined|Infinity|NaN)\\b",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Boolean aliases (yes/no/on/off) and special constants"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(console\\.(?:log|warn|error|info|dir|trace)|alert|setTimeout|setInterval|clearTimeout|clearInterval|require|module\\.exports)\\b",
      "tokenModifiers": [],
      "description": "Common JS runtime and Node.js module functions"
    },
    {
      "tokenType": "operator",
      "pattern": "\\?=",
      "tokenModifiers": [],
      "description": "Existential assignment operator (?=) assigns only if null/undefined"
    },
    {
      "tokenType": "operator",
      "pattern": "[-+*/%]=|<<=|>>=|>>>=|&&=|\\|\\|=|\\^=",
      "tokenModifiers": [],
      "description": "Compound assignment operators"
    },
    {
      "tokenType": "property",
      "pattern": "@([a-zA-Z_][a-zA-Z0-9_]*)\\s*:\\s*\\([^)]*\\)\\s*[-=]>",
      "tokenModifiers": [
        "definition",
        "static"
      ],
      "description": "Static class method via @ prefix (@method: -> body)"
    }
  ]
}
