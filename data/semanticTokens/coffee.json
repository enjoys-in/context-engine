{
  "language": "coffee",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["class", "function", "variable", "property", "parameter", "keyword", "string", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static"]
  },
  "semanticRules": [
    {
      "type": "class",
      "pattern": "\\bclass\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Class declarations"
    },
    {
      "type": "function",
      "pattern": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*[:=]\\s*\\([^)]*\\)\\s*=>",
      "modifiers": ["definition"],
      "description": "Fat arrow function definitions (=>)"
    },
    {
      "type": "function",
      "pattern": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*[:=]\\s*\\([^)]*\\)\\s*->",
      "modifiers": ["definition"],
      "description": "Thin arrow function definitions (->)"
    },
    {
      "type": "string",
      "pattern": "#\\{[^}]+\\}",
      "modifiers": [],
      "description": "String interpolation expressions (#{...})"
    },
    {
      "type": "variable",
      "pattern": "\\{([a-zA-Z_][a-zA-Z0-9_]*(?:\\s*,\\s*[a-zA-Z_][a-zA-Z0-9_]*)*)\\}\\s*=",
      "modifiers": ["declaration"],
      "description": "Destructuring assignments"
    },
    {
      "type": "property",
      "pattern": "@([a-zA-Z_][a-zA-Z0-9_]*)",
      "modifiers": [],
      "description": "Instance property shorthand (@property)"
    },
    {
      "type": "keyword",
      "pattern": "\\b(extends|super|constructor|this)\\b",
      "modifiers": [],
      "description": "Class-related keywords"
    },
    {
      "type": "keyword",
      "pattern": "\\b(if|then|else|unless|while|until|for|in|of|when|switch|try|catch|finally|throw)\\b",
      "modifiers": [],
      "description": "Control flow keywords"
    },
    {
      "type": "operator",
      "pattern": "\\b(is|isnt|not|and|or|in|of)\\b",
      "modifiers": [],
      "description": "CoffeeScript English-style operators"
    },
    {
      "type": "variable",
      "pattern": "\\[([a-zA-Z_][a-zA-Z0-9_]*(?:\\s*,\\s*[a-zA-Z_][a-zA-Z0-9_]*)*)\\]\\s*=",
      "modifiers": ["declaration"],
      "description": "Array destructuring assignments"
    }
  ]
}
