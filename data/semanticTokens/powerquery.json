{
  "language": "powerquery",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["type", "variable", "property", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "keyword",
      "pattern": "\\b(let|in|if|then|else|each|try|otherwise|error|type|is|as|not|and|or|meta|section|shared|null|true|false)\\b",
      "modifiers": [],
      "description": "Power Query M language keywords"
    },
    {
      "type": "variable",
      "pattern": "\\b(let)\\s+(\\w+)\\s*=",
      "modifiers": ["declaration"],
      "description": "Variable bindings in let expressions"
    },
    {
      "type": "type",
      "pattern": "\\b(type)\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Type declarations"
    },
    {
      "type": "type",
      "pattern": "\\b(number|text|logical|date|datetime|datetimezone|duration|time|record|list|table|function|binary|type|null|any|none|action)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in Power Query types"
    },
    {
      "type": "function",
      "pattern": "\\b(Table|List|Record|Text|Number|Date|DateTime|DateTimeZone|Duration|Time|Binary|Comparer|Combiner|Splitter|Uri|Value|Expression|Error|Function|Type|Replacer|Lines|Diagnostics|DirectQueryCapabilities)\\.[A-Z]\\w+",
      "modifiers": ["defaultLibrary"],
      "description": "Standard library functions from built-in modules"
    },
    {
      "type": "property",
      "pattern": "\\[\\s*\\w+\\s*\\]|\\[\\s*\\w+\\s*=",
      "modifiers": [],
      "description": "Record field access and record expressions [field=value]"
    },
    {
      "type": "variable",
      "pattern": "#shared|#sections|#date|#time|#datetime|#datetimezone|#duration|#table|#infinity|#nan",
      "modifiers": ["readonly", "defaultLibrary"],
      "description": "Special # prefixed intrinsic values and constructors"
    },
    {
      "type": "keyword",
      "pattern": "\\beach\\b",
      "modifiers": [],
      "description": "Each keyword for shorthand function syntax"
    },
    {
      "type": "comment",
      "pattern": "//[^\\n]*|/\\*[\\s\\S]*?\\*/",
      "modifiers": [],
      "description": "Single-line and multi-line comments"
    },
    {
      "type": "string",
      "pattern": "\"([^\"\\\\]|\\\\.)*\"",
      "modifiers": [],
      "description": "String literals in double quotes"
    },
    {
      "type": "number",
      "pattern": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b|0x[0-9a-fA-F]+\\b",
      "modifiers": [],
      "description": "Numeric literals including hexadecimal"
    },
    {
      "type": "operator",
      "pattern": "(=>|=|<>|<|>|<=|>=|\\+|-|\\*|/|&|@|\\.\\.\\.|\\?)",
      "modifiers": [],
      "description": "Operators including fat arrow, comparison, arithmetic, and optional access"
    }
  ]
}
