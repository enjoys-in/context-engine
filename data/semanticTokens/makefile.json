{
  "language": "makefile",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["type", "variable", "property", "function", "macro", "keyword", "comment", "string", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "function",
      "pattern": "^[a-zA-Z_][a-zA-Z0-9_.-]*(?=\\s*:(?!=))",
      "modifiers": ["declaration"],
      "description": "Target declarations before the colon"
    },
    {
      "type": "property",
      "pattern": "(?<=:\\s*)[a-zA-Z_][a-zA-Z0-9_. -]*(?=\\s|$)",
      "modifiers": [],
      "description": "Prerequisites listed after the colon"
    },
    {
      "type": "keyword",
      "pattern": "^\\t.*$",
      "modifiers": [],
      "description": "Recipe lines (tab-indented commands)"
    },
    {
      "type": "variable",
      "pattern": "\\$\\([a-zA-Z_][a-zA-Z0-9_]*\\)|\\$\\{[a-zA-Z_][a-zA-Z0-9_]*\\}",
      "modifiers": [],
      "description": "Variable references $(VAR) or ${VAR}"
    },
    {
      "type": "variable",
      "pattern": "^\\s*[a-zA-Z_][a-zA-Z0-9_]*\\s*[:?+]?=",
      "modifiers": ["declaration"],
      "description": "Variable assignments with =, :=, ?=, +="
    },
    {
      "type": "macro",
      "pattern": "\\$[@<^?*%+]|\\$\\([@<^?*%+][DF]?\\)",
      "modifiers": ["readonly"],
      "description": "Automatic variables: $@, $<, $^, $?, $*, $%, $+"
    },
    {
      "type": "keyword",
      "pattern": "^\\.PHONY|\\.SUFFIXES|\\.DEFAULT|\\.PRECIOUS|\\.INTERMEDIATE|\\.SECONDARY|\\.SECONDEXPANSION|\\.DELETE_ON_ERROR|\\.IGNORE|\\.SILENT|\\.EXPORT_ALL_VARIABLES|\\.NOTPARALLEL|\\.ONESHELL|\\.POSIX",
      "modifiers": ["defaultLibrary"],
      "description": "Special built-in target names"
    },
    {
      "type": "function",
      "pattern": "\\$\\((wildcard|patsubst|subst|strip|findstring|filter|filter-out|sort|word|words|wordlist|firstword|lastword|dir|notdir|suffix|basename|addsuffix|addprefix|join|realpath|abspath|shell|foreach|call|eval|origin|value|info|warning|error)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in Make functions"
    },
    {
      "type": "keyword",
      "pattern": "\\b(ifeq|ifneq|ifdef|ifndef|else|endif|include|-include|sinclude|override|export|unexport|define|endef|vpath)\\b",
      "modifiers": [],
      "description": "Make directives and conditionals"
    },
    {
      "type": "comment",
      "pattern": "#.*$",
      "modifiers": ["documentation"],
      "description": "Comment lines starting with #"
    }
  ]
}
