{
  "language": "systemverilog",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "enum", "interface", "typeParameter", "parameter", "variable", "property", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "class",
      "pattern": "\\bmodule\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Module declarations"
    },
    {
      "type": "interface",
      "pattern": "\\binterface\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Interface declarations"
    },
    {
      "type": "class",
      "pattern": "\\bclass\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Class declarations"
    },
    {
      "type": "keyword",
      "pattern": "\\b(always|always_comb|always_ff|always_latch|initial|assign|generate|endgenerate|genvar)\\b",
      "modifiers": [],
      "description": "Procedural and generate block keywords"
    },
    {
      "type": "type",
      "pattern": "\\b(reg|wire|logic|bit|integer|real|time|shortint|longint|byte|shortreal|string|chandle|event)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Data types including wire, reg, logic"
    },
    {
      "type": "function",
      "pattern": "\\btask\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Task declarations"
    },
    {
      "type": "function",
      "pattern": "\\bfunction\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Function declarations"
    },
    {
      "type": "keyword",
      "pattern": "\\b(input|output|inout|ref|parameter|localparam|typedef|enum|struct|union|packed|signed|unsigned)\\b",
      "modifiers": [],
      "description": "Port directions, parameters, and type modifiers"
    },
    {
      "type": "macro",
      "pattern": "`([a-zA-Z_][a-zA-Z0-9_]*)",
      "modifiers": [],
      "description": "Compiler directives and macros with backtick"
    },
    {
      "type": "keyword",
      "pattern": "\\b(posedge|negedge|if|else|case|casex|casez|for|foreach|while|repeat|forever|begin|end|fork|join|join_any|join_none|wait|disable|assert|assume|cover|constraint|rand|randc)\\b",
      "modifiers": [],
      "description": "Control flow, sensitivity, and verification keywords"
    }
  ]
}
