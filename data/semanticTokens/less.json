{
  "language": "less",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["type", "variable", "property", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "variable",
      "pattern": "@[a-zA-Z_-][a-zA-Z0-9_-]*",
      "modifiers": [],
      "description": "Less variables prefixed with @"
    },
    {
      "type": "variable",
      "pattern": "@[a-zA-Z_-][a-zA-Z0-9_-]*\\s*:",
      "modifiers": ["declaration"],
      "description": "Less variable declarations with @var:"
    },
    {
      "type": "function",
      "pattern": "\\.[a-zA-Z_-][a-zA-Z0-9_-]*\\s*(?=\\()",
      "modifiers": ["definition"],
      "description": "Mixin definitions and calls with parentheses"
    },
    {
      "type": "type",
      "pattern": "\\b[a-zA-Z][a-zA-Z0-9-]*(?=\\s*[{,>+~]|\\s*$)",
      "modifiers": [],
      "description": "Element selectors (tag names)"
    },
    {
      "type": "type",
      "pattern": "[.#][a-zA-Z_-][a-zA-Z0-9_-]*",
      "modifiers": [],
      "description": "Class selectors (.) and ID selectors (#)"
    },
    {
      "type": "property",
      "pattern": "\\b[a-z-]+(?=\\s*:)",
      "modifiers": [],
      "description": "CSS property names before colon"
    },
    {
      "type": "keyword",
      "pattern": "\\b(when|and|not|or)\\b",
      "modifiers": [],
      "description": "Mixin guard keywords"
    },
    {
      "type": "keyword",
      "pattern": "@(import|media|charset|font-face|keyframes|supports|namespace|page)\\b",
      "modifiers": [],
      "description": "At-rule directives"
    },
    {
      "type": "function",
      "pattern": "\\b(darken|lighten|saturate|desaturate|fadein|fadeout|fade|spin|mix|contrast|unit|ceil|floor|percentage|round|sqrt|abs|length|extract|escape|e|color|rgb|rgba|hsl|hsla)\\s*(?=\\()",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in Less functions"
    },
    {
      "type": "comment",
      "pattern": "//.*$|/\\*[\\s\\S]*?\\*/",
      "modifiers": ["documentation"],
      "description": "Single-line and multi-line comments"
    },
    {
      "type": "number",
      "pattern": "-?\\d+\\.?\\d*(px|em|rem|%|vh|vw|s|ms|deg|fr)?",
      "modifiers": [],
      "description": "Numeric values with optional CSS units"
    }
  ]
}
