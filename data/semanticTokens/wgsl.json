{
  "language": "wgsl",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["type", "struct", "parameter", "variable", "property", "function", "keyword", "modifier", "comment", "number", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "function",
      "pattern": "\\bfn\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Function declarations with fn keyword"
    },
    {
      "type": "variable",
      "pattern": "\\b(var|let|const)\\s*(<[^>]+>)?\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Variable declarations with var/let/const"
    },
    {
      "type": "struct",
      "pattern": "\\bstruct\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Struct declarations"
    },
    {
      "type": "decorator",
      "pattern": "@(vertex|fragment|compute|binding|group|location|builtin|workgroup_size|id|align|size|interpolate|invariant|must_use)",
      "modifiers": [],
      "description": "WGSL attribute annotations"
    },
    {
      "type": "type",
      "pattern": "\\b(vec[234]|mat[234]x[234]|vec[234][fhiu]|mat[234]x[234]f)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Vector and matrix types"
    },
    {
      "type": "type",
      "pattern": "\\b(bool|f16|f32|i32|u32|sampler|sampler_comparison|texture_1d|texture_2d|texture_3d|texture_cube|texture_multisampled_2d|texture_depth_2d|texture_depth_cube|texture_storage_2d|array|ptr)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in scalar, sampler, and texture types"
    },
    {
      "type": "function",
      "pattern": "\\b(abs|acos|asin|atan|atan2|ceil|clamp|cos|cross|degrees|determinant|distance|dot|exp|exp2|floor|fract|length|log|log2|max|min|mix|normalize|pow|radians|reflect|refract|round|sign|sin|smoothstep|sqrt|step|tan|transpose|trunc)\\s*\\(",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in math and utility functions"
    },
    {
      "type": "keyword",
      "pattern": "\\b(if|else|for|while|loop|break|continue|return|switch|case|default|discard|continuing|enable|diagnostic|const_assert|override)\\b",
      "modifiers": [],
      "description": "Control flow and declaration keywords"
    },
    {
      "type": "keyword",
      "pattern": "\\b(uniform|storage|read|write|read_write|function|private|workgroup)\\b",
      "modifiers": [],
      "description": "Address space and access mode keywords"
    }
  ]
}
