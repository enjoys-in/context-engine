{
  "language": "awk",
  "legend": {
    "tokenTypes": [
      "variable",
      "property",
      "function",
      "keyword",
      "comment",
      "string",
      "number",
      "regexp",
      "operator"
    ],
    "tokenModifiers": [
      "declaration",
      "readonly",
      "defaultLibrary"
    ]
  },
  "semanticRules": [
    {
      "tokenType": "keyword",
      "pattern": "\\b(BEGIN|END)\\b",
      "tokenModifiers": [],
      "description": "BEGIN and END special pattern rules"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(BEGINFILE|ENDFILE)\\b",
      "tokenModifiers": [],
      "description": "GAWK per-file special pattern rules"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(if|else|while|for|do)\\b",
      "tokenModifiers": [],
      "description": "Control flow keywords"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(break|continue|next|nextfile|exit|return)\\b",
      "tokenModifiers": [],
      "description": "Loop control and exit keywords"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(in)\\b",
      "tokenModifiers": [],
      "description": "Array membership test keyword (for-in loops and if-in tests)"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\bdelete\\b",
      "tokenModifiers": [],
      "description": "Array element or whole-array deletion keyword"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\bfunction\\b",
      "tokenModifiers": [],
      "description": "User-defined function declaration keyword"
    },
    {
      "tokenType": "function",
      "pattern": "\\bfunction\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "User-defined function name declarations"
    },
    {
      "tokenType": "variable",
      "pattern": "\\$[0-9]+",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Numeric field references ($0, $1, $2, ...)"
    },
    {
      "tokenType": "variable",
      "pattern": "\\$\\([^)]+\\)|\\$[a-zA-Z_][a-zA-Z0-9_]*",
      "tokenModifiers": [],
      "description": "Computed and variable field references ($NF, $(NF-1))"
    },
    {
      "tokenType": "variable",
      "pattern": "\\b(NR|NF|FNR|FS|RS|OFS|ORS|FILENAME)\\b",
      "tokenModifiers": [
        "readonly",
        "defaultLibrary"
      ],
      "description": "Core built-in record and field variables"
    },
    {
      "tokenType": "variable",
      "pattern": "\\b(ARGC|ARGV|ENVIRON)\\b",
      "tokenModifiers": [
        "readonly",
        "defaultLibrary"
      ],
      "description": "Program argument and environment variables"
    },
    {
      "tokenType": "variable",
      "pattern": "\\b(RSTART|RLENGTH)\\b",
      "tokenModifiers": [
        "readonly",
        "defaultLibrary"
      ],
      "description": "Match result variables set by match()"
    },
    {
      "tokenType": "variable",
      "pattern": "\\b(OFMT|CONVFMT|SUBSEP)\\b",
      "tokenModifiers": [
        "readonly",
        "defaultLibrary"
      ],
      "description": "Output format, conversion format, and subscript separator variables"
    },
    {
      "tokenType": "variable",
      "pattern": "\\b(RT|FPAT|FIELDWIDTHS|PREC|ROUNDMODE|BINMODE|LINT|TEXTDOMAIN|PROCINFO)\\b",
      "tokenModifiers": [
        "readonly",
        "defaultLibrary"
      ],
      "description": "GAWK-specific built-in variables"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(print|printf)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Output statements print and printf"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(sprintf)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Formatted string construction function"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(length|substr|index|tolower|toupper)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "String manipulation functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(split|patsplit)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "String-to-array splitting functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(sub|gsub|gensub|match)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Pattern substitution and matching functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(sin|cos|atan2|exp|log|sqrt|int)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Mathematical functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(rand|srand)\\s*\\(?",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Random number generation functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(mktime|systime|strftime)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Time and date functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(system|close|fflush)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "System command execution and I/O stream control"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\bgetline\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Input reading command for lines from files, pipes, or stdin"
    },
    {
      "tokenType": "regexp",
      "pattern": "/[^/\\n]+/",
      "tokenModifiers": [],
      "description": "Regular expression literal patterns"
    },
    {
      "tokenType": "operator",
      "pattern": "(~|!~)",
      "tokenModifiers": [],
      "description": "Regex match (~) and negated match (!~) operators"
    },
    {
      "tokenType": "operator",
      "pattern": "(>>|\\|&|\\|)",
      "tokenModifiers": [],
      "description": "Output append (>>), co-process pipe (|&), and pipe (|) operators"
    },
    {
      "tokenType": "operator",
      "pattern": "(\\+\\+|--|\\+=|-=|\\*=|/=|%=|\\^=|&&|\\|\\||!)",
      "tokenModifiers": [],
      "description": "Increment, compound assignment, and logical operators"
    },
    {
      "tokenType": "operator",
      "pattern": "(==|!=|<=|>=|<|>)",
      "tokenModifiers": [],
      "description": "Comparison operators"
    },
    {
      "tokenType": "operator",
      "pattern": "[+\\-*/%^]",
      "tokenModifiers": [],
      "description": "Arithmetic operators including exponentiation (^)"
    },
    {
      "tokenType": "keyword",
      "pattern": "@(include|load|namespace)\\b",
      "tokenModifiers": [],
      "description": "GAWK extension directives (@include, @load, @namespace)"
    },
    {
      "tokenType": "property",
      "pattern": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\s*\\[",
      "tokenModifiers": [],
      "description": "Associative array element access"
    },
    {
      "tokenType": "string",
      "pattern": "\"([^\"\\\\]|\\\\.)*\"",
      "tokenModifiers": [],
      "description": "Double-quoted string literals with escape sequences"
    },
    {
      "tokenType": "number",
      "pattern": "\\b0[xX][0-9a-fA-F]+\\b|\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b",
      "tokenModifiers": [],
      "description": "Decimal, floating-point, and hexadecimal numeric literals"
    },
    {
      "tokenType": "comment",
      "pattern": "#[^\\n]*",
      "tokenModifiers": [],
      "description": "Line comments starting with #"
    }
  ]
}
