{
  "language": "awk",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "function", "keyword", "regexp", "operator", "number", "string"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "variable",
      "pattern": "\\$[0-9]+",
      "modifiers": ["readonly"],
      "description": "Field references ($0, $1, $2, ...)"
    },
    {
      "type": "keyword",
      "pattern": "\\b(BEGIN|END|BEGINFILE|ENDFILE)\\b",
      "modifiers": [],
      "description": "Special pattern rules"
    },
    {
      "type": "function",
      "pattern": "\\b(print|printf|sprintf|gsub|sub|match|split|substr|index|length|tolower|toupper)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in string and I/O functions"
    },
    {
      "type": "function",
      "pattern": "\\bfunction\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "modifiers": ["declaration"],
      "description": "User-defined function declarations"
    },
    {
      "type": "variable",
      "pattern": "\\b(NR|NF|FS|RS|OFS|ORS|FILENAME|FNR|ARGC|ARGV)\\b",
      "modifiers": ["readonly", "defaultLibrary"],
      "description": "Built-in variables"
    },
    {
      "type": "regexp",
      "pattern": "/[^/]+/",
      "modifiers": [],
      "description": "Regular expression patterns in rules"
    },
    {
      "type": "operator",
      "pattern": "(~|!~|\\|\\||&&|>>|\\|&)",
      "modifiers": [],
      "description": "AWK-specific operators (match, pipe, append)"
    },
    {
      "type": "function",
      "pattern": "\\b(sin|cos|atan2|exp|log|sqrt|int|rand|srand|systime|mktime)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in numeric and time functions"
    },
    {
      "type": "keyword",
      "pattern": "\\b(if|else|while|for|do|break|continue|next|nextfile|exit|return|delete|getline)\\b",
      "modifiers": [],
      "description": "Control flow keywords"
    }
  ]
}
