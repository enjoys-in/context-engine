{
  "language": "scss",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "property", "function", "keyword", "comment", "string", "number", "operator", "type"],
    "tokenModifiers": ["declaration", "definition", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "variable",
      "pattern": "\\$([a-zA-Z_][a-zA-Z0-9_-]*)\\s*:",
      "modifiers": ["declaration"],
      "description": "SCSS variable declarations with $ prefix"
    },
    {
      "type": "variable",
      "pattern": "\\$([a-zA-Z_][a-zA-Z0-9_-]*)",
      "modifiers": [],
      "description": "SCSS variable references"
    },
    {
      "type": "function",
      "pattern": "@mixin\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\b",
      "modifiers": ["declaration"],
      "description": "Mixin declarations with @mixin"
    },
    {
      "type": "keyword",
      "pattern": "@(include|extend|import|use|forward|at-root|if|else|each|for|while|warn|debug|error|return|content)\\b",
      "modifiers": [],
      "description": "SCSS at-rule directives"
    },
    {
      "type": "operator",
      "pattern": "&",
      "modifiers": [],
      "description": "Parent selector reference"
    },
    {
      "type": "type",
      "pattern": "%([a-zA-Z_][a-zA-Z0-9_-]*)",
      "modifiers": ["declaration"],
      "description": "Placeholder selectors with % prefix"
    },
    {
      "type": "function",
      "pattern": "@function\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\b",
      "modifiers": ["declaration"],
      "description": "SCSS function declarations"
    },
    {
      "type": "function",
      "pattern": "\\b(rgb|rgba|hsl|hsla|mix|lighten|darken|saturate|desaturate|adjust-hue|opacify|transparentize|map-get|map-merge|nth|length|percentage|round|ceil|floor|abs|min|max)\\s*\\(",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in SCSS functions"
    },
    {
      "type": "property",
      "pattern": "\\b([a-z][a-z-]*)\\s*:",
      "modifiers": [],
      "description": "CSS property names"
    },
    {
      "type": "comment",
      "pattern": "//[^\\n]*",
      "modifiers": [],
      "description": "Single-line comments"
    }
  ]
}
