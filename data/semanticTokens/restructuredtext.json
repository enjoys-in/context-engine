{
  "language": "restructuredtext",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["keyword", "function", "variable", "property", "comment", "string", "operator", "decorator", "macro"],
    "tokenModifiers": ["declaration", "definition", "readonly", "documentation"]
  },
  "semanticRules": [
    {
      "type": "keyword",
      "pattern": "\\.\\.\\s+(\\w[\\w-]*)::.*",
      "modifiers": ["definition"],
      "description": "Directives like .. directive:: (image, code-block, toctree, etc.)"
    },
    {
      "type": "decorator",
      "pattern": ":[a-zA-Z][\\w-]*:`[^`]*`",
      "modifiers": [],
      "description": "Interpreted text roles :role:`text` (ref, doc, class, func, etc.)"
    },
    {
      "type": "property",
      "pattern": "^[=\\-~`'\"^_*+#]+$",
      "modifiers": ["definition"],
      "description": "Section heading underline/overline characters"
    },
    {
      "type": "variable",
      "pattern": "\\.\\.\\s+\\[\\d+\\]\\s+",
      "modifiers": ["declaration"],
      "description": "Footnote definitions .. [1] and auto-numbered .. [#]"
    },
    {
      "type": "variable",
      "pattern": "\\[\\d+\\]_|\\[#\\w*\\]_|\\[\\*\\]_",
      "modifiers": [],
      "description": "Footnote references [1]_, [#label]_, [*]_"
    },
    {
      "type": "function",
      "pattern": "\\.\\.\\s+_[^:]+:.*|\\.\\.\\s+__:.*",
      "modifiers": ["declaration"],
      "description": "Hyperlink targets and anonymous targets"
    },
    {
      "type": "variable",
      "pattern": "`[^`]+`_|\\w+_(?=\\s|$|[.,;:!?)])",
      "modifiers": [],
      "description": "Hyperlink references `Link Text`_ and simple word_"
    },
    {
      "type": "macro",
      "pattern": "\\|\\w[\\w\\s]*\\|",
      "modifiers": [],
      "description": "Substitution references |name| and definitions"
    },
    {
      "type": "comment",
      "pattern": "\\.\\.\\s*$|\\.\\.\\s+[^\\[_|]",
      "modifiers": ["documentation"],
      "description": "Comments starting with .. followed by blank or non-directive text"
    },
    {
      "type": "string",
      "pattern": "``[^`]+``",
      "modifiers": [],
      "description": "Inline literals (code) wrapped in double backticks"
    },
    {
      "type": "operator",
      "pattern": "\\*\\*[^*]+\\*\\*|\\*[^*]+\\*",
      "modifiers": [],
      "description": "Strong emphasis **text** and emphasis *text*"
    }
  ]
}
