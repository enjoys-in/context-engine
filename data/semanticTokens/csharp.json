{
  "language": "csharp",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["class", "interface", "struct", "enum", "enumMember", "type", "typeParameter", "namespace", "method", "function", "property", "variable", "parameter", "event", "keyword", "decorator", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "documentation", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "class",
      "pattern": "\\b(class|record)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Class and record type declarations"
    },
    {
      "type": "interface",
      "pattern": "\\binterface\\s+(I[A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Interface declarations (I-prefix convention)"
    },
    {
      "type": "keyword",
      "pattern": "\\b(async\\s+)?await\\b",
      "modifiers": ["async"],
      "description": "Async/await expressions"
    },
    {
      "type": "method",
      "pattern": "\\basync\\s+Task[<]?[^>]*[>]?\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "modifiers": ["declaration", "async"],
      "description": "Async method declarations"
    },
    {
      "type": "keyword",
      "pattern": "\\b(from|where|select|orderby|group|into|join|on|equals|let)\\b",
      "modifiers": [],
      "description": "LINQ query expression keywords"
    },
    {
      "type": "decorator",
      "pattern": "\\[([A-Z][a-zA-Z0-9_]*)(?:\\([^)]*\\))?\\]",
      "modifiers": [],
      "description": "Attribute decorators ([Attribute], [Serializable], etc.)"
    },
    {
      "type": "keyword",
      "pattern": "\\busing\\s+(?:static\\s+)?([a-zA-Z_][a-zA-Z0-9_.]*);",
      "modifiers": [],
      "description": "Using directives (namespace imports)"
    },
    {
      "type": "struct",
      "pattern": "\\bstruct\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Struct declarations"
    },
    {
      "type": "enum",
      "pattern": "\\benum\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Enum declarations"
    },
    {
      "type": "property",
      "pattern": "\\b([A-Z][a-zA-Z0-9_]*)\\s*\\{\\s*(get|set|init)",
      "modifiers": ["definition"],
      "description": "Property definitions with accessors"
    },
    {
      "type": "event",
      "pattern": "\\bevent\\s+[A-Za-z<>_]+\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Event declarations"
    }
  ]
}
