{
  "language": "javascript",
  "legend": {
    "tokenTypes": [
      "namespace",
      "type",
      "class",
      "enum",
      "interface",
      "struct",
      "typeParameter",
      "parameter",
      "variable",
      "property",
      "enumMember",
      "event",
      "function",
      "method",
      "macro",
      "keyword",
      "modifier",
      "comment",
      "string",
      "number",
      "regexp",
      "operator",
      "decorator"
    ],
    "tokenModifiers": [
      "declaration",
      "definition",
      "readonly",
      "static",
      "deprecated",
      "abstract",
      "async",
      "modification",
      "documentation",
      "defaultLibrary"
    ]
  },
  "semanticRules": [
    {
      "tokenType": "keyword",
      "pattern": "\\b(if|else|switch|case|default|for|while|do|break|continue|return|throw|with)\\b",
      "tokenModifiers": [],
      "description": "Control flow keywords"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(try|catch|finally)\\b",
      "tokenModifiers": [],
      "description": "Error handling keywords for try/catch/finally blocks"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(function)\\s+[a-zA-Z_$][a-zA-Z0-9_$]*",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Named function declarations"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(const|let|var)\\s+[a-zA-Z_$][a-zA-Z0-9_$]*\\s*=\\s*(?:async\\s+)?(?:function\\b|\\([^)]*\\)\\s*=>|[a-zA-Z_$]+\\s*=>)",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Arrow function and function expression assignments"
    },
    {
      "tokenType": "function",
      "pattern": "\\bfunction\\s*\\*\\s*[a-zA-Z_$][a-zA-Z0-9_$]*",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Generator function declarations using function*"
    },
    {
      "tokenType": "function",
      "pattern": "\\basync\\s+function\\s*\\*\\s*[a-zA-Z_$][a-zA-Z0-9_$]*",
      "tokenModifiers": [
        "declaration",
        "async"
      ],
      "description": "Async generator function declarations"
    },
    {
      "tokenType": "class",
      "pattern": "\\bclass\\s+[A-Z][a-zA-Z0-9_$]*(?:\\s+extends\\s+[A-Z][a-zA-Z0-9_$.]*)?",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Class declarations with optional extends clause"
    },
    {
      "tokenType": "property",
      "pattern": "#[a-zA-Z_$][a-zA-Z0-9_$]*",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Private class fields and methods using # prefix"
    },
    {
      "tokenType": "modifier",
      "pattern": "\\b(static)\\s+(?:#?[a-zA-Z_$][a-zA-Z0-9_$]*)",
      "tokenModifiers": [
        "static"
      ],
      "description": "Static class member declarations"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(const|let|var)\\b",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Variable declaration keywords"
    },
    {
      "tokenType": "variable",
      "pattern": "\\b(const|let|var)\\s+\\{[^}]+\\}\\s*=",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Object destructuring assignment patterns"
    },
    {
      "tokenType": "variable",
      "pattern": "\\b(const|let|var)\\s+\\[[^\\]]+\\]\\s*=",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Array destructuring assignment patterns"
    },
    {
      "tokenType": "operator",
      "pattern": "\\.\\.\\.",
      "tokenModifiers": [],
      "description": "Spread operator and rest parameters"
    },
    {
      "tokenType": "operator",
      "pattern": "\\?\\.",
      "tokenModifiers": [],
      "description": "Optional chaining operator for safe property access"
    },
    {
      "tokenType": "operator",
      "pattern": "\\?\\?",
      "tokenModifiers": [],
      "description": "Nullish coalescing operator for default values"
    },
    {
      "tokenType": "operator",
      "pattern": "(&&=|\\|\\|=|\\?\\?=)",
      "tokenModifiers": [
        "modification"
      ],
      "description": "Logical assignment operators (&&=, ||=, ??=)"
    },
    {
      "tokenType": "operator",
      "pattern": "=>",
      "tokenModifiers": [],
      "description": "Arrow function expression operator"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(import|export)\\b",
      "tokenModifiers": [],
      "description": "ES module import and export keywords"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\bimport\\s*\\(",
      "tokenModifiers": [],
      "description": "Dynamic import() expression for code splitting"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\bexport\\s+default\\b",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Default export declaration"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(async)\\s+function\\b",
      "tokenModifiers": [
        "async"
      ],
      "description": "Async function declaration keyword"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\bawait\\b",
      "tokenModifiers": [
        "async"
      ],
      "description": "Await expression for resolving promises"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\byield\\s*\\*?\\b",
      "tokenModifiers": [],
      "description": "Yield expression for generators including yield* delegation"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\bfor\\s+await\\s*\\(",
      "tokenModifiers": [
        "async"
      ],
      "description": "Async iterator consumption with for-await-of loops"
    },
    {
      "tokenType": "string",
      "pattern": "`(?:[^`\\\\]|\\\\.)*`",
      "tokenModifiers": [],
      "description": "Template literal strings with backtick delimiters"
    },
    {
      "tokenType": "function",
      "pattern": "\\b[a-zA-Z_$][a-zA-Z0-9_$]*`",
      "tokenModifiers": [],
      "description": "Tagged template literal function calls"
    },
    {
      "tokenType": "class",
      "pattern": "\\b(Promise|Promise\\.all|Promise\\.race|Promise\\.allSettled|Promise\\.any|Promise\\.resolve|Promise\\.reject)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Promise constructor and static methods"
    },
    {
      "tokenType": "class",
      "pattern": "\\b(Symbol|Symbol\\.iterator|Symbol\\.asyncIterator|Symbol\\.hasInstance|Symbol\\.toPrimitive|Symbol\\.toStringTag|Symbol\\.species)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Symbol constructor and well-known symbols"
    },
    {
      "tokenType": "class",
      "pattern": "\\b(Proxy|Reflect)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Proxy and Reflect metaprogramming APIs"
    },
    {
      "tokenType": "class",
      "pattern": "\\b(WeakRef|FinalizationRegistry)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Weak reference and garbage collection APIs"
    },
    {
      "tokenType": "class",
      "pattern": "\\b(Map|Set|WeakMap|WeakSet)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Keyed collection built-in constructors"
    },
    {
      "tokenType": "variable",
      "pattern": "\\b(console|window|document|globalThis|process|navigator|location|history|localStorage|sessionStorage)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Global objects and browser/Node.js runtime globals"
    },
    {
      "tokenType": "class",
      "pattern": "\\bnew\\s+[A-Z][a-zA-Z0-9_$]*",
      "tokenModifiers": [],
      "description": "Constructor invocations with new keyword"
    },
    {
      "tokenType": "property",
      "pattern": "\\[(?:[a-zA-Z_$][a-zA-Z0-9_$]*|`.+?`)\\]\\s*(?::|\\()",
      "tokenModifiers": [],
      "description": "Computed property names and computed method names in objects/classes"
    },
    {
      "tokenType": "method",
      "pattern": "(?<=\\.)[a-zA-Z_$][a-zA-Z0-9_$]*\\s*(?=\\()",
      "tokenModifiers": [],
      "description": "Method calls on objects via dot notation"
    },
    {
      "tokenType": "regexp",
      "pattern": "/(?:[^/\\\\]|\\\\.)+/[gimsuy]*",
      "tokenModifiers": [],
      "description": "Regular expression literals with optional flags"
    },
    {
      "tokenType": "comment",
      "pattern": "//[^\\n]*|/\\*[\\s\\S]*?\\*/",
      "tokenModifiers": [],
      "description": "Single-line and multi-line comments"
    },
    {
      "tokenType": "comment",
      "pattern": "/\\*\\*[\\s\\S]*?\\*/",
      "tokenModifiers": [
        "documentation"
      ],
      "description": "JSDoc documentation comments"
    },
    {
      "tokenType": "method",
      "pattern": "\\b(get|set)\\s+[a-zA-Z_$][a-zA-Z0-9_$]*\\s*\\(",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Getter and setter accessor method declarations"
    },
    {
      "tokenType": "operator",
      "pattern": "\\b(instanceof|typeof|void|delete|in|of)\\b",
      "tokenModifiers": [],
      "description": "Unary and relational keyword operators"
    },
    {
      "tokenType": "operator",
      "pattern": "===|!==|==|!=",
      "tokenModifiers": [],
      "description": "Strict and loose equality/inequality operators"
    }
  ]
}
