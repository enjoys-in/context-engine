{
  "language": "javascript",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "class", "parameter", "variable", "property", "function", "method", "keyword", "comment", "string", "number", "regexp", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "async", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "keyword",
      "pattern": "\\b(function|class|const|let|var|return|if|else|for|while|do|switch|case|default|break|continue|try|catch|finally|throw|new|typeof|instanceof|in|of|delete|void|yield|with)\\b",
      "modifiers": [],
      "description": "JavaScript language keywords"
    },
    {
      "type": "function",
      "pattern": "(?<=function\\s+)[a-zA-Z_$][a-zA-Z0-9_$]*|(?<=(?:const|let|var)\\s+)[a-zA-Z_$][a-zA-Z0-9_$]*(?=\\s*=\\s*(?:async\\s+)?(?:\\([^)]*\\)|[a-zA-Z_$]+)\\s*=>)",
      "modifiers": ["declaration"],
      "description": "Function declarations and arrow function assignments"
    },
    {
      "type": "class",
      "pattern": "(?<=class\\s+)[A-Z][a-zA-Z0-9_$]*",
      "modifiers": ["declaration"],
      "description": "Class declarations"
    },
    {
      "type": "keyword",
      "pattern": "\\b(import|export|from|as|default)\\b",
      "modifiers": [],
      "description": "Module import/export keywords"
    },
    {
      "type": "keyword",
      "pattern": "\\b(async|await)\\b",
      "modifiers": ["async"],
      "description": "Async/await keywords"
    },
    {
      "type": "string",
      "pattern": "`(?:[^`\\\\]|\\\\.)*`",
      "modifiers": [],
      "description": "Template literal strings with backticks"
    },
    {
      "type": "method",
      "pattern": "(?<=\\.)[a-zA-Z_$][a-zA-Z0-9_$]*\\s*(?=\\()",
      "modifiers": [],
      "description": "Method calls on objects"
    },
    {
      "type": "variable",
      "pattern": "\\b(console|window|document|globalThis|process|module|exports|require|Promise|Symbol|Proxy|Reflect)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Well-known global objects and built-ins"
    },
    {
      "type": "regexp",
      "pattern": "/(?:[^/\\\\]|\\\\.)+/[gimsuy]*",
      "modifiers": [],
      "description": "Regular expression literals"
    },
    {
      "type": "comment",
      "pattern": "//.*$|/\\*[\\s\\S]*?\\*/",
      "modifiers": ["documentation"],
      "description": "Single-line and multi-line comments"
    },
    {
      "type": "operator",
      "pattern": "(=>|===|!==|\\?\\.\\?|\\?\\?|\\.\\.\\.|\\?\\.|&&=|\\|\\|=|\\?\\?=)",
      "modifiers": [],
      "description": "Arrow, strict equality, optional chaining, spread, and logical assignment operators"
    }
  ]
}
