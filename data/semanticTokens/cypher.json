{
  "language": "cypher",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["keyword", "variable", "property", "type", "function", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "readonly", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "variable",
      "pattern": "\\(([a-zA-Z_][a-zA-Z0-9_]*)(?::[A-Z][a-zA-Z0-9_]*)?\\)",
      "modifiers": ["declaration"],
      "description": "Node pattern variables (n), (n:Label)"
    },
    {
      "type": "variable",
      "pattern": "\\[([a-zA-Z_][a-zA-Z0-9_]*)(?::[A-Z_]+)?\\]",
      "modifiers": ["declaration"],
      "description": "Relationship pattern variables [r], [r:TYPE]"
    },
    {
      "type": "keyword",
      "pattern": "\\b(MATCH|WHERE|RETURN|CREATE|MERGE|DELETE|DETACH|SET|REMOVE|WITH|UNWIND|OPTIONAL)\\b",
      "modifiers": [],
      "description": "Core Cypher query clauses"
    },
    {
      "type": "property",
      "pattern": "([a-zA-Z_][a-zA-Z0-9_]*)\\.([a-zA-Z_][a-zA-Z0-9_]*)",
      "modifiers": [],
      "description": "Node/relationship property access (n.name)"
    },
    {
      "type": "type",
      "pattern": ":([A-Z][a-zA-Z0-9_]*)",
      "modifiers": [],
      "description": "Node labels and relationship types"
    },
    {
      "type": "function",
      "pattern": "\\b(count|sum|avg|min|max|collect|size|length|type|id|labels|keys|nodes|relationships|toInteger|toString|coalesce)\\s*\\(",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in Cypher functions"
    },
    {
      "type": "operator",
      "pattern": "(-\\[|\\]->|<-\\[|\\]-)|(-->|<--|--)",
      "modifiers": [],
      "description": "Relationship direction operators"
    },
    {
      "type": "keyword",
      "pattern": "\\b(ORDER\\s+BY|LIMIT|SKIP|DISTINCT|AS|AND|OR|NOT|IN|IS\\s+NULL|IS\\s+NOT\\s+NULL|CONTAINS|STARTS\\s+WITH|ENDS\\s+WITH)\\b",
      "modifiers": [],
      "description": "Filter and ordering keywords"
    },
    {
      "type": "variable",
      "pattern": "\\$([a-zA-Z_][a-zA-Z0-9_]*)",
      "modifiers": ["readonly"],
      "description": "Query parameters ($param)"
    }
  ]
}
