{
  "language": "cypher",
  "legend": {
    "tokenTypes": [
      "keyword",
      "variable",
      "property",
      "type",
      "function",
      "number",
      "operator",
      "comment",
      "parameter"
    ],
    "tokenModifiers": [
      "declaration",
      "readonly",
      "defaultLibrary"
    ]
  },
  "semanticRules": [
    {
      "tokenType": "keyword",
      "pattern": "\\b(MATCH|OPTIONAL\\s+MATCH|WHERE|RETURN|WITH|UNWIND|CREATE|MERGE|DELETE|DETACH\\s+DELETE|SET|REMOVE|FOREACH)\\b",
      "tokenModifiers": [],
      "description": "Core Cypher read and write clauses"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(ORDER\\s+BY|SKIP|LIMIT|DISTINCT|AS|UNION\\s+ALL|UNION)\\b",
      "tokenModifiers": [],
      "description": "Result ordering, pagination, and set operation clauses"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(AND|OR|XOR|NOT|IN|IS\\s+NULL|IS\\s+NOT\\s+NULL)\\b",
      "tokenModifiers": [],
      "description": "Logical and null-check operators"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(CONTAINS|STARTS\\s+WITH|ENDS\\s+WITH)\\b",
      "tokenModifiers": [],
      "description": "String predicate operators"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(CASE|WHEN|THEN|ELSE|END)\\b",
      "tokenModifiers": [],
      "description": "CASE conditional expression keywords"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(CALL|YIELD|LOAD\\s+CSV|WITH\\s+HEADERS|FROM|FIELDTERMINATOR)\\b",
      "tokenModifiers": [],
      "description": "Procedure calls, CSV import, and subquery keywords"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(CREATE\\s+INDEX|DROP\\s+INDEX|CREATE\\s+CONSTRAINT|DROP\\s+CONSTRAINT|CREATE\\s+(?:POINT|RANGE|TEXT|FULLTEXT|VECTOR)\\s+INDEX)\\b",
      "tokenModifiers": [],
      "description": "Schema index and constraint DDL statements"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(ON\\s+CREATE\\s+SET|ON\\s+MATCH\\s+SET)\\b",
      "tokenModifiers": [],
      "description": "MERGE conditional SET clauses"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\bUSING\\s+(INDEX|SCAN|JOIN)\\b",
      "tokenModifiers": [],
      "description": "Planner hints (USING INDEX, USING SCAN, USING JOIN)"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\bEXISTS\\s*\\{",
      "tokenModifiers": [],
      "description": "EXISTS subquery expression"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(COUNT\\s*\\{|COLLECT\\s*\\{)",
      "tokenModifiers": [],
      "description": "COUNT and COLLECT subquery expressions"
    },
    {
      "tokenType": "variable",
      "pattern": "\\(([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*[:)}])",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Node pattern variable bindings"
    },
    {
      "tokenType": "type",
      "pattern": "\\(\\w*:((?:[A-Z][a-zA-Z0-9_]*)(?::[A-Z][a-zA-Z0-9_]*)*)\\s*(?:[{)])",
      "tokenModifiers": [],
      "description": "Node labels in patterns (:Label or :Label1:Label2)"
    },
    {
      "tokenType": "variable",
      "pattern": "\\[([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*[:\\]])",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Relationship pattern variable bindings"
    },
    {
      "tokenType": "type",
      "pattern": "\\[\\w*:((?:[A-Z_]+)(?:\\|[A-Z_]+)*)\\]",
      "tokenModifiers": [],
      "description": "Relationship types in bracket patterns ([:TYPE] or [:T1|T2])"
    },
    {
      "tokenType": "operator",
      "pattern": "\\*\\d*(?:\\.\\.\\d*)?",
      "tokenModifiers": [],
      "description": "Variable-length relationship quantifiers (*1..3, *.., *2)"
    },
    {
      "tokenType": "operator",
      "pattern": "(-\\[|\\]->|<-\\[|\\]-|-->|<--|--)",
      "tokenModifiers": [],
      "description": "Relationship direction and arrow operators"
    },
    {
      "tokenType": "operator",
      "pattern": "=~",
      "tokenModifiers": [],
      "description": "Regular expression match operator"
    },
    {
      "tokenType": "property",
      "pattern": "([a-zA-Z_][a-zA-Z0-9_]*)\\.([a-zA-Z_][a-zA-Z0-9_]*)",
      "tokenModifiers": [],
      "description": "Property access on nodes and relationships (n.prop)"
    },
    {
      "tokenType": "parameter",
      "pattern": "\\$([a-zA-Z_][a-zA-Z0-9_]*)",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Query parameters ($paramName)"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(count|sum|avg|min|max|collect|stDev|stDevP|percentileDisc|percentileCont)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Aggregation functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(size|length|type|id|elementId|labels|keys|properties|nodes|relationships|startNode|endNode)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Scalar and graph element introspection functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(head|tail|last|range|reverse|reduce|extract|filter)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "List manipulation functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(any|all|none|single|exists)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "List predicate functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(toString|toInteger|toFloat|toBoolean|toStringOrNull|toIntegerOrNull|toFloatOrNull|toBooleanOrNull)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Type conversion and coercion functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(trim|ltrim|rtrim|replace|substring|left|right|split|toLower|toUpper|reverse)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "String manipulation functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(abs|ceil|floor|round|sign|rand|sqrt|log|log10|exp|e|pi|sin|cos|tan|asin|acos|atan|atan2|degrees|radians)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Mathematical and trigonometric functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(date|datetime|time|localtime|localdatetime|duration)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Temporal type constructor functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(date\\.truncate|datetime\\.truncate|duration\\.between|duration\\.inMonths|duration\\.inDays|duration\\.inSeconds)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Temporal utility and truncation functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(point|distance)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Spatial point and distance functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(coalesce|nullIf|valueType|char_length|character_length)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Null handling and value type functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\bapoc\\.[a-zA-Z_]+\\.[a-zA-Z_]+\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "APOC library procedure and function calls"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(shortestPath|allShortestPaths)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Path finding functions"
    },
    {
      "tokenType": "number",
      "pattern": "\\b\\d+(?:\\.\\d+)?\\b",
      "tokenModifiers": [],
      "description": "Numeric integer and float literals"
    },
    {
      "tokenType": "comment",
      "pattern": "//[^\\n]*",
      "tokenModifiers": [],
      "description": "Single-line comments"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(true|false|null)\\b",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Boolean and null literal values"
    }
  ]
}
