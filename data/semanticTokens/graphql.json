{
  "language": "graphql",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["type", "enum", "interface", "variable", "property", "enumMember", "function", "keyword", "comment", "string", "number", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "deprecated"]
  },
  "semanticRules": [
    {
      "type": "keyword",
      "pattern": "\\b(type|input|enum|interface|union|scalar|query|mutation|subscription|fragment|on|extend|schema|implements|directive|repeatable)\\b",
      "modifiers": [],
      "description": "GraphQL schema and operation keywords"
    },
    {
      "type": "type",
      "pattern": "(?<=(?:type|input|interface|union|scalar|enum|implements|on|extend\\s+type)\\s+)[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Named type declarations for types, inputs, interfaces, unions"
    },
    {
      "type": "property",
      "pattern": "^\\s*[a-z_][a-zA-Z0-9_]*(?=\\s*[:(])",
      "modifiers": ["definition"],
      "description": "Field definitions and field resolvers in type bodies"
    },
    {
      "type": "decorator",
      "pattern": "@[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": [],
      "description": "Directives like @deprecated, @skip, @include"
    },
    {
      "type": "enum",
      "pattern": "(?<=enum\\s+)[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Enum type declarations"
    },
    {
      "type": "enumMember",
      "pattern": "^\\s*[A-Z_][A-Z0-9_]*\\s*$",
      "modifiers": [],
      "description": "Enum member values in all-caps"
    },
    {
      "type": "variable",
      "pattern": "\\$[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": [],
      "description": "Query variables prefixed with $"
    },
    {
      "type": "type",
      "pattern": "\\b(String|Int|Float|Boolean|ID)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in scalar types"
    },
    {
      "type": "operator",
      "pattern": "(!|=|\\.\\.\\.|:)",
      "modifiers": [],
      "description": "Non-null !, assignment, spread, and colon operators"
    },
    {
      "type": "comment",
      "pattern": "#.*$|\"\"\"[\\s\\S]*?\"\"\"",
      "modifiers": ["documentation"],
      "description": "Single-line comments and description block strings"
    }
  ]
}
