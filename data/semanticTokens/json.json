{
  "language": "json",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["property", "keyword", "string", "number", "operator"],
    "tokenModifiers": ["declaration"]
  },
  "semanticRules": [
    {
      "type": "property",
      "pattern": "\"[^\"]+\"(?=\\s*:)",
      "modifiers": ["declaration"],
      "description": "Object property keys before colon"
    },
    {
      "type": "string",
      "pattern": "(?<=:\\s*)\"(?:[^\"\\\\]|\\\\.)*\"",
      "modifiers": [],
      "description": "String values after colon"
    },
    {
      "type": "number",
      "pattern": "(?<=:\\s*)-?\\d+\\.?\\d*(?:[eE][+-]?\\d+)?",
      "modifiers": [],
      "description": "Numeric values including integers, floats, and scientific notation"
    },
    {
      "type": "keyword",
      "pattern": "(?<=:\\s*)\\b(true|false)\\b",
      "modifiers": [],
      "description": "Boolean literal values"
    },
    {
      "type": "keyword",
      "pattern": "(?<=:\\s*)\\bnull\\b",
      "modifiers": [],
      "description": "Null literal value"
    },
    {
      "type": "operator",
      "pattern": "[:\\[\\]{}]",
      "modifiers": [],
      "description": "Structural operators: colon, brackets, and braces"
    },
    {
      "type": "string",
      "pattern": "(?<=\\[\\s*|,\\s*)\"(?:[^\"\\\\]|\\\\.)*\"(?=\\s*[,\\]])",
      "modifiers": [],
      "description": "String values inside arrays"
    }
  ]
}
