{
  "language": "apex",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["class", "interface", "enum", "type", "variable", "function", "method", "property", "parameter", "decorator", "keyword"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "documentation", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "class",
      "pattern": "\\b(public|private|global)\\s+(class|trigger)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Trigger and class declarations"
    },
    {
      "type": "keyword",
      "pattern": "\\b(SELECT|FROM|WHERE|LIMIT|ORDER\\s+BY|GROUP\\s+BY)\\b",
      "modifiers": [],
      "description": "SOQL query keywords"
    },
    {
      "type": "decorator",
      "pattern": "@(AuraEnabled|isTest|future|InvocableMethod|InvocableVariable|RemoteAction)",
      "modifiers": [],
      "description": "Salesforce-specific annotations"
    },
    {
      "type": "keyword",
      "pattern": "\\b(insert|update|delete|upsert|undelete|merge)\\b",
      "modifiers": [],
      "description": "DML operation statements"
    },
    {
      "type": "method",
      "pattern": "\\b(public|private|global|protected)\\s+(static\\s+)?[A-Za-z<>\\[\\]]+\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "modifiers": ["declaration"],
      "description": "Method declarations"
    },
    {
      "type": "interface",
      "pattern": "\\binterface\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Interface declarations"
    },
    {
      "type": "enum",
      "pattern": "\\benum\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Enum declarations"
    },
    {
      "type": "property",
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\{\\s*(get|set)",
      "modifiers": ["definition"],
      "description": "Property definitions with getters/setters"
    },
    {
      "type": "type",
      "pattern": "\\b(List|Set|Map)<([A-Za-z_][A-Za-z0-9_,\\s]*)>",
      "modifiers": ["defaultLibrary"],
      "description": "Generic collection types"
    },
    {
      "type": "variable",
      "pattern": "\\b(trigger\\.(new|old|newMap|oldMap|isInsert|isUpdate|isDelete|isBefore|isAfter))\\b",
      "modifiers": ["readonly", "defaultLibrary"],
      "description": "Trigger context variables"
    }
  ]
}
