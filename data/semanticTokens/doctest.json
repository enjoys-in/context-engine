{
  "language": "doctest",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["keyword", "function", "string", "variable", "comment", "operator"],
    "tokenModifiers": ["readonly", "documentation", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "keyword",
      "pattern": "^>>>\\s",
      "modifiers": [],
      "description": "Interactive prompt test directive (>>>)"
    },
    {
      "type": "keyword",
      "pattern": "^\\.\\.\\.\\s",
      "modifiers": [],
      "description": "Continuation prompt (...)"
    },
    {
      "type": "string",
      "pattern": "^(?!>>>|\\.\\.\\.)(.+)$",
      "modifiers": ["readonly"],
      "description": "Expected output lines"
    },
    {
      "type": "keyword",
      "pattern": "Traceback \\(most recent call last\\):",
      "modifiers": [],
      "description": "Traceback header for expected exceptions"
    },
    {
      "type": "variable",
      "pattern": "([A-Z][a-zA-Z0-9_]*Error|[A-Z][a-zA-Z0-9_]*Exception|[A-Z][a-zA-Z0-9_]*Warning):",
      "modifiers": ["readonly"],
      "description": "Exception type in traceback output"
    },
    {
      "type": "comment",
      "pattern": "#\\s*doctest:\\s*\\+([A-Z_]+)",
      "modifiers": ["documentation"],
      "description": "Doctest directive flags (# doctest: +ELLIPSIS, +SKIP, etc.)"
    },
    {
      "type": "function",
      "pattern": ">>>\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "modifiers": [],
      "description": "Function calls in test prompts"
    },
    {
      "type": "operator",
      "pattern": "\\.\\.\\.",
      "modifiers": [],
      "description": "Ellipsis wildcard in expected output"
    }
  ]
}
