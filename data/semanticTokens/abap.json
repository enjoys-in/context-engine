{
  "language": "abap",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["class", "interface", "type", "variable", "function", "method", "keyword", "property", "parameter", "event", "macro"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "documentation", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "variable",
      "pattern": "\\bDATA\\s+([a-z_][a-z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "DATA variable declarations"
    },
    {
      "type": "type",
      "pattern": "\\bTYPES\\s+([a-z_][a-z0-9_]*)\\b",
      "modifiers": ["definition"],
      "description": "TYPES type definitions"
    },
    {
      "type": "method",
      "pattern": "\\bCLASS-METHODS\\s+([a-z_][a-z0-9_]*)\\b",
      "modifiers": ["declaration", "static"],
      "description": "CLASS-METHODS static method declarations"
    },
    {
      "type": "function",
      "pattern": "\\bFORM\\s+([a-z_][a-z0-9_]*)\\b",
      "modifiers": ["definition"],
      "description": "FORM subroutine definitions"
    },
    {
      "type": "keyword",
      "pattern": "\\b(SELECT|FROM|WHERE|INTO|TABLE|ENDSELECT)\\b",
      "modifiers": [],
      "description": "SELECT statement keywords"
    },
    {
      "type": "function",
      "pattern": "\\bCALL\\s+FUNCTION\\s+'([^']+)'",
      "modifiers": ["defaultLibrary"],
      "description": "Function module calls"
    },
    {
      "type": "class",
      "pattern": "\\bCLASS\\s+([a-z_][a-z0-9_]*)\\s+DEFINITION\\b",
      "modifiers": ["declaration"],
      "description": "Class definitions"
    },
    {
      "type": "interface",
      "pattern": "\\bINTERFACE\\s+([a-z_][a-z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Interface declarations"
    },
    {
      "type": "method",
      "pattern": "\\bMETHODS\\s+([a-z_][a-z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Instance method declarations"
    },
    {
      "type": "event",
      "pattern": "\\bEVENTS\\s+([a-z_][a-z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Event declarations"
    }
  ]
}
