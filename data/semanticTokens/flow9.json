{
  "language": "flow9",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "interface", "typeParameter", "parameter", "variable", "property", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "type",
      "pattern": "\\b[A-Z][a-zA-Z0-9]*\\b",
      "modifiers": ["declaration"],
      "description": "Type declarations starting with uppercase letter"
    },
    {
      "type": "function",
      "pattern": "\\b[a-z][a-zA-Z0-9]*\\s*(?=\\()",
      "modifiers": ["definition"],
      "description": "Function definitions followed by parentheses"
    },
    {
      "type": "keyword",
      "pattern": "\\b(import|export|require|forbid|native|if|else|switch|ref|deref)\\b",
      "modifiers": [],
      "description": "Flow9 language keywords"
    },
    {
      "type": "type",
      "pattern": "\\b(Material|Form|Transform|Group|Text|Picture)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in material and UI types"
    },
    {
      "type": "namespace",
      "pattern": "(?<=import\\s+)[a-zA-Z_/]+",
      "modifiers": [],
      "description": "Import path references"
    },
    {
      "type": "variable",
      "pattern": "\\b[a-z][a-zA-Z0-9]*\\b(?!\\s*\\()",
      "modifiers": [],
      "description": "Variable references in expressions"
    },
    {
      "type": "typeParameter",
      "pattern": "(?<=<\\s*)\\b[A-Z]\\b(?=\\s*>)",
      "modifiers": ["declaration"],
      "description": "Generic type parameters in angle brackets"
    },
    {
      "type": "operator",
      "pattern": "(->|\\|>|:=|==|!=|<=|>=|\\\\|\\|)",
      "modifiers": [],
      "description": "Flow9 operators including pipe and lambda arrow"
    },
    {
      "type": "comment",
      "pattern": "//.*$|/\\*[\\s\\S]*?\\*/",
      "modifiers": ["documentation"],
      "description": "Single-line and multi-line comments"
    },
    {
      "type": "string",
      "pattern": "\"(?:[^\"\\\\]|\\\\.)*\"",
      "modifiers": [],
      "description": "String literals in double quotes"
    }
  ]
}
