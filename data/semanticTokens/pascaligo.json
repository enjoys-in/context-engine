{
  "language": "pascaligo",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "enum", "typeParameter", "variable", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly"]
  },
  "semanticRules": [
    {
      "type": "variable",
      "pattern": "\\b(let|const)\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Let and const bindings for value declarations"
    },
    {
      "type": "type",
      "pattern": "\\btype\\s+(\\w+)\\s*=",
      "modifiers": ["declaration"],
      "description": "Type alias and definition declarations"
    },
    {
      "type": "keyword",
      "pattern": "\\b(let|in|type|is|of|if|then|else|match|with|function|var|const|begin|end|block|case|for|to|while|do|skip|record|map|list|set|module|from|import|export|recursive|contains|not|and|or|mod)\\b",
      "modifiers": [],
      "description": "PascaLIGO and CameLIGO keywords"
    },
    {
      "type": "function",
      "pattern": "\\b(function|recursive)\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Function declarations including recursive functions"
    },
    {
      "type": "keyword",
      "pattern": "\\b(match)\\s+\\w+\\s+(with)\\b",
      "modifiers": [],
      "description": "Pattern match expressions"
    },
    {
      "type": "type",
      "pattern": "\\b(nat|int|tez|string|bytes|address|key|key_hash|signature|timestamp|bool|unit|operation|contract|option|list|map|big_map|set)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "LIGO built-in types for Tezos smart contracts"
    },
    {
      "type": "function",
      "pattern": "\\b(Tezos\\.|Crypto\\.|Bytes\\.|Map\\.|List\\.|Set\\.|Big_map\\.)\\w+",
      "modifiers": ["defaultLibrary"],
      "description": "LIGO standard library module functions"
    },
    {
      "type": "enum",
      "pattern": "\\|\\s*(\\w+)\\s*(of\\b)?",
      "modifiers": ["declaration"],
      "description": "Variant/sum type constructors"
    },
    {
      "type": "comment",
      "pattern": "//[^\\n]*|\\(\\*[\\s\\S]*?\\*\\)",
      "modifiers": [],
      "description": "Line comments // and block comments (* *)"
    },
    {
      "type": "string",
      "pattern": "\"([^\"\\\\]|\\\\.)*\"",
      "modifiers": [],
      "description": "String literals in double quotes"
    },
    {
      "type": "number",
      "pattern": "\\b\\d+n?\\b|\\b\\d+\\.\\d+\\b|\\b\\d+mutez\\b|\\b\\d+tez\\b",
      "modifiers": [],
      "description": "Numeric literals including nat (n suffix) and tez amounts"
    }
  ]
}
