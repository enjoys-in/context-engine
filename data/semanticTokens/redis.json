{
  "language": "redis",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["keyword", "function", "variable", "string", "number", "comment", "operator", "type"],
    "tokenModifiers": ["defaultLibrary", "readonly"]
  },
  "semanticRules": [
    {
      "type": "keyword",
      "pattern": "\\b(GET|SET|DEL|EXISTS|EXPIRE|TTL|PERSIST|KEYS|SCAN|TYPE|RENAME|RENAMENX|DUMP|RESTORE|OBJECT|WAIT|TOUCH|UNLINK|COPY|MOVE)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Key manipulation commands"
    },
    {
      "type": "keyword",
      "pattern": "\\b(HGET|HSET|HDEL|HMGET|HMSET|HGETALL|HKEYS|HVALS|HEXISTS|HINCRBY|HINCRBYFLOAT|HLEN|HSCAN|HSETNX)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Hash commands"
    },
    {
      "type": "keyword",
      "pattern": "\\b(LPUSH|RPUSH|LPOP|RPOP|LLEN|LRANGE|LINDEX|LSET|LINSERT|LREM|BLPOP|BRPOP|BRPOPLPUSH|LMOVE|BLMOVE|LPOS)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "List commands"
    },
    {
      "type": "keyword",
      "pattern": "\\b(SADD|SREM|SMEMBERS|SISMEMBER|SCARD|SUNION|SINTER|SDIFF|SRANDMEMBER|SPOP|SSCAN|SMISMEMBER|SMOVE)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Set commands"
    },
    {
      "type": "keyword",
      "pattern": "\\b(ZADD|ZREM|ZSCORE|ZRANK|ZREVRANK|ZRANGE|ZREVRANGE|ZRANGEBYSCORE|ZCOUNT|ZCARD|ZINCRBY|ZPOPMIN|ZPOPMAX|ZRANGESTORE|ZUNIONSTORE|ZINTERSTORE|ZDIFFSTORE|ZLEXCOUNT|ZRANDMEMBER|ZSCAN)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Sorted set commands"
    },
    {
      "type": "keyword",
      "pattern": "\\b(PUBLISH|SUBSCRIBE|UNSUBSCRIBE|PSUBSCRIBE|PUNSUBSCRIBE|PUBSUB)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Pub/Sub commands"
    },
    {
      "type": "function",
      "pattern": "\\b(EVAL|EVALSHA|SCRIPT)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Lua scripting commands"
    },
    {
      "type": "variable",
      "pattern": "[\\w:*?\\[\\]-]+(?=\\s|$)",
      "modifiers": [],
      "description": "Redis key patterns with glob-style matching"
    },
    {
      "type": "string",
      "pattern": "\"([^\"\\\\]|\\\\.)*\"|'([^'\\\\]|\\\\.)*'",
      "modifiers": [],
      "description": "String values in quotes"
    },
    {
      "type": "number",
      "pattern": "\\b-?\\d+(\\.\\d+)?\\b",
      "modifiers": [],
      "description": "Numeric values (scores, TTLs, counts)"
    },
    {
      "type": "comment",
      "pattern": "#[^\\n]*",
      "modifiers": [],
      "description": "Comments in Redis configuration and scripts"
    }
  ]
}
