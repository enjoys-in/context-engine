{
  "language": "redis",
  "legend": {
    "tokenTypes": [
      "namespace",
      "keyword",
      "function",
      "variable",
      "property",
      "string",
      "number",
      "comment",
      "operator",
      "type",
      "modifier",
      "enum",
      "enumMember"
    ],
    "tokenModifiers": [
      "defaultLibrary",
      "readonly",
      "modification"
    ]
  },
  "semanticRules": [
    {
      "tokenType": "keyword",
      "pattern": "\\b(SET|GET|MSET|MGET|APPEND|INCR|DECR|INCRBY|DECRBY|INCRBYFLOAT|STRLEN|GETRANGE|SETRANGE|SETNX|SETEX|PSETEX|GETSET|GETDEL|GETEX|MSETNX|LCS)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "String commands for get/set operations and manipulation"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(HSET|HGET|HMSET|HMGET|HDEL|HEXISTS|HGETALL|HKEYS|HVALS|HLEN|HINCRBY|HINCRBYFLOAT|HSETNX|HSCAN|HRANDFIELD)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Hash commands for field-value pair operations"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(LPUSH|RPUSH|LPOP|RPOP|LLEN|LRANGE|LINDEX|LSET|LINSERT|LREM|LTRIM|BLPOP|BRPOP|LMPOP|BLMPOP|LMOVE|BLMOVE|LPOS|LPUSHX|RPUSHX)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "List commands for push/pop and range operations"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(SADD|SREM|SMEMBERS|SISMEMBER|SCARD|SUNION|SINTER|SDIFF|SRANDMEMBER|SPOP|SMOVE|SUNIONSTORE|SINTERSTORE|SDIFFSTORE|SSCAN|SMISMEMBER|SINTERCARD)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Set commands for unordered collection operations"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(ZADD|ZREM|ZRANGE|ZRANGEBYSCORE|ZREVRANGEBYSCORE|ZRANGEBYLEX|ZREVRANGEBYLEX|ZRANK|ZREVRANK|ZSCORE|ZCARD|ZCOUNT|ZINCRBY|ZUNIONSTORE|ZINTERSTORE|ZDIFFSTORE|ZPOPMIN|ZPOPMAX|BZPOPMIN|BZPOPMAX|ZRANGESTORE|ZLEXCOUNT|ZRANDMEMBER|ZSCAN|ZMSCORE|ZMPOP|BZMPOP|ZDIFF|ZUNION|ZINTER|ZREVRANGE)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Sorted set commands for score-based ordered collections"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(DEL|EXISTS|EXPIRE|TTL|PEXPIRE|PTTL|PERSIST|RENAME|RENAMENX|TYPE|KEYS|SCAN|RANDOMKEY|DUMP|RESTORE|OBJECT|WAIT|TOUCH|UNLINK|COPY|MOVE|EXPIREAT|PEXPIREAT|EXPIRETIME|PEXPIRETIME|SORT|SORT_RO)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Key management commands for lifecycle and inspection"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(XADD|XREAD|XRANGE|XREVRANGE|XLEN|XINFO|XGROUP|XACK|XCLAIM|XDEL|XTRIM|XAUTOCLAIM|XPENDING|XSETID)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Stream commands for append-only log data structure"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(SUBSCRIBE|UNSUBSCRIBE|PUBLISH|PSUBSCRIBE|PUNSUBSCRIBE|PUBSUB|SSUBSCRIBE|SUNSUBSCRIBE)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Pub/Sub messaging commands"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(MULTI|EXEC|DISCARD|WATCH|UNWATCH)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Transaction commands for atomic operation batching"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(EVAL|EVALSHA|EVALRO|SCRIPT|FUNCTION|FCALL|FCALL_RO)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Scripting and function commands for server-side Lua/library execution"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(INFO|CONFIG|DBSIZE|FLUSHDB|FLUSHALL|BGSAVE|BGREWRITEAOF|CLIENT|MONITOR|DEBUG|SLOWLOG|SAVE|LASTSAVE|SHUTDOWN|SLAVEOF|REPLICAOF|COMMAND|ACL|MODULE|SWAPDB|RESET|FAILOVER|LATENCY|MEMORY|CLUSTER|SENTINEL|TIME|ROLE|HELLO|QUIT|PING|ECHO|SELECT|AUTH)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Server administration and connection commands"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(PFADD|PFCOUNT|PFMERGE)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "HyperLogLog commands for cardinality estimation"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(GEOADD|GEOPOS|GEODIST|GEORADIUS|GEORADIUSBYMEMBER|GEOSEARCH|GEOSEARCHSTORE|GEOHASH)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Geospatial commands for location-based operations"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(BITCOUNT|BITPOS|BITOP|BITFIELD|BITFIELD_RO|SETBIT|GETBIT)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Bitmap/bitfield commands for bit-level operations"
    },
    {
      "tokenType": "modifier",
      "pattern": "\\b(NX|XX|EX|PX|EXAT|PXAT|KEEPTTL|GT|LT|GET|ABSTTL|REPLACE|FREQ|IDLETIME|ENCODING|REFCOUNT|HELP)\\b",
      "tokenModifiers": [],
      "description": "Command option flags and modifiers for SET, EXPIRE, RESTORE, OBJECT, etc."
    },
    {
      "tokenType": "modifier",
      "pattern": "\\b(MATCH|COUNT|TYPE|BY|LIMIT|WITHSCORES|WITHCOORD|WITHDIST|WITHHASH|REV|BYSCORE|BYLEX|AGGREGATE|WEIGHTS|ASC|DESC|ALPHA|STORE|CH|INCR|ASYNC|SYNC|NOSAVE)\\b",
      "tokenModifiers": [],
      "description": "Subcommand arguments for SCAN, SORT, GEO, ZADD, FLUSHDB, etc."
    },
    {
      "tokenType": "enumMember",
      "pattern": "\\b(BEFORE|AFTER|LEFT|RIGHT|MIN|MAX|SUM|CREATE|SETID|DELCONSUMER|DESTROY|MKSTREAM|NOMKSTREAM|LOAD|FLUSH|LIST|KILL|GETNAME|SETNAME|PAUSE|UNPAUSE|ID|BLOCK|STREAMS|GROUP|CONSUMERS|FULL)\\b",
      "tokenModifiers": [],
      "description": "Positional arguments and subcommand keywords for LINSERT, LMPOP, XGROUP, CLIENT, SCRIPT, XINFO, XREAD, etc."
    },
    {
      "tokenType": "type",
      "pattern": "\\b(string|list|set|zset|hash|stream|ReJSON-RL|MBbloom--|graphdata|TSDB-TYPE)\\b",
      "tokenModifiers": ["readonly"],
      "description": "Redis data type identifiers returned by TYPE command"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(XINFO\\s+STREAM|XINFO\\s+GROUPS|XINFO\\s+CONSUMERS|XGROUP\\s+CREATE|XGROUP\\s+SETID|XGROUP\\s+DESTROY|XGROUP\\s+DELCONSUMER|XGROUP\\s+CREATECONSUMER)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Compound stream subcommands for XINFO and XGROUP"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(CLIENT\\s+LIST|CLIENT\\s+KILL|CLIENT\\s+GETNAME|CLIENT\\s+SETNAME|CLIENT\\s+PAUSE|CLIENT\\s+UNPAUSE|CLIENT\\s+ID|CLIENT\\s+INFO)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "CLIENT subcommands for connection management"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(CONFIG\\s+SET|CONFIG\\s+GET|CONFIG\\s+RESETSTAT|CONFIG\\s+REWRITE)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "CONFIG subcommands for runtime configuration"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(SCRIPT\\s+LOAD|SCRIPT\\s+EXISTS|SCRIPT\\s+FLUSH|SCRIPT\\s+DEBUG|FUNCTION\\s+LOAD|FUNCTION\\s+LIST|FUNCTION\\s+DELETE|FUNCTION\\s+DUMP|FUNCTION\\s+RESTORE|FUNCTION\\s+STATS)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "SCRIPT and FUNCTION subcommands for server-side scripting"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(OBJECT\\s+ENCODING|OBJECT\\s+REFCOUNT|OBJECT\\s+IDLETIME|OBJECT\\s+FREQ|OBJECT\\s+HELP)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "OBJECT subcommands for key introspection"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(CLUSTER\\s+INFO|CLUSTER\\s+NODES|CLUSTER\\s+MEET|CLUSTER\\s+ADDSLOTS|CLUSTER\\s+DELSLOTS|CLUSTER\\s+FAILOVER|CLUSTER\\s+RESET|CLUSTER\\s+SLOTS|CLUSTER\\s+SHARDS|CLUSTER\\s+KEYSLOT|CLUSTER\\s+REPLICATE|CLUSTER\\s+SETSLOT|CLUSTER\\s+SAVECONFIG|CLUSTER\\s+FLUSHSLOTS|CLUSTER\\s+MYID)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "CLUSTER subcommands for cluster management"
    },
    {
      "tokenType": "variable",
      "pattern": "[a-zA-Z][a-zA-Z0-9_:.-]*(?=\\s|$)",
      "tokenModifiers": [],
      "description": "Redis key names including namespaced keys with colons"
    },
    {
      "tokenType": "string",
      "pattern": "\"([^\"\\\\]|\\\\.)*\"|'([^'\\\\]|\\\\.)*'",
      "tokenModifiers": [],
      "description": "Quoted string values"
    },
    {
      "tokenType": "number",
      "pattern": "[+-]?\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b",
      "tokenModifiers": [],
      "description": "Numeric literals for scores, TTLs, counts, and offsets"
    },
    {
      "tokenType": "number",
      "pattern": "[+-]inf\\b|\\binf\\b",
      "tokenModifiers": [],
      "description": "Infinity literals for sorted set range queries"
    },
    {
      "tokenType": "comment",
      "pattern": "#[^\\n]*",
      "tokenModifiers": [],
      "description": "Comments starting with # in redis.conf and scripts"
    },
    {
      "tokenType": "operator",
      "pattern": "\\*\\d+|\\$\\d+",
      "tokenModifiers": [],
      "description": "RESP protocol array (*N) and bulk string ($N) length prefixes"
    }
  ]
}
