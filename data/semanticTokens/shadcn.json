{
  "language": "shadcn",
  "legend": {
    "tokenTypes": [
      "namespace",
      "type",
      "class",
      "enum",
      "interface",
      "struct",
      "typeParameter",
      "parameter",
      "variable",
      "property",
      "enumMember",
      "event",
      "function",
      "method",
      "keyword",
      "modifier",
      "string",
      "decorator",
      "macro"
    ],
    "tokenModifiers": [
      "declaration",
      "definition",
      "readonly",
      "static",
      "deprecated",
      "abstract",
      "async",
      "modification",
      "documentation",
      "defaultLibrary"
    ]
  },
  "semanticRules": [
    {
      "tokenType": "class",
      "pattern": "<([A-Z][a-zA-Z0-9]*)(?:\\s|>|/)",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "shadcn/ui component names used as PascalCase JSX tags (e.g. Button, Card, Dialog)"
    },
    {
      "tokenType": "class",
      "pattern": "<([A-Z][a-zA-Z0-9]*\\.[A-Z][a-zA-Z0-9]*)(?:\\s|>|/)",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Radix UI namespaced primitives (e.g. Dialog.Root, Accordion.Item)"
    },
    {
      "tokenType": "function",
      "pattern": "\\bcn\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "cn() utility function call for Tailwind class merging"
    },
    {
      "tokenType": "function",
      "pattern": "\\bcva\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "cva() class-variance-authority definition call"
    },
    {
      "tokenType": "enumMember",
      "pattern": "variant\\s*:\\s*[\"']([a-zA-Z]+)[\"']",
      "tokenModifiers": [],
      "description": "Variant prop string values (e.g. variant=\"destructive\")"
    },
    {
      "tokenType": "variable",
      "pattern": "var\\(--([a-zA-Z][a-zA-Z0-9-]*)\\)",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "CSS custom property variable references (e.g. var(--primary))"
    },
    {
      "tokenType": "string",
      "pattern": "(?<=[\"'`\\s])([a-z][a-z0-9]*(?:-[a-z0-9]+)*(?:/[a-z0-9]+)?(?:\\[[^\\]]*\\])?)(?=[\"'`\\s])",
      "tokenModifiers": [],
      "description": "Tailwind CSS utility class names within className strings"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(use[A-Z][a-zA-Z0-9]*)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "React hook calls (useState, useEffect, useToast, useForm, etc.)"
    },
    {
      "tokenType": "function",
      "pattern": "React\\.forwardRef\\s*(?:<[^>]*>)?\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "React.forwardRef wrapper call"
    },
    {
      "tokenType": "property",
      "pattern": "([A-Z][a-zA-Z0-9]*)\\.displayName\\s*=",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Component displayName assignment for DevTools"
    },
    {
      "tokenType": "function",
      "pattern": "\\bz\\.(?:object|string|number|boolean|enum|array|union|optional|nullable|literal|record|tuple|lazy|nativeEnum|discriminatedUnion|intersection)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Zod schema validator method calls"
    },
    {
      "tokenType": "property",
      "pattern": "\\bfield\\.([a-zA-Z][a-zA-Z0-9]*)\\b",
      "tokenModifiers": [],
      "description": "Form field accessor properties (field.value, field.onChange, field.name)"
    },
    {
      "tokenType": "type",
      "pattern": ":\\s*([A-Z][a-zA-Z0-9]*(?:<[^>]*>)?(?:\\[\\])?)",
      "tokenModifiers": [],
      "description": "TypeScript type annotations after colons"
    },
    {
      "tokenType": "interface",
      "pattern": "(?:interface|type)\\s+([A-Z][a-zA-Z0-9]*)",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Interface and type alias declarations"
    },
    {
      "tokenType": "property",
      "pattern": "([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*(?::\\s*[^,}]+)?\\s*(?=[,}])",
      "tokenModifiers": [],
      "description": "Interface and type property names"
    },
    {
      "tokenType": "variable",
      "pattern": "import\\s+\\{\\s*([^}]+)\\s*\\}",
      "tokenModifiers": [],
      "description": "Named import specifiers within import statements"
    },
    {
      "tokenType": "property",
      "pattern": "(?<=<[A-Z][a-zA-Z0-9]*\\s[^>]*)([a-zA-Z][a-zA-Z0-9]*)(?==)",
      "tokenModifiers": [],
      "description": "JSX attribute names on components"
    },
    {
      "tokenType": "event",
      "pattern": "\\b(on[A-Z][a-zA-Z0-9]*)\\s*(?:=|\\()",
      "tokenModifiers": [],
      "description": "Event handler props and callbacks (onClick, onChange, onSubmit)"
    },
    {
      "tokenType": "variable",
      "pattern": "ref\\s*=\\s*\\{([a-zA-Z][a-zA-Z0-9]*)\\}",
      "tokenModifiers": [
        "modification"
      ],
      "description": "Ref forwarding patterns passing ref prop"
    },
    {
      "tokenType": "variable",
      "pattern": "\\bconst\\s+([a-zA-Z][a-zA-Z0-9]*Variants?)\\s*=\\s*cva\\b",
      "tokenModifiers": [
        "declaration",
        "readonly"
      ],
      "description": "cva variant definition const declarations"
    },
    {
      "tokenType": "function",
      "pattern": "\\bclsx\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "clsx() utility function call for class concatenation"
    },
    {
      "tokenType": "function",
      "pattern": "\\bzodResolver\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "zodResolver() call for react-hook-form integration"
    },
    {
      "tokenType": "property",
      "pattern": "\\basChild\\b",
      "tokenModifiers": [],
      "description": "Radix UI asChild prop for component composition"
    },
    {
      "tokenType": "modifier",
      "pattern": "(?<=[\"'`\\s])(sm|md|lg|xl|2xl):",
      "tokenModifiers": [],
      "description": "Tailwind responsive breakpoint prefixes (sm:, md:, lg:, xl:, 2xl:)"
    },
    {
      "tokenType": "modifier",
      "pattern": "(?<=[\"'`\\s])(hover|focus|active|disabled|dark|group-hover|focus-visible|focus-within|placeholder|first|last|odd|even|peer-checked):",
      "tokenModifiers": [],
      "description": "Tailwind state and pseudo-class variant prefixes (hover:, focus:, active:, disabled:, dark:, group-hover:, etc.)"
    },
    {
      "tokenType": "property",
      "pattern": "\\bdata-(state|disabled|orientation|side|align|swipe|motion|highlighted|placeholder|open|closed)(?:=|\\b)",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Radix UI data attributes for component state (data-state, data-disabled, data-orientation, etc.)"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(?:toast|sonner)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "shadcn/ui toast and sonner notification function calls"
    },
    {
      "tokenType": "method",
      "pattern": "\\btoast\\.(?:success|error|warning|info|promise|dismiss|custom|loading|message)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Toast method variants (toast.success(), toast.error(), toast.promise(), etc.)"
    },
    {
      "tokenType": "class",
      "pattern": "<(Command(?:Dialog|Input|List|Empty|Group|Item|Separator|Shortcut)?)(?:\\s|>|/)",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "cmdk Command palette component family (CommandInput, CommandList, CommandItem, etc.)"
    },
    {
      "tokenType": "namespace",
      "pattern": "import\\s+\\{[^}]*\\}\\s+from\\s+[\"']lucide-react[\"']",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Lucide icon library imports from lucide-react"
    },
    {
      "tokenType": "class",
      "pattern": "<([A-Z][a-zA-Z]*(?:Icon))(?:\\s|>|/)",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Lucide icon component usage as JSX elements (e.g. <ChevronDownIcon />, <SearchIcon />)"
    },
    {
      "tokenType": "decorator",
      "pattern": "(?<=[\"'`\\s])(animate-[a-z][a-z0-9-]*)(?=[\"'`\\s])",
      "tokenModifiers": [],
      "description": "Tailwind animation utility classes (animate-spin, animate-pulse, animate-bounce, etc.)"
    },
    {
      "tokenType": "decorator",
      "pattern": "(?<=[\"'`\\s])(transition(?:-(?:all|colors|opacity|shadow|transform|none))?)(?=[\"'`\\s])",
      "tokenModifiers": [],
      "description": "Tailwind transition utility classes (transition, transition-colors, transition-opacity, etc.)"
    },
    {
      "tokenType": "decorator",
      "pattern": "(?<=[\"'`\\s])(duration-(?:[0-9]+|\\[[^\\]]+\\]))(?=[\"'`\\s])",
      "tokenModifiers": [],
      "description": "Tailwind transition duration classes (duration-150, duration-300, duration-[2000ms])"
    },
    {
      "tokenType": "decorator",
      "pattern": "(?<=[\"'`\\s])(ease-(?:linear|in|out|in-out|\\[[^\\]]+\\]))(?=[\"'`\\s])",
      "tokenModifiers": [],
      "description": "Tailwind easing function classes (ease-in, ease-out, ease-in-out, ease-linear)"
    },
    {
      "tokenType": "class",
      "pattern": "<(Form(?:Field|Item|Label|Control|Description|Message)?)(?:\\s|>|/)",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "shadcn/ui form component family (FormField, FormItem, FormLabel, FormControl, FormMessage)"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(useRouter|usePathname|useSearchParams|useParams|useSelectedLayoutSegment|useSelectedLayoutSegments)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Next.js App Router navigation hooks (useRouter, usePathname, useSearchParams, etc.)"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(redirect|notFound|permanentRedirect|useFormState|useFormStatus)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Next.js server action and navigation utility functions"
    },
    {
      "tokenType": "macro",
      "pattern": "(?<=[\"'`\\s])(?:[a-z][a-z0-9-]*)?\\[([^\\]]+)\\](?=[\"'`\\s])",
      "tokenModifiers": [],
      "description": "Tailwind arbitrary value bracket notation (min-h-[100px], bg-[#1a1a1a], grid-cols-[1fr_2fr])"
    },
    {
      "tokenType": "keyword",
      "pattern": "@layer\\s+(base|components|utilities)\\b",
      "tokenModifiers": [],
      "description": "CSS @layer declarations for Tailwind layer organization (base, components, utilities)"
    },
    {
      "tokenType": "keyword",
      "pattern": "@apply\\s+",
      "tokenModifiers": [],
      "description": "Tailwind @apply directive for applying utility classes within CSS"
    },
    {
      "tokenType": "property",
      "pattern": "\\b(asChild|forceMount|sideOffset|alignOffset|collisionPadding|avoidCollisions)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Radix UI Slot and positioning props for component composition (asChild, forceMount, sideOffset, etc.)"
    },
    {
      "tokenType": "class",
      "pattern": "<(Slot|SlotClone|Slottable)(?:\\s|>|/)",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Radix UI Slot components for polymorphic component composition"
    },
    {
      "tokenType": "class",
      "pattern": "<(Toaster|ToastProvider|ToastViewport|ToastAction|ToastClose|ToastTitle|ToastDescription)(?:\\s|>|/)",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "shadcn/ui Toast component family (Toaster, ToastAction, ToastTitle, etc.)"
    },
    {
      "tokenType": "string",
      "pattern": "(?<=[\"'`\\s])(data-\\[[a-z-]+\\]:[a-z][a-z0-9-]*)(?=[\"'`\\s])",
      "tokenModifiers": [],
      "description": "Tailwind data attribute selectors for Radix state styling (data-[state=open]:bg-accent, etc.)"
    },
    {
      "tokenType": "modifier",
      "pattern": "(?<=[\"'`\\s])(aria-(?:selected|checked|disabled|expanded|hidden|required|invalid|pressed|current):[a-z][a-z0-9-]*)(?=[\"'`\\s])",
      "tokenModifiers": [],
      "description": "Tailwind aria attribute modifier classes for accessibility-driven styling"
    }
  ]
}
