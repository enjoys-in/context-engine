{
  "language": "crontab",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["number", "keyword", "variable", "function", "string", "operator", "comment"],
    "tokenModifiers": ["readonly", "definition"]
  },
  "semanticRules": [
    {
      "type": "number",
      "pattern": "^\\s*([0-9*,/-]+)\\s+([0-9*,/-]+)\\s+([0-9*,/-]+)\\s+([0-9*,/-]+)\\s+([0-9*,/-]+)",
      "modifiers": [],
      "description": "Cron timing fields (minute, hour, day, month, weekday)"
    },
    {
      "type": "keyword",
      "pattern": "@(reboot|yearly|annually|monthly|weekly|daily|midnight|hourly)",
      "modifiers": ["readonly"],
      "description": "Special schedule shortcuts"
    },
    {
      "type": "function",
      "pattern": "(/usr/bin/|/bin/|/usr/local/bin/)([a-zA-Z0-9_.-]+)",
      "modifiers": [],
      "description": "Command paths with executables"
    },
    {
      "type": "variable",
      "pattern": "^\\s*([A-Z_][A-Z0-9_]*)\\s*=",
      "modifiers": ["definition"],
      "description": "Environment variable assignments"
    },
    {
      "type": "variable",
      "pattern": "\\$([A-Z_][A-Z0-9_]*)",
      "modifiers": ["readonly"],
      "description": "Environment variable references"
    },
    {
      "type": "keyword",
      "pattern": "\\b(MAILTO|SHELL|PATH|HOME|LOGNAME|CRON_TZ)\\b",
      "modifiers": ["readonly"],
      "description": "Well-known crontab environment variables"
    },
    {
      "type": "operator",
      "pattern": "[,\\-*/]",
      "modifiers": [],
      "description": "Cron field operators (range, step, list, wildcard)"
    },
    {
      "type": "string",
      "pattern": "\\b(root|nobody)\\b",
      "modifiers": [],
      "description": "User fields in system crontab"
    }
  ]
}
