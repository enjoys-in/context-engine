{
  "language": "mdx",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "variable", "property", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "type",
      "pattern": "<[A-Z][a-zA-Z0-9]*",
      "modifiers": [],
      "description": "JSX component tags starting with uppercase"
    },
    {
      "type": "keyword",
      "pattern": "^import\\s+",
      "modifiers": [],
      "description": "Import statements for components and modules"
    },
    {
      "type": "keyword",
      "pattern": "^export\\s+(?:default\\s+)?",
      "modifiers": [],
      "description": "Export statements for MDX content"
    },
    {
      "type": "keyword",
      "pattern": "^#{1,6}\\s+.*$",
      "modifiers": ["declaration"],
      "description": "Markdown heading declarations"
    },
    {
      "type": "string",
      "pattern": "(`{1,3})(?!`)[\\s\\S]*?\\1",
      "modifiers": [],
      "description": "Inline code spans and fenced code blocks"
    },
    {
      "type": "property",
      "pattern": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*=\\s*[{\"])",
      "modifiers": [],
      "description": "JSX attribute/prop names"
    },
    {
      "type": "variable",
      "pattern": "\\{[^}]+\\}",
      "modifiers": [],
      "description": "JSX expression blocks in curly braces"
    },
    {
      "type": "variable",
      "pattern": "\\[([^\\]]+)\\]\\(([^)]+)\\)",
      "modifiers": [],
      "description": "Markdown inline links [text](url)"
    },
    {
      "type": "function",
      "pattern": "(?<=import\\s+\\{[^}]*)[a-zA-Z_][a-zA-Z0-9_]*(?=[^}]*\\})",
      "modifiers": [],
      "description": "Named imports in import statements"
    },
    {
      "type": "comment",
      "pattern": "\\{/\\*[\\s\\S]*?\\*/\\}",
      "modifiers": ["documentation"],
      "description": "JSX comments {/* ... */}"
    },
    {
      "type": "property",
      "pattern": "^\\s*[-*+]\\s+|^\\s*\\d+\\.\\s+",
      "modifiers": [],
      "description": "Markdown list item markers"
    }
  ]
}
