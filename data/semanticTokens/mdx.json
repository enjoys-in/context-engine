{
  "language": "mdx",
  "legend": {
    "tokenTypes": [
      "keyword",
      "variable",
      "type",
      "property",
      "function",
      "string",
      "comment",
      "operator",
      "namespace"
    ],
    "tokenModifiers": [
      "declaration",
      "definition",
      "defaultLibrary",
      "documentation"
    ]
  },
  "semanticRules": [
    {
      "tokenType": "keyword",
      "pattern": "^import\\s+",
      "tokenModifiers": [],
      "description": "ESM import statements"
    },
    {
      "tokenType": "keyword",
      "pattern": "^export\\s+default\\s+",
      "tokenModifiers": ["declaration"],
      "description": "Default export statements for layout or content"
    },
    {
      "tokenType": "keyword",
      "pattern": "^export\\s+(?:const|function|let|var)\\s+",
      "tokenModifiers": ["declaration"],
      "description": "Named export declarations"
    },
    {
      "tokenType": "keyword",
      "pattern": "^export\\s+\\{",
      "tokenModifiers": [],
      "description": "Named re-export statements (export { name })"
    },
    {
      "tokenType": "function",
      "pattern": "(?<=import\\s+)[A-Z][a-zA-Z0-9_]*(?=\\s+from)",
      "tokenModifiers": [],
      "description": "Default import identifiers (component names)"
    },
    {
      "tokenType": "function",
      "pattern": "(?<=import\\s+\\{\\s*)[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*[,}])",
      "tokenModifiers": [],
      "description": "Named import identifiers in destructuring"
    },
    {
      "tokenType": "string",
      "pattern": "(?<=from\\s+)['\"][^'\"]+['\"]",
      "tokenModifiers": [],
      "description": "Module specifier strings in import/export"
    },
    {
      "tokenType": "type",
      "pattern": "<([A-Z][a-zA-Z0-9.]*)(?=\\s|>|/)",
      "tokenModifiers": [],
      "description": "Opening JSX component tags (uppercase)"
    },
    {
      "tokenType": "type",
      "pattern": "</([A-Z][a-zA-Z0-9.]*)\\s*>",
      "tokenModifiers": [],
      "description": "Closing JSX component tags"
    },
    {
      "tokenType": "type",
      "pattern": "<([A-Z][a-zA-Z0-9.]*)\\s*/\\s*>",
      "tokenModifiers": [],
      "description": "Self-closing JSX component tags"
    },
    {
      "tokenType": "keyword",
      "pattern": "<(div|span|p|a|img|ul|ol|li|h[1-6]|table|thead|tbody|tr|th|td|section|article|nav|header|footer|main|aside|form|input|button|label|select|textarea|pre|code|blockquote|hr|br|details|summary)(?=\\s|>|/)",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Intrinsic HTML element tags in JSX"
    },
    {
      "tokenType": "property",
      "pattern": "(?<=<[a-zA-Z][a-zA-Z0-9.]*\\s[^>]*)\\b([a-zA-Z_][a-zA-Z0-9_-]*)\\s*=\\s*(?=[{\"])",
      "tokenModifiers": [],
      "description": "JSX attribute names with string or expression values"
    },
    {
      "tokenType": "property",
      "pattern": "(?<=<[a-zA-Z][a-zA-Z0-9.]*\\s[^>]*)\\b(className|style|key|ref|id|href|src|alt|onClick|onChange|onSubmit|disabled|placeholder|type|value|name|target|rel)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Common JSX/HTML attribute names"
    },
    {
      "tokenType": "operator",
      "pattern": "\\{\\s*\\.\\.\\.[a-zA-Z_][a-zA-Z0-9_.]*\\s*\\}",
      "tokenModifiers": [],
      "description": "JSX spread attribute expressions {...props}"
    },
    {
      "tokenType": "variable",
      "pattern": "(?<!\\{)\\{(?!/\\*)[^{}]*\\}(?!\\})",
      "tokenModifiers": [],
      "description": "JSX/MDX expression containers {expression}"
    },
    {
      "tokenType": "comment",
      "pattern": "\\{/\\*[\\s\\S]*?\\*/\\}",
      "tokenModifiers": ["documentation"],
      "description": "MDX/JSX comments {/* ... */}"
    },
    {
      "tokenType": "keyword",
      "pattern": "^#{1,6}\\s+.+$",
      "tokenModifiers": ["declaration"],
      "description": "Markdown heading declarations (# through ######)"
    },
    {
      "tokenType": "operator",
      "pattern": "\\*\\*[^*]+\\*\\*|__[^_]+__",
      "tokenModifiers": [],
      "description": "Markdown bold/strong emphasis"
    },
    {
      "tokenType": "operator",
      "pattern": "(?<!\\*)\\*(?!\\*)[^*]+(?<!\\*)\\*(?!\\*)|(?<!_)_(?!_)[^_]+(?<!_)_(?!_)",
      "tokenModifiers": [],
      "description": "Markdown italic emphasis"
    },
    {
      "tokenType": "variable",
      "pattern": "\\[([^\\]]+)\\]\\(([^)]+)\\)",
      "tokenModifiers": [],
      "description": "Markdown inline links [text](url)"
    },
    {
      "tokenType": "variable",
      "pattern": "!\\[([^\\]]*)\\]\\(([^)]+)\\)",
      "tokenModifiers": [],
      "description": "Markdown image syntax ![alt](src)"
    },
    {
      "tokenType": "string",
      "pattern": "^```([a-zA-Z0-9_+-]*)\\s*$[\\s\\S]*?^```\\s*$",
      "tokenModifiers": [],
      "description": "Fenced code blocks with optional language identifier"
    },
    {
      "tokenType": "string",
      "pattern": "(?<!`)`(?!`)[^`\\n]+`(?!`)",
      "tokenModifiers": [],
      "description": "Inline code spans"
    },
    {
      "tokenType": "keyword",
      "pattern": "^>\\s+",
      "tokenModifiers": [],
      "description": "Markdown blockquote markers"
    },
    {
      "tokenType": "property",
      "pattern": "^\\s*[-*+]\\s+|^\\s*\\d+\\.\\s+",
      "tokenModifiers": [],
      "description": "Markdown list item markers (unordered and ordered)"
    },
    {
      "tokenType": "operator",
      "pattern": "^(---|\\*\\*\\*|___)\\s*$",
      "tokenModifiers": [],
      "description": "Markdown horizontal rules / thematic breaks"
    },
    {
      "tokenType": "namespace",
      "pattern": "^---\\s*$[\\s\\S]*?^---\\s*$",
      "tokenModifiers": ["definition"],
      "description": "YAML frontmatter blocks delimited by ---"
    },
    {
      "tokenType": "keyword",
      "pattern": "^:::([a-zA-Z_][a-zA-Z0-9_-]*)(?:\\s+.*)?$",
      "tokenModifiers": [],
      "description": "Remark/rehype container directives (:::note, :::tip, :::warning)"
    },
    {
      "tokenType": "keyword",
      "pattern": "^export\\s+default\\s+function\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "tokenModifiers": ["declaration"],
      "description": "MDX layout component function export"
    },
    {
      "tokenType": "property",
      "pattern": "\\|[^|\\n]+\\|",
      "tokenModifiers": [],
      "description": "Markdown table cell delimiters and content"
    },
    {
      "tokenType": "variable",
      "pattern": "\\[([^\\]]+)\\]\\[([^\\]]*)\\]",
      "tokenModifiers": [],
      "description": "Markdown reference-style links [text][ref]"
    },
    {
      "tokenType": "variable",
      "pattern": "^\\[([^\\]]+)\\]:\\s+(.+)$",
      "tokenModifiers": ["definition"],
      "description": "Markdown link reference definitions"
    },
    {
      "tokenType": "string",
      "pattern": "(?<=<[a-zA-Z][^>]*)\"[^\"]*\"|'[^']*'",
      "tokenModifiers": [],
      "description": "JSX string literal attribute values"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(const|let|var|function|return|if|else|switch|case|default|break|continue|while|for|of|in|new|typeof|instanceof)\\b",
      "tokenModifiers": [],
      "description": "JavaScript keywords in MDX expression blocks"
    }
  ]
}
