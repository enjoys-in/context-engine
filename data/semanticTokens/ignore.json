{
  "language": "ignore",
  "legend": {
    "tokenTypes": [
      "namespace",
      "type",
      "class",
      "enum",
      "interface",
      "struct",
      "typeParameter",
      "parameter",
      "variable",
      "property",
      "enumMember",
      "event",
      "function",
      "method",
      "macro",
      "keyword",
      "modifier",
      "comment",
      "string",
      "number",
      "regexp",
      "operator",
      "decorator"
    ],
    "tokenModifiers": [
      "declaration",
      "definition",
      "readonly",
      "static",
      "deprecated",
      "abstract",
      "async",
      "modification",
      "documentation",
      "defaultLibrary"
    ]
  },
  "semanticRules": [
    {
      "tokenType": "keyword",
      "pattern": "\\\\b(if|else|for|while|return|function|class|import|export|const|var|let|type|new|try)\\\\b",
      "tokenModifiers": [],
      "description": "Ignore Files keywords"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\\\b(catch|throw|switch|case|break|continue|do|in|of)\\\\b",
      "tokenModifiers": [],
      "description": "Ignore Files additional keywords"
    },
    {
      "tokenType": "type",
      "pattern": "\\\\b(String|Number|Boolean|Array|Object|Function|Date|Map|Set|Error)\\\\b",
      "tokenModifiers": [],
      "description": "Ignore Files built-in types"
    },
    {
      "tokenType": "function",
      "pattern": "\\\\b([a-zA-Z_]\\\\w*)\\\\s*\\\\(",
      "tokenModifiers": [],
      "description": "Function calls"
    },
    {
      "tokenType": "function",
      "pattern": "\\\\b(print|log|write|read|open|close|length|size|count|sort)\\\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Ignore Files built-in functions"
    },
    {
      "tokenType": "variable",
      "pattern": "\\\\b(const|let|var|val|dim)\\\\s+(\\\\w+)",
      "tokenModifiers": [],
      "description": "Ignore Files variable declarations"
    },
    {
      "tokenType": "variable",
      "pattern": "\\\\b[A-Z_][A-Z0-9_]{2,}\\\\b",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Constant/uppercase identifiers"
    },
    {
      "tokenType": "class",
      "pattern": "\\\\b[A-Z][a-zA-Z0-9_]*\\\\b",
      "tokenModifiers": [],
      "description": "PascalCase type/class references"
    },
    {
      "tokenType": "parameter",
      "pattern": "\\\\((\\\\w+)(?:\\\\s*[:,]\\\\s*\\\\w+)*\\\\)",
      "tokenModifiers": [],
      "description": "Function parameters"
    },
    {
      "tokenType": "property",
      "pattern": "\\\\.([a-zA-Z_]\\\\w*)",
      "tokenModifiers": [],
      "description": "Property access"
    },
    {
      "tokenType": "string",
      "pattern": "\"([^\"\\\\\\\\]|\\\\\\\\.)*\"",
      "tokenModifiers": [],
      "description": "Double-quoted strings"
    },
    {
      "tokenType": "string",
      "pattern": "'([^'\\\\\\\\]|\\\\\\\\.)*'",
      "tokenModifiers": [],
      "description": "Single-quoted strings"
    },
    {
      "tokenType": "number",
      "pattern": "\\\\b\\\\d+(\\\\.\\\\d+)?([eE][+-]?\\\\d+)?\\\\b",
      "tokenModifiers": [],
      "description": "Numeric literals"
    },
    {
      "tokenType": "number",
      "pattern": "\\\\b0x[0-9a-fA-F]+\\\\b",
      "tokenModifiers": [],
      "description": "Hexadecimal literals"
    },
    {
      "tokenType": "comment",
      "pattern": "\\/\\/.*$",
      "tokenModifiers": [],
      "description": "Line comments"
    },
    {
      "tokenType": "comment",
      "pattern": "\\/\\\\*[\\\\s\\\\S]*?\\\\*\\/",
      "tokenModifiers": [],
      "description": "Block comments"
    },
    {
      "tokenType": "comment",
      "pattern": "\\/\\\\*\\\\*[\\\\s\\\\S]*?\\\\*\\/",
      "tokenModifiers": [
        "documentation"
      ],
      "description": "Documentation comments"
    },
    {
      "tokenType": "operator",
      "pattern": "[+\\\\-*/%=<>!&|^~?:]+",
      "tokenModifiers": [],
      "description": "Operators"
    },
    {
      "tokenType": "decorator",
      "pattern": "@\\\\w+",
      "tokenModifiers": [],
      "description": "Decorators/annotations"
    },
    {
      "tokenType": "namespace",
      "pattern": "\\\\b(namespace|package|module)\\\\s+[\\\\w.]+",
      "tokenModifiers": [],
      "description": "Namespace/module references"
    },
    {
      "tokenType": "enum",
      "pattern": "\\\\benum\\\\s+([A-Z]\\\\w*)",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Enum declarations"
    },
    {
      "tokenType": "enumMember",
      "pattern": "\\\\b[A-Z][A-Z0-9_]+\\\\b",
      "tokenModifiers": [],
      "description": "Enum member references"
    },
    {
      "tokenType": "interface",
      "pattern": "\\\\binterface\\\\s+(\\\\w+)",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Interface declarations"
    },
    {
      "tokenType": "method",
      "pattern": "\\\\.([a-zA-Z_]\\\\w*)\\\\s*\\\\(",
      "tokenModifiers": [],
      "description": "Method calls"
    },
    {
      "tokenType": "modifier",
      "pattern": "\\\\b(public|private|protected|static|final|const|abstract)\\\\b",
      "tokenModifiers": [],
      "description": "Access modifiers and qualifiers"
    },
    {
      "tokenType": "regexp",
      "pattern": "\\/[^\\/]+\\/[gimsuy]*",
      "tokenModifiers": [],
      "description": "Regular expression literals"
    },
    {
      "tokenType": "macro",
      "pattern": "#\\\\w+",
      "tokenModifiers": [],
      "description": "Macros and preprocessor directives"
    },
    {
      "tokenType": "struct",
      "pattern": "\\\\bstruct\\\\s+([A-Z]\\\\w*)",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Struct declarations"
    },
    {
      "tokenType": "typeParameter",
      "pattern": "<([A-Z]\\\\w*)>",
      "tokenModifiers": [],
      "description": "Generic type parameters"
    },
    {
      "tokenType": "event",
      "pattern": "\\\\b(on\\\\w+|handle\\\\w+|emit\\\\w+)\\\\b",
      "tokenModifiers": [],
      "description": "Event handlers and emitters"
    }
  ]
}
