{
  "language": "bicep",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["keyword", "variable", "parameter", "type", "function", "property", "namespace", "decorator", "string"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary", "documentation"]
  },
  "semanticRules": [
    {
      "type": "keyword",
      "pattern": "\\b(resource)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s+'([^']+)'",
      "modifiers": ["declaration"],
      "description": "Resource declarations with symbolic name and type"
    },
    {
      "type": "parameter",
      "pattern": "\\bparam\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Parameter declarations"
    },
    {
      "type": "variable",
      "pattern": "\\bvar\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Variable declarations"
    },
    {
      "type": "variable",
      "pattern": "\\boutput\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Output declarations"
    },
    {
      "type": "namespace",
      "pattern": "\\bmodule\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s+'([^']+)'",
      "modifiers": ["declaration"],
      "description": "Module references"
    },
    {
      "type": "function",
      "pattern": "\\b(resourceGroup|subscription|tenant|managementGroup|resourceId|reference|uniqueString|concat|format)\\s*\\(",
      "modifiers": ["defaultLibrary"],
      "description": "Scope and built-in functions"
    },
    {
      "type": "type",
      "pattern": "\\b(string|int|bool|object|array)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in Bicep types"
    },
    {
      "type": "decorator",
      "pattern": "@(description|secure|allowed|minLength|maxLength|minValue|maxValue|metadata|batchSize)",
      "modifiers": [],
      "description": "Bicep decorators"
    },
    {
      "type": "keyword",
      "pattern": "\\b(targetScope|existing|if|for|in)\\b",
      "modifiers": [],
      "description": "Bicep language keywords"
    },
    {
      "type": "property",
      "pattern": "\\.([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": [],
      "description": "Property access on resources and objects"
    }
  ]
}
