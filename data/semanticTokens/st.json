{
  "language": "st",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["class", "variable", "parameter", "property", "method", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "method",
      "pattern": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(:?\\s*[a-zA-Z_])?",
      "modifiers": ["declaration"],
      "description": "Method definitions with keyword-style selectors"
    },
    {
      "type": "parameter",
      "pattern": "\\[\\s*:([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\|",
      "modifiers": ["declaration"],
      "description": "Block closure parameters [:x |]"
    },
    {
      "type": "variable",
      "pattern": "\\|\\s*([a-zA-Z_][a-zA-Z0-9_ ]*)\\s*\\|",
      "modifiers": ["declaration"],
      "description": "Temporary variable declarations between pipes"
    },
    {
      "type": "class",
      "pattern": "\\b([A-Z][a-zA-Z0-9_]*)\\s+(subclass|class)\\b",
      "modifiers": ["declaration"],
      "description": "Class declarations and references"
    },
    {
      "type": "keyword",
      "pattern": "\\b(self|super|true|false|nil|thisContext)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Pseudo-variables and special objects"
    },
    {
      "type": "method",
      "pattern": "\\b(ifTrue|ifFalse|ifNil|ifNotNil|whileTrue|whileFalse|do|collect|select|reject|inject|detect|new|value|yourself)\\s*:",
      "modifiers": ["defaultLibrary"],
      "description": "Common message sends"
    },
    {
      "type": "operator",
      "pattern": "(:=|\\^)",
      "modifiers": [],
      "description": "Assignment (:=) and return (^) operators"
    },
    {
      "type": "string",
      "pattern": "'[^']*'",
      "modifiers": [],
      "description": "String literals in single quotes"
    },
    {
      "type": "comment",
      "pattern": "\"[^\"]*\"",
      "modifiers": [],
      "description": "Comments enclosed in double quotes"
    },
    {
      "type": "number",
      "pattern": "\\b[0-9]+(r[0-9A-Za-z]+)?\\b",
      "modifiers": [],
      "description": "Numeric literals with optional radix"
    }
  ]
}
