{
  "language": "cameligo",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["function", "variable", "type", "namespace", "parameter", "keyword", "operator", "enumMember"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "variable",
      "pattern": "\\blet\\s+([a-z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Let bindings for values and functions"
    },
    {
      "type": "type",
      "pattern": "\\btype\\s+([a-z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["definition"],
      "description": "Type definitions"
    },
    {
      "type": "keyword",
      "pattern": "\\b(match|with|begin|end)\\b",
      "modifiers": [],
      "description": "Match/with pattern matching expressions"
    },
    {
      "type": "namespace",
      "pattern": "\\bmodule\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Module declarations and references"
    },
    {
      "type": "function",
      "pattern": "\\blet\\s+(rec\\s+)?([a-z_][a-zA-Z0-9_]*)\\s*\\([^)]*\\)",
      "modifiers": ["declaration"],
      "description": "Recursive and non-recursive function declarations"
    },
    {
      "type": "type",
      "pattern": "\\b(int|nat|tez|string|bytes|address|key|key_hash|timestamp|bool|unit|operation|list|map|set|option)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in Tezos/CameLIGO types"
    },
    {
      "type": "keyword",
      "pattern": "\\b(if|then|else|let|in|rec|fun|of)\\b",
      "modifiers": [],
      "description": "Core language keywords"
    },
    {
      "type": "enumMember",
      "pattern": "\\|\\s*([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["definition"],
      "description": "Variant/union type constructors"
    },
    {
      "type": "function",
      "pattern": "\\b(Tezos|Map|List|Set|Bytes|Crypto|Current)\\.[a-z_][a-zA-Z0-9_]*",
      "modifiers": ["defaultLibrary"],
      "description": "Standard library module function calls"
    }
  ]
}
