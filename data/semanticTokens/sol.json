{
  "language": "sol",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "parameter", "variable", "property", "enumMember", "event", "function", "method", "keyword", "modifier", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "class",
      "pattern": "\\bcontract\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Contract declarations"
    },
    {
      "type": "interface",
      "pattern": "\\binterface\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Interface declarations"
    },
    {
      "type": "class",
      "pattern": "\\blibrary\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Library declarations"
    },
    {
      "type": "function",
      "pattern": "\\bfunction\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Function declarations"
    },
    {
      "type": "modifier",
      "pattern": "\\bmodifier\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Custom modifier declarations"
    },
    {
      "type": "event",
      "pattern": "\\bevent\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Event declarations"
    },
    {
      "type": "type",
      "pattern": "\\b(mapping|address|bool|string|bytes[0-9]*|uint[0-9]*|int[0-9]*)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Solidity built-in types including mapping and address"
    },
    {
      "type": "keyword",
      "pattern": "\\b(payable|view|pure|external|public|internal|private|virtual|override|immutable|constant|indexed|memory|storage|calldata)\\b",
      "modifiers": [],
      "description": "Solidity visibility, mutability, and data location keywords"
    },
    {
      "type": "struct",
      "pattern": "\\bstruct\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Struct declarations"
    },
    {
      "type": "enum",
      "pattern": "\\benum\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Enum declarations"
    },
    {
      "type": "keyword",
      "pattern": "\\b(pragma\\s+solidity|import|using|is|emit|revert|require|assert)\\b",
      "modifiers": [],
      "description": "Pragma, import, inheritance, and error handling keywords"
    }
  ]
}
