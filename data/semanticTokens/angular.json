{
  "language": "angular",
  "legend": {
    "tokenTypes": [
      "namespace",
      "type",
      "class",
      "enum",
      "interface",
      "struct",
      "typeParameter",
      "parameter",
      "variable",
      "property",
      "enumMember",
      "event",
      "function",
      "method",
      "keyword",
      "decorator"
    ],
    "tokenModifiers": [
      "declaration",
      "definition",
      "readonly",
      "static",
      "deprecated",
      "abstract",
      "async",
      "defaultLibrary"
    ]
  },
  "semanticRules": [
    {
      "tokenType": "decorator",
      "pattern": "@Component\\b",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Angular @Component decorator"
    },
    {
      "tokenType": "decorator",
      "pattern": "@Injectable\\b",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Angular @Injectable decorator"
    },
    {
      "tokenType": "decorator",
      "pattern": "@NgModule\\b",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Angular @NgModule decorator"
    },
    {
      "tokenType": "decorator",
      "pattern": "@Directive\\b",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Angular @Directive decorator"
    },
    {
      "tokenType": "decorator",
      "pattern": "@Pipe\\b",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Angular @Pipe decorator"
    },
    {
      "tokenType": "decorator",
      "pattern": "@Input\\b",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Angular @Input property decorator"
    },
    {
      "tokenType": "decorator",
      "pattern": "@Output\\b",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Angular @Output property decorator"
    },
    {
      "tokenType": "decorator",
      "pattern": "@ViewChild\\b|@ViewChildren\\b|@ContentChild\\b|@ContentChildren\\b",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Angular query decorators for view and content children"
    },
    {
      "tokenType": "decorator",
      "pattern": "@(HostBinding|HostListener)\\b",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Angular @HostBinding and @HostListener decorators"
    },
    {
      "tokenType": "method",
      "pattern": "\\b(ngOnInit|ngOnDestroy|ngOnChanges|ngAfterViewInit|ngAfterContentInit|ngDoCheck|ngAfterViewChecked|ngAfterContentChecked)\\b",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Angular lifecycle hook methods"
    },
    {
      "tokenType": "function",
      "pattern": "\\bsignal\\s*(<[^>]*>)?\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Angular signal() creation function"
    },
    {
      "tokenType": "function",
      "pattern": "\\bcomputed\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Angular computed() signal function"
    },
    {
      "tokenType": "function",
      "pattern": "\\beffect\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Angular effect() function for reactive side effects"
    },
    {
      "tokenType": "function",
      "pattern": "\\blinkedSignal\\s*(<[^>]*>)?\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Angular linkedSignal() for derived writable signals"
    },
    {
      "tokenType": "function",
      "pattern": "\\binput\\s*(<[^>]*>)?\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Angular input() signal-based input function"
    },
    {
      "tokenType": "function",
      "pattern": "\\binput\\.required\\s*(<[^>]*>)?\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Angular input.required() for required signal inputs"
    },
    {
      "tokenType": "function",
      "pattern": "\\boutput\\s*(<[^>]*>)?\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Angular output() signal-based output function"
    },
    {
      "tokenType": "function",
      "pattern": "\\bmodel\\s*(<[^>]*>)?\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Angular model() for two-way binding signal inputs"
    },
    {
      "tokenType": "function",
      "pattern": "\\bmodel\\.required\\s*(<[^>]*>)?\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Angular model.required() for required two-way binding signal inputs"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(viewChild|viewChildren|contentChild|contentChildren)\\s*(<[^>]*>)?\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Angular signal-based query functions (viewChild/viewChildren/contentChild/contentChildren)"
    },
    {
      "tokenType": "function",
      "pattern": "\\binject\\s*(<[^>]*>)?\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Angular inject() function for dependency injection"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(map|filter|switchMap|mergeMap|concatMap|exhaustMap|tap|catchError|takeUntil|debounceTime|distinctUntilChanged|combineLatest|forkJoin|of|from|pipe)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "RxJS operators and creation functions"
    },
    {
      "tokenType": "keyword",
      "pattern": "@(if|else|for|switch|case|default|defer|placeholder|loading|error|empty)\\b",
      "tokenModifiers": [],
      "description": "Angular built-in template control flow syntax keywords (@if/@for/@switch/@defer)"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(track|prefetch|when|on\\s+(?:idle|viewport|interaction|hover|immediate|timer))\\b",
      "tokenModifiers": [],
      "description": "Angular control flow and @defer trigger keywords"
    },
    {
      "tokenType": "property",
      "pattern": "\\bstandalone\\s*:\\s*true\\b",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Angular standalone component/directive/pipe declaration"
    },
    {
      "tokenType": "property",
      "pattern": "\\bhostDirectives\\s*:\\s*\\[",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Angular hostDirectives composition API"
    },
    {
      "tokenType": "variable",
      "pattern": "\\b(InjectionToken|inject|provide|useClass|useValue|useFactory|useExisting)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Angular dependency injection tokens and provider configuration"
    },
    {
      "tokenType": "interface",
      "pattern": "\\b(CanActivate|CanDeactivate|CanActivateChild|CanMatch|Resolve)\\b",
      "tokenModifiers": [],
      "description": "Angular route guard interfaces"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(loadComponent|loadChildren)\\s*:\\s*\\(\\)\\s*=>\\s*import\\s*\\(",
      "tokenModifiers": [
        "async"
      ],
      "description": "Angular route lazy loading with loadComponent/loadChildren"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(ViewTransitionService|onViewTransitionCreated|withViewTransitions)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Angular View Transitions API integration"
    },
    {
      "tokenType": "class",
      "pattern": "\\b\\w+Pipe\\b|\\b(DatePipe|CurrencyPipe|DecimalPipe|PercentPipe|JsonPipe|SlicePipe|AsyncPipe|UpperCasePipe|LowerCasePipe|TitleCasePipe|KeyValuePipe)\\b",
      "tokenModifiers": [],
      "description": "Angular pipe class names"
    },
    {
      "tokenType": "method",
      "pattern": "\\b(Validators\\.required|Validators\\.min|Validators\\.max|Validators\\.minLength|Validators\\.maxLength|Validators\\.pattern|Validators\\.email|Validators\\.compose)\\b",
      "tokenModifiers": [
        "static",
        "defaultLibrary"
      ],
      "description": "Angular form validators"
    },
    {
      "tokenType": "class",
      "pattern": "\\bclass\\s+([A-Z][a-zA-Z0-9]*(?:Component|Service|Directive|Module|Pipe|Guard|Interceptor|Resolver))\\b",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Angular class declarations with conventional suffixes"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(toSignal|toObservable)\\s*(<[^>]*>)?\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Angular interop functions between signals and RxJS (toSignal/toObservable)"
    },
    {
      "tokenType": "interface",
      "pattern": "\\binterface\\s+([A-Z][a-zA-Z0-9]*)\\b",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Interface declarations"
    },
    {
      "tokenType": "enum",
      "pattern": "\\benum\\s+([A-Z][a-zA-Z0-9]*)\\b",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Enum declarations"
    },
    {
      "tokenType": "variable",
      "pattern": "\\b([A-Z][A-Z0-9_]+)\\b",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Constant variables in UPPER_SNAKE_CASE"
    },
    {
      "tokenType": "typeParameter",
      "pattern": "<([A-Z]\\w*)>",
      "tokenModifiers": [],
      "description": "Generic type parameters in angle brackets"
    }
  ]
}
