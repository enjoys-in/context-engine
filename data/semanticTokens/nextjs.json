{
  "language": "nextjs",
  "tokenTypes": [
    "namespace",
    "type",
    "class",
    "enum",
    "interface",
    "struct",
    "typeParameter",
    "parameter",
    "variable",
    "property",
    "enumMember",
    "event",
    "function",
    "method",
    "macro",
    "keyword",
    "modifier",
    "comment",
    "string",
    "number",
    "regexp",
    "operator",
    "decorator"
  ],
  "tokenModifiers": [
    "declaration",
    "definition",
    "readonly",
    "static",
    "deprecated",
    "async",
    "modification",
    "documentation",
    "defaultLibrary",
    "abstract"
  ],
  "tokenLegend": {
    "tokenTypes": [
      "namespace",
      "type",
      "class",
      "enum",
      "interface",
      "struct",
      "typeParameter",
      "parameter",
      "variable",
      "property",
      "enumMember",
      "event",
      "function",
      "method",
      "macro",
      "keyword",
      "modifier",
      "comment",
      "string",
      "number",
      "regexp",
      "operator",
      "decorator"
    ],
    "tokenModifiers": [
      "declaration",
      "definition",
      "readonly",
      "static",
      "deprecated",
      "async",
      "modification",
      "documentation",
      "defaultLibrary",
      "abstract"
    ]
  },
  "semanticRules": [
    {
      "pattern": "\\b(import|export|from|default|as)\\b",
      "tokenType": "keyword",
      "tokenModifiers": [],
      "description": "Module keywords"
    },
    {
      "pattern": "\\b(function|return|const|let|var|if|else|for|while|do|switch|case|break|continue|throw|try|catch|finally|new|delete|typeof|instanceof|in|of|void|yield|await|async|class|extends|super|this|static|get|set)\\b",
      "tokenType": "keyword",
      "tokenModifiers": [],
      "description": "Language keywords"
    },
    {
      "pattern": "\\b(use(?:State|Effect|Context|Reducer|Callback|Memo|Ref|ImperativeHandle|LayoutEffect|DebugValue|DeferredValue|Transition|Id|SyncExternalStore|FormStatus|FormState|Optimistic|Router|Pathname|SearchParams|Params|SelectedLayoutSegment|SelectedLayoutSegments|ReportWebVitals))\\b",
      "tokenType": "function",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "React/Next.js hooks"
    },
    {
      "pattern": "\\b(Image|Link|Script|Head|NextScript|NextDocument|Main|Html)\\b",
      "tokenType": "class",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Next.js built-in components"
    },
    {
      "pattern": "\\b(NextRequest|NextResponse|NextMiddleware)\\b",
      "tokenType": "class",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Next.js server types"
    },
    {
      "pattern": "\\b(NextPage|NextApiRequest|NextApiResponse|GetServerSideProps|GetStaticProps|GetStaticPaths|Metadata|MetadataRoute|Viewport)\\b",
      "tokenType": "type",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Next.js type definitions"
    },
    {
      "pattern": "\\bexport\\s+default\\s+function\\s+(\\w+)",
      "tokenType": "function",
      "tokenModifiers": [
        "declaration",
        "definition"
      ],
      "description": "Default-exported component"
    },
    {
      "pattern": "\\bexport\\s+async\\s+function\\s+(GET|POST|PUT|PATCH|DELETE|HEAD|OPTIONS)\\b",
      "tokenType": "method",
      "tokenModifiers": [
        "declaration",
        "async"
      ],
      "description": "Route handler methods"
    },
    {
      "pattern": "\\bexport\\s+async\\s+function\\s+(generateStaticParams|generateMetadata)\\b",
      "tokenType": "function",
      "tokenModifiers": [
        "declaration",
        "async"
      ],
      "description": "Next.js generation functions"
    },
    {
      "pattern": "\\bexport\\s+const\\s+(metadata|revalidate|dynamic|runtime|fetchCache|preferredRegion)\\b",
      "tokenType": "variable",
      "tokenModifiers": [
        "declaration",
        "readonly"
      ],
      "description": "Route segment config exports"
    },
    {
      "pattern": "\"use (client|server)\"",
      "tokenType": "macro",
      "tokenModifiers": [],
      "description": "React directives"
    },
    {
      "pattern": "\\b(React\\.(?:FC|Component|PureComponent|Fragment|Suspense|StrictMode|Profiler|createElement|cloneElement|createContext|forwardRef|lazy|memo|startTransition))\\b",
      "tokenType": "function",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "React namespace APIs"
    },
    {
      "pattern": "\\binterface\\s+(\\w+)",
      "tokenType": "interface",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Interface declarations"
    },
    {
      "pattern": "\\btype\\s+(\\w+)\\s*=",
      "tokenType": "type",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Type alias declarations"
    },
    {
      "pattern": "\\benum\\s+(\\w+)",
      "tokenType": "enum",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Enum declarations"
    },
    {
      "pattern": "\\bclass\\s+(\\w+)",
      "tokenType": "class",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Class declarations"
    },
    {
      "pattern": "<([A-Z][a-zA-Z0-9.]*)",
      "tokenType": "class",
      "tokenModifiers": [],
      "description": "JSX component references"
    },
    {
      "pattern": "\\b(redirect|notFound|revalidatePath|revalidateTag|unstable_cache|unstable_noStore|headers|cookies|fetch)\\b",
      "tokenType": "function",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Next.js server functions"
    },
    {
      "pattern": "\\b(params|searchParams|children|className)\\b",
      "tokenType": "parameter",
      "tokenModifiers": [],
      "description": "Common Next.js props"
    },
    {
      "pattern": "@(\\w+)",
      "tokenType": "decorator",
      "tokenModifiers": [],
      "description": "Decorators"
    },
    {
      "pattern": "(?:^|\\s)(?:\\/\\/.*|\\/\\*[\\s\\S]*?\\*\\/)",
      "tokenType": "comment",
      "tokenModifiers": [],
      "description": "Comments"
    },
    {
      "pattern": "(?:'[^']*'|\"[^\"]*\"|`[^`]*`)",
      "tokenType": "string",
      "tokenModifiers": [],
      "description": "String literals"
    },
    {
      "pattern": "\\b\\d+(\\.\\d+)?\\b",
      "tokenType": "number",
      "tokenModifiers": [],
      "description": "Numeric literals"
    },
    {
      "pattern": "\\/(?!\\/|\\*)[^\\/\\n]+\\/[gimsuy]*",
      "tokenType": "regexp",
      "tokenModifiers": [],
      "description": "Regular expressions"
    },
    {
      "pattern": "\\b(process\\.env\\.\\w+|NEXT_PUBLIC_\\w+)\\b",
      "tokenType": "variable",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Environment variables"
    }
  ]
}
