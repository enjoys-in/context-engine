{
  "language": "nextjs",
  "legend": {
    "tokenTypes": [
      "namespace",
      "type",
      "class",
      "enum",
      "interface",
      "struct",
      "typeParameter",
      "parameter",
      "variable",
      "property",
      "enumMember",
      "event",
      "function",
      "method",
      "macro",
      "keyword",
      "modifier",
      "comment",
      "string",
      "number",
      "regexp",
      "operator",
      "decorator"
    ],
    "tokenModifiers": [
      "declaration",
      "definition",
      "readonly",
      "static",
      "deprecated",
      "async",
      "modification",
      "documentation",
      "defaultLibrary",
      "abstract"
    ]
  },
  "semanticRules": [
    {
      "tokenType": "keyword",
      "pattern": "\\b(import|export|from|default|as)\\b",
      "tokenModifiers": [],
      "description": "Module keywords"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(function|return|const|let|var|if|else|for|while|do|switch|case|break|continue|throw|try|catch|finally|new|delete|typeof|instanceof|in|of|void|yield|await|async|class|extends|super|this|static|get|set)\\b",
      "tokenModifiers": [],
      "description": "Language keywords"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(use(?:State|Effect|Context|Reducer|Callback|Memo|Ref|ImperativeHandle|LayoutEffect|DebugValue|DeferredValue|Transition|Id|SyncExternalStore|FormStatus|FormState|Optimistic|Router|Pathname|SearchParams|Params|SelectedLayoutSegment|SelectedLayoutSegments|ReportWebVitals))\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "React/Next.js hooks"
    },
    {
      "tokenType": "class",
      "pattern": "\\b(Image|Link|Script|Head|NextScript|NextDocument|Main|Html)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Next.js built-in components"
    },
    {
      "tokenType": "class",
      "pattern": "\\b(NextRequest|NextResponse|NextMiddleware)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Next.js server types"
    },
    {
      "tokenType": "type",
      "pattern": "\\b(NextPage|NextApiRequest|NextApiResponse|GetServerSideProps|GetStaticProps|GetStaticPaths|Metadata|MetadataRoute|Viewport)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Next.js type definitions"
    },
    {
      "tokenType": "function",
      "pattern": "\\bexport\\s+default\\s+function\\s+(\\w+)",
      "tokenModifiers": [
        "declaration",
        "definition"
      ],
      "description": "Default-exported component"
    },
    {
      "tokenType": "method",
      "pattern": "\\bexport\\s+async\\s+function\\s+(GET|POST|PUT|PATCH|DELETE|HEAD|OPTIONS)\\b",
      "tokenModifiers": [
        "declaration",
        "async"
      ],
      "description": "Route handler methods (app/api)"
    },
    {
      "tokenType": "function",
      "pattern": "\\bexport\\s+async\\s+function\\s+(generateStaticParams|generateMetadata|generateSitemaps|generateImageMetadata)\\b",
      "tokenModifiers": [
        "declaration",
        "async"
      ],
      "description": "Next.js generation functions"
    },
    {
      "tokenType": "variable",
      "pattern": "\\bexport\\s+const\\s+(metadata|revalidate|dynamic|runtime|fetchCache|preferredRegion|maxDuration|dynamicParams)\\b",
      "tokenModifiers": [
        "declaration",
        "readonly"
      ],
      "description": "Route segment config exports"
    },
    {
      "tokenType": "macro",
      "pattern": "\"use (client|server)\"",
      "tokenModifiers": [],
      "description": "React Server Component directives"
    },
    {
      "tokenType": "macro",
      "pattern": "'use (client|server)'",
      "tokenModifiers": [],
      "description": "React Server Component directives (single-quoted)"
    },
    {
      "tokenType": "function",
      "pattern": "\\bexport\\s+default\\s+function\\s+(Loading|Error|NotFound|Layout|Template|Default)\\b",
      "tokenModifiers": [
        "declaration",
        "definition"
      ],
      "description": "Next.js special boundary/layout file exports (loading.tsx, error.tsx, not-found.tsx)"
    },
    {
      "tokenType": "function",
      "pattern": "\\bexport\\s+function\\s+(middleware)\\b",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Next.js middleware function export"
    },
    {
      "tokenType": "variable",
      "pattern": "\\bexport\\s+const\\s+(config)\\s*=\\s*\\{\\s*matcher",
      "tokenModifiers": [
        "declaration",
        "readonly"
      ],
      "description": "Next.js middleware matcher config"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(React\\.(?:FC|Component|PureComponent|Fragment|Suspense|StrictMode|Profiler|createElement|cloneElement|createContext|forwardRef|lazy|memo|startTransition))\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "React namespace APIs"
    },
    {
      "tokenType": "interface",
      "pattern": "\\binterface\\s+(\\w+)",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Interface declarations"
    },
    {
      "tokenType": "type",
      "pattern": "\\btype\\s+(\\w+)\\s*=",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Type alias declarations"
    },
    {
      "tokenType": "enum",
      "pattern": "\\benum\\s+(\\w+)",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Enum declarations"
    },
    {
      "tokenType": "class",
      "pattern": "\\bclass\\s+(\\w+)",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Class declarations"
    },
    {
      "tokenType": "class",
      "pattern": "<([A-Z][a-zA-Z0-9.]*)",
      "tokenModifiers": [],
      "description": "JSX component references"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(redirect|permanentRedirect|notFound|revalidatePath|revalidateTag|unstable_cache|unstable_noStore|headers|cookies|fetch|draftMode)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Next.js server functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(dynamic)\\s*\\(\\s*\\(\\)\\s*=>\\s*import\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "next/dynamic lazy loading pattern"
    },
    {
      "tokenType": "namespace",
      "pattern": "@[a-zA-Z][a-zA-Z0-9]*(?=\\/)",
      "tokenModifiers": [],
      "description": "Parallel route slot folders (@folder convention)"
    },
    {
      "tokenType": "operator",
      "pattern": "\\(\\.\\.\\.?\\)|\\(\\.\\)",
      "tokenModifiers": [],
      "description": "Intercepting route conventions ((.), (..), (...))"
    },
    {
      "tokenType": "parameter",
      "pattern": "\\b(params|searchParams|children|className)\\b",
      "tokenModifiers": [],
      "description": "Common Next.js props"
    },
    {
      "tokenType": "decorator",
      "pattern": "@(\\w+)",
      "tokenModifiers": [],
      "description": "Decorators"
    },
    {
      "tokenType": "comment",
      "pattern": "(?:^|\\s)(?:\\/\\/.*|\\/\\*[\\s\\S]*?\\*\\/)",
      "tokenModifiers": [],
      "description": "Comments"
    },
    {
      "tokenType": "string",
      "pattern": "(?:'[^']*'|\"[^\"]*\"|`[^`]*`)",
      "tokenModifiers": [],
      "description": "String literals"
    },
    {
      "tokenType": "number",
      "pattern": "\\b\\d+(\\.\\d+)?\\b",
      "tokenModifiers": [],
      "description": "Numeric literals"
    },
    {
      "tokenType": "regexp",
      "pattern": "\\/(?!\\/|\\*)[^\\/\\n]+\\/[gimsuy]*",
      "tokenModifiers": [],
      "description": "Regular expressions"
    },
    {
      "tokenType": "variable",
      "pattern": "\\b(process\\.env\\.\\w+|NEXT_PUBLIC_\\w+)\\b",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Environment variables"
    }
  ]
}
