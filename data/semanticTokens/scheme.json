{
  "language": "scheme",
  "legend": {
    "tokenTypes": [
      "namespace",
      "variable",
      "parameter",
      "function",
      "macro",
      "keyword",
      "comment",
      "number",
      "operator"
    ],
    "tokenModifiers": [
      "declaration",
      "definition",
      "defaultLibrary",
      "documentation"
    ]
  },
  "semanticRules": [
    {
      "tokenType": "function",
      "pattern": "\\(define\\s+\\(([a-zA-Z!$%&*/:<=>?~_^][a-zA-Z0-9!$%&*/:<=>?~_^.+-]*)\\b",
      "tokenModifiers": ["definition"],
      "description": "Function definitions via (define (name args...) body)"
    },
    {
      "tokenType": "variable",
      "pattern": "\\(define\\s+([a-zA-Z!$%&*/:<=>?~_^][a-zA-Z0-9!$%&*/:<=>?~_^.+-]*)\\s",
      "tokenModifiers": ["definition"],
      "description": "Variable definitions via (define name value)"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\(\\s*(lambda|\\u03bb)\\b",
      "tokenModifiers": [],
      "description": "Lambda expression for anonymous procedures"
    },
    {
      "tokenType": "parameter",
      "pattern": "\\(lambda\\s+\\(([^)]+)\\)",
      "tokenModifiers": ["declaration"],
      "description": "Lambda formal parameter lists"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\(\\s*(let|let\\*|letrec|letrec\\*)\\b",
      "tokenModifiers": [],
      "description": "Local binding forms: let, let*, letrec, letrec*"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\(\\s*let\\s+([a-zA-Z_!$%&*/:<=>?~^][a-zA-Z0-9_!$%&*/:<=>?~^.+-]*)\\s*\\(",
      "tokenModifiers": [],
      "description": "Named let for tail-recursive loops"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\(\\s*(if|cond|case|when|unless|and|or|begin|do)\\b",
      "tokenModifiers": [],
      "description": "Conditional and sequencing special forms"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\(\\s*(set!|define-values|define-record-type)\\b",
      "tokenModifiers": [],
      "description": "Mutation, multiple-value define, and record type forms"
    },
    {
      "tokenType": "macro",
      "pattern": "\\(define-syntax\\s+([a-zA-Z!$%&*/:<=>?~_^][a-zA-Z0-9!$%&*/:<=>?~_^.+-]*)\\b",
      "tokenModifiers": ["definition"],
      "description": "Hygienic macro definitions (define-syntax)"
    },
    {
      "tokenType": "macro",
      "pattern": "\\(\\s*(syntax-rules)\\s+\\(",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Pattern-based macro transformer (syntax-rules)"
    },
    {
      "tokenType": "macro",
      "pattern": "\\(\\s*(syntax-case|with-syntax|syntax|quasisyntax|unsyntax|unsyntax-splicing)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Procedural macro system (syntax-case and helpers)"
    },
    {
      "tokenType": "macro",
      "pattern": "\\(\\s*(let-syntax|letrec-syntax)\\b",
      "tokenModifiers": [],
      "description": "Local syntax binding forms"
    },
    {
      "tokenType": "function",
      "pattern": "\\(\\s*(car|cdr|cons|list|append|reverse|length|assoc|assv|assq|member|memv|memq)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Core list operations: car, cdr, cons, list manipulation"
    },
    {
      "tokenType": "function",
      "pattern": "\\(\\s*(map|for-each|filter|fold-left|fold-right|reduce|apply|sort)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Higher-order list processing procedures"
    },
    {
      "tokenType": "function",
      "pattern": "\\(\\s*(null\\?|pair\\?|list\\?|symbol\\?|number\\?|string\\?|char\\?|boolean\\?|vector\\?|port\\?|procedure\\?|eof-object\\?|bytevector\\?)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Type predicate procedures (?-suffix conventions)"
    },
    {
      "tokenType": "function",
      "pattern": "\\(\\s*(eq\\?|eqv\\?|equal\\?|not)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Equality and boolean predicates"
    },
    {
      "tokenType": "function",
      "pattern": "\\(\\s*(\\+|-|\\*|/|=|<|>|<=|>=|zero\\?|positive\\?|negative\\?|even\\?|odd\\?|abs|max|min|gcd|lcm|modulo|remainder|quotient|expt|sqrt|floor|ceiling|truncate|round)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Arithmetic operations and numeric predicates"
    },
    {
      "tokenType": "function",
      "pattern": "\\(\\s*(string-append|string-length|string-ref|string-set!|substring|string->number|number->string|string->list|list->string|string-copy|string-upcase|string-downcase|string-contains|string->symbol|symbol->string)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "String manipulation and conversion procedures"
    },
    {
      "tokenType": "function",
      "pattern": "\\(\\s*(make-vector|vector|vector-ref|vector-set!|vector-length|vector->list|list->vector|vector-fill!|vector-copy|vector-map|vector-for-each|vector-append)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Vector operations for indexed collections"
    },
    {
      "tokenType": "function",
      "pattern": "\\(\\s*(call-with-current-continuation|call/cc)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "First-class continuation capture (call/cc)"
    },
    {
      "tokenType": "function",
      "pattern": "\\(\\s*(dynamic-wind)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Dynamic-wind for entry/exit thunks around continuation jumps"
    },
    {
      "tokenType": "function",
      "pattern": "\\(\\s*(values|call-with-values|receive)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Multiple return values (values, call-with-values, receive)"
    },
    {
      "tokenType": "function",
      "pattern": "\\(\\s*(make-parameter|parameterize)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Dynamic parameters (R7RS parameterize)"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\(\\s*(guard|raise|raise-continuable|with-exception-handler|error)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "R7RS exception system: guard, raise, with-exception-handler"
    },
    {
      "tokenType": "function",
      "pattern": "\\(\\s*(open-input-file|open-output-file|open-input-string|open-output-string|close-port|close-input-port|close-output-port|call-with-port|call-with-input-file|call-with-output-file|with-input-from-file|with-output-to-file)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Port and file I/O operations"
    },
    {
      "tokenType": "function",
      "pattern": "\\(\\s*(read|read-char|read-line|read-string|read-u8|peek-char|peek-u8|char-ready\\?|u8-ready\\?|write|write-char|write-string|write-u8|display|newline|current-input-port|current-output-port|current-error-port)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "I/O read/write procedures for characters, strings, and bytes"
    },
    {
      "tokenType": "function",
      "pattern": "\\(\\s*(bytevector|make-bytevector|bytevector-length|bytevector-u8-ref|bytevector-u8-set!|bytevector-copy|bytevector-copy!|bytevector-append|utf8->string|string->utf8)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Bytevector operations for binary data (R7RS)"
    },
    {
      "tokenType": "function",
      "pattern": "\\(\\s*(eval|interaction-environment|scheme-report-environment)\\b",
      "tokenModifiers": ["defaultLibrary"],
      "description": "Evaluation and environment procedures"
    },
    {
      "tokenType": "namespace",
      "pattern": "\\(\\s*(import|define-library|export|include|include-ci|include-library-declarations|cond-expand)\\b",
      "tokenModifiers": [],
      "description": "R7RS library/module system forms"
    },
    {
      "tokenType": "operator",
      "pattern": "'(?=[a-zA-Z(])",
      "tokenModifiers": [],
      "description": "Quote shorthand ('expr)"
    },
    {
      "tokenType": "operator",
      "pattern": "`(?=[a-zA-Z(])",
      "tokenModifiers": [],
      "description": "Quasiquote shorthand (`expr)"
    },
    {
      "tokenType": "operator",
      "pattern": ",@",
      "tokenModifiers": [],
      "description": "Unquote-splicing (,@expr) inside quasiquote"
    },
    {
      "tokenType": "operator",
      "pattern": ",(?=[a-zA-Z(])",
      "tokenModifiers": [],
      "description": "Unquote (,expr) inside quasiquote"
    },
    {
      "tokenType": "number",
      "pattern": "#[bodxei][0-9a-fA-F+\\-./]+",
      "tokenModifiers": [],
      "description": "Numeric literals with radix prefixes (#b, #o, #d, #x, #e, #i)"
    },
    {
      "tokenType": "comment",
      "pattern": ";[^\\n]*",
      "tokenModifiers": [],
      "description": "Line comments starting with semicolon"
    },
    {
      "tokenType": "comment",
      "pattern": "#;\\s*\\S+",
      "tokenModifiers": [],
      "description": "Datum comment (#;) — comments out next datum"
    },
    {
      "tokenType": "comment",
      "pattern": "#\\|[\\s\\S]*?\\|#",
      "tokenModifiers": ["documentation"],
      "description": "Block comment (#| ... |#) for multi-line documentation"
    }
  ]
}
