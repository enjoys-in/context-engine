{
  "language": "scheme",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "parameter", "function", "macro", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "function",
      "pattern": "\\(define\\s+\\(([a-zA-Z!$%&*/:<=>?~_^][a-zA-Z0-9!$%&*/:<=>?~_^.+-]*)\\b",
      "modifiers": ["declaration"],
      "description": "Function definitions with define"
    },
    {
      "type": "variable",
      "pattern": "\\(define\\s+([a-zA-Z!$%&*/:<=>?~_^][a-zA-Z0-9!$%&*/:<=>?~_^.+-]*)\\s",
      "modifiers": ["declaration"],
      "description": "Variable definitions with define"
    },
    {
      "type": "keyword",
      "pattern": "\\(\\s*(lambda|let|let\\*|letrec|letrec\\*|if|cond|case|when|unless|begin|do|and|or|set!|define-syntax|syntax-rules|define-record-type)\\b",
      "modifiers": [],
      "description": "Special forms and syntax keywords"
    },
    {
      "type": "macro",
      "pattern": "\\(define-syntax\\s+([a-zA-Z!$%&*/:<=>?~_^][a-zA-Z0-9!$%&*/:<=>?~_^.+-]*)\\b",
      "modifiers": ["declaration"],
      "description": "Syntax/macro definitions"
    },
    {
      "type": "function",
      "pattern": "\\(\\s*(call-with-current-continuation|call/cc|dynamic-wind|values|call-with-values)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Continuation and control flow primitives"
    },
    {
      "type": "function",
      "pattern": "\\(\\s*(car|cdr|cons|list|append|map|filter|fold|for-each|apply|eval|display|newline|read|write)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Standard library list and I/O procedures"
    },
    {
      "type": "parameter",
      "pattern": "\\(lambda\\s+\\(([^)]+)\\)",
      "modifiers": ["declaration"],
      "description": "Lambda parameter lists"
    },
    {
      "type": "comment",
      "pattern": ";[^\\n]*",
      "modifiers": [],
      "description": "Line comments starting with semicolon"
    },
    {
      "type": "number",
      "pattern": "#[bodxei][0-9a-fA-F+\\-./]+",
      "modifiers": [],
      "description": "Numeric literals with radix prefixes"
    }
  ]
}
