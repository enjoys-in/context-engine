{
  "language": "dockerfile",
  "legend": {
    "tokenTypes": [
      "keyword",
      "variable",
      "string",
      "function",
      "property",
      "namespace",
      "number",
      "comment",
      "operator"
    ],
    "tokenModifiers": [
      "declaration",
      "definition",
      "readonly",
      "defaultLibrary",
      "documentation"
    ]
  },
  "semanticRules": [
    {
      "tokenType": "keyword",
      "pattern": "^(FROM|RUN|COPY|CMD|ENTRYPOINT|ADD|EXPOSE|VOLUME|WORKDIR|USER|LABEL|STOPSIGNAL|HEALTHCHECK|SHELL|ONBUILD|ARG|ENV|MAINTAINER)\\b",
      "tokenModifiers": [],
      "description": "Dockerfile instruction keywords"
    },
    {
      "tokenType": "namespace",
      "pattern": "^FROM\\s+(?:--platform=\\S+\\s+)?([a-z][a-z0-9_./-]*(?::[a-zA-Z0-9_.-]+)?(?:@sha256:[a-f0-9]+)?)\\s+AS\\s+([a-zA-Z_][a-zA-Z0-9_-]*)",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Multi-stage FROM with image reference and AS stage alias"
    },
    {
      "tokenType": "string",
      "pattern": "(?:COPY|ADD)\\s+--from=([a-zA-Z_][a-zA-Z0-9_-]*|\\d+)",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Cross-stage COPY/ADD --from=stage reference"
    },
    {
      "tokenType": "property",
      "pattern": "--mount=type=(cache|bind|secret|ssh|tmpfs)(?:,([a-z]+=[^\\s,]+))*",
      "tokenModifiers": [],
      "description": "RUN --mount options for cache, bind, secret, ssh, and tmpfs mounts"
    },
    {
      "tokenType": "variable",
      "pattern": "^ARG\\s+([a-zA-Z_][a-zA-Z0-9_]*)(?:=(.*))?$",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "ARG build argument declarations with optional default value"
    },
    {
      "tokenType": "variable",
      "pattern": "^ENV\\s+([a-zA-Z_][a-zA-Z0-9_]*)(?:[=\\s])",
      "tokenModifiers": [
        "definition"
      ],
      "description": "ENV environment variable definitions"
    },
    {
      "tokenType": "variable",
      "pattern": "\\$\\{([a-zA-Z_][a-zA-Z0-9_]*)(?::[-+]([^}]*))?\\}",
      "tokenModifiers": [],
      "description": "Variable substitution with default/alternate: ${VAR:-default}, ${VAR:+alt}"
    },
    {
      "tokenType": "keyword",
      "pattern": "^HEALTHCHECK\\s+(?:--interval=\\S+\\s+)?(?:--timeout=\\S+\\s+)?(?:--start-period=\\S+\\s+)?(?:--start-interval=\\S+\\s+)?(?:--retries=\\d+\\s+)?(CMD|NONE)",
      "tokenModifiers": [],
      "description": "HEALTHCHECK instruction with --interval, --timeout, --start-period, --retries options"
    },
    {
      "tokenType": "function",
      "pattern": "^CMD\\s+\\[\\s*\"([^\"]+)\"(?:\\s*,\\s*\"[^\"]*\")*\\s*\\]",
      "tokenModifiers": [],
      "description": "CMD exec form [\"executable\", \"param1\", ...]"
    },
    {
      "tokenType": "function",
      "pattern": "^ENTRYPOINT\\s+\\[\\s*\"([^\"]+)\"(?:\\s*,\\s*\"[^\"]*\")*\\s*\\]",
      "tokenModifiers": [],
      "description": "ENTRYPOINT exec form [\"executable\", \"param1\", ...]"
    },
    {
      "tokenType": "keyword",
      "pattern": "^(?:CMD|RUN|ENTRYPOINT)\\s+(?!\\[)(.+)$",
      "tokenModifiers": [],
      "description": "Shell form instructions (CMD, RUN, ENTRYPOINT without JSON array)"
    },
    {
      "tokenType": "number",
      "pattern": "^EXPOSE\\s+(\\d+(?:/(?:tcp|udp))?)(?:\\s+\\d+(?:/(?:tcp|udp))?)*",
      "tokenModifiers": [],
      "description": "EXPOSE port/protocol declarations (e.g., 8080/tcp 443/udp)"
    },
    {
      "tokenType": "property",
      "pattern": "^LABEL\\s+((?:[a-zA-Z_][a-zA-Z0-9_.-]*=(?:\"[^\"]*\"|\\S+)\\s*)+)",
      "tokenModifiers": [
        "definition"
      ],
      "description": "LABEL metadata key=value pairs"
    },
    {
      "tokenType": "keyword",
      "pattern": "^STOPSIGNAL\\s+(SIG[A-Z]+|\\d+)",
      "tokenModifiers": [],
      "description": "STOPSIGNAL signal name or number (e.g., SIGTERM, 9)"
    },
    {
      "tokenType": "string",
      "pattern": "<<(-?)([a-zA-Z_][a-zA-Z0-9_]*)$",
      "tokenModifiers": [],
      "description": "Heredoc syntax (RUN <<EOF ... EOF)"
    },
    {
      "tokenType": "property",
      "pattern": "--(chown|chmod|link|from|platform|mount|network|security|start-period|start-interval|interval|timeout|retries)(?:=|\\s)",
      "tokenModifiers": [],
      "description": "Instruction flag parameters for COPY, ADD, RUN, HEALTHCHECK"
    },
    {
      "tokenType": "function",
      "pattern": "^RUN\\s+(apt-get|apk|yum|dnf|pip|pip3|npm|yarn|curl|wget|chmod|chown|mkdir|ln|groupadd|useradd|install)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Common commands used in RUN instructions"
    },
    {
      "tokenType": "comment",
      "pattern": "^\\s*#.*$",
      "tokenModifiers": [
        "documentation"
      ],
      "description": "Comment lines and parser directives (# syntax=, # escape=)"
    },
    {
      "tokenType": "comment",
      "pattern": "^#\\s*syntax\\s*=\\s*\\S+",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Parser directive for BuildKit syntax (# syntax=docker/dockerfile:1)"
    },
    {
      "tokenType": "comment",
      "pattern": "^#\\s*escape\\s*=\\s*.",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Parser directive for escape character (# escape=backquote)"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\bAS\\b",
      "tokenModifiers": [],
      "description": "AS keyword in FROM instruction for stage naming"
    },
    {
      "tokenType": "property",
      "pattern": "--platform=(linux/amd64|linux/arm64|linux/arm/v7|linux/386|\\$[A-Z_]+|\\$\\{[A-Z_]+\\})",
      "tokenModifiers": [],
      "description": "Platform flag values in FROM (linux/amd64, linux/arm64, etc.)"
    },
    {
      "tokenType": "namespace",
      "pattern": "^FROM\\s+(?:--platform=\\S+\\s+)?([a-z][a-z0-9_./-]*(?::[a-zA-Z0-9_.-]+)?(?:@sha256:[a-f0-9]+)?)\\s*$",
      "tokenModifiers": [],
      "description": "FROM with image reference without stage alias"
    },
    {
      "tokenType": "variable",
      "pattern": "\\$([a-zA-Z_][a-zA-Z0-9_]*)",
      "tokenModifiers": [],
      "description": "Simple variable reference $VAR without braces"
    },
    {
      "tokenType": "operator",
      "pattern": "\\\\\\s*$",
      "tokenModifiers": [],
      "description": "Line continuation backslash at end of line"
    },
    {
      "tokenType": "string",
      "pattern": "^VOLUME\\s+(\\[\\s*\"[^\"]*\"(?:\\s*,\\s*\"[^\"]*\")*\\s*\\]|/\\S+(?:\\s+/\\S+)*)",
      "tokenModifiers": [],
      "description": "VOLUME declarations in exec form or shell form"
    },
    {
      "tokenType": "function",
      "pattern": "^SHELL\\s+\\[\\s*\"([^\"]+)\"(?:\\s*,\\s*\"[^\"]*\")*\\s*\\]",
      "tokenModifiers": [],
      "description": "SHELL instruction to change default shell [\"executable\", \"params\"]"
    },
    {
      "tokenType": "variable",
      "pattern": "\\\\bthis\\\\b|\\\\bself\\\\b",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Self/this keyword semantic token"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\\\b(async|await|yield)\\\\b",
      "tokenModifiers": [
        "async"
      ],
      "description": "Async/concurrent keywords"
    },
    {
      "tokenType": "type",
      "pattern": "\\\\b(Promise|Future|Task|Observable)\\\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Concurrent/async types"
    },
    {
      "tokenType": "function",
      "pattern": "\\\\b(get|set)\\\\s+\\\\w+\\\\s*\\\\(",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Getter/setter declarations"
    },
    {
      "tokenType": "variable",
      "pattern": "\\\\b_\\\\w+\\\\b",
      "tokenModifiers": [],
      "description": "Private/underscore-prefixed identifiers"
    },
    {
      "tokenType": "type",
      "pattern": "\\\\b(Array|List|Map|Set|Dict|Vector|HashMap|TreeMap)\\\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Collection types"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\\\b(abstract|virtual|override|final|sealed)\\\\b",
      "tokenModifiers": [],
      "description": "OOP modifier keywords"
    },
    {
      "tokenType": "property",
      "pattern": "\\\\b(length|size|count|isEmpty|isNotEmpty)\\\\b",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Common read-only properties"
    },
    {
      "tokenType": "function",
      "pattern": "\\\\b(map|filter|reduce|forEach|find|some|every)\\\\b",
      "tokenModifiers": [],
      "description": "Iteration/functional methods"
    },
    {
      "tokenType": "modifier",
      "pattern": "\\\\b(override|static|readonly|const|final|volatile)\\\\b",
      "tokenModifiers": [],
      "description": "Member modifiers"
    },
    {
      "tokenType": "namespace",
      "pattern": "\\\\b(std|System|java|kotlin|swift|Foundation)\\\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Standard library namespaces"
    },
    {
      "tokenType": "decorator",
      "pattern": "@[A-Z]\\\\w+",
      "tokenModifiers": [],
      "description": "Class/method annotations (PascalCase)"
    },
    {
      "tokenType": "typeParameter",
      "pattern": "<[A-Z](\\\\w*)>",
      "tokenModifiers": [],
      "description": "Single-letter and named type parameters"
    },
    {
      "tokenType": "event",
      "pattern": "\\\\b(onClick|onChange|onSubmit|onLoad|onError)\\\\b",
      "tokenModifiers": [],
      "description": "Common event handler names"
    },
    {
      "tokenType": "enumMember",
      "pattern": "\\\\b[A-Z][a-z]+[A-Z]\\\\w*\\\\b",
      "tokenModifiers": [],
      "description": "CamelCase identifiers (often enum values)"
    }
  ]
}
