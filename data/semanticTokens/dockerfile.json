{
  "language": "dockerfile",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["keyword", "variable", "string", "function", "property", "namespace"],
    "tokenModifiers": ["declaration", "definition", "readonly"]
  },
  "semanticRules": [
    {
      "type": "keyword",
      "pattern": "^(FROM|RUN|COPY|CMD|ENTRYPOINT|ADD|EXPOSE|VOLUME|WORKDIR|USER|LABEL|STOPSIGNAL|HEALTHCHECK|SHELL|ONBUILD)\\b",
      "modifiers": [],
      "description": "Dockerfile instruction keywords"
    },
    {
      "type": "variable",
      "pattern": "\\bARG\\s+([a-zA-Z_][a-zA-Z0-9_]*)(?:=.*)?$",
      "modifiers": ["declaration"],
      "description": "ARG build argument declarations"
    },
    {
      "type": "variable",
      "pattern": "\\bENV\\s+([a-zA-Z_][a-zA-Z0-9_]*)(?:[=\\s])",
      "modifiers": ["definition"],
      "description": "ENV environment variable definitions"
    },
    {
      "type": "variable",
      "pattern": "\\$\\{?([a-zA-Z_][a-zA-Z0-9_]*)\\}?",
      "modifiers": [],
      "description": "Variable references ($VAR, ${VAR})"
    },
    {
      "type": "namespace",
      "pattern": "\\bFROM\\s+([a-z][a-z0-9_./-]*(?::[a-zA-Z0-9_.-]+)?)\\s+(?:AS\\s+([a-z][a-z0-9_-]*))?",
      "modifiers": ["declaration"],
      "description": "FROM base image with optional multi-stage alias"
    },
    {
      "type": "string",
      "pattern": "--from=([a-z][a-z0-9_-]*)",
      "modifiers": ["readonly"],
      "description": "Multi-stage build references (COPY --from=stage)"
    },
    {
      "type": "property",
      "pattern": "--(chown|chmod|link|from|platform|mount|network|security)=",
      "modifiers": [],
      "description": "Instruction flag parameters"
    },
    {
      "type": "keyword",
      "pattern": "\\b(AS)\\b",
      "modifiers": [],
      "description": "Multi-stage build AS keyword"
    },
    {
      "type": "function",
      "pattern": "\\bRUN\\s+(apt-get|apk|yum|pip|npm|curl|wget|chmod|chown|mkdir|ln)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Common commands used in RUN instructions"
    }
  ]
}
