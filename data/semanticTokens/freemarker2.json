{
  "language": "freemarker2",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "property", "function", "macro", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "keyword",
      "pattern": "<#(if|elseif|else|list|items|sep|include|import|assign|local|global|function|macro|return|break|continue|switch|case|default|attempt|recover|visit|recurse|fallback|flush|stop|ftl|setting|nested|compress|escape|noescape|noparse|nt|t|lt|rt)\\b",
      "modifiers": [],
      "description": "FreeMarker directives like <#if>, <#list>, <#macro>"
    },
    {
      "type": "function",
      "pattern": "\\?[a-z_]+",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in functions like ?string, ?size, ?has_content"
    },
    {
      "type": "variable",
      "pattern": "\\$\\{[^}]+\\}",
      "modifiers": [],
      "description": "Variable interpolation expressions ${...}"
    },
    {
      "type": "macro",
      "pattern": "(?<=<#macro\\s+)[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Macro name declarations"
    },
    {
      "type": "macro",
      "pattern": "<@[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": [],
      "description": "User-defined directive (macro) invocations"
    },
    {
      "type": "property",
      "pattern": "(?<=\\.)[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": [],
      "description": "Property access on objects via dot notation"
    },
    {
      "type": "keyword",
      "pattern": "\\b(as|using|in|true|false)\\b",
      "modifiers": [],
      "description": "FreeMarker expression keywords"
    },
    {
      "type": "comment",
      "pattern": "<#--[\\s\\S]*?-->",
      "modifiers": ["documentation"],
      "description": "FreeMarker comments <#-- ... -->"
    },
    {
      "type": "string",
      "pattern": "\"(?:[^\"\\\\]|\\\\.)*\"|'(?:[^'\\\\]|\\\\.)*'",
      "modifiers": [],
      "description": "String literals in single or double quotes"
    },
    {
      "type": "operator",
      "pattern": "(\\?\\?|!|\\+|==|!=|<|>|<=|>=|&&|\\|\\||\\.\\.)",
      "modifiers": [],
      "description": "FreeMarker operators including null-safe ?? and range .."
    }
  ]
}
