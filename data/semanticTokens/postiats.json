{
  "language": "postiats",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "enum", "typeParameter", "variable", "function", "keyword", "modifier", "comment", "string", "number", "operator", "macro"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "function",
      "pattern": "\\b(fun|fn|implement|prfun|prfn|praxi|castfn)\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Function definitions including proof functions and cast functions"
    },
    {
      "type": "type",
      "pattern": "\\b(typedef|abstype|abst@ype|absvtype|absvt@ype|sortdef|stacst)\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Type and sort declarations including abstract types"
    },
    {
      "type": "keyword",
      "pattern": "\\b(datatype|datavtype|dataview|datasort|dataprop)\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Datatype and dataview declarations"
    },
    {
      "type": "variable",
      "pattern": "\\b(val|var|val\\+|val-|prval)\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Value and variable bindings including proof values"
    },
    {
      "type": "keyword",
      "pattern": "\\b(let|in|end|local|where|if|then|else|sif|sthen|selse|case|case\\+|case-|of|when|while|for|begin|lam|llam|fix|staload|dynload|overload|with|extern|macdef|symintr)\\b",
      "modifiers": [],
      "description": "ATS/Postiats structural and control flow keywords"
    },
    {
      "type": "type",
      "pattern": "\\b(int|bool|char|double|float|string|void|ptr|size_t|ssize_t|nat|Nat|Int|Bool|Char|String|List|Option|stream)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in types and sorts"
    },
    {
      "type": "macro",
      "pattern": "#(define|include|if|ifdef|ifndef|else|endif|then|print|error|assert)\\b",
      "modifiers": [],
      "description": "Preprocessor directives"
    },
    {
      "type": "modifier",
      "pattern": "\\b(assume|reassume|stadef|propdef|viewdef|vtypedef)\\b",
      "modifiers": [],
      "description": "Type assumption and definition modifiers"
    },
    {
      "type": "comment",
      "pattern": "//[^\\n]*|/\\*[\\s\\S]*?\\*/|\\(\\*[\\s\\S]*?\\*\\)",
      "modifiers": [],
      "description": "Line comments, C-style block comments, and ML-style comments"
    },
    {
      "type": "string",
      "pattern": "\"([^\"\\\\]|\\\\.)*\"",
      "modifiers": [],
      "description": "String literals in double quotes"
    },
    {
      "type": "number",
      "pattern": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b|\\b0x[0-9a-fA-F]+\\b",
      "modifiers": [],
      "description": "Integer, floating-point, and hexadecimal literals"
    }
  ]
}
