{
  "language": "twig",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "property", "function", "macro", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "keyword",
      "pattern": "\\{%[-~]?\\s*(block|endblock|extends|include|embed|endembed|use|import|from|set|endset|if|elseif|else|endif|for|endfor|macro|endmacro|apply|endapply|autoescape|endautoescape|deprecated|do|flush|sandbox|endsandbox|verbatim|endverbatim|with|endwith)\\b",
      "modifiers": [],
      "description": "Twig tag keywords"
    },
    {
      "type": "variable",
      "pattern": "\\{\\{\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": [],
      "description": "Variable output expressions {{ variable }}"
    },
    {
      "type": "function",
      "pattern": "\\|\\s*(escape|e|raw|upper|lower|title|capitalize|trim|striptags|nl2br|number_format|round|abs|length|count|first|last|join|split|sort|reverse|merge|slice|batch|column|keys|filter|map|reduce|default|date|date_modify|format|replace|url_encode|json_encode)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in Twig filter functions"
    },
    {
      "type": "macro",
      "pattern": "\\{%[-~]?\\s*macro\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Macro definitions"
    },
    {
      "type": "keyword",
      "pattern": "\\{%[-~]?\\s*block\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Block definitions"
    },
    {
      "type": "comment",
      "pattern": "\\{#[\\s\\S]*?#\\}",
      "modifiers": [],
      "description": "Twig comments {# ... #}"
    },
    {
      "type": "function",
      "pattern": "\\b(range|cycle|constant|include|source|template_from_string|random|min|max|dump|block|parent|attribute)\\s*\\(",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in Twig functions"
    },
    {
      "type": "operator",
      "pattern": "\\b(is|is not|in|not in|and|or|not|b-and|b-xor|b-or|matches|starts with|ends with|has some|has every)\\b",
      "modifiers": [],
      "description": "Twig test and logical operators"
    },
    {
      "type": "property",
      "pattern": "\\.([a-zA-Z_][a-zA-Z0-9_]*)",
      "modifiers": [],
      "description": "Property access via dot notation"
    }
  ]
}
