{
  "language": "redis-cli",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["keyword", "variable", "string", "number", "comment", "operator"],
    "tokenModifiers": ["defaultLibrary", "readonly"]
  },
  "semanticRules": [
    {
      "type": "keyword",
      "pattern": "\\b(GET|SET|DEL|EXISTS|EXPIRE|TTL|KEYS|SCAN|TYPE|RENAME|MGET|MSET|APPEND|INCR|DECR|INCRBY|DECRBY|INCRBYFLOAT|SETNX|SETEX|PSETEX|GETSET|GETDEL|GETEX|STRLEN)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Redis string and key commands"
    },
    {
      "type": "keyword",
      "pattern": "\\b(HGET|HSET|HDEL|HMGET|HMSET|HGETALL|LPUSH|RPUSH|LPOP|RPOP|LRANGE|SADD|SREM|SMEMBERS|ZADD|ZREM|ZRANGE|ZSCORE)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Redis data structure commands (hash, list, set, sorted set)"
    },
    {
      "type": "keyword",
      "pattern": "\\b(AUTH|SELECT|PING|ECHO|QUIT|INFO|CONFIG|DBSIZE|FLUSHDB|FLUSHALL|SAVE|BGSAVE|BGREWRITEAOF|LASTSAVE|SHUTDOWN|MONITOR|DEBUG|SLOWLOG|CLIENT|CLUSTER|COMMAND|MEMORY|MODULE|SWAPDB|WAIT|RESET)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Server administration and connection commands"
    },
    {
      "type": "keyword",
      "pattern": "\\b(MULTI|EXEC|DISCARD|WATCH|UNWATCH)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Transaction commands"
    },
    {
      "type": "variable",
      "pattern": "[\\w:*?\\[\\]-]+",
      "modifiers": [],
      "description": "Redis key patterns and key names"
    },
    {
      "type": "string",
      "pattern": "\"([^\"\\\\]|\\\\.)*\"|'([^'\\\\]|\\\\.)*'",
      "modifiers": [],
      "description": "Quoted string values"
    },
    {
      "type": "number",
      "pattern": "\\b-?\\d+(\\.\\d+)?\\b",
      "modifiers": [],
      "description": "Numeric values for scores, indices, and timeouts"
    },
    {
      "type": "comment",
      "pattern": "#[^\\n]*",
      "modifiers": [],
      "description": "Comments in redis-cli scripts"
    }
  ]
}
