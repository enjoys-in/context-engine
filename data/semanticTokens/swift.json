{
  "language": "swift",
  "legend": {
    "tokenTypes": [
      "namespace",
      "type",
      "class",
      "enum",
      "struct",
      "typeParameter",
      "parameter",
      "variable",
      "property",
      "enumMember",
      "function",
      "method",
      "macro",
      "keyword",
      "modifier",
      "comment",
      "string",
      "number",
      "operator",
      "decorator"
    ],
    "tokenModifiers": [
      "declaration",
      "definition",
      "readonly",
      "static",
      "deprecated",
      "async",
      "documentation",
      "defaultLibrary"
    ]
  },
  "semanticRules": [
    {
      "tokenType": "function",
      "pattern": "\\bfunc\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Function declarations with func keyword"
    },
    {
      "tokenType": "class",
      "pattern": "\\bclass\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Class declarations"
    },
    {
      "tokenType": "struct",
      "pattern": "\\bstruct\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Struct declarations"
    },
    {
      "tokenType": "type",
      "pattern": "\\bprotocol\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Protocol declarations"
    },
    {
      "tokenType": "enum",
      "pattern": "\\benum\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Enum declarations"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(guard|if\\s+let|while\\s+let|as\\?|as!|try\\?|try!|throws|rethrows|async|await|actor|some|any|where|extension|subscript|typealias|associatedtype|inout|defer|willSet|didSet)\\b",
      "tokenModifiers": [],
      "description": "Swift-specific keywords including optionals and concurrency"
    },
    {
      "tokenType": "decorator",
      "pattern": "@([a-zA-Z_][a-zA-Z0-9_]*)",
      "tokenModifiers": [],
      "description": "Attribute annotations like @available, @objc, @MainActor"
    },
    {
      "tokenType": "typeParameter",
      "pattern": "<([A-Z][a-zA-Z0-9_]*(?:\\s*:\\s*[A-Z][a-zA-Z0-9_]*)?)>",
      "tokenModifiers": [],
      "description": "Generic type parameters with optional constraints"
    },
    {
      "tokenType": "variable",
      "pattern": "\\b(let|var)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Variable and constant declarations"
    },
    {
      "tokenType": "type",
      "pattern": "\\b(Int|Int8|Int16|Int32|Int64|UInt|Float|Double|Bool|String|Character|Array|Dictionary|Set|Optional|Result|Any|AnyObject|Void|Never)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Standard library types"
    },
    {
      "tokenType": "class",
      "pattern": "\\bactor\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Actor declarations for Swift concurrency"
    },
    {
      "tokenType": "type",
      "pattern": ":\\s*([A-Z][a-zA-Z0-9_]*)(?=\\s*[,{])",
      "tokenModifiers": [],
      "description": "Protocol conformance in type declarations"
    },
    {
      "tokenType": "operator",
      "pattern": "\\?\\.|\\?\\.\\[|\\?\\(",
      "tokenModifiers": [],
      "description": "Optional chaining operators on properties, subscripts, and calls"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(if|guard)\\s+let\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "tokenModifiers": [],
      "description": "Optional binding with if let and guard let"
    },
    {
      "tokenType": "function",
      "pattern": "\\{\\s*(?:\\[(?:weak|unowned)\\s+self\\]\\s*)?(?:\\([^)]*\\)\\s*(?:->\\s*[A-Za-z_][A-Za-z0-9_?]*\\s*)?)?\\bin\\b",
      "tokenModifiers": [],
      "description": "Closure expressions with capture lists and parameters"
    },
    {
      "tokenType": "decorator",
      "pattern": "@(escaping|autoclosure|Sendable)\\b",
      "tokenModifiers": [],
      "description": "Closure and concurrency attributes: @escaping, @autoclosure, @Sendable"
    },
    {
      "tokenType": "decorator",
      "pattern": "@(State|Binding|Published|ObservedObject|StateObject|EnvironmentObject|Environment|AppStorage)\\b",
      "tokenModifiers": [],
      "description": "SwiftUI property wrapper attributes for state management"
    },
    {
      "tokenType": "decorator",
      "pattern": "@(resultBuilder|ViewBuilder|SceneBuilder)\\b",
      "tokenModifiers": [],
      "description": "Result builder attributes for DSL-style syntax"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\basync\\s+(?:throws\\s+)?(?:->|let|func)\\b",
      "tokenModifiers": [
        "async"
      ],
      "description": "Async function signatures and async let bindings"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\bTask\\s*(?:\\.\\w+)?\\s*\\{",
      "tokenModifiers": [
        "async"
      ],
      "description": "Task creation for structured concurrency"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\bSendable\\b",
      "tokenModifiers": [],
      "description": "Sendable protocol marker for concurrency safety"
    },
    {
      "tokenType": "enumMember",
      "pattern": "\\bcase\\s+([a-z][a-zA-Z0-9_]*)\\s*\\([^)]+\\)",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Enum cases with associated values"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\bcase\\s+let\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "tokenModifiers": [],
      "description": "Pattern matching with case let in switch and if statements"
    },
    {
      "tokenType": "operator",
      "pattern": "\\\\\\.[a-zA-Z_][a-zA-Z0-9_.]*",
      "tokenModifiers": [],
      "description": "KeyPath expressions using backslash-dot syntax"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\bsome\\s+[A-Z][a-zA-Z0-9_]*",
      "tokenModifiers": [],
      "description": "Opaque return types with some keyword"
    },
    {
      "tokenType": "macro",
      "pattern": "#([A-Z][a-zA-Z0-9_]*|Preview|stringify|warning|error|selector|available|if|elseif|else|endif|file|line|function)\\b",
      "tokenModifiers": [],
      "description": "Swift macros and compiler directives (#Preview, #stringify, #available)"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\bany\\s+[A-Z][a-zA-Z0-9_]*",
      "tokenModifiers": [],
      "description": "Existential types with any keyword for protocol types"
    },
    {
      "tokenType": "variable",
      "pattern": "\\\\bthis\\\\b|\\\\bself\\\\b",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Self/this keyword semantic token"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\\\b(async|await|yield)\\\\b",
      "tokenModifiers": [
        "async"
      ],
      "description": "Async/concurrent keywords"
    },
    {
      "tokenType": "type",
      "pattern": "\\\\b(Promise|Future|Task|Observable)\\\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Concurrent/async types"
    },
    {
      "tokenType": "function",
      "pattern": "\\\\b(get|set)\\\\s+\\\\w+\\\\s*\\\\(",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Getter/setter declarations"
    },
    {
      "tokenType": "variable",
      "pattern": "\\\\b_\\\\w+\\\\b",
      "tokenModifiers": [],
      "description": "Private/underscore-prefixed identifiers"
    },
    {
      "tokenType": "type",
      "pattern": "\\\\b(Array|List|Map|Set|Dict|Vector|HashMap|TreeMap)\\\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Collection types"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\\\b(abstract|virtual|override|final|sealed)\\\\b",
      "tokenModifiers": [],
      "description": "OOP modifier keywords"
    },
    {
      "tokenType": "property",
      "pattern": "\\\\b(length|size|count|isEmpty|isNotEmpty)\\\\b",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Common read-only properties"
    },
    {
      "tokenType": "function",
      "pattern": "\\\\b(map|filter|reduce|forEach|find|some|every)\\\\b",
      "tokenModifiers": [],
      "description": "Iteration/functional methods"
    },
    {
      "tokenType": "modifier",
      "pattern": "\\\\b(override|static|readonly|const|final|volatile)\\\\b",
      "tokenModifiers": [],
      "description": "Member modifiers"
    },
    {
      "tokenType": "namespace",
      "pattern": "\\\\b(std|System|java|kotlin|swift|Foundation)\\\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Standard library namespaces"
    },
    {
      "tokenType": "decorator",
      "pattern": "@[A-Z]\\\\w+",
      "tokenModifiers": [],
      "description": "Class/method annotations (PascalCase)"
    },
    {
      "tokenType": "typeParameter",
      "pattern": "<[A-Z](\\\\w*)>",
      "tokenModifiers": [],
      "description": "Single-letter and named type parameters"
    },
    {
      "tokenType": "event",
      "pattern": "\\\\b(onClick|onChange|onSubmit|onLoad|onError)\\\\b",
      "tokenModifiers": [],
      "description": "Common event handler names"
    },
    {
      "tokenType": "enumMember",
      "pattern": "\\\\b[A-Z][a-z]+[A-Z]\\\\w*\\\\b",
      "tokenModifiers": [],
      "description": "CamelCase identifiers (often enum values)"
    }
  ]
}
