{
  "language": "swift",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "enum", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "function", "method", "keyword", "modifier", "comment", "string", "number", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "async", "documentation", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "function",
      "pattern": "\\bfunc\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Function declarations with func keyword"
    },
    {
      "type": "class",
      "pattern": "\\bclass\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Class declarations"
    },
    {
      "type": "struct",
      "pattern": "\\bstruct\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Struct declarations"
    },
    {
      "type": "type",
      "pattern": "\\bprotocol\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Protocol declarations"
    },
    {
      "type": "enum",
      "pattern": "\\benum\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Enum declarations"
    },
    {
      "type": "keyword",
      "pattern": "\\b(guard|if\\s+let|while\\s+let|as\\?|as!|try\\?|try!|throws|rethrows|async|await|actor|some|any|where|extension|subscript|typealias|associatedtype|inout|defer|willSet|didSet)\\b",
      "modifiers": [],
      "description": "Swift-specific keywords including optionals and concurrency"
    },
    {
      "type": "decorator",
      "pattern": "@([a-zA-Z_][a-zA-Z0-9_]*)",
      "modifiers": [],
      "description": "Attribute annotations like @available, @objc, @MainActor"
    },
    {
      "type": "typeParameter",
      "pattern": "<([A-Z][a-zA-Z0-9_]*(?:\\s*:\\s*[A-Z][a-zA-Z0-9_]*)?)>",
      "modifiers": [],
      "description": "Generic type parameters with optional constraints"
    },
    {
      "type": "variable",
      "pattern": "\\b(let|var)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Variable and constant declarations"
    },
    {
      "type": "type",
      "pattern": "\\b(Int|Int8|Int16|Int32|Int64|UInt|Float|Double|Bool|String|Character|Array|Dictionary|Set|Optional|Result|Any|AnyObject|Void|Never)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Standard library types"
    }
  ]
}
