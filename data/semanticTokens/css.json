{
  "language": "css",
  "legend": {
    "tokenTypes": [
      "class",
      "variable",
      "property",
      "keyword",
      "function",
      "number",
      "string",
      "comment",
      "operator",
      "decorator",
      "enum",
      "modifier",
      "namespace",
      "type"
    ],
    "tokenModifiers": [
      "declaration",
      "definition",
      "readonly",
      "deprecated",
      "documentation",
      "defaultLibrary"
    ]
  },
  "semanticRules": [
    {
      "tokenType": "class",
      "pattern": "\\.[a-zA-Z_][a-zA-Z0-9_-]*",
      "tokenModifiers": [],
      "description": "CSS class selectors (.classname). Styled as class type for visual distinction from other selector types."
    },
    {
      "tokenType": "class",
      "pattern": "#[a-zA-Z_][a-zA-Z0-9_-]*",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "CSS ID selectors (#idname). Styled as class with readonly modifier since IDs should be unique."
    },
    {
      "tokenType": "property",
      "pattern": "(?<=^\\s*|;\\s*)[a-z][a-z-]*(?=\\s*:)",
      "tokenModifiers": [],
      "description": "CSS property names (display, margin, color, etc.). Core declarations that assign values to styling properties."
    },
    {
      "tokenType": "variable",
      "pattern": "--[a-zA-Z_][a-zA-Z0-9_-]*(?=\\s*:)",
      "tokenModifiers": [
        "declaration",
        "definition"
      ],
      "description": "CSS custom property definitions (--variable-name: value). Marked as variable declarations."
    },
    {
      "tokenType": "variable",
      "pattern": "var\\(\\s*--[a-zA-Z_][a-zA-Z0-9_-]*",
      "tokenModifiers": [],
      "description": "CSS custom property references inside var(). Styled as variable to match the definition."
    },
    {
      "tokenType": "keyword",
      "pattern": "@(media|keyframes|supports|layer|container|font-face|import|charset|namespace|page|counter-style|property|scope|starting-style)\\b",
      "tokenModifiers": [],
      "description": "CSS at-rule keywords (@media, @keyframes, @supports, @layer, @container, @property, @scope, @starting-style)."
    },
    {
      "tokenType": "modifier",
      "pattern": ":(hover|focus|active|visited|first-child|last-child|nth-child|nth-of-type|not|is|where|has|focus-visible|focus-within|checked|disabled|enabled|empty|root|target|lang|any-link|placeholder-shown|required|optional|valid|invalid|in-range|out-of-range|read-only|read-write|default|indeterminate|first-of-type|last-of-type|only-child|only-of-type|modal|fullscreen|picture-in-picture|autofill|popover-open|user-valid|user-invalid|state)\\b",
      "tokenModifiers": [],
      "description": "CSS pseudo-classes (:hover, :focus, :has(), :is(), :where(), :user-valid, :state(), etc.)."
    },
    {
      "tokenType": "decorator",
      "pattern": "::(before|after|first-line|first-letter|selection|placeholder|marker|backdrop|file-selector-button|cue|part|slotted|highlight|spelling-error|grammar-error|target-text|view-transition|view-transition-old|view-transition-new|view-transition-group|view-transition-image-pair)\\b",
      "tokenModifiers": [],
      "description": "CSS pseudo-elements (::before, ::after, ::placeholder, ::view-transition, etc.)."
    },
    {
      "tokenType": "function",
      "pattern": "(calc|var|min|max|clamp|env|attr|url|linear-gradient|radial-gradient|conic-gradient|repeating-linear-gradient|repeating-radial-gradient|image-set|counter|counters|fit-content|minmax|repeat|translateX?|translateY|translate3d|rotateX?|rotateY|rotateZ|rotate3d|scaleX?|scaleY|scale3d|skewX?|skewY|matrix|matrix3d|perspective|cubic-bezier|steps|rgb|rgba|hsl|hsla|oklch|oklab|lab|lch|color|color-mix|light-dark|sin|cos|tan|asin|acos|atan|atan2|pow|sqrt|hypot|log|exp|abs|sign|round|mod|rem)\\s*\\(",
      "tokenModifiers": [],
      "description": "CSS function calls including math (calc, clamp, sin, cos, abs, sign, round, mod) and color (oklch, color-mix, light-dark)."
    },
    {
      "tokenType": "enum",
      "pattern": "#[0-9a-fA-F]{3,8}\\b",
      "tokenModifiers": [],
      "description": "CSS hex color values (#fff, #ff0000, #ff000080). Styled as enum for color constant identification."
    },
    {
      "tokenType": "number",
      "pattern": "-?\\d+(\\.\\d+)?(px|em|rem|%|vw|vh|vmin|vmax|svh|svw|dvh|dvw|ch|ex|lh|rlh|cap|ic|cqw|cqh|cqi|cqb|cqmin|cqmax|deg|rad|grad|turn|s|ms|Hz|kHz|dpi|dpcm|dppx|fr)?\\b",
      "tokenModifiers": [],
      "description": "CSS numeric values with units (16px, 1.5rem, 100%, 360deg, 0.3s, 1fr). Includes all CSS unit types."
    },
    {
      "tokenType": "string",
      "pattern": "['\\\"][^'\\\"]*['\\\"]",
      "tokenModifiers": [],
      "description": "CSS string literals in quotes. Used in content property, font-family names, url() paths, and attribute selectors."
    },
    {
      "tokenType": "comment",
      "pattern": "/\\*[\\s\\S]*?\\*/",
      "tokenModifiers": [],
      "description": "CSS comments (/* ... */). CSS only supports block comments, not line comments."
    },
    {
      "tokenType": "operator",
      "pattern": "[>+~|](?=\\s*[.#a-zA-Z*:\\[])",
      "tokenModifiers": [],
      "description": "CSS selector combinators: > (child), + (adjacent sibling), ~ (general sibling), || (column)."
    },
    {
      "tokenType": "namespace",
      "pattern": "@media\\s+[^{]+",
      "tokenModifiers": [],
      "description": "Media query conditions. Styled as namespace since they define a contextual scope for enclosed rules."
    },
    {
      "tokenType": "keyword",
      "pattern": "!important\\b",
      "tokenModifiers": [
        "deprecated"
      ],
      "description": "CSS !important flag. Marked as deprecated modifier to discourage overuse in modern CSS (prefer cascade layers)."
    },
    {
      "tokenType": "property",
      "pattern": "\\b(margin-inline|margin-inline-start|margin-inline-end|margin-block|margin-block-start|margin-block-end|padding-inline|padding-inline-start|padding-inline-end|padding-block|padding-block-start|padding-block-end|border-inline|border-block|inset|inset-inline|inset-inline-start|inset-inline-end|inset-block|inset-block-start|inset-block-end|inline-size|block-size|min-inline-size|max-inline-size|min-block-size|max-block-size)(?=\\s*:)",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "CSS logical properties for writing-mode-aware layout (margin-inline, padding-block, inset, inline-size, etc.)."
    },
    {
      "tokenType": "namespace",
      "pattern": "@container\\s+[^{]+",
      "tokenModifiers": [],
      "description": "Container query conditions (@container (min-width: 400px)). Scoped style context based on container size."
    },
    {
      "tokenType": "property",
      "pattern": "\\b(container-type|container-name|container)(?=\\s*:)",
      "tokenModifiers": [],
      "description": "Container query properties for establishing query containers (container-type, container-name)."
    },
    {
      "tokenType": "property",
      "pattern": "\\b(animation-timeline|animation-range|animation-range-start|animation-range-end|view-timeline|view-timeline-name|view-timeline-axis|view-timeline-inset|scroll-timeline|scroll-timeline-name|scroll-timeline-axis|timeline-scope)(?=\\s*:)",
      "tokenModifiers": [],
      "description": "Scroll-driven animation properties (animation-timeline, view-timeline, scroll-timeline)."
    },
    {
      "tokenType": "operator",
      "pattern": "&(?=\\s*[.#:\\[>+~a-zA-Z{])",
      "tokenModifiers": [],
      "description": "CSS nesting selector (&) for native CSS nesting, referencing the parent selector context."
    },
    {
      "tokenType": "keyword",
      "pattern": "\\bsubgrid\\b",
      "tokenModifiers": [],
      "description": "CSS subgrid keyword allowing child grids to adopt parent track sizing."
    },
    {
      "tokenType": "property",
      "pattern": "\\b(aspect-ratio)(?=\\s*:)",
      "tokenModifiers": [],
      "description": "CSS aspect-ratio property for maintaining element proportions (e.g., aspect-ratio: 16/9)."
    },
    {
      "tokenType": "keyword",
      "pattern": "@starting-style\\b",
      "tokenModifiers": [],
      "description": "CSS @starting-style at-rule for defining entry animation starting states for elements entering the DOM."
    },
    {
      "tokenType": "function",
      "pattern": "(oklch|oklab|color-mix|color|light-dark|color-contrast)\\s*\\(",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Modern CSS color functions (oklch(), oklab(), color-mix(), light-dark(), color-contrast())."
    }
  ]
}
