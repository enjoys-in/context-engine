{
  "language": "nginx",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["keyword", "variable", "property", "string", "number", "comment", "operator", "type"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "keyword",
      "pattern": "\\b(server|location|upstream|http|events|stream|mail|map|geo|types|if|return|rewrite|set|include|worker_processes|worker_connections|error_log|access_log|pid)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Nginx block directives and core keywords"
    },
    {
      "type": "variable",
      "pattern": "\\$[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": [],
      "description": "Nginx variables like $uri, $host, $remote_addr"
    },
    {
      "type": "property",
      "pattern": "\\b(proxy_pass|proxy_set_header|proxy_redirect|proxy_connect_timeout|proxy_read_timeout|fastcgi_pass|uwsgi_pass|grpc_pass)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Proxy directives"
    },
    {
      "type": "property",
      "pattern": "\\b(listen|server_name|root|index|try_files|alias|error_page|client_max_body_size|keepalive_timeout|sendfile|gzip|ssl_certificate|ssl_certificate_key)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Server and location configuration directives"
    },
    {
      "type": "type",
      "pattern": "\\b(text/html|text/plain|text/css|application/json|application/javascript|application/xml|image/png|image/jpeg|image/gif|application/octet-stream)\\b",
      "modifiers": ["readonly"],
      "description": "MIME types used in content type declarations"
    },
    {
      "type": "string",
      "pattern": "'([^'\\\\]|\\\\.)*'|\"([^\"\\\\]|\\\\.)*\"",
      "modifiers": [],
      "description": "String literals in single or double quotes"
    },
    {
      "type": "number",
      "pattern": "\\b\\d+[kmgKMG]?\\b",
      "modifiers": [],
      "description": "Numeric values with optional size suffixes"
    },
    {
      "type": "comment",
      "pattern": "#[^\\n]*",
      "modifiers": [],
      "description": "Single-line comments starting with #"
    },
    {
      "type": "keyword",
      "pattern": "\\b(location)\\s+(=|~|~\\*|\\^~)?",
      "modifiers": ["definition"],
      "description": "Location block with match modifier"
    },
    {
      "type": "operator",
      "pattern": "(=|~|~\\*|\\^~|!~|!~\\*)",
      "modifiers": [],
      "description": "Match and regex operators in location and if blocks"
    }
  ]
}
