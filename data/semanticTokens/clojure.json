{
  "language": "clojure",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["function", "variable", "macro", "namespace", "keyword", "parameter", "property", "type"],
    "tokenModifiers": ["declaration", "definition", "readonly", "deprecated", "defaultLibrary", "documentation"]
  },
  "semanticRules": [
    {
      "type": "function",
      "pattern": "\\(defn-?\\s+([a-zA-Z_!?*+<>=-][a-zA-Z0-9_!?*+<>=-]*)\\b",
      "modifiers": ["definition"],
      "description": "Public and private function definitions (defn, defn-)"
    },
    {
      "type": "variable",
      "pattern": "\\(def\\s+([a-zA-Z_!?*+<>=-][a-zA-Z0-9_!?*+<>=-]*)\\b",
      "modifiers": ["definition"],
      "description": "Var definitions (def)"
    },
    {
      "type": "macro",
      "pattern": "\\(defmacro\\s+([a-zA-Z_!?*+<>=-][a-zA-Z0-9_!?*+<>=-]*)\\b",
      "modifiers": ["definition"],
      "description": "Macro definitions (defmacro)"
    },
    {
      "type": "namespace",
      "pattern": "\\(ns\\s+([a-zA-Z_][a-zA-Z0-9_.-]*)\\b",
      "modifiers": ["declaration"],
      "description": "Namespace declarations"
    },
    {
      "type": "keyword",
      "pattern": ":[a-zA-Z_!?*+<>=-][a-zA-Z0-9_!?*+<>/=-]*",
      "modifiers": [],
      "description": "Clojure keywords (:keyword, :namespaced/keyword)"
    },
    {
      "type": "keyword",
      "pattern": "\\b(if|when|cond|let|loop|recur|do|fn|quote|var|try|catch|finally|throw|monitor-enter|monitor-exit)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Special forms"
    },
    {
      "type": "macro",
      "pattern": "\\b(and|or|when-let|if-let|cond->|cond->>|->|->|as->|some->|doseq|dotimes|for|with-open)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Core macros and threading macros"
    },
    {
      "type": "type",
      "pattern": "\\(defrecord\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["definition"],
      "description": "Record type definitions"
    },
    {
      "type": "type",
      "pattern": "\\(defprotocol\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["definition"],
      "description": "Protocol definitions"
    },
    {
      "type": "function",
      "pattern": "\\b(map|filter|reduce|apply|partial|comp|juxt|identity|constantly|complement|merge|assoc|dissoc|get|conj|cons|into)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Core library functions"
    }
  ]
}
