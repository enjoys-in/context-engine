{
  "language": "c",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["function", "variable", "type", "struct", "enum", "enumMember", "macro", "parameter", "keyword", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "function",
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\([^)]*\\)\\s*\\{",
      "modifiers": ["definition"],
      "description": "Function definitions"
    },
    {
      "type": "type",
      "pattern": "\\btypedef\\s+(?:struct|union|enum)?\\s*\\{?[^}]*\\}?\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*;",
      "modifiers": ["definition"],
      "description": "Typedef type definitions"
    },
    {
      "type": "struct",
      "pattern": "\\bstruct\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Struct declarations"
    },
    {
      "type": "enum",
      "pattern": "\\benum\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Enum declarations"
    },
    {
      "type": "macro",
      "pattern": "#define\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "modifiers": ["definition"],
      "description": "Preprocessor macro definitions (#define)"
    },
    {
      "type": "macro",
      "pattern": "#(include|ifdef|ifndef|endif|pragma|if|elif|else|undef|error|warning)\\b",
      "modifiers": [],
      "description": "Preprocessor directives"
    },
    {
      "type": "type",
      "pattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\*+",
      "modifiers": [],
      "description": "Pointer type declarations"
    },
    {
      "type": "keyword",
      "pattern": "\\b(static|extern|const|volatile|register|inline|restrict)\\b",
      "modifiers": [],
      "description": "Storage class and type qualifiers"
    },
    {
      "type": "function",
      "pattern": "\\b(malloc|calloc|realloc|free|printf|scanf|strlen|strcpy|memcpy|memset|fopen|fclose)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Standard library functions"
    },
    {
      "type": "type",
      "pattern": "\\b(int|char|float|double|void|long|short|unsigned|signed|size_t|ptrdiff_t)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in and standard types"
    }
  ]
}
