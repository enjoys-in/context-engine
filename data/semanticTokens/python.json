{
  "language": "python",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "enum", "typeParameter", "parameter", "variable", "property", "function", "method", "keyword", "modifier", "comment", "string", "number", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "async", "deprecated", "defaultLibrary", "documentation"]
  },
  "semanticRules": [
    {
      "type": "function",
      "pattern": "\\bdef\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Function definitions with def keyword"
    },
    {
      "type": "class",
      "pattern": "\\bclass\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Class definitions with class keyword"
    },
    {
      "type": "decorator",
      "pattern": "@[\\w.]+(?:\\([^)]*\\))?",
      "modifiers": [],
      "description": "Decorator expressions prefixed with @"
    },
    {
      "type": "type",
      "pattern": ":\\s*(\\w+(?:\\[.*?\\])?)|->\\s*(\\w+(?:\\[.*?\\])?)",
      "modifiers": [],
      "description": "Type hints in annotations and return types"
    },
    {
      "type": "keyword",
      "pattern": "\\b(async\\s+def|await|async\\s+for|async\\s+with)\\b",
      "modifiers": ["async"],
      "description": "Async/await keywords for asynchronous programming"
    },
    {
      "type": "string",
      "pattern": "f\"[^\"]*\"|f'[^']*'|f\"\"\"[\\s\\S]*?\"\"\"|f'''[\\s\\S]*?'''",
      "modifiers": [],
      "description": "F-string literals with embedded expressions"
    },
    {
      "type": "namespace",
      "pattern": "\\b(import|from)\\s+([\\w.]+)",
      "modifiers": ["definition"],
      "description": "Import statements and from...import declarations"
    },
    {
      "type": "keyword",
      "pattern": "\\b(if|elif|else|while|for|in|try|except|finally|raise|with|as|pass|break|continue|return|yield|assert|del|lambda|global|nonlocal|is|not|and|or|match|case)\\b",
      "modifiers": [],
      "description": "Python control flow and structural keywords"
    },
    {
      "type": "type",
      "pattern": "\\b(int|float|str|bool|list|dict|tuple|set|frozenset|bytes|bytearray|memoryview|complex|None|type|object|Callable|Optional|Union|Any|List|Dict|Tuple|Set|Type|Generator|Iterator|Iterable|Sequence|Mapping)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in types and typing module types"
    },
    {
      "type": "variable",
      "pattern": "\\b(self|cls)\\b",
      "modifiers": ["readonly"],
      "description": "Instance (self) and class (cls) reference variables"
    },
    {
      "type": "comment",
      "pattern": "#[^\\n]*|\"\"\"[\\s\\S]*?\"\"\"|'''[\\s\\S]*?'''",
      "modifiers": ["documentation"],
      "description": "Line comments and docstring comments"
    },
    {
      "type": "number",
      "pattern": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?j?\\b|0[xXoObB][0-9a-fA-F_]+\\b",
      "modifiers": [],
      "description": "Numeric literals including complex, hex, octal, and binary"
    }
  ]
}
