{
  "language": "julia",
  "legend": {
    "tokenTypes": [
      "namespace",
      "type",
      "struct",
      "typeParameter",
      "parameter",
      "variable",
      "property",
      "function",
      "method",
      "macro",
      "keyword",
      "comment",
      "string",
      "number",
      "operator"
    ],
    "tokenModifiers": [
      "declaration",
      "definition",
      "readonly",
      "abstract",
      "documentation",
      "defaultLibrary"
    ]
  },
  "semanticRules": [
    {
      "tokenType": "keyword",
      "pattern": "\\b(function|end|struct|module|macro|begin|let|if|elseif|else|for|while|do|try|catch|finally|return|break|continue|import|using|export|const|global|local|mutable|abstract|primitive|where|baremodule|quote)\\b",
      "tokenModifiers": [],
      "description": "Julia language keywords"
    },
    {
      "tokenType": "function",
      "pattern": "(?<=function\\s+)[a-zA-Z_][a-zA-Z0-9_!]*",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Function declarations including bang functions"
    },
    {
      "tokenType": "macro",
      "pattern": "@[a-zA-Z_][a-zA-Z0-9_]*",
      "tokenModifiers": [],
      "description": "Macro invocations like @show, @time, @assert"
    },
    {
      "tokenType": "struct",
      "pattern": "(?<=(?:mutable\\s+)?struct\\s+)[A-Z][a-zA-Z0-9_]*",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Struct type declarations, mutable and immutable"
    },
    {
      "tokenType": "namespace",
      "pattern": "(?<=module\\s+)[A-Z][a-zA-Z0-9_]*",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Module declarations"
    },
    {
      "tokenType": "type",
      "pattern": "(?<=::)\\s*[A-Z][a-zA-Z0-9_]*",
      "tokenModifiers": [],
      "description": "Type annotations after :: operator"
    },
    {
      "tokenType": "operator",
      "pattern": "(::|<:|>:|\\|>|\\.(?=[a-zA-Z(])|=>|\\.\\.\\.|\\u2208|\\u2218|\\u2282|\\u2283|\\u2229|\\u222A)",
      "tokenModifiers": [],
      "description": "Type annotation ::, subtype <:, pipe |>, broadcast ., and Unicode operators"
    },
    {
      "tokenType": "function",
      "pattern": "\\b[a-z_][a-zA-Z0-9_!]*\\s*(?=\\([^)]*\\)\\s*where)",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Method definitions with multiple dispatch (where clause)"
    },
    {
      "tokenType": "type",
      "pattern": "\\b(Int|Int8|Int16|Int32|Int64|UInt8|UInt16|UInt32|UInt64|Float16|Float32|Float64|Bool|Char|String|Symbol|Nothing|Any|Union|Tuple|NamedTuple|Array|Vector|Matrix|Dict|Set)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Built-in types in the Julia standard library"
    },
    {
      "tokenType": "comment",
      "pattern": "#=.*?=#|#.*$",
      "tokenModifiers": [
        "documentation"
      ],
      "description": "Single-line and block comments"
    },
    {
      "tokenType": "string",
      "pattern": "\"\"\"[\\s\\S]*?\"\"\"|\"(?:[^\"\\\\]|\\\\.)*\"",
      "tokenModifiers": [],
      "description": "Triple-quoted and regular string literals"
    },
    {
      "tokenType": "function",
      "pattern": "\\b[a-z_][a-zA-Z0-9_!]*\\s*\\(.*::[A-Z][a-zA-Z0-9_{}]*(?:\\s*,\\s*.*::[A-Z][a-zA-Z0-9_{}]*)*\\)",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Multiple dispatch: function signatures with typed arguments"
    },
    {
      "tokenType": "type",
      "pattern": "\\b[A-Z][a-zA-Z0-9_]*\\{[^}]+\\}",
      "tokenModifiers": [],
      "description": "Parametric types with type parameters (e.g., Array{Float64,2}, Dict{String,Int})"
    },
    {
      "tokenType": "operator",
      "pattern": "\\b\\w+\\.\\(|\\.[+\\-*/^%<>=!&|]",
      "tokenModifiers": [],
      "description": "Broadcasting dot syntax for element-wise operations (f.(x), .+, .*, etc.)"
    },
    {
      "tokenType": "string",
      "pattern": "\\$(?:\\w+|\\([^)]+\\))",
      "tokenModifiers": [],
      "description": "String interpolation with $variable or $(expression)"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\[\\s*[^\\]]*\\bfor\\s+\\w+\\s+in\\s+[^\\]]*\\]",
      "tokenModifiers": [],
      "description": "Array comprehensions ([expr for x in iter])"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\(\\s*[^)]*\\bfor\\s+\\w+\\s+in\\s+[^)]*\\)",
      "tokenModifiers": [],
      "description": "Generator expressions ((expr for x in iter))"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\bdo\\s*$|\\bdo\\s+\\w+",
      "tokenModifiers": [],
      "description": "Do block syntax for passing anonymous functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(Channel|Task|put!|take!|fetch|schedule)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Channel and Task concurrency primitives"
    },
    {
      "tokenType": "macro",
      "pattern": "@(spawn|threads|distributed|parallel|everywhere|spawnat|fetchfrom|simd|inbounds|views|generated|enum|deprecate|doc|async|sync)",
      "tokenModifiers": [],
      "description": "Threading, parallelism, and utility macros (@spawn, @threads, @async, @sync, etc.)"
    },
    {
      "tokenType": "macro",
      "pattern": "\\b(quote|eval|macroexpand|esc|gensym)\\b|@macroexpand|\\bMeta\\.parse\\b",
      "tokenModifiers": [],
      "description": "Metaprogramming primitives (quote, eval, macroexpand, esc, gensym)"
    },
    {
      "tokenType": "type",
      "pattern": "\\bUnion\\{[^}]+\\}",
      "tokenModifiers": [],
      "description": "Type unions (Union{Int, Float64, Nothing})"
    },
    {
      "tokenType": "typeParameter",
      "pattern": "\\bwhere\\s+[A-Z][a-zA-Z0-9_]*(?:\\s*<:\\s*[A-Z][a-zA-Z0-9_]*)?",
      "tokenModifiers": [],
      "description": "Where clause for parametric type constraints (where T <: Number)"
    },
    {
      "tokenType": "type",
      "pattern": "\\babstract\\s+type\\s+[A-Z][a-zA-Z0-9_]*(?:\\s*<:\\s*[A-Z][a-zA-Z0-9_]*)?\\s*end",
      "tokenModifiers": [
        "declaration",
        "abstract"
      ],
      "description": "Abstract type declarations (abstract type Name <: Parent end)"
    },
    {
      "tokenType": "variable",
      "pattern": "\\bconst\\s+[a-zA-Z_][a-zA-Z0-9_]*\\s*=",
      "tokenModifiers": [
        "readonly",
        "declaration"
      ],
      "description": "Constant declarations (const NAME = value)"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(using|import)\\s+[A-Z][a-zA-Z0-9_]*(?:\\.[A-Z][a-zA-Z0-9_]*)*(?:\\s*:\\s*[a-zA-Z_][a-zA-Z0-9_!,\\s]*)?",
      "tokenModifiers": [],
      "description": "Using/Import statements with optional selective imports (using Pkg: add, rm)"
    },
    {
      "tokenType": "variable",
      "pattern": "\\\\bthis\\\\b|\\\\bself\\\\b",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Self/this keyword semantic token"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\\\b(async|await|yield)\\\\b",
      "tokenModifiers": [
        "async"
      ],
      "description": "Async/concurrent keywords"
    },
    {
      "tokenType": "type",
      "pattern": "\\\\b(Promise|Future|Task|Observable)\\\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Concurrent/async types"
    },
    {
      "tokenType": "function",
      "pattern": "\\\\b(get|set)\\\\s+\\\\w+\\\\s*\\\\(",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Getter/setter declarations"
    },
    {
      "tokenType": "variable",
      "pattern": "\\\\b_\\\\w+\\\\b",
      "tokenModifiers": [],
      "description": "Private/underscore-prefixed identifiers"
    },
    {
      "tokenType": "type",
      "pattern": "\\\\b(Array|List|Map|Set|Dict|Vector|HashMap|TreeMap)\\\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Collection types"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\\\b(abstract|virtual|override|final|sealed)\\\\b",
      "tokenModifiers": [],
      "description": "OOP modifier keywords"
    },
    {
      "tokenType": "property",
      "pattern": "\\\\b(length|size|count|isEmpty|isNotEmpty)\\\\b",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Common read-only properties"
    },
    {
      "tokenType": "function",
      "pattern": "\\\\b(map|filter|reduce|forEach|find|some|every)\\\\b",
      "tokenModifiers": [],
      "description": "Iteration/functional methods"
    },
    {
      "tokenType": "modifier",
      "pattern": "\\\\b(override|static|readonly|const|final|volatile)\\\\b",
      "tokenModifiers": [],
      "description": "Member modifiers"
    },
    {
      "tokenType": "namespace",
      "pattern": "\\\\b(std|System|java|kotlin|swift|Foundation)\\\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Standard library namespaces"
    },
    {
      "tokenType": "decorator",
      "pattern": "@[A-Z]\\\\w+",
      "tokenModifiers": [],
      "description": "Class/method annotations (PascalCase)"
    },
    {
      "tokenType": "typeParameter",
      "pattern": "<[A-Z](\\\\w*)>",
      "tokenModifiers": [],
      "description": "Single-letter and named type parameters"
    },
    {
      "tokenType": "event",
      "pattern": "\\\\b(onClick|onChange|onSubmit|onLoad|onError)\\\\b",
      "tokenModifiers": [],
      "description": "Common event handler names"
    },
    {
      "tokenType": "enumMember",
      "pattern": "\\\\b[A-Z][a-z]+[A-Z]\\\\w*\\\\b",
      "tokenModifiers": [],
      "description": "CamelCase identifiers (often enum values)"
    }
  ]
}
