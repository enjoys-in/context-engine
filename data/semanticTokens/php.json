{
  "language": "php",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "enum", "interface", "variable", "property", "function", "method", "keyword", "modifier", "comment", "string", "number", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "class",
      "pattern": "\\b(class|trait)\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Class and trait declarations"
    },
    {
      "type": "function",
      "pattern": "\\bfunction\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Function declarations"
    },
    {
      "type": "namespace",
      "pattern": "\\bnamespace\\s+([\\w\\\\]+)",
      "modifiers": ["declaration"],
      "description": "Namespace declarations"
    },
    {
      "type": "variable",
      "pattern": "\\$[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": [],
      "description": "PHP variables prefixed with $"
    },
    {
      "type": "namespace",
      "pattern": "\\buse\\s+([\\w\\\\]+)",
      "modifiers": ["definition"],
      "description": "Use statements for importing classes and namespaces"
    },
    {
      "type": "interface",
      "pattern": "\\binterface\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Interface declarations"
    },
    {
      "type": "enum",
      "pattern": "\\benum\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Enum declarations (PHP 8.1+)"
    },
    {
      "type": "modifier",
      "pattern": "\\b(public|private|protected|static|final|abstract|readonly|const)\\b",
      "modifiers": [],
      "description": "Access modifiers and class member qualifiers"
    },
    {
      "type": "type",
      "pattern": "\\b(string|int|float|bool|array|object|callable|iterable|void|never|null|mixed|self|parent|static)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Type hint keywords for parameters, return types, and properties"
    },
    {
      "type": "comment",
      "pattern": "//[^\\n]*|#[^\\n]*|/\\*\\*[\\s\\S]*?\\*/|/\\*[\\s\\S]*?\\*/",
      "modifiers": ["documentation"],
      "description": "Line comments, block comments, and PHPDoc docblocks"
    },
    {
      "type": "decorator",
      "pattern": "#\\[\\w+[^\\]]*\\]",
      "modifiers": [],
      "description": "PHP 8 attributes #[Attribute]"
    },
    {
      "type": "keyword",
      "pattern": "\\b(if|else|elseif|while|for|foreach|do|switch|case|break|continue|return|yield|throw|try|catch|finally|new|instanceof|match|echo|print|include|require|include_once|require_once|fn|as)\\b",
      "modifiers": [],
      "description": "PHP control flow and language keywords"
    }
  ]
}
