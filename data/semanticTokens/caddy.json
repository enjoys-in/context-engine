{
  "language": "caddy",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["keyword", "function", "variable", "property", "string", "namespace", "operator"],
    "tokenModifiers": ["declaration", "definition", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "keyword",
      "pattern": "\\b(reverse_proxy|file_server|respond|redir|rewrite|encode|tls|log|header|basicauth|handle|handle_path|route)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Caddy directives"
    },
    {
      "type": "function",
      "pattern": "@([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Named matchers (@name)"
    },
    {
      "type": "namespace",
      "pattern": "^\\s*([a-zA-Z0-9.-]+(?::[0-9]+)?)\\s*\\{",
      "modifiers": ["declaration"],
      "description": "Site address / host blocks"
    },
    {
      "type": "variable",
      "pattern": "\\{([a-zA-Z_.][a-zA-Z0-9_.]*)\\}",
      "modifiers": [],
      "description": "Placeholders ({http.request.host}, {args.0})"
    },
    {
      "type": "keyword",
      "pattern": "\\b(import|snippet)\\b",
      "modifiers": [],
      "description": "Snippet and import references"
    },
    {
      "type": "property",
      "pattern": "\\b(path|host|method|protocol|header|query|remote_ip|not|expression)\\b",
      "modifiers": [],
      "description": "Matcher types in matcher blocks"
    },
    {
      "type": "keyword",
      "pattern": "\\b(php_fastcgi|templates|root|try_files|uri|vars|map|error|abort|skip_log)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Additional Caddy directives"
    },
    {
      "type": "string",
      "pattern": "\\b(gzip|zstd|br)\\b",
      "modifiers": [],
      "description": "Encoding format identifiers"
    },
    {
      "type": "operator",
      "pattern": "\\b(to|from|between|except)\\b",
      "modifiers": [],
      "description": "Subdirective keywords"
    }
  ]
}
