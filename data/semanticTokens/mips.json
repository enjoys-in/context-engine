{
  "language": "mips",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "property", "function", "keyword", "comment", "string", "number", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly"]
  },
  "semanticRules": [
    {
      "type": "variable",
      "pattern": "\\$(?:zero|at|v[0-1]|a[0-3]|t[0-9]|s[0-7]|k[0-1]|gp|sp|fp|ra)",
      "modifiers": ["readonly"],
      "description": "Named MIPS registers ($t0-$t9, $s0-$s7, $zero, $ra, etc.)"
    },
    {
      "type": "variable",
      "pattern": "\\$\\d{1,2}",
      "modifiers": ["readonly"],
      "description": "Numbered registers $0-$31"
    },
    {
      "type": "keyword",
      "pattern": "\\b(add|addi|addiu|addu|sub|subu|mul|mult|multu|div|divu|and|andi|or|ori|nor|xor|xori|sll|srl|sra|sllv|srlv|srav|slt|slti|sltiu|sltu|beq|bne|bgt|bge|blt|ble|j|jal|jr|jalr|lw|lh|lb|lbu|lhu|sw|sh|sb|lui|la|li|move|mfhi|mflo|mthi|mtlo|nop|syscall|break)\\b",
      "modifiers": [],
      "description": "MIPS instruction mnemonics"
    },
    {
      "type": "function",
      "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*:",
      "modifiers": ["declaration"],
      "description": "Label declarations (targets for jumps/branches)"
    },
    {
      "type": "decorator",
      "pattern": "\\.(data|text|globl|global|word|half|byte|ascii|asciiz|space|align|float|double|extern|kdata|ktext|set|macro|end_macro|eqv|include)",
      "modifiers": [],
      "description": "Assembler directives (.data, .text, .globl, etc.)"
    },
    {
      "type": "number",
      "pattern": "\\b0x[0-9a-fA-F]+\\b|\\b-?\\d+\\b",
      "modifiers": [],
      "description": "Immediate values in decimal or hexadecimal"
    },
    {
      "type": "operator",
      "pattern": "[(),+\\-]",
      "modifiers": [],
      "description": "Parentheses for addressing modes and arithmetic signs"
    },
    {
      "type": "comment",
      "pattern": "#.*$",
      "modifiers": ["documentation"],
      "description": "Comments starting with #"
    },
    {
      "type": "string",
      "pattern": "\"(?:[^\"\\\\]|\\\\.)*\"",
      "modifiers": [],
      "description": "String literals in double quotes for .asciiz/.ascii"
    },
    {
      "type": "variable",
      "pattern": "\\$f[0-9]{1,2}",
      "modifiers": ["readonly"],
      "description": "Floating-point registers $f0-$f31"
    }
  ]
}
