{
  "language": "markdown",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["type", "variable", "property", "keyword", "comment", "string", "operator"],
    "tokenModifiers": ["declaration", "definition"]
  },
  "semanticRules": [
    {
      "type": "keyword",
      "pattern": "^#{1,6}\\s+.*$",
      "modifiers": ["declaration"],
      "description": "Heading declarations from # to ######"
    },
    {
      "type": "variable",
      "pattern": "\\[([^\\]]+)\\]\\(([^)]+)\\)",
      "modifiers": [],
      "description": "Inline links [text](url)"
    },
    {
      "type": "variable",
      "pattern": "\\[([^\\]]+)\\]\\[([^\\]]+)\\]",
      "modifiers": [],
      "description": "Reference-style links [text][ref]"
    },
    {
      "type": "string",
      "pattern": "(`{1,3})(?!`)[\\s\\S]*?\\1",
      "modifiers": [],
      "description": "Inline code spans and fenced code blocks"
    },
    {
      "type": "keyword",
      "pattern": "(\\*\\*|__)[^*_]+\\1",
      "modifiers": [],
      "description": "Bold/strong emphasis with ** or __"
    },
    {
      "type": "comment",
      "pattern": "(\\*|_)(?!\\1)[^*_]+\\1",
      "modifiers": [],
      "description": "Italic/emphasis with * or _"
    },
    {
      "type": "property",
      "pattern": "^\\s*[-*+]\\s+|^\\s*\\d+\\.\\s+",
      "modifiers": [],
      "description": "Unordered and ordered list item markers"
    },
    {
      "type": "operator",
      "pattern": "^---+$|^\\*\\*\\*+$|^___+$",
      "modifiers": [],
      "description": "Horizontal rules (thematic breaks)"
    },
    {
      "type": "variable",
      "pattern": "!\\[([^\\]]*)\\]\\(([^)]+)\\)",
      "modifiers": [],
      "description": "Image references ![alt](url)"
    },
    {
      "type": "type",
      "pattern": "^>\\s+.*$",
      "modifiers": [],
      "description": "Blockquote lines starting with >"
    }
  ]
}
