{
  "language": "mysql",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "variable", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "keyword",
      "pattern": "\\b(SELECT|INSERT|UPDATE|DELETE|CREATE|ALTER|DROP|FROM|WHERE|JOIN|LEFT|RIGHT|INNER|OUTER|ON|GROUP\\s+BY|ORDER\\s+BY|HAVING|LIMIT|OFFSET|UNION|INTO|VALUES|SET|INDEX|TABLE|DATABASE|VIEW|TRIGGER|PROCEDURE|FUNCTION|BEGIN|END|IF|THEN|ELSE|WHILE|DO|LOOP|REPEAT|UNTIL|CASE|WHEN|RETURN|DECLARE|CURSOR|FETCH|CALL)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "SQL keywords and DML/DDL statements"
    },
    {
      "type": "function",
      "pattern": "\\b(CREATE\\s+(PROCEDURE|FUNCTION)\\s+)(\\w+)",
      "modifiers": ["declaration"],
      "description": "Stored procedure and function definitions"
    },
    {
      "type": "variable",
      "pattern": "@\\w+",
      "modifiers": [],
      "description": "User-defined variables prefixed with @"
    },
    {
      "type": "variable",
      "pattern": "@@\\w+",
      "modifiers": ["readonly", "defaultLibrary"],
      "description": "System variables prefixed with @@"
    },
    {
      "type": "type",
      "pattern": "\\b(INT|INTEGER|BIGINT|SMALLINT|TINYINT|MEDIUMINT|FLOAT|DOUBLE|DECIMAL|NUMERIC|CHAR|VARCHAR|TEXT|TINYTEXT|MEDIUMTEXT|LONGTEXT|BLOB|DATE|DATETIME|TIMESTAMP|TIME|YEAR|BOOLEAN|BOOL|ENUM|SET|JSON|BINARY|VARBINARY)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "MySQL data types"
    },
    {
      "type": "function",
      "pattern": "\\b(COUNT|SUM|AVG|MIN|MAX|CONCAT|SUBSTRING|LENGTH|TRIM|UPPER|LOWER|NOW|CURDATE|DATE_FORMAT|IFNULL|COALESCE|CAST|CONVERT|GROUP_CONCAT|ROUND|FLOOR|CEIL)\\s*\\(",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in MySQL functions"
    },
    {
      "type": "namespace",
      "pattern": "\\b(USE|DATABASE)\\s+(\\w+)",
      "modifiers": ["definition"],
      "description": "Database/schema references"
    },
    {
      "type": "comment",
      "pattern": "--[^\\n]*|/\\*[\\s\\S]*?\\*/|#[^\\n]*",
      "modifiers": [],
      "description": "Single-line and multi-line comments"
    },
    {
      "type": "string",
      "pattern": "'([^'\\\\]|\\\\.)*'|\"([^\"\\\\]|\\\\.)*\"",
      "modifiers": [],
      "description": "String literals in single or double quotes"
    },
    {
      "type": "number",
      "pattern": "\\b\\d+(\\.\\d+)?\\b",
      "modifiers": [],
      "description": "Numeric literals"
    },
    {
      "type": "operator",
      "pattern": "(=|<>|!=|<=|>=|<|>|\\+|-|\\*|/|%|AND|OR|NOT|IN|LIKE|BETWEEN|IS\\s+NULL|IS\\s+NOT\\s+NULL|EXISTS)",
      "modifiers": [],
      "description": "Comparison, arithmetic, and logical operators"
    }
  ]
}
