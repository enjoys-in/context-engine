{
  "language": "cpp",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["class", "struct", "enum", "enumMember", "namespace", "type", "typeParameter", "function", "method", "variable", "property", "parameter", "macro", "keyword", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "class",
      "pattern": "\\bclass\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Class declarations"
    },
    {
      "type": "struct",
      "pattern": "\\bstruct\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Struct declarations"
    },
    {
      "type": "typeParameter",
      "pattern": "\\btemplate\\s*<([^>]+)>",
      "modifiers": ["declaration"],
      "description": "Template parameter lists"
    },
    {
      "type": "namespace",
      "pattern": "\\bnamespace\\s+([a-zA-Z_][a-zA-Z0-9_:]*)\\b",
      "modifiers": ["declaration"],
      "description": "Namespace declarations"
    },
    {
      "type": "method",
      "pattern": "\\b(virtual|override)\\s+[a-zA-Z_][a-zA-Z0-9_:<>]*\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "modifiers": ["abstract"],
      "description": "Virtual and overridden method declarations"
    },
    {
      "type": "function",
      "pattern": "\\boperator\\s*(\\+\\+|--|<<|>>|[+\\-*/%=<>!&|^~]=?|\\(\\)|\\[\\]|->\\*?|,)",
      "modifiers": ["definition"],
      "description": "Operator overloading definitions"
    },
    {
      "type": "keyword",
      "pattern": "\\b(constexpr|consteval|constinit|noexcept|decltype|auto|concept|requires)\\b",
      "modifiers": [],
      "description": "Modern C++ keywords"
    },
    {
      "type": "macro",
      "pattern": "#define\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "modifiers": ["definition"],
      "description": "Preprocessor macro definitions"
    },
    {
      "type": "type",
      "pattern": "\\b(std::[a-z_][a-z0-9_]*(?:<[^>]*>)?)",
      "modifiers": ["defaultLibrary"],
      "description": "Standard library types (std::vector, std::string, etc.)"
    },
    {
      "type": "keyword",
      "pattern": "\\b(public|private|protected|virtual|override|final|static|inline|explicit|mutable|volatile)\\b",
      "modifiers": [],
      "description": "Access specifiers and member modifiers"
    },
    {
      "type": "enum",
      "pattern": "\\benum\\s+(class\\s+)?([A-Z][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Enum and scoped enum declarations"
    }
  ]
}
