{
  "language": "go",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "interface", "struct", "typeParameter", "parameter", "variable", "property", "function", "method", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "keyword",
      "pattern": "\\b(func|type|var|const|package|import|return|if|else|for|range|switch|case|default|select|go|defer|recover|panic|chan|map|make|new|append|len|cap|close|delete|copy)\\b",
      "modifiers": [],
      "description": "Go language keywords and built-in functions"
    },
    {
      "type": "function",
      "pattern": "(?<=func\\s+)[a-zA-Z_][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Function declarations after func keyword"
    },
    {
      "type": "struct",
      "pattern": "(?<=type\\s+)[A-Z][a-zA-Z0-9_]*(?=\\s+struct)",
      "modifiers": ["declaration"],
      "description": "Struct type declarations"
    },
    {
      "type": "interface",
      "pattern": "(?<=type\\s+)[A-Z][a-zA-Z0-9_]*(?=\\s+interface)",
      "modifiers": ["declaration"],
      "description": "Interface type declarations"
    },
    {
      "type": "method",
      "pattern": "(?<=\\.)\\s*[a-zA-Z_][a-zA-Z0-9_]*\\s*(?=\\()",
      "modifiers": [],
      "description": "Method calls on receivers via dot notation"
    },
    {
      "type": "namespace",
      "pattern": "(?<=package\\s+)[a-z][a-z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Package declarations"
    },
    {
      "type": "variable",
      "pattern": "\\b[a-z_][a-zA-Z0-9_]*\\s*:=",
      "modifiers": ["declaration"],
      "description": "Short variable declarations with :="
    },
    {
      "type": "keyword",
      "pattern": "\\b(go|defer)\\b",
      "modifiers": ["async"],
      "description": "Goroutine launch and deferred execution keywords"
    },
    {
      "type": "type",
      "pattern": "\\b(int|int8|int16|int32|int64|uint|uint8|uint16|uint32|uint64|float32|float64|complex64|complex128|string|bool|byte|rune|error|any)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in primitive types"
    },
    {
      "type": "comment",
      "pattern": "//.*$|/\\*[\\s\\S]*?\\*/",
      "modifiers": ["documentation"],
      "description": "Single-line and multi-line comments"
    },
    {
      "type": "string",
      "pattern": "\"(?:[^\"\\\\]|\\\\.)*\"|`[^`]*`",
      "modifiers": [],
      "description": "Interpreted and raw string literals"
    }
  ]
}
