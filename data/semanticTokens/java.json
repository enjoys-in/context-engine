{
  "language": "java",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "enum", "interface", "typeParameter", "parameter", "variable", "property", "enumMember", "method", "keyword", "modifier", "comment", "string", "number", "operator", "decorator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "keyword",
      "pattern": "\\b(class|interface|enum|record|extends|implements|throws|throw|new|instanceof|return|if|else|for|while|do|switch|case|default|break|continue|try|catch|finally|import|package|this|super|void|assert|yield)\\b",
      "modifiers": [],
      "description": "Java language keywords"
    },
    {
      "type": "decorator",
      "pattern": "@[A-Z][a-zA-Z0-9_]*",
      "modifiers": [],
      "description": "Annotations like @Override, @Deprecated, @FunctionalInterface"
    },
    {
      "type": "class",
      "pattern": "(?<=(?:class|interface|enum|record)\\s+)[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Class, interface, enum, and record declarations"
    },
    {
      "type": "typeParameter",
      "pattern": "(?<=<\\s*)[A-Z][a-zA-Z0-9_]*(?=\\s*(?:extends|super|>|,))",
      "modifiers": ["declaration"],
      "description": "Generic type parameters like <T>, <K extends Comparable>"
    },
    {
      "type": "modifier",
      "pattern": "\\b(public|private|protected|static|final|abstract|synchronized|volatile|transient|native|strictfp|sealed|non-sealed|default)\\b",
      "modifiers": [],
      "description": "Access and non-access modifiers"
    },
    {
      "type": "method",
      "pattern": "\\b[a-z_][a-zA-Z0-9_]*\\s*(?=\\()",
      "modifiers": ["definition"],
      "description": "Method declarations and invocations"
    },
    {
      "type": "type",
      "pattern": "\\b(String|Integer|Long|Double|Float|Boolean|Character|Byte|Short|Object|List|Map|Set|Optional|Stream|Collection|Iterable|Comparable|Runnable|Callable)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Common built-in and standard library types"
    },
    {
      "type": "namespace",
      "pattern": "(?<=(?:package|import)\\s+)[a-z][a-z0-9.]*",
      "modifiers": [],
      "description": "Package and import path declarations"
    },
    {
      "type": "comment",
      "pattern": "//.*$|/\\*[\\s\\S]*?\\*/|/\\*\\*[\\s\\S]*?\\*/",
      "modifiers": ["documentation"],
      "description": "Single-line, multi-line, and Javadoc comments"
    },
    {
      "type": "string",
      "pattern": "\"(?:[^\"\\\\]|\\\\.)*\"|\"\"\"[\\s\\S]*?\"\"\"",
      "modifiers": [],
      "description": "String literals and text blocks"
    },
    {
      "type": "enumMember",
      "pattern": "\\b[A-Z][A-Z0-9_]+\\b",
      "modifiers": ["readonly", "static"],
      "description": "Enum constants and static final fields in UPPER_CASE"
    }
  ]
}
