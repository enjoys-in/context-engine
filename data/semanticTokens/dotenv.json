{
  "language": "dotenv",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "string", "comment", "keyword", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly"]
  },
  "semanticRules": [
    {
      "type": "variable",
      "pattern": "^([A-Z_][A-Z0-9_]*)\\s*=",
      "modifiers": ["definition"],
      "description": "KEY=VALUE variable definitions"
    },
    {
      "type": "comment",
      "pattern": "^\\s*#.*$",
      "modifiers": ["documentation"],
      "description": "Comment lines starting with #"
    },
    {
      "type": "keyword",
      "pattern": "^export\\s+",
      "modifiers": [],
      "description": "Exported variable prefix"
    },
    {
      "type": "string",
      "pattern": "=\\s*\"([^\"]*)\"",
      "modifiers": [],
      "description": "Double-quoted values"
    },
    {
      "type": "string",
      "pattern": "=\\s*'([^']*)'",
      "modifiers": ["readonly"],
      "description": "Single-quoted literal values (no interpolation)"
    },
    {
      "type": "variable",
      "pattern": "\\$\\{([A-Z_][A-Z0-9_]*)\\}",
      "modifiers": [],
      "description": "Interpolated variable references (${VAR})"
    },
    {
      "type": "variable",
      "pattern": "\\$([A-Z_][A-Z0-9_]*)",
      "modifiers": [],
      "description": "Simple interpolated variable references ($VAR)"
    },
    {
      "type": "operator",
      "pattern": "=",
      "modifiers": [],
      "description": "Assignment operator"
    }
  ]
}
