{
  "language": "dotenv",
  "legend": {
    "tokenTypes": [
      "variable",
      "string",
      "comment",
      "keyword",
      "operator",
      "number",
      "property"
    ],
    "tokenModifiers": [
      "declaration",
      "definition",
      "readonly",
      "documentation"
    ]
  },
  "semanticRules": [
    {
      "tokenType": "variable",
      "pattern": "^([A-Z_][A-Z0-9_]*)\\s*=",
      "tokenModifiers": [
        "definition"
      ],
      "description": "KEY=VALUE variable definitions"
    },
    {
      "tokenType": "comment",
      "pattern": "^\\s*#.*$",
      "tokenModifiers": [
        "documentation"
      ],
      "description": "Comment lines starting with #"
    },
    {
      "tokenType": "keyword",
      "pattern": "^export\\s+",
      "tokenModifiers": [],
      "description": "Exported variable prefix"
    },
    {
      "tokenType": "string",
      "pattern": "=\\s*\"([^\"]*)\"",
      "tokenModifiers": [],
      "description": "Double-quoted values (support interpolation)"
    },
    {
      "tokenType": "string",
      "pattern": "=\\s*'([^']*)'",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Single-quoted literal values (no interpolation)"
    },
    {
      "tokenType": "variable",
      "pattern": "\\$\\{([A-Z_][A-Z0-9_]*)\\}",
      "tokenModifiers": [],
      "description": "Interpolated variable references ${VAR}"
    },
    {
      "tokenType": "variable",
      "pattern": "\\$([A-Z_][A-Z0-9_]*)",
      "tokenModifiers": [],
      "description": "Simple interpolated variable references $VAR"
    },
    {
      "tokenType": "operator",
      "pattern": "=",
      "tokenModifiers": [],
      "description": "Assignment operator"
    },
    {
      "tokenType": "variable",
      "pattern": "\\$\\{([A-Z_][A-Z0-9_]*):-([^}]*)\\}",
      "tokenModifiers": [],
      "description": "Default value expansion ${VAR:-default}"
    },
    {
      "tokenType": "variable",
      "pattern": "\\$\\{([A-Z_][A-Z0-9_]*):\\?([^}]*)\\}",
      "tokenModifiers": [],
      "description": "Error if unset expansion ${VAR:?error message}"
    },
    {
      "tokenType": "string",
      "pattern": "=\\s*\"[^\"]*\\\\\\n[\\s\\S]*?\"",
      "tokenModifiers": [],
      "description": "Multi-line values with backslash continuation in double quotes"
    },
    {
      "tokenType": "comment",
      "pattern": "\\s+#[^\"']*$",
      "tokenModifiers": [],
      "description": "Inline comments (# after value, not inside quotes)"
    },
    {
      "tokenType": "keyword",
      "pattern": "(?<==\\s*)(true|false|TRUE|FALSE|True|False|yes|no|YES|NO)\\s*$",
      "tokenModifiers": [],
      "description": "Boolean-like values (true/false/yes/no)"
    },
    {
      "tokenType": "string",
      "pattern": "(?<==\\s*)(https?://[^\\s#]+|ftp://[^\\s#]+|amqps?://[^\\s#]+|redis://[^\\s#]+|postgres(ql)?://[^\\s#]+|mysql://[^\\s#]+|mongodb(\\+srv)?://[^\\s#]+)",
      "tokenModifiers": [],
      "description": "URL values (http, https, postgres, redis, mongodb, etc.)"
    },
    {
      "tokenType": "number",
      "pattern": "(?<==\\s*)\\d{1,5}(?=\\s*(?:#.*)?$)",
      "tokenModifiers": [],
      "description": "Port numbers and numeric values"
    },
    {
      "tokenType": "string",
      "pattern": "(?<==\\s*)(/[a-zA-Z0-9_./-]+|\\./[a-zA-Z0-9_./-]+)",
      "tokenModifiers": [],
      "description": "File path values (absolute or relative)"
    },
    {
      "tokenType": "property",
      "pattern": "^(NODE_ENV|APP_ENV|RAILS_ENV|FLASK_ENV|RACK_ENV|MIX_ENV)\\s*=",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Environment mode variables (NODE_ENV, APP_ENV, etc.)"
    },
    {
      "tokenType": "property",
      "pattern": "^(PORT|HOST|HOSTNAME|BIND_ADDRESS|LISTEN_PORT)\\s*=",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Server binding variables (PORT, HOST, etc.)"
    },
    {
      "tokenType": "property",
      "pattern": "^(DATABASE_URL|DB_HOST|DB_PORT|DB_NAME|DB_USER|DB_PASSWORD|DB_CONNECTION|REDIS_URL|REDIS_HOST|REDIS_PORT)\\s*=",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Database and cache connection variables"
    },
    {
      "tokenType": "property",
      "pattern": "^(API_KEY|API_SECRET|SECRET_KEY|JWT_SECRET|SESSION_SECRET|ENCRYPTION_KEY|AUTH_SECRET|APP_KEY)\\s*=",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Secret and API key variables"
    },
    {
      "tokenType": "property",
      "pattern": "^(AWS_ACCESS_KEY_ID|AWS_SECRET_ACCESS_KEY|AWS_REGION|AWS_BUCKET|AWS_ENDPOINT|S3_BUCKET|S3_REGION)\\s*=",
      "tokenModifiers": [
        "definition"
      ],
      "description": "AWS and S3 cloud configuration variables"
    },
    {
      "tokenType": "property",
      "pattern": "^(SMTP_HOST|SMTP_PORT|SMTP_USER|SMTP_PASSWORD|MAIL_FROM|MAIL_HOST|MAIL_PORT|SENDGRID_API_KEY)\\s*=",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Email and SMTP configuration variables"
    },
    {
      "tokenType": "string",
      "pattern": "(?<==\\s*)(development|production|staging|test|local)\\s*$",
      "tokenModifiers": [],
      "description": "Common environment mode values"
    },
    {
      "tokenType": "string",
      "pattern": "=\\s*$",
      "tokenModifiers": [],
      "description": "Empty values (KEY= with no value)"
    },
    {
      "tokenType": "property",
      "pattern": "^(LOG_LEVEL|LOG_FILE|DEBUG|VERBOSE|SENTRY_DSN|NEW_RELIC_LICENSE_KEY)\\s*=",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Logging and monitoring configuration variables"
    },
    {
      "tokenType": "variable",
      "pattern": "\\$\\{([A-Z_][A-Z0-9_]*):\\+([^}]*)\\}",
      "tokenModifiers": [],
      "description": "Alternate value expansion ${VAR:+alternate}"
    },
    {
      "tokenType": "variable",
      "pattern": "\\\\bthis\\\\b|\\\\bself\\\\b",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Self/this keyword semantic token"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\\\b(async|await|yield)\\\\b",
      "tokenModifiers": [
        "async"
      ],
      "description": "Async/concurrent keywords"
    },
    {
      "tokenType": "type",
      "pattern": "\\\\b(Promise|Future|Task|Observable)\\\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Concurrent/async types"
    },
    {
      "tokenType": "function",
      "pattern": "\\\\b(get|set)\\\\s+\\\\w+\\\\s*\\\\(",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Getter/setter declarations"
    },
    {
      "tokenType": "variable",
      "pattern": "\\\\b_\\\\w+\\\\b",
      "tokenModifiers": [],
      "description": "Private/underscore-prefixed identifiers"
    },
    {
      "tokenType": "type",
      "pattern": "\\\\b(Array|List|Map|Set|Dict|Vector|HashMap|TreeMap)\\\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Collection types"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\\\b(abstract|virtual|override|final|sealed)\\\\b",
      "tokenModifiers": [],
      "description": "OOP modifier keywords"
    },
    {
      "tokenType": "property",
      "pattern": "\\\\b(length|size|count|isEmpty|isNotEmpty)\\\\b",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Common read-only properties"
    },
    {
      "tokenType": "function",
      "pattern": "\\\\b(map|filter|reduce|forEach|find|some|every)\\\\b",
      "tokenModifiers": [],
      "description": "Iteration/functional methods"
    },
    {
      "tokenType": "modifier",
      "pattern": "\\\\b(override|static|readonly|const|final|volatile)\\\\b",
      "tokenModifiers": [],
      "description": "Member modifiers"
    },
    {
      "tokenType": "namespace",
      "pattern": "\\\\b(std|System|java|kotlin|swift|Foundation)\\\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Standard library namespaces"
    },
    {
      "tokenType": "decorator",
      "pattern": "@[A-Z]\\\\w+",
      "tokenModifiers": [],
      "description": "Class/method annotations (PascalCase)"
    },
    {
      "tokenType": "typeParameter",
      "pattern": "<[A-Z](\\\\w*)>",
      "tokenModifiers": [],
      "description": "Single-letter and named type parameters"
    },
    {
      "tokenType": "event",
      "pattern": "\\\\b(onClick|onChange|onSubmit|onLoad|onError)\\\\b",
      "tokenModifiers": [],
      "description": "Common event handler names"
    },
    {
      "tokenType": "enumMember",
      "pattern": "\\\\b[A-Z][a-z]+[A-Z]\\\\w*\\\\b",
      "tokenModifiers": [],
      "description": "CamelCase identifiers (often enum values)"
    }
  ]
}
