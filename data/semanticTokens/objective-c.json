{
  "language": "objective-c",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["class", "interface", "enum", "struct", "method", "property", "variable", "function", "macro", "keyword", "modifier", "comment", "string", "number", "operator", "decorator", "type"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "interface",
      "pattern": "@interface\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Objective-C class interface declarations"
    },
    {
      "type": "class",
      "pattern": "@implementation\\s+(\\w+)",
      "modifiers": ["definition"],
      "description": "Objective-C class implementation blocks"
    },
    {
      "type": "method",
      "pattern": "[-+]\\s*\\([^)]+\\)\\s*\\w+",
      "modifiers": ["definition"],
      "description": "Instance (-) and class (+) method signatures"
    },
    {
      "type": "interface",
      "pattern": "@protocol\\s+(\\w+)",
      "modifiers": ["declaration"],
      "description": "Protocol declarations"
    },
    {
      "type": "macro",
      "pattern": "#import\\s+[<\"][^>\"]+[>\"]",
      "modifiers": [],
      "description": "#import directives for header inclusion"
    },
    {
      "type": "property",
      "pattern": "@property\\s*\\([^)]*\\)\\s*\\w+\\s*\\*?\\s*\\w+",
      "modifiers": ["declaration"],
      "description": "@property declarations with attributes"
    },
    {
      "type": "keyword",
      "pattern": "@(synthesize|dynamic|autoreleasepool|try|catch|finally|throw|synchronized|selector|encode|end|class|optional|required|public|private|protected|package)",
      "modifiers": ["defaultLibrary"],
      "description": "Objective-C @ keywords"
    },
    {
      "type": "type",
      "pattern": "\\b(NSString|NSArray|NSDictionary|NSNumber|NSObject|NSInteger|NSUInteger|CGFloat|BOOL|id|instancetype|void|SEL|IMP|Class)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Foundation and runtime types"
    },
    {
      "type": "string",
      "pattern": "@\"([^\"\\\\]|\\\\.)*\"",
      "modifiers": [],
      "description": "NSString literals prefixed with @"
    },
    {
      "type": "decorator",
      "pattern": "__attribute__\\s*\\(\\([^)]*\\)\\)",
      "modifiers": [],
      "description": "GCC/Clang attribute decorators"
    },
    {
      "type": "comment",
      "pattern": "//[^\\n]*|/\\*[\\s\\S]*?\\*/",
      "modifiers": [],
      "description": "Single-line and multi-line comments"
    }
  ]
}
