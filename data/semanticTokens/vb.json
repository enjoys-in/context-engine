{
  "language": "vb",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "parameter", "variable", "property", "enumMember", "event", "function", "method", "keyword", "modifier", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "documentation", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "function",
      "pattern": "\\b(Sub|Function)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Sub and Function declarations"
    },
    {
      "type": "class",
      "pattern": "\\bClass\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Class declarations"
    },
    {
      "type": "namespace",
      "pattern": "\\bModule\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Module declarations"
    },
    {
      "type": "variable",
      "pattern": "\\b(Dim|Public|Private|Protected|Static|Friend)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Variable declarations with access modifiers"
    },
    {
      "type": "property",
      "pattern": "\\bProperty\\s+(Get|Set|Let)?\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Property accessors"
    },
    {
      "type": "event",
      "pattern": "\\b(Event|RaiseEvent|WithEvents)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Event declarations and WithEvents"
    },
    {
      "type": "keyword",
      "pattern": "\\b(If|Then|Else|ElseIf|End\\s+If|For|To|Step|Next|Do|Loop|While|Wend|Select\\s+Case|Case|End\\s+Select|With|End\\s+With|Try|Catch|Finally|End\\s+Try|Using|End\\s+Using|GoTo|Return|Exit|Continue)\\b",
      "modifiers": [],
      "description": "Control flow keywords"
    },
    {
      "type": "type",
      "pattern": "\\b(Integer|Long|Short|Byte|Single|Double|Decimal|Boolean|String|Char|Date|Object|Variant|Nothing|DBNull)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in VB data types"
    },
    {
      "type": "keyword",
      "pattern": "\\b(Imports|Namespace|Inherits|Implements|MustInherit|MustOverride|Overrides|Overridable|NotInheritable|NotOverridable|Shared|Shadows|ReadOnly|WriteOnly|Handles|AddHandler|RemoveHandler|Async|Await)\\b",
      "modifiers": [],
      "description": "OOP, inheritance, and async keywords"
    },
    {
      "type": "comment",
      "pattern": "'[^\\n]*",
      "modifiers": [],
      "description": "Single-line comments starting with apostrophe"
    }
  ]
}
