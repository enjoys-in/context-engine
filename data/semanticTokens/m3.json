{
  "language": "m3",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "type", "interface", "variable", "property", "function", "method", "keyword", "modifier", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly", "abstract"]
  },
  "semanticRules": [
    {
      "type": "keyword",
      "pattern": "\\b(MODULE|INTERFACE|OBJECT|PROCEDURE|BEGIN|END|RETURN|IF|THEN|ELSIF|ELSE|CASE|FOR|TO|BY|DO|WHILE|REPEAT|UNTIL|LOOP|EXIT|WITH|LOCK|TRY|EXCEPT|FINALLY|RAISE|VAR|CONST|TYPE|IMPORT|FROM|REVEAL|UNSAFE|BRANDED|UNTRACED|ROOT|REFANY|ARRAY|RECORD|SET|SUBRANGE|ENUM|REF|ADDRESS|BOOLEAN|INTEGER|REAL|LONGREAL|EXTENDED|CARDINAL|CHAR|TEXT|MUTEX|THREAD)\\b",
      "modifiers": [],
      "description": "Modula-3 language keywords"
    },
    {
      "type": "interface",
      "pattern": "(?<=INTERFACE\\s+)[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Interface declarations"
    },
    {
      "type": "namespace",
      "pattern": "(?<=MODULE\\s+)[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Module declarations"
    },
    {
      "type": "type",
      "pattern": "(?<=OBJECT\\s+)[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Object type declarations"
    },
    {
      "type": "function",
      "pattern": "(?<=PROCEDURE\\s+)[A-Z][a-zA-Z0-9_]*",
      "modifiers": ["declaration"],
      "description": "Procedure declarations"
    },
    {
      "type": "modifier",
      "pattern": "\\b(REVEAL|UNSAFE|BRANDED|UNTRACED|READONLY|METHODS|OVERRIDES)\\b",
      "modifiers": [],
      "description": "Modula-3 modifiers including REVEAL and UNSAFE"
    },
    {
      "type": "keyword",
      "pattern": "\\b(TRY|EXCEPT|FINALLY|RAISE)\\b",
      "modifiers": [],
      "description": "Exception handling keywords"
    },
    {
      "type": "type",
      "pattern": "\\b(BOOLEAN|INTEGER|REAL|LONGREAL|EXTENDED|CARDINAL|CHAR|TEXT|MUTEX|THREAD|REFANY|ADDRESS|NULL)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in types"
    },
    {
      "type": "comment",
      "pattern": "\\(\\*[\\s\\S]*?\\*\\)",
      "modifiers": ["documentation"],
      "description": "Block comments in (* ... *) delimiters"
    },
    {
      "type": "string",
      "pattern": "\"(?:[^\"\\\\]|\\\\.)*\"",
      "modifiers": [],
      "description": "String literals in double quotes"
    },
    {
      "type": "operator",
      "pattern": "(:=|#|<=|>=|<:|<>|\\.\\.|&)",
      "modifiers": [],
      "description": "Modula-3 operators: assignment, not-equal, subtype, range"
    }
  ]
}
