{
  "language": "m3",
  "legend": {
    "tokenTypes": [
      "namespace",
      "type",
      "class",
      "interface",
      "variable",
      "property",
      "function",
      "method",
      "keyword",
      "modifier",
      "comment",
      "string",
      "number",
      "operator",
      "enumMember"
    ],
    "tokenModifiers": [
      "declaration",
      "definition",
      "readonly",
      "abstract",
      "defaultLibrary",
      "static"
    ]
  },
  "semanticRules": [
    {
      "tokenType": "namespace",
      "pattern": "(?<=MODULE\\s+)[A-Z][a-zA-Z0-9_]*",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Module name declarations"
    },
    {
      "tokenType": "interface",
      "pattern": "(?<=INTERFACE\\s+)[A-Z][a-zA-Z0-9_]*",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Interface name declarations"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(MODULE|INTERFACE|GENERIC|IMPORT|FROM|EXPORT|BEGIN|END)\\b",
      "tokenModifiers": [],
      "description": "Module structure keywords"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(IF|THEN|ELSE|ELSIF|CASE|OF|WHILE|DO|FOR|TO|BY|REPEAT|UNTIL|LOOP|EXIT|RETURN|EVAL|WITH)\\b",
      "tokenModifiers": [],
      "description": "Control flow keywords"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(TRY|EXCEPT|FINALLY|RAISE|RAISES|LOCK)\\b",
      "tokenModifiers": [],
      "description": "Exception handling and thread synchronization keywords"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(VAR|CONST|TYPE|EXCEPTION|PROCEDURE)\\b",
      "tokenModifiers": [],
      "description": "Declaration section keywords"
    },
    {
      "tokenType": "function",
      "pattern": "(?<=PROCEDURE\\s+)[A-Za-z][a-zA-Z0-9_]*",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Procedure name declarations"
    },
    {
      "tokenType": "variable",
      "pattern": "(?<=VAR\\s+)[a-zA-Z][a-zA-Z0-9_]*",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Variable declarations in VAR blocks"
    },
    {
      "tokenType": "variable",
      "pattern": "(?<=CONST\\s+)[a-zA-Z][a-zA-Z0-9_]*",
      "tokenModifiers": [
        "declaration",
        "readonly"
      ],
      "description": "Constant declarations in CONST blocks"
    },
    {
      "tokenType": "modifier",
      "pattern": "\\b(REVEAL|UNSAFE|BRANDED|UNTRACED|READONLY)\\b",
      "tokenModifiers": [],
      "description": "Module and type modifiers"
    },
    {
      "tokenType": "class",
      "pattern": "\\bOBJECT\\b",
      "tokenModifiers": [],
      "description": "OBJECT keyword for class-like type definitions"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(METHODS|OVERRIDES)\\b",
      "tokenModifiers": [],
      "description": "Object method and override section keywords"
    },
    {
      "tokenType": "type",
      "pattern": "\\b(INTEGER|REAL|LONGREAL|EXTENDED|CHAR|BOOLEAN|TEXT|CARDINAL)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Built-in primitive types"
    },
    {
      "tokenType": "type",
      "pattern": "\\b(REFANY|ADDRESS|NULL|ROOT|MUTEX)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Built-in reference and system types"
    },
    {
      "tokenType": "type",
      "pattern": "\\b(ARRAY|RECORD|SET|SUBRANGE|REF)\\b",
      "tokenModifiers": [],
      "description": "Composite and reference type constructors"
    },
    {
      "tokenType": "enumMember",
      "pattern": "\\b(TRUE|FALSE|NIL)\\b",
      "tokenModifiers": [
        "readonly",
        "defaultLibrary"
      ],
      "description": "Built-in constant values TRUE, FALSE, NIL"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(ABS|MAX|MIN|ORD|VAL|NUMBER|FIRST|LAST|TYPECODE|NARROW|ISTYPE|LOOPHOLE|ADR|ADRSIZE|BITSIZE|BYTESIZE)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Built-in functions for arithmetic, ordinals, and type info"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(FLOAT|ROUND|TRUNC|CEILING|FLOOR)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Built-in floating-point conversion functions"
    },
    {
      "tokenType": "function",
      "pattern": "\\b(INC|DEC|NEW|DISPOSE|SUBARRAY)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Built-in memory and array manipulation procedures"
    },
    {
      "tokenType": "operator",
      "pattern": "\\b(OR|AND|NOT|DIV|MOD|IN)\\b",
      "tokenModifiers": [],
      "description": "Keyword operators: logical, division, modulo, set membership"
    },
    {
      "tokenType": "operator",
      "pattern": "(:=|#|<=|>=|<:|<>|\\.\\.|&|\\+|-|\\*|/|<|>|=|\\^)",
      "tokenModifiers": [],
      "description": "Symbol operators: assignment, not-equal, subtype, range, dereference"
    },
    {
      "tokenType": "property",
      "pattern": "(?<=\\.)\\s*[a-zA-Z][a-zA-Z0-9_]*",
      "tokenModifiers": [],
      "description": "Record field and object method access after dot"
    },
    {
      "tokenType": "namespace",
      "pattern": "[A-Z][a-zA-Z0-9_]*(?=\\.)",
      "tokenModifiers": [],
      "description": "Qualified module name before dot in qualified references"
    },
    {
      "tokenType": "type",
      "pattern": "(?<=TYPE\\s+)[A-Z][a-zA-Z0-9_]*",
      "tokenModifiers": [
        "declaration"
      ],
      "description": "Named type declarations in TYPE blocks"
    },
    {
      "tokenType": "comment",
      "pattern": "\\(\\*[\\s\\S]*?\\*\\)",
      "tokenModifiers": [],
      "description": "Block comments delimited by (* and *)"
    },
    {
      "tokenType": "string",
      "pattern": "\"(?:[^\"\\\\]|\\\\.)*\"",
      "tokenModifiers": [],
      "description": "String literals in double quotes"
    },
    {
      "tokenType": "string",
      "pattern": "'[^']*'",
      "tokenModifiers": [],
      "description": "Character literals in single quotes"
    },
    {
      "tokenType": "number",
      "pattern": "\\b\\d+_[0-9a-fA-F]+\\b|\\b\\d+\\.\\d+([DEde][+-]?\\d+)?\\b|\\b\\d+\\b",
      "tokenModifiers": [],
      "description": "Numeric literals: based integers (16_FF), floating-point with D/E exponent, and decimal integers"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\b(THREAD)\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Thread module keyword for concurrent programming"
    },
    {
      "tokenType": "variable",
      "pattern": "\\\\bthis\\\\b|\\\\bself\\\\b",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Self/this keyword semantic token"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\\\b(async|await|yield)\\\\b",
      "tokenModifiers": [
        "async"
      ],
      "description": "Async/concurrent keywords"
    },
    {
      "tokenType": "type",
      "pattern": "\\\\b(Promise|Future|Task|Observable)\\\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Concurrent/async types"
    },
    {
      "tokenType": "function",
      "pattern": "\\\\b(get|set)\\\\s+\\\\w+\\\\s*\\\\(",
      "tokenModifiers": [
        "definition"
      ],
      "description": "Getter/setter declarations"
    },
    {
      "tokenType": "variable",
      "pattern": "\\\\b_\\\\w+\\\\b",
      "tokenModifiers": [],
      "description": "Private/underscore-prefixed identifiers"
    },
    {
      "tokenType": "type",
      "pattern": "\\\\b(Array|List|Map|Set|Dict|Vector|HashMap|TreeMap)\\\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Collection types"
    },
    {
      "tokenType": "keyword",
      "pattern": "\\\\b(abstract|virtual|override|final|sealed)\\\\b",
      "tokenModifiers": [],
      "description": "OOP modifier keywords"
    },
    {
      "tokenType": "property",
      "pattern": "\\\\b(length|size|count|isEmpty|isNotEmpty)\\\\b",
      "tokenModifiers": [
        "readonly"
      ],
      "description": "Common read-only properties"
    },
    {
      "tokenType": "function",
      "pattern": "\\\\b(map|filter|reduce|forEach|find|some|every)\\\\b",
      "tokenModifiers": [],
      "description": "Iteration/functional methods"
    },
    {
      "tokenType": "modifier",
      "pattern": "\\\\b(override|static|readonly|const|final|volatile)\\\\b",
      "tokenModifiers": [],
      "description": "Member modifiers"
    },
    {
      "tokenType": "namespace",
      "pattern": "\\\\b(std|System|java|kotlin|swift|Foundation)\\\\b",
      "tokenModifiers": [
        "defaultLibrary"
      ],
      "description": "Standard library namespaces"
    },
    {
      "tokenType": "decorator",
      "pattern": "@[A-Z]\\\\w+",
      "tokenModifiers": [],
      "description": "Class/method annotations (PascalCase)"
    },
    {
      "tokenType": "typeParameter",
      "pattern": "<[A-Z](\\\\w*)>",
      "tokenModifiers": [],
      "description": "Single-letter and named type parameters"
    },
    {
      "tokenType": "event",
      "pattern": "\\\\b(onClick|onChange|onSubmit|onLoad|onError)\\\\b",
      "tokenModifiers": [],
      "description": "Common event handler names"
    },
    {
      "tokenType": "enumMember",
      "pattern": "\\\\b[A-Z][a-z]+[A-Z]\\\\w*\\\\b",
      "tokenModifiers": [],
      "description": "CamelCase identifiers (often enum values)"
    }
  ]
}
