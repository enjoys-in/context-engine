{
  "language": "ssh_config",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "property", "keyword", "comment", "string", "number"],
    "tokenModifiers": ["declaration", "definition", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "keyword",
      "pattern": "^\\s*(Host|Match)\\b",
      "modifiers": ["declaration"],
      "description": "Host and Match block declarations"
    },
    {
      "type": "property",
      "pattern": "^\\s*(HostName|User|Port|IdentityFile|IdentitiesOnly|ProxyJump|ProxyCommand|ForwardAgent|ForwardX11|LocalForward|RemoteForward|AddKeysToAgent|ServerAliveInterval|ServerAliveCountMax|StrictHostKeyChecking|UserKnownHostsFile|LogLevel|Compression|TCPKeepAlive|ConnectTimeout|ConnectionAttempts|BatchMode|RequestTTY|PermitLocalCommand|SendEnv|SetEnv|Include)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "SSH configuration directive keywords"
    },
    {
      "type": "string",
      "pattern": "\\b(yes|no)\\b",
      "modifiers": [],
      "description": "Boolean values yes/no"
    },
    {
      "type": "variable",
      "pattern": "%([dlhknprtu]|\\{[^}]+\\})",
      "modifiers": [],
      "description": "Token substitutions like %h, %u, %r, %{host}"
    },
    {
      "type": "string",
      "pattern": "~/.ssh/[a-zA-Z0-9_./\\-]+",
      "modifiers": [],
      "description": "Common SSH file paths"
    },
    {
      "type": "comment",
      "pattern": "#[^\\n]*",
      "modifiers": [],
      "description": "Line comments starting with #"
    },
    {
      "type": "number",
      "pattern": "\\b([0-9]+)\\b",
      "modifiers": [],
      "description": "Numeric values for ports and timeouts"
    }
  ]
}
