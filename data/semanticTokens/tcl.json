{
  "language": "tcl",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "variable", "parameter", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "function",
      "pattern": "\\bproc\\s+([a-zA-Z_:][a-zA-Z0-9_:]*)\\b",
      "modifiers": ["declaration"],
      "description": "Procedure declarations with proc"
    },
    {
      "type": "variable",
      "pattern": "\\$([a-zA-Z_][a-zA-Z0-9_]*)",
      "modifiers": [],
      "description": "Variable references with $ prefix"
    },
    {
      "type": "variable",
      "pattern": "\\bset\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "modifiers": ["declaration"],
      "description": "Variable assignments with set command"
    },
    {
      "type": "keyword",
      "pattern": "\\b(upvar|uplevel|global|variable|unset|array|info|rename)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Variable scope and management commands"
    },
    {
      "type": "namespace",
      "pattern": "\\bnamespace\\s+(eval|export|import|current|path|children|ensemble)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Namespace subcommands"
    },
    {
      "type": "keyword",
      "pattern": "\\b(if|else|elseif|while|for|foreach|switch|break|continue|return|catch|try|throw|error)\\b",
      "modifiers": [],
      "description": "Control flow keywords"
    },
    {
      "type": "function",
      "pattern": "\\b(expr|eval|source|exec|open|close|read|puts|gets|format|scan|regexp|regsub|string|list|lindex|lsearch|lsort|llength|lappend|lrange|lreplace|dict|file|glob|clock|after|vwait|update)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Built-in Tcl commands"
    },
    {
      "type": "keyword",
      "pattern": "\\bpackage\\s+(require|provide|ifneeded)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Package management commands"
    },
    {
      "type": "function",
      "pattern": "\\binterp\\s+(create|delete|eval|alias|expose|hide|invokehidden)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Interpreter management commands"
    },
    {
      "type": "comment",
      "pattern": "#[^\\n]*",
      "modifiers": [],
      "description": "Line comments starting with #"
    }
  ]
}
