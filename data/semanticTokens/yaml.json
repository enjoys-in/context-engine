{
  "language": "yaml",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["variable", "property", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "readonly"]
  },
  "semanticRules": [
    {
      "type": "property",
      "pattern": "^\\s*([a-zA-Z_][a-zA-Z0-9_.\\-]*)\\s*:",
      "modifiers": ["declaration"],
      "description": "Mapping key declarations"
    },
    {
      "type": "string",
      "pattern": "(\"[^\"]*\"|'[^']*')",
      "modifiers": [],
      "description": "Quoted string values"
    },
    {
      "type": "number",
      "pattern": ":\\s*([+-]?(\\.[0-9]+|[0-9]+(\\.[0-9]*)?)([eE][+-]?[0-9]+)?|0x[0-9a-fA-F]+|0o[0-7]+)\\s*$",
      "modifiers": [],
      "description": "Numeric values including hex and octal"
    },
    {
      "type": "keyword",
      "pattern": ":\\s*(true|false|yes|no|on|off|null|~)\\s*$",
      "modifiers": [],
      "description": "Boolean and null values"
    },
    {
      "type": "variable",
      "pattern": "&([a-zA-Z_][a-zA-Z0-9_]*)",
      "modifiers": ["declaration"],
      "description": "Anchor definitions with &"
    },
    {
      "type": "variable",
      "pattern": "\\*([a-zA-Z_][a-zA-Z0-9_]*)",
      "modifiers": ["readonly"],
      "description": "Alias references with *"
    },
    {
      "type": "operator",
      "pattern": "!!([a-zA-Z_][a-zA-Z0-9_:.]*)",
      "modifiers": [],
      "description": "Tag declarations with !!"
    },
    {
      "type": "operator",
      "pattern": "^\\s*(\\||>)[-+]?\\s*$",
      "modifiers": [],
      "description": "Block scalar indicators | and >"
    },
    {
      "type": "keyword",
      "pattern": "^---\\s*$|^\\.\\.\\.\\s*$",
      "modifiers": [],
      "description": "Document start (---) and end (...) markers"
    },
    {
      "type": "comment",
      "pattern": "#[^\\n]*",
      "modifiers": [],
      "description": "Line comments starting with #"
    }
  ]
}
