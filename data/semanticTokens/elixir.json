{
  "language": "elixir",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["namespace", "function", "macro", "variable", "keyword", "operator", "property", "type", "decorator", "string"],
    "tokenModifiers": ["declaration", "definition", "readonly", "deprecated", "documentation", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "namespace",
      "pattern": "\\bdefmodule\\s+([A-Z][a-zA-Z0-9_.]+)\\b",
      "modifiers": ["declaration"],
      "description": "Module declarations (defmodule)"
    },
    {
      "type": "function",
      "pattern": "\\bdef\\s+([a-z_][a-zA-Z0-9_!?]*)\\b",
      "modifiers": ["definition"],
      "description": "Public function definitions (def)"
    },
    {
      "type": "function",
      "pattern": "\\bdefp\\s+([a-z_][a-zA-Z0-9_!?]*)\\b",
      "modifiers": ["definition"],
      "description": "Private function definitions (defp)"
    },
    {
      "type": "operator",
      "pattern": "\\|>",
      "modifiers": [],
      "description": "Pipe operator (|>)"
    },
    {
      "type": "decorator",
      "pattern": "@(moduledoc|doc|spec|type|typep|callback|behaviour|impl|derive)\\b",
      "modifiers": ["documentation"],
      "description": "Module attributes for documentation and types"
    },
    {
      "type": "variable",
      "pattern": "\\b([a-z_][a-zA-Z0-9_]*)\\s*=",
      "modifiers": ["declaration"],
      "description": "Pattern matching / variable binding"
    },
    {
      "type": "property",
      "pattern": ":[a-z_][a-zA-Z0-9_]*",
      "modifiers": ["readonly"],
      "description": "Atoms (:atom_name)"
    },
    {
      "type": "macro",
      "pattern": "\\b(defmacro|defmacrop|quote|unquote|use|require|import|alias)\\b",
      "modifiers": [],
      "description": "Macro definitions and metaprogramming keywords"
    },
    {
      "type": "keyword",
      "pattern": "\\b(case|cond|with|if|unless|try|catch|rescue|after|raise|throw)\\b",
      "modifiers": [],
      "description": "Control flow and pattern matching keywords"
    },
    {
      "type": "type",
      "pattern": "\\b(defstruct|defprotocol|defimpl)\\b",
      "modifiers": ["definition"],
      "description": "Struct and protocol definitions"
    },
    {
      "type": "function",
      "pattern": "\\b(Enum|Map|List|String|IO|Kernel|Agent|GenServer|Task|Supervisor)\\.[a-z_][a-zA-Z0-9_!?]*",
      "modifiers": ["defaultLibrary"],
      "description": "Standard library module function calls"
    }
  ]
}
