{
  "language": "html",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["type", "variable", "property", "event", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "deprecated", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "type",
      "pattern": "(?<=<\\/?)\\s*[a-zA-Z][a-zA-Z0-9-]*",
      "modifiers": [],
      "description": "HTML tag names in opening and closing tags"
    },
    {
      "type": "property",
      "pattern": "\\b[a-zA-Z_-][a-zA-Z0-9_-]*(?=\\s*=)",
      "modifiers": [],
      "description": "Attribute names in HTML elements"
    },
    {
      "type": "string",
      "pattern": "(?<==\\s*)\"[^\"]*\"|'[^']*'",
      "modifiers": [],
      "description": "Attribute values in quotes"
    },
    {
      "type": "variable",
      "pattern": "&[a-zA-Z]+;|&#[0-9]+;|&#x[0-9a-fA-F]+;",
      "modifiers": ["defaultLibrary"],
      "description": "HTML character entities like &amp; &#160; &#x20;"
    },
    {
      "type": "event",
      "pattern": "\\bon[a-z]+(?=\\s*=)",
      "modifiers": [],
      "description": "Event handler attributes like onclick, onload, onsubmit"
    },
    {
      "type": "property",
      "pattern": "\\b(id|class)(?=\\s*=)",
      "modifiers": ["definition"],
      "description": "Id and class attribute references"
    },
    {
      "type": "keyword",
      "pattern": "<!DOCTYPE[^>]*>",
      "modifiers": [],
      "description": "DOCTYPE declaration"
    },
    {
      "type": "comment",
      "pattern": "<!--[\\s\\S]*?-->",
      "modifiers": ["documentation"],
      "description": "HTML comments"
    },
    {
      "type": "type",
      "pattern": "\\b(div|span|p|a|img|input|button|form|table|tr|td|th|ul|ol|li|h[1-6]|section|article|nav|header|footer|main|aside)\\b",
      "modifiers": ["defaultLibrary"],
      "description": "Common built-in HTML element names"
    },
    {
      "type": "property",
      "pattern": "\\b(data-[a-zA-Z0-9-]+)(?=\\s*=)",
      "modifiers": [],
      "description": "Custom data attributes (data-*)"
    }
  ]
}
