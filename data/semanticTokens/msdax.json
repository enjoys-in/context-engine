{
  "language": "msdax",
  "tokenTypes": ["namespace", "type", "class", "enum", "interface", "struct", "typeParameter", "parameter", "variable", "property", "enumMember", "event", "function", "method", "macro", "keyword", "modifier", "comment", "string", "number", "regexp", "operator", "decorator"],
  "tokenModifiers": ["declaration", "definition", "readonly", "static", "deprecated", "abstract", "async", "modification", "documentation", "defaultLibrary"],
  "tokenLegend": {
    "tokenTypes": ["type", "variable", "property", "function", "keyword", "comment", "string", "number", "operator"],
    "tokenModifiers": ["declaration", "definition", "defaultLibrary"]
  },
  "semanticRules": [
    {
      "type": "function",
      "pattern": "\\b(CALCULATE|CALCULATETABLE|SUMX|AVERAGEX|COUNTX|MINX|MAXX|RANKX|FILTER|ALL|ALLEXCEPT|ALLSELECTED|VALUES|DISTINCT|RELATED|RELATEDTABLE|EARLIER|EARLIEST|USERELATIONSHIP|CROSSFILTER|TREATAS|SUMMARIZE|SUMMARIZECOLUMNS|ADDCOLUMNS|SELECTCOLUMNS|TOPN|GENERATE|GENERATEALL|UNION|INTERSECT|EXCEPT|DATATABLE|ROW|BLANK|ERROR)\\s*(?=\\()",
      "modifiers": ["defaultLibrary"],
      "description": "DAX table and filter functions"
    },
    {
      "type": "function",
      "pattern": "\\b(SUM|AVERAGE|COUNT|COUNTA|COUNTBLANK|COUNTROWS|MIN|MAX|DIVIDE|IF|SWITCH|AND|OR|NOT|TRUE|FALSE|FORMAT|YEAR|MONTH|DAY|DATE|NOW|TODAY|DATEDIFF|DATEADD|TOTALYTD|TOTALQTD|TOTALMTD|SAMEPERIODLASTYEAR|PARALLELPERIOD|CLOSINGBALANCEMONTH|OPENINGBALANCEMONTH)\\s*(?=\\()",
      "modifiers": ["defaultLibrary"],
      "description": "DAX aggregation, logical, date, and time intelligence functions"
    },
    {
      "type": "variable",
      "pattern": "(?<=DEFINE\\s+(?:MEASURE|VAR)\\s+)[a-zA-Z_'][a-zA-Z0-9_ ']*",
      "modifiers": ["declaration"],
      "description": "Measure and variable declarations in DEFINE blocks"
    },
    {
      "type": "property",
      "pattern": "'?[a-zA-Z_][a-zA-Z0-9_ ]*'?\\[[a-zA-Z_][a-zA-Z0-9_ ]*\\]",
      "modifiers": [],
      "description": "Table[Column] references for calculated columns"
    },
    {
      "type": "type",
      "pattern": "'[a-zA-Z_][a-zA-Z0-9_ ]*'",
      "modifiers": [],
      "description": "Table references in single quotes"
    },
    {
      "type": "variable",
      "pattern": "\\[[a-zA-Z_][a-zA-Z0-9_ ]*\\]",
      "modifiers": [],
      "description": "Measure references in square brackets"
    },
    {
      "type": "keyword",
      "pattern": "\\b(DEFINE|MEASURE|VAR|RETURN|EVALUATE|ORDER BY|ASC|DESC|START AT)\\b",
      "modifiers": [],
      "description": "DAX query and definition keywords"
    },
    {
      "type": "operator",
      "pattern": "(&&|\\|\\||<>|>=|<=|\\+|-|\\*|/|&|=|<|>)",
      "modifiers": [],
      "description": "DAX operators: arithmetic, comparison, logical, and concatenation"
    },
    {
      "type": "comment",
      "pattern": "//.*$|/\\*[\\s\\S]*?\\*/",
      "modifiers": ["documentation"],
      "description": "Single-line and multi-line DAX comments"
    },
    {
      "type": "string",
      "pattern": "\"(?:[^\"]|\"\")*\"",
      "modifiers": [],
      "description": "String literals with double-quote escaping"
    },
    {
      "type": "number",
      "pattern": "-?\\d+\\.?\\d*",
      "modifiers": [],
      "description": "Numeric literals"
    }
  ]
}
