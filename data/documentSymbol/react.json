{
  "language": "react",
  "symbolPatterns": [
    {
      "name": "FunctionalComponentExport",
      "pattern": "export\\s+(?:default\\s+)?function\\s+([A-Z][a-zA-Z0-9]*)",
      "captureGroup": 1,
      "kind": 11,
      "detail": "Exported React functional component"
    },
    {
      "name": "ConstComponentExport",
      "pattern": "export\\s+(?:default\\s+)?const\\s+([A-Z][a-zA-Z0-9]*)\\s*(?::\\s*React\\.FC)?\\s*=",
      "captureGroup": 1,
      "kind": 12,
      "detail": "Exported const React component"
    },
    {
      "name": "ArrowComponentConst",
      "pattern": "const\\s+([A-Z][a-zA-Z0-9]*)\\s*(?::\\s*React\\.FC[^=]*)?\\s*=\\s*(?:\\([^)]*\\)|[a-zA-Z_$][a-zA-Z0-9_$]*)\\s*=>",
      "captureGroup": 1,
      "kind": 12,
      "detail": "Arrow function React component"
    },
    {
      "name": "ClassComponent",
      "pattern": "class\\s+([A-Z][a-zA-Z0-9]*)\\s+extends\\s+(?:React\\.)?(?:Component|PureComponent)",
      "captureGroup": 1,
      "kind": 4,
      "detail": "Class-based React component"
    },
    {
      "name": "CustomHook",
      "pattern": "(?:export\\s+)?(?:function|const)\\s+(use[A-Z][a-zA-Z0-9]*)\\s*(?:=|\\()",
      "captureGroup": 1,
      "kind": 11,
      "detail": "Custom React hook"
    },
    {
      "name": "CreateContext",
      "pattern": "(?:export\\s+)?const\\s+([A-Za-z][a-zA-Z0-9]*Context)\\s*=\\s*(?:React\\.)?createContext",
      "captureGroup": 1,
      "kind": 12,
      "detail": "React Context"
    },
    {
      "name": "MemoComponent",
      "pattern": "(?:export\\s+)?const\\s+([A-Z][a-zA-Z0-9]*)\\s*=\\s*(?:React\\.)?memo\\s*\\(",
      "captureGroup": 1,
      "kind": 12,
      "detail": "Memoized React component"
    },
    {
      "name": "ForwardRefComponent",
      "pattern": "(?:export\\s+)?const\\s+([A-Z][a-zA-Z0-9]*)\\s*=\\s*(?:React\\.)?forwardRef\\s*[<(]",
      "captureGroup": 1,
      "kind": 12,
      "detail": "forwardRef React component"
    },
    {
      "name": "LazyComponent",
      "pattern": "const\\s+([A-Z][a-zA-Z0-9]*)\\s*=\\s*(?:React\\.)?lazy\\s*\\(",
      "captureGroup": 1,
      "kind": 12,
      "detail": "Lazy-loaded React component"
    },
    {
      "name": "ReducerFunction",
      "pattern": "(?:export\\s+)?(?:function|const)\\s+([a-z][a-zA-Z0-9]*Reducer)\\s*(?:=|\\()",
      "captureGroup": 1,
      "kind": 11,
      "detail": "Reducer function"
    },
    {
      "name": "ActionType",
      "pattern": "type\\s+([A-Z][a-zA-Z0-9]*Action)\\s*=",
      "captureGroup": 1,
      "kind": 12,
      "detail": "TypeScript action type"
    },
    {
      "name": "HOCFunction",
      "pattern": "(?:export\\s+)?(?:function|const)\\s+(with[A-Z][a-zA-Z0-9]*)\\s*(?:=|\\(|<)",
      "captureGroup": 1,
      "kind": 11,
      "detail": "Higher-Order Component"
    },
    {
      "name": "PropsInterface",
      "pattern": "(?:export\\s+)?interface\\s+([A-Z][a-zA-Z0-9]*Props)\\s*(?:<[^>]*>)?\\s*\\{",
      "captureGroup": 1,
      "kind": 4,
      "detail": "Component props interface"
    },
    {
      "name": "StateInterface",
      "pattern": "(?:export\\s+)?interface\\s+([A-Z][a-zA-Z0-9]*State)\\s*\\{",
      "captureGroup": 1,
      "kind": 4,
      "detail": "Component state interface"
    },
    {
      "name": "TypeAlias",
      "pattern": "(?:export\\s+)?type\\s+([A-Z][a-zA-Z0-9]*)\\s*(?:<[^>]*>)?\\s*=",
      "captureGroup": 1,
      "kind": 12,
      "detail": "TypeScript type alias"
    },
    {
      "name": "ContextProvider",
      "pattern": "(?:export\\s+)?(?:function|const)\\s+([A-Z][a-zA-Z0-9]*Provider)\\s*(?:=|\\(|:)",
      "captureGroup": 1,
      "kind": 11,
      "detail": "Context Provider component"
    },
    {
      "name": "EventHandler",
      "pattern": "const\\s+(handle[A-Z][a-zA-Z0-9]*)\\s*=\\s*(?:useCallback\\()?",
      "captureGroup": 1,
      "kind": 11,
      "detail": "Event handler function"
    },
    {
      "name": "DefaultExport",
      "pattern": "export\\s+default\\s+([A-Z][a-zA-Z0-9]*)",
      "captureGroup": 1,
      "kind": 1,
      "detail": "Default exported component"
    },
    {
      "name": "ConstantDeclaration",
      "pattern": "(?:export\\s+)?const\\s+([A-Z_][A-Z_0-9]*)\\s*=",
      "captureGroup": 1,
      "kind": 13,
      "detail": "Constant declaration"
    },
    {
      "name": "EnumDeclaration",
      "pattern": "(?:export\\s+)?enum\\s+([A-Z][a-zA-Z0-9]*)\\s*\\{",
      "captureGroup": 1,
      "kind": 12,
      "detail": "TypeScript enum"
    }
  ]
}