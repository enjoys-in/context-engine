{
  "language": "react",
  "symbolPatterns": [
    {
      "name": "Function Component Export",
      "pattern": "export\\s+(?:default\\s+)?function\\s+([A-Z]\\w*)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function-component"
    },
    {
      "name": "Const Component Export",
      "pattern": "export\\s+(?:default\\s+)?const\\s+([A-Z]\\w*)\\s*(?::\\s*React\\.FC[^=]*)?\\s*=",
      "captureGroup": 1,
      "kind": 12,
      "type": "const-component"
    },
    {
      "name": "Class Component",
      "pattern": "class\\s+([A-Z]\\w*)\\s+extends\\s+(?:React\\.)?(?:Component|PureComponent)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class-component"
    },
    {
      "name": "useState",
      "pattern": "const\\s+\\[(\\w+),\\s*set\\w+\\]\\s*=\\s*useState",
      "captureGroup": 1,
      "kind": 12,
      "type": "use-state"
    },
    {
      "name": "useEffect",
      "pattern": "(useEffect)\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "use-effect"
    },
    {
      "name": "useContext",
      "pattern": "const\\s+(\\w+)\\s*=\\s*useContext\\s*\\(",
      "captureGroup": 1,
      "kind": 12,
      "type": "use-context"
    },
    {
      "name": "useReducer",
      "pattern": "const\\s+\\[(\\w+),\\s*\\w+\\]\\s*=\\s*useReducer\\s*\\(",
      "captureGroup": 1,
      "kind": 12,
      "type": "use-reducer"
    },
    {
      "name": "useMemo",
      "pattern": "const\\s+(\\w+)\\s*=\\s*useMemo\\s*\\(",
      "captureGroup": 1,
      "kind": 12,
      "type": "use-memo"
    },
    {
      "name": "useCallback",
      "pattern": "const\\s+(\\w+)\\s*=\\s*useCallback\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "use-callback"
    },
    {
      "name": "useRef",
      "pattern": "const\\s+(\\w+)\\s*=\\s*useRef\\s*[<(]",
      "captureGroup": 1,
      "kind": 12,
      "type": "use-ref"
    },
    {
      "name": "Custom Hook",
      "pattern": "(?:export\\s+)?(?:function|const)\\s+(use[A-Z]\\w*)\\s*[=(]",
      "captureGroup": 1,
      "kind": 11,
      "type": "custom-hook"
    },
    {
      "name": "JSX Element",
      "pattern": "<([A-Z]\\w*)(?:\\s|>|/)",
      "captureGroup": 1,
      "kind": 12,
      "type": "jsx-element"
    },
    {
      "name": "Props Destructuring",
      "pattern": "(?:function\\s+\\w+|=>)\\s*\\(\\s*\\{\\s*([^}]+)\\}",
      "captureGroup": 1,
      "kind": 7,
      "type": "props-destructure"
    },
    {
      "name": "createContext",
      "pattern": "(?:export\\s+)?const\\s+(\\w+)\\s*=\\s*(?:React\\.)?createContext",
      "captureGroup": 1,
      "kind": 12,
      "type": "context"
    },
    {
      "name": "forwardRef",
      "pattern": "(?:export\\s+)?const\\s+([A-Z]\\w*)\\s*=\\s*(?:React\\.)?forwardRef\\s*[<(]",
      "captureGroup": 1,
      "kind": 12,
      "type": "forward-ref"
    },
    {
      "name": "memo",
      "pattern": "(?:export\\s+)?const\\s+([A-Z]\\w*)\\s*=\\s*(?:React\\.)?memo\\s*\\(",
      "captureGroup": 1,
      "kind": 12,
      "type": "memo"
    },
    {
      "name": "Suspense",
      "pattern": "<(Suspense)\\s+fallback=",
      "captureGroup": 1,
      "kind": 12,
      "type": "suspense"
    },
    {
      "name": "lazy",
      "pattern": "const\\s+([A-Z]\\w*)\\s*=\\s*(?:React\\.)?lazy\\s*\\(",
      "captureGroup": 1,
      "kind": 12,
      "type": "lazy"
    },
    {
      "name": "ErrorBoundary",
      "pattern": "class\\s+([A-Z]\\w*)\\s+extends\\s+(?:React\\.)?Component[^{]*componentDidCatch|class\\s+(\\w*ErrorBoundary)\\s+extends",
      "captureGroup": 1,
      "kind": 4,
      "type": "error-boundary"
    },
    {
      "name": "defaultProps",
      "pattern": "(\\w+)\\.defaultProps\\s*=",
      "captureGroup": 1,
      "kind": 6,
      "type": "default-props"
    },
    {
      "name": "propTypes",
      "pattern": "(\\w+)\\.propTypes\\s*=",
      "captureGroup": 1,
      "kind": 6,
      "type": "prop-types"
    },
    {
      "name": "Context Provider",
      "pattern": "(?:export\\s+)?(?:function|const)\\s+([A-Z]\\w*Provider)\\s*[=(]",
      "captureGroup": 1,
      "kind": 11,
      "type": "context-provider"
    },
    {
      "name": "Reducer Function",
      "pattern": "(?:export\\s+)?(?:function|const)\\s+(\\w+Reducer)\\s*[=(]",
      "captureGroup": 1,
      "kind": 11,
      "type": "reducer"
    },
    {
      "name": "HOC",
      "pattern": "(?:export\\s+)?(?:function|const)\\s+(with[A-Z]\\w*)\\s*[=(]",
      "captureGroup": 1,
      "kind": 11,
      "type": "hoc"
    }
  ]
}
