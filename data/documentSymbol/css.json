{
  "language": "css",
  "symbolPatterns": [
    {
      "name": "Class Selector",
      "pattern": "(\\.([a-zA-Z_][a-zA-Z0-9_-]*))\\s*(?:[{,>+~\\s])",
      "captureGroup": 1,
      "kind": "Class",
      "type": "5"
    },
    {
      "name": "ID Selector",
      "pattern": "(#([a-zA-Z_][a-zA-Z0-9_-]*))\\s*(?=[{,>+~\\s])",
      "captureGroup": 1,
      "kind": "Constant",
      "type": "13"
    },
    {
      "name": "Element Selector",
      "pattern": "^\\s*([a-zA-Z][a-zA-Z0-9]*)\\s*(?=[{,>+~:\\[\\s])",
      "captureGroup": 1,
      "kind": "Field",
      "type": "7"
    },
    {
      "name": "@media Query",
      "pattern": "@media\\s+([^{]+)\\s*\\{",
      "captureGroup": 1,
      "kind": "Namespace",
      "type": "2"
    },
    {
      "name": "@keyframes Animation",
      "pattern": "@keyframes\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\s*\\{",
      "captureGroup": 1,
      "kind": "Function",
      "type": "11"
    },
    {
      "name": "Custom Property",
      "pattern": "--(([a-zA-Z_][a-zA-Z0-9_-]*))\\s*:",
      "captureGroup": 1,
      "kind": "Variable",
      "type": "12"
    },
    {
      "name": "@font-face",
      "pattern": "@font-face\\s*\\{[^}]*font-family\\s*:\\s*['\"]?([^'\";}]+)",
      "captureGroup": 1,
      "kind": "Struct",
      "type": "22"
    },
    {
      "name": "@layer",
      "pattern": "@layer\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\s*[{;]",
      "captureGroup": 1,
      "kind": "Module",
      "type": "1"
    },
    {
      "name": "@import",
      "pattern": "@import\\s+(?:url\\()?['\"]?([^'\"\\);]+)",
      "captureGroup": 1,
      "kind": "Package",
      "type": "3"
    },
    {
      "name": "@supports Feature Query",
      "pattern": "@supports\\s+([^{]+)\\s*\\{",
      "captureGroup": 1,
      "kind": "Interface",
      "type": "10"
    },
    {
      "name": "@container Query",
      "pattern": "@container\\s+(?:([a-zA-Z_][a-zA-Z0-9_-]*)\\s+)?\\([^)]+\\)\\s*\\{",
      "captureGroup": 1,
      "kind": "Event",
      "type": "23"
    },
    {
      "name": "@property Registration",
      "pattern": "@property\\s+--(([a-zA-Z_][a-zA-Z0-9_-]*))\\s*\\{",
      "captureGroup": 1,
      "kind": "Property",
      "type": "6"
    },
    {
      "name": "Compound Selector",
      "pattern": "([.#]?[a-zA-Z_][a-zA-Z0-9_-]*(?:\\s*[>+~]\\s*[.#]?[a-zA-Z_][a-zA-Z0-9_-]*)+)\\s*\\{",
      "captureGroup": 1,
      "kind": "String",
      "type": "14"
    }
  ]
}