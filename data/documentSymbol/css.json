{
  "language": "css",
  "symbolPatterns": [
    {
      "name": "Class Selector",
      "pattern": "\\.([a-zA-Z_][a-zA-Z0-9_-]*)\\s*[{,>+~\\s]",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "ID Selector",
      "pattern": "#([a-zA-Z_][a-zA-Z0-9_-]*)\\s*[{,>+~\\s]",
      "captureGroup": 1,
      "kind": 19,
      "type": "id"
    },
    {
      "name": "Element Selector",
      "pattern": "^\\s*([a-zA-Z][a-zA-Z0-9]*)\\s*[{,>+~:\\[\\s]",
      "captureGroup": 1,
      "kind": 7,
      "type": "element"
    },
    {
      "name": "@media Query",
      "pattern": "@media\\s+([^{]+?)\\s*\\{",
      "captureGroup": 1,
      "kind": 2,
      "type": "media-query"
    },
    {
      "name": "@keyframes",
      "pattern": "@keyframes\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\s*\\{",
      "captureGroup": 1,
      "kind": 11,
      "type": "keyframes"
    },
    {
      "name": "@font-face",
      "pattern": "@font-face\\s*\\{[^}]*font-family:\\s*[\"']?([^\"';}]+)",
      "captureGroup": 1,
      "kind": 22,
      "type": "font-face"
    },
    {
      "name": "@import",
      "pattern": "@import\\s+(?:url\\()?[\"']?([^\"')\\s;]+)",
      "captureGroup": 1,
      "kind": 3,
      "type": "import"
    },
    {
      "name": "@supports",
      "pattern": "@supports\\s+([^{]+?)\\s*\\{",
      "captureGroup": 1,
      "kind": 10,
      "type": "supports"
    },
    {
      "name": "@layer",
      "pattern": "@layer\\s+([a-zA-Z_][a-zA-Z0-9_.-]*)\\s*[{;]",
      "captureGroup": 1,
      "kind": 1,
      "type": "layer"
    },
    {
      "name": "CSS Variable",
      "pattern": "(--[a-zA-Z_][a-zA-Z0-9_-]*)\\s*:",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Pseudo-class",
      "pattern": ":(?!:)([a-zA-Z][a-zA-Z0-9-]*)(?:\\([^)]*\\))?",
      "captureGroup": 1,
      "kind": 6,
      "type": "pseudo-class"
    },
    {
      "name": "Pseudo-element",
      "pattern": "::([a-zA-Z][a-zA-Z0-9-]*)",
      "captureGroup": 1,
      "kind": 6,
      "type": "pseudo-element"
    },
    {
      "name": "Property Declaration",
      "pattern": "^\\s+([a-zA-Z-][a-zA-Z0-9-]*)\\s*:",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": ":root Selector",
      "pattern": "(:root)\\s*\\{",
      "captureGroup": 1,
      "kind": 2,
      "type": "root"
    },
    {
      "name": "@container Query",
      "pattern": "@container\\s+([a-zA-Z_][\\w-]*)\\s*\\(",
      "captureGroup": 1,
      "kind": 2,
      "type": "container"
    },
    {
      "name": "CallbackDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(function|=>|->)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "GenericTypeDeclaration",
      "pattern": "\\\\b(\\\\w+)<[^>]+>",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "ClosureDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(\\\\(|\\\\|)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "TestDeclaration",
      "pattern": "\\\\b(?:test|it|describe|spec)\\\\s*\\\\(?['\"]([^'\"]+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "ErrorDeclaration",
      "pattern": "\\\\b(?:class|type)\\\\s+(\\\\w*Error|\\\\w*Exception)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "ConfigObjectDeclaration",
      "pattern": "\\\\b(config|options|settings)\\\\s*[:=]\\\\s*\\\\{",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "GetterDeclaration",
      "pattern": "\\\\bget\\\\s+(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
