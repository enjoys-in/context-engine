{
  "language": "pascal",
  "symbolPatterns": [
    {
      "name": "Program",
      "pattern": "^\\s*program\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Unit",
      "pattern": "^\\s*unit\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Procedure",
      "pattern": "^\\s*procedure\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Function",
      "pattern": "^\\s*function\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Type",
      "pattern": "^\\s*(T\\w+)\\s*=\\s*class",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Record",
      "pattern": "^\\s*(\\w+)\\s*=\\s*record",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Variable",
      "pattern": "(?:var|let|const|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
