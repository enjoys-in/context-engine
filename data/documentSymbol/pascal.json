{
  "language": "pascal",
  "symbolPatterns": [
    {
      "name": "Program",
      "pattern": "^\\s*program\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Unit",
      "pattern": "^\\s*unit\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Uses Clause",
      "pattern": "^\\s*uses\\s+([\\w,\\s]+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Type Class",
      "pattern": "^\\s*(\\w+)\\s*=\\s*class",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Type Record",
      "pattern": "^\\s*(\\w+)\\s*=\\s*record",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Type Object",
      "pattern": "^\\s*(\\w+)\\s*=\\s*object",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Type Alias",
      "pattern": "^\\s*(\\w+)\\s*=\\s*type\\s+",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Type Enum",
      "pattern": "^\\s*(\\w+)\\s*=\\s*\\(",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Interface Section",
      "pattern": "^\\s*(interface)\\s*$",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Implementation Section",
      "pattern": "^\\s*(implementation)\\s*$",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Procedure",
      "pattern": "^\\s*(?:class\\s+)?procedure\\s+(?:\\w+\\.)?(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Function",
      "pattern": "^\\s*(?:class\\s+)?function\\s+(?:\\w+\\.)?(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Constructor",
      "pattern": "^\\s*constructor\\s+(?:\\w+\\.)?(\\w+)",
      "captureGroup": 1,
      "kind": 8,
      "type": "constructor"
    },
    {
      "name": "Destructor",
      "pattern": "^\\s*destructor\\s+(?:\\w+\\.)?(\\w+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Const",
      "pattern": "^\\s*(\\w+)\\s*=\\s*[^(;]+;",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Var",
      "pattern": "^\\s*(\\w+)\\s*:\\s*\\w+",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Property",
      "pattern": "^\\s*property\\s+(\\w+)\\s*:",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Class Method",
      "pattern": "^\\s*class\\s+(?:procedure|function)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Virtual Method",
      "pattern": "^\\s*(?:procedure|function)\\s+(\\w+)[^;]*;\\s*virtual",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Override Method",
      "pattern": "^\\s*(?:procedure|function)\\s+(\\w+)[^;]*;\\s*override",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Abstract Method",
      "pattern": "^\\s*(?:procedure|function)\\s+(\\w+)[^;]*;\\s*(?:virtual;\\s*)?abstract",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Forward Declaration",
      "pattern": "^\\s*(?:procedure|function)\\s+(\\w+)[^;]*;\\s*forward",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    }
  ]
}
