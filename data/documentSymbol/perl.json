{
  "language": "perl",
  "symbolPatterns": [
    {
      "name": "Package",
      "pattern": "^\\s*package\\s+([\\w:]+)",
      "captureGroup": 1,
      "kind": 3,
      "type": "package"
    },
    {
      "name": "Subroutine",
      "pattern": "^\\s*sub\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Method",
      "pattern": "^\\s*sub\\s+(\\w+)\\s*\\{[^}]*my\\s*\\(\\s*\\$self",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Use",
      "pattern": "^\\s*use\\s+([\\w:]+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Require",
      "pattern": "^\\s*require\\s+([\\w:]+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "My Variable",
      "pattern": "^\\s*my\\s+([\\$@%]\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Our Variable",
      "pattern": "^\\s*our\\s+([\\$@%]\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Local Variable",
      "pattern": "^\\s*local\\s+([\\$@%]\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Constant",
      "pattern": "^\\s*use\\s+constant\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Constant Hash",
      "pattern": "^\\s*use\\s+constant\\s+\\{\\s*(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "POD Head1",
      "pattern": "^=head1\\s+(.+)$",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "POD Head2",
      "pattern": "^=head2\\s+(.+)$",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Here-doc",
      "pattern": "<<\\s*['\"]?(\\w+)['\"]?",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "BEGIN Block",
      "pattern": "^\\s*(BEGIN)\\s*\\{",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "END Block",
      "pattern": "^\\s*(END)\\s*\\{",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "INIT Block",
      "pattern": "^\\s*(INIT)\\s*\\{",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "CHECK Block",
      "pattern": "^\\s*(CHECK)\\s*\\{",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Moose Has",
      "pattern": "^\\s*has\\s+['\"]?(\\w+)['\"]?",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Moose Extends",
      "pattern": "^\\s*extends\\s+['\"]([\\w:]+)['\"]",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Moose With",
      "pattern": "^\\s*with\\s+['\"]([\\w:]+)['\"]",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Regex Binding",
      "pattern": "=~\\s*(?:s|tr|y|m)?/((?:[^/\\\\]|\\\\.)+)/",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Readonly",
      "pattern": "^\\s*(?:Readonly::)?Readonly\\s+my\\s+([\\$@%]\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    }
  ]
}
