{
  "language": "perl",
  "symbolPatterns": [
    {
      "name": "Subroutine",
      "pattern": "^\\\\s*sub\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Package",
      "pattern": "^\\\\s*package\\\\s+([\\\\w:]+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Variable",
      "pattern": "^\\\\s*my\\\\s+\\\\$?(\\\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    }
  ]
}
