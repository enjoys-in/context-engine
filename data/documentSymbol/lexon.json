{
  "language": "lexon",
  "symbolPatterns": [
    {
      "name": "Lex",
      "pattern": "^LEX\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Clause",
      "pattern": "^CLAUSE:\\s+(.+)\\.",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "pattern": "^LEX\\s+(\\w.+)\\.",
      "captureGroup": 1,
      "kind": 2,
      "description": "Contract declaration"
    },
    {
      "pattern": "^CLAUSE\\s+(\\w.+)\\.",
      "captureGroup": 1,
      "kind": 12,
      "description": "Clause definition"
    },
    {
      "pattern": "^(\\w+)\\s+is\\s+a",
      "captureGroup": 1,
      "kind": 13,
      "description": "Term definition"
    },
    {
      "name": "Variable",
      "pattern": "(?:var|let|const|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Module",
      "pattern": "(?:module|namespace|package|import)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
