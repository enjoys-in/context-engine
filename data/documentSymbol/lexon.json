{
  "language": "lexon",
  "symbolPatterns": [
    {
      "name": "LEX declaration",
      "pattern": "^\\\\s*LEX\\\\s+(.+?)\\\\.",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "CLAUSE",
      "pattern": "^\\\\s*CLAUSE:\\\\s+(.+?)\\\\.",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "TERMS",
      "pattern": "^\\\\s*(TERMS)\\\\.",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "SECTION",
      "pattern": "^\\\\s*SECTION\\\\s+(.+?)\\\\.",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "RECITAL",
      "pattern": "^\\\\s*RECITAL\\\\s+(.+?)\\\\.",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "WHEREAS",
      "pattern": "^\\\\s*WHEREAS\\\\s+(.+?)\\\\.",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "ARTICLE",
      "pattern": "^\\\\s*ARTICLE\\\\s+(.+?)\\\\.",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Definition",
      "pattern": "\"([^\"]+)\"\\\\s+means",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Condition",
      "pattern": "^\\\\s*(?:if|when|unless)\\\\s+(.+?)(?:then|,)",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "Action",
      "pattern": "^\\\\s*(?:shall|may)\\\\s+(.+?)\\\\.",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Party declaration",
      "pattern": "^\\\\s*(\\\\w+)\\\\s+is\\\\s+a\\\\s+party",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Amount",
      "pattern": "^\\\\s*(\\\\w+)\\\\s+is\\\\s+an?\\\\s+amount",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Date",
      "pattern": "^\\\\s*(\\\\w+)\\\\s+is\\\\s+an?\\\\s+date",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Covenant",
      "pattern": "^\\\\s*COVENANT\\\\s+(.+?)\\\\.",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "FunctionDeclaration",
      "pattern": "(?:function|def|fn|func|sub|proc)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "ClassDeclaration",
      "pattern": "\\\\bclass\\\\s+([A-Z]\\\\w*)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "VariableDeclaration",
      "pattern": "(?:const|let|var|val|dim)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "ConstantDeclaration",
      "pattern": "(?:const|final|readonly)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "MethodDeclaration",
      "pattern": "(?:public|private|protected)?\\\\s*(?:static\\\\s+)?(?:\\\\w+\\\\s+)?(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "PropertyDeclaration",
      "pattern": "(\\\\w+)\\\\s*[=:]\\\\s*",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "InterfaceDeclaration",
      "pattern": "\\\\binterface\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "EnumDeclaration",
      "pattern": "\\\\benum\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "TypeDeclaration",
      "pattern": "(?:type|struct|record)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "ModuleDeclaration",
      "pattern": "(?:module|namespace|package)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "NamespaceDeclaration",
      "pattern": "\\\\b(namespace|package|module)\\\\s+[\\\\w.]+",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "ConstructorDeclaration",
      "pattern": "(constructor|__init__|init|initialize)\\\\s*\\\\(?",
      "captureGroup": 1,
      "kind": 8,
      "type": "constructor"
    },
    {
      "name": "EventDeclaration",
      "pattern": "\\\\b(on\\\\w+|handle\\\\w+|emit\\\\w+)\\\\b",
      "captureGroup": 1,
      "kind": 23,
      "type": "event"
    },
    {
      "name": "ImportStatement",
      "pattern": "import\\\\s+.*?['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "ExportStatement",
      "pattern": "(?:export|pub|public)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "CommentBlock",
      "pattern": "\\/\\\\*\\\\*([\\\\s\\\\S]*?)\\\\*\\/",
      "captureGroup": 0,
      "kind": 20,
      "type": "string"
    },
    {
      "name": "AnnotationDeclaration",
      "pattern": "@\\\\w+",
      "captureGroup": 1,
      "kind": 24,
      "type": "operator"
    },
    {
      "name": "FieldDeclaration",
      "pattern": "(\\\\w+)\\\\s*:\\\\s*\\\\w+",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "KeyDeclaration",
      "pattern": "\"?(\\\\w+)\"?\\\\s*[:=]",
      "captureGroup": 1,
      "kind": 19,
      "type": "key"
    },
    {
      "name": "ArrayDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*\\\\[",
      "captureGroup": 1,
      "kind": 17,
      "type": "array"
    }
  ]
}
