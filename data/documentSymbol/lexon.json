{
  "language": "lexon",
  "symbolPatterns": [
    {
      "name": "LEX declaration",
      "pattern": "^\\\\s*LEX\\\\s+(.+?)\\\\.",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "CLAUSE",
      "pattern": "^\\\\s*CLAUSE:\\\\s+(.+?)\\\\.",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "TERMS",
      "pattern": "^\\\\s*(TERMS)\\\\.",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "SECTION",
      "pattern": "^\\\\s*SECTION\\\\s+(.+?)\\\\.",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "RECITAL",
      "pattern": "^\\\\s*RECITAL\\\\s+(.+?)\\\\.",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "WHEREAS",
      "pattern": "^\\\\s*WHEREAS\\\\s+(.+?)\\\\.",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "ARTICLE",
      "pattern": "^\\\\s*ARTICLE\\\\s+(.+?)\\\\.",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Definition",
      "pattern": "\"([^\"]+)\"\\\\s+means",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Condition",
      "pattern": "^\\\\s*(?:if|when|unless)\\\\s+(.+?)(?:then|,)",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "Action",
      "pattern": "^\\\\s*(?:shall|may)\\\\s+(.+?)\\\\.",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Party declaration",
      "pattern": "^\\\\s*(\\\\w+)\\\\s+is\\\\s+a\\\\s+party",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Amount",
      "pattern": "^\\\\s*(\\\\w+)\\\\s+is\\\\s+an?\\\\s+amount",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Date",
      "pattern": "^\\\\s*(\\\\w+)\\\\s+is\\\\s+an?\\\\s+date",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Covenant",
      "pattern": "^\\\\s*COVENANT\\\\s+(.+?)\\\\.",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    }
  ]
}
