{
  "language": "clojure",
  "symbolPatterns": [
    {
      "name": "PublicFunction",
      "pattern": "^\\s*\\(defn\\s+(\\w[\\w\\-\\!\\?\\*\\+<>=]*)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "PrivateFunction",
      "pattern": "^\\s*\\(defn-\\s+(\\w[\\w\\-\\!\\?\\*\\+<>=]*)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Variable",
      "pattern": "^\\s*\\(def\\s+(?!\\^)(?!once\\b)(\\w[\\w\\-\\!\\?\\*\\+<>=]*)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "DynamicVar",
      "pattern": "^\\s*\\(def\\s+\\^:dynamic\\s+(\\*\\w[\\w\\-]*\\*)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Defonce",
      "pattern": "^\\s*\\(defonce\\s+(\\w[\\w\\-\\!\\?\\*\\+<>=]*)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Macro",
      "pattern": "^\\s*\\(defmacro\\s+(\\w[\\w\\-\\!\\?\\*\\+<>=]*)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Multimethod",
      "pattern": "^\\s*\\(defmulti\\s+(\\w[\\w\\-\\!\\?\\*\\+<>=]*)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "MethodImpl",
      "pattern": "^\\s*\\(defmethod\\s+(\\w[\\w\\-\\!\\?\\*\\+<>=]*)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Protocol",
      "pattern": "^\\s*\\(defprotocol\\s+(\\w[\\w\\-\\!\\?\\*\\+<>=]*)",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Record",
      "pattern": "^\\s*\\(defrecord\\s+(\\w[\\w\\-\\!\\?\\*\\+<>=]*)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Type",
      "pattern": "^\\s*\\(deftype\\s+(\\w[\\w\\-\\!\\?\\*\\+<>=]*)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Struct",
      "pattern": "^\\s*\\(defstruct\\s+(\\w[\\w\\-\\!\\?\\*\\+<>=]*)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Namespace",
      "pattern": "^\\s*\\(ns\\s+([\\w\\.\\-]+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Require",
      "pattern": "\\(:?require\\s+\\[?([\\w\\.\\-]+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Use",
      "pattern": "\\(:?use\\s+\\[?([\\w\\.\\-]+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Import",
      "pattern": "\\(:?import\\s+\\[?([\\w\\.\\-]+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "LetBinding",
      "pattern": "\\(let\\s+\\[(\\w[\\w\\-\\!\\?\\*]*)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Atom",
      "pattern": "\\(def\\s+(\\w[\\w\\-\\!\\?\\*]*)\\s+\\(atom\\b",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    }
  ]
}
