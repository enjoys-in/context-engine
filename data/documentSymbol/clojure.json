{
  "language": "clojure",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\s*\\(defn-?\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Def",
      "pattern": "^\\s*\\(def\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Macro",
      "pattern": "^\\s*\\(defmacro\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Protocol",
      "pattern": "^\\s*\\(defprotocol\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Record",
      "pattern": "^\\s*\\(defrecord\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Namespace",
      "pattern": "^\\s*\\(ns\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    }
  ]
}