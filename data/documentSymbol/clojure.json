{
  "language": "clojure",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\s*\\(defn-?\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Def",
      "pattern": "^\\s*\\(def\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Macro",
      "pattern": "^\\s*\\(defmacro\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Protocol",
      "pattern": "^\\s*\\(defprotocol\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Record",
      "pattern": "^\\s*\\(defrecord\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Namespace",
      "pattern": "^\\s*\\(ns\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Module",
      "pattern": "(?:module|namespace|package|import)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
