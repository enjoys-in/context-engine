{
  "language": "dockerfile",
  "symbolPatterns": [
    {
      "name": "Multi-stage build",
      "pattern": "^FROM\\s+\\S+\\s+[Aa][Ss]\\s+(\\w[\\w.-]*)",
      "captureGroup": 1,
      "kind": 2,
      "type": "stage"
    },
    {
      "name": "FROM",
      "pattern": "^FROM\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "image"
    },
    {
      "name": "RUN",
      "pattern": "^RUN\\s+(.+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "instruction"
    },
    {
      "name": "CMD",
      "pattern": "^CMD\\s+(.+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "entrypoint"
    },
    {
      "name": "ENTRYPOINT",
      "pattern": "^ENTRYPOINT\\s+(.+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "entrypoint"
    },
    {
      "name": "EXPOSE",
      "pattern": "^EXPOSE\\s+(.+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "port"
    },
    {
      "name": "ENV",
      "pattern": "^ENV\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "ARG",
      "pattern": "^ARG\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "argument"
    },
    {
      "name": "COPY",
      "pattern": "^COPY\\s+(.+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "instruction"
    },
    {
      "name": "ADD",
      "pattern": "^ADD\\s+(.+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "instruction"
    },
    {
      "name": "WORKDIR",
      "pattern": "^WORKDIR\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "directory"
    },
    {
      "name": "VOLUME",
      "pattern": "^VOLUME\\s+(.+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "volume"
    },
    {
      "name": "USER",
      "pattern": "^USER\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "user"
    },
    {
      "name": "LABEL",
      "pattern": "^LABEL\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "label"
    },
    {
      "name": "HEALTHCHECK",
      "pattern": "^HEALTHCHECK\\s+(.+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "healthcheck"
    },
    {
      "name": "SHELL",
      "pattern": "^SHELL\\s+(.+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "shell"
    },
    {
      "name": "ONBUILD",
      "pattern": "^ONBUILD\\s+(\\w+.+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "trigger"
    },
    {
      "name": "STOPSIGNAL",
      "pattern": "^STOPSIGNAL\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "signal"
    },
    {
      "name": "Comment",
      "pattern": "^#\\s*(.+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "comment"
    },
    {
      "name": "CallbackDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(function|=>|->)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "GenericTypeDeclaration",
      "pattern": "\\\\b(\\\\w+)<[^>]+>",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "ClosureDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(\\\\(|\\\\|)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    }
  ]
}
