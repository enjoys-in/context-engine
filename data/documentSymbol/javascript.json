{
  "language": "javascript",
  "symbolPatterns": [
    {
      "name": "Function Declaration",
      "pattern": "^\\\\s*(?:async\\\\s+)?function\\\\s+(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Generator Function Declaration",
      "pattern": "^\\\\s*(?:async\\\\s+)?function\\\\*\\\\s*(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Arrow Function Assignment",
      "pattern": "^\\\\s*(?:export\\\\s+)?(?:const|let|var)\\\\s+(\\\\w+)\\\\s*=\\\\s*(?:async\\\\s+)?(?:\\\\([^)]*\\\\)|\\\\w+)\\\\s*=>",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Class Declaration",
      "pattern": "^\\\\s*(?:export\\\\s+)?class\\\\s+(\\\\w+)(?:\\\\s+extends\\\\s+\\\\w+)?\\\\s*\\\\{",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Class Method",
      "pattern": "^\\\\s*(?:async\\\\s+)?(?:static\\\\s+)?(?:get\\\\s+|set\\\\s+)?(\\\\w+)\\\\s*\\\\([^)]*\\\\)\\\\s*\\\\{",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Private Class Method",
      "pattern": "^\\\\s*(?:async\\\\s+)?(?:static\\\\s+)?(?:get\\\\s+|set\\\\s+)?#(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Constructor",
      "pattern": "^\\\\s*(constructor)\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 8,
      "type": "constructor"
    },
    {
      "name": "Const Declaration",
      "pattern": "^\\\\s*(?:export\\\\s+)?const\\\\s+(\\\\w+)\\\\s*=\\\\s*(?!(?:async\\\\s+)?(?:\\\\([^)]*\\\\)|\\\\w+)\\\\s*=>)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Let/Var Declaration",
      "pattern": "^\\\\s*(?:export\\\\s+)?(?:let|var)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Destructuring Assignment",
      "pattern": "^\\\\s*(?:export\\\\s+)?(?:const|let|var)\\\\s+(\\\\{[^}]+\\\\}|\\\\[[^\\\\]]+\\\\])\\\\s*=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Default Export",
      "pattern": "^\\\\s*export\\\\s+default\\\\s+(?:(?:async\\\\s+)?function\\\\*?\\\\s+(\\\\w+)|class\\\\s+(\\\\w+)|(\\\\w+))",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Named Export",
      "pattern": "^\\\\s*export\\\\s+(?:(?:async\\\\s+)?function\\\\*?\\\\s+(\\\\w+)|(?:const|let|var)\\\\s+(\\\\w+)|class\\\\s+(\\\\w+))",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "CommonJS Module Export",
      "pattern": "^\\\\s*module\\\\.exports\\\\s*=\\\\s*(\\\\w+|\\\\{|function|class)",
      "captureGroup": 0,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "CommonJS Named Export",
      "pattern": "^\\\\s*exports\\\\.(\\\\w+)\\\\s*=",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Prototype Method",
      "pattern": "^\\\\s*(\\\\w+)\\\\.prototype\\\\.(\\\\w+)\\\\s*=\\\\s*function",
      "captureGroup": 2,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Object Property",
      "pattern": "^\\\\s+(\\\\w+)\\\\s*:\\\\s*(?:function|async\\\\s+function|\\\\([^)]*\\\\)\\\\s*=>|[^,]+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "IIFE",
      "pattern": "^\\\\s*\\\\(\\\\s*(?:async\\\\s+)?function\\\\s*\\\\w*\\\\s*\\\\(|^\\\\s*\\\\(\\\\s*\\\\(\\\\)\\\\s*=>",
      "captureGroup": 0,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "JSDoc Typedef",
      "pattern": "@typedef\\\\s+\\\\{[^}]*\\\\}\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "JSDoc Callback",
      "pattern": "@callback\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Event Listener",
      "pattern": "\\\\.addEventListener\\\\(\\\\s*['\"]([\\\\w-]+)['\"]",
      "captureGroup": 1,
      "kind": 23,
      "type": "event"
    }
  ]
}
