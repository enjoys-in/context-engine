{
  "language": "javascript",
  "symbolPatterns": [
    {
      "name": "Function Declaration",
      "pattern": "^\\\\s*(?:export\\\\s+)?(?:async\\\\s+)?function\\\\s*\\\\*?\\\\s*(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Class",
      "pattern": "^\\\\s*(?:export\\\\s+)?class\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Const/Let/Var",
      "pattern": "^\\\\s*(?:export\\\\s+)?(?:const|let|var)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Arrow Function",
      "pattern": "^\\\\s*(?:export\\\\s+)?(?:const|let|var)\\\\s+(\\\\w+)\\\\s*=\\\\s*(?:async\\\\s+)?(?:\\\\([^)]*\\\\)|\\\\w+)\\\\s*=>",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Method",
      "pattern": "^\\\\s*(?:async\\\\s+)?(?:static\\\\s+)?(?:get\\\\s+|set\\\\s+)?(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    }
  ]
}