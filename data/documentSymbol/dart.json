{
  "language": "dart",
  "symbolPatterns": [
    {
      "name": "Class",
      "pattern": "^\\s*(?:(?:base|final|interface)\\s+)*class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Abstract Class",
      "pattern": "^\\s*abstract\\s+(?:(?:base|final|interface)\\s+)*class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "abstract class"
    },
    {
      "name": "Sealed Class",
      "pattern": "^\\s*sealed\\s+class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "sealed class"
    },
    {
      "name": "Mixin",
      "pattern": "^\\s*(?:base\\s+)?mixin\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "mixin"
    },
    {
      "name": "Extension",
      "pattern": "^\\s*extension\\s+(\\w+)\\s+on\\s+",
      "captureGroup": 1,
      "kind": 2,
      "type": "extension"
    },
    {
      "name": "Extension Type",
      "pattern": "^\\s*extension\\s+type\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "extension type"
    },
    {
      "name": "Enum",
      "pattern": "^\\s*enum\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Factory Constructor",
      "pattern": "^\\s*(?:const\\s+)?factory\\s+(\\w+)(?:\\.(\\w+))?\\s*\\(",
      "captureGroup": 1,
      "kind": 8,
      "type": "factory constructor"
    },
    {
      "name": "Named Constructor",
      "pattern": "^\\s*(?:const\\s+)?(\\w+)\\s*\\.\\s*(\\w+)\\s*\\(",
      "captureGroup": 2,
      "kind": 8,
      "type": "named constructor"
    },
    {
      "name": "Method",
      "pattern": "^\\s+(?:(?:static|external|@override)\\s+)*(?:Future|Stream|void|bool|int|double|String|List|Map|Set|Iterable|\\w+)(?:<[^>]*>)?\\s+(\\w+)\\s*(?:<[^>]*>)?\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Getter",
      "pattern": "^\\s*(?:(?:static|external)\\s+)*(?:\\w+(?:<[^>]*>)?\\s+)?get\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "getter"
    },
    {
      "name": "Setter",
      "pattern": "^\\s*(?:(?:static|external)\\s+)*set\\s+(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 6,
      "type": "setter"
    },
    {
      "name": "Field",
      "pattern": "^\\s*(?:(?:static|external|covariant)\\s+)*(?:final|late|late\\s+final|var|const)\\s+(?:\\w+(?:<[^>]*>)?\\s+)?(\\w+)\\s*[;=]",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "Typedef",
      "pattern": "^\\s*typedef\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 25,
      "type": "typedef"
    },
    {
      "name": "Part",
      "pattern": "^part\\s+'([^']+)'\\s*;",
      "captureGroup": 1,
      "kind": 1,
      "type": "part"
    },
    {
      "name": "Part Of",
      "pattern": "^part\\s+of\\s+([\\w.']+)\\s*;",
      "captureGroup": 1,
      "kind": 1,
      "type": "part of"
    },
    {
      "name": "Import",
      "pattern": "^import\\s+'([^']+)'",
      "captureGroup": 1,
      "kind": 2,
      "type": "import"
    },
    {
      "name": "Export",
      "pattern": "^export\\s+'([^']+)'",
      "captureGroup": 1,
      "kind": 2,
      "type": "export"
    },
    {
      "name": "Library",
      "pattern": "^library\\s+([\\w.]+)\\s*;",
      "captureGroup": 1,
      "kind": 1,
      "type": "library"
    },
    {
      "name": "CallbackDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(function|=>|->)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "GenericTypeDeclaration",
      "pattern": "\\\\b(\\\\w+)<[^>]+>",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "ClosureDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(\\\\(|\\\\|)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    }
  ]
}
