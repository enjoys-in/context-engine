{
  "language": "dart",
  "symbolPatterns": [
    {
      "name": "Class Declaration",
      "pattern": "^\\s*(?:(?:abstract|sealed|interface|base|final|mixin)\\s+)*class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "detail": "class"
    },
    {
      "name": "Mixin Declaration",
      "pattern": "^\\s*(?:(?:base)\\s+)?mixin\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "detail": "mixin"
    },
    {
      "name": "Enum Declaration",
      "pattern": "^\\s*enum\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "detail": "enum"
    },
    {
      "name": "Extension Declaration",
      "pattern": "^\\s*extension\\s+(\\w+)\\s+on",
      "captureGroup": 1,
      "kind": 4,
      "detail": "extension"
    },
    {
      "name": "Extension Type Declaration",
      "pattern": "^\\s*extension\\s+type\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "detail": "extension type"
    },
    {
      "name": "Function Declaration",
      "pattern": "^\\s*(?:(?:static|external)\\s+)*(?:\\w+(?:<[^>]*>)?\\s+)?(\\w+)\\s*(?:<[^>]*>)?\\s*\\([^)]*\\)\\s*(?:async\\*?|sync\\*)?\\s*\\{",
      "captureGroup": 1,
      "kind": 11,
      "detail": "function"
    },
    {
      "name": "Method Declaration",
      "pattern": "^\\s+(?:(?:static|external|@override)\\s+)*(?:\\w+(?:<[^>]*>)?\\s+)?(\\w+)\\s*(?:<[^>]*>)?\\s*\\([^)]*\\)",
      "captureGroup": 1,
      "kind": 5,
      "detail": "method"
    },
    {
      "name": "Getter Declaration",
      "pattern": "^\\s*(?:(?:static|external)\\s+)*(?:\\w+\\s+)?get\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "detail": "getter"
    },
    {
      "name": "Setter Declaration",
      "pattern": "^\\s*(?:(?:static|external)\\s+)*set\\s+(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 9,
      "detail": "setter"
    },
    {
      "name": "Typedef Declaration",
      "pattern": "^\\s*typedef\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 25,
      "detail": "typedef"
    },
    {
      "name": "Variable Declaration",
      "pattern": "^\\s*(?:(?:static|late|external)\\s+)*(?:var|final|const)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "detail": "variable"
    },
    {
      "name": "Top-Level Const",
      "pattern": "^const\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 13,
      "detail": "constant"
    },
    {
      "name": "Constructor",
      "pattern": "^\\s*(?:const\\s+)?(?:factory\\s+)?\\w+(?:\\.(\\w+))?\\s*\\(",
      "captureGroup": 1,
      "kind": 8,
      "detail": "constructor"
    },
    {
      "name": "Library Declaration",
      "pattern": "^\\s*library\\s+([\\w.]+);",
      "captureGroup": 1,
      "kind": 3,
      "detail": "library"
    },
    {
      "name": "Part Declaration",
      "pattern": "^\\s*part\\s+'([^']+)'",
      "captureGroup": 1,
      "kind": 3,
      "detail": "part"
    }
  ]
}