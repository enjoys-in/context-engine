{
  "language": "bicep",
  "symbolPatterns": [
    {
      "name": "Resource",
      "pattern": "^\\s*resource\\s+(\\w+)\\s+'[^']+'",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "ExistingResource",
      "pattern": "^\\s*resource\\s+(\\w+)\\s+'[^']+'\\s+existing",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Module",
      "pattern": "^\\s*module\\s+(\\w+)\\s+'[^']+'",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Param",
      "pattern": "^\\s*param\\s+(\\w+)\\s+\\w+",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Var",
      "pattern": "^\\s*var\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Output",
      "pattern": "^\\s*output\\s+(\\w+)\\s+\\w+",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Type",
      "pattern": "^\\s*type\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "TargetScope",
      "pattern": "^\\s*targetScope\\s*=\\s*'([^']+)'",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Decorator",
      "pattern": "^\\s*@(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "ConditionalDeployment",
      "pattern": "\\s*=\\s*if\\s*\\(",
      "captureGroup": 0,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Loop",
      "pattern": "\\[for\\s+(\\w+)\\s+in",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Import",
      "pattern": "^\\s*import\\s+'([^']+)'",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    }
  ]
}
