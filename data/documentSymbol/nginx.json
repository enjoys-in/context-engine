{
  "language": "nginx",
  "symbolPatterns": [
    {
      "name": "Server Block",
      "pattern": "^\\\\s*server\\\\s*\\\\{",
      "captureGroup": 0,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Location",
      "pattern": "^\\\\s*location\\\\s+(\\\\S+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Upstream",
      "pattern": "^\\\\s*upstream\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Class",
      "pattern": "(?:class|struct|interface|trait|type|record)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Variable",
      "pattern": "(?:var|let|const|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Method",
      "pattern": "(?:public|private|protected)?\\s*(?:static)?\\s*(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "TypeAlias",
      "pattern": "(?:type|typedef)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 25,
      "type": "typeAlias"
    }
  ]
}
