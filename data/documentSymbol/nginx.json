{
  "language": "nginx",
  "symbolPatterns": [
    {
      "name": "Server Block",
      "pattern": "^\\\\s*server\\\\s*\\\\{",
      "captureGroup": 0,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Location",
      "pattern": "^\\\\s*location\\\\s+(\\\\S+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Upstream",
      "pattern": "^\\\\s*upstream\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    }
  ]
}