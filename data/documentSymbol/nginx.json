{
  "language": "nginx",
  "symbolPatterns": [
    {
      "name": "Events block",
      "pattern": "^\\s*events\\s*\\{",
      "captureGroup": 0,
      "kind": 2,
      "type": "block"
    },
    {
      "name": "Http block",
      "pattern": "^\\s*http\\s*\\{",
      "captureGroup": 0,
      "kind": 2,
      "type": "block"
    },
    {
      "name": "Stream block",
      "pattern": "^\\s*stream\\s*\\{",
      "captureGroup": 0,
      "kind": 2,
      "type": "block"
    },
    {
      "name": "Upstream block",
      "pattern": "^\\s*upstream\\s+(\\S+)\\s*\\{",
      "captureGroup": 1,
      "kind": 4,
      "type": "upstream"
    },
    {
      "name": "Server block",
      "pattern": "^\\s*server\\s*\\{",
      "captureGroup": 0,
      "kind": 4,
      "type": "server"
    },
    {
      "name": "Location block",
      "pattern": "^\\s*location\\s+(.+?)\\s*\\{",
      "captureGroup": 1,
      "kind": 5,
      "type": "location"
    },
    {
      "name": "Map block",
      "pattern": "^\\s*map\\s+(\\S+)\\s+(\\$\\w+)\\s*\\{",
      "captureGroup": 2,
      "kind": 11,
      "type": "map"
    },
    {
      "name": "Geo block",
      "pattern": "^\\s*geo\\s+(\\$\\w+)\\s*\\{",
      "captureGroup": 1,
      "kind": 11,
      "type": "geo"
    },
    {
      "name": "If conditional",
      "pattern": "^\\s*if\\s*\\((.+?)\\)\\s*\\{",
      "captureGroup": 1,
      "kind": 19,
      "type": "conditional"
    },
    {
      "name": "Listen directive",
      "pattern": "^\\s*listen\\s+(.+);",
      "captureGroup": 1,
      "kind": 6,
      "type": "directive"
    },
    {
      "name": "Server name",
      "pattern": "^\\s*server_name\\s+(.+);",
      "captureGroup": 1,
      "kind": 6,
      "type": "directive"
    },
    {
      "name": "Root directive",
      "pattern": "^\\s*root\\s+(.+);",
      "captureGroup": 1,
      "kind": 6,
      "type": "directive"
    },
    {
      "name": "Proxy pass",
      "pattern": "^\\s*proxy_pass\\s+(.+);",
      "captureGroup": 1,
      "kind": 6,
      "type": "directive"
    },
    {
      "name": "Include",
      "pattern": "^\\s*include\\s+(.+);",
      "captureGroup": 1,
      "kind": 1,
      "type": "include"
    },
    {
      "name": "Limit req zone",
      "pattern": "^\\s*limit_req_zone\\s+(.+);",
      "captureGroup": 1,
      "kind": 11,
      "type": "rate-limit"
    },
    {
      "name": "CallbackDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(function|=>|->)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "GenericTypeDeclaration",
      "pattern": "\\\\b(\\\\w+)<[^>]+>",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "ClosureDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(\\\\(|\\\\|)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "TestDeclaration",
      "pattern": "\\\\b(?:test|it|describe|spec)\\\\s*\\\\(?['\"]([^'\"]+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "ErrorDeclaration",
      "pattern": "\\\\b(?:class|type)\\\\s+(\\\\w*Error|\\\\w*Exception)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "ConfigObjectDeclaration",
      "pattern": "\\\\b(config|options|settings)\\\\s*[:=]\\\\s*\\\\{",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "GetterDeclaration",
      "pattern": "\\\\bget\\\\s+(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
