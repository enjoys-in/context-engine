{
  "language": "flow9",
  "symbolPatterns": [
    {
      "name": "Import",
      "pattern": "^\\\\s*import\\\\s+(\\\\S+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Export",
      "pattern": "^\\\\s*export\\\\s*\\\\{\\\\s*(\\\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Native declaration",
      "pattern": "^\\\\s*native\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Struct",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*\\\\(\\\\s*(?:mutable\\\\s+)?\\\\w+\\\\s*:",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Union",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*::=",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Function",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*\\\\([^)]*\\\\)\\\\s*->",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Lambda",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*=\\\\s*\\\\\\\\",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Global variable",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*:\\\\s*\\\\w+\\\\s*=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Require",
      "pattern": "^\\\\s*require\\\\s+(\\\\S+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Forbid",
      "pattern": "^\\\\s*forbid\\\\s+(\\\\S+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Type declaration",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*:\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Switch",
      "pattern": "^\\\\s*switch\\\\s*\\\\(\\\\s*(\\\\w+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Ref",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*=\\\\s*ref\\\\s+",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    }
  ]
}
