{
  "language": "flow9",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\s*(\\w+)\\s*\\(.*\\)\\s*->",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Import",
      "pattern": "^\\s*import\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    }
  ]
}