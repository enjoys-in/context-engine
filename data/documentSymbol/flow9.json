{
  "language": "flow9",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\s*(\\w+)\\s*\\(.*\\)\\s*->",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Import",
      "pattern": "^\\s*import\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "pattern": "^(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 12,
      "description": "Function declaration",
      "name": "Symbol"
    },
    {
      "pattern": "^(\\w+)\\s*:\\s*(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 13,
      "description": "Variable with type",
      "name": "Type"
    },
    {
      "pattern": "^export\\s+\\{?\\s*(\\w+)",
      "captureGroup": 1,
      "kind": 2,
      "description": "Export declaration",
      "name": "Symbol"
    },
    {
      "pattern": "import\\s+.*/(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "description": "Import",
      "name": "Import"
    },
    {
      "name": "Class",
      "pattern": "(?:class|struct|interface|trait|type|record)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Variable",
      "pattern": "(?:var|let|const|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    }
  ]
}
