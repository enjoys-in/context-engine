{
  "language": "sb",
  "symbolPatterns": [
    {
      "name": "Sub",
      "pattern": "^\\s*Sub\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "VariableAssignment",
      "pattern": "^\\s*(\\w+)\\s*=\\s*",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "TextWindowOp",
      "pattern": "\\b(TextWindow\\.\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "GraphicsWindowOp",
      "pattern": "\\b(GraphicsWindow\\.\\w+)\\s*[=(]",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "ForLoop",
      "pattern": "^\\s*For\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "WhileLoop",
      "pattern": "^\\s*(While)\\s*\\(",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "If",
      "pattern": "^\\s*(If)\\s*\\(",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "ElseIf",
      "pattern": "^\\s*(ElseIf)\\s*\\(",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Else",
      "pattern": "^\\s*(Else)\\s*$",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "GotoLabel",
      "pattern": "^\\s*(\\w+):\\s*$",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Goto",
      "pattern": "^\\s*Goto\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Array",
      "pattern": "^\\s*(\\w+)\\[(\\w+)\\]\\s*=",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "ObjectPropertyAccess",
      "pattern": "\\b(\\w+\\.\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
