{
  "language": "sb",
  "symbolPatterns": [
    {
      "name": "Sub",
      "pattern": "^\\s*Sub\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Label",
      "pattern": "^(\\w+):",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "pattern": "^Sub\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "description": "Subroutine",
      "name": "Symbol"
    },
    {
      "pattern": "^(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 13,
      "description": "Variable assignment",
      "name": "Symbol"
    },
    {
      "pattern": "^'\\s*(.+)",
      "captureGroup": 1,
      "kind": 15,
      "description": "Comment",
      "name": "Comment"
    },
    {
      "name": "Class",
      "pattern": "(?:class|struct|interface|trait|type|record)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Variable",
      "pattern": "(?:var|let|const|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Module",
      "pattern": "(?:module|namespace|package|import)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
