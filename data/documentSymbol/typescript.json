{
  "language": "typescript",
  "symbolPatterns": [
    {
      "name": "Function Declaration",
      "pattern": "^\\\\s*(?:export\\\\s+)?(?:declare\\\\s+)?(?:async\\\\s+)?function\\\\s*\\\\*?\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Arrow Function Assignment",
      "pattern": "^\\\\s*(?:export\\\\s+)?(?:const|let)\\\\s+(\\\\w+)\\\\s*(?:<[^>]*>)?\\\\s*(?::\\\\s*[^=]+?)?=\\\\s*(?:async\\\\s+)?(?:\\\\([^)]*\\\\)|\\\\w+)\\\\s*(?::\\\\s*[^=]+?)?\\\\s*=>",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Class",
      "pattern": "^\\\\s*(?:export\\\\s+)?(?:declare\\\\s+)?(?:abstract\\\\s+)?class\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Interface",
      "pattern": "^\\\\s*(?:export\\\\s+)?(?:declare\\\\s+)?interface\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Type Alias",
      "pattern": "^\\\\s*(?:export\\\\s+)?(?:declare\\\\s+)?type\\\\s+(\\\\w+)\\\\s*(?:<[^>]*>)?\\\\s*=",
      "captureGroup": 1,
      "kind": 25,
      "type": "typeParameter"
    },
    {
      "name": "Enum",
      "pattern": "^\\\\s*(?:export\\\\s+)?(?:declare\\\\s+)?(?:const\\\\s+)?enum\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Enum Member",
      "pattern": "^\\\\s+(\\\\w+)\\\\s*(?:=\\\\s*[^,}]+)?\\\\s*[,}]?\\\\s*$",
      "captureGroup": 1,
      "kind": 21,
      "type": "enumMember"
    },
    {
      "name": "Namespace",
      "pattern": "^\\\\s*(?:export\\\\s+)?(?:declare\\\\s+)?namespace\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Module Declaration",
      "pattern": "^\\\\s*declare\\\\s+module\\\\s+['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Method",
      "pattern": "^\\\\s*(?:(?:public|private|protected)\\\\s+)?(?:static\\\\s+)?(?:abstract\\\\s+)?(?:override\\\\s+)?(?:readonly\\\\s+)?(?:async\\\\s+)?(?:\\\\*\\\\s*)?(\\\\w+)\\\\s*(?:<[^>]*>)?\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Private Field",
      "pattern": "^\\\\s*(?:(?:readonly|static)\\\\s+)*(#\\\\w+)\\\\s*[=:;(]",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "Constructor",
      "pattern": "^\\\\s*(?:(?:public|private|protected)\\\\s+)?(constructor)\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 8,
      "type": "constructor"
    },
    {
      "name": "Property",
      "pattern": "^\\\\s*(?:(?:public|private|protected)\\\\s+)?(?:static\\\\s+)?(?:readonly\\\\s+)?(?:abstract\\\\s+)?(?:override\\\\s+)?(\\\\w+)\\\\??\\\\s*[=:;]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Getter",
      "pattern": "^\\\\s*(?:(?:public|private|protected)\\\\s+)?(?:static\\\\s+)?(?:override\\\\s+)?get\\\\s+(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Setter",
      "pattern": "^\\\\s*(?:(?:public|private|protected)\\\\s+)?(?:static\\\\s+)?(?:override\\\\s+)?set\\\\s+(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Decorator",
      "pattern": "^\\\\s*@(\\\\w+)(?:\\\\.|\\\\()?",
      "captureGroup": 1,
      "kind": 24,
      "type": "operator"
    },
    {
      "name": "Generic Type Parameter",
      "pattern": "(?:class|interface|type|function)\\\\s+\\\\w+\\\\s*<(\\\\w+)(?:\\\\s+extends\\\\s+[^>,]+)?",
      "captureGroup": 1,
      "kind": 25,
      "type": "typeParameter"
    },
    {
      "name": "Index Signature",
      "pattern": "^\\\\s*(?:readonly\\\\s+)?\\\\[(\\\\w+)\\\\s*:\\\\s*\\\\w+\\\\]\\\\s*:",
      "captureGroup": 1,
      "kind": 19,
      "type": "key"
    },
    {
      "name": "Mapped Type",
      "pattern": "^\\\\s*(?:export\\\\s+)?type\\\\s+(\\\\w+)\\\\s*(?:<[^>]*>)?\\\\s*=\\\\s*\\\\{\\\\s*\\\\[\\\\w+\\\\s+in\\\\s+",
      "captureGroup": 1,
      "kind": 25,
      "type": "typeParameter"
    },
    {
      "name": "Conditional Type",
      "pattern": "^\\\\s*(?:export\\\\s+)?type\\\\s+(\\\\w+)\\\\s*(?:<[^>]*>)?\\\\s*=\\\\s*[^=]+\\\\s+extends\\\\s+[^?]+\\\\?",
      "captureGroup": 1,
      "kind": 25,
      "type": "typeParameter"
    },
    {
      "name": "Default Export",
      "pattern": "^\\\\s*export\\\\s+default\\\\s+(?:class|function|abstract\\\\s+class)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Named Export",
      "pattern": "^\\\\s*export\\\\s+\\\\{\\\\s*(\\\\w+(?:\\\\s+as\\\\s+\\\\w+)?(?:\\\\s*,\\\\s*\\\\w+(?:\\\\s+as\\\\s+\\\\w+)?)*)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Re-export",
      "pattern": "^\\\\s*export\\\\s+\\\\{\\\\s*(\\\\w+(?:\\\\s+as\\\\s+\\\\w+)?(?:\\\\s*,\\\\s*\\\\w+(?:\\\\s+as\\\\s+\\\\w+)?)*)\\\\s*\\\\}\\\\s+from\\\\s+['\"]",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Variable Declaration",
      "pattern": "^\\\\s*(?:export\\\\s+)?(?:declare\\\\s+)?(const|let|var)\\\\s+(\\\\w+)\\\\s*(?:[=:;])",
      "captureGroup": 2,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Type Guard",
      "pattern": "^\\\\s*(?:export\\\\s+)?function\\\\s+(\\\\w+)\\\\s*\\\\([^)]*\\\\)\\\\s*:\\\\s*\\\\w+\\\\s+is\\\\s+",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Overload Signature",
      "pattern": "^\\\\s*(?:export\\\\s+)?function\\\\s+(\\\\w+)\\\\s*(?:<[^>]*>)?\\\\s*\\\\([^)]*\\\\)\\\\s*:\\\\s*[^{]+;\\\\s*$",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    }
  ]
}
