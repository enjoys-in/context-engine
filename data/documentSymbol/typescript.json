{
  "language": "typescript",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\\\s*(?:export\\\\s+)?(?:async\\\\s+)?function\\\\s*\\\\*?\\\\s*(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Class",
      "pattern": "^\\\\s*(?:export\\\\s+)?(?:abstract\\\\s+)?class\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Interface",
      "pattern": "^\\\\s*(?:export\\\\s+)?interface\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Type Alias",
      "pattern": "^\\\\s*(?:export\\\\s+)?type\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Enum",
      "pattern": "^\\\\s*(?:export\\\\s+)?(?:const\\\\s+)?enum\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Const/Let/Var",
      "pattern": "^\\\\s*(?:export\\\\s+)?(?:const|let|var)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Arrow Function",
      "pattern": "^\\\\s*(?:export\\\\s+)?(?:const|let|var)\\\\s+(\\\\w+)\\\\s*=\\\\s*(?:async\\\\s+)?(?:\\\\([^)]*\\\\)|\\\\w+)\\\\s*(?::\\\\s*[^=]+)?=>",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Namespace",
      "pattern": "^\\\\s*(?:export\\\\s+)?(?:declare\\\\s+)?namespace\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "module"
    }
  ]
}