{
  "language": "abap",
  "symbolPatterns": [
    {
      "name": "Class",
      "pattern": "^\\s*CLASS\\s+(\\w+)\\s+DEFINITION",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Method",
      "pattern": "^\\s*METHOD\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Form",
      "pattern": "^\\s*FORM\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Function",
      "pattern": "^\\s*FUNCTION\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Interface",
      "pattern": "^\\s*INTERFACE\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Data",
      "pattern": "^\\s*DATA[:\\s]\\s*(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Types",
      "pattern": "^\\s*TYPES[:\\s]\\s*(\\w+)",
      "captureGroup": 1,
      "kind": 25,
      "type": "type"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Module",
      "pattern": "(?:module|namespace|package|import)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    }
  ]
}
