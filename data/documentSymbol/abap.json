{
  "language": "abap",
  "symbolPatterns": [
    {
      "name": "Class Definition",
      "pattern": "^\\s*CLASS\\s+(\\w+)\\s+DEFINITION",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Class Implementation",
      "pattern": "^\\s*CLASS\\s+(\\w+)\\s+IMPLEMENTATION",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Interface",
      "pattern": "^\\s*INTERFACE\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Method",
      "pattern": "^\\s*METHODS?\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Form",
      "pattern": "^\\s*FORM\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Function-Pool",
      "pattern": "^\\s*FUNCTION-POOL\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Function",
      "pattern": "^\\s*FUNCTION\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Data",
      "pattern": "^\\s*DATA[:\\s]+\\s*(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Types",
      "pattern": "^\\s*TYPES[:\\s]+\\s*(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Constants",
      "pattern": "^\\s*CONSTANTS[:\\s]+\\s*(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Tables",
      "pattern": "^\\s*TABLES[:\\s]+\\s*(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Select-Options",
      "pattern": "^\\s*SELECT-OPTIONS\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Parameters",
      "pattern": "^\\s*PARAMETERS[:\\s]+\\s*(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Report",
      "pattern": "^\\s*REPORT\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Include",
      "pattern": "^\\s*INCLUDE\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "AT Selection-Screen",
      "pattern": "^\\s*(AT\\s+SELECTION-SCREEN(?:\\s+ON\\s+\\w+)?)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Start-Of-Selection",
      "pattern": "^\\s*(START-OF-SELECTION)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "End-Of-Selection",
      "pattern": "^\\s*(END-OF-SELECTION)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Module",
      "pattern": "^\\s*MODULE\\s+(\\w+)\\s+(?:INPUT|OUTPUT)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Perform",
      "pattern": "^\\s*PERFORM\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Field-Symbols",
      "pattern": "^\\s*FIELD-SYMBOLS\\s+<(\\w+)>",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    }
  ]
}
