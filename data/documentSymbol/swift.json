{
  "language": "swift",
  "symbolPatterns": [
    {
      "name": "Class",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public|open|final)\\s+)*class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Struct",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public)\\s+)*struct\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Enum",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public|indirect)\\s+)*enum\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Enum Case",
      "pattern": "^\\s*(?:indirect\\s+)?case\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 21,
      "type": "enum case"
    },
    {
      "name": "Protocol",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public)\\s+)*protocol\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "protocol"
    },
    {
      "name": "Extension",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public)\\s+)*extension\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "extension"
    },
    {
      "name": "Actor",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public|distributed)\\s+)*actor\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "actor"
    },
    {
      "name": "Func",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public|open|override|final|static|class|mutating|nonmutating|nonisolated)\\s+)*func\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Async Function",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public|open|override|static|class|mutating)\\s+)*func\\s+(\\w+)\\s*\\([^)]*\\)\\s*(?:throws\\s+)?async",
      "captureGroup": 1,
      "kind": 11,
      "type": "async function"
    },
    {
      "name": "Init",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public|required|convenience)\\s+)*init[?!]?\\s*(?:\\(|<)",
      "captureGroup": 0,
      "kind": 8,
      "type": "initializer"
    },
    {
      "name": "Deinit",
      "pattern": "^\\s*deinit\\s*\\{",
      "captureGroup": 0,
      "kind": 8,
      "type": "deinitializer"
    },
    {
      "name": "Property",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public|open|override|final|static|class|weak|unowned|lazy)\\s+)*(?:var|let)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Computed Property",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public|override|static|class)\\s+)*var\\s+(\\w+)\\s*:\\s*\\w[^=]*\\{",
      "captureGroup": 1,
      "kind": 6,
      "type": "computed property"
    },
    {
      "name": "Subscript",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public|override|static|class)\\s+)*subscript\\s*(?:<[^>]*>)?\\s*\\(",
      "captureGroup": 0,
      "kind": 5,
      "type": "subscript"
    },
    {
      "name": "Typealias",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public)\\s+)*typealias\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 25,
      "type": "typealias"
    },
    {
      "name": "Associated Type",
      "pattern": "^\\s*associatedtype\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 25,
      "type": "associated type"
    },
    {
      "name": "Operator",
      "pattern": "^\\s*(?:prefix|infix|postfix)\\s+operator\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 24,
      "type": "operator"
    },
    {
      "name": "Macro",
      "pattern": "^\\s*(?:(?:private|fileprivate|internal|public)\\s+)*macro\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "macro"
    },
    {
      "name": "Import",
      "pattern": "^import\\s+(?:(?:typealias|struct|class|enum|protocol|let|var|func)\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "import"
    }
  ]
}
