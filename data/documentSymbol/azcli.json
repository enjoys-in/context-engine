{
  "language": "azcli",
  "symbolPatterns": [
    {
      "name": "Command",
      "pattern": "^\\s*(az\\s+\\w+(?:\\s+\\w+)*)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "pattern": "^az\\s+(\\w[\\w-]+)",
      "captureGroup": 1,
      "kind": 12,
      "description": "Azure CLI command group"
    },
    {
      "pattern": "--(\\w[\\w-]+)",
      "captureGroup": 1,
      "kind": 13,
      "description": "CLI flag/option"
    },
    {
      "pattern": "^#\\s*(.+)",
      "captureGroup": 1,
      "kind": 15,
      "description": "Comment annotation"
    },
    {
      "name": "Class",
      "pattern": "(?:class|struct|interface|trait|type|record)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Variable",
      "pattern": "(?:var|let|const|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Module",
      "pattern": "(?:module|namespace|package|import)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
