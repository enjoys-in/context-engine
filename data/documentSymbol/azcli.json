{
  "language": "azcli",
  "symbolPatterns": [
    {
      "name": "AzGroup",
      "pattern": "^\\s*az\\s+group\\s+(\\w[\\w-]*)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "AzResource",
      "pattern": "^\\s*az\\s+resource\\s+(\\w[\\w-]*)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "AzVm",
      "pattern": "^\\s*az\\s+vm\\s+(\\w[\\w-]*)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "AzStorage",
      "pattern": "^\\s*az\\s+storage\\s+(\\w[\\w-]*(?:\\s+\\w[\\w-]*)?)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "AzNetwork",
      "pattern": "^\\s*az\\s+network\\s+(\\w[\\w-]*(?:\\s+\\w[\\w-]*)?)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "AzWebapp",
      "pattern": "^\\s*az\\s+webapp\\s+(\\w[\\w-]*)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "AzAks",
      "pattern": "^\\s*az\\s+aks\\s+(\\w[\\w-]*)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "AzAcr",
      "pattern": "^\\s*az\\s+acr\\s+(\\w[\\w-]*)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "AzSql",
      "pattern": "^\\s*az\\s+sql\\s+(\\w[\\w-]*(?:\\s+\\w[\\w-]*)?)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "AzKeyvault",
      "pattern": "^\\s*az\\s+keyvault\\s+(\\w[\\w-]*)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "AzMonitor",
      "pattern": "^\\s*az\\s+monitor\\s+(\\w[\\w-]*(?:\\s+\\w[\\w-]*)?)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Parameter",
      "pattern": "--(\\w[\\w-]*)(?:\\s+|=)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "OutputFlag",
      "pattern": "--output\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "AzLogin",
      "pattern": "^\\s*(az\\s+login)(?:\\s|$)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "AzAccount",
      "pattern": "^\\s*az\\s+account\\s+(\\w[\\w-]*)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "VariableAssignment",
      "pattern": "^\\s*(\\w+)=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Comment",
      "pattern": "^\\s*#\\s*(.+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Continuation",
      "pattern": "\\\\\\s*$",
      "captureGroup": 0,
      "kind": 12,
      "type": "variable"
    }
  ]
}
