{
  "language": "scss",
  "symbolPatterns": [
    {
      "name": "Class Selector",
      "pattern": "\\.([a-zA-Z_][a-zA-Z0-9_-]*)\\s*[{,>+~\\s]",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "ID Selector",
      "pattern": "#([a-zA-Z_][a-zA-Z0-9_-]*)\\s*[{,>+~\\s]",
      "captureGroup": 1,
      "kind": 19,
      "type": "id"
    },
    {
      "name": "Element Selector",
      "pattern": "^\\s*([a-zA-Z][a-zA-Z0-9]*)\\s*[{,>+~:\\[\\s]",
      "captureGroup": 1,
      "kind": 7,
      "type": "element"
    },
    {
      "name": "@media Query",
      "pattern": "@media\\s+([^{]+?)\\s*\\{",
      "captureGroup": 1,
      "kind": 2,
      "type": "media-query"
    },
    {
      "name": "@keyframes",
      "pattern": "@keyframes\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\s*\\{",
      "captureGroup": 1,
      "kind": 11,
      "type": "keyframes"
    },
    {
      "name": "@font-face",
      "pattern": "@font-face\\s*\\{[^}]*font-family:\\s*[\"']?([^\"';}]+)",
      "captureGroup": 1,
      "kind": 22,
      "type": "font-face"
    },
    {
      "name": "@import",
      "pattern": "@import\\s+[\"']([^\"']+)[\"']",
      "captureGroup": 1,
      "kind": 3,
      "type": "import"
    },
    {
      "name": "@supports",
      "pattern": "@supports\\s+([^{]+?)\\s*\\{",
      "captureGroup": 1,
      "kind": 10,
      "type": "supports"
    },
    {
      "name": "@layer",
      "pattern": "@layer\\s+([a-zA-Z_][a-zA-Z0-9_.-]*)\\s*[{;]",
      "captureGroup": 1,
      "kind": 1,
      "type": "layer"
    },
    {
      "name": "CSS Variable",
      "pattern": "(--[a-zA-Z_][a-zA-Z0-9_-]*)\\s*:",
      "captureGroup": 1,
      "kind": 12,
      "type": "css-variable"
    },
    {
      "name": "Pseudo-class",
      "pattern": ":(?!:)([a-zA-Z][a-zA-Z0-9-]*)(?:\\([^)]*\\))?",
      "captureGroup": 1,
      "kind": 6,
      "type": "pseudo-class"
    },
    {
      "name": "Pseudo-element",
      "pattern": "::([a-zA-Z][a-zA-Z0-9-]*)",
      "captureGroup": 1,
      "kind": 6,
      "type": "pseudo-element"
    },
    {
      "name": "Property Declaration",
      "pattern": "^\\s+([a-zA-Z-][a-zA-Z0-9-]*)\\s*:",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": ":root Selector",
      "pattern": "(:root)\\s*\\{",
      "captureGroup": 1,
      "kind": 2,
      "type": "root"
    },
    {
      "name": "@container Query",
      "pattern": "@container\\s+([a-zA-Z_][\\w-]*)\\s*\\(",
      "captureGroup": 1,
      "kind": 2,
      "type": "container"
    },
    {
      "name": "$variable",
      "pattern": "(\\$[a-zA-Z_][\\w-]*)\\s*:",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "@mixin",
      "pattern": "@mixin\\s+([\\w-]+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "mixin"
    },
    {
      "name": "@include",
      "pattern": "@include\\s+([\\w-]+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "include"
    },
    {
      "name": "@extend",
      "pattern": "@extend\\s+([.%#][\\w-]+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "extend"
    },
    {
      "name": "@function",
      "pattern": "@function\\s+([\\w-]+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "@use",
      "pattern": "@use\\s+[\"']([^\"']+)[\"']",
      "captureGroup": 1,
      "kind": 3,
      "type": "use"
    },
    {
      "name": "@forward",
      "pattern": "@forward\\s+[\"']([^\"']+)[\"']",
      "captureGroup": 1,
      "kind": 3,
      "type": "forward"
    },
    {
      "name": "Nesting",
      "pattern": "(&[.:_#-][\\w-]+)",
      "captureGroup": 1,
      "kind": 7,
      "type": "nesting"
    },
    {
      "name": "Placeholder Selector",
      "pattern": "(%[a-zA-Z_][\\w-]*)",
      "captureGroup": 1,
      "kind": 4,
      "type": "placeholder"
    },
    {
      "name": "@each",
      "pattern": "@each\\s+(\\$[\\w-]+)\\s+in",
      "captureGroup": 1,
      "kind": 9,
      "type": "each"
    },
    {
      "name": "@for",
      "pattern": "@for\\s+(\\$[\\w-]+)\\s+from",
      "captureGroup": 1,
      "kind": 9,
      "type": "for"
    },
    {
      "name": "@while",
      "pattern": "@while\\s+(.+?)\\s*\\{",
      "captureGroup": 1,
      "kind": 9,
      "type": "while"
    },
    {
      "name": "Interpolation",
      "pattern": "#\\{([^}]+)\\}",
      "captureGroup": 1,
      "kind": 12,
      "type": "interpolation"
    },
    {
      "name": "@at-root",
      "pattern": "@at-root\\s+([^{]+?)\\s*\\{",
      "captureGroup": 1,
      "kind": 2,
      "type": "at-root"
    }
  ]
}
