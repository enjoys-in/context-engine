{
  "language": "ecl",
  "symbolPatterns": [
    {
      "name": "EXPORT definition",
      "pattern": "^\\\\s*EXPORT\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "SHARED definition",
      "pattern": "^\\\\s*SHARED\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "MODULE",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*:=\\\\s*MODULE",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "RECORD structure",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*:=\\\\s*RECORD",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "DATASET declaration",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*:=\\\\s*DATASET",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "OUTPUT",
      "pattern": "^\\\\s*OUTPUT\\\\s*\\\\(\\\\s*(\\\\w+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "TRANSFORM function",
      "pattern": "^\\\\s*(\\\\w+)\\\\s+(\\\\w+)\\\\s*\\\\(.*\\\\)\\\\s*:=\\\\s*TRANSFORM",
      "captureGroup": 2,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "ACTION",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*:=\\\\s*ACTION",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "FUNCTION",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*:=\\\\s*FUNCTION",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "MACRO",
      "pattern": "^\\\\s*MACRO\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "IMPORT",
      "pattern": "^\\\\s*IMPORT\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "INTERFACE",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*:=\\\\s*INTERFACE",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Type definition",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*:=\\\\s*(?:INTEGER|REAL|STRING|BOOLEAN|UNSIGNED|DATA|DECIMAL|UNICODE|UTF8|VARSTRING|SET\\\\s+OF)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Attribute definition",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*:=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "SERVICE",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*:=\\\\s*SERVICE",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    }
  ]
}
