{
  "language": "cameligo",
  "symbolPatterns": [
    {
      "name": "LetBinding",
      "pattern": "^let\\s+(\\w+)\\s*(?::|=)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "LetFunction",
      "pattern": "^let\\s+(\\w+)\\s+\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "LetRecursive",
      "pattern": "^let\\s+rec\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "TypeDeclaration",
      "pattern": "^type\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Module",
      "pattern": "^module\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "EntryPoint",
      "pattern": "\\[@entry\\]\\s*(?:\\n|\\r\\n?)\\s*let\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "View",
      "pattern": "\\[@view\\]\\s*(?:\\n|\\r\\n?)\\s*let\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "MatchExpression",
      "pattern": "\\bmatch\\s+(\\w+)\\s+with",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "IfThenElse",
      "pattern": "\\bif\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "FunctionParam",
      "pattern": "\\(\\s*(\\w+)\\s*:\\s*\\w+\\s*\\)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Include",
      "pattern": "^#include\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Import",
      "pattern": "^#import\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Test",
      "pattern": "^let\\s+(test_\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "RecordField",
      "pattern": "^\\s+(\\w+)\\s*:\\s*\\w+\\s*;",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "VariantConstructor",
      "pattern": "^\\s*\\|\\s+(\\w+)\\s+of",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "CallbackDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(function|=>|->)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "GenericTypeDeclaration",
      "pattern": "\\\\b(\\\\w+)<[^>]+>",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "ClosureDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(\\\\(|\\\\|)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "TestDeclaration",
      "pattern": "\\\\b(?:test|it|describe|spec)\\\\s*\\\\(?['\"]([^'\"]+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "ErrorDeclaration",
      "pattern": "\\\\b(?:class|type)\\\\s+(\\\\w*Error|\\\\w*Exception)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "ConfigObjectDeclaration",
      "pattern": "\\\\b(config|options|settings)\\\\s*[:=]\\\\s*\\\\{",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "GetterDeclaration",
      "pattern": "\\\\bget\\\\s+(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
