{
  "language": "doctest",
  "symbolPatterns": [
    {
      "name": "TestCase",
      "pattern": "^>>>\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "pattern": "^>>>\\s+def\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "description": "Function definition in doctest",
      "name": "Test"
    },
    {
      "pattern": "^>>>\\s+class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 5,
      "description": "Class definition in doctest",
      "name": "Test"
    },
    {
      "pattern": "^>>>\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 13,
      "description": "Variable assignment in doctest",
      "name": "Test"
    },
    {
      "name": "Class",
      "pattern": "(?:class|struct|interface|trait|type|record)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Variable",
      "pattern": "(?:var|let|const|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Module",
      "pattern": "(?:module|namespace|package|import)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
