{
  "language": "doctest",
  "symbolPatterns": [
    {
      "name": "TestBlock",
      "pattern": "^>>>\\s+(.+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "ExpectedOutput",
      "pattern": "^(?!>>>|\\.\\.\\.)([^\\s#].+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Continuation",
      "pattern": "^\\.\\.\\.\\s+(.+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "BlankSeparator",
      "pattern": "^(<BLANKLINE>)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "DirectiveComment",
      "pattern": "#\\s*doctest:\\s*(\\+[A-Z_]+(?:\\s*,\\s*\\+[A-Z_]+)*)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "ExceptionTest",
      "pattern": "^Traceback\\s+\\(most\\s+recent\\s+call\\s+last\\):",
      "captureGroup": 0,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "ExceptionType",
      "pattern": "^(\\w+(?:Error|Exception|Warning)):",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Ellipsis",
      "pattern": "^\\.\\.\\.$",
      "captureGroup": 0,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "NormalizeWhitespace",
      "pattern": "#\\s*doctest:\\s*(\\+NORMALIZE_WHITESPACE)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Skip",
      "pattern": "#\\s*doctest:\\s*(\\+SKIP)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "EllipsisDirective",
      "pattern": "#\\s*doctest:\\s*(\\+ELLIPSIS)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "FunctionDef",
      "pattern": "^>>>\\s+def\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "ClassDef",
      "pattern": "^>>>\\s+class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Assignment",
      "pattern": "^>>>\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    }
  ]
}
