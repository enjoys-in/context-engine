{
  "language": "scala",
  "symbolPatterns": [
    {
      "name": "Class",
      "pattern": "^\\s*(?:(?:abstract|sealed|final|open|private|protected)\\s+)*class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Case Class",
      "pattern": "^\\s*(?:(?:abstract|sealed|final|private|protected)\\s+)*case\\s+class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "case class"
    },
    {
      "name": "Object",
      "pattern": "^\\s*(?:(?:private|protected|implicit|lazy)\\s+)*object\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "object"
    },
    {
      "name": "Trait",
      "pattern": "^\\s*(?:(?:private|protected)\\s+)*trait\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "trait"
    },
    {
      "name": "Sealed Trait",
      "pattern": "^\\s*(?:(?:private|protected)\\s+)*sealed\\s+trait\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "sealed trait"
    },
    {
      "name": "Def",
      "pattern": "^\\s*(?:(?:override|private|protected|final|abstract|implicit|inline|transparent|infix)\\s+)*def\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "def"
    },
    {
      "name": "Val",
      "pattern": "^\\s*(?:(?:override|private|protected|final|implicit)\\s+)*val\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "val"
    },
    {
      "name": "Var",
      "pattern": "^\\s*(?:(?:override|private|protected)\\s+)*var\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "var"
    },
    {
      "name": "Lazy Val",
      "pattern": "^\\s*(?:(?:override|private|protected|final)\\s+)*lazy\\s+val\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "lazy val"
    },
    {
      "name": "Type Alias",
      "pattern": "^\\s*(?:(?:override|private|protected|opaque)\\s+)*type\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 25,
      "type": "type alias"
    },
    {
      "name": "Package Object",
      "pattern": "^\\s*package\\s+object\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 3,
      "type": "package object"
    },
    {
      "name": "Import",
      "pattern": "^\\s*import\\s+([\\w.{},_ *]+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "import"
    },
    {
      "name": "Implicit",
      "pattern": "^\\s*implicit\\s+(?:val|def|class|object|lazy\\s+val)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "implicit"
    },
    {
      "name": "Given (Scala 3)",
      "pattern": "^\\s*(?:(?:private|protected)\\s+)*given\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "given"
    },
    {
      "name": "Extension (Scala 3)",
      "pattern": "^\\s*extension\\s*(?:\\[\\w+\\])?\\s*\\((\\w+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "extension"
    },
    {
      "name": "Enum (Scala 3)",
      "pattern": "^\\s*(?:(?:private|protected)\\s+)*enum\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Enum Case (Scala 3)",
      "pattern": "^\\s*case\\s+(\\w+)(?:\\s*\\(|\\s*extends|\\s*$)",
      "captureGroup": 1,
      "kind": 21,
      "type": "enum case"
    },
    {
      "name": "CallbackDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(function|=>|->)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "GenericTypeDeclaration",
      "pattern": "\\\\b(\\\\w+)<[^>]+>",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "ClosureDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(\\\\(|\\\\|)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "TestDeclaration",
      "pattern": "\\\\b(?:test|it|describe|spec)\\\\s*\\\\(?['\"]([^'\"]+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "ErrorDeclaration",
      "pattern": "\\\\b(?:class|type)\\\\s+(\\\\w*Error|\\\\w*Exception)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    }
  ]
}
