{
  "language": "postiats",
  "symbolPatterns": [
    {
      "name": "Fun",
      "pattern": "^\\s*(?:fun|fn)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Implement",
      "pattern": "^\\s*implement\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Val",
      "pattern": "^\\s*val\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Var",
      "pattern": "^\\s*var\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Datatype",
      "pattern": "^\\s*datatype\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Datasort",
      "pattern": "^\\s*datasort\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Typedef",
      "pattern": "^\\s*typedef\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Stadef",
      "pattern": "^\\s*stadef\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Sortdef",
      "pattern": "^\\s*sortdef\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Exception",
      "pattern": "^\\s*exception\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Assume",
      "pattern": "^\\s*assume\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Extern",
      "pattern": "^\\s*extern\\s+(?:fun|fn|val)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Macdef",
      "pattern": "^\\s*macdef\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Staload",
      "pattern": "^\\s*staload\\s+(?:\"([^\"]+)\"|\\w+\\s*=\\s*\"([^\"]+)\")",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Dynload",
      "pattern": "^\\s*dynload\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Include",
      "pattern": "^\\s*#include\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "ProofFunction",
      "pattern": "^\\s*(?:prfun|prfn)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Abstype",
      "pattern": "^\\s*(?:abstype|abst@ype|absvtype|absvt@ype)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Overload",
      "pattern": "^\\s*overload\\s+(\\S+)\\s+with",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Where",
      "pattern": "\\bwhere\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    }
  ]
}
