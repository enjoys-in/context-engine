{
  "language": "cypher",
  "symbolPatterns": [
    {
      "name": "Node Label",
      "pattern": "^\\s*CREATE\\s+\\([^:]*:(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Relationship Type",
      "pattern": "-\\[\\w*:(\\w+)\\]->",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Variable",
      "pattern": "\\((\\w+)\\s*[:{)]",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*:",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Function Call",
      "pattern": "(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Parameter",
      "pattern": "\\$(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    }
  ]
}