{
  "language": "cypher",
  "symbolPatterns": [
    {
      "name": "Node Label",
      "pattern": "^\\s*CREATE\\s+\\([^:]*:(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Relationship Type",
      "pattern": "-\\[\\w*:(\\w+)\\]->",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Variable",
      "pattern": "\\((\\w+)\\s*[:{)]",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*:",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Function Call",
      "pattern": "(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Parameter",
      "pattern": "\\$(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Module",
      "pattern": "(?:module|namespace|package|import)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Method",
      "pattern": "(?:public|private|protected)?\\s*(?:static)?\\s*(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    }
  ]
}
