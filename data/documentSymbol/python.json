{
  "language": "python",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\\\s*(?:async\\\\s+)?def\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Class",
      "pattern": "^\\\\s*class\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Variable",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*(?::\\\\s*\\\\w+\\\\s*)?=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    }
  ]
}