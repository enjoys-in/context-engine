{
  "language": "csharp",
  "symbolPatterns": [
    {
      "name": "Class",
      "pattern": "^\\\\s*(?:public|private|protected|internal|static|abstract|sealed|partial)?\\\\s*class\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Interface",
      "pattern": "^\\\\s*(?:public|private|protected|internal)?\\\\s*interface\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Method",
      "pattern": "^\\\\s*(?:public|private|protected|internal|static|virtual|override|abstract|async)?\\\\s*[\\\\w<>\\\\[\\\\],?]+\\\\s+(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Enum",
      "pattern": "^\\\\s*(?:public|private|protected|internal)?\\\\s*enum\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Struct",
      "pattern": "^\\\\s*(?:public|private|protected|internal)?\\\\s*struct\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Namespace",
      "pattern": "^\\\\s*namespace\\\\s+([\\\\w.]+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "module"
    },
    {
      "name": "Function",
      "pattern": "(?:function|def|fn|func|sub|proc)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Variable",
      "pattern": "(?:var|let|const|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
