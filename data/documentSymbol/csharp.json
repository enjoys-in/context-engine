{
  "language": "csharp",
  "symbolPatterns": [
    {
      "name": "Class",
      "pattern": "^\\s*(?:(?:public|private|protected|internal|static|abstract|sealed|partial|new)\\s+)*class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Record",
      "pattern": "^\\s*(?:(?:public|private|protected|internal|sealed|abstract|partial)\\s+)*record\\s+(?:class\\s+|struct\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Interface",
      "pattern": "^\\s*(?:(?:public|private|protected|internal|partial)\\s+)*interface\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Struct",
      "pattern": "^\\s*(?:(?:public|private|protected|internal|readonly|ref|partial)\\s+)*struct\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Enum",
      "pattern": "^\\s*(?:(?:public|private|protected|internal)\\s+)*enum\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "EnumMember",
      "pattern": "^\\s+(\\w+)\\s*(?:=\\s*[^,]+)?\\s*[,}]?\\s*$",
      "captureGroup": 1,
      "kind": 21,
      "type": "enumMember"
    },
    {
      "name": "Namespace",
      "pattern": "^\\s*namespace\\s+([\\w.]+)\\s*[{;]",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Method",
      "pattern": "^\\s*(?:(?:public|private|protected|internal|static|virtual|override|abstract|async|partial|new|sealed|extern|unsafe)\\s+)*[\\w<>\\[\\],?]+\\s+(\\w+)\\s*(?:<[^>]*>)?\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "ExtensionMethod",
      "pattern": "^\\s*(?:(?:public|internal)\\s+)*static\\s+[\\w<>\\[\\],?]+\\s+(\\w+)\\s*\\(\\s*this\\s+",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Constructor",
      "pattern": "^\\s*(?:(?:public|private|protected|internal|static)\\s+)*(\\w+)\\s*\\([^)]*\\)\\s*(?::|\\{)",
      "captureGroup": 1,
      "kind": 8,
      "type": "constructor"
    },
    {
      "name": "PrimaryConstructor",
      "pattern": "^\\s*(?:(?:public|private|protected|internal|sealed|abstract|partial)\\s+)*(?:class|struct|record)\\s+(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 8,
      "type": "constructor"
    },
    {
      "name": "Finalizer",
      "pattern": "^\\s*~(\\w+)\\s*\\(\\s*\\)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Property",
      "pattern": "^\\s*(?:(?:public|private|protected|internal|static|virtual|override|abstract|sealed|new|required)\\s+)*[\\w<>\\[\\],?]+\\s+(\\w+)\\s*\\{\\s*(?:get|set|init)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "AutoProperty",
      "pattern": "^\\s*(?:(?:public|private|protected|internal|static|virtual|override|abstract|required)\\s+)*[\\w<>\\[\\],?]+\\s+(\\w+)\\s*\\{\\s*get;",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Field",
      "pattern": "^\\s*(?:(?:public|private|protected|internal|static|readonly|volatile|new|required)\\s+)+[\\w<>\\[\\],?]+\\s+(\\w+)\\s*[;=]",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "Constant",
      "pattern": "^\\s*(?:(?:public|private|protected|internal)\\s+)*const\\s+[\\w<>\\[\\],?]+\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Event",
      "pattern": "^\\s*(?:(?:public|private|protected|internal|static|virtual|override|abstract|sealed|new)\\s+)*event\\s+[\\w<>]+\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 23,
      "type": "event"
    },
    {
      "name": "Delegate",
      "pattern": "^\\s*(?:(?:public|private|protected|internal)\\s+)*delegate\\s+[\\w<>\\[\\],?]+\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Indexer",
      "pattern": "^\\s*(?:(?:public|private|protected|internal|static|virtual|override)\\s+)*[\\w<>\\[\\],?]+\\s+(this)\\s*\\[",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "OperatorOverload",
      "pattern": "^\\s*(?:(?:public|private|protected|internal)\\s+)*static\\s+[\\w<>]+\\s+operator\\s*([^(]+?)\\s*\\(",
      "captureGroup": 1,
      "kind": 24,
      "type": "operator"
    },
    {
      "name": "UsingDirective",
      "pattern": "^\\s*(?:global\\s+)?using\\s+(?:static\\s+)?([\\w.]+)\\s*;",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "UsingAlias",
      "pattern": "^\\s*(?:global\\s+)?using\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 25,
      "type": "typeAlias"
    },
    {
      "name": "Attribute",
      "pattern": "^\\s*\\[([\\w.]+)(?:\\([^)]*\\))?\\]",
      "captureGroup": 1,
      "kind": 18,
      "type": "object"
    },
    {
      "name": "GenericConstraint",
      "pattern": "\\bwhere\\s+(\\w+)\\s*:",
      "captureGroup": 1,
      "kind": 25,
      "type": "typeParameter"
    }
  ]
}
