{
  "language": "docker-compose",
  "symbolPatterns": [
    {
      "name": "Version",
      "pattern": "^version:\\s*['\"]?([\\d.]+)['\"]?",
      "captureGroup": 1,
      "kind": 13,
      "type": "version"
    },
    {
      "name": "Top-level services",
      "pattern": "^services:\\s*$",
      "captureGroup": 0,
      "kind": 2,
      "type": "section"
    },
    {
      "name": "Top-level networks",
      "pattern": "^networks:\\s*$",
      "captureGroup": 0,
      "kind": 2,
      "type": "section"
    },
    {
      "name": "Top-level volumes",
      "pattern": "^volumes:\\s*$",
      "captureGroup": 0,
      "kind": 2,
      "type": "section"
    },
    {
      "name": "Secrets",
      "pattern": "^secrets:\\s*$",
      "captureGroup": 0,
      "kind": 19,
      "type": "secrets"
    },
    {
      "name": "Configs",
      "pattern": "^configs:\\s*$",
      "captureGroup": 0,
      "kind": 19,
      "type": "configs"
    },
    {
      "name": "Service definition",
      "pattern": "^\\s{2}(\\w[\\w.-]*):\\s*$",
      "captureGroup": 1,
      "kind": 4,
      "type": "service"
    },
    {
      "name": "Image",
      "pattern": "^\\s+image:\\s*(.+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "image"
    },
    {
      "name": "Build context",
      "pattern": "^\\s+build:\\s*(\\S.*)",
      "captureGroup": 1,
      "kind": 5,
      "type": "build"
    },
    {
      "name": "Port mapping",
      "pattern": "^\\s+-\\s*['\"]?(\\d[\\d.:/-]+)['\"]?",
      "captureGroup": 1,
      "kind": 6,
      "type": "port"
    },
    {
      "name": "Volume mount",
      "pattern": "^\\s+-\\s*([\\w./${}][\\w./${}:-]+:[\\w./:-]+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "volume"
    },
    {
      "name": "Environment variable (list)",
      "pattern": "^\\s+-\\s*(\\w+)=(.+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "envvar"
    },
    {
      "name": "Environment variable (map)",
      "pattern": "^\\s{6}(\\w+):\\s*.+",
      "captureGroup": 1,
      "kind": 12,
      "type": "envvar"
    },
    {
      "name": "Networks",
      "pattern": "^\\s{4}networks:",
      "captureGroup": 0,
      "kind": 6,
      "type": "networks"
    },
    {
      "name": "Depends on",
      "pattern": "^\\s{4}depends_on:",
      "captureGroup": 0,
      "kind": 6,
      "type": "dependency"
    },
    {
      "name": "Command",
      "pattern": "^\\s+command:\\s*(.+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "command"
    },
    {
      "name": "CallbackDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(function|=>|->)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "GenericTypeDeclaration",
      "pattern": "\\\\b(\\\\w+)<[^>]+>",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "ClosureDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(\\\\(|\\\\|)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "TestDeclaration",
      "pattern": "\\\\b(?:test|it|describe|spec)\\\\s*\\\\(?['\"]([^'\"]+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "ErrorDeclaration",
      "pattern": "\\\\b(?:class|type)\\\\s+(\\\\w*Error|\\\\w*Exception)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "ConfigObjectDeclaration",
      "pattern": "\\\\b(config|options|settings)\\\\s*[:=]\\\\s*\\\\{",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    }
  ]
}
