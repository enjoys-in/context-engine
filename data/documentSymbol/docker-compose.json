{
  "language": "docker-compose",
  "symbolPatterns": [
    {
      "name": "Service Definition",
      "pattern": "^  (\\w[\\w-]*):\\s*$",
      "captureGroup": 1,
      "kind": 1,
      "detail": "service"
    },
    {
      "name": "Top-level Services",
      "pattern": "^services:\\s*$",
      "captureGroup": 0,
      "kind": 2,
      "detail": "namespace"
    },
    {
      "name": "Top-level Networks",
      "pattern": "^networks:\\s*$",
      "captureGroup": 0,
      "kind": 2,
      "detail": "namespace"
    },
    {
      "name": "Top-level Volumes",
      "pattern": "^volumes:\\s*$",
      "captureGroup": 0,
      "kind": 2,
      "detail": "namespace"
    },
    {
      "name": "Top-level Secrets",
      "pattern": "^secrets:\\s*$",
      "captureGroup": 0,
      "kind": 2,
      "detail": "namespace"
    },
    {
      "name": "Top-level Configs",
      "pattern": "^configs:\\s*$",
      "captureGroup": 0,
      "kind": 2,
      "detail": "namespace"
    },
    {
      "name": "Named Network",
      "pattern": "^  (\\w[\\w-]*):\\s*$",
      "captureGroup": 1,
      "kind": 7,
      "detail": "network"
    },
    {
      "name": "Named Volume",
      "pattern": "^  (\\w[\\w-]*):\\s*$",
      "captureGroup": 1,
      "kind": 12,
      "detail": "volume"
    },
    {
      "name": "Environment Variable",
      "pattern": "^\\s+(\\w+):\\s+.+$",
      "captureGroup": 1,
      "kind": 12,
      "detail": "variable"
    },
    {
      "name": "YAML Anchor",
      "pattern": "^x-([\\w-]+):\\s*&([\\w-]+)",
      "captureGroup": 2,
      "kind": 13,
      "detail": "anchor"
    }
  ]
}
