{
  "language": "elixir",
  "symbolPatterns": [
    {
      "name": "Module",
      "pattern": "^\\s*defmodule\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Function",
      "pattern": "^\\s*def[p]?\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Macro",
      "pattern": "^\\s*defmacro[p]?\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Struct",
      "pattern": "^\\s*defstruct\\b",
      "captureGroup": 0,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Protocol",
      "pattern": "^\\s*defprotocol\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    }
  ]
}