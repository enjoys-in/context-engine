{
  "language": "elixir",
  "symbolPatterns": [
    {
      "name": "Module",
      "pattern": "^\\s*defmodule\\s+([A-Z][\\w.]*)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Function",
      "pattern": "^\\s*def\\s+(\\w+[!?]?)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Private Function",
      "pattern": "^\\s*defp\\s+(\\w+[!?]?)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Macro",
      "pattern": "^\\s*defmacro\\s+(\\w+[!?]?)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Private Macro",
      "pattern": "^\\s*defmacrop\\s+(\\w+[!?]?)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Guard",
      "pattern": "^\\s*defguard[p]?\\s+(\\w+[!?]?)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Protocol",
      "pattern": "^\\s*defprotocol\\s+([A-Z][\\w.]*)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Impl",
      "pattern": "^\\s*defimpl\\s+([A-Z][\\w.]*)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Struct",
      "pattern": "^\\s*defstruct\\s",
      "captureGroup": 0,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Callback",
      "pattern": "^\\s*@callback\\s+(\\w+[!?]?)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Type",
      "pattern": "^\\s*@type\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Private Type",
      "pattern": "^\\s*@typep\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Opaque Type",
      "pattern": "^\\s*@opaque\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Module Attribute",
      "pattern": "^\\s*@(\\w+)\\s+",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Behaviour",
      "pattern": "^\\s*@behaviour\\s+([A-Z][\\w.]*)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Use",
      "pattern": "^\\s*use\\s+([A-Z][\\w.]*)",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Import",
      "pattern": "^\\s*import\\s+([A-Z][\\w.]*)",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Alias",
      "pattern": "^\\s*alias\\s+([A-Z][\\w.]*)",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Require",
      "pattern": "^\\s*require\\s+([A-Z][\\w.]*)",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Delegate",
      "pattern": "^\\s*defdelegate\\s+(\\w+[!?]?)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Exception",
      "pattern": "^\\s*defexception\\s",
      "captureGroup": 0,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Override",
      "pattern": "^\\s*defoverridable\\s",
      "captureGroup": 0,
      "kind": 11,
      "type": "function"
    }
  ]
}
