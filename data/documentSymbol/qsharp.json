{
  "language": "qsharp",
  "symbolPatterns": [
    {
      "name": "Operation",
      "pattern": "^\\s*(?:internal\\s+)?operation\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Function",
      "pattern": "^\\s*(?:internal\\s+)?function\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Newtype",
      "pattern": "^\\s*newtype\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Namespace",
      "pattern": "^\\s*namespace\\s+([\\w.]+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Open",
      "pattern": "^\\s*open\\s+([\\w.]+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "BodySpecialization",
      "pattern": "^\\s*(body)\\s*(?:\\.\\.\\.|\\{)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "AdjointSpecialization",
      "pattern": "^\\s*(adjoint)\\s+(?:auto|self|invert|\\.\\.\\.|\\{)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "ControlledSpecialization",
      "pattern": "^\\s*(controlled)\\s+(?:auto|distribute|\\.\\.\\.|\\{)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "MutableVariable",
      "pattern": "^\\s*mutable\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "LetBinding",
      "pattern": "^\\s*let\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "UsingQubits",
      "pattern": "^\\s*using\\s*\\(\\s*(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "BorrowingQubits",
      "pattern": "^\\s*borrowing\\s*\\(\\s*(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "If",
      "pattern": "^\\s*(if)\\s*\\(",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Elif",
      "pattern": "^\\s*(elif)\\s*\\(",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Else",
      "pattern": "^\\s*(else)\\s*\\{",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "ForLoop",
      "pattern": "^\\s*for\\s*\\(\\s*(\\w+)\\s+in",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "RepeatUntil",
      "pattern": "^\\s*(repeat)\\s*\\{",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Return",
      "pattern": "^\\s*(return)\\b",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "InternalAccess",
      "pattern": "^\\s*(internal)\\s+(?:operation|function)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
