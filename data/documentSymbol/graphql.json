{
  "language": "graphql",
  "symbolPatterns": [
    {
      "name": "Type Definition",
      "pattern": "^\\\\s*type\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Input Type",
      "pattern": "^\\\\s*input\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Interface",
      "pattern": "^\\\\s*interface\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Enum",
      "pattern": "^\\\\s*enum\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Union",
      "pattern": "^\\\\s*union\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Scalar",
      "pattern": "^\\\\s*scalar\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Schema Definition",
      "pattern": "^\\\\s*(schema)\\\\s*\\\\{",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Query",
      "pattern": "^\\\\s*query\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Mutation",
      "pattern": "^\\\\s*mutation\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Subscription",
      "pattern": "^\\\\s*subscription\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Field Definition",
      "pattern": "^\\\\s+(\\\\w+)\\\\s*(?:\\\\([^)]*\\\\))?\\\\s*:\\\\s*",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "Argument",
      "pattern": "^\\\\s+(\\\\w+)\\\\s*:\\\\s*(?:\\\\[?\\\\w+\\\\]?!?)\\\\s*(?:=|,|\\\\))",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Directive Definition",
      "pattern": "^\\\\s*directive\\\\s+@(\\\\w+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Fragment",
      "pattern": "^\\\\s*fragment\\\\s+(\\\\w+)\\\\s+on\\\\s+\\\\w+",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Extend Type",
      "pattern": "^\\\\s*extend\\\\s+type\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "CallbackDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(function|=>|->)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "GenericTypeDeclaration",
      "pattern": "\\\\b(\\\\w+)<[^>]+>",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "ClosureDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(\\\\(|\\\\|)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "TestDeclaration",
      "pattern": "\\\\b(?:test|it|describe|spec)\\\\s*\\\\(?['\"]([^'\"]+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "ErrorDeclaration",
      "pattern": "\\\\b(?:class|type)\\\\s+(\\\\w*Error|\\\\w*Exception)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "ConfigObjectDeclaration",
      "pattern": "\\\\b(config|options|settings)\\\\s*[:=]\\\\s*\\\\{",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "GetterDeclaration",
      "pattern": "\\\\bget\\\\s+(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
