{
  "language": "mysql",
  "symbolPatterns": [
    {
      "name": "Table",
      "pattern": "CREATE\\s+TABLE\\s+(?:IF\\s+NOT\\s+EXISTS\\s+)?`?(\\w+)`?",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Procedure",
      "pattern": "CREATE\\s+PROCEDURE\\s+`?(\\w+)`?",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Function",
      "pattern": "CREATE\\s+FUNCTION\\s+`?(\\w+)`?",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "View",
      "pattern": "CREATE\\s+VIEW\\s+`?(\\w+)`?",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Variable",
      "pattern": "(?:var|let|const|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Module",
      "pattern": "(?:module|namespace|package|import)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Method",
      "pattern": "(?:public|private|protected)?\\s*(?:static)?\\s*(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    }
  ]
}
