      "kind": 4,
      "type": "class"
    },
    {
      "name": "Procedure",
      "pattern": "CREATE\\s+PROCEDURE\\s+`?(\\w+)`?",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Function",
      "pattern": "CREATE\\s+FUNCTION\\s+`?(\\w+)`?",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "View",
      "pattern": "CREATE\\s+VIEW\\s+`?(\\w+)`?",
