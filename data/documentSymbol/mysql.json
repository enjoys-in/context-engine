{
  "language": "mysql",
  "symbolPatterns": [
    {
      "name": "CreateTable",
      "pattern": "CREATE\\s+TABLE\\s+(?:IF\\s+NOT\\s+EXISTS\\s+)?`?([\\w.]+)`?",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "CreateView",
      "pattern": "CREATE\\s+(?:OR\\s+REPLACE\\s+)?(?:ALGORITHM\\s*=\\s*\\w+\\s+)?VIEW\\s+`?([\\w.]+)`?",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "CreateIndex",
      "pattern": "CREATE\\s+(?:UNIQUE\\s+|FULLTEXT\\s+|SPATIAL\\s+)?INDEX\\s+`?([\\w.]+)`?",
      "captureGroup": 1,
      "kind": 19,
      "type": "key"
    },
    {
      "name": "CreateProcedure",
      "pattern": "CREATE\\s+(?:DEFINER\\s*=\\s*\\S+\\s+)?PROCEDURE\\s+`?([\\w.]+)`?",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "CreateFunction",
      "pattern": "CREATE\\s+(?:DEFINER\\s*=\\s*\\S+\\s+)?FUNCTION\\s+`?([\\w.]+)`?",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "CreateTrigger",
      "pattern": "CREATE\\s+(?:DEFINER\\s*=\\s*\\S+\\s+)?TRIGGER\\s+`?([\\w.]+)`?",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "AlterTable",
      "pattern": "ALTER\\s+TABLE\\s+`?([\\w.]+)`?",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "DropTable",
      "pattern": "DROP\\s+TABLE\\s+(?:IF\\s+EXISTS\\s+)?`?([\\w.]+)`?",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "SelectAlias",
      "pattern": "\\)\\s+AS\\s+`?(\\w+)`?",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "InsertInto",
      "pattern": "INSERT\\s+(?:IGNORE\\s+)?INTO\\s+`?([\\w.]+)`?",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Update",
      "pattern": "UPDATE\\s+(?:LOW_PRIORITY\\s+|IGNORE\\s+)?`?([\\w.]+)`?\\s+SET\\b",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "DeleteFrom",
      "pattern": "DELETE\\s+(?:LOW_PRIORITY\\s+|QUICK\\s+|IGNORE\\s+)*FROM\\s+`?([\\w.]+)`?",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "CTE",
      "pattern": "(?:WITH|,)\\s+(?:RECURSIVE\\s+)?`?(\\w+)`?\\s+AS\\s*\\(",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Grant",
      "pattern": "GRANT\\s+[\\w,\\s]+ON\\s+(?:TABLE\\s+)?`?([\\w.*]+)`?",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Revoke",
      "pattern": "REVOKE\\s+[\\w,\\s]+ON\\s+(?:TABLE\\s+)?`?([\\w.*]+)`?",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "DeclareVariable",
      "pattern": "DECLARE\\s+(\\w+)\\s+\\w+",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "CreateSchema",
      "pattern": "CREATE\\s+SCHEMA\\s+(?:IF\\s+NOT\\s+EXISTS\\s+)?`?(\\w+)`?",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Constraint",
      "pattern": "CONSTRAINT\\s+`?(\\w+)`?\\s+(?:PRIMARY|FOREIGN|UNIQUE|CHECK)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Delimiter",
      "pattern": "DELIMITER\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "CreateDatabase",
      "pattern": "CREATE\\s+DATABASE\\s+(?:IF\\s+NOT\\s+EXISTS\\s+)?`?(\\w+)`?",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Engine",
      "pattern": "ENGINE\\s*=\\s*(\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "AutoIncrement",
      "pattern": "AUTO_INCREMENT\\s*=\\s*(\\d+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "PartitionBy",
      "pattern": "PARTITION\\s+BY\\s+(RANGE|LIST|HASH|KEY|LINEAR\\s+HASH|LINEAR\\s+KEY)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "CreateEvent",
      "pattern": "CREATE\\s+(?:DEFINER\\s*=\\s*\\S+\\s+)?EVENT\\s+(?:IF\\s+NOT\\s+EXISTS\\s+)?`?([\\w.]+)`?",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "CreateUser",
      "pattern": "CREATE\\s+USER\\s+(?:IF\\s+NOT\\s+EXISTS\\s+)?'?([\\w@%.]+)'?",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Definer",
      "pattern": "DEFINER\\s*=\\s*`?([\\w@%.']+)`?",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "DeclareHandler",
      "pattern": "DECLARE\\s+(CONTINUE|EXIT|UNDO)\\s+HANDLER\\s+FOR",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Signal",
      "pattern": "(?:SIGNAL|RESIGNAL)\\s+(?:SQLSTATE\\s+(?:VALUE\\s+)?'?(\\w+)'?|(\\w+))",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    }
  ]
}
