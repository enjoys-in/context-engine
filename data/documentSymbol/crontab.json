{
  "language": "crontab",
  "symbolPatterns": [
    {
      "name": "Cron Entry",
      "pattern": "^\\\\s*(\\\\S+\\\\s+\\\\S+\\\\s+\\\\S+\\\\s+\\\\S+\\\\s+\\\\S+)\\\\s+(.+)",
      "captureGroup": 0,
      "kind": 11,
      "type": "function"
    },
    {
      "pattern": "^#\\s*(.+)",
      "captureGroup": 1,
      "kind": 15,
      "description": "Comment / description",
      "name": "Comment"
    },
    {
      "pattern": "^[@\\d*].*\\s+(\\S+)$",
      "captureGroup": 1,
      "kind": 12,
      "description": "Scheduled command",
      "name": "Symbol"
    },
    {
      "pattern": "^(\\w+)=(.*)",
      "captureGroup": 1,
      "kind": 13,
      "description": "Environment variable",
      "name": "Symbol"
    },
    {
      "name": "Class",
      "pattern": "(?:class|struct|interface|trait|type|record)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Variable",
      "pattern": "(?:var|let|const|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Module",
      "pattern": "(?:module|namespace|package|import)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
