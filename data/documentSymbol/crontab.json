{
  "language": "crontab",
  "symbolPatterns": [
    {
      "name": "CronEntry",
      "pattern": "^\\s*(\\S+\\s+\\S+\\s+\\S+\\s+\\S+\\s+\\S+)\\s+(.+)",
      "captureGroup": 2,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "SpecialSchedule",
      "pattern": "^\\s*(@(?:reboot|hourly|daily|midnight|weekly|monthly|annually|yearly))\\s+(.+)",
      "captureGroup": 0,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Mailto",
      "pattern": "^\\s*MAILTO\\s*=\\s*(.*)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Shell",
      "pattern": "^\\s*SHELL\\s*=\\s*(\\S+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Path",
      "pattern": "^\\s*PATH\\s*=\\s*(\\S+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "EnvVariable",
      "pattern": "^\\s*(\\w+)\\s*=\\s*(.+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Comment",
      "pattern": "^\\s*#\\s*(.+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    }
  ]
}
