{
  "language": "pascaligo",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\s*function\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Recursive Function",
      "pattern": "^\\s*recursive\\s+function\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Const",
      "pattern": "^\\s*const\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Var",
      "pattern": "^\\s*var\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Type Declaration",
      "pattern": "^\\s*type\\s+(\\w+)\\s+is",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Record Type",
      "pattern": "^\\s*type\\s+(\\w+)\\s+is\\s+record",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Module",
      "pattern": "^\\s*module\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Entry Point",
      "pattern": "^\\s*function\\s+(main)\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Block Expression",
      "pattern": "^\\s*(block)\\s*\\{",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "For Loop",
      "pattern": "^\\s*for\\s+(\\w+)\\s+:=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "While Loop",
      "pattern": "^\\s*(while)\\s+",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Case Expression",
      "pattern": "^\\s*case\\s+(\\w+)\\s+of",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "FunctionDeclaration",
      "pattern": "(?:function|def|fn|func|sub|proc)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "ClassDeclaration",
      "pattern": "\\\\bclass\\\\s+([A-Z]\\\\w*)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "VariableDeclaration",
      "pattern": "(?:const|let|var|val|dim)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "ConstantDeclaration",
      "pattern": "(?:const|final|readonly)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "MethodDeclaration",
      "pattern": "(?:public|private|protected)?\\\\s*(?:static\\\\s+)?(?:\\\\w+\\\\s+)?(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "PropertyDeclaration",
      "pattern": "(\\\\w+)\\\\s*[=:]\\\\s*",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "InterfaceDeclaration",
      "pattern": "\\\\binterface\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "EnumDeclaration",
      "pattern": "\\\\benum\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "TypeDeclaration",
      "pattern": "(?:type|struct|record)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "ModuleDeclaration",
      "pattern": "(?:module|namespace|package)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "NamespaceDeclaration",
      "pattern": "\\\\b(namespace|package|module)\\\\s+[\\\\w.]+",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "ConstructorDeclaration",
      "pattern": "(constructor|__init__|init|initialize)\\\\s*\\\\(?",
      "captureGroup": 1,
      "kind": 8,
      "type": "constructor"
    },
    {
      "name": "EventDeclaration",
      "pattern": "\\\\b(on\\\\w+|handle\\\\w+|emit\\\\w+)\\\\b",
      "captureGroup": 1,
      "kind": 23,
      "type": "event"
    },
    {
      "name": "ImportStatement",
      "pattern": "import\\\\s+.*?['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "ExportStatement",
      "pattern": "(?:export|pub|public)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "CommentBlock",
      "pattern": "\\/\\\\*\\\\*([\\\\s\\\\S]*?)\\\\*\\/",
      "captureGroup": 0,
      "kind": 20,
      "type": "string"
    },
    {
      "name": "AnnotationDeclaration",
      "pattern": "@\\\\w+",
      "captureGroup": 1,
      "kind": 24,
      "type": "operator"
    },
    {
      "name": "FieldDeclaration",
      "pattern": "(\\\\w+)\\\\s*:\\\\s*\\\\w+",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "KeyDeclaration",
      "pattern": "\"?(\\\\w+)\"?\\\\s*[:=]",
      "captureGroup": 1,
      "kind": 19,
      "type": "key"
    },
    {
      "name": "ArrayDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*\\\\[",
      "captureGroup": 1,
      "kind": 17,
      "type": "array"
    }
  ]
}
