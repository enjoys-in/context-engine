{
  "language": "pascaligo",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\s*function\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Recursive Function",
      "pattern": "^\\s*recursive\\s+function\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Const",
      "pattern": "^\\s*const\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Var",
      "pattern": "^\\s*var\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Type Declaration",
      "pattern": "^\\s*type\\s+(\\w+)\\s+is",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Record Type",
      "pattern": "^\\s*type\\s+(\\w+)\\s+is\\s+record",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Module",
      "pattern": "^\\s*module\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Entry Point",
      "pattern": "^\\s*function\\s+(main)\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Block Expression",
      "pattern": "^\\s*(block)\\s*\\{",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "For Loop",
      "pattern": "^\\s*for\\s+(\\w+)\\s+:=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "While Loop",
      "pattern": "^\\s*(while)\\s+",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Case Expression",
      "pattern": "^\\s*case\\s+(\\w+)\\s+of",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    }
  ]
}
