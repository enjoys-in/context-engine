{
  "language": "less",
  "symbolPatterns": [
    {
      "name": "Variable",
      "pattern": "^\\s*(@\\w+)\\s*:",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Mixin",
      "pattern": "^\\s*\\.([\\w-]+)\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Selector",
      "pattern": "^\\s*([.#][\\w-]+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    }
  ]
}