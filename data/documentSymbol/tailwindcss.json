{
  "language": "tailwindcss",
  "symbolPatterns": [
    {
      "name": "Config Export",
      "pattern": "(?:module\\.exports\\s*=|export\\s+default)\\s*(?:defineConfig\\()?\\s*\\{",
      "captureGroup": 0,
      "kind": 1,
      "type": "config"
    },
    {
      "name": "Theme Key",
      "pattern": "^\\s+(colors|spacing|fontSize|fontFamily|fontWeight|borderRadius|screens|extend|animation|keyframes|backgroundImage|boxShadow|width|height|maxWidth|minHeight|zIndex|opacity|lineHeight|letterSpacing|container)\\s*:",
      "captureGroup": 1,
      "kind": 19,
      "type": "themeKey"
    },
    {
      "name": "Extend Section",
      "pattern": "\\bextend\\s*:\\s*\\{",
      "captureGroup": 0,
      "kind": 2,
      "type": "extend"
    },
    {
      "name": "Plugin",
      "pattern": "(?:require\\(['\"]|plugin\\(|from\\s+['\"])([\\w@/-]+plugin[\\w/-]*)['\"]\\)?",
      "captureGroup": 1,
      "kind": 1,
      "type": "plugin"
    },
    {
      "name": "Plugin Function",
      "pattern": "plugin\\((?:function)?\\s*\\(\\{\\s*(addUtilities|addComponents|addBase|addVariant|matchUtilities|theme|e)",
      "captureGroup": 1,
      "kind": 11,
      "type": "pluginFn"
    },
    {
      "name": "addVariant",
      "pattern": "addVariant\\(['\"]([\\w-]+)['\"]",
      "captureGroup": 1,
      "kind": 5,
      "type": "variant"
    },
    {
      "name": "Screen Breakpoint",
      "pattern": "^\\s+['\"]?(sm|md|lg|xl|2xl|\\w+)['\"]?\\s*:\\s*['\"]?\\d+(?:px|rem|em)",
      "captureGroup": 1,
      "kind": 13,
      "type": "screen"
    },
    {
      "name": "Content Path",
      "pattern": "content\\s*:\\s*\\[[^\\]]*['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "kind": 7,
      "type": "contentPath"
    },
    {
      "name": "@layer utilities",
      "pattern": "@layer\\s+utilities\\s*\\{",
      "captureGroup": 0,
      "kind": 2,
      "type": "layerUtilities"
    },
    {
      "name": "@layer components",
      "pattern": "@layer\\s+components\\s*\\{",
      "captureGroup": 0,
      "kind": 2,
      "type": "layerComponents"
    },
    {
      "name": "@apply Directive",
      "pattern": "\\.([\\w-]+)\\s*\\{[^}]*@apply\\s+([^;]+);",
      "captureGroup": 1,
      "kind": 4,
      "type": "applyDirective"
    },
    {
      "name": "@screen",
      "pattern": "@screen\\s+(\\w+)\\s*\\{",
      "captureGroup": 1,
      "kind": 2,
      "type": "screen"
    },
    {
      "name": "@responsive",
      "pattern": "@responsive\\s*\\{",
      "captureGroup": 0,
      "kind": 2,
      "type": "responsive"
    },
    {
      "name": "Arbitrary Value",
      "pattern": "\\[([\\w-]+):\\s*([^\\]]+)\\]",
      "captureGroup": 0,
      "kind": 6,
      "type": "arbitraryValue"
    },
    {
      "name": "Group Modifier",
      "pattern": "\\bgroup(?:/([\\w-]+))?\\b",
      "captureGroup": 0,
      "kind": 5,
      "type": "groupModifier"
    },
    {
      "name": "Peer Modifier",
      "pattern": "\\bpeer(?:/([\\w-]+))?\\b",
      "captureGroup": 0,
      "kind": 5,
      "type": "peerModifier"
    }
  ]
}
