{
  "language": "tailwindcss",
  "symbolPatterns": [
    {
      "name": "layer:${1}",
      "pattern": "@layer\\s+(base|components|utilities)\\s*\\{",
      "captureGroup": 1,
      "kind": "module",
      "type": "layer"
    },
    {
      "name": "@apply:${1}",
      "pattern": "\\.([\\w-]+)\\s*\\{[^}]*@apply",
      "captureGroup": 1,
      "kind": "class",
      "type": "component"
    },
    {
      "name": "@tailwind:${1}",
      "pattern": "@tailwind\\s+(base|components|utilities|variants)\\s*;",
      "captureGroup": 1,
      "kind": "namespace",
      "type": "directive"
    },
    {
      "name": "@config:${1}",
      "pattern": "@config\\s+['\"]([^'\"]+)['\"]\\s*;",
      "captureGroup": 1,
      "kind": "file",
      "type": "config"
    },
    {
      "name": "selector:${1}",
      "pattern": "^\\s*\\.([\\w-]+)\\s*\\{",
      "captureGroup": 1,
      "kind": "class",
      "type": "selector"
    },
    {
      "name": "media:${1}",
      "pattern": "@media\\s+([^{]+)\\s*\\{",
      "captureGroup": 1,
      "kind": "namespace",
      "type": "media"
    },
    {
      "name": "screen:${1}",
      "pattern": "@screen\\s+(\\w+)\\s*\\{",
      "captureGroup": 1,
      "kind": "namespace",
      "type": "screen"
    },
    {
      "name": "keyframes:${1}",
      "pattern": "@keyframes\\s+([\\w-]+)\\s*\\{",
      "captureGroup": 1,
      "kind": "enum",
      "type": "keyframes"
    }
  ]
}