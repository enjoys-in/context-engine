{
  "language": "tailwindcss",
  "symbolPatterns": [
    {
      "name": "layer:${1}",
      "pattern": "@layer\\s+(base|components|utilities)\\s*\\{",
      "captureGroup": 1,
      "kind": 1,
      "type": "layer"
    },
    {
      "name": "@apply:${1}",
      "pattern": "\\.([\\w-]+)\\s*\\{[^}]*@apply",
      "captureGroup": 1,
      "kind": 4,
      "type": "component"
    },
    {
      "name": "@tailwind:${1}",
      "pattern": "@tailwind\\s+(base|components|utilities|variants)\\s*;",
      "captureGroup": 1,
      "kind": 2,
      "type": "directive"
    },
    {
      "name": "@config:${1}",
      "pattern": "@config\\s+['\"]([^'\"]+)['\"]\\s*;",
      "captureGroup": 1,
      "kind": 0,
      "type": "config"
    },
    {
      "name": "selector:${1}",
      "pattern": "^\\s*\\.([\\w-]+)\\s*\\{",
      "captureGroup": 1,
      "kind": 4,
      "type": "selector"
    },
    {
      "name": "media:${1}",
      "pattern": "@media\\s+([^{]+)\\s*\\{",
      "captureGroup": 1,
      "kind": 2,
      "type": "media"
    },
    {
      "name": "screen:${1}",
      "pattern": "@screen\\s+(\\w+)\\s*\\{",
      "captureGroup": 1,
      "kind": 2,
      "type": "screen"
    },
    {
      "name": "keyframes:${1}",
      "pattern": "@keyframes\\s+([\\w-]+)\\s*\\{",
      "captureGroup": 1,
      "kind": 9,
      "type": "keyframes"
    },
    {
      "name": "addUtilities",
      "pattern": "addUtilities\\s*\\(",
      "captureGroup": 0,
      "kind": 11,
      "type": "pluginUtilities"
    },
    {
      "name": "addComponents",
      "pattern": "addComponents\\s*\\(",
      "captureGroup": 0,
      "kind": 11,
      "type": "pluginComponents"
    },
    {
      "name": "addBase",
      "pattern": "addBase\\s*\\(",
      "captureGroup": 0,
      "kind": 11,
      "type": "pluginBase"
    },
    {
      "name": "addVariant:${1}",
      "pattern": "addVariant\\s*\\(['\"]([\\w-]+)['\"]",
      "captureGroup": 1,
      "kind": 11,
      "type": "pluginVariant"
    },
    {
      "name": "@source:${1}",
      "pattern": "@source\\s+['\"]([^'\"]+)['\"]\\s*;",
      "captureGroup": 1,
      "kind": 0,
      "type": "source"
    },
    {
      "name": "@plugin:${1}",
      "pattern": "@plugin\\s+['\"]([^'\"]+)['\"]\\s*;",
      "captureGroup": 1,
      "kind": 1,
      "type": "plugin"
    },
    {
      "name": "@import:${1}",
      "pattern": "@import\\s+['\"]([^'\"]+)['\"]\\s*;",
      "captureGroup": 1,
      "kind": 0,
      "type": "import"
    }
  ]
}