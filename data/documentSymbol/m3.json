{
  "language": "m3",
  "symbolPatterns": [
    {
      "name": "MODULE",
      "pattern": "^\\\\s*(?:UNSAFE\\\\s+)?MODULE\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "INTERFACE",
      "pattern": "^\\\\s*(?:UNSAFE\\\\s+)?INTERFACE\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "PROCEDURE",
      "pattern": "^\\\\s*PROCEDURE\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "TYPE",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*=\\\\s*(?:RECORD|OBJECT|BRANDED|REF|SET|ARRAY|BITS|PACKED|UNTRACED)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "VAR",
      "pattern": "^\\\\s*VAR\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "CONST",
      "pattern": "^\\\\s*CONST\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "EXCEPTION",
      "pattern": "^\\\\s*EXCEPTION\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "REVEAL",
      "pattern": "^\\\\s*REVEAL\\\\s+(\\\\w+\\\\.\\\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "IMPORT",
      "pattern": "^\\\\s*IMPORT\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "FROM...IMPORT",
      "pattern": "^\\\\s*FROM\\\\s+(\\\\w+)\\\\s+IMPORT",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "BRANDED type",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*=\\\\s*BRANDED\\\\s+",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "OBJECT type",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*=\\\\s*(?:\\\\w+\\\\.)?\\\\w+\\\\s+OBJECT",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "METHODS",
      "pattern": "^\\\\s*METHODS\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "GENERIC MODULE",
      "pattern": "^\\\\s*GENERIC\\\\s+MODULE\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "GENERIC INTERFACE",
      "pattern": "^\\\\s*GENERIC\\\\s+INTERFACE\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Record type",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*=\\\\s*RECORD",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Enum type",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*=\\\\s*\\\\{",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    }
  ]
}
