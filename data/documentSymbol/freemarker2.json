{
  "language": "freemarker2",
  "symbolPatterns": [
    {
      "name": "Assign",
      "pattern": "<#assign\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Function",
      "pattern": "<#function\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Macro",
      "pattern": "<#macro\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Import",
      "pattern": "<#import\\\\s+\"([^\"]+)\"\\\\s+as\\\\s+(\\\\w+)",
      "captureGroup": 2,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Include",
      "pattern": "<#include\\\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "IfDirective",
      "pattern": "<#if\\\\s+(.+?)\\\\s*>",
      "captureGroup": 1,
      "kind": 19,
      "type": "key"
    },
    {
      "name": "ListDirective",
      "pattern": "<#list\\\\s+(\\\\S+)\\\\s+as\\\\s+(\\\\w+)",
      "captureGroup": 2,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "SwitchDirective",
      "pattern": "<#switch\\\\s+(\\\\S+)\\\\s*>",
      "captureGroup": 1,
      "kind": 19,
      "type": "key"
    },
    {
      "name": "CaseDirective",
      "pattern": "<#case\\\\s+(.+?)\\\\s*>",
      "captureGroup": 1,
      "kind": 19,
      "type": "key"
    },
    {
      "name": "AttemptBlock",
      "pattern": "<#attempt>",
      "captureGroup": 0,
      "kind": 19,
      "type": "key"
    },
    {
      "name": "RecoverBlock",
      "pattern": "<#recover>",
      "captureGroup": 0,
      "kind": 19,
      "type": "key"
    },
    {
      "name": "Setting",
      "pattern": "<#setting\\\\s+(\\\\w+)\\\\s*=",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Interpolation",
      "pattern": "\\\\$\\\\{([\\\\w.]+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Local",
      "pattern": "<#local\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Global",
      "pattern": "<#global\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "FtlDirective",
      "pattern": "<#ftl\\\\s+(.+?)\\\\s*>",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "CompressBlock",
      "pattern": "<#compress>",
      "captureGroup": 0,
      "kind": 19,
      "type": "key"
    },
    {
      "name": "EscapeDirective",
      "pattern": "<#escape\\\\s+(\\\\w+)\\\\s+as",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "NoparseBlock",
      "pattern": "<#noparse>",
      "captureGroup": 0,
      "kind": 19,
      "type": "key"
    },
    {
      "name": "UserDirective",
      "pattern": "<@(\\\\w+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "BuiltIn",
      "pattern": "(\\\\w+)\\\\?(\\\\w+)",
      "captureGroup": 2,
      "kind": 5,
      "type": "method"
    }
  ]
}
