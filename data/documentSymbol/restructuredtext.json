{
  "language": "restructuredtext",
  "symbolPatterns": [
    {
      "name": "SectionEquals",
      "pattern": "^(.+)\\n={3,}\\s*$",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "SectionDash",
      "pattern": "^(.+)\\n-{3,}\\s*$",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "SectionTilde",
      "pattern": "^(.+)\\n~{3,}\\s*$",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "SectionCaret",
      "pattern": "^(.+)\\n\\^{3,}\\s*$",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Directive",
      "pattern": "^\\.\\.\\s+(\\w[\\w-]*)::",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Role",
      "pattern": ":(\\w[\\w-]*):`[^`]+`",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Footnote",
      "pattern": "^\\.\\.\\s+\\[(\\d+|\\*|#\\w*)\\]",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Citation",
      "pattern": "^\\.\\.\\s+\\[([A-Za-z][\\w-]*)\\]",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "HyperlinkTarget",
      "pattern": "^\\.\\.\\s+_([^:]+):",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Substitution",
      "pattern": "^\\.\\.\\s+\\|([^|]+)\\|\\s+\\w+::",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Comment",
      "pattern": "^\\.\\.\\s+([^\\s:.|_\\[][^\\n]*)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "CodeBlock",
      "pattern": "^\\.\\.\\s+code-block::\\s*(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Image",
      "pattern": "^\\.\\.\\s+(?:image|figure)::\\s*(\\S+)",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "Toctree",
      "pattern": "^\\.\\.\\s+toctree::(.*)",
      "captureGroup": 0,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Include",
      "pattern": "^\\.\\.\\s+include::\\s*(\\S+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "IndexEntry",
      "pattern": "^\\.\\.\\s+index::\\s*(.+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
