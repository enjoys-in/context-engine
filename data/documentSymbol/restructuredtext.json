{
  "language": "restructuredtext",
  "symbolPatterns": [
    {
      "name": "Section",
      "pattern": "^(.+)\\n[=\\-~^]+$",
      "captureGroup": 1,
      "kind": 14,
      "type": "string"
    },
    {
      "name": "Directive",
      "pattern": "^\\.\\. (\\w+)::",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "pattern": "^(.+)\\n[=\\-~^]+$",
      "captureGroup": 1,
      "kind": 15,
      "description": "Section heading",
      "name": "Section"
    },
    {
      "pattern": "^\\.\\.\\s+(\\w+)::",
      "captureGroup": 1,
      "kind": 12,
      "description": "Directive",
      "name": "Directive"
    },
    {
      "pattern": "^\\.\\.\\s+_(.+):",
      "captureGroup": 1,
      "kind": 14,
      "description": "Reference target",
      "name": "Target"
    },
    {
      "name": "Class",
      "pattern": "(?:class|struct|interface|trait|type|record)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Variable",
      "pattern": "(?:var|let|const|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Module",
      "pattern": "(?:module|namespace|package|import)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    }
  ]
}
