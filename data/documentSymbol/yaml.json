{
  "language": "yaml",
  "symbolPatterns": [
    {
      "name": "Top-level Key",
      "pattern": "^([a-zA-Z_][\\w.-]*)\\s*:",
      "captureGroup": 1,
      "kind": 19,
      "type": "key"
    },
    {
      "name": "Nested Key",
      "pattern": "^\\s+(\\w[\\w.-]*)\\s*:",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "Sequence Item",
      "pattern": "^\\s*-\\s+(.+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Anchor",
      "pattern": "&([\\w.-]+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Alias",
      "pattern": "\\*([\\w.-]+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Tag",
      "pattern": "!{1,2}([\\w./:-]+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Multi-line Scalar",
      "pattern": "([\\w.-]+)\\s*:\\s*[|>][-+]?\\s*$",
      "captureGroup": 1,
      "kind": 14,
      "type": "string"
    },
    {
      "name": "Document Separator",
      "pattern": "^(---|\\.\\.\\.)\\s*$",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Comment",
      "pattern": "#\\s*(.+)$",
      "captureGroup": 1,
      "kind": 14,
      "type": "string"
    },
    {
      "name": "Merge Key",
      "pattern": "<<\\s*:\\s*\\*([\\w.-]+)",
      "captureGroup": 1,
      "kind": 19,
      "type": "key"
    }
  ]
}
