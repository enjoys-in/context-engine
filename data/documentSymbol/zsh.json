{
  "language": "zsh",
  "symbolPatterns": [
    {
      "name": "Function (keyword)",
      "pattern": "^\\\\s*function\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Function (parens)",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*\\\\(\\\\)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Variable",
      "pattern": "^\\\\s*(\\\\w+)=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    }
  ]
}
