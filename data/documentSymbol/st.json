{
  "language": "st",
  "symbolPatterns": [
    {
      "name": "Program",
      "pattern": "^\\s*PROGRAM\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "FunctionBlock",
      "pattern": "^\\s*FUNCTION_BLOCK\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Function",
      "pattern": "^\\s*FUNCTION\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Method",
      "pattern": "^\\s*METHOD\\s+(?:PUBLIC\\s+|PRIVATE\\s+|PROTECTED\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Property",
      "pattern": "^\\s*PROPERTY\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "VarSection",
      "pattern": "^\\s*(VAR(?:_INPUT|_OUTPUT|_IN_OUT|_GLOBAL|_TEMP|_EXTERNAL)?)\\b",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Type",
      "pattern": "^\\s*TYPE\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Struct",
      "pattern": "^\\s*(\\w+)\\s*:\\s*STRUCT\\b",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Enum",
      "pattern": "^\\s*(\\w+)\\s*:\\s*\\(",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Interface",
      "pattern": "^\\s*INTERFACE\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Action",
      "pattern": "^\\s*ACTION\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Constant",
      "pattern": "^\\s*(VAR\\s+CONSTANT)\\b",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    }
  ]
}
