{
  "language": "st",
  "symbolPatterns": [
    {
      "name": "Program",
      "pattern": "^\\s*PROGRAM\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "FunctionBlock",
      "pattern": "^\\s*FUNCTION_BLOCK\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Function",
      "pattern": "^\\s*FUNCTION\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Type",
      "pattern": "^\\s*TYPE\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 25,
      "type": "type"
    }
  ]
}