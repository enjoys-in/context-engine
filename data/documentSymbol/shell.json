{
  "language": "shell",
  "symbolPatterns": [
    {
      "name": "Function (keyword)",
      "pattern": "^\\s*function\\s+([\\w-]+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Function (parens)",
      "pattern": "^\\s*([\\w-]+)\\s*\\(\\s*\\)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Alias",
      "pattern": "^\\s*alias\\s+([\\w.-]+)=",
      "captureGroup": 1,
      "kind": 12,
      "type": "alias"
    },
    {
      "name": "Export variable",
      "pattern": "^\\s*export\\s+(\\w+)=",
      "captureGroup": 1,
      "kind": 12,
      "type": "exportVariable"
    },
    {
      "name": "Export (no assignment)",
      "pattern": "^\\s*export\\s+(\\w+)\\s*$",
      "captureGroup": 1,
      "kind": 12,
      "type": "exportVariable"
    },
    {
      "name": "Local variable",
      "pattern": "^\\s*local\\s+(?:-[a-zA-Z]\\s+)*(\\w+)=",
      "captureGroup": 1,
      "kind": 12,
      "type": "localVariable"
    },
    {
      "name": "Readonly variable",
      "pattern": "^\\s*readonly\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Declare variable",
      "pattern": "^\\s*declare\\s+(?:-[a-zA-Z]+\\s+)*(\\w+)=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Associative array",
      "pattern": "^\\s*declare\\s+-A\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "associativeArray"
    },
    {
      "name": "Indexed array",
      "pattern": "^\\s*declare\\s+-a\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "array"
    },
    {
      "name": "Source/Dot",
      "pattern": "^\\s*(?:source|\\.)\\s+([\"']?[\\w/.~$-]+[\"']?)",
      "captureGroup": 1,
      "kind": 1,
      "type": "source"
    },
    {
      "name": "Case statement",
      "pattern": "^\\s*case\\s+(.+?)\\s+in",
      "captureGroup": 1,
      "kind": 12,
      "type": "case"
    },
    {
      "name": "If block",
      "pattern": "^\\s*if\\s+(.+?)\\s*;?\\s*then",
      "captureGroup": 1,
      "kind": 12,
      "type": "ifBlock"
    },
    {
      "name": "For loop",
      "pattern": "^\\s*for\\s+(\\w+)\\s+in",
      "captureGroup": 1,
      "kind": 12,
      "type": "forLoop"
    },
    {
      "name": "While loop",
      "pattern": "^\\s*while\\s+(.+?)\\s*;?\\s*do",
      "captureGroup": 1,
      "kind": 12,
      "type": "whileLoop"
    },
    {
      "name": "Until loop",
      "pattern": "^\\s*until\\s+(.+?)\\s*;?\\s*do",
      "captureGroup": 1,
      "kind": 12,
      "type": "untilLoop"
    },
    {
      "name": "Here-document",
      "pattern": "<<-?\\s*['\"]?(\\w+)['\"]?",
      "captureGroup": 1,
      "kind": 12,
      "type": "heredoc"
    },
    {
      "name": "Trap",
      "pattern": "^\\s*trap\\s+['\"]?(.+?)['\"]?\\s+(?:EXIT|ERR|INT|TERM|HUP|SIGINT|SIGTERM|SIGHUP|DEBUG|RETURN|\\d+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "trap"
    },
    {
      "name": "Shebang",
      "pattern": "^#!\\s*(/\\S+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "shebang"
    },
    {
      "name": "Global variable assignment",
      "pattern": "^(\\w+)=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    }
  ]
}
