{
  "language": "shell",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\s*(?:function\\s+)?(\\w+)\\s*\\(\\)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Variable",
      "pattern": "^\\s*(\\w+)=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Alias",
      "pattern": "^\\s*alias\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Function (keyword form)",
      "pattern": "^\\s*function\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "detail": "function"
    },
    {
      "name": "Function (parens form)",
      "pattern": "^\\s*(\\w[\\w-]*)\\s*\\(\\s*\\)",
      "captureGroup": 1,
      "kind": 11,
      "detail": "function"
    },
    {
      "name": "Global variable assignment",
      "pattern": "^(\\w+)=",
      "captureGroup": 1,
      "kind": 12,
      "detail": "variable"
    },
    {
      "name": "Readonly variable",
      "pattern": "^\\s*readonly\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "detail": "constant"
    },
    {
      "name": "Exported variable",
      "pattern": "^\\s*export\\s+(\\w+)=",
      "captureGroup": 1,
      "kind": 12,
      "detail": "exported variable"
    },
    {
      "name": "Declare variable",
      "pattern": "^\\s*declare\\s+(?:-\\w+\\s+)*(\\w+)=",
      "captureGroup": 1,
      "kind": 12,
      "detail": "declared variable"
    },
    {
      "name": "Local variable",
      "pattern": "^\\s*local\\s+(\\w+)=",
      "captureGroup": 1,
      "kind": 12,
      "detail": "local variable"
    },
    {
      "name": "Indexed array",
      "pattern": "^\\s*(?:declare\\s+-a\\s+)?(\\w+)=\\(",
      "captureGroup": 1,
      "kind": 17,
      "detail": "array"
    },
    {
      "name": "Associative array",
      "pattern": "^\\s*declare\\s+-A\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 18,
      "detail": "associative array"
    },
    {
      "name": "Alias definition",
      "pattern": "^\\s*alias\\s+([\\w-]+)=",
      "captureGroup": 1,
      "kind": 12,
      "detail": "alias"
    },
    {
      "name": "Here-document marker",
      "pattern": "<<-?\\s*['\"]?(\\w+)['\"]?",
      "captureGroup": 1,
      "kind": 14,
      "detail": "heredoc"
    },
    {
      "name": "Source/include file",
      "pattern": "^\\s*(?:source|\\.)\\s+['\"]?([^'\"\\s]+)",
      "captureGroup": 1,
      "kind": 1,
      "detail": "source import"
    },
    {
      "name": "Trap handler",
      "pattern": "^\\s*trap\\s+['\"]?([^'\"]+)['\"]?\\s+(\\w+)",
      "captureGroup": 2,
      "kind": 23,
      "detail": "trap signal handler"
    },
    {
      "name": "Case statement",
      "pattern": "^\\s*case\\s+(\\S+)\\s+in",
      "captureGroup": 1,
      "kind": 14,
      "detail": "case pattern"
    },
    {
      "name": "Main entry guard",
      "pattern": "^\\s*(?:if\\s+)?\\[\\[?\\s*[\"']?\\$\\{?(?:BASH_SOURCE|0).*==.*main",
      "captureGroup": 0,
      "kind": 11,
      "detail": "main guard"
    },
    {
      "name": "Shebang",
      "pattern": "^#!(.+)",
      "captureGroup": 1,
      "kind": 0,
      "detail": "shebang"
    },
    {
      "name": "Completion function registration",
      "pattern": "^\\s*complete\\s+.*-F\\s+(\\w+)\\s+(\\w+)",
      "captureGroup": 2,
      "kind": 11,
      "detail": "completion for"
    },
    {
      "name": "Function (keyword)",
      "pattern": "^\\\\s*function\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Function (parens)",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*\\\\(\\\\)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Variable",
      "pattern": "^\\\\s*(\\\\w+)=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    }
  ]
}