{
  "language": "shell",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\s*(?:function\\s+)?(\\w+)\\s*\\(\\)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Variable",
      "pattern": "^\\s*(\\w+)=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Alias",
      "pattern": "^\\s*alias\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    }
  ]
}