{
  "language": "redis",
  "symbolPatterns": [
    {
      "name": "Command",
      "pattern": "^\\s*(GET|SET|DEL|HGET|HSET|HDEL|HGETALL|LPUSH|RPUSH|LPOP|RPOP|LRANGE|SADD|SREM|SMEMBERS|ZADD|ZREM|ZRANGE|SUBSCRIBE|PUBLISH|MULTI|EXEC|SELECT|AUTH|KEYS|SCAN|INFO|CONFIG|FLUSHDB|FLUSHALL)\\b",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Key",
      "pattern": "^\\s*(?:GET|SET|DEL|HGET|HSET|LPUSH|RPUSH|SADD|ZADD)\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Comment",
      "pattern": "^\\s*#\\s*(.*)",
      "captureGroup": 1,
      "kind": 14,
      "type": "string"
    }
  ]
}