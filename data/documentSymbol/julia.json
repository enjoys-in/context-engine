{
  "language": "julia",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\s*function\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Typed Function",
      "pattern": "^\\s*function\\s+(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Short Function",
      "pattern": "^\\s*(\\w+)\\s*\\([^)]*\\)\\s*=",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Parametric Function",
      "pattern": "^\\s*function\\s+(\\w+)\\s*\\{",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Qualified Method",
      "pattern": "^\\s*function\\s+(\\w+\\.\\w+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Struct",
      "pattern": "^\\s*struct\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Mutable Struct",
      "pattern": "^\\s*mutable\\s+struct\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Parametric Struct",
      "pattern": "^\\s*(?:mutable\\s+)?struct\\s+(\\w+)\\s*\\{",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Abstract Type",
      "pattern": "^\\s*abstract\\s+type\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Primitive Type",
      "pattern": "^\\s*primitive\\s+type\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Module",
      "pattern": "^\\s*(?:bare)?module\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Import",
      "pattern": "^\\s*import\\s+([\\w.]+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Using",
      "pattern": "^\\s*using\\s+([\\w.]+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Export",
      "pattern": "^\\s*export\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Const",
      "pattern": "^\\s*const\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Global Const",
      "pattern": "^\\s*global\\s+const\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Macro",
      "pattern": "^\\s*macro\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Type Alias",
      "pattern": "^\\s*const\\s+(\\w+)\\s*=\\s*Union\\b",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Type Alias (assignment)",
      "pattern": "^\\s*(\\w+)\\s*=\\s*(?:Union|Type|Abstract)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Enum Macro",
      "pattern": "^\\s*@enum\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Global Variable",
      "pattern": "^\\s*global\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    }
  ]
}
