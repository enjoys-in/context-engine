{
  "language": "systemd",
  "symbolPatterns": [
    {
      "name": "UnitSection",
      "pattern": "^\\[Unit\\]",
      "captureGroup": 0,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "ServiceSection",
      "pattern": "^\\[Service\\]",
      "captureGroup": 0,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "InstallSection",
      "pattern": "^\\[Install\\]",
      "captureGroup": 0,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "TimerSection",
      "pattern": "^\\[Timer\\]",
      "captureGroup": 0,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "SocketSection",
      "pattern": "^\\[Socket\\]",
      "captureGroup": 0,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "MountSection",
      "pattern": "^\\[Mount\\]",
      "captureGroup": 0,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "PathSection",
      "pattern": "^\\[Path\\]",
      "captureGroup": 0,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Description",
      "pattern": "^\\s*Description\\s*=\\s*(.+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "ExecStart",
      "pattern": "^\\s*ExecStart\\s*=\\s*(.+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "ExecStop",
      "pattern": "^\\s*ExecStop\\s*=\\s*(.+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Environment",
      "pattern": "^\\s*Environment\\s*=\\s*(.+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "WantedBy",
      "pattern": "^\\s*WantedBy\\s*=\\s*(.+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "AfterBefore",
      "pattern": "^\\s*(After|Before)\\s*=\\s*(.+)",
      "captureGroup": 0,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Directive",
      "pattern": "^\\s*(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 19,
      "type": "key"
    }
  ]
}
