{
  "language": "systemd",
  "symbolPatterns": [
    {
      "name": "Section",
      "pattern": "^\\\\[([^\\\\]]+)\\\\]",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Directive",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*=",
      "captureGroup": 1,
      "kind": 9,
      "type": "variable"
    },
    {
      "pattern": "^\\[(\\w+)\\]",
      "captureGroup": 1,
      "kind": 3,
      "description": "Section header"
    },
    {
      "pattern": "^(\\w+)=",
      "captureGroup": 1,
      "kind": 7,
      "description": "Directive key"
    },
    {
      "pattern": "^#\\s*(.+)",
      "captureGroup": 1,
      "kind": 15,
      "description": "Comment annotation"
    },
    {
      "name": "Function",
      "pattern": "(?:function|def|fn|func|sub|proc)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Class",
      "pattern": "(?:class|struct|interface|trait|type|record)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
