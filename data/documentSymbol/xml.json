{
  "language": "xml",
  "symbolPatterns": [
    {
      "name": "Element",
      "pattern": "<(\\\\w[\\\\w:-]*)(?:\\\\s|>|/)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Attribute",
      "pattern": "(\\\\w[\\\\w:-]*)\\\\s*=\\\\s*\"",
      "captureGroup": 1,
      "kind": 9,
      "type": "variable"
    },
    {
      "pattern": "<(\\w[\\w:-]*)\\b[^/]*>",
      "captureGroup": 1,
      "kind": 5,
      "description": "Element"
    },
    {
      "pattern": "(\\w+)=\"[^\"]*\"",
      "captureGroup": 1,
      "kind": 7,
      "description": "Attribute"
    },
    {
      "pattern": "<!--\\s*(.+?)\\s*-->",
      "captureGroup": 1,
      "kind": 15,
      "description": "Comment"
    },
    {
      "name": "Function",
      "pattern": "(?:function|def|fn|func|sub|proc)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Module",
      "pattern": "(?:module|namespace|package|import)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
