{
  "language": "xml",
  "symbolPatterns": [
    {
      "name": "Element",
      "pattern": "<([a-zA-Z][\\w:.-]*)(?:\\s|>|/>)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Attribute",
      "pattern": "\\s([a-zA-Z][\\w:.-]*)\\s*=\\s*\"",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Namespace Declaration",
      "pattern": "xmlns:([\\w.-]+)\\s*=\\s*\"([^\"]+)\"",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Processing Instruction",
      "pattern": "<\\?([\\w.-]+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "CDATA Section",
      "pattern": "<!\\[CDATA\\[",
      "captureGroup": 0,
      "kind": 14,
      "type": "string"
    },
    {
      "name": "Comment",
      "pattern": "<!--\\s*(.+?)\\s*-->",
      "captureGroup": 1,
      "kind": 14,
      "type": "string"
    },
    {
      "name": "DTD Declaration",
      "pattern": "<!DOCTYPE\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Entity Declaration",
      "pattern": "<!ENTITY\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Root Element",
      "pattern": "^\\s*<([a-zA-Z][\\w:.-]*)(?:\\s|>)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    }
  ]
}
