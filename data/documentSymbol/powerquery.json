{
  "language": "powerquery",
  "symbolPatterns": [
    {
      "name": "Step",
      "pattern": "^\\s*(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Section",
      "pattern": "^\\s*section\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "pattern": "(\\w+)\\s*=\\s*",
      "captureGroup": 1,
      "kind": 13,
      "description": "Let step / variable",
      "name": "Symbol"
    },
    {
      "pattern": "shared\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "description": "Shared function",
      "name": "Symbol"
    },
    {
      "pattern": "type\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 5,
      "description": "Type definition",
      "name": "Type"
    },
    {
      "name": "Function",
      "pattern": "(?:function|def|fn|func|sub|proc)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Class",
      "pattern": "(?:class|struct|interface|trait|type|record)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
