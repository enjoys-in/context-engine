{
  "language": "go",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\\\s*func\\\\s+(?:\\\\([^)]*\\\\)\\\\s+)?(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Type",
      "pattern": "^\\\\s*type\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Const",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*=",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Var",
      "pattern": "^\\\\s*var\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    }
  ]
}