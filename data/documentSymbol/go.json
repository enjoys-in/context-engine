{
  "language": "go",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^func\\\\s+([A-Za-z_]\\\\w*)\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "MethodWithReceiver",
      "pattern": "^func\\\\s+\\\\([^)]*\\\\b\\\\w+\\\\s+\\\\*?\\\\w+\\\\)\\\\s+(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "StructType",
      "pattern": "^type\\\\s+(\\\\w+)\\\\s+struct\\\\s*\\\\{",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "InterfaceType",
      "pattern": "^type\\\\s+(\\\\w+)\\\\s+interface\\\\s*\\\\{",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "TypeDefinition",
      "pattern": "^type\\\\s+(\\\\w+)\\\\s+(?!struct\\\\b|interface\\\\b|=\\\\s)([A-Za-z_]\\\\w*(?:\\\\.\\\\w+)?(?:\\\\[.*?\\\\])?)",
      "captureGroup": 1,
      "kind": 4,
      "type": "typeDefinition"
    },
    {
      "name": "TypeAlias",
      "pattern": "^type\\\\s+(\\\\w+)\\\\s*=\\\\s*\\\\S+",
      "captureGroup": 1,
      "kind": 4,
      "type": "typeAlias"
    },
    {
      "name": "ConstSingle",
      "pattern": "^const\\\\s+(\\\\w+)\\\\s*(?:\\\\w+)?\\\\s*=",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "ConstBlock",
      "pattern": "^const\\\\s*\\\\(",
      "captureGroup": 0,
      "kind": 13,
      "type": "constantBlock"
    },
    {
      "name": "VarSingle",
      "pattern": "^var\\\\s+(\\\\w+)\\\\s+\\\\S+",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "VarBlock",
      "pattern": "^var\\\\s*\\\\(",
      "captureGroup": 0,
      "kind": 12,
      "type": "variableBlock"
    },
    {
      "name": "PackageDeclaration",
      "pattern": "^package\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 3,
      "type": "package"
    },
    {
      "name": "ImportSingle",
      "pattern": "^import\\\\s+(?:(\\\\w+)\\\\s+)?\"([^\"]+)\"",
      "captureGroup": 2,
      "kind": 2,
      "type": "import"
    },
    {
      "name": "ImportBlock",
      "pattern": "^import\\\\s*\\\\(",
      "captureGroup": 0,
      "kind": 2,
      "type": "importBlock"
    },
    {
      "name": "InitFunction",
      "pattern": "^func\\\\s+(init)\\\\s*\\\\(\\\\s*\\\\)",
      "captureGroup": 1,
      "kind": 11,
      "type": "initFunction"
    },
    {
      "name": "MainFunction",
      "pattern": "^func\\\\s+(main)\\\\s*\\\\(\\\\s*\\\\)",
      "captureGroup": 1,
      "kind": 11,
      "type": "mainFunction"
    },
    {
      "name": "ExportedSymbol",
      "pattern": "^(?:func|type|var|const)\\\\s+(?:\\\\([^)]*\\\\)\\\\s+)?([A-Z]\\\\w*)",
      "captureGroup": 1,
      "kind": 11,
      "type": "exported"
    },
    {
      "name": "StructField",
      "pattern": "^\\\\s+(\\\\w+)\\\\s+(?:\\\\*?[A-Za-z_]\\\\w*(?:\\\\.\\\\w+)?(?:\\\\s+`[^`]*`)?)",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "GoDirective",
      "pattern": "^\\/\\/go:(\\\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "directive"
    },
    {
      "name": "CallbackDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(function|=>|->)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "GenericTypeDeclaration",
      "pattern": "\\\\b(\\\\w+)<[^>]+>",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "ClosureDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(\\\\(|\\\\|)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "TestDeclaration",
      "pattern": "\\\\b(?:test|it|describe|spec)\\\\s*\\\\(?['\"]([^'\"]+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    }
  ]
}
