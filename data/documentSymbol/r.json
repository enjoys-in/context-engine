{
  "language": "r",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\\\s*(\\\\w[\\\\w.]*)\\\\s*<-\\\\s*function\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Function (right assign)",
      "pattern": "function\\\\s*\\\\([^)]*\\\\)\\\\s*\\\\{[^}]*\\\\}\\\\s*->\\\\s*(\\\\w[\\\\w.]*)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Variable (left assign)",
      "pattern": "^\\\\s*(\\\\w[\\\\w.]*)\\\\s*<-\\\\s*(?!function)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Variable (equals assign)",
      "pattern": "^\\\\s*(\\\\w[\\\\w.]*)\\\\s*=\\\\s*(?!function)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "S4 Class",
      "pattern": "^\\\\s*setClass\\\\s*\\\\(\\\\s*[\"'](\\\\w+)[\"']",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "R6 Class",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*<-\\\\s*R6Class\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Reference Class",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*<-\\\\s*setRefClass\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "S4 Generic",
      "pattern": "^\\\\s*setGeneric\\\\s*\\\\(\\\\s*[\"'](\\\\w+)[\"']",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "S4 Method",
      "pattern": "^\\\\s*setMethod\\\\s*\\\\(\\\\s*[\"'](\\\\w+)[\"']",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    }
  ]
}
