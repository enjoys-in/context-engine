{
  "language": "mdx",
  "symbolPatterns": [
    {
      "name": "Heading",
      "pattern": "^(#{1,6})\\s+(.+)",
      "captureGroup": 2,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Link",
      "pattern": "\\[([^\\]]+)\\]\\(([^)]+)\\)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Image",
      "pattern": "!\\[([^\\]]*)\\]\\(([^)]+)\\)",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "Code Block",
      "pattern": "^```(\\w*)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Inline Code",
      "pattern": "`([^`]+)`",
      "captureGroup": 1,
      "kind": 14,
      "type": "string"
    },
    {
      "name": "Bold",
      "pattern": "\\*\\*(.+?)\\*\\*|__(.+?)__",
      "captureGroup": 1,
      "kind": 14,
      "type": "string"
    },
    {
      "name": "Italic",
      "pattern": "\\*([^*\\n]+)\\*|_([^_\\n]+)_",
      "captureGroup": 1,
      "kind": 14,
      "type": "string"
    },
    {
      "name": "List Item",
      "pattern": "^\\s*(?:[-*+]|\\d+\\.)\\s+(.+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Blockquote",
      "pattern": "^>+\\s+(.+)",
      "captureGroup": 1,
      "kind": 14,
      "type": "string"
    },
    {
      "name": "Table Header",
      "pattern": "^\\|(.+)\\|\\s*$",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Horizontal Rule",
      "pattern": "^([-*_]{3,})\\s*$",
      "captureGroup": 0,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Footnote",
      "pattern": "^\\[\\^([^\\]]+)\\]:",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Definition List",
      "pattern": "^:\\s+(.+)",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "Task List Item",
      "pattern": "^\\s*[-*+]\\s+\\[([ xX])\\]\\s+(.+)",
      "captureGroup": 2,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "HTML Block",
      "pattern": "^<([a-z][\\w-]*)(?:\\s|>)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "JSX Component",
      "pattern": "<([A-Z][\\w.]*)(?:\\s|>|/>)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Import Statement",
      "pattern": "^import\\s+(?:\\{[^}]+\\}|\\w+).*?from\\s+['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Export Statement",
      "pattern": "^export\\s+(?:function|class)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Expression",
      "pattern": "\\{([^}]+)\\}",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Named Export",
      "pattern": "^export\\s+(?:const|let|var)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Default Export",
      "pattern": "^export\\s+default\\s+(?:function|class)?\\s*(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Front Matter",
      "pattern": "^---\\s*$",
      "captureGroup": 0,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Remark Directive",
      "pattern": "^:{1,3}(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    }
  ]
}
