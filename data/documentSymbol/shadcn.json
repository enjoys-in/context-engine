{
  "language": "shadcn",
  "symbolPatterns": [
    {
      "name": "React Component (function)",
      "pattern": "^\\s*(?:export\\s+)?(?:default\\s+)?function\\s+(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "detail": "React function component"
    },
    {
      "name": "React Component (arrow)",
      "pattern": "^\\s*(?:export\\s+)?(?:const|let)\\s+(\\w+)\\s*(?::\\s*React\\.FC)?\\s*=\\s*(?:(?:React\\.)?memo\\s*\\()?\\s*(?:\\([^)]*\\)|\\w+)\\s*=>",
      "captureGroup": 1,
      "kind": 11,
      "detail": "React arrow function component"
    },
    {
      "name": "forwardRef Component",
      "pattern": "^\\s*(?:export\\s+)?const\\s+(\\w+)\\s*=\\s*React\\.forwardRef",
      "captureGroup": 1,
      "kind": 11,
      "detail": "React.forwardRef component"
    },
    {
      "name": "CVA Variant Definition",
      "pattern": "^\\s*(?:export\\s+)?const\\s+(\\w+Variants?)\\s*=\\s*cva\\(",
      "captureGroup": 1,
      "kind": 12,
      "detail": "CVA variant definition"
    },
    {
      "name": "Interface Props",
      "pattern": "^\\s*(?:export\\s+)?interface\\s+(\\w+Props?)\\b",
      "captureGroup": 1,
      "kind": 10,
      "detail": "Component props interface"
    },
    {
      "name": "Type Props",
      "pattern": "^\\s*(?:export\\s+)?type\\s+(\\w+Props?)\\s*=",
      "captureGroup": 1,
      "kind": 4,
      "detail": "Component props type alias"
    },
    {
      "name": "Named Export",
      "pattern": "^\\s*export\\s+(?:const|function|class)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "detail": "Named export"
    },
    {
      "name": "Default Export",
      "pattern": "^\\s*export\\s+default\\s+(?:function\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "detail": "Default export"
    },
    {
      "name": "cn() Usage",
      "pattern": "\\bcn\\(([^)]+)\\)",
      "captureGroup": 0,
      "kind": 5,
      "detail": "cn() class merge call"
    },
    {
      "name": "Custom Hook",
      "pattern": "^\\s*(?:export\\s+)?(?:const|function)\\s+(use\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "detail": "Custom React hook"
    },
    {
      "name": "Zod Schema",
      "pattern": "^\\s*(?:export\\s+)?const\\s+(\\w+Schema|\\w+Validation)\\s*=\\s*z\\.",
      "captureGroup": 1,
      "kind": 12,
      "detail": "Zod validation schema"
    },
    {
      "name": "Column Definition",
      "pattern": "^\\s*(?:export\\s+)?const\\s+(\\w*[Cc]olumns?)\\s*(?::\\s*ColumnDef)?\\s*=",
      "captureGroup": 1,
      "kind": 12,
      "detail": "DataTable column definition"
    },
    {
      "name": "Const Component Assignment",
      "pattern": "^\\s*(?:export\\s+)?const\\s+(\\w+)\\s*=\\s*(?:Accordion|Alert|Avatar|Badge|Button|Card|Dialog|Form|Input|Select|Table|Tabs)",
      "captureGroup": 1,
      "kind": 12,
      "detail": "Component alias"
    },
    {
      "name": "Re-export Statement",
      "pattern": "^\\s*export\\s+\\{\\s*([^}]+)\\s*\\}\\s*from",
      "captureGroup": 1,
      "kind": 12,
      "detail": "Re-export statement"
    },
    {
      "name": "Import Statement",
      "pattern": "^\\s*import\\s+\\{([^}]+)\\}\\s+from\\s+['\"]@/components/ui/",
      "captureGroup": 1,
      "kind": 1,
      "detail": "shadcn/ui component import"
    },
    {
      "name": "CSS Variable Declaration",
      "pattern": "\\s*(--[a-z][a-z-]*)\\s*:",
      "captureGroup": 1,
      "kind": 12,
      "detail": "CSS custom property"
    },
    {
      "name": "Tailwind Config Extension",
      "pattern": "^\\s*(?:export\\s+)?const\\s+(\\w*[Cc]onfig)\\s*(?::\\s*Config)?\\s*=",
      "captureGroup": 1,
      "kind": 12,
      "detail": "Tailwind config"
    },
    {
      "name": "Form Schema with zod",
      "pattern": "^\\s*(?:export\\s+)?const\\s+(\\w+)\\s*=\\s*z\\.object\\(",
      "captureGroup": 1,
      "kind": 12,
      "detail": "Zod object schema"
    }
  ]
}