{
  "language": "shadcn",
  "symbolPatterns": [
    {
      "name": "forwardRef Component",
      "pattern": "(?:export\\s+)?const\\s+(\\w+)\\s*=\\s*React\\.forwardRef",
      "captureGroup": 1,
      "kind": 11,
      "type": "component"
    },
    {
      "name": "CVA Variants",
      "pattern": "(?:export\\s+)?const\\s+(\\w+)\\s*=\\s*cva\\(",
      "captureGroup": 1,
      "kind": 12,
      "type": "variants"
    },
    {
      "name": "Variant Prop",
      "pattern": "^\\s+(\\w+):\\s*\\{[^}]*(?:default|sm|md|lg|xl|destructive|outline|secondary|ghost|link)",
      "captureGroup": 1,
      "kind": 6,
      "type": "variantProp"
    },
    {
      "name": "Default Variant",
      "pattern": "defaultVariants:\\s*\\{\\s*(\\w+):",
      "captureGroup": 1,
      "kind": 13,
      "type": "defaultVariant"
    },
    {
      "name": "Compound Variant",
      "pattern": "compoundVariants:\\s*\\[\\s*\\{\\s*(\\w+):",
      "captureGroup": 1,
      "kind": 6,
      "type": "compoundVariant"
    },
    {
      "name": "cn() Call",
      "pattern": "\\bcn\\(([^)]+)\\)",
      "captureGroup": 0,
      "kind": 5,
      "type": "cnCall"
    },
    {
      "name": "UI Component Import",
      "pattern": "import\\s+\\{([^}]+)\\}\\s+from\\s+['\"]@/components/ui/([\\w-]+)['\"]",
      "captureGroup": 2,
      "kind": 1,
      "type": "uiImport"
    },
    {
      "name": "Props Interface",
      "pattern": "(?:export\\s+)?interface\\s+(\\w+Props)\\b",
      "captureGroup": 1,
      "kind": 4,
      "type": "propsInterface"
    },
    {
      "name": "Props Type",
      "pattern": "(?:export\\s+)?type\\s+(\\w+Props)\\s*=",
      "captureGroup": 1,
      "kind": 4,
      "type": "propsType"
    },
    {
      "name": "Slot Usage",
      "pattern": "<(\\w+)\\s[^>]*asChild",
      "captureGroup": 1,
      "kind": 7,
      "type": "slot"
    },
    {
      "name": "Radix Primitive",
      "pattern": "import\\s+\\*\\s+as\\s+(\\w+)\\s+from\\s+['\"]@radix-ui/react-([\\w-]+)['\"]",
      "captureGroup": 1,
      "kind": 1,
      "type": "radixPrimitive"
    },
    {
      "name": "Radix Sub-Component",
      "pattern": "(\\w+)\\.(Root|Trigger|Content|Portal|Overlay|Close|Item|Group|Label|Separator|Arrow|Viewport|ScrollUpButton|ScrollDownButton|Indicator|Icon|Image|Fallback|Track|Range|Thumb)",
      "captureGroup": 0,
      "kind": 6,
      "type": "radixSubComponent"
    },
    {
      "name": "FunctionDeclaration",
      "pattern": "(?:function|def|fn|func|sub|proc)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "ClassDeclaration",
      "pattern": "\\\\bclass\\\\s+([A-Z]\\\\w*)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "VariableDeclaration",
      "pattern": "(?:const|let|var|val|dim)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "ConstantDeclaration",
      "pattern": "(?:const|final|readonly)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "MethodDeclaration",
      "pattern": "(?:public|private|protected)?\\\\s*(?:static\\\\s+)?(?:\\\\w+\\\\s+)?(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "PropertyDeclaration",
      "pattern": "(\\\\w+)\\\\s*[=:]\\\\s*",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "InterfaceDeclaration",
      "pattern": "\\\\binterface\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "EnumDeclaration",
      "pattern": "\\\\benum\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "TypeDeclaration",
      "pattern": "(?:type|struct|record)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "ModuleDeclaration",
      "pattern": "(?:module|namespace|package)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "NamespaceDeclaration",
      "pattern": "\\\\b(namespace|package|module)\\\\s+[\\\\w.]+",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "ConstructorDeclaration",
      "pattern": "(constructor|__init__|init|initialize)\\\\s*\\\\(?",
      "captureGroup": 1,
      "kind": 8,
      "type": "constructor"
    },
    {
      "name": "EventDeclaration",
      "pattern": "\\\\b(on\\\\w+|handle\\\\w+|emit\\\\w+)\\\\b",
      "captureGroup": 1,
      "kind": 23,
      "type": "event"
    },
    {
      "name": "ImportStatement",
      "pattern": "import\\\\s+.*?['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "ExportStatement",
      "pattern": "(?:export|pub|public)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "CommentBlock",
      "pattern": "\\/\\\\*\\\\*([\\\\s\\\\S]*?)\\\\*\\/",
      "captureGroup": 0,
      "kind": 20,
      "type": "string"
    },
    {
      "name": "AnnotationDeclaration",
      "pattern": "@\\\\w+",
      "captureGroup": 1,
      "kind": 24,
      "type": "operator"
    },
    {
      "name": "FieldDeclaration",
      "pattern": "(\\\\w+)\\\\s*:\\\\s*\\\\w+",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "KeyDeclaration",
      "pattern": "\"?(\\\\w+)\"?\\\\s*[:=]",
      "captureGroup": 1,
      "kind": 19,
      "type": "key"
    },
    {
      "name": "ArrayDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*\\\\[",
      "captureGroup": 1,
      "kind": 17,
      "type": "array"
    }
  ]
}
