{
  "language": "shadcn",
  "symbolPatterns": [
    {
      "name": "forwardRef Component",
      "pattern": "(?:export\\s+)?const\\s+(\\w+)\\s*=\\s*React\\.forwardRef",
      "captureGroup": 1,
      "kind": 11,
      "type": "component"
    },
    {
      "name": "CVA Variants",
      "pattern": "(?:export\\s+)?const\\s+(\\w+)\\s*=\\s*cva\\(",
      "captureGroup": 1,
      "kind": 12,
      "type": "variants"
    },
    {
      "name": "Variant Prop",
      "pattern": "^\\s+(\\w+):\\s*\\{[^}]*(?:default|sm|md|lg|xl|destructive|outline|secondary|ghost|link)",
      "captureGroup": 1,
      "kind": 6,
      "type": "variantProp"
    },
    {
      "name": "Default Variant",
      "pattern": "defaultVariants:\\s*\\{\\s*(\\w+):",
      "captureGroup": 1,
      "kind": 13,
      "type": "defaultVariant"
    },
    {
      "name": "Compound Variant",
      "pattern": "compoundVariants:\\s*\\[\\s*\\{\\s*(\\w+):",
      "captureGroup": 1,
      "kind": 6,
      "type": "compoundVariant"
    },
    {
      "name": "cn() Call",
      "pattern": "\\bcn\\(([^)]+)\\)",
      "captureGroup": 0,
      "kind": 5,
      "type": "cnCall"
    },
    {
      "name": "UI Component Import",
      "pattern": "import\\s+\\{([^}]+)\\}\\s+from\\s+['\"]@/components/ui/([\\w-]+)['\"]",
      "captureGroup": 2,
      "kind": 1,
      "type": "uiImport"
    },
    {
      "name": "Props Interface",
      "pattern": "(?:export\\s+)?interface\\s+(\\w+Props)\\b",
      "captureGroup": 1,
      "kind": 4,
      "type": "propsInterface"
    },
    {
      "name": "Props Type",
      "pattern": "(?:export\\s+)?type\\s+(\\w+Props)\\s*=",
      "captureGroup": 1,
      "kind": 4,
      "type": "propsType"
    },
    {
      "name": "Slot Usage",
      "pattern": "<(\\w+)\\s[^>]*asChild",
      "captureGroup": 1,
      "kind": 7,
      "type": "slot"
    },
    {
      "name": "Radix Primitive",
      "pattern": "import\\s+\\*\\s+as\\s+(\\w+)\\s+from\\s+['\"]@radix-ui/react-([\\w-]+)['\"]",
      "captureGroup": 1,
      "kind": 1,
      "type": "radixPrimitive"
    },
    {
      "name": "Radix Sub-Component",
      "pattern": "(\\w+)\\.(Root|Trigger|Content|Portal|Overlay|Close|Item|Group|Label|Separator|Arrow|Viewport|ScrollUpButton|ScrollDownButton|Indicator|Icon|Image|Fallback|Track|Range|Thumb)",
      "captureGroup": 0,
      "kind": 6,
      "type": "radixSubComponent"
    }
  ]
}
