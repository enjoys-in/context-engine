{
  "language": "lua",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\s*function\\s+(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Local Function",
      "pattern": "^\\s*local\\s+function\\s+(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Method (colon)",
      "pattern": "^\\s*function\\s+(\\w+):(\\w+)\\s*\\(",
      "captureGroup": 2,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Static Method (dot)",
      "pattern": "^\\s*function\\s+(\\w+)\\.(\\w+)\\s*\\(",
      "captureGroup": 2,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Nested Method",
      "pattern": "^\\s*function\\s+(\\w+[\\w.:]+)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Function Variable",
      "pattern": "^\\s*(\\w+)\\s*=\\s*function\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Local Function Variable",
      "pattern": "^\\s*local\\s+(\\w+)\\s*=\\s*function\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Local Variable",
      "pattern": "^\\s*local\\s+(\\w+)\\s*=\\s*(?!function)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Table Constructor",
      "pattern": "^\\s*(\\w+)\\s*=\\s*\\{",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Local Table",
      "pattern": "^\\s*local\\s+(\\w+)\\s*=\\s*\\{",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Module Require",
      "pattern": "(?:local\\s+)?(\\w+)\\s*=\\s*require\\s*[\\(\"']",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Module Declaration",
      "pattern": "^\\s*module\\s*\\(\\s*[\"']([\\w.]+)[\"']",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Metamethod __index",
      "pattern": "(\\w+).__index\\s*=",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Metamethod __newindex",
      "pattern": "(\\w+).__newindex\\s*=",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Metamethod __call",
      "pattern": "(\\w+).__call\\s*=",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Metamethod __tostring",
      "pattern": "(\\w+).__tostring\\s*=",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Metamethod __add",
      "pattern": "(\\w+).__add\\s*=",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Metamethod __eq",
      "pattern": "(\\w+).__eq\\s*=",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Setmetatable",
      "pattern": "setmetatable\\s*\\(\\s*(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "CallbackDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(function|=>|->)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "GenericTypeDeclaration",
      "pattern": "\\\\b(\\\\w+)<[^>]+>",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "ClosureDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(\\\\(|\\\\|)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    }
  ]
}
