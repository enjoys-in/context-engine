{
  "language": "lua",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\\\s*(?:local\\\\s+)?function\\\\s+(\\\\w+[\\\\w.:]*)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Local Variable",
      "pattern": "^\\\\s*local\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    }
  ]
}
