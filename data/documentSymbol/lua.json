{
  "language": "lua",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\\\s*(?:local\\\\s+)?function\\\\s+(\\\\w+[\\\\w.:]*)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Local Variable",
      "pattern": "^\\\\s*local\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "function",
      "pattern": "^\\s*(?:local\\s+)?function\\s+([\\w.:]+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "function"
    },
    {
      "name": "local",
      "pattern": "^\\s*local\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 13,
      "type": "variable"
    },
    {
      "name": "function_var",
      "pattern": "^\\s*(\\w+)\\s*=\\s*function",
      "captureGroup": 1,
      "kind": 12,
      "type": "function"
    },
    {
      "name": "Class",
      "pattern": "(?:class|struct|interface|trait|type|record)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Module",
      "pattern": "(?:module|namespace|package|import)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
