{
  "language": "lua",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\\\s*(?:local\\\\s+)?function\\\\s+(\\\\w+[\\\\w.:]*)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Local Variable",
      "pattern": "^\\\\s*local\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "function",
      "pattern": "^\\s*(?:local\\s+)?function\\s+([\\w.:]+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "function"
    },
    {
      "name": "local",
      "pattern": "^\\s*local\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 13,
      "type": "variable"
    },
    {
      "name": "function_var",
      "pattern": "^\\s*(\\w+)\\s*=\\s*function",
      "captureGroup": 1,
      "kind": 12,
      "type": "function"
    }
  ]
}