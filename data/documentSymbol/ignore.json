{
  "language": "ignore",
  "symbolPatterns": [
    {
      "name": "Comment Section",
      "pattern": "^\\s*#\\s*(.+)",
      "captureGroup": 1,
      "kind": 14,
      "detail": "comment"
    },
    {
      "name": "Directory Pattern",
      "pattern": "^\\s*!?([^#\\s][^\\s]*)/\\s*$",
      "captureGroup": 1,
      "kind": 23,
      "detail": "directory"
    },
    {
      "name": "Negated Pattern",
      "pattern": "^\\s*!(.+)",
      "captureGroup": 1,
      "kind": 12,
      "detail": "negated"
    },
    {
      "name": "Glob Pattern",
      "pattern": "^\\s*([^#!\\s][^\\s]*\\*[^\\s]*)",
      "captureGroup": 1,
      "kind": 14,
      "detail": "glob"
    },
    {
      "name": "File Pattern",
      "pattern": "^\\s*([^#!\\s*/][^\\s]*)\\s*$",
      "captureGroup": 1,
      "kind": 0,
      "detail": "file"
    }
  ]
}