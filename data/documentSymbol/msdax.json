{
  "language": "msdax",
  "symbolPatterns": [
    {
      "name": "Measure",
      "pattern": "^\\s*(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Variable",
      "pattern": "^\\s*VAR\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "pattern": "^(\\w[\\w ]+)\\s*:?=",
      "captureGroup": 1,
      "kind": 12,
      "description": "Measure definition"
    },
    {
      "pattern": "VAR\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "description": "Variable declaration"
    },
    {
      "pattern": "DEFINE\\s+MEASURE\\s+(\\w[\\w ]+)",
      "captureGroup": 1,
      "kind": 12,
      "description": "DEFINE MEASURE"
    },
    {
      "name": "Function",
      "pattern": "(?:function|def|fn|func|sub|proc)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Class",
      "pattern": "(?:class|struct|interface|trait|type|record)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Module",
      "pattern": "(?:module|namespace|package|import)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    }
  ]
}
