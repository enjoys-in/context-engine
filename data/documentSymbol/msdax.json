{
  "language": "msdax",
  "symbolPatterns": [
    {
      "name": "DEFINE MEASURE",
      "pattern": "DEFINE\\s+MEASURE\\s+(?:'[^']*'\\[([^\\]]+)\\]|([\\w]+)\\[([^\\]]+)\\])",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "DEFINE VAR",
      "pattern": "DEFINE\\s+VAR\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "DEFINE TABLE",
      "pattern": "DEFINE\\s+TABLE\\s+(?:'([^']+)'|(\\w+))",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "DEFINE COLUMN",
      "pattern": "DEFINE\\s+COLUMN\\s+(?:'[^']*'\\[([^\\]]+)\\]|([\\w]+)\\[([^\\]]+)\\])",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "EVALUATE",
      "pattern": "(?:^|\\n)\\s*(EVALUATE)\\b",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "ORDER BY",
      "pattern": "(?:^|\\n)\\s*ORDER\\s+BY\\s+(.+?)(?:\\s*(?:ASC|DESC)\\s*)?$",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "VAR Declaration",
      "pattern": "(?:^|\\n)\\s*VAR\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "CALCULATE Call",
      "pattern": "\\b(CALCULATE)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "CALCULATETABLE Call",
      "pattern": "\\b(CALCULATETABLE)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "FILTER Call",
      "pattern": "\\b(FILTER)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Iterator Function",
      "pattern": "\\b(SUMX|AVERAGEX|COUNTX|MINX|MAXX|RANKX|PRODUCTX|CONCATENATEX|COUNTAX|COUNTBLANKX)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "RELATED Function",
      "pattern": "\\b(RELATED|RELATEDTABLE)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Table Reference",
      "pattern": "'([^']+)'",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Column Reference",
      "pattern": "(?:'[^']*'|\\w+)\\[([^\\]]+)\\]",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "Measure Reference",
      "pattern": "\\[([^\\]]+)\\]",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "RETURN",
      "pattern": "(?:^|\\n)\\s*(RETURN)\\b",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Measure Assignment",
      "pattern": "^\\s*([\\w][\\w\\s]*)\\s*:?=",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Time Intelligence",
      "pattern": "\\b(DATEADD|DATESYTD|DATESQTD|DATESMTD|TOTALYTD|TOTALQTD|TOTALMTD|SAMEPERIODLASTYEAR|PREVIOUSMONTH|PREVIOUSQUARTER|PREVIOUSYEAR|PARALLELPERIOD|DATESBETWEEN|DATESINPERIOD)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "CallbackDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(function|=>|->)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "GenericTypeDeclaration",
      "pattern": "\\\\b(\\\\w+)<[^>]+>",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "ClosureDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(\\\\(|\\\\|)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "TestDeclaration",
      "pattern": "\\\\b(?:test|it|describe|spec)\\\\s*\\\\(?['\"]([^'\"]+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    }
  ]
}
