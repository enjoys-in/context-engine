{
  "language": "caddy",
  "symbolPatterns": [
    {
      "name": "Site Block",
      "pattern": "^\\\\s*(\\\\S+:\\\\d+|\\\\S+\\\\.\\\\S+|localhost)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Snippet",
      "pattern": "^\\\\s*\\\\(([^)]+)\\\\)",
      "captureGroup": 1,
      "kind": 28,
      "type": "function"
    },
    {
      "pattern": "^(\\w[\\w.]+)\\s*\\{",
      "captureGroup": 1,
      "kind": 5,
      "description": "Site block / address"
    },
    {
      "pattern": "^\\s+(\\w+)\\b",
      "captureGroup": 1,
      "kind": 12,
      "description": "Directive"
    },
    {
      "pattern": "@(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "description": "Named matcher"
    },
    {
      "name": "Class",
      "pattern": "(?:class|struct|interface|trait|type|record)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Variable",
      "pattern": "(?:var|let|const|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
