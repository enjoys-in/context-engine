{
  "language": "caddy",
  "symbolPatterns": [
    {
      "name": "Global options block",
      "pattern": "^\\{\\s*$",
      "captureGroup": 0,
      "kind": 2,
      "type": "global-options"
    },
    {
      "name": "Snippet",
      "pattern": "^\\((\\S+)\\)\\s*\\{",
      "captureGroup": 1,
      "kind": 11,
      "type": "snippet"
    },
    {
      "name": "Site block",
      "pattern": "^([a-zA-Z0-9*.:][^\\s{]*)\\s*\\{",
      "captureGroup": 1,
      "kind": 4,
      "type": "site"
    },
    {
      "name": "Matcher",
      "pattern": "^\\s*@(\\w[\\w-]*)\\s+",
      "captureGroup": 1,
      "kind": 11,
      "type": "matcher"
    },
    {
      "name": "Named route",
      "pattern": "^\\s*route\\s*(.*?)\\s*\\{",
      "captureGroup": 1,
      "kind": 5,
      "type": "route"
    },
    {
      "name": "Handle",
      "pattern": "^\\s*handle\\s+(.+?)\\s*\\{",
      "captureGroup": 1,
      "kind": 5,
      "type": "handle"
    },
    {
      "name": "Handle path",
      "pattern": "^\\s*handle_path\\s+(.+?)\\s*\\{",
      "captureGroup": 1,
      "kind": 5,
      "type": "handle-path"
    },
    {
      "name": "Reverse proxy",
      "pattern": "^\\s*reverse_proxy\\s+(.+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "proxy"
    },
    {
      "name": "TLS directive",
      "pattern": "^\\s*tls\\s+(.*)",
      "captureGroup": 1,
      "kind": 6,
      "type": "tls"
    },
    {
      "name": "Header directive",
      "pattern": "^\\s*header\\s+(.+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "header"
    },
    {
      "name": "Respond",
      "pattern": "^\\s*respond\\s+(.+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "response"
    },
    {
      "name": "Redir",
      "pattern": "^\\s*redir\\s+(.+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "redirect"
    },
    {
      "name": "Rewrite",
      "pattern": "^\\s*rewrite\\s+(.+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "rewrite"
    },
    {
      "name": "File server",
      "pattern": "^\\s*file_server\\s*(.*)",
      "captureGroup": 0,
      "kind": 6,
      "type": "file-server"
    },
    {
      "name": "Encode",
      "pattern": "^\\s*encode\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "encode"
    },
    {
      "name": "Log",
      "pattern": "^\\s*log\\s*(.*)",
      "captureGroup": 0,
      "kind": 6,
      "type": "log"
    },
    {
      "name": "Import",
      "pattern": "^\\s*import\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "import"
    }
  ]
}
