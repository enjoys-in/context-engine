{
  "language": "protobuf",
  "symbolPatterns": [
    {
      "name": "Syntax",
      "pattern": "^\\\\s*syntax\\\\s*=\\\\s*[\"'](\\\\w+)[\"']",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Package",
      "pattern": "^\\\\s*package\\\\s+([\\\\w.]+)\\\\s*;",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Import",
      "pattern": "^\\\\s*import\\\\s+(?:public\\\\s+|weak\\\\s+)?[\"']([^\"']+)[\"']",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Option",
      "pattern": "^\\\\s*option\\\\s+([\\\\w.]+)\\\\s*=",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Message",
      "pattern": "^\\\\s*message\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Nested Message",
      "pattern": "^\\\\s{2,}message\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Field",
      "pattern": "^\\\\s+(?:optional\\\\s+|required\\\\s+|repeated\\\\s+)?(?:map<[^>]+>|[\\\\w.]+)\\\\s+(\\\\w+)\\\\s*=\\\\s*\\\\d+",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "Map Field",
      "pattern": "^\\\\s+map\\\\s*<\\\\s*\\\\w+\\\\s*,\\\\s*\\\\w+\\\\s*>\\\\s+(\\\\w+)\\\\s*=\\\\s*\\\\d+",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "Enum",
      "pattern": "^\\\\s*enum\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Enum Value",
      "pattern": "^\\\\s+(\\\\w+)\\\\s*=\\\\s*-?\\\\d+\\\\s*;",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Service",
      "pattern": "^\\\\s*service\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "RPC Method",
      "pattern": "^\\\\s*rpc\\\\s+(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Oneof",
      "pattern": "^\\\\s+oneof\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Extend",
      "pattern": "^\\\\s*extend\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Reserved",
      "pattern": "^\\\\s*(reserved)\\\\s+(?:\\\\d|\")",
      "captureGroup": 1,
      "kind": 19,
      "type": "key"
    },
    {
      "name": "CallbackDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(function|=>|->)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "GenericTypeDeclaration",
      "pattern": "\\\\b(\\\\w+)<[^>]+>",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "ClosureDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(\\\\(|\\\\|)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "TestDeclaration",
      "pattern": "\\\\b(?:test|it|describe|spec)\\\\s*\\\\(?['\"]([^'\"]+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "ErrorDeclaration",
      "pattern": "\\\\b(?:class|type)\\\\s+(\\\\w*Error|\\\\w*Exception)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "ConfigObjectDeclaration",
      "pattern": "\\\\b(config|options|settings)\\\\s*[:=]\\\\s*\\\\{",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "GetterDeclaration",
      "pattern": "\\\\bget\\\\s+(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
