{
  "language": "protobuf",
  "symbolPatterns": [
    {
      "name": "Message",
      "pattern": "^\\\\s*message\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Service",
      "pattern": "^\\\\s*service\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Enum",
      "pattern": "^\\\\s*enum\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "RPC",
      "pattern": "^\\\\s*rpc\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Function",
      "pattern": "(?:function|def|fn|func|sub|proc)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Variable",
      "pattern": "(?:var|let|const|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Module",
      "pattern": "(?:module|namespace|package|import)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "TypeAlias",
      "pattern": "(?:type|typedef)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 25,
      "type": "typeAlias"
    }
  ]
}
