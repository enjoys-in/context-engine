{
  "language": "nextjs",
  "symbolPatterns": [
    {
      "name": "Page Component",
      "pattern": "export\\s+default\\s+(?:async\\s+)?function\\s+([A-Z]\\w*)",
      "captureGroup": 1,
      "kind": 11,
      "type": "page-component"
    },
    {
      "name": "getServerSideProps",
      "pattern": "export\\s+(?:const|async\\s+function)\\s+(getServerSideProps)",
      "captureGroup": 1,
      "kind": 11,
      "type": "server-side-props"
    },
    {
      "name": "getStaticProps",
      "pattern": "export\\s+(?:const|async\\s+function)\\s+(getStaticProps)",
      "captureGroup": 1,
      "kind": 11,
      "type": "static-props"
    },
    {
      "name": "getStaticPaths",
      "pattern": "export\\s+(?:const|async\\s+function)\\s+(getStaticPaths)",
      "captureGroup": 1,
      "kind": 11,
      "type": "static-paths"
    },
    {
      "name": "API Route Handler",
      "pattern": "export\\s+default\\s+(?:async\\s+)?function\\s+(handler)\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "api-handler"
    },
    {
      "name": "Middleware",
      "pattern": "export\\s+(?:async\\s+)?function\\s+(middleware)\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "middleware"
    },
    {
      "name": "Layout Component",
      "pattern": "export\\s+default\\s+(?:async\\s+)?function\\s+(\\w*Layout)\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "layout"
    },
    {
      "name": "Loading Component",
      "pattern": "export\\s+default\\s+function\\s+(Loading)\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "loading"
    },
    {
      "name": "Error Component",
      "pattern": "export\\s+default\\s+function\\s+(Error)\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "error"
    },
    {
      "name": "Not Found Component",
      "pattern": "export\\s+default\\s+function\\s+(NotFound)\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "not-found"
    },
    {
      "name": "Route Group",
      "pattern": "\\(([\\w-]+)\\)/",
      "captureGroup": 1,
      "kind": 2,
      "type": "route-group"
    },
    {
      "name": "Dynamic Route Param",
      "pattern": "\\[([\\w.]+)\\]",
      "captureGroup": 1,
      "kind": 12,
      "type": "dynamic-route"
    },
    {
      "name": "generateMetadata",
      "pattern": "export\\s+(?:async\\s+)?function\\s+(generateMetadata)\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "generate-metadata"
    },
    {
      "name": "generateStaticParams",
      "pattern": "export\\s+(?:async\\s+)?function\\s+(generateStaticParams)\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "generate-static-params"
    },
    {
      "name": "Server Action",
      "pattern": "['\"]use\\s+server['\"]\\s*;?\\s*(?:export\\s+)?async\\s+function\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "server-action"
    },
    {
      "name": "Client Component",
      "pattern": "['\"]use\\s+client['\"]",
      "captureGroup": 0,
      "kind": 1,
      "type": "client-directive"
    },
    {
      "name": "Route Handler GET",
      "pattern": "export\\s+(?:async\\s+)?function\\s+(GET)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "route-get"
    },
    {
      "name": "Route Handler POST",
      "pattern": "export\\s+(?:async\\s+)?function\\s+(POST)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "route-post"
    },
    {
      "name": "Route Handler PUT",
      "pattern": "export\\s+(?:async\\s+)?function\\s+(PUT)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "route-put"
    },
    {
      "name": "Route Handler DELETE",
      "pattern": "export\\s+(?:async\\s+)?function\\s+(DELETE)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "route-delete"
    },
    {
      "name": "Route Handler PATCH",
      "pattern": "export\\s+(?:async\\s+)?function\\s+(PATCH)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "route-patch"
    },
    {
      "name": "Metadata Export",
      "pattern": "export\\s+const\\s+(metadata)\\s*[=:]",
      "captureGroup": 1,
      "kind": 13,
      "type": "metadata"
    },
    {
      "name": "Revalidate Config",
      "pattern": "export\\s+const\\s+(revalidate)\\s*=",
      "captureGroup": 1,
      "kind": 13,
      "type": "revalidate"
    },
    {
      "name": "Dynamic Config",
      "pattern": "export\\s+const\\s+(dynamic)\\s*=",
      "captureGroup": 1,
      "kind": 13,
      "type": "dynamic-config"
    },
    {
      "name": "Runtime Config",
      "pattern": "export\\s+const\\s+(runtime)\\s*=",
      "captureGroup": 1,
      "kind": 13,
      "type": "runtime-config"
    }
  ]
}
