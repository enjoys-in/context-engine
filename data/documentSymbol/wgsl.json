{
  "language": "wgsl",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\s*(?:@\\w+\\s+)*fn\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Struct",
      "pattern": "^\\s*struct\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Global",
      "pattern": "^\\s*(?:@group\\(\\d+\\)\\s+@binding\\(\\d+\\)\\s+)?var(?:<[^>]+>)?\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Const",
      "pattern": "^\\s*(?:override|const)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    }
  ]
}