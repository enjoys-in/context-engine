{
  "language": "wgsl",
  "symbolPatterns": [
    {
      "name": "VertexFn",
      "pattern": "^\\s*@vertex\\s+fn\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "FragmentFn",
      "pattern": "^\\s*@fragment\\s+fn\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "ComputeFn",
      "pattern": "^\\s*@compute\\s+(?:@workgroup_size\\([^)]*\\)\\s+)?fn\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Function",
      "pattern": "^\\s*fn\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Struct",
      "pattern": "^\\s*struct\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "TypeAlias",
      "pattern": "^\\s*alias\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Const",
      "pattern": "^\\s*const\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Let",
      "pattern": "^\\s*let\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Var",
      "pattern": "^\\s*var(?:<[^>]+>)?\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Override",
      "pattern": "^\\s*override\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Binding",
      "pattern": "^\\s*@group\\((\\d+)\\)\\s*@binding\\(\\d+\\)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Enable",
      "pattern": "^\\s*enable\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Diagnostic",
      "pattern": "^\\s*diagnostic\\s*\\(\\s*(\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
