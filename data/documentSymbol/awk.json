{
  "language": "awk",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\\\s*function\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "BEGIN block",
      "pattern": "^\\\\s*(BEGIN)\\\\s*\\\\{",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "END block",
      "pattern": "^\\\\s*(END)\\\\s*\\\\{",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "BEGINFILE block",
      "pattern": "^\\\\s*(BEGINFILE)\\\\s*\\\\{",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "ENDFILE block",
      "pattern": "^\\\\s*(ENDFILE)\\\\s*\\\\{",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Pattern-action rule",
      "pattern": "^\\\\s*/((?:[^\\\\\\\\/]|\\\\\\\\.)*)/ *\\\\{",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "Variable assignment",
      "pattern": "^\\\\s*(\\\\w+)\\\\s*=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Field reference",
      "pattern": "\\\\$(\\\\d+|NF|NR)",
      "captureGroup": 0,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "@include",
      "pattern": "^\\\\s*@include\\\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "@namespace",
      "pattern": "^\\\\s*@namespace\\\\s+\"(\\\\w+)\"",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Built-in variable",
      "pattern": "^\\\\s*(FS|RS|OFS|ORS|NR|NF|FILENAME|FNR|SUBSEP|RSTART|RLENGTH|OFMT|CONVFMT)\\\\s*=",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    }
  ]
}
