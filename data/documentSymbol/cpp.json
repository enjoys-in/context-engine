{
  "language": "cpp",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\\\s*(?:[\\\\w:<>&*]+\\\\s+)+\\\\*?(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Class",
      "pattern": "^\\\\s*(?:template\\\\s*<[^>]*>\\\\s*)?class\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Struct",
      "pattern": "^\\\\s*(?:template\\\\s*<[^>]*>\\\\s*)?struct\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Namespace",
      "pattern": "^\\\\s*namespace\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "module"
    },
    {
      "name": "Enum",
      "pattern": "^\\\\s*enum\\\\s+(?:class\\\\s+)?(\\\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    }
  ]
}
