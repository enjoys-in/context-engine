{
  "language": "cpp",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\\\s*(?:[\\\\w:<>&*]+\\\\s+)+\\\\*?(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Class",
      "pattern": "^\\\\s*(?:template\\\\s*<[^>]*>\\\\s*)?class\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Struct",
      "pattern": "^\\\\s*(?:template\\\\s*<[^>]*>\\\\s*)?struct\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Namespace",
      "pattern": "^\\\\s*namespace\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "module"
    },
    {
      "name": "Enum",
      "pattern": "^\\\\s*enum\\\\s+(?:class\\\\s+)?(\\\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Variable",
      "pattern": "(?:var|let|const|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Method",
      "pattern": "(?:public|private|protected)?\\s*(?:static)?\\s*(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "TypeAlias",
      "pattern": "(?:type|typedef)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 25,
      "type": "typeAlias"
    }
  ]
}
