{
  "language": "redis-cli",
  "symbolPatterns": [
    {
      "name": "Command",
      "pattern": "^\\s*(GET|SET|DEL|HGET|HSET|HDEL|HGETALL|LPUSH|RPUSH|LPOP|RPOP|LRANGE|SADD|SREM|SMEMBERS|ZADD|ZREM|ZRANGE|SUBSCRIBE|PUBLISH|MULTI|EXEC|SELECT|AUTH|KEYS|SCAN|INFO|CONFIG|FLUSHDB|FLUSHALL)\\b",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Key",
      "pattern": "^\\s*(?:GET|SET|DEL|HGET|HSET|LPUSH|RPUSH|SADD|ZADD)\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Comment",
      "pattern": "^\\s*#\\s*(.*)",
      "captureGroup": 1,
      "kind": 14,
      "type": "string"
    },
    {
      "name": "Class",
      "pattern": "(?:class|struct|interface|trait|type|record)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Module",
      "pattern": "(?:module|namespace|package|import)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Method",
      "pattern": "(?:public|private|protected)?\\s*(?:static)?\\s*(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "TypeAlias",
      "pattern": "(?:type|typedef)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 25,
      "type": "typeAlias"
    }
  ]
}
