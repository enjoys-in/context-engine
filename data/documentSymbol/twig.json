{
  "language": "twig",
  "symbolPatterns": [
    {
      "name": "Block",
      "pattern": "\\{%[-~]?\\s*block\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "block"
    },
    {
      "name": "Extends",
      "pattern": "\\{%[-~]?\\s*extends\\s+['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "kind": 1,
      "type": "extends"
    },
    {
      "name": "Include",
      "pattern": "\\{%[-~]?\\s*include\\s+['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "kind": 1,
      "type": "include"
    },
    {
      "name": "Macro",
      "pattern": "\\{%[-~]?\\s*macro\\s+(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "macro"
    },
    {
      "name": "Set Variable",
      "pattern": "\\{%[-~]?\\s*set\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Set Block",
      "pattern": "\\{%[-~]?\\s*set\\s+(\\w+)\\s*%\\}",
      "captureGroup": 1,
      "kind": 12,
      "type": "variableBlock"
    },
    {
      "name": "For Loop",
      "pattern": "\\{%[-~]?\\s*for\\s+(\\w+)(?:\\s*,\\s*\\w+)?\\s+in\\s+",
      "captureGroup": 1,
      "kind": 12,
      "type": "forLoop"
    },
    {
      "name": "If Condition",
      "pattern": "\\{%[-~]?\\s*if\\s+(.+?)\\s*[-~]?%\\}",
      "captureGroup": 1,
      "kind": 7,
      "type": "condition"
    },
    {
      "name": "Import",
      "pattern": "\\{%[-~]?\\s*import\\s+['\"]([^'\"]+)['\"]\\s+as\\s+(\\w+)",
      "captureGroup": 2,
      "kind": 1,
      "type": "import"
    },
    {
      "name": "From Import",
      "pattern": "\\{%[-~]?\\s*from\\s+['\"]([^'\"]+)['\"]\\s+import\\s+(\\w+)",
      "captureGroup": 2,
      "kind": 1,
      "type": "fromImport"
    },
    {
      "name": "Embed",
      "pattern": "\\{%[-~]?\\s*embed\\s+['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "kind": 1,
      "type": "embed"
    },
    {
      "name": "Use",
      "pattern": "\\{%[-~]?\\s*use\\s+['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "kind": 1,
      "type": "use"
    },
    {
      "name": "Filter",
      "pattern": "\\{\\{\\s*\\w+(?:\\.\\w+)*\\|(\\w+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "filter"
    },
    {
      "name": "Raw Block",
      "pattern": "\\{%[-~]?\\s*(raw)\\s*[-~]?%\\}",
      "captureGroup": 1,
      "kind": 2,
      "type": "raw"
    },
    {
      "name": "Verbatim Block",
      "pattern": "\\{%[-~]?\\s*(verbatim)\\s*[-~]?%\\}",
      "captureGroup": 1,
      "kind": 2,
      "type": "verbatim"
    },
    {
      "name": "Autoescape",
      "pattern": "\\{%[-~]?\\s*autoescape\\s+['\"]?(\\w+)['\"]?",
      "captureGroup": 1,
      "kind": 2,
      "type": "autoescape"
    },
    {
      "name": "Spaceless",
      "pattern": "\\{%[-~]?\\s*(spaceless)\\s*[-~]?%\\}",
      "captureGroup": 1,
      "kind": 2,
      "type": "spaceless"
    },
    {
      "name": "CallbackDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(function|=>|->)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "GenericTypeDeclaration",
      "pattern": "\\\\b(\\\\w+)<[^>]+>",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "ClosureDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(\\\\(|\\\\|)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "TestDeclaration",
      "pattern": "\\\\b(?:test|it|describe|spec)\\\\s*\\\\(?['\"]([^'\"]+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "ErrorDeclaration",
      "pattern": "\\\\b(?:class|type)\\\\s+(\\\\w*Error|\\\\w*Exception)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    }
  ]
}
