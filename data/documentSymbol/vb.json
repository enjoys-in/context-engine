{
  "language": "vb",
  "symbolPatterns": [
    {
      "name": "Class",
      "pattern": "^\\s*(?:Public|Private|Friend)?\\s*(?:Partial\\s+)?Class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Module",
      "pattern": "^\\s*Module\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Sub",
      "pattern": "^\\s*(?:Public|Private|Protected|Friend)?\\s*(?:Shared\\s+)?Sub\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Function",
      "pattern": "^\\s*(?:Public|Private|Protected|Friend)?\\s*(?:Shared\\s+)?Function\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Property",
      "pattern": "^\\s*(?:Public|Private)?\\s*Property\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Interface",
      "pattern": "^\\s*(?:Public|Private)?\\s*Interface\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Enum",
      "pattern": "^\\s*(?:Public|Private)?\\s*Enum\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Function",
      "pattern": "(?:function|def|fn|func|sub|proc)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Variable",
      "pattern": "(?:var|let|const|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    }
  ]
}
