{
  "language": "vb",
  "symbolPatterns": [
    {
      "name": "Module",
      "pattern": "^\\s*(?:(?:Public|Friend)\\s+)?Module\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Class",
      "pattern": "^\\s*(?:(?:Public|Private|Friend)\\s+)?(?:Partial\\s+)?(?:(?:MustInherit|NotInheritable)\\s+)?Class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Structure",
      "pattern": "^\\s*(?:(?:Public|Private|Friend)\\s+)?(?:Partial\\s+)?Structure\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Enum",
      "pattern": "^\\s*(?:(?:Public|Private|Friend)\\s+)?Enum\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Interface",
      "pattern": "^\\s*(?:(?:Public|Private|Friend)\\s+)?Interface\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Sub",
      "pattern": "^\\s*(?:(?:Public|Private|Protected|Friend)\\s+)?(?:Shared\\s+)?(?:(?:Overrides|Overridable|MustOverride|Overloads)\\s+)?(?:Async\\s+)?Sub\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Function",
      "pattern": "^\\s*(?:(?:Public|Private|Protected|Friend)\\s+)?(?:Shared\\s+)?(?:(?:Overrides|Overridable|MustOverride|Overloads)\\s+)?(?:Async\\s+)?Function\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Property",
      "pattern": "^\\s*(?:(?:Public|Private|Protected|Friend)\\s+)?(?:Shared\\s+)?(?:(?:ReadOnly|WriteOnly)\\s+)?(?:Default\\s+)?Property\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Dim Variable",
      "pattern": "^\\s*Dim\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Private Field",
      "pattern": "^\\s*Private\\s+(\\w+)\\s+As\\s+",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "Public Field",
      "pattern": "^\\s*Public\\s+(\\w+)\\s+As\\s+",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "Const",
      "pattern": "^\\s*(?:(?:Public|Private|Friend)\\s+)?Const\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Event",
      "pattern": "^\\s*(?:(?:Public|Private|Friend)\\s+)?(?:Shared\\s+)?Event\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Delegate",
      "pattern": "^\\s*(?:(?:Public|Private|Friend)\\s+)?Delegate\\s+(?:Sub|Function)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Operator",
      "pattern": "^\\s*(?:(?:Public|Private)\\s+)?(?:Shared\\s+)?(?:(?:Widening|Narrowing)\\s+)?Operator\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Imports",
      "pattern": "^\\s*Imports\\s+([\\w.]+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Namespace",
      "pattern": "^\\s*Namespace\\s+([\\w.]+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "WithEvents",
      "pattern": "^\\s*(?:(?:Public|Private|Friend)\\s+)?WithEvents\\s+(\\w+)\\s+As\\s+",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Handles",
      "pattern": "\\)\\s+Handles\\s+([\\w.]+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "RaiseEvent",
      "pattern": "^\\s*RaiseEvent\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Custom Event",
      "pattern": "^\\s*(?:(?:Public|Private|Friend)\\s+)?Custom\\s+Event\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
