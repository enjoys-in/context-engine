{
  "language": "liquid",
  "symbolPatterns": [
    {
      "name": "Assign",
      "pattern": "\\{%[-]?\\s*assign\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Capture",
      "pattern": "\\{%[-]?\\s*capture\\s+(\\w+)\\s*[-]?%\\}",
      "captureGroup": 1,
      "kind": 12,
      "type": "capture"
    },
    {
      "name": "For Loop",
      "pattern": "\\{%[-]?\\s*for\\s+(\\w+)\\s+in\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "forLoop"
    },
    {
      "name": "If Condition",
      "pattern": "\\{%[-]?\\s*if\\s+(.+?)\\s*[-]?%\\}",
      "captureGroup": 1,
      "kind": 7,
      "type": "condition"
    },
    {
      "name": "Unless",
      "pattern": "\\{%[-]?\\s*unless\\s+(.+?)\\s*[-]?%\\}",
      "captureGroup": 1,
      "kind": 7,
      "type": "unless"
    },
    {
      "name": "Case",
      "pattern": "\\{%[-]?\\s*case\\s+(\\w+)\\s*[-]?%\\}",
      "captureGroup": 1,
      "kind": 7,
      "type": "case"
    },
    {
      "name": "When",
      "pattern": "\\{%[-]?\\s*when\\s+(.+?)\\s*[-]?%\\}",
      "captureGroup": 1,
      "kind": 7,
      "type": "when"
    },
    {
      "name": "Include",
      "pattern": "\\{%[-]?\\s*include\\s+['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "kind": 1,
      "type": "include"
    },
    {
      "name": "Render",
      "pattern": "\\{%[-]?\\s*render\\s+['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "kind": 1,
      "type": "render"
    },
    {
      "name": "Section",
      "pattern": "\\{%[-]?\\s*section\\s+['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "kind": 2,
      "type": "section"
    },
    {
      "name": "Block",
      "pattern": "\\{%[-]?\\s*block\\s+(\\w+)\\s*[-]?%\\}",
      "captureGroup": 1,
      "kind": 11,
      "type": "block"
    },
    {
      "name": "Comment",
      "pattern": "\\{%[-]?\\s*(comment)\\s*[-]?%\\}",
      "captureGroup": 1,
      "kind": 2,
      "type": "comment"
    },
    {
      "name": "Raw",
      "pattern": "\\{%[-]?\\s*(raw)\\s*[-]?%\\}",
      "captureGroup": 1,
      "kind": 2,
      "type": "raw"
    },
    {
      "name": "Schema",
      "pattern": "\\{%[-]?\\s*(schema)\\s*[-]?%\\}",
      "captureGroup": 1,
      "kind": 4,
      "type": "schema"
    },
    {
      "name": "Javascript",
      "pattern": "\\{%[-]?\\s*(javascript)\\s*[-]?%\\}",
      "captureGroup": 1,
      "kind": 2,
      "type": "javascript"
    },
    {
      "name": "Stylesheet",
      "pattern": "\\{%[-]?\\s*(stylesheet)\\s*[-]?%\\}",
      "captureGroup": 1,
      "kind": 2,
      "type": "stylesheet"
    },
    {
      "name": "Increment",
      "pattern": "\\{%[-]?\\s*increment\\s+(\\w+)\\s*[-]?%\\}",
      "captureGroup": 1,
      "kind": 12,
      "type": "increment"
    },
    {
      "name": "Decrement",
      "pattern": "\\{%[-]?\\s*decrement\\s+(\\w+)\\s*[-]?%\\}",
      "captureGroup": 1,
      "kind": 12,
      "type": "decrement"
    },
    {
      "name": "Paginate",
      "pattern": "\\{%[-]?\\s*paginate\\s+(\\S+)\\s+by\\s+(\\d+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "paginate"
    },
    {
      "name": "Layout",
      "pattern": "\\{%[-]?\\s*layout\\s+['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "kind": 1,
      "type": "layout"
    },
    {
      "name": "Content For Header",
      "pattern": "\\{\\{\\s*(content_for_header)\\s*\\}\\}",
      "captureGroup": 1,
      "kind": 6,
      "type": "contentForHeader"
    },
    {
      "name": "Tablerow",
      "pattern": "\\{%[-]?\\s*tablerow\\s+(\\w+)\\s+in\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "tablerow"
    }
  ]
}
