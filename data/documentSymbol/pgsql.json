{
  "language": "pgsql",
  "symbolPatterns": [
    {
      "name": "Table",
      "pattern": "CREATE\\s+TABLE\\s+(?:IF\\s+NOT\\s+EXISTS\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Function",
      "pattern": "CREATE\\s+(?:OR\\s+REPLACE\\s+)?FUNCTION\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "View",
      "pattern": "CREATE\\s+(?:MATERIALIZED\\s+)?VIEW\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Index",
      "pattern": "CREATE\\s+(?:UNIQUE\\s+)?INDEX\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Type",
      "pattern": "CREATE\\s+TYPE\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 25,
      "type": "type"
    }
  ]
}