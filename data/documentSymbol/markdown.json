{
  "language": "markdown",
  "symbolPatterns": [
    {
      "name": "Heading",
      "pattern": "^(#{1,6})\\\\s+(.+)",
      "captureGroup": 2,
      "kind": 2,
      "type": "module"
    },
    {
      "name": "Link Definition",
      "pattern": "^\\\\[(\\\\w+)\\\\]:",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "heading1",
      "pattern": "^#\\s+(.+)",
      "captureGroup": 1,
      "kind": 15,
      "type": "heading"
    },
    {
      "name": "heading2",
      "pattern": "^##\\s+(.+)",
      "captureGroup": 1,
      "kind": 15,
      "type": "heading"
    },
    {
      "name": "heading3",
      "pattern": "^###\\s+(.+)",
      "captureGroup": 1,
      "kind": 15,
      "type": "heading"
    },
    {
      "name": "code_block",
      "pattern": "^```(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "code"
    },
    {
      "name": "link_def",
      "pattern": "^\\[(\\w+)\\]:",
      "captureGroup": 1,
      "kind": 20,
      "type": "link"
    },
    {
      "name": "Function",
      "pattern": "(?:function|def|fn|func|sub|proc)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Class",
      "pattern": "(?:class|struct|interface|trait|type|record)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    }
  ]
}
