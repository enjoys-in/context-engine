{
  "language": "html",
  "symbolPatterns": [
    {
      "name": "Tag",
      "pattern": "<([a-zA-Z][a-zA-Z0-9]*)(?=[\\s>/])",
      "captureGroup": 1,
      "kind": 7,
      "type": "tag"
    },
    {
      "name": "ID Attribute",
      "pattern": "\\bid=[\"']([^\"']+)[\"']",
      "captureGroup": 1,
      "kind": 19,
      "type": "id"
    },
    {
      "name": "Class Attribute",
      "pattern": "\\bclass=[\"']([^\"']+)[\"']",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Script Tag",
      "pattern": "<(script)\\b[^>]*>",
      "captureGroup": 1,
      "kind": 1,
      "type": "script"
    },
    {
      "name": "Style Tag",
      "pattern": "<(style)\\b[^>]*>",
      "captureGroup": 1,
      "kind": 1,
      "type": "style"
    },
    {
      "name": "Link Tag",
      "pattern": "<link\\b[^>]*href=[\"']([^\"']+)[\"']",
      "captureGroup": 1,
      "kind": 14,
      "type": "link"
    },
    {
      "name": "Form Element",
      "pattern": "<(form|input|select|textarea|button)\\b",
      "captureGroup": 1,
      "kind": 7,
      "type": "form-element"
    },
    {
      "name": "Semantic Element",
      "pattern": "<(head|body|main|nav|header|footer|section|article|aside)\\b",
      "captureGroup": 1,
      "kind": 2,
      "type": "semantic-element"
    },
    {
      "name": "Custom Element",
      "pattern": "<([a-z][a-z0-9]*-[a-z0-9-]+)\\b",
      "captureGroup": 1,
      "kind": 4,
      "type": "custom-element"
    },
    {
      "name": "Data Attribute",
      "pattern": "\\b(data-[a-z][a-z0-9-]*)=",
      "captureGroup": 1,
      "kind": 6,
      "type": "data-attribute"
    },
    {
      "name": "Meta Tag",
      "pattern": "<meta\\b[^>]*(?:name|property)=[\"']([^\"']+)[\"']",
      "captureGroup": 1,
      "kind": 6,
      "type": "meta"
    },
    {
      "name": "Comment",
      "pattern": "<!--\\s*(.+?)\\s*-->",
      "captureGroup": 1,
      "kind": 14,
      "type": "comment"
    },
    {
      "name": "FunctionDeclaration",
      "pattern": "(?:function|def|fn|func|sub|proc)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "ClassDeclaration",
      "pattern": "\\\\bclass\\\\s+([A-Z]\\\\w*)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "VariableDeclaration",
      "pattern": "(?:const|let|var|val|dim)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "ConstantDeclaration",
      "pattern": "(?:const|final|readonly)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "MethodDeclaration",
      "pattern": "(?:public|private|protected)?\\\\s*(?:static\\\\s+)?(?:\\\\w+\\\\s+)?(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "PropertyDeclaration",
      "pattern": "(\\\\w+)\\\\s*[=:]\\\\s*",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "InterfaceDeclaration",
      "pattern": "\\\\binterface\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "EnumDeclaration",
      "pattern": "\\\\benum\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "TypeDeclaration",
      "pattern": "(?:type|struct|record)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "ModuleDeclaration",
      "pattern": "(?:module|namespace|package)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "NamespaceDeclaration",
      "pattern": "\\\\b(namespace|package|module)\\\\s+[\\\\w.]+",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "ConstructorDeclaration",
      "pattern": "(constructor|__init__|init|initialize)\\\\s*\\\\(?",
      "captureGroup": 1,
      "kind": 8,
      "type": "constructor"
    },
    {
      "name": "EventDeclaration",
      "pattern": "\\\\b(on\\\\w+|handle\\\\w+|emit\\\\w+)\\\\b",
      "captureGroup": 1,
      "kind": 23,
      "type": "event"
    },
    {
      "name": "ImportStatement",
      "pattern": "import\\\\s+.*?['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "ExportStatement",
      "pattern": "(?:export|pub|public)\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "CommentBlock",
      "pattern": "\\/\\\\*\\\\*([\\\\s\\\\S]*?)\\\\*\\/",
      "captureGroup": 0,
      "kind": 20,
      "type": "string"
    },
    {
      "name": "AnnotationDeclaration",
      "pattern": "@\\\\w+",
      "captureGroup": 1,
      "kind": 24,
      "type": "operator"
    },
    {
      "name": "FieldDeclaration",
      "pattern": "(\\\\w+)\\\\s*:\\\\s*\\\\w+",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "KeyDeclaration",
      "pattern": "\"?(\\\\w+)\"?\\\\s*[:=]",
      "captureGroup": 1,
      "kind": 19,
      "type": "key"
    },
    {
      "name": "ArrayDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*\\\\[",
      "captureGroup": 1,
      "kind": 17,
      "type": "array"
    }
  ]
}
