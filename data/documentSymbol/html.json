{
  "language": "html",
  "symbolPatterns": [
    {
      "name": "ID",
      "pattern": "id=\"([^\"]+)\"",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Class",
      "pattern": "class=\"([^\"]+)\"",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "id",
      "pattern": "\\bid=[\"']([^\"']+)[\"']",
      "captureGroup": 1,
      "kind": 20,
      "type": "id"
    },
    {
      "name": "class",
      "pattern": "\\bclass=[\"']([^\"']+)[\"']",
      "captureGroup": 1,
      "kind": 7,
      "type": "class"
    },
    {
      "name": "script",
      "pattern": "<script[^>]*>",
      "captureGroup": 0,
      "kind": 1,
      "type": "script"
    },
    {
      "name": "style",
      "pattern": "<style[^>]*>",
      "captureGroup": 0,
      "kind": 1,
      "type": "style"
    },
    {
      "name": "Function",
      "pattern": "(?:function|def|fn|func|sub|proc)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Module",
      "pattern": "(?:module|namespace|package|import)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    }
  ]
}
