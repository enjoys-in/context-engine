{
  "language": "html",
  "symbolPatterns": [
    {
      "name": "Tag",
      "pattern": "<([a-zA-Z][a-zA-Z0-9]*)(?=[\\s>/])",
      "captureGroup": 1,
      "kind": 7,
      "type": "tag"
    },
    {
      "name": "ID Attribute",
      "pattern": "\\bid=[\"']([^\"']+)[\"']",
      "captureGroup": 1,
      "kind": 19,
      "type": "id"
    },
    {
      "name": "Class Attribute",
      "pattern": "\\bclass=[\"']([^\"']+)[\"']",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Script Tag",
      "pattern": "<(script)\\b[^>]*>",
      "captureGroup": 1,
      "kind": 1,
      "type": "script"
    },
    {
      "name": "Style Tag",
      "pattern": "<(style)\\b[^>]*>",
      "captureGroup": 1,
      "kind": 1,
      "type": "style"
    },
    {
      "name": "Link Tag",
      "pattern": "<link\\b[^>]*href=[\"']([^\"']+)[\"']",
      "captureGroup": 1,
      "kind": 14,
      "type": "link"
    },
    {
      "name": "Form Element",
      "pattern": "<(form|input|select|textarea|button)\\b",
      "captureGroup": 1,
      "kind": 7,
      "type": "form-element"
    },
    {
      "name": "Semantic Element",
      "pattern": "<(head|body|main|nav|header|footer|section|article|aside)\\b",
      "captureGroup": 1,
      "kind": 2,
      "type": "semantic-element"
    },
    {
      "name": "Custom Element",
      "pattern": "<([a-z][a-z0-9]*-[a-z0-9-]+)\\b",
      "captureGroup": 1,
      "kind": 4,
      "type": "custom-element"
    },
    {
      "name": "Data Attribute",
      "pattern": "\\b(data-[a-z][a-z0-9-]*)=",
      "captureGroup": 1,
      "kind": 6,
      "type": "data-attribute"
    },
    {
      "name": "Meta Tag",
      "pattern": "<meta\\b[^>]*(?:name|property)=[\"']([^\"']+)[\"']",
      "captureGroup": 1,
      "kind": 6,
      "type": "meta"
    },
    {
      "name": "Comment",
      "pattern": "<!--\\s*(.+?)\\s*-->",
      "captureGroup": 1,
      "kind": 14,
      "type": "comment"
    }
  ]
}
