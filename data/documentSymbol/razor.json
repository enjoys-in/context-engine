{
  "language": "razor",
  "symbolPatterns": [
    {
      "name": "Model",
      "pattern": "@model\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Section",
      "pattern": "@section\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "CodeBlock",
      "pattern": "@functions|@code",
      "captureGroup": 0,
      "kind": 11,
      "type": "function"
    }
  ]
}