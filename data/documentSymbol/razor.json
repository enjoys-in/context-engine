{
  "language": "razor",
  "symbolPatterns": [
    {
      "name": "PageDirective",
      "pattern": "@page\\\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "ModelDirective",
      "pattern": "@model\\\\s+(\\\\S+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "UsingDirective",
      "pattern": "@using\\\\s+(\\\\S+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "InjectDirective",
      "pattern": "@inject\\\\s+(\\\\S+)\\\\s+(\\\\w+)",
      "captureGroup": 2,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "Section",
      "pattern": "@section\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "FunctionsBlock",
      "pattern": "@functions\\\\s*\\\\{",
      "captureGroup": 0,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "CodeBlock",
      "pattern": "@code\\\\s*\\\\{",
      "captureGroup": 0,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Helper",
      "pattern": "@helper\\\\s+(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "RazorExpression",
      "pattern": "@\\\\(([^)]+)\\\\)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "HtmlHelper",
      "pattern": "@Html\\\\.(\\\\w+)\\\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "TagHelper",
      "pattern": "<(\\\\w+[-\\\\w]*)\\\\s+asp-\\\\w+",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "PartialView",
      "pattern": "@await\\\\s+Html\\\\.PartialAsync\\\\(\"([^\"]+)\"",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "ComponentTag",
      "pattern": "<([A-Z]\\\\w+)(?:\\\\s|/|>)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "AttributeDirective",
      "pattern": "@attribute\\\\s+\\\\[([^\\\\]]+)\\\\]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "LayoutDirective",
      "pattern": "@layout\\\\s+(\\\\S+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "ImplementsDirective",
      "pattern": "@implements\\\\s+(\\\\S+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "InheritsDirective",
      "pattern": "@inherits\\\\s+(\\\\S+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "ConditionalBlock",
      "pattern": "@if\\\\s*\\\\(([^)]+)\\\\)",
      "captureGroup": 1,
      "kind": 19,
      "type": "key"
    },
    {
      "name": "ForLoop",
      "pattern": "@for\\\\s*\\\\(([^)]+)\\\\)",
      "captureGroup": 1,
      "kind": 19,
      "type": "key"
    },
    {
      "name": "ForEachLoop",
      "pattern": "@foreach\\\\s*\\\\(\\\\s*(?:var\\\\s+)?(\\\\w+)\\\\s+in",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "VariableDeclaration",
      "pattern": "(?:var|int|string|bool|double|decimal|float|long)\\\\s+(\\\\w+)\\\\s*=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    }
  ]
}
