{
  "language": "dotenv",
  "symbolPatterns": [
    {
      "name": "Variable",
      "pattern": "^([A-Za-z_]\\\\w*)\\\\s*=\\\\s*[^\"'\\\\s]",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "QuotedVariable",
      "pattern": "^([A-Za-z_]\\\\w*)\\\\s*=\\\\s*[\"']",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "ExportVariable",
      "pattern": "^export\\\\s+([A-Za-z_]\\\\w*)\\\\s*=",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Comment",
      "pattern": "^#\\\\s*(.+)",
      "captureGroup": 1,
      "kind": 19,
      "type": "key"
    },
    {
      "name": "EmptyValue",
      "pattern": "^([A-Za-z_]\\\\w*)\\\\s*=\\\\s*$",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "MultiWordValue",
      "pattern": "^([A-Za-z_]\\\\w*)\\\\s*=\\\\s*\"([^\"]*\\\\s[^\"]*)\"",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "VariableReference",
      "pattern": "\\\\$\\\\{([A-Za-z_]\\\\w*)\\\\}",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    }
  ]
}
