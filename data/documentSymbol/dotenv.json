{
  "language": "dotenv",
  "symbolPatterns": [
    {
      "name": "Variable",
      "pattern": "^\\\\s*(?:export\\\\s+)?(\\\\w+)\\\\s*=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "pattern": "^(\\w+)=",
      "captureGroup": 1,
      "kind": 13,
      "description": "Environment variable",
      "name": "Symbol"
    },
    {
      "pattern": "^#\\s*=+\\s*(.+)\\s*=+",
      "captureGroup": 1,
      "kind": 3,
      "description": "Section header comment",
      "name": "Comment"
    },
    {
      "pattern": "^#\\s*(.+)",
      "captureGroup": 1,
      "kind": 15,
      "description": "Comment annotation",
      "name": "Comment"
    },
    {
      "name": "Function",
      "pattern": "(?:function|def|fn|func|sub|proc)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Class",
      "pattern": "(?:class|struct|interface|trait|type|record)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Module",
      "pattern": "(?:module|namespace|package|import)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
