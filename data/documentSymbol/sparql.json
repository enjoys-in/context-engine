{
  "language": "sparql",
  "symbolPatterns": [
    {
      "name": "Prefix",
      "pattern": "^PREFIX\\s+(\\w+):",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Variable",
      "pattern": "\\?(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    }
  ]
}