{
  "language": "sparql",
  "symbolPatterns": [
    {
      "name": "SELECT Query",
      "pattern": "(?:^|\\n)\\s*(SELECT)\\s+(?:DISTINCT\\s+|REDUCED\\s+)?(.+?)\\s*(?:WHERE|\\{)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "ASK Query",
      "pattern": "(?:^|\\n)\\s*(ASK)\\s*(?:WHERE)?\\s*\\{",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "CONSTRUCT Query",
      "pattern": "(?:^|\\n)\\s*(CONSTRUCT)\\s*\\{",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "DESCRIBE Query",
      "pattern": "(?:^|\\n)\\s*(DESCRIBE)\\s+(\\S+)",
      "captureGroup": 2,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "PREFIX",
      "pattern": "^\\s*PREFIX\\s+(\\w+)\\s*:",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "BASE",
      "pattern": "^\\s*BASE\\s+<([^>]+)>",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "FILTER",
      "pattern": "FILTER\\s*\\(\\s*(.+?)\\s*\\)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "OPTIONAL Block",
      "pattern": "(OPTIONAL)\\s*\\{",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "UNION Block",
      "pattern": "\\}\\s*(UNION)\\s*\\{",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "SERVICE",
      "pattern": "SERVICE\\s+(?:SILENT\\s+)?<([^>]+)>",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "BIND",
      "pattern": "BIND\\s*\\(.+\\s+AS\\s+\\?(\\w+)\\s*\\)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "VALUES",
      "pattern": "VALUES\\s+\\(?(\\?\\w+(?:\\s+\\?\\w+)*)\\)?",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "GRAPH",
      "pattern": "GRAPH\\s+(?:<([^>]+)>|\\?(\\w+))",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "INSERT DATA",
      "pattern": "(?:^|\\n)\\s*(INSERT\\s+DATA)\\s*\\{",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "DELETE DATA",
      "pattern": "(?:^|\\n)\\s*(DELETE\\s+DATA)\\s*\\{",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "DELETE/INSERT WHERE",
      "pattern": "(?:^|\\n)\\s*(?:WITH\\s+<[^>]+>\\s+)?(DELETE)\\s*\\{",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Variable",
      "pattern": "\\?(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Prefixed URI",
      "pattern": "(\\w+):(\\w+)",
      "captureGroup": 2,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "Named Graph WITH",
      "pattern": "WITH\\s+<([^>]+)>",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    }
  ]
}