{
  "language": "sparql",
  "symbolPatterns": [
    {
      "name": "Prefix",
      "pattern": "^PREFIX\\s+(\\w+):",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Variable",
      "pattern": "\\?(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "pattern": "PREFIX\\s+(\\w+):",
      "captureGroup": 1,
      "kind": 3,
      "description": "Prefix declaration",
      "name": "Symbol"
    },
    {
      "pattern": "\\?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "description": "Variable",
      "name": "Symbol"
    },
    {
      "pattern": "(\\w+):(\\w+)",
      "captureGroup": 2,
      "kind": 7,
      "description": "Prefixed name",
      "name": "Symbol"
    },
    {
      "name": "Function",
      "pattern": "(?:function|def|fn|func|sub|proc)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Class",
      "pattern": "(?:class|struct|interface|trait|type|record)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
