{
  "language": "c",
  "symbolPatterns": [
    {
      "name": "Function definition",
      "pattern": "^(?:static\\s+|inline\\s+|extern\\s+)*(?:(?:unsigned|signed|long|short|const|volatile|struct|enum|union)\\s+)*\\w[\\w*\\s]+\\s+\\*?(\\w+)\\s*\\([^)]*\\)\\s*\\{",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Function prototype",
      "pattern": "^(?:extern\\s+)?(?:(?:unsigned|signed|long|short|const|volatile|struct|enum|union)\\s+)*\\w[\\w*\\s]+\\s+\\*?(\\w+)\\s*\\([^)]*\\)\\s*;",
      "captureGroup": 1,
      "kind": 11,
      "type": "functionPrototype"
    },
    {
      "name": "Struct",
      "pattern": "^\\s*(?:typedef\\s+)?struct\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Typedef struct (alias)",
      "pattern": "^\\s*typedef\\s+struct\\s+\\w*\\s*\\{[^}]*\\}\\s*(\\w+)\\s*;",
      "captureGroup": 1,
      "kind": 22,
      "type": "typedefStruct"
    },
    {
      "name": "Union",
      "pattern": "^\\s*(?:typedef\\s+)?union\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 22,
      "type": "union"
    },
    {
      "name": "Enum",
      "pattern": "^\\s*(?:typedef\\s+)?enum\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Enum member",
      "pattern": "^\\s+(\\w+)\\s*(?:=\\s*[^,}]+)?\\s*[,}]",
      "captureGroup": 1,
      "kind": 13,
      "type": "enumMember"
    },
    {
      "name": "Typedef (simple)",
      "pattern": "^\\s*typedef\\s+(?:unsigned\\s+|signed\\s+|long\\s+|short\\s+)*\\w+\\s+\\**(\\w+)\\s*;",
      "captureGroup": 1,
      "kind": 12,
      "type": "typedef"
    },
    {
      "name": "Function pointer typedef",
      "pattern": "^\\s*typedef\\s+\\w[\\w\\s*]+\\(\\s*\\*\\s*(\\w+)\\s*\\)\\s*\\(",
      "captureGroup": 1,
      "kind": 12,
      "type": "functionPointerTypedef"
    },
    {
      "name": "#define macro (object-like)",
      "pattern": "^\\s*#\\s*define\\s+(\\w+)(?:\\s+.+)?$",
      "captureGroup": 1,
      "kind": 13,
      "type": "macro"
    },
    {
      "name": "#define macro (function-like)",
      "pattern": "^\\s*#\\s*define\\s+(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "macroFunction"
    },
    {
      "name": "#include",
      "pattern": "^\\s*#\\s*include\\s+([\"<][^>\"]+[\">])",
      "captureGroup": 1,
      "kind": 1,
      "type": "include"
    },
    {
      "name": "Global variable",
      "pattern": "^(?:(?:unsigned|signed|long|short|const|volatile)\\s+)*\\w+\\s+\\**(\\w+)\\s*(?:=\\s*[^;]+)?\\s*;",
      "captureGroup": 1,
      "kind": 12,
      "type": "globalVariable"
    },
    {
      "name": "Static variable",
      "pattern": "^\\s*static\\s+(?:(?:unsigned|signed|long|short|const|volatile)\\s+)*\\w+\\s+\\**(\\w+)\\s*(?:=\\s*[^;]+)?\\s*;",
      "captureGroup": 1,
      "kind": 12,
      "type": "staticVariable"
    },
    {
      "name": "Extern declaration",
      "pattern": "^\\s*extern\\s+(?:(?:unsigned|signed|long|short|const|volatile)\\s+)*\\w+\\s+\\**(\\w+)\\s*;",
      "captureGroup": 1,
      "kind": 12,
      "type": "externDeclaration"
    },
    {
      "name": "Inline function",
      "pattern": "^\\s*(?:static\\s+)?inline\\s+\\w[\\w*\\s]+\\s+\\*?(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "inlineFunction"
    }
  ]
}
