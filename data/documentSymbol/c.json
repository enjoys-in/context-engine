{
  "language": "c",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\\\s*(?:\\\\w+\\\\s+)+\\\\*?(\\\\w+)\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Struct",
      "pattern": "^\\\\s*(?:typedef\\\\s+)?struct\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Enum",
      "pattern": "^\\\\s*(?:typedef\\\\s+)?enum\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    }
  ]
}