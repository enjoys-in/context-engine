{
  "language": "mips",
  "symbolPatterns": [
    {
      "name": "Label",
      "pattern": "^(\\w+):",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Directive",
      "pattern": "^\\s*(\\.\\w+)",
      "captureGroup": 1,
      "kind": 14,
      "type": "string"
    },
    {
      "pattern": "^(\\w+):",
      "captureGroup": 1,
      "kind": 12,
      "description": "Label"
    },
    {
      "pattern": "^\\s*\\.(data|text|globl)\\b",
      "captureGroup": 1,
      "kind": 3,
      "description": "Section directive"
    },
    {
      "pattern": "^(\\w+):\\s*\\.(word|byte|asciiz|space)",
      "captureGroup": 1,
      "kind": 13,
      "description": "Data label"
    },
    {
      "name": "Function",
      "pattern": "(?:function|def|fn|func|sub|proc)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Class",
      "pattern": "(?:class|struct|interface|trait|type|record)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Variable",
      "pattern": "(?:var|let|const|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Module",
      "pattern": "(?:module|namespace|package|import)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    }
  ]
}
