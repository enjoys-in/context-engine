{
  "language": "mips",
  "symbolPatterns": [
    {
      "name": "Label",
      "pattern": "^([a-zA-Z_]\\w*)\\s*:",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "TextSection",
      "pattern": "^\\s*(\\.text)\\b",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "DataSection",
      "pattern": "^\\s*(\\.data)\\b",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "GlobalDirective",
      "pattern": "^\\s*\\.globl\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "WordData",
      "pattern": "^(\\w+):\\s*\\.word\\b",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "ByteData",
      "pattern": "^(\\w+):\\s*\\.byte\\b",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "HalfData",
      "pattern": "^(\\w+):\\s*\\.half\\b",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "SpaceData",
      "pattern": "^(\\w+):\\s*\\.space\\b",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "AsciizData",
      "pattern": "^(\\w+):\\s*\\.asciiz\\b",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "Register",
      "pattern": "(\\$(?:t[0-9]|s[0-7]|a[0-3]|v[01]|ra|sp|gp|fp|zero|at|k[01]))\\b",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Instruction",
      "pattern": "^\\s+(add|addi|addiu|addu|sub|subu|mul|div|divu|and|andi|or|ori|nor|xor|xori|sll|srl|sra|slt|slti|sltiu|sltu|beq|bne|bgt|bge|blt|ble|j|jal|jr|jalr|lw|sw|lb|sb|lh|sh|lbu|lhu|lui|la|li|move|mfhi|mflo|nop|syscall)\\b",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Macro",
      "pattern": "^\\s*\\.macro\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Syscall",
      "pattern": "^\\s*(syscall)\\b",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Include",
      "pattern": "^\\s*\\.include\\s+\"([^\"]+)\"",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "EqvConstant",
      "pattern": "^\\s*\\.eqv\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Align",
      "pattern": "^\\s*(\\.align)\\s+\\d+",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Comment",
      "pattern": "#\\s*(.+)$",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
