{
  "language": "makefile",
  "symbolPatterns": [
    {
      "name": "Target",
      "pattern": "^([a-zA-Z_][a-zA-Z0-9_./-]*)\\\\s*:",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Variable",
      "pattern": "^\\\\s*([A-Z_][A-Z0-9_]*)\\\\s*[:?+]?=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    }
  ]
}
