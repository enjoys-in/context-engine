{
  "language": "makefile",
  "symbolPatterns": [
    {
      "name": "Include",
      "pattern": "^-?include\\s+(.+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "include"
    },
    {
      "name": ".PHONY",
      "pattern": "^\\.PHONY:\\s*(.+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "phony"
    },
    {
      "name": "Override variable",
      "pattern": "^override\\s+(\\w+)\\s*[:?+]?=",
      "captureGroup": 1,
      "kind": 12,
      "type": "override"
    },
    {
      "name": "Export variable",
      "pattern": "^export\\s+(\\w+)\\s*[:?+]?=",
      "captureGroup": 1,
      "kind": 12,
      "type": "export"
    },
    {
      "name": "Define macro",
      "pattern": "^define\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "macro"
    },
    {
      "name": "Conditional",
      "pattern": "^(ifeq|ifneq|ifdef|ifndef)\\s+(.+)",
      "captureGroup": 2,
      "kind": 19,
      "type": "conditional"
    },
    {
      "name": "Variable assignment",
      "pattern": "^([A-Za-z_][\\w]*)\\s*[:?+]?=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Pattern rule",
      "pattern": "^(%[\\w.]+)\\s*:\\s*%",
      "captureGroup": 1,
      "kind": 5,
      "type": "pattern-rule"
    },
    {
      "name": "Target",
      "pattern": "^([a-zA-Z_][\\w.-]*)\\s*:[^=]",
      "captureGroup": 1,
      "kind": 11,
      "type": "target"
    },
    {
      "name": "Function call",
      "pattern": "\\$\\(call\\s+(\\w[\\w-]*)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function-call"
    },
    {
      "name": "Recipe line",
      "pattern": "^\\t(.+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "recipe"
    }
  ]
}
