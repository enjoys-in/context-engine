{
  "language": "kotlin",
  "symbolPatterns": [
    {
      "name": "Class",
      "pattern": "^\\s*(?:(?:private|protected|internal|public|open|abstract|inner)\\s+)*class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Data Class",
      "pattern": "^\\s*(?:(?:private|protected|internal|public)\\s+)*data\\s+class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "data class"
    },
    {
      "name": "Sealed Class",
      "pattern": "^\\s*(?:(?:private|protected|internal|public)\\s+)*sealed\\s+class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "sealed class"
    },
    {
      "name": "Annotation Class",
      "pattern": "^\\s*(?:(?:private|protected|internal|public)\\s+)*annotation\\s+class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "annotation class"
    },
    {
      "name": "Object",
      "pattern": "^\\s*(?:(?:private|protected|internal|public)\\s+)*object\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "object"
    },
    {
      "name": "Companion Object",
      "pattern": "^\\s*companion\\s+object\\s*(\\w*)",
      "captureGroup": 1,
      "kind": 1,
      "type": "companion object"
    },
    {
      "name": "Interface",
      "pattern": "^\\s*(?:(?:private|protected|internal|public|sealed|fun)\\s+)*interface\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Enum Class",
      "pattern": "^\\s*(?:(?:private|protected|internal|public)\\s+)*enum\\s+class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum class"
    },
    {
      "name": "Enum Entry",
      "pattern": "^\\s+(\\w+)\\s*(?:\\(|,|;|$)",
      "captureGroup": 1,
      "kind": 21,
      "type": "enum entry"
    },
    {
      "name": "Fun",
      "pattern": "^\\s*(?:(?:private|protected|internal|public|override|open|abstract|inline|infix|operator|tailrec|external)\\s+)*fun\\s+(?:<[^>]+>\\s+)?(?:\\w+\\.)?([\\w]+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Suspend Function",
      "pattern": "^\\s*(?:(?:private|protected|internal|public|override|open|abstract)\\s+)*suspend\\s+fun\\s+(?:<[^>]+>\\s+)?(?:\\w+\\.)?([\\w]+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "suspend function"
    },
    {
      "name": "Extension Function",
      "pattern": "^\\s*(?:(?:private|protected|internal|public|inline)\\s+)*fun\\s+(?:<[^>]+>\\s+)?(\\w+)\\.(\\w+)",
      "captureGroup": 2,
      "kind": 11,
      "type": "extension function"
    },
    {
      "name": "Property",
      "pattern": "^\\s*(?:(?:private|protected|internal|public|override|open|lateinit|abstract)\\s+)*(?:val|var)\\s+(?:<[^>]+>\\s+)?(?:\\w+\\.)?(\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Const Val",
      "pattern": "^\\s*(?:(?:private|protected|internal|public)\\s+)*const\\s+val\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Constructor",
      "pattern": "^\\s*(?:(?:private|protected|internal|public)\\s+)*constructor\\s*\\(",
      "captureGroup": 0,
      "kind": 8,
      "type": "constructor"
    },
    {
      "name": "Init Block",
      "pattern": "^\\s*init\\s*\\{",
      "captureGroup": 0,
      "kind": 8,
      "type": "init block"
    },
    {
      "name": "Typealias",
      "pattern": "^\\s*(?:(?:private|protected|internal|public)\\s+)*typealias\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 25,
      "type": "typealias"
    },
    {
      "name": "Package",
      "pattern": "^package\\s+([\\w.]+)",
      "captureGroup": 1,
      "kind": 3,
      "type": "package"
    },
    {
      "name": "Import",
      "pattern": "^import\\s+([\\w.*]+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "import"
    }
  ]
}
