{
  "language": "kotlin",
  "symbolPatterns": [
    {
      "name": "Function Declaration",
      "pattern": "^\\s*(?:(?:private|protected|internal|public|override|open|abstract|suspend|inline|infix|operator|tailrec)\\s+)*fun\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "detail": "function"
    },
    {
      "name": "Class Declaration",
      "pattern": "^\\s*(?:(?:private|protected|internal|public|abstract|open|sealed|data|inner|enum|annotation)\\s+)*class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "detail": "class"
    },
    {
      "name": "Interface Declaration",
      "pattern": "^\\s*(?:(?:private|protected|internal|public|sealed)\\s+)*interface\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "detail": "interface"
    },
    {
      "name": "Object Declaration",
      "pattern": "^\\s*(?:(?:private|protected|internal|public)\\s+)*object\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "detail": "object"
    },
    {
      "name": "Property Declaration",
      "pattern": "^\\s*(?:(?:private|protected|internal|public|override|open|const|lateinit)\\s+)*(?:val|var)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "detail": "property"
    },
    {
      "name": "Enum Entry",
      "pattern": "^\\s+(\\w+)\\s*(?:\\(|,|$)",
      "captureGroup": 1,
      "kind": 21,
      "detail": "enum entry"
    },
    {
      "name": "Companion Object",
      "pattern": "^\\s*companion\\s+object\\s*(\\w*)",
      "captureGroup": 1,
      "kind": 1,
      "detail": "companion object"
    },
    {
      "name": "Type Alias",
      "pattern": "^\\s*typealias\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 25,
      "detail": "type alias"
    },
    {
      "name": "Constructor",
      "pattern": "^\\s*(?:(?:private|protected|internal|public)\\s+)?constructor\\s*\\(",
      "captureGroup": 0,
      "kind": 8,
      "detail": "constructor"
    },
    {
      "name": "Package Declaration",
      "pattern": "^\\s*package\\s+([\\w.]+)",
      "captureGroup": 1,
      "kind": 3,
      "detail": "package"
    }
  ]
}