{
  "language": "json",
  "symbolPatterns": [
    {
      "name": "Top-level Key",
      "pattern": "^\\s*\"(\\w[\\w$.-]*)\"\\s*:",
      "captureGroup": 1,
      "kind": 19,
      "type": "key"
    },
    {
      "name": "Nested Object Key",
      "pattern": "\"(\\w[\\w$.-]*)\"\\s*:\\s*\\{",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Array Property",
      "pattern": "\"(\\w[\\w$.-]*)\"\\s*:\\s*\\[",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "String Value",
      "pattern": "\"(\\w[\\w$.-]*)\"\\s*:\\s*\"",
      "captureGroup": 1,
      "kind": 14,
      "type": "string"
    },
    {
      "name": "Number Value",
      "pattern": "\"(\\w[\\w$.-]*)\"\\s*:\\s*-?\\d",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Boolean Value",
      "pattern": "\"(\\w[\\w$.-]*)\"\\s*:\\s*(?:true|false)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Null Value",
      "pattern": "\"(\\w[\\w$.-]*)\"\\s*:\\s*null",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Deeply Nested Key",
      "pattern": "^\\s{4,}\"(\\w[\\w$.-]*)\"\\s*:",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    }
  ]
}
