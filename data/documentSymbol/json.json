{
  "language": "json",
  "symbolPatterns": [
    {
      "name": "Key",
      "pattern": "\"(\\\\w+)\"\\\\s*:",
      "captureGroup": 1,
      "kind": 19,
      "type": "variable"
    },
    {
      "pattern": "\"(\\w+)\"\\s*:",
      "captureGroup": 1,
      "kind": 20,
      "description": "Object key",
      "name": "Symbol"
    },
    {
      "pattern": "\"(\\w+)\"\\s*:\\s*\\{",
      "captureGroup": 1,
      "kind": 19,
      "description": "Nested object",
      "name": "Symbol"
    },
    {
      "pattern": "\"(\\w+)\"\\s*:\\s*\\[",
      "captureGroup": 1,
      "kind": 18,
      "description": "Array property",
      "name": "Symbol"
    },
    {
      "name": "Function",
      "pattern": "(?:function|def|fn|func|sub|proc)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Class",
      "pattern": "(?:class|struct|interface|trait|type|record)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Module",
      "pattern": "(?:module|namespace|package|import)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
