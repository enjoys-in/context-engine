{
  "language": "ruby",
  "symbolPatterns": [
    {
      "name": "Method",
      "pattern": "^\\\\s*def\\\\s+(\\\\w+[!?=]?)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Class",
      "pattern": "^\\\\s*class\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Module",
      "pattern": "^\\\\s*module\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Constant",
      "pattern": "^\\\\s*([A-Z][A-Z0-9_]*)\\\\s*=",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Function",
      "pattern": "(?:function|def|fn|func|sub|proc)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Variable",
      "pattern": "(?:var|let|const|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "TypeAlias",
      "pattern": "(?:type|typedef)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 25,
      "type": "typeAlias"
    },
    {
      "name": "Event",
      "pattern": "(?:event|on\\w+)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 23,
      "type": "event"
    }
  ]
}
