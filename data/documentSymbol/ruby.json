{
  "language": "ruby",
  "symbolPatterns": [
    {
      "name": "Method",
      "pattern": "^\\\\s*def\\\\s+(\\\\w+[!?=]?)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Class",
      "pattern": "^\\\\s*class\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Module",
      "pattern": "^\\\\s*module\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Constant",
      "pattern": "^\\\\s*([A-Z][A-Z0-9_]*)\\\\s*=",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    }
  ]
}
