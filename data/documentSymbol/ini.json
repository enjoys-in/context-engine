{
  "language": "ini",
  "symbolPatterns": [
    {
      "name": "Section",
      "pattern": "^\\\\s*\\\\[([^\\\\]\\\\[]+)\\\\]\\\\s*$",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Subsection",
      "pattern": "^\\\\s*\\\\[([^\\\\]]+\\\\.[^\\\\]]+)\\\\]\\\\s*$",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Key=Value",
      "pattern": "^\\\\s*([\\\\w.-]+)\\\\s*[=:]\\\\s*(.+)$",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "Comment",
      "pattern": "^\\\\s*[;#]\\\\s*(.+)$",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Multi-line Value",
      "pattern": "^\\\\s*([\\\\w.-]+)\\\\s*=\\\\s*.*\\\\\\\\\\\\s*$",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
