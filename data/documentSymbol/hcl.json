{
  "language": "hcl",
  "symbolPatterns": [
    {
      "name": "Resource",
      "pattern": "^\\s*resource\\s+\"([\\w-]+)\"\\s+\"([\\w-]+)\"",
      "captureGroup": 0,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "DataSource",
      "pattern": "^\\s*data\\s+\"([\\w-]+)\"\\s+\"([\\w-]+)\"",
      "captureGroup": 0,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Variable",
      "pattern": "^\\s*variable\\s+\"([\\w-]+)\"",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Output",
      "pattern": "^\\s*output\\s+\"([\\w-]+)\"",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Module",
      "pattern": "^\\s*module\\s+\"([\\w-]+)\"",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Provider",
      "pattern": "^\\s*provider\\s+\"([\\w-]+)\"",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Locals",
      "pattern": "^\\s*locals\\s*\\{",
      "captureGroup": 0,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Terraform",
      "pattern": "^\\s*terraform\\s*\\{",
      "captureGroup": 0,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Backend",
      "pattern": "^\\s*backend\\s+\"([\\w-]+)\"",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Dynamic",
      "pattern": "^\\s*dynamic\\s+\"([\\w-]+)\"",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "ForEach",
      "pattern": "^\\s*for_each\\s*=",
      "captureGroup": 0,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Count",
      "pattern": "^\\s*count\\s*=",
      "captureGroup": 0,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Provisioner",
      "pattern": "^\\s*provisioner\\s+\"([\\w-]+)\"",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Lifecycle",
      "pattern": "^\\s*lifecycle\\s*\\{",
      "captureGroup": 0,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Moved",
      "pattern": "^\\s*moved\\s*\\{",
      "captureGroup": 0,
      "kind": 22,
      "type": "struct"
    }
  ]
}
