{
  "language": "hcl",
  "symbolPatterns": [
    {
      "name": "Resource",
      "pattern": "^\\\\s*resource\\\\s+\"(\\\\w+)\"\\\\s+\"(\\\\w+)\"",
      "captureGroup": 0,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Variable",
      "pattern": "^\\\\s*variable\\\\s+\"(\\\\w+)\"",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Output",
      "pattern": "^\\\\s*output\\\\s+\"(\\\\w+)\"",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Module",
      "pattern": "^\\\\s*module\\\\s+\"(\\\\w+)\"",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Function",
      "pattern": "(?:function|def|fn|func|sub|proc)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Method",
      "pattern": "(?:public|private|protected)?\\s*(?:static)?\\s*(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "TypeAlias",
      "pattern": "(?:type|typedef)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 25,
      "type": "typeAlias"
    }
  ]
}
