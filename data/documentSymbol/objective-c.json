{
  "language": "objective-c",
  "symbolPatterns": [
    {
      "name": "Interface",
      "pattern": "@interface\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Implementation",
      "pattern": "@implementation\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Protocol",
      "pattern": "@protocol\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Method",
      "pattern": "^\\s*[-+]\\s*\\([^)]+\\)(\\w+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Property",
      "pattern": "@property\\s+.*\\s+(\\w+);",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}