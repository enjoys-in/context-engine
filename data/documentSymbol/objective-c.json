{
  "language": "objective-c",
  "symbolPatterns": [
    {
      "name": "@interface",
      "pattern": "^\\s*@interface\\s+(\\w+)\\s*(?::\\s*\\w+)?",
      "captureGroup": 1,
      "kind": 4,
      "type": "interface"
    },
    {
      "name": "@implementation",
      "pattern": "^\\s*@implementation\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "implementation"
    },
    {
      "name": "@protocol",
      "pattern": "^\\s*@protocol\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "protocol"
    },
    {
      "name": "Instance method",
      "pattern": "^\\s*-\\s*\\(([^)]+)\\)\\s*(\\w+)",
      "captureGroup": 2,
      "kind": 5,
      "type": "instanceMethod"
    },
    {
      "name": "Class method",
      "pattern": "^\\s*\\+\\s*\\(([^)]+)\\)\\s*(\\w+)",
      "captureGroup": 2,
      "kind": 5,
      "type": "classMethod"
    },
    {
      "name": "@property",
      "pattern": "^\\s*@property\\s*(?:\\([^)]*\\))?\\s*(?:\\w+\\s*\\*?\\s*)*(\\w+)\\s*;",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "@synthesize",
      "pattern": "^\\s*@synthesize\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "synthesize"
    },
    {
      "name": "@dynamic",
      "pattern": "^\\s*@dynamic\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "dynamic"
    },
    {
      "name": "Category",
      "pattern": "^\\s*@interface\\s+(\\w+)\\s*\\(\\s*(\\w+)\\s*\\)",
      "captureGroup": 2,
      "kind": 4,
      "type": "category"
    },
    {
      "name": "Class extension",
      "pattern": "^\\s*@interface\\s+(\\w+)\\s*\\(\\s*\\)",
      "captureGroup": 1,
      "kind": 4,
      "type": "extension"
    },
    {
      "name": "#import",
      "pattern": "^\\s*#import\\s+([\"<][^>\"]+[\">])",
      "captureGroup": 1,
      "kind": 1,
      "type": "import"
    },
    {
      "name": "NS_ENUM",
      "pattern": "\\btypedef\\s+NS_ENUM\\s*\\(\\s*\\w+\\s*,\\s*(\\w+)\\s*\\)",
      "captureGroup": 1,
      "kind": 9,
      "type": "nsEnum"
    },
    {
      "name": "NS_OPTIONS",
      "pattern": "\\btypedef\\s+NS_OPTIONS\\s*\\(\\s*\\w+\\s*,\\s*(\\w+)\\s*\\)",
      "captureGroup": 1,
      "kind": 9,
      "type": "nsOptions"
    },
    {
      "name": "Block typedef",
      "pattern": "^\\s*typedef\\s+\\w[\\w\\s*]*\\(\\s*\\^\\s*(\\w+)\\s*\\)\\s*\\(",
      "captureGroup": 1,
      "kind": 12,
      "type": "blockTypedef"
    },
    {
      "name": "Extern NSString constant",
      "pattern": "^\\s*extern\\s+NSString\\s*\\*\\s*(?:const\\s+)?(\\w+)\\s*;",
      "captureGroup": 1,
      "kind": 13,
      "type": "externConstant"
    },
    {
      "name": "FOUNDATION_EXPORT constant",
      "pattern": "^\\s*(?:FOUNDATION_EXPORT|FOUNDATION_EXTERN)\\s+NSString\\s*\\*\\s*(?:const\\s+)?(\\w+)\\s*;",
      "captureGroup": 1,
      "kind": 13,
      "type": "foundationConstant"
    },
    {
      "name": "Protocol conformance",
      "pattern": "^\\s*@interface\\s+\\w+\\s*(?::\\s*\\w+)?\\s*<([\\w,\\s]+)>",
      "captureGroup": 1,
      "kind": 10,
      "type": "protocolConformance"
    },
    {
      "name": "Plain enum",
      "pattern": "^\\s*(?:typedef\\s+)?enum\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "CallbackDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(function|=>|->)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "GenericTypeDeclaration",
      "pattern": "\\\\b(\\\\w+)<[^>]+>",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "ClosureDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(\\\\(|\\\\|)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "TestDeclaration",
      "pattern": "\\\\b(?:test|it|describe|spec)\\\\s*\\\\(?['\"]([^'\"]+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    }
  ]
}
