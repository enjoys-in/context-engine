{
  "language": "pla",
  "symbolPatterns": [
    {
      "name": "Inputs",
      "pattern": "^(\\.i)\\s+\\d+",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Outputs",
      "pattern": "^(\\.o)\\s+\\d+",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "ProductTerms",
      "pattern": "^(\\.p)\\s+\\d+",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "InputLabels",
      "pattern": "^\\.ilb\\s+(.+)$",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "OutputLabels",
      "pattern": "^\\.ob\\s+(.+)$",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "Type",
      "pattern": "^\\.type\\s+(fd|fr|fp|fdr)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Phase",
      "pattern": "^(\\.phase)\\s+[01]+",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "End",
      "pattern": "^(\\.e)\\s*$",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "ProductTerm",
      "pattern": "^([01-]+)\\s+[01-]+",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Comment",
      "pattern": "^#\\s*(.+)$",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
