{
  "language": "nestjs",
  "symbolPatterns": [
    {
      "name": "Controller",
      "pattern": "@Controller\\s*\\([^)]*\\)\\s*(?:export\\s+)?class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "controller"
    },
    {
      "name": "Injectable Service",
      "pattern": "@Injectable\\s*\\([^)]*\\)\\s*(?:export\\s+)?class\\s+(\\w+Service)",
      "captureGroup": 1,
      "kind": 4,
      "type": "service"
    },
    {
      "name": "Module",
      "pattern": "@Module\\s*\\([^)]*\\)\\s*(?:export\\s+)?class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "GET Handler",
      "pattern": "@Get\\s*\\([^)]*\\)\\s*(?:@\\w+\\s*\\([^)]*\\)\\s*)*(?:async\\s+)?(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "get-handler"
    },
    {
      "name": "POST Handler",
      "pattern": "@Post\\s*\\([^)]*\\)\\s*(?:@\\w+\\s*\\([^)]*\\)\\s*)*(?:async\\s+)?(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "post-handler"
    },
    {
      "name": "PUT Handler",
      "pattern": "@Put\\s*\\([^)]*\\)\\s*(?:@\\w+\\s*\\([^)]*\\)\\s*)*(?:async\\s+)?(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "put-handler"
    },
    {
      "name": "DELETE Handler",
      "pattern": "@Delete\\s*\\([^)]*\\)\\s*(?:@\\w+\\s*\\([^)]*\\)\\s*)*(?:async\\s+)?(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "delete-handler"
    },
    {
      "name": "PATCH Handler",
      "pattern": "@Patch\\s*\\([^)]*\\)\\s*(?:@\\w+\\s*\\([^)]*\\)\\s*)*(?:async\\s+)?(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "patch-handler"
    },
    {
      "name": "Guard",
      "pattern": "@Injectable\\s*\\(\\)\\s*(?:export\\s+)?class\\s+(\\w+Guard)\\s+implements\\s+CanActivate",
      "captureGroup": 1,
      "kind": 4,
      "type": "guard"
    },
    {
      "name": "Interceptor",
      "pattern": "@Injectable\\s*\\(\\)\\s*(?:export\\s+)?class\\s+(\\w+Interceptor)\\s+implements\\s+NestInterceptor",
      "captureGroup": 1,
      "kind": 4,
      "type": "interceptor"
    },
    {
      "name": "Pipe",
      "pattern": "@Injectable\\s*\\(\\)\\s*(?:export\\s+)?class\\s+(\\w+Pipe)\\s+implements\\s+PipeTransform",
      "captureGroup": 1,
      "kind": 4,
      "type": "pipe"
    },
    {
      "name": "Middleware",
      "pattern": "@Injectable\\s*\\(\\)\\s*(?:export\\s+)?class\\s+(\\w+Middleware)\\s+implements\\s+NestMiddleware",
      "captureGroup": 1,
      "kind": 4,
      "type": "middleware"
    },
    {
      "name": "WebSocket Gateway",
      "pattern": "@WebSocketGateway\\s*\\([^)]*\\)\\s*(?:export\\s+)?class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "gateway"
    },
    {
      "name": "EventPattern",
      "pattern": "@EventPattern\\s*\\(['\"]([^'\"]+)['\"]\\)",
      "captureGroup": 1,
      "kind": 5,
      "type": "event-pattern"
    },
    {
      "name": "MessagePattern",
      "pattern": "@MessagePattern\\s*\\(['\"]([^'\"]+)['\"]\\)",
      "captureGroup": 1,
      "kind": 5,
      "type": "message-pattern"
    },
    {
      "name": "Inject",
      "pattern": "@Inject\\s*\\(['\"]?(\\w+)['\"]?\\)",
      "captureGroup": 1,
      "kind": 7,
      "type": "inject"
    },
    {
      "name": "InjectRepository",
      "pattern": "@InjectRepository\\s*\\((\\w+)\\)",
      "captureGroup": 1,
      "kind": 7,
      "type": "inject-repository"
    },
    {
      "name": "Constructor DI",
      "pattern": "constructor\\s*\\(([^)]+)\\)",
      "captureGroup": 1,
      "kind": 8,
      "type": "constructor"
    },
    {
      "name": "DTO Class",
      "pattern": "(?:export\\s+)?class\\s+(\\w+Dto)\\s*(?:extends|implements|\\{)",
      "captureGroup": 1,
      "kind": 4,
      "type": "dto"
    },
    {
      "name": "Entity Class",
      "pattern": "@Entity\\s*\\([^)]*\\)\\s*(?:export\\s+)?class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "entity"
    },
    {
      "name": "Resolver",
      "pattern": "@Resolver\\s*\\([^)]*\\)\\s*(?:export\\s+)?class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "resolver"
    },
    {
      "name": "GraphQL Query",
      "pattern": "@Query\\s*\\([^)]*\\)\\s*(?:async\\s+)?(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "gql-query"
    },
    {
      "name": "GraphQL Mutation",
      "pattern": "@Mutation\\s*\\([^)]*\\)\\s*(?:async\\s+)?(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "gql-mutation"
    },
    {
      "name": "Provider",
      "pattern": "(?:export\\s+)?const\\s+(\\w+Provider)\\s*[:,=]",
      "captureGroup": 1,
      "kind": 13,
      "type": "provider"
    },
    {
      "name": "Exception Filter",
      "pattern": "@Catch\\s*\\([^)]*\\)\\s*(?:export\\s+)?class\\s+(\\w+)\\s+implements\\s+ExceptionFilter",
      "captureGroup": 1,
      "kind": 4,
      "type": "exception-filter"
    }
  ]
}
