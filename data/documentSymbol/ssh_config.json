{
  "language": "ssh_config",
  "symbolPatterns": [
    {
      "name": "Host",
      "pattern": "^\\s*Host\\s+(\\S+.*)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Match",
      "pattern": "^\\s*Match\\s+(.+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "HostName",
      "pattern": "^\\s*HostName\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "User",
      "pattern": "^\\s*User\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Port",
      "pattern": "^\\s*Port\\s+(\\d+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "IdentityFile",
      "pattern": "^\\s*IdentityFile\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "ProxyJump",
      "pattern": "^\\s*ProxyJump\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "ForwardAgent",
      "pattern": "^\\s*ForwardAgent\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Include",
      "pattern": "^\\s*Include\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Compression",
      "pattern": "^\\s*Compression\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "StrictHostKeyChecking",
      "pattern": "^\\s*StrictHostKeyChecking\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "ServerAliveInterval",
      "pattern": "^\\s*ServerAliveInterval\\s+(\\d+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Comment",
      "pattern": "^\\s*#\\s*(.+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    }
  ]
}
