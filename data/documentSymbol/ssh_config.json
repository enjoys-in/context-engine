{
  "language": "ssh_config",
  "symbolPatterns": [
    {
      "name": "Host",
      "pattern": "^\\\\s*Host\\\\s+(\\\\S+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Match",
      "pattern": "^\\\\s*Match\\\\s+(.+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "pattern": "^Host\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 5,
      "description": "Host block"
    },
    {
      "pattern": "^Match\\s+(.*)",
      "captureGroup": 1,
      "kind": 5,
      "description": "Match block"
    },
    {
      "pattern": "^\\s+(\\w+)\\s",
      "captureGroup": 1,
      "kind": 7,
      "description": "Configuration directive"
    },
    {
      "name": "Function",
      "pattern": "(?:function|def|fn|func|sub|proc)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Class",
      "pattern": "(?:class|struct|interface|trait|type|record)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Variable",
      "pattern": "(?:var|let|const|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    }
  ]
}
