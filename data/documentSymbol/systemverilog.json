{
  "language": "systemverilog",
  "symbolPatterns": [
    {
      "name": "Module",
      "pattern": "^\\s*module\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Interface",
      "pattern": "^\\s*interface\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Class",
      "pattern": "^\\s*(?:virtual\\s+)?class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Function",
      "pattern": "^\\s*(?:virtual\\s+)?function\\s+\\w+\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Task",
      "pattern": "^\\s*task\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Package",
      "pattern": "^\\s*package\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 3,
      "type": "package"
    }
  ]
}