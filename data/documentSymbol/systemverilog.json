{
  "language": "systemverilog",
  "symbolPatterns": [
    {
      "name": "Module",
      "pattern": "^\\s*module\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Interface",
      "pattern": "^\\s*interface\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Class",
      "pattern": "^\\s*(?:virtual\\s+)?class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Function",
      "pattern": "^\\s*(?:virtual\\s+)?function\\s+\\w+\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Task",
      "pattern": "^\\s*task\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Package",
      "pattern": "^\\s*package\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 3,
      "type": "package"
    },
    {
      "name": "Variable",
      "pattern": "(?:var|let|const|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
