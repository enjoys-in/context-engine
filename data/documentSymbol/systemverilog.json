{
  "language": "systemverilog",
  "symbolPatterns": [
    {
      "name": "Module",
      "pattern": "^\\s*module\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Interface",
      "pattern": "^\\s*interface\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Class",
      "pattern": "^\\s*(?:virtual\\s+)?class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Package",
      "pattern": "^\\s*package\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Function",
      "pattern": "^\\s*(?:virtual\\s+)?function\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Task",
      "pattern": "^\\s*(?:virtual\\s+)?task\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "AlwaysBlock",
      "pattern": "^\\s*(always(?:_ff|_comb|_latch)?)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Parameter",
      "pattern": "^\\s*(?:localparam|parameter)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Typedef",
      "pattern": "^\\s*typedef\\s+.*\\b(\\w+)\\s*;",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Enum",
      "pattern": "^\\s*(?:typedef\\s+)?enum\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Struct",
      "pattern": "^\\s*(?:typedef\\s+)?struct\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Constraint",
      "pattern": "^\\s*constraint\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Covergroup",
      "pattern": "^\\s*covergroup\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Define",
      "pattern": "^\\s*`define\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Include",
      "pattern": "^\\s*`include\\s+[\"<]([^\">]+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    }
  ]
}
