{
  "language": "angular",
  "symbolPatterns": [
    {
      "name": "Component",
      "pattern": "@Component\\s*\\([^)]*\\)\\s*(?:export\\s+)?class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "component"
    },
    {
      "name": "Injectable",
      "pattern": "@Injectable\\s*\\([^)]*\\)\\s*(?:export\\s+)?class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "injectable"
    },
    {
      "name": "NgModule",
      "pattern": "@NgModule\\s*\\([^)]*\\)\\s*(?:export\\s+)?class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Directive",
      "pattern": "@Directive\\s*\\([^)]*\\)\\s*(?:export\\s+)?class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "directive"
    },
    {
      "name": "Pipe",
      "pattern": "@Pipe\\s*\\([^)]*\\)\\s*(?:export\\s+)?class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "pipe"
    },
    {
      "name": "Input Property",
      "pattern": "@Input\\s*\\([^)]*\\)\\s+(?:readonly\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "input"
    },
    {
      "name": "Output Property",
      "pattern": "@Output\\s*\\([^)]*\\)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "output"
    },
    {
      "name": "ViewChild",
      "pattern": "@ViewChild\\s*\\([^)]*\\)\\s+(?:readonly\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "viewchild"
    },
    {
      "name": "ContentChild",
      "pattern": "@ContentChild\\s*\\([^)]*\\)\\s+(?:readonly\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "contentchild"
    },
    {
      "name": "Class",
      "pattern": "(?:export\\s+)?class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Constructor DI",
      "pattern": "constructor\\s*\\(([^)]+)\\)",
      "captureGroup": 1,
      "kind": 8,
      "type": "constructor"
    },
    {
      "name": "ngOnInit",
      "pattern": "(ngOnInit)\\s*\\(\\s*\\)",
      "captureGroup": 1,
      "kind": 5,
      "type": "lifecycle-hook"
    },
    {
      "name": "ngOnDestroy",
      "pattern": "(ngOnDestroy)\\s*\\(\\s*\\)",
      "captureGroup": 1,
      "kind": 5,
      "type": "lifecycle-hook"
    },
    {
      "name": "ngOnChanges",
      "pattern": "(ngOnChanges)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "lifecycle-hook"
    },
    {
      "name": "ngAfterViewInit",
      "pattern": "(ngAfterViewInit)\\s*\\(\\s*\\)",
      "captureGroup": 1,
      "kind": 5,
      "type": "lifecycle-hook"
    },
    {
      "name": "ngAfterContentInit",
      "pattern": "(ngAfterContentInit)\\s*\\(\\s*\\)",
      "captureGroup": 1,
      "kind": 5,
      "type": "lifecycle-hook"
    },
    {
      "name": "Template Reference",
      "pattern": "#(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "template-ref"
    },
    {
      "name": "EventEmitter",
      "pattern": "(\\w+)\\s*=\\s*new\\s+EventEmitter",
      "captureGroup": 1,
      "kind": 6,
      "type": "event-emitter"
    },
    {
      "name": "BehaviorSubject",
      "pattern": "(\\w+)\\s*=\\s*new\\s+BehaviorSubject",
      "captureGroup": 1,
      "kind": 12,
      "type": "behavior-subject"
    },
    {
      "name": "Observable",
      "pattern": "(\\w+)\\$\\s*(?::|=)\\s*(?:Observable|this\\.\\w+\\.pipe|combineLatest|merge|forkJoin)",
      "captureGroup": 1,
      "kind": 12,
      "type": "observable"
    },
    {
      "name": "Route Definition",
      "pattern": "(?:const|let)\\s+(\\w*[Rr]outes?)\\s*:\\s*Routes",
      "captureGroup": 1,
      "kind": 12,
      "type": "route-config"
    },
    {
      "name": "Reactive FormGroup",
      "pattern": "(\\w+)\\s*=\\s*(?:new\\s+FormGroup|this\\.\\w+\\.group)\\s*\\(",
      "captureGroup": 1,
      "kind": 12,
      "type": "form-group"
    },
    {
      "name": "Module Imports Array",
      "pattern": "imports\\s*:\\s*\\[([^\\]]+)\\]",
      "captureGroup": 1,
      "kind": 19,
      "type": "module-imports"
    },
    {
      "name": "Module Declarations Array",
      "pattern": "declarations\\s*:\\s*\\[([^\\]]+)\\]",
      "captureGroup": 1,
      "kind": 19,
      "type": "module-declarations"
    },
    {
      "name": "Module Providers Array",
      "pattern": "providers\\s*:\\s*\\[([^\\]]+)\\]",
      "captureGroup": 1,
      "kind": 19,
      "type": "module-providers"
    },
    {
      "name": "Signal",
      "pattern": "(?:readonly\\s+)?(\\w+)\\s*=\\s*signal\\s*[<(]",
      "captureGroup": 1,
      "kind": 12,
      "type": "signal"
    },
    {
      "name": "Computed",
      "pattern": "(?:readonly\\s+)?(\\w+)\\s*=\\s*computed\\s*\\(",
      "captureGroup": 1,
      "kind": 12,
      "type": "computed"
    },
    {
      "name": "Signal Input",
      "pattern": "(?:readonly\\s+)?(\\w+)\\s*=\\s*input(?:\\.required)?\\s*[<(]",
      "captureGroup": 1,
      "kind": 6,
      "type": "signal-input"
    },
    {
      "name": "Signal Output",
      "pattern": "(?:readonly\\s+)?(\\w+)\\s*=\\s*output\\s*[<(]",
      "captureGroup": 1,
      "kind": 6,
      "type": "signal-output"
    }
  ]
}
