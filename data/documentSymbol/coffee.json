{
  "language": "coffee",
  "symbolPatterns": [
    {
      "name": "Class",
      "pattern": "^\\s*class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "ClassExtends",
      "pattern": "^\\s*class\\s+(\\w+)\\s+extends\\s+\\w+",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Constructor",
      "pattern": "^\\s+constructor\\s*:",
      "captureGroup": 0,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Method",
      "pattern": "^\\s+(\\w+)\\s*:\\s*(?:\\(.*\\))?\\s*->",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "BoundMethod",
      "pattern": "^\\s+(\\w+)\\s*:\\s*(?:\\(.*\\))?\\s*=>",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Function",
      "pattern": "^(\\w+)\\s*=\\s*(?:\\(.*\\))?\\s*->",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "BoundFunction",
      "pattern": "^(\\w+)\\s*=\\s*(?:\\(.*\\))?\\s*=>",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "PropertyAccess",
      "pattern": "^\\s+@(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "InstanceProperty",
      "pattern": "^\\s+@(\\w+)\\s*:\\s*",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "DestructuringAssignment",
      "pattern": "^\\s*\\{([\\w,\\s]+)\\}\\s*=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "ArrayDestructuring",
      "pattern": "^\\s*\\[([\\w,\\s]+)\\]\\s*=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Variable",
      "pattern": "^(\\w+)\\s*=\\s*(?!.*[-=]>)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Constant",
      "pattern": "^([A-Z][A-Z_0-9]+)\\s*=",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "SplatParam",
      "pattern": "(?:\\(|,\\s*)(\\w+)\\.\\.\\.",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "ModuleExport",
      "pattern": "^module\\.exports\\s*=\\s*(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "NamedExport",
      "pattern": "^exports\\.(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Require",
      "pattern": "(\\w+)\\s*=\\s*require\\s+['\"]([\\w\\-\\./]+)['\"]",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Comprehension",
      "pattern": "(\\w+)\\s*=\\s*(?:for\\s+\\w+\\s+in\\b|\\(.*\\s+for\\s+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "CallbackDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(function|=>|->)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "GenericTypeDeclaration",
      "pattern": "\\\\b(\\\\w+)<[^>]+>",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "ClosureDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(\\\\(|\\\\|)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "TestDeclaration",
      "pattern": "\\\\b(?:test|it|describe|spec)\\\\s*\\\\(?['\"]([^'\"]+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    }
  ]
}
