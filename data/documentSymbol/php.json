{
  "language": "php",
  "symbolPatterns": [
    {
      "name": "Class",
      "pattern": "^\\s*(?:(?:abstract|final|readonly)\\s+)*class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Interface",
      "pattern": "^\\s*interface\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Trait",
      "pattern": "^\\s*trait\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Enum",
      "pattern": "^\\s*enum\\s+(\\w+)(?:\\s*:\\s*\\w+)?(?:\\s+implements)?",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Namespace",
      "pattern": "^\\s*namespace\\s+([\\w\\\\]+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Function",
      "pattern": "^\\s*function\\s+(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Method",
      "pattern": "^\\s*(?:(?:public|private|protected|static|abstract|final)\\s+)+function\\s+(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Constructor",
      "pattern": "^\\s*(?:(?:public|private|protected)\\s+)?function\\s+(__construct)\\s*\\(",
      "captureGroup": 1,
      "kind": 8,
      "type": "constructor"
    },
    {
      "name": "Destructor",
      "pattern": "^\\s*(?:(?:public|private|protected)\\s+)?function\\s+(__destruct)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "TypedProperty",
      "pattern": "^\\s*(?:(?:public|private|protected|static|readonly)\\s+)+(?:\\?)?[\\w\\\\|]+\\s+\\$(\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "PromotedConstructorParam",
      "pattern": "\\b(?:public|private|protected|readonly)\\s+(?:(?:\\?)?[\\w\\\\|]+\\s+)?\\$(\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "ClassConstant",
      "pattern": "^\\s*(?:(?:public|private|protected)\\s+)?const\\s+(\\w+)\\s*=",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "DefineConstant",
      "pattern": "\\bdefine\\s*\\(\\s*['\"]([^'\"]+)['\"]",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "UseNamespace",
      "pattern": "^\\s*use\\s+([\\w\\\\]+)(?:\\s+as\\s+\\w+)?\\s*;",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "UseTrait",
      "pattern": "^\\s*use\\s+(\\w+(?:\\s*,\\s*\\w+)*)\\s*[;{]",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "ArrowFunction",
      "pattern": "\\$(\\w+)\\s*=\\s*fn\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "ClosureAssignment",
      "pattern": "\\$(\\w+)\\s*=\\s*function\\s*\\(",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "AnonymousClass",
      "pattern": "\\$?(\\w+)\\s*=\\s*new\\s+class(?:\\s*\\([^)]*\\))?\\s*(?:extends|implements|\\{)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Attribute",
      "pattern": "^\\s*#\\[([\\w\\\\]+)(?:\\([^)]*\\))?\\]",
      "captureGroup": 1,
      "kind": 18,
      "type": "object"
    },
    {
      "name": "GlobalVariable",
      "pattern": "^\\s*global\\s+\\$(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "MatchExpression",
      "pattern": "\\$(\\w+)\\s*=\\s*match\\s*\\(",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "EnumCase",
      "pattern": "^\\s*case\\s+(\\w+)(?:\\s*=)?",
      "captureGroup": 1,
      "kind": 21,
      "type": "enumMember"
    },
    {
      "name": "NamedArgument",
      "pattern": "(\\w+):\\s*(?:\\$|['\"]|\\d|\\[|true|false|null|new\\b)",
      "captureGroup": 1,
      "kind": 19,
      "type": "key"
    }
  ]
}
