{
  "language": "php",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\\\s*(?:public|private|protected|static)?\\\\s*function\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Class",
      "pattern": "^\\\\s*(?:abstract|final)?\\\\s*class\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Interface",
      "pattern": "^\\\\s*interface\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Trait",
      "pattern": "^\\\\s*trait\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Enum",
      "pattern": "^\\\\s*enum\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Namespace",
      "pattern": "^\\\\s*namespace\\\\s+([\\\\w\\\\\\\\]+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "module"
    }
  ]
}
