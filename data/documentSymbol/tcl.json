{
  "language": "tcl",
  "symbolPatterns": [
    {
      "name": "Proc",
      "pattern": "^\\s*proc\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Namespace",
      "pattern": "^\\s*namespace\\s+eval\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Variable",
      "pattern": "^\\s*(?:set|variable)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    }
  ]
}