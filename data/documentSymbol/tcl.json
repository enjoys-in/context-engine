{
  "language": "tcl",
  "symbolPatterns": [
    {
      "name": "Proc",
      "pattern": "^\\s*proc\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Namespace",
      "pattern": "^\\s*namespace\\s+eval\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Variable",
      "pattern": "^\\s*variable\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Set",
      "pattern": "^\\s*set\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Array",
      "pattern": "^\\s*array\\s+set\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "PackageProvide",
      "pattern": "^\\s*package\\s+provide\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "PackageRequire",
      "pattern": "^\\s*package\\s+require\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Source",
      "pattern": "^\\s*source\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "OOClass",
      "pattern": "^\\s*oo::class\\s+create\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "OOMethod",
      "pattern": "^\\s*method\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Constructor",
      "pattern": "^\\s*constructor\\s*(\\{[^}]*\\})",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "ItclClass",
      "pattern": "^\\s*(?:itcl::)?class\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "SnitType",
      "pattern": "^\\s*snit::type\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Coroutine",
      "pattern": "^\\s*coroutine\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    }
  ]
}
