{
  "language": "apex",
  "symbolPatterns": [
    {
      "name": "Class",
      "pattern": "^\\s*(?:(?:public|private|global|protected)\\s+)?(?:(?:virtual|abstract|with\\s+sharing|without\\s+sharing)\\s+)?class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Interface",
      "pattern": "^\\s*(?:(?:public|global)\\s+)?interface\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Enum",
      "pattern": "^\\s*(?:(?:public|private|global)\\s+)?enum\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Trigger",
      "pattern": "^\\s*trigger\\s+(\\w+)\\s+on\\s+\\w+",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Method",
      "pattern": "^\\s*(?:(?:public|private|protected|global)\\s+)?(?:static\\s+)?(?:override\\s+)?(?:virtual\\s+)?(?:\\w+(?:<[^>]+>)?(?:\\[\\])?)\\s+(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Constructor",
      "pattern": "^\\s*(?:(?:public|private|protected|global)\\s+)(\\w+)\\s*\\([^)]*\\)\\s*\\{",
      "captureGroup": 1,
      "kind": 8,
      "type": "constructor"
    },
    {
      "name": "Property",
      "pattern": "^\\s*(?:(?:public|private|protected|global)\\s+)?(?:static\\s+)?(?:\\w+(?:<[^>]+>)?(?:\\[\\])?)\\s+(\\w+)\\s*\\{\\s*(?:get|set)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "SOQL Query",
      "pattern": "\\[\\s*SELECT\\s+.+?\\s+FROM\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "DML Insert",
      "pattern": "^\\s*insert\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "DML Update",
      "pattern": "^\\s*update\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "DML Delete",
      "pattern": "^\\s*delete\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "DML Upsert",
      "pattern": "^\\s*upsert\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Annotation",
      "pattern": "^\\s*@(\\w+)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Test Method",
      "pattern": "@[Ii]s[Tt]est\\s+(?:(?:public|private|protected|global|static)\\s+)*(?:\\w+\\s+)?(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Batch Class",
      "pattern": "class\\s+(\\w+)\\s+implements\\s+Database\\.Batchable",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Future Method",
      "pattern": "@[Ff]uture[^\\n]*\\s+(?:(?:public|private|protected|global|static)\\s+)*(?:\\w+\\s+)?(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Queueable Class",
      "pattern": "class\\s+(\\w+)\\s+implements\\s+Queueable",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "AuraEnabled Method",
      "pattern": "@[Aa]ura[Ee]nabled[^\\n]*\\s+(?:(?:public|private|protected|global|static)\\s+)*(?:\\w+\\s+)?(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "WebService Method",
      "pattern": "(?:webService|webservice)\\s+(?:static\\s+)?(?:\\w+\\s+)?(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "CallbackDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(function|=>|->)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "GenericTypeDeclaration",
      "pattern": "\\\\b(\\\\w+)<[^>]+>",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "ClosureDeclaration",
      "pattern": "\\\\b(\\\\w+)\\\\s*=\\\\s*(\\\\(|\\\\|)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    }
  ]
}
