{
  "language": "apex",
  "symbolPatterns": [
    {
      "name": "Class",
      "pattern": "^\\s*(?:public|private|global|protected)?\\s*(?:virtual|abstract|with sharing|without sharing)?\\s*class\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Interface",
      "pattern": "^\\s*(?:public|global)\\s+interface\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Method",
      "pattern": "^\\s*(?:public|private|protected|global|static|override|virtual|abstract|testMethod)?\\s*(?:static)?\\s*(?:\\w+)\\s+(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Trigger",
      "pattern": "^\\s*trigger\\s+(\\w+)\\s+on",
      "captureGroup": 1,
      "kind": 23,
      "type": "event"
    },
    {
      "name": "Enum",
      "pattern": "^\\s*(?:public|private|global)?\\s*enum\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Function",
      "pattern": "(?:function|def|fn|func|sub|proc)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Variable",
      "pattern": "(?:var|let|const|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Module",
      "pattern": "(?:module|namespace|package|import)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
