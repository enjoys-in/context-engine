{
  "language": "powershell",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\\\s*function\\\\s+(\\\\w[\\\\w-]*)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Class",
      "pattern": "^\\\\s*class\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Enum",
      "pattern": "^\\\\s*enum\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Variable",
      "pattern": "^\\\\s*\\\\$(\\\\w+)\\\\s*=",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    }
  ]
}