{
  "language": "rust",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\\\s*(?:pub\\\\s+)?(?:async\\\\s+)?fn\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Struct",
      "pattern": "^\\\\s*(?:pub\\\\s+)?struct\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Enum",
      "pattern": "^\\\\s*(?:pub\\\\s+)?enum\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Trait",
      "pattern": "^\\\\s*(?:pub\\\\s+)?(?:unsafe\\\\s+)?trait\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Impl",
      "pattern": "^\\\\s*impl(?:<[^>]*>)?\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Type Alias",
      "pattern": "^\\\\s*(?:pub\\\\s+)?type\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Module",
      "pattern": "^\\\\s*(?:pub\\\\s+)?mod\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Const",
      "pattern": "^\\\\s*(?:pub\\\\s+)?const\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Static",
      "pattern": "^\\\\s*(?:pub\\\\s+)?static\\\\s+(?:mut\\\\s+)?(\\\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    }
  ]
}
