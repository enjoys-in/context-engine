{
  "language": "rust",
  "symbolPatterns": [
    {
      "name": "Function",
      "pattern": "^\\\\s*(?:pub(?:\\\\s*\\\\([^)]*\\\\))?\\\\s+)?fn\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Async Function",
      "pattern": "^\\\\s*(?:pub(?:\\\\s*\\\\([^)]*\\\\))?\\\\s+)?async\\\\s+fn\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Unsafe Function",
      "pattern": "^\\\\s*(?:pub(?:\\\\s*\\\\([^)]*\\\\))?\\\\s+)?unsafe\\\\s+fn\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Const Function",
      "pattern": "^\\\\s*(?:pub(?:\\\\s*\\\\([^)]*\\\\))?\\\\s+)?const\\\\s+fn\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Extern Function",
      "pattern": "^\\\\s*(?:pub(?:\\\\s*\\\\([^)]*\\\\))?\\\\s+)?(?:unsafe\\\\s+)?extern\\\\s+\"[^\"]*\"\\\\s+fn\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Struct",
      "pattern": "^\\\\s*(?:pub(?:\\\\s*\\\\([^)]*\\\\))?\\\\s+)?struct\\\\s+(\\\\w+)\\\\s*(?:<[^>]*>)?\\\\s*\\\\{",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Tuple Struct",
      "pattern": "^\\\\s*(?:pub(?:\\\\s*\\\\([^)]*\\\\))?\\\\s+)?struct\\\\s+(\\\\w+)\\\\s*(?:<[^>]*>)?\\\\s*\\\\(",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Enum",
      "pattern": "^\\\\s*(?:pub(?:\\\\s*\\\\([^)]*\\\\))?\\\\s+)?enum\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Enum Variant",
      "pattern": "^\\\\s+(\\\\w+)(?:\\\\s*\\\\{|\\\\s*\\\\(|\\\\s*=|\\\\s*,|\\\\s*$)",
      "captureGroup": 1,
      "kind": 21,
      "type": "enumMember"
    },
    {
      "name": "Trait",
      "pattern": "^\\\\s*(?:pub(?:\\\\s*\\\\([^)]*\\\\))?\\\\s+)?(?:unsafe\\\\s+)?trait\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 10,
      "type": "interface"
    },
    {
      "name": "Impl Block",
      "pattern": "^\\\\s*(?:unsafe\\\\s+)?impl(?:<[^>]*>)?\\\\s+(?:(\\\\w+)(?:<[^>]*>)?\\\\s+for\\\\s+)?(\\\\w+)",
      "captureGroup": 2,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Type Alias",
      "pattern": "^\\\\s*(?:pub(?:\\\\s*\\\\([^)]*\\\\))?\\\\s+)?type\\\\s+(\\\\w+)(?:<[^>]*>)?\\\\s*=",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Module",
      "pattern": "^\\\\s*(?:pub(?:\\\\s*\\\\([^)]*\\\\))?\\\\s+)?mod\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Const",
      "pattern": "^\\\\s*(?:pub(?:\\\\s*\\\\([^)]*\\\\))?\\\\s+)?const\\\\s+(\\\\w+)\\\\s*:",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Static",
      "pattern": "^\\\\s*(?:pub(?:\\\\s*\\\\([^)]*\\\\))?\\\\s+)?static\\\\s+(\\\\w+)\\\\s*:",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Static Mut",
      "pattern": "^\\\\s*(?:pub(?:\\\\s*\\\\([^)]*\\\\))?\\\\s+)?static\\\\s+mut\\\\s+(\\\\w+)\\\\s*:",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Macro Definition",
      "pattern": "^\\\\s*(?:#\\\\[macro_export\\\\]\\\\s*)?macro_rules!\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Union",
      "pattern": "^\\\\s*(?:pub(?:\\\\s*\\\\([^)]*\\\\))?\\\\s+)?union\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Extern Crate",
      "pattern": "^\\\\s*extern\\\\s+crate\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Use Statement",
      "pattern": "^\\\\s*(?:pub(?:\\\\s*\\\\([^)]*\\\\))?\\\\s+)?use\\\\s+([\\\\w:]+(?:::\\\\{[^}]*\\\\})?)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Struct Field",
      "pattern": "^\\\\s+(?:pub(?:\\\\s*\\\\([^)]*\\\\))?\\\\s+)?(\\\\w+)\\\\s*:\\\\s*[^:=]",
      "captureGroup": 1,
      "kind": 7,
      "type": "field"
    },
    {
      "name": "Associated Type",
      "pattern": "^\\\\s+type\\\\s+(\\\\w+)(?:\\\\s*=|\\\\s*;|\\\\s*:)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    }
  ]
}
