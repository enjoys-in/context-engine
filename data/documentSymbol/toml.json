{
  "language": "toml",
  "symbolPatterns": [
    {
      "name": "Table",
      "pattern": "^\\\\s*\\\\[([^\\\\[\\\\]]+)\\\\]\\\\s*$",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Array of Tables",
      "pattern": "^\\\\s*\\\\[\\\\[([^\\\\[\\\\]]+)\\\\]\\\\]\\\\s*$",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Key-Value Pair",
      "pattern": "^\\\\s*([\\\\w-]+)\\\\s*=\\\\s*",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Dotted Key",
      "pattern": "^\\\\s*([\\\\w-]+(?:\\\\.[\\\\w-]+)+)\\\\s*=\\\\s*",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Inline Table",
      "pattern": "^\\\\s*([\\\\w.-]+)\\\\s*=\\\\s*\\\\{",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Array Value",
      "pattern": "^\\\\s*([\\\\w.-]+)\\\\s*=\\\\s*\\\\[",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Multi-line String",
      "pattern": "^\\\\s*([\\\\w.-]+)\\\\s*=\\\\s*\"\"\"",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Datetime Value",
      "pattern": "^\\\\s*([\\\\w.-]+)\\\\s*=\\\\s*\\\\d{4}-\\\\d{2}-\\\\d{2}",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    }
  ]
}
