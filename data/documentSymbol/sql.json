{
  "language": "sql",
  "symbolPatterns": [
    {
      "name": "Table",
      "pattern": "^\\\\s*CREATE\\\\s+TABLE\\\\s+(?:IF\\\\s+NOT\\\\s+EXISTS\\\\s+)?(\\\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "View",
      "pattern": "^\\\\s*CREATE\\\\s+(?:OR\\\\s+REPLACE\\\\s+)?VIEW\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "Function",
      "pattern": "^\\\\s*CREATE\\\\s+(?:OR\\\\s+REPLACE\\\\s+)?FUNCTION\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Procedure",
      "pattern": "^\\\\s*CREATE\\\\s+(?:OR\\\\s+REPLACE\\\\s+)?PROCEDURE\\\\s+(\\\\w+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Index",
      "pattern": "^\\\\s*CREATE\\\\s+(?:UNIQUE\\\\s+)?INDEX\\\\s+(?:IF\\\\s+NOT\\\\s+EXISTS\\\\s+)?(\\\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    },
    {
      "name": "Enum",
      "pattern": "(?:enum)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "type": "enum"
    },
    {
      "name": "Module",
      "pattern": "(?:module|namespace|package|import)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Property",
      "pattern": "(\\w+)\\s*[=:]",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Method",
      "pattern": "(?:public|private|protected)?\\s*(?:static)?\\s*(\\w+)\\s*\\(",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    }
  ]
}
