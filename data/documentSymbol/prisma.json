{
  "language": "prisma",
  "symbolPatterns": [
    {
      "name": "Model Declaration",
      "pattern": "^\\s*model\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "detail": "model"
    },
    {
      "name": "Enum Declaration",
      "pattern": "^\\s*enum\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 9,
      "detail": "enum"
    },
    {
      "name": "Datasource Block",
      "pattern": "^\\s*datasource\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "detail": "datasource"
    },
    {
      "name": "Generator Block",
      "pattern": "^\\s*generator\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 1,
      "detail": "generator"
    },
    {
      "name": "Composite Type",
      "pattern": "^\\s*type\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 22,
      "detail": "type"
    },
    {
      "name": "View Declaration",
      "pattern": "^\\s*view\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 4,
      "detail": "view"
    },
    {
      "name": "Field Declaration",
      "pattern": "^\\s+(\\w+)\\s+(String|Int|BigInt|Float|Decimal|Boolean|DateTime|Json|Bytes|\\w+)(\\?|\\[\\])?",
      "captureGroup": 1,
      "kind": 7,
      "detail": "field"
    },
    {
      "name": "Enum Value",
      "pattern": "^\\s+([A-Z][A-Z0-9_]+)\\s*$",
      "captureGroup": 1,
      "kind": 21,
      "detail": "enum value"
    }
  ]
}