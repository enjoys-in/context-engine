{
  "language": "scheme",
  "symbolPatterns": [
    {
      "name": "DefineFunction",
      "pattern": "^\\s*\\(define\\s+\\((\\w[\\w\\-\\!\\?\\*\\+<>=]*)\\s",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "DefineVariable",
      "pattern": "^\\s*\\(define\\s+(\\w[\\w\\-\\!\\?\\*\\+<>=]*)\\s+(?!\\(lambda|\\()",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "DefineLambda",
      "pattern": "^\\s*\\(define\\s+(\\w[\\w\\-\\!\\?\\*\\+<>=]*)\\s+\\(lambda\\b",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "DefineSyntax",
      "pattern": "^\\s*\\(define-syntax\\s+(\\w[\\w\\-\\!\\?\\*\\+<>=]*)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "SyntaxRules",
      "pattern": "\\(syntax-rules\\s+\\(([^)]*)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "DefineRecordType",
      "pattern": "^\\s*\\(define-record-type\\s+(\\w[\\w\\-\\!\\?\\*\\+<>=]*)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "DefineValues",
      "pattern": "^\\s*\\(define-values\\s+\\((\\w[\\w\\-\\!\\?\\*\\+<>=]*)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Lambda",
      "pattern": "\\(lambda\\s+\\((\\w[\\w\\-\\!\\?\\*]*)?",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "Let",
      "pattern": "\\(let\\*?\\s+(?:(\\w[\\w\\-]*)\\s+)?\\(\\(",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Letrec",
      "pattern": "\\(letrec\\s+\\(\\((\\w[\\w\\-\\!\\?\\*]*)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Module",
      "pattern": "^\\s*\\(module\\s+(\\w[\\w\\-\\!\\?\\*]*)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Library",
      "pattern": "^\\s*\\((?:define-library|library)\\s+\\(([^)]+)\\)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Import",
      "pattern": "\\(import\\s+\\(([\\w\\-\\s]+)\\)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Export",
      "pattern": "\\(export\\s+(\\w[\\w\\-\\!\\?\\*]*)",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "CondExpand",
      "pattern": "\\(cond-expand\\s+\\((\\w[\\w\\-]*)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Begin",
      "pattern": "^\\s*\\(begin\\b",
      "captureGroup": 0,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Values",
      "pattern": "\\(values\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "CallCC",
      "pattern": "\\(call-with-current-continuation\\s+(\\w[\\w\\-\\!\\?\\*]*)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    }
  ]
}
