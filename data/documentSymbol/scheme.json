{
  "language": "scheme",
  "symbolPatterns": [
    {
      "name": "Define",
      "pattern": "^\\s*\\(define\\s+\\(?(\\S+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "DefineVar",
      "pattern": "^\\s*\\(define\\s+(\\S+)\\s+(?!\\()",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Library",
      "pattern": "^\\s*\\(define-library\\s+\\(([^)]+)\\)",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    }
  ]
}