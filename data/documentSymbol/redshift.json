{
  "language": "redshift",
  "symbolPatterns": [
    {
      "name": "CreateTable",
      "pattern": "CREATE\\s+TABLE\\s+(?:IF\\s+NOT\\s+EXISTS\\s+)?([\\w.]+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "CreateView",
      "pattern": "CREATE\\s+(?:OR\\s+REPLACE\\s+)?VIEW\\s+([\\w.]+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "CreateIndex",
      "pattern": "CREATE\\s+(?:UNIQUE\\s+)?INDEX\\s+([\\w.]+)",
      "captureGroup": 1,
      "kind": 19,
      "type": "key"
    },
    {
      "name": "CreateProcedure",
      "pattern": "CREATE\\s+(?:OR\\s+REPLACE\\s+)?PROCEDURE\\s+([\\w.]+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "CreateFunction",
      "pattern": "CREATE\\s+(?:OR\\s+REPLACE\\s+)?FUNCTION\\s+([\\w.]+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "CreateTrigger",
      "pattern": "CREATE\\s+(?:OR\\s+REPLACE\\s+)?TRIGGER\\s+([\\w.]+)",
      "captureGroup": 1,
      "kind": 11,
      "type": "function"
    },
    {
      "name": "AlterTable",
      "pattern": "ALTER\\s+TABLE\\s+([\\w.]+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "DropTable",
      "pattern": "DROP\\s+TABLE\\s+(?:IF\\s+EXISTS\\s+)?([\\w.]+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "SelectAlias",
      "pattern": "\\)\\s+AS\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "InsertInto",
      "pattern": "INSERT\\s+INTO\\s+([\\w.]+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Update",
      "pattern": "UPDATE\\s+([\\w.]+)\\s+SET\\b",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "DeleteFrom",
      "pattern": "DELETE\\s+FROM\\s+([\\w.]+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "CTE",
      "pattern": "(?:WITH|,)\\s+(?:RECURSIVE\\s+)?(\\w+)\\s+AS\\s*\\(",
      "captureGroup": 1,
      "kind": 22,
      "type": "struct"
    },
    {
      "name": "Grant",
      "pattern": "GRANT\\s+[\\w,\\s]+ON\\s+(?:TABLE\\s+|SCHEMA\\s+)?([\\w.]+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Revoke",
      "pattern": "REVOKE\\s+[\\w,\\s]+ON\\s+(?:TABLE\\s+|SCHEMA\\s+)?([\\w.]+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "DeclareVariable",
      "pattern": "DECLARE\\s+(\\w+)\\s+\\w+",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "CreateSchema",
      "pattern": "CREATE\\s+SCHEMA\\s+(?:IF\\s+NOT\\s+EXISTS\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Constraint",
      "pattern": "CONSTRAINT\\s+(\\w+)\\s+(?:PRIMARY|FOREIGN|UNIQUE|CHECK|DEFAULT)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "CreateExternalTable",
      "pattern": "CREATE\\s+EXTERNAL\\s+TABLE\\s+(?:IF\\s+NOT\\s+EXISTS\\s+)?([\\w.]+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "CreateExternalSchema",
      "pattern": "CREATE\\s+EXTERNAL\\s+SCHEMA\\s+(?:IF\\s+NOT\\s+EXISTS\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    },
    {
      "name": "Copy",
      "pattern": "COPY\\s+([\\w.]+)\\s+(?:FROM|TO)\\b",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Unload",
      "pattern": "UNLOAD\\s*\\(\\s*'([^']*)'",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Distkey",
      "pattern": "DISTKEY\\s*\\(\\s*(\\w+)\\s*\\)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Sortkey",
      "pattern": "(?:COMPOUND\\s+|INTERLEAVED\\s+)?SORTKEY\\s*\\(\\s*([\\w,\\s]+?)\\s*\\)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Diststyle",
      "pattern": "DISTSTYLE\\s+(ALL|EVEN|KEY|AUTO)",
      "captureGroup": 1,
      "kind": 6,
      "type": "property"
    },
    {
      "name": "Vacuum",
      "pattern": "VACUUM\\s+(?:FULL\\s+|SORT\\s+ONLY\\s+|DELETE\\s+ONLY\\s+|REINDEX\\s+)?([\\w.]+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "Analyze",
      "pattern": "ANALYZE\\s+(?:VERBOSE\\s+)?([\\w.]+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "method"
    },
    {
      "name": "CreateLibrary",
      "pattern": "CREATE\\s+(?:OR\\s+REPLACE\\s+)?LIBRARY\\s+(\\w+)\\s+LANGUAGE",
      "captureGroup": 1,
      "kind": 1,
      "type": "module"
    },
    {
      "name": "Spectrum",
      "pattern": "CREATE\\s+EXTERNAL\\s+SCHEMA\\s+(\\w+)\\s+FROM\\s+(?:DATA\\s+CATALOG|HIVE\\s+METASTORE|SPECTRUM)",
      "captureGroup": 1,
      "kind": 2,
      "type": "namespace"
    }
  ]
}
