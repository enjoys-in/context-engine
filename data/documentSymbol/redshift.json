{
  "language": "redshift",
  "symbolPatterns": [
    {
      "name": "Table",
      "pattern": "CREATE\\s+TABLE\\s+(?:IF\\s+NOT\\s+EXISTS\\s+)?(\\S+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "View",
      "pattern": "CREATE\\s+VIEW\\s+(\\S+)",
      "captureGroup": 1,
      "kind": 4,
      "type": "class"
    },
    {
      "name": "table",
      "pattern": "(?:CREATE|ALTER)\\s+TABLE\\s+(?:IF\\s+NOT\\s+EXISTS\\s+)?([\\w.]+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "table"
    },
    {
      "name": "view",
      "pattern": "CREATE\\s+(?:OR\\s+REPLACE\\s+)?VIEW\\s+([\\w.]+)",
      "captureGroup": 1,
      "kind": 5,
      "type": "view"
    },
    {
      "name": "function",
      "pattern": "CREATE\\s+(?:OR\\s+REPLACE\\s+)?FUNCTION\\s+([\\w.]+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "function"
    },
    {
      "name": "procedure",
      "pattern": "CREATE\\s+(?:OR\\s+REPLACE\\s+)?PROCEDURE\\s+([\\w.]+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "procedure"
    },
    {
      "name": "index",
      "pattern": "CREATE\\s+(?:UNIQUE\\s+)?INDEX\\s+([\\w.]+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "index"
    },
    {
      "name": "trigger",
      "pattern": "CREATE\\s+TRIGGER\\s+([\\w.]+)",
      "captureGroup": 1,
      "kind": 24,
      "type": "trigger"
    },
    {
      "name": "Variable",
      "pattern": "(?:var|let|const|dim|my|local)\\s+(\\w+)",
      "captureGroup": 1,
      "kind": 12,
      "type": "variable"
    },
    {
      "name": "Constant",
      "pattern": "(?:CONST|const|final|readonly)\\s+(?:\\w+\\s+)?(\\w+)",
      "captureGroup": 1,
      "kind": 13,
      "type": "constant"
    }
  ]
}
