{
  "language": "python",
  "formatting": {
    "defaultTabSize": 4,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\\\s+$",
        "replacement": ""
      },
      {
        "description": "Ensure single space after keywords",
        "pattern": "\\\\b(if|elif|else|for|while|with|try|except|finally)\\\\(",
        "replacement": "$1 ("
      },
      {
        "description": "Normalize line endings",
        "pattern": "\\\\r\\\\n",
        "replacement": "\\n"
      }
    ],
    "indentation": {
      "increasePattern": ":\\\\s*$",
      "decreasePattern": "^\\\\s*(?:pass|return|break|continue|raise)\\\\b"
    }
  }
}
