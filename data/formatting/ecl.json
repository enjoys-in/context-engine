{
  "language": "ecl",
  "formatting": {
    "defaultTabSize": 2,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      },
      {
        "description": "Normalize line endings",
        "pattern": "\\r\\n",
        "replacement": "\\n"
      },
      {
        "description": "Uppercase keywords",
        "pattern": "\\b(output|record|transform|dataset)\\b",
        "replacement": "$1"
      },
      {
        "description": "Normalize line endings to LF",
        "pattern": "\\r\\n",
        "replacement": "\\n"
      },
      {
        "description": "Ensure newline at end of file",
        "pattern": "(?<!\\n)$",
        "replacement": "\\n"
      },
      {
        "description": "Remove consecutive blank lines",
        "pattern": "\\n{3,}",
        "replacement": "\\n\\n"
      },
      {
        "description": "Trim trailing blank lines",
        "pattern": "\\n+$",
        "replacement": "\\n"
      }
    ],
    "indentation": {
      "increasePattern": "\\bBEGIN\\b|:=\\s*$",
      "decreasePattern": "\\bEND\\b|;\\s*$"
    }
  }
}
