{
  "language": "ruby",
  "formatting": {
    "defaultTabSize": 2,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      },
      {
        "description": "Ensure single space after keywords",
        "pattern": "\\b(if|else|elsif|unless|while|until|for|case|when|begin|rescue|ensure)\\(",
        "replacement": "$1 ("
      },
      {
        "description": "Normalize line endings",
        "pattern": "\\r\\n",
        "replacement": "\\n"
      },
      {
        "description": "Normalize line endings to LF",
        "pattern": "\\r\\n",
        "replacement": "\\n"
      },
      {
        "description": "Ensure newline at end of file",
        "pattern": "(?<!\\n)$",
        "replacement": "\\n"
      },
      {
        "description": "Remove consecutive blank lines",
        "pattern": "\\n{3,}",
        "replacement": "\\n\\n"
      },
      {
        "description": "Trim trailing blank lines",
        "pattern": "\\n+$",
        "replacement": "\\n"
      },
      {
        "description": "Normalize trailing whitespace",
        "pattern": "\\\\s+$",
        "replacement": ""
      },
      {
        "description": "Ensure single space after comma",
        "pattern": ",([^\\\\s])",
        "replacement": ", $1"
      },
      {
        "description": "Remove trailing semicolons in blank lines",
        "pattern": "^\\\\s*;\\\\s*$",
        "replacement": ""
      },
      {
        "description": "Normalize multiple blank lines to single",
        "pattern": "\\\\n{3,}",
        "replacement": "\\n\\n"
      },
      {
        "description": "Ensure space around assignment operator",
        "pattern": "(\\\\w)=(\\\\w)",
        "replacement": "$1 = $2"
      },
      {
        "description": "Ensure space after opening brace",
        "pattern": "\\\\{([^\\\\s})\\\\n])",
        "replacement": "{ $1"
      },
      {
        "description": "Ensure space before closing brace",
        "pattern": "([^\\\\s{\\\\n])\\\\}",
        "replacement": "$1 }"
      },
      {
        "description": "Remove space before semicolon",
        "pattern": "\\\\s+;",
        "replacement": ";"
      },
      {
        "description": "Normalize space around colon in declarations",
        "pattern": "(\\\\w)\\\\s*:\\\\s*(\\\\w)",
        "replacement": "$1: $2"
      },
      {
        "description": "Remove space inside parentheses",
        "pattern": "\\\\(\\\\s+",
        "replacement": "("
      },
      {
        "description": "Remove space before closing parenthesis",
        "pattern": "\\\\s+\\\\)",
        "replacement": ")"
      },
      {
        "description": "Ruby-specific brace alignment",
        "pattern": "\\\\n\\\\s*\\\\{",
        "replacement": " {"
      },
      {
        "description": "Normalize Ruby statement terminators",
        "pattern": "\\\\s+$",
        "replacement": ""
      }
    ],
    "indentation": {
      "increasePattern": "(?:do|\\{|\\bdef\\b|\\bclass\\b|\\bmodule\\b|\\bif\\b|\\bunless\\b|\\bwhile\\b|\\buntil\\b|\\bfor\\b|\\bbegin\\b|\\bcase\\b)\\s*$",
      "decreasePattern": "^\\s*(?:end|else|elsif|when|rescue|ensure|\\})\\b"
    }
  }
}
