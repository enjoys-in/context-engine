{
  "language": "less",
  "formatting": {
    "defaultTabSize": 2,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      },
      {
        "description": "Normalize line endings",
        "pattern": "\\r\\n",
        "replacement": "\\n"
      },
      {
        "description": "Opening brace on same line as selector",
        "pattern": "\\{$",
        "replacement": ""
      },
      {
        "description": "Closing brace dedent",
        "pattern": "^\\s*\\}",
        "replacement": ""
      },
      {
        "description": "Space before opening brace",
        "pattern": "(?<=\\S)\\{",
        "replacement": " {"
      },
      {
        "description": "Property on its own line",
        "pattern": ";(?!\\s*$)",
        "replacement": ";\n"
      },
      {
        "description": "Space after colon in property",
        "pattern": ":(?!\\s)",
        "replacement": ": "
      },
      {
        "description": "No trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      }
    ],
    "indentation": {
      "increasePattern": "\\{\\s*$",
      "decreasePattern": "^\\s*\\}"
    }
  }
}
