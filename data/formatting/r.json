{
  "language": "r",
  "formatting": {
    "defaultTabSize": 2,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\\\s+$",
        "replacement": ""
      },
      {
        "description": "Space around assignment operators",
        "pattern": "(\\\\w)(<-|->|<<-|->>)(\\\\w)",
        "replacement": "$1 $2 $3"
      },
      {
        "description": "Space after comma",
        "pattern": ",(\\\\S)",
        "replacement": ", $1"
      },
      {
        "description": "Normalize line endings",
        "pattern": "\\\\r\\\\n",
        "replacement": "\\n"
      }
    ],
    "indentation": {
      "increasePattern": "\\\\{\\\\s*$|\\\\(\\\\s*$",
      "decreasePattern": "^\\\\s*[\\\\}\\\\)]"
    }
  }
}