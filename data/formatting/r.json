{
  "language": "r",
  "formatting": {
    "defaultTabSize": 2,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      },
      {
        "description": "Space around assignment operators",
        "pattern": "(\\w)(<-|->|<<-|->>)(\\w)",
        "replacement": "$1 $2 $3"
      },
      {
        "description": "Space after comma",
        "pattern": ",(\\S)",
        "replacement": ", $1"
      },
      {
        "description": "Normalize line endings",
        "pattern": "\\r\\n",
        "replacement": "\\n"
      },
      {
        "description": "Normalize line endings to LF",
        "pattern": "\\r\\n",
        "replacement": "\\n"
      },
      {
        "description": "Ensure newline at end of file",
        "pattern": "(?<!\\n)$",
        "replacement": "\\n"
      },
      {
        "description": "Remove consecutive blank lines",
        "pattern": "\\n{3,}",
        "replacement": "\\n\\n"
      }
    ],
    "indentation": {
      "increasePattern": "\\{\\s*$|\\(\\s*$",
      "decreasePattern": "^\\s*[\\}\\)]"
    }
  }
}
