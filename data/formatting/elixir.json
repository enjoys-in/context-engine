{
  "language": "elixir",
  "formatting": {
    "defaultTabSize": 2,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      },
      {
        "description": "Normalize line endings",
        "pattern": "\\r\\n",
        "replacement": "\\n"
      },
      {
        "description": "Indent after do/fn",
        "pattern": "\\b(do|fn)\\s*$",
        "replacement": ""
      },
      {
        "description": "Dedent end",
        "pattern": "^\\s*end\\b",
        "replacement": ""
      },
      {
        "description": "Space after comma",
        "pattern": ",(?!\\s)",
        "replacement": ", "
      },
      {
        "description": "Pipe operator alignment",
        "pattern": "|>",
        "replacement": "$0"
      },
      {
        "description": "No trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      }
    ],
    "indentation": {
      "increasePattern": "[{(\\[]\\s*$",
      "decreasePattern": "^\\s*[})\\]]"
    }
  }
}
