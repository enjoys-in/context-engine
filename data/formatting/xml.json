{
  "language": "xml",
  "formatting": {
    "defaultTabSize": 2,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      },
      {
        "description": "Normalize line endings",
        "pattern": "\\r\\n",
        "replacement": "\\n"
      },
      {
        "description": "Indent nested elements",
        "pattern": "<[^/!][^>]*[^/]>\\s*$",
        "replacement": ""
      },
      {
        "description": "Dedent closing tags",
        "pattern": "^\\s*</",
        "replacement": ""
      },
      {
        "description": "Self-closing tags on one line",
        "pattern": "<\\w+[^>]*/>",
        "replacement": "$0"
      },
      {
        "description": "No trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      },
      {
        "description": "Attribute alignment",
        "pattern": "\\s{2,}(?=\\w+=)",
        "replacement": " "
      },
      {
        "description": "Normalize trailing whitespace",
        "pattern": "\\\\s+$",
        "replacement": ""
      },
      {
        "description": "Ensure single space after comma",
        "pattern": ",([^\\\\s])",
        "replacement": ", $1"
      },
      {
        "description": "Remove trailing semicolons in blank lines",
        "pattern": "^\\\\s*;\\\\s*$",
        "replacement": ""
      },
      {
        "description": "Normalize multiple blank lines to single",
        "pattern": "\\\\n{3,}",
        "replacement": "\\n\\n"
      },
      {
        "description": "Ensure space around assignment operator",
        "pattern": "(\\\\w)=(\\\\w)",
        "replacement": "$1 = $2"
      },
      {
        "description": "Ensure space after opening brace",
        "pattern": "\\\\{([^\\\\s})\\\\n])",
        "replacement": "{ $1"
      },
      {
        "description": "Ensure space before closing brace",
        "pattern": "([^\\\\s{\\\\n])\\\\}",
        "replacement": "$1 }"
      },
      {
        "description": "Remove space before semicolon",
        "pattern": "\\\\s+;",
        "replacement": ";"
      },
      {
        "description": "Normalize space around colon in declarations",
        "pattern": "(\\\\w)\\\\s*:\\\\s*(\\\\w)",
        "replacement": "$1: $2"
      },
      {
        "description": "Ensure newline at end of file",
        "pattern": "([^\\\\n])$",
        "replacement": "$1\\n"
      },
      {
        "description": "Remove space inside parentheses",
        "pattern": "\\\\(\\\\s+",
        "replacement": "("
      },
      {
        "description": "Remove space before closing parenthesis",
        "pattern": "\\\\s+\\\\)",
        "replacement": ")"
      },
      {
        "description": "XML-specific brace alignment",
        "pattern": "\\\\n\\\\s*\\\\{",
        "replacement": " {"
      },
      {
        "description": "Normalize XML statement terminators",
        "pattern": "\\\\s+$",
        "replacement": ""
      }
    ],
    "indentation": {
      "increasePattern": "<[^/!?][^>]*[^/]>\\s*$",
      "decreasePattern": "^\\s*</"
    }
  }
}
