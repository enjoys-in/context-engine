{
  "language": "vb",
  "formatting": {
    "defaultTabSize": 4,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      },
      {
        "description": "Normalize line endings",
        "pattern": "\\r\\n",
        "replacement": "\\n"
      },
      {
        "description": "Capitalize keywords",
        "pattern": "\\b(dim|sub|function|if|then|else|end|for|next|while|do|loop)\\b",
        "replacement": "$1"
      },
      {
        "description": "Normalize line endings to LF",
        "pattern": "\\r\\n",
        "replacement": "\\n"
      },
      {
        "description": "Ensure newline at end of file",
        "pattern": "(?<!\\n)$",
        "replacement": "\\n"
      },
      {
        "description": "Remove consecutive blank lines",
        "pattern": "\\n{3,}",
        "replacement": "\\n\\n"
      },
      {
        "description": "Trim trailing blank lines",
        "pattern": "\\n+$",
        "replacement": "\\n"
      }
    ],
    "indentation": {
      "increasePattern": "\\b(Sub|Function|If|For|While|Select|Class|Module|Namespace)\\b.*$",
      "decreasePattern": "^\\s*(End\\s+\\w+|Next|Wend|Loop)\\b"
    }
  }
}
