{
  "language": "nestjs",
  "formatting": {
    "defaultTabSize": 2,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      },
      {
        "description": "Space after keywords",
        "pattern": "\\b(if|for|while|switch|catch|return)\\(",
        "replacement": "$1 ("
      },
      {
        "description": "Space before opening brace",
        "pattern": "\\)\\{",
        "replacement": ") {"
      },
      {
        "description": "Consistent arrow spacing",
        "pattern": "=>\\{",
        "replacement": "=> {"
      },
      {
        "description": "Space after decorator parenthesis",
        "pattern": "@(\\w+)\\( ",
        "replacement": "@$1("
      },
      {
        "description": "Remove multiple blank lines",
        "pattern": "\\n{3,}",
        "replacement": "\\n\\n"
      },
      {
        "description": "Semicolon enforcement",
        "pattern": "(?<![;{}*/])\\s*$",
        "replacement": ";"
      },
      {
        "description": "Trailing comma in multiline objects",
        "pattern": "(\\S)\\n(\\s*[}\\]])",
        "replacement": "$1,\\n$2"
      },
      {
        "description": "Normalize line endings",
        "pattern": "\\r\\n",
        "replacement": "\\n"
      },
      {
        "description": "Consistent inject spacing",
        "pattern": "private\\s+readonly\\s+",
        "replacement": "private readonly "
      },
      {
        "description": "Normalize NestJS decorator spacing",
        "pattern": "@(Controller|Injectable|Module|Guard|Pipe)\\(",
        "replacement": "@$1("
      },
      {
        "description": "Ensure DI parameter formatting",
        "pattern": "(private|protected|readonly)\\s+(\\w+):\\s*(\\w+)",
        "replacement": "$1 $2: $3"
      },
      {
        "description": "Normalize route path strings",
        "pattern": "@(Get|Post|Put|Delete|Patch)\\('([^']+)'\\)",
        "replacement": "@$1('$2')"
      },
      {
        "description": "Space after middleware decorator",
        "pattern": "@UseGuards\\(",
        "replacement": "@UseGuards("
      },
      {
        "description": "Consistent DTO property spacing",
        "pattern": "@(IsString|IsNumber|IsOptional)\\(\\)",
        "replacement": "@$1()"
      }
    ],
    "indentation": {
      "increasePattern": "(?:\\{[^}]*$|\\([^)]*$|=>\\s*$|@Module\\(\\{|@Controller\\(|class\\s+\\w+[^{]*\\{)",
      "decreasePattern": "^\\s*[}\\)\\]]|^\\s*\\)\\s*;?\\s*$"
    }
  }
}
