{
  "language": "hcl",
  "formatting": {
    "defaultTabSize": 2,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      },
      {
        "description": "Normalize line endings",
        "pattern": "\\r\\n",
        "replacement": "\\n"
      },
      {
        "description": "Indent after opening brace",
        "pattern": "\\{\\s*$",
        "replacement": ""
      },
      {
        "description": "Dedent closing brace",
        "pattern": "^\\s*\\}",
        "replacement": ""
      },
      {
        "description": "Space around assignment",
        "pattern": "(?<=\\w)=(?=\\S)",
        "replacement": " = "
      },
      {
        "description": "Align equals signs",
        "pattern": "\\s+=\\s+",
        "replacement": "$0"
      },
      {
        "description": "No trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      }
    ],
    "indentation": {
      "increasePattern": "\\{\\s*$",
      "decreasePattern": "^\\s*\\}"
    }
  }
}
