{
  "language": "sql",
  "formatting": {
    "defaultTabSize": 2,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      },
      {
        "description": "Ensure single space after keywords",
        "pattern": "\\b(SELECT|FROM|WHERE|JOIN|GROUP|ORDER|HAVING|LIMIT|INSERT|UPDATE|DELETE|CREATE|ALTER|DROP)\\(",
        "replacement": "$1 ("
      },
      {
        "description": "Normalize line endings",
        "pattern": "\\r\\n",
        "replacement": "\\n"
      },
      {
        "description": "Normalize line endings to LF",
        "pattern": "\\r\\n",
        "replacement": "\\n"
      },
      {
        "description": "Ensure newline at end of file",
        "pattern": "(?<!\\n)$",
        "replacement": "\\n"
      },
      {
        "description": "Remove consecutive blank lines",
        "pattern": "\\n{3,}",
        "replacement": "\\n\\n"
      },
      {
        "description": "Trim trailing blank lines",
        "pattern": "\\n+$",
        "replacement": "\\n"
      },
      {
        "description": "Normalize trailing whitespace",
        "pattern": "\\\\s+$",
        "replacement": ""
      },
      {
        "description": "Ensure single space after comma",
        "pattern": ",([^\\\\s])",
        "replacement": ", $1"
      },
      {
        "description": "Remove trailing semicolons in blank lines",
        "pattern": "^\\\\s*;\\\\s*$",
        "replacement": ""
      },
      {
        "description": "Normalize multiple blank lines to single",
        "pattern": "\\\\n{3,}",
        "replacement": "\\n\\n"
      },
      {
        "description": "Ensure space around assignment operator",
        "pattern": "(\\\\w)=(\\\\w)",
        "replacement": "$1 = $2"
      },
      {
        "description": "Ensure space after opening brace",
        "pattern": "\\\\{([^\\\\s})\\\\n])",
        "replacement": "{ $1"
      },
      {
        "description": "Ensure space before closing brace",
        "pattern": "([^\\\\s{\\\\n])\\\\}",
        "replacement": "$1 }"
      },
      {
        "description": "Remove space before semicolon",
        "pattern": "\\\\s+;",
        "replacement": ";"
      },
      {
        "description": "Normalize space around colon in declarations",
        "pattern": "(\\\\w)\\\\s*:\\\\s*(\\\\w)",
        "replacement": "$1: $2"
      },
      {
        "description": "Remove space inside parentheses",
        "pattern": "\\\\(\\\\s+",
        "replacement": "("
      },
      {
        "description": "Remove space before closing parenthesis",
        "pattern": "\\\\s+\\\\)",
        "replacement": ")"
      },
      {
        "description": "Uppercase SQL keywords",
        "pattern": "\\\\b(select|from|where|insert|update|delete|join|order|group|having)\\\\b",
        "replacement": "UPPER"
      },
      {
        "description": "Newline before major clauses",
        "pattern": "\\\\s+(FROM|WHERE|JOIN|ORDER|GROUP|HAVING)",
        "replacement": "\\n$1"
      }
    ],
    "indentation": {
      "increasePattern": "\\b(?:BEGIN|THEN|LOOP|AS)\\s*$",
      "decreasePattern": "^\\s*(?:END|ELSE|ELSIF|WHEN)\\b"
    }
  }
}
