{
  "language": "abap",
  "formatting": {
    "defaultTabSize": 2,
    "defaultInsertSpaces": true,
    "rules": [
      { "description": "Remove trailing whitespace", "pattern": "\\s+$", "replacement": "" },
      { "description": "Normalize line endings", "pattern": "\\r\\n", "replacement": "\\n" }
    ]
  }
}
