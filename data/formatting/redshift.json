{
  "language": "redshift",
  "formatting": {
    "defaultTabSize": 4,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      },
      {
        "description": "Normalize line endings",
        "pattern": "\\r\\n",
        "replacement": "\\n"
      },
      {
        "description": "Uppercase keywords",
        "pattern": "\\b(select|from|where|join|on|group by|order by|having|insert|update|delete|create|alter|drop)\\b",
        "replacement": "$1_UPPER"
      },
      {
        "description": "Newline before major clauses",
        "pattern": "\\s+(FROM|WHERE|JOIN|GROUP BY|ORDER BY|HAVING)",
        "replacement": "\n$1"
      },
      {
        "description": "Indent subqueries",
        "pattern": "\\(\\s*SELECT",
        "action": "indent"
      },
      {
        "description": "Comma at end of line in SELECT",
        "pattern": ",\\s*(?=\\w)",
        "replacement": ",\n  "
      },
      {
        "description": "No trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      }
    ],
    "indentation": {
      "increasePattern": "[{(\\[]\\s*$",
      "decreasePattern": "^\\s*[})\\]]"
    }
  }
}
