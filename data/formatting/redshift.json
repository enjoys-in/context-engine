{
  "language": "redshift",
  "formatting": {
    "defaultTabSize": 4,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      },
      {
        "description": "Normalize line endings",
        "pattern": "\\r\\n",
        "replacement": "\\n"
      },
      {
        "description": "Uppercase keywords",
        "pattern": "\\b(select|from|where|join|on|group by|order by|having|insert|update|delete|create|alter|drop)\\b",
        "replacement": "$1_UPPER"
      },
      {
        "description": "Newline before major clauses",
        "pattern": "\\s+(FROM|WHERE|JOIN|GROUP BY|ORDER BY|HAVING)",
        "replacement": "\n$1"
      },
      {
        "description": "Indent subqueries",
        "pattern": "\\(\\s*SELECT",
        "replacement": ""
      },
      {
        "description": "Comma at end of line in SELECT",
        "pattern": ",\\s*(?=\\w)",
        "replacement": ",\n  "
      },
      {
        "description": "No trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      },
      {
        "description": "Normalize trailing whitespace",
        "pattern": "\\\\s+$",
        "replacement": ""
      },
      {
        "description": "Ensure single space after comma",
        "pattern": ",([^\\\\s])",
        "replacement": ", $1"
      },
      {
        "description": "Remove trailing semicolons in blank lines",
        "pattern": "^\\\\s*;\\\\s*$",
        "replacement": ""
      },
      {
        "description": "Normalize multiple blank lines to single",
        "pattern": "\\\\n{3,}",
        "replacement": "\\n\\n"
      },
      {
        "description": "Ensure space around assignment operator",
        "pattern": "(\\\\w)=(\\\\w)",
        "replacement": "$1 = $2"
      },
      {
        "description": "Ensure space after opening brace",
        "pattern": "\\\\{([^\\\\s})\\\\n])",
        "replacement": "{ $1"
      },
      {
        "description": "Ensure space before closing brace",
        "pattern": "([^\\\\s{\\\\n])\\\\}",
        "replacement": "$1 }"
      },
      {
        "description": "Remove space before semicolon",
        "pattern": "\\\\s+;",
        "replacement": ";"
      },
      {
        "description": "Normalize space around colon in declarations",
        "pattern": "(\\\\w)\\\\s*:\\\\s*(\\\\w)",
        "replacement": "$1: $2"
      },
      {
        "description": "Ensure newline at end of file",
        "pattern": "([^\\\\n])$",
        "replacement": "$1\\n"
      },
      {
        "description": "Remove space inside parentheses",
        "pattern": "\\\\(\\\\s+",
        "replacement": "("
      },
      {
        "description": "Remove space before closing parenthesis",
        "pattern": "\\\\s+\\\\)",
        "replacement": ")"
      },
      {
        "description": "Redshift SQL-specific brace alignment",
        "pattern": "\\\\n\\\\s*\\\\{",
        "replacement": " {"
      },
      {
        "description": "Normalize Redshift SQL statement terminators",
        "pattern": "\\\\s+$",
        "replacement": ""
      }
    ],
    "indentation": {
      "increasePattern": "[{(\\[]\\s*$",
      "decreasePattern": "^\\s*[})\\]]"
    }
  }
}
