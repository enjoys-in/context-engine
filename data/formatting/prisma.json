{
  "language": "prisma",
  "formatting": {
    "defaultTabSize": 2,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      },
      {
        "description": "Normalize line endings",
        "pattern": "\\r\\n",
        "replacement": "\n"
      },
      {
        "description": "Ensure single blank line between blocks",
        "pattern": "\\}\\n{3,}(model|enum|datasource|generator|type|view)",
        "replacement": "}\n\n$1"
      },
      {
        "description": "Align field types (Prisma format convention)",
        "pattern": "(\\w+)(\\s+)(String|Int|BigInt|Float|Decimal|Boolean|DateTime|Json|Bytes|\\w+)",
        "replacement": "$1 $3"
      }
    ],
    "indentation": {
      "increasePattern": "\\{\\s*$",
      "decreasePattern": "^\\s*\\}"
    }
  }
}