{
  "language": "mips",
  "formatting": {
    "defaultTabSize": 8,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      },
      {
        "description": "Normalize line endings",
        "pattern": "\\r\\n",
        "replacement": "\\n"
      },
      {
        "description": "Align operands",
        "pattern": "\\t(\\$\\w+),(\\$\\w+)",
        "replacement": "\t$1, $2"
      },
      {
        "description": "Normalize line endings to LF",
        "pattern": "\\r\\n",
        "replacement": "\\n"
      },
      {
        "description": "Ensure newline at end of file",
        "pattern": "(?<!\\n)$",
        "replacement": "\\n"
      },
      {
        "description": "Remove consecutive blank lines",
        "pattern": "\\n{3,}",
        "replacement": "\\n\\n"
      },
      {
        "description": "Trim trailing blank lines",
        "pattern": "\\n+$",
        "replacement": "\\n"
      }
    ],
    "indentation": {
      "increasePattern": "\\w+:",
      "decreasePattern": "^\\s*\\}"
    }
  }
}
