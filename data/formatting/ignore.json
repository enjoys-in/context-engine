{
  "language": "ignore",
  "formatting": {
    "defaultTabSize": 0,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      },
      {
        "description": "Remove multiple consecutive blank lines",
        "pattern": "\\n{3,}",
        "replacement": "\n\n"
      },
      {
        "description": "Ensure newline at end of file",
        "pattern": "([^\\n])$",
        "replacement": "$1\n"
      },
      {
        "description": "Remove leading whitespace from patterns",
        "pattern": "^[ \\t]+([^#\\s])",
        "replacement": "$1"
      },
      {
        "description": "Normalize trailing whitespace",
        "pattern": "\\\\s+$",
        "replacement": ""
      },
      {
        "description": "Ensure single space after comma",
        "pattern": ",([^\\\\s])",
        "replacement": ", $1"
      },
      {
        "description": "Remove trailing semicolons in blank lines",
        "pattern": "^\\\\s*;\\\\s*$",
        "replacement": ""
      },
      {
        "description": "Normalize multiple blank lines to single",
        "pattern": "\\\\n{3,}",
        "replacement": "\\n\\n"
      },
      {
        "description": "Ensure space around assignment operator",
        "pattern": "(\\\\w)=(\\\\w)",
        "replacement": "$1 = $2"
      },
      {
        "description": "Ensure space after opening brace",
        "pattern": "\\\\{([^\\\\s})\\\\n])",
        "replacement": "{ $1"
      },
      {
        "description": "Ensure space before closing brace",
        "pattern": "([^\\\\s{\\\\n])\\\\}",
        "replacement": "$1 }"
      },
      {
        "description": "Remove space before semicolon",
        "pattern": "\\\\s+;",
        "replacement": ";"
      },
      {
        "description": "Normalize space around colon in declarations",
        "pattern": "(\\\\w)\\\\s*:\\\\s*(\\\\w)",
        "replacement": "$1: $2"
      },
      {
        "description": "Remove space inside parentheses",
        "pattern": "\\\\(\\\\s+",
        "replacement": "("
      },
      {
        "description": "Remove space before closing parenthesis",
        "pattern": "\\\\s+\\\\)",
        "replacement": ")"
      },
      {
        "description": "Ignore Files-specific brace alignment",
        "pattern": "\\\\n\\\\s*\\\\{",
        "replacement": " {"
      },
      {
        "description": "Normalize Ignore Files statement terminators",
        "pattern": "\\\\s+$",
        "replacement": ""
      }
    ],
    "indentation": {
      "increasePattern": "",
      "decreasePattern": ""
    }
  }
}
