{
  "language": "ignore",
  "formatting": {
    "defaultTabSize": 0,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      },
      {
        "description": "Remove multiple consecutive blank lines",
        "pattern": "\\n{3,}",
        "replacement": "\n\n"
      },
      {
        "description": "Ensure newline at end of file",
        "pattern": "([^\\n])$",
        "replacement": "$1\n"
      },
      {
        "description": "Remove leading whitespace from patterns",
        "pattern": "^[ \\t]+([^#\\s])",
        "replacement": "$1"
      }
    ],
    "indentation": {
      "increasePattern": "",
      "decreasePattern": ""
    }
  }
}