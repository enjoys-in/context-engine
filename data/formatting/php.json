{
  "language": "php",
  "formatting": {
    "defaultTabSize": 4,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\\\s+$",
        "replacement": ""
      },
      {
        "description": "Ensure single space after keywords",
        "pattern": "\\\\b(if|else|elseif|for|foreach|while|switch|catch|match)\\\\(",
        "replacement": "$1 ("
      },
      {
        "description": "Normalize line endings",
        "pattern": "\\\\r\\\\n",
        "replacement": "\\n"
      }
    ],
    "indentation": {
      "increasePattern": "\\\\{\\\\s*$",
      "decreasePattern": "^\\\\s*\\\\}"
    }
  }
}
