{
  "language": "swift",
  "formatting": {
    "defaultTabSize": 4,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      },
      {
        "description": "Space after control flow keywords",
        "pattern": "\\b(if|for|while|switch|guard|catch)\\(",
        "replacement": "$1 ("
      },
      {
        "description": "Normalize line endings",
        "pattern": "\\r\\n",
        "replacement": "\\n"
      },
      {
        "description": "Space before opening brace",
        "pattern": "(\\S)\\{",
        "replacement": "$1 {"
      },
      {
        "description": "No space before colon in type annotation",
        "pattern": "(\\w)\\s+:",
        "replacement": "$1:"
      },
      {
        "description": "Space after colon in type annotation",
        "pattern": ":(\\S)",
        "replacement": ": $1"
      },
      {
        "description": "Space around arrow operator",
        "pattern": "(\\S)->",
        "replacement": "$1 ->"
      },
      {
        "description": "Space after arrow operator",
        "pattern": "->(\\S)",
        "replacement": "-> $1"
      },
      {
        "description": "No space before comma",
        "pattern": "\\s+,",
        "replacement": ","
      },
      {
        "description": "Space after comma",
        "pattern": ",(\\S)",
        "replacement": ", $1"
      },
      {
        "description": "Normalize Swift guard statement",
        "pattern": "guard\\s+let\\s+",
        "replacement": "guard let "
      },
      {
        "description": "Normalize optional chaining",
        "pattern": "(\\w+)\\?\\.(\\w+)",
        "replacement": "$1?.$2"
      },
      {
        "description": "Swift trailing closure brace on new line",
        "pattern": "\\)\\s*\\{",
        "replacement": ") {"
      },
      {
        "description": "Normalize Swift enum case",
        "pattern": "case\\s+(\\w+)",
        "replacement": "case $1"
      },
      {
        "description": "Ensure space in Swift range operator",
        "pattern": "(\\w+)\\.\\.\\.(\\w+)",
        "replacement": "$1...$2"
      }
    ],
    "indentation": {
      "increasePattern": "\\{\\s*$",
      "decreasePattern": "^\\s*\\}"
    }
  }
}
