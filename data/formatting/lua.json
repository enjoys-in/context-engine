{
  "language": "lua",
  "formatting": {
    "defaultTabSize": 2,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\\\s+$",
        "replacement": ""
      },
      {
        "description": "Ensure single space after keywords",
        "pattern": "\\\\b(if|for|while|repeat)\\\\(",
        "replacement": "$1 ("
      },
      {
        "description": "Normalize line endings",
        "pattern": "\\\\r\\\\n",
        "replacement": "\\n"
      }
    ],
    "indentation": {
      "increasePattern": "(?:then|do|else|function\\\\s*\\\\(.*\\\\))\\\\s*$",
      "decreasePattern": "^\\\\s*(?:end|else|elseif|until)\\\\b"
    }
  }
}