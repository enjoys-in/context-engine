{
  "language": "docker-compose",
  "formatting": {
    "defaultTabSize": 2,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      },
      {
        "description": "Normalize line endings",
        "pattern": "\\r\\n",
        "replacement": "\\n"
      },
      {
        "description": "Ensure consistent 2-space indentation",
        "pattern": "\\t",
        "replacement": "  "
      }
    ]
  }
}
