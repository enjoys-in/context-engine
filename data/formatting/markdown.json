{
  "language": "markdown",
  "formatting": {
    "defaultTabSize": 2,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\\\s+$",
        "replacement": ""
      },
      {
        "description": "Normalize line endings",
        "pattern": "\\\\r\\\\n",
        "replacement": "\\n"
      },
      {
        "description": "Blank line before headings",
        "pattern": "(?<=\\S\\n)(?=#)",
        "action": "ensureBlankLine"
      },
      {
        "description": "Space after hash in heading",
        "pattern": "^(#{1,6})(?!\\s)",
        "replacement": "$1 "
      },
      {
        "description": "No trailing whitespace except double-space line break",
        "pattern": "(?<!  )\\s+$",
        "replacement": ""
      },
      {
        "description": "Blank line before and after code blocks",
        "pattern": "(?<=\\S\\n)(?=```)",
        "action": "ensureBlankLine"
      },
      {
        "description": "Consistent list marker",
        "pattern": "^(\\s*)[-*+] ",
        "replacement": "$1- "
      }
    ]
  }
}