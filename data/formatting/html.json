{
  "language": "html",
  "formatting": {
    "defaultTabSize": 2,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\\\s+$",
        "replacement": ""
      },
      {
        "description": "Normalize line endings",
        "pattern": "\\\\r\\\\n",
        "replacement": "\\n"
      },
      {
        "description": "Indent nested elements",
        "pattern": "<[^/!][^>]*[^/]>\\s*$",
        "action": "indent"
      },
      {
        "description": "Dedent closing tags",
        "pattern": "^\\s*</",
        "action": "dedent"
      },
      {
        "description": "Self-closing tags on one line",
        "pattern": "<\\w+[^>]*/>",
        "action": "nothing"
      },
      {
        "description": "No trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      },
      {
        "description": "Attribute alignment",
        "pattern": "\\s{2,}(?=\\w+=)",
        "replacement": " "
      }
    ],
    "indentation": {
      "increasePattern": "<[^/][^>]*[^/]>\\\\s*$",
      "decreasePattern": "^\\\\s*</"
    }
  }
}