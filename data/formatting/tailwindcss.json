{
  "language": "tailwindcss",
  "formatting": {
    "defaultTabSize": 2,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Sort utility classes in @apply rules following recommended order (layout, spacing, sizing, typography, backgrounds, borders, effects, transitions)",
        "pattern": "@apply\\s+([\\w\\s:/-]+);",
        "replacement": "@apply ${sorted_classes};"
      },
      {
        "description": "Normalize spacing in @apply directives to single spaces between classes",
        "pattern": "@apply\\s{2,}|@apply\\s+([\\w:-]+)\\s{2,}",
        "replacement": "@apply ${1} "
      },
      {
        "description": "Ensure @tailwind directives are ordered: base, components, utilities",
        "pattern": "@tailwind\\s+(utilities|components|base)\\s*;",
        "replacement": "@tailwind ${ordered_layer};"
      },
      {
        "description": "Add blank line between @layer blocks for readability",
        "pattern": "(\\})(\\s*)(@layer)",
        "replacement": "${1}\n\n${3}"
      },
      {
        "description": "Normalize @layer block formatting with consistent indentation",
        "pattern": "@layer\\s+(\\w+)\\s*\\{\\s*",
        "replacement": "@layer ${1} {\n  "
      },
      {
        "description": "Ensure semicolons after @apply and @tailwind directives",
        "pattern": "(@apply\\s+[\\w\\s:/-]+)\\s*$",
        "replacement": "${1};"
      },
      {
        "description": "Format @config directive with consistent quoting",
        "pattern": "@config\\s+\"([^\"]+)\"\\s*;",
        "replacement": "@config '${1}';"
      },
      {
        "description": "Normalize trailing whitespace",
        "pattern": "\\\\s+$",
        "replacement": ""
      },
      {
        "description": "Ensure single space after comma",
        "pattern": ",([^\\\\s])",
        "replacement": ", $1"
      },
      {
        "description": "Remove trailing semicolons in blank lines",
        "pattern": "^\\\\s*;\\\\s*$",
        "replacement": ""
      },
      {
        "description": "Normalize multiple blank lines to single",
        "pattern": "\\\\n{3,}",
        "replacement": "\\n\\n"
      },
      {
        "description": "Ensure space around assignment operator",
        "pattern": "(\\\\w)=(\\\\w)",
        "replacement": "$1 = $2"
      },
      {
        "description": "Ensure space after opening brace",
        "pattern": "\\\\{([^\\\\s})\\\\n])",
        "replacement": "{ $1"
      },
      {
        "description": "Ensure space before closing brace",
        "pattern": "([^\\\\s{\\\\n])\\\\}",
        "replacement": "$1 }"
      },
      {
        "description": "Remove space before semicolon",
        "pattern": "\\\\s+;",
        "replacement": ";"
      },
      {
        "description": "Normalize space around colon in declarations",
        "pattern": "(\\\\w)\\\\s*:\\\\s*(\\\\w)",
        "replacement": "$1: $2"
      },
      {
        "description": "Ensure newline at end of file",
        "pattern": "([^\\\\n])$",
        "replacement": "$1\\n"
      },
      {
        "description": "Remove space inside parentheses",
        "pattern": "\\\\(\\\\s+",
        "replacement": "("
      },
      {
        "description": "Remove space before closing parenthesis",
        "pattern": "\\\\s+\\\\)",
        "replacement": ")"
      },
      {
        "description": "Tailwind CSS-specific brace alignment",
        "pattern": "\\\\n\\\\s*\\\\{",
        "replacement": " {"
      },
      {
        "description": "Normalize Tailwind CSS statement terminators",
        "pattern": "\\\\s+$",
        "replacement": ""
      }
    ],
    "indentation": {
      "increasePattern": "\\{\\s*$|@layer\\s+\\w+\\s*\\{",
      "decreasePattern": "^\\s*\\}"
    }
  }
}
