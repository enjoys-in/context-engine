{
  "language": "scala",
  "formatting": {
    "defaultTabSize": 2,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      },
      {
        "description": "Space after control flow keywords",
        "pattern": "\\b(if|for|while|match|catch)\\(",
        "replacement": "$1 ("
      },
      {
        "description": "Normalize line endings",
        "pattern": "\\r\\n",
        "replacement": "\\n"
      },
      {
        "description": "Space before opening brace",
        "pattern": "(\\S)\\{",
        "replacement": "$1 {"
      },
      {
        "description": "Space around arrow operators",
        "pattern": "(\\S)=>(\\S)",
        "replacement": "$1 => $2"
      },
      {
        "description": "Space around generator arrow",
        "pattern": "(\\S)<-(\\S)",
        "replacement": "$1 <- $2"
      },
      {
        "description": "No space before colon in type annotation",
        "pattern": "\\s+:",
        "replacement": ":"
      },
      {
        "description": "Space after colon in type annotation",
        "pattern": ":\\s*(?=[A-Z])",
        "replacement": ": "
      }
    ],
    "indentation": {
      "increasePattern": "\\{\\s*$",
      "decreasePattern": "^\\s*\\}"
    }
  }
}
