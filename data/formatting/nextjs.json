{
  "language": "nextjs",
  "formatting": {
    "defaultTabSize": 2,
    "defaultInsertSpaces": true,
    "rules": [
      {
        "description": "Remove trailing whitespace",
        "pattern": "\\s+$",
        "replacement": ""
      },
      {
        "description": "Space after keywords",
        "pattern": "\\b(if|for|while|switch|catch|return)\\(",
        "replacement": "$1 ("
      },
      {
        "description": "Space before opening brace",
        "pattern": "\\)\\{",
        "replacement": ") {"
      },
      {
        "description": "Consistent arrow function spacing",
        "pattern": "=>\\{",
        "replacement": "=> {"
      },
      {
        "description": "Space after commas in JSX props",
        "pattern": "(\\w)=\\{",
        "replacement": "$1={"
      },
      {
        "description": "Remove multiple blank lines",
        "pattern": "\\n{3,}",
        "replacement": "\\n\\n"
      },
      {
        "description": "Normalize imports",
        "pattern": "import\\s+\\{\\s*(\\S+)\\s*\\}",
        "replacement": "import { $1 }"
      },
      {
        "description": "Semicolon enforcement",
        "pattern": "(?<!;|\\{|\\}|\\*\\/)\\s*$",
        "replacement": ";"
      },
      {
        "description": "JSX self-closing space",
        "pattern": "(\\w)\\/>",
        "replacement": "$1 />"
      },
      {
        "description": "Normalize line endings",
        "pattern": "\\r\\n",
        "replacement": "\\n"
      },
      {
        "description": "Normalize Next.js page export",
        "pattern": "export\\s+default\\s+function\\s+",
        "replacement": "export default function "
      },
      {
        "description": "Normalize getServerSideProps export",
        "pattern": "export\\s+async\\s+function\\s+getServerSideProps",
        "replacement": "export async function getServerSideProps"
      },
      {
        "description": "Normalize dynamic import",
        "pattern": "dynamic\\(\\s*\\(\\)\\s*=>\\s*import\\('",
        "replacement": "dynamic(() => import('"
      },
      {
        "description": "Normalize Next.js Image component",
        "pattern": "<Image\\s+",
        "replacement": "<Image "
      },
      {
        "description": "API route handler spacing",
        "pattern": "export\\s+async\\s+function\\s+(GET|POST|PUT|DELETE|PATCH)",
        "replacement": "export async function $1"
      }
    ],
    "indentation": {
      "increasePattern": "(?:\\{[^}]*$|\\([^)]*$|<[^/][^>]*[^/]>\\s*$|=>\\s*$)",
      "decreasePattern": "^\\s*[}\\)\\]]|^\\s*<\\/|^\\s*\\/>|^\\s*\\)\\s*;?\\s*$"
    }
  }
}
