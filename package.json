{
  "name": "@enjoys/context-engine",
  "version": "1.5.1",
  "description": "Comprehensive CLI command context engine with 135 tools — subcommands, options, examples, and runtime context detectors for intelligent terminal autocomplete",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "require": "./index.js",
      "import": "./index.mjs",
      "types": "./index.d.ts"
    },
    "./commands": "./data/commands",
    "./commands/*": "./data/commands/*",
    "./completion/*": "./data/completion/*",
    "./definition/*": "./data/definition/*",
    "./defination/*": "./data/definition/*",
    "./hover/*": "./data/hover/*",
    "./codeActions/*": "./data/codeActions/*",
    "./codeLens/*": "./data/codeLens/*",
    "./color/*": "./data/color/*",
    "./declaration/*": "./data/declaration/*",
    "./documentHighlight/*": "./data/documentHighlight/*",
    "./documentSymbol/*": "./data/documentSymbol/*",
    "./formatting/*": "./data/formatting/*",
    "./implementation/*": "./data/implementation/*",
    "./inlayHints/*": "./data/inlayHints/*",
    "./inlineCompletions/*": "./data/inlineCompletions/*",
    "./links/*": "./data/links/*",
    "./references/*": "./data/references/*",
    "./typeDefinition/*": "./data/typeDefinition/*",
    "./signatureHelp/*": "./data/signatureHelp/*",
    "./foldingRange/*": "./data/foldingRange/*",
    "./rename/*": "./data/rename/*",
    "./selectionRange/*": "./data/selectionRange/*",
    "./linkedEditingRange/*": "./data/linkedEditingRange/*",
    "./onTypeFormatting/*": "./data/onTypeFormatting/*",
    "./documentRangeFormatting/*": "./data/documentRangeFormatting/*",
    "./semanticTokens/*": "./data/semanticTokens/*",
    "./rangeSemanticTokens/*": "./data/rangeSemanticTokens/*",
    "./data/*": "./data/*"
  },
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts",
    "data/"
  ],
  "scripts": {
    "test": "node test.js",
    "prepublishOnly": "node -e \"require('./index.js')\""
  },
  "keywords": [
    "cli",
    "terminal",
    "autocomplete",
    "context-engine",
    "command-palette",
    "shell",
    "bash",
    "zsh",
    "devtools",
    "docker",
    "git",
    "kubectl",
    "terraform",
    "aws",
    "npm",
    "node",
    "python",
    "go",
    "rust",
    "completions",
    "subcommands",
    "options",
    "webterminal"
  ],
  "author": "Enjoys Inc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enjoys-in/context-engine.git"
  },
  "homepage": "https://github.com/enjoys-in/context-engine#readme",
  "bugs": {
    "url": "https://github.com/enjoys-in/context-engine/issues"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
