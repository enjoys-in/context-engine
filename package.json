{
  "name": "@enjoys/context-engine",
  "version": "1.0.9",
  "description": "Comprehensive CLI command context engine with 135 tools — subcommands, options, examples, and runtime context detectors for intelligent terminal autocomplete",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "require": "./index.js",
      "import": "./index.mjs",
      "types": "./index.d.ts"
    },
    "./commands": "./data/commands",
    "./commands/*": "./data/commands/*",
    "./completion/*": "./data/completion/*",
    "./defination/*": "./data/defination/*",
    "./hover/*": "./data/hover/*",
    "./data/*": "./data/*"
  },
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts",
    "data/"
  ],
  "scripts": {
    "test": "node test.js",
    "prepublishOnly": "node -e \"require('./index.js')\""
  },
  "keywords": [
    "cli",
    "terminal",
    "autocomplete",
    "context-engine",
    "command-palette",
    "shell",
    "bash",
    "zsh",
    "devtools",
    "docker",
    "git",
    "kubectl",
    "terraform",
    "aws",
    "npm",
    "node",
    "python",
    "go",
    "rust",
    "completions",
    "subcommands",
    "options",
    "webterminal"
  ],
  "author": "Enjoys Inc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enjoys-in/context-engine.git"
  },
  "homepage": "https://github.com/enjoys-in/context-engine#readme",
  "bugs": {
    "url": "https://github.com/enjoys-in/context-engine/issues"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
