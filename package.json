{
  "name": "@enjoys/context-engine",
  "version": "1.17.1",
  "description": "Monaco Editor language intelligence engine — 96 languages, 29 providers, 119 themes, 466 CLI command files (448 unique). Completions, hover, definitions, code actions, formatting, symbols, monarch tokenizers, multi-document highlights, AI rename suggestions, themes, and more as pre-built JSON data with zero backend",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.js"
    },
    "./commands": "./data/commands",
    "./commands/*": "./data/commands/*",
    "./completion/*": "./data/completion/*",
    "./definition/*": "./data/definition/*",
    "./defination/*": "./data/definition/*",
    "./hover/*": "./data/hover/*",
    "./codeActions/*": "./data/codeActions/*",
    "./codeLens/*": "./data/codeLens/*",
    "./color/*": "./data/color/*",
    "./declaration/*": "./data/declaration/*",
    "./documentHighlight/*": "./data/documentHighlight/*",
    "./documentSymbol/*": "./data/documentSymbol/*",
    "./formatting/*": "./data/formatting/*",
    "./implementation/*": "./data/implementation/*",
    "./inlayHints/*": "./data/inlayHints/*",
    "./inlineCompletions/*": "./data/inlineCompletions/*",
    "./links/*": "./data/links/*",
    "./references/*": "./data/references/*",
    "./typeDefinition/*": "./data/typeDefinition/*",
    "./signatureHelp/*": "./data/signatureHelp/*",
    "./foldingRange/*": "./data/foldingRange/*",
    "./rename/*": "./data/rename/*",
    "./selectionRange/*": "./data/selectionRange/*",
    "./linkedEditingRange/*": "./data/linkedEditingRange/*",
    "./onTypeFormatting/*": "./data/onTypeFormatting/*",
    "./documentRangeFormatting/*": "./data/documentRangeFormatting/*",
    "./semanticTokens/*": "./data/semanticTokens/*",
    "./rangeSemanticTokens/*": "./data/rangeSemanticTokens/*",
    "./monarchTokens/*": "./data/monarchTokens/*",
    "./newSymbolNames/*": "./data/newSymbolNames/*",
    "./multiDocumentHighlight/*": "./data/multiDocumentHighlight/*",
    "./themes/*": "./data/themes/*",
    "./data/*": "./data/*"
  },
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts",
    "data/"
  ],
  "scripts": {
    "build": "node build.mjs",
    "test": "node test.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "cli",
    "terminal",
    "autocomplete",
    "context-engine",
    "command-palette",
    "shell",
    "bash",
    "zsh",
    "devtools",
    "docker",
    "git",
    "kubectl",
    "terraform",
    "aws",
    "npm",
    "node",
    "python",
    "go",
    "rust",
    "completions",
    "subcommands",
    "options",
    "webterminal"
  ],
  "author": "Enjoys Inc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enjoys-in/context-engine.git"
  },
  "homepage": "https://github.com/enjoys-in/context-engine#readme",
  "bugs": {
    "url": "https://github.com/enjoys-in/context-engine/issues"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "typescript": "^6.0.2"
  }
}
